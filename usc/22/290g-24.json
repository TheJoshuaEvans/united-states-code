{"tag":"section","attrib":{"id":"id8ee09de9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–24"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–24"},"text":"§ 290g–24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fourteenth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ee09dea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–24/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Fund is authorized to contribute on behalf of the United States $513,900,000 to the fourteenth replenishment of the resources of the Fund, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee09deb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–24/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $513,900,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee09dec-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s225"},"text":"Pub. L. 94–302, title II, § 225","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dK/tVII/s7083/c"},"text":"Pub. L. 115–141, div. K, title VII, § 7083(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/966"},"text":"132 Stat. 966","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
