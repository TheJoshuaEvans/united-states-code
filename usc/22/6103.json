{"tag":"section","attrib":{"id":"id90acab32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6103"},"text":null,"children":[{"tag":"num","attrib":{"value":"6103"},"text":"§ 6103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separation of Government personnel during fellowships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90acab33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under such terms and conditions as the agency head may direct, any agency of the United States Government may separate from Government service for a specified period any officer or employee of that agency who accepts a fellowship under the program established by this chapter and is not detailed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6104"},"text":"section 6104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90acab34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reemployment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any fellow who is not a detailee, at the end of the fellowship, is entitled to be reemployed in the same manner as if covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3582"},"text":"section 3582 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90acab35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 8347(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), 8713, or 8914 of title 5 and in accordance with regulations of the Office of Personnel Management, an employee, while serving as a fellow who is not a detailee, is entitled to the same rights and benefits as if covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3582"},"text":"section 3582 of title 5","children":[],"tail":". The Center shall reimburse the employing agency for any costs incurred under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3582"},"text":"section 3582 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90acab36-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with Budget Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds are available under this section to the extent and in the amounts provided in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90acab37-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tII/s254"},"text":"Pub. L. 103–236, title II, § 254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/430"},"text":"108 Stat. 430","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
