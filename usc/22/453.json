{"tag":"section","attrib":{"id":"id8eec84fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s453"},"text":null,"children":[{"tag":"num","attrib":{"value":"453"},"text":"§ 453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may, from time to time, promulgate such rules and regulations, not inconsistent with law, as may be necessary and proper to carry out any of the provisions of this subchapter; and he may exercise any power or authority conferred on him by this subchapter through such officer or officers, or agency or agencies, as he shall direct.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eec84fe-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-11-04/ch2/s13"},"text":"Nov. 4, 1939, ch. 2, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/11"},"text":"54 Stat. 11","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eec84ff-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8eec8500-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8eec8501-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delegation of Powers","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Power to make rules and regulations under this subchapter delegated to Secretary of State by Proc. No. 2374, promulgated ","children":[{"tag":"date","attrib":{"date":"1939-11-04"},"text":"Nov. 4, 1939","children":[],"tail":", 4 F.R. 4493, "},{"tag":"ref","attrib":{"href":"/us/stat/54/2671"},"text":"54 Stat. 2671","children":[],"tail":". See proclamations preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1"},"text":"section 1 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
