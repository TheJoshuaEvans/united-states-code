{"tag":"section","attrib":{"id":"id90bd7476-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6481"},"text":null,"children":[{"tag":"num","attrib":{"value":"6481"},"text":"§ 6481.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business codes of conduct","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90bd7477-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6481/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional finding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress recognizes the increasing importance of transnational corporations as global actors, and their potential for providing positive leadership in their host countries in the area of human rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bd7478-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6481/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of the Congress that transnational corporations operating overseas, particularly those corporations operating in countries the governments of which have engaged in or tolerated violations of religious freedom, as identified in the Annual Report, should adopt codes of conduct—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bd7479-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6481/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upholding the right to freedom of religion of their employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd747a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6481/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that a worker’s religious views and peaceful practices of belief in no way affect, or be allowed to affect, the status or terms of his or her employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90bd747b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292/tVII/s701"},"text":"Pub. L. 105–292, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2815"},"text":"112 Stat. 2815","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
