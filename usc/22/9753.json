{"tag":"section","attrib":{"id":"id914c6d41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753"},"text":null,"children":[{"tag":"num","attrib":{"value":"9753"},"text":"§ 9753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Countering Russian influence in Venezuela","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id914c6d42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Russian-Venezuelan Threat Mitigation Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914c6d43-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threat assessment and strategy to counter Russian influence in Venezuela","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914c6d44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defined term","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914c6d45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6d46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threat assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Secretary of State shall submit a report to the appropriate congressional committees regarding—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914c6d48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of Russian-Venezuelan security cooperation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6d49-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential threat such cooperation poses to the United States and countries in the Western Hemisphere; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6d4a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategy to counter threats identified in subparagraphs (A) and (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914c6d4b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aliens ineligible for visas, admission, or parole","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914c6d4c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aliens described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An alien described in this paragraph is an alien who the Secretary of State or the Secretary of Homeland Security (or a designee of either Secretary) knows, or has reason to believe, is acting or has acted on behalf of the Government of Russia in direct support of the security forces of the Maduro regime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visas, admission, or parole","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An alien described in paragraph (1) is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914c6d4e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inadmissible to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6d4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ineligible to receive a visa or other documentation to enter the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6d50-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise ineligible to be admitted or paroled into the United States or to receive any benefit under the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d51-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current visas revoked","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914c6d52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An alien described in paragraph (1) is subject to revocation of any visa or other entry documentation regardless of when the visa or other entry documentation is or was issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6d53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A revocation under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id914c6d54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take effect immediately; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id914c6d55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automatically cancel any other valid visa or entry documentation that is in the alien’s possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sanctions under paragraphs (2) and (3) shall not apply with respect to an alien if admitting or paroling the alien into the United States is necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914c6d57-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permit the United States to comply with the Agreement regarding the Headquarters of the United Nations, signed at Lake Success ","children":[{"tag":"date","attrib":{"date":"1947-06-26"},"text":"June 26, 1947","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1947-11-21"},"text":"November 21, 1947","children":[],"tail":", between the United Nations and the United States, or other applicable international obligations; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6d58-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out or assist law enforcement activity in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d59-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may waive the application of this subsection with respect to an alien if the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914c6d5a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that such a waiver is in the national interest of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6d5b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits a notice of, and justification for, such waiver to the appropriate congressional committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d5c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9753/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall terminate on the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914c6d5d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tI/s165"},"text":"Pub. L. 116–94, div. J, title I, § 165","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3043"},"text":"133 Stat. 3043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id914c6d5e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id914c6d5f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id914c6d60-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (c)(2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of Title 8, Aliens and Nationality. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
