{"tag":"section","attrib":{"id":"id8fd8922d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2595a"},"text":"§ 2595a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy coordination concerning implementation of on-site inspection provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fd8922e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"OSIA should receive policy guidance which is formulated through an interagency mechanism established by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fd8922f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of Secretary of Defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense should provide to OSIA appropriate policy guidance formulated through the interagency mechanism described in subsection (a) and operational direction, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s113/b"},"text":"section 113(b) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fd89230-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2595a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of Secretary of State","children":[],"tail":null},{"tag":"content