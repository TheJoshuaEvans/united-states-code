{"tag":"section","attrib":{"id":"id90ed0fd7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706"},"text":null,"children":[{"tag":"num","attrib":{"value":"7706"},"text":"§ 7706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ed0fd8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by the Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall determine whether a candidate country is an eligible country for purposes of this section. Such determination shall be based, to the maximum extent possible, upon objective and quantifiable indicators of a country’s demonstrated commitment to the criteria in subsection (b), and shall, where appropriate, take into account and assess the role of women and girls. A determination whether a country is eligible for a subsequent, non-concurrent Millennium Challenge Compact shall also be based, to the extent practicable, on significantly improved performance across the criteria in subsection (b) that, at a minimum, are relevant to the preceding Compact, compared to the country’s performance with respect to such criteria when selected for such preceding Compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed0fd9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A candidate country should be considered to be an eligible country for purposes of this section if the Board determines that the country has demonstrated a commitment to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed0fda-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" just and democratic governance, including a demonstrated commitment to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ed0fdb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote political pluralism, equality, and the rule of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed0fdc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respect human and civil rights, including the rights of people with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed0fdd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect private property rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed0fde-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage transparency and accountability of government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed0fdf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combat corruption; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed0fe0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of the civil society enabling environment;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed0fe1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" economic freedom, including a demonstrated commitment to economic policies that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ed0fe2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage citizens and firms to participate in global trade and international capital markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed0fe3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote private sector growth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed0fe4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen market forces in the economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed0fe5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respect worker rights, including the right to form labor unions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed0fe6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" investments in the people of such country, particularly women and children, including programs that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ed0fe7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote broad-based primary education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed0fe8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen and build capacity to provide quality public health and reduce child mortality; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed0fe9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the protection of biodiversity and the transparent and sustainable management and use of natural resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed0fea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection by the Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed0feb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the time the Board determines eligible countries under this section for a fiscal year, the Board shall select those eligible countries with respect to which the United States will initially seek to enter into a Millennium Challenge Compact pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7708"},"text":"section 7708 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed0fec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting eligible countries under paragraph (1), the Board shall prioritize need and impact by considering the following factors:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ed0fed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the country clearly meets or exceeds the eligibility criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed0fee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The opportunity to reduce poverty and generate economic growth in the country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed0fef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The availability of amounts to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed0ff0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting on treatment of civil society","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the 7-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2018-04-23"},"text":"April 23, 2018","children":[],"tail":", before the Board selects an eligible country for a Compact under subsection (c), the Corporation shall provide information to the Board regarding the country’s treatment of civil society, including classified information, as appropriate. The information shall include an assessment and analysis of factors including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed0ff1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any relevant laws governing the formation or establishment of a civil society organization, particularly laws intended to curb the activities of foreign civil society organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed0ff2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any relevant laws governing the operations of a civil society organization, particularly those laws seeking to define or otherwise regulate the actions of foreign civil society organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed0ff3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laws relating to the legal status of civil society organizations, including laws which effectively discriminate against foreign civil society organizations as compared to similarly situated domestic organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed0ff4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laws regulating the freedom of expression and peaceful assembly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed0ff5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laws regulating the usage of the Internet, particularly by foreign civil society organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed0ff6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of criteria and methodology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The criteria and methodology submitted by the Board to Congress and published in the Federal Register under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7707/b/2"},"text":"section 7707(b)(2) of this title","children":[],"tail":" with respect to a fiscal year shall remain fixed for purposes of eligibility determinations for such year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed0ff7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7706/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual modification of criteria and methodology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As appropriate, the Board, acting through the Chief Executive Officer, shall review the eligibility criteria and methodology and modify such criteria and methodology in subsequent years consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7707/b"},"text":"section 7707(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ed0ff8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tVI/s607"},"text":"Pub. L. 108–199, div. D, title VI, § 607","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/216"},"text":"118 Stat. 216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dJ/tVI/s699I/a"},"text":"Pub. L. 110–161, div. J, title VI, § 699I(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2372"},"text":"121 Stat. 2372","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/167/tII/s203"},"text":"Pub. L. 115–167, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-04-23"},"text":"Apr. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1279"},"text":"132 Stat. 1279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLI/s5122/d"},"text":"Pub. L. 118–159, div. E, title LI, § 5122(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2431"},"text":"138 Stat. 2431","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ed0ff9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ed0ffa-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90ed0ffb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(2)(C), was in the original “this title”, meaning title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD"},"text":"Pub. L. 108–199, div. D","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/211"},"text":"118 Stat. 211","children":[],"tail":", which is classified generally to this chapter. For complete classification of this title to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7701"},"text":"section 7701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90ed0ffc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “prioritize need and impact by considering” for “consider” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167/s203/1"},"text":"Pub. L. 115–167, § 203(1)","children":[],"tail":", inserted at end “A determination whether a country is eligible for a subsequent, non-concurrent Millennium Challenge Compact shall also be based, to the extent practicable, on significantly improved performance across the criteria in subsection (b) that, at a minimum, are relevant to the preceding Compact, compared to the country’s performance with respect to such criteria when selected for such preceding Compact.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167/s203/2"},"text":"Pub. L. 115–167, § 203(2)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167/s203/3"},"text":"Pub. L. 115–167, § 203(3)","children":[],"tail":", (4), added subsec. (d) and redesignated former subsecs. (d) and (e) as (e) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s699I/a/1"},"text":"Pub. L. 110–161, § 699I(a)(1)","children":[],"tail":", struck out “and the sustainable management of natural resources” after “growth”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/s699I/a/2"},"text":"Pub. L. 110–161, § 699I(a)(2)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
