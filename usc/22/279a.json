{"tag":"section","attrib":{"id":"id8eb595bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s279a"},"text":null,"children":[{"tag":"num","attrib":{"value":"279a"},"text":"§ 279a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for payment of United States expenses in Organization; limitation of contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated, out of any money in the Treasury not otherwise appropriated, such sums as may be required for expenditure under the direction of the Secretary of State, for the payment by the United States of its proportionate share in the expenses of the Organization: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the percentage contribution of the United States to the total annual budget of the Organization shall not exceed 33.33 per centum."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eb595c0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch342/s2"},"text":"July 31, 1945, ch. 342, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/529"},"text":"59 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-21/ch976/s1/b"},"text":"Sept. 21, 1950, ch. 976, § 1(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/902"},"text":"64 Stat. 902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-26/ch937"},"text":"Aug. 26, 1954, ch. 937","children":[],"tail":", title IV, § 421, as added "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-18/ch627/s8/n"},"text":"July 18, 1956, ch. 627, § 8(n)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/559"},"text":"70 Stat. 559","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-26/