l":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-07-18"},"text":"July 18, 1956","children":[],"tail":", increased authorized annual appropriation from $2,000,000, to $3,000,000, and inserted provisions limiting percentage contribution of United States to total annual budget to not more than 31.5 per centum."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Joint Res. ","children":[{"tag":"date","attrib":{"date":"1950-09-21"},"text":"Sept. 21, 1950","children":[],"tail":", increased authorized annual appropriation from $1,250,000 to $2,000,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eb595c4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"id8eb595c5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s709"},"text":"Section 709 of Pub. L. 87–195","children":[],"tail":", cited as a credit to this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/87/565/s401"},"text":"section 401 of Pub. L. 87–565","children":[],"tail":", pt. IV, "},{"tag":"date","attrib":{"date":"1962-08-01"},"text":"Aug. 1, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/263"},"text":"76 Stat. 263","children":[],"tail":", except insofar as section 709 affected this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 544(b) of act ","children":[{"tag":"date","attrib":{"date":"1954-08-26"},"text":"Aug. 26, 1954","children":[],"tail":", cited as a credit to this section, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/85/477"