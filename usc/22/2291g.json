{"tag":"section","attrib":{"id":"id8f7b7e1a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2291g"},"text":"§ 2291g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on acquisition of real property and construction of facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f7b7e1b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of real property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7b7e1c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available to carry out this part may not be used to acquire (by purchase or other means) any land or other real property for use by foreign military, paramilitary, or law enforcement forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7b7e1d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to the acquisition of real property by lease of a duration not to exceed 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7b7e1e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7b7e1f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available to carry out this part may not be used for construction of facilities for use by foreign military, paramilitary, or law enforcement forces unless, at least 15 days before obligating funds for such construction, the President notifies the appropriate congressional committees in accordance with procedures applicable to reprogramming notifications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394–1"},"text":"section 2394–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7b7e20-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to the construction of facilities which would require the obligation of less than $750,000 under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f7b7e21-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 488, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIV/s4505"},"text":"Pub. L. 100–690, title IV, § 4505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4285"},"text":"102 Stat. 4285","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/583/s4/g"},"text":"Pub. L. 102–583, § 4(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-02"},"text":"Nov. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4917"},"text":"106 Stat. 4917","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tVI/s671/3"},"text":"Pub. L. 107–228, div. A, title VI, § 671(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1407"},"text":"116 Stat. 1407","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f7b7e22-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f7b7e23-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f7b7e24-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec.(a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" struck out heading and text of par. (3). Text read as follows: “The Secretary of State shall provide to the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate within 30 days after the end of each quarter of the fiscal year a detailed report on all leases entered into pursuant to paragraph (2), including the cost and duration of such lease, a description of the property leased, and the purpose for which such lease was entered into.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/583"},"text":"Pub. L. 102–583","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Funds made available to carry out this part may not be used to acquire (by purchase, lease, or other means) any real property for use by foreign military, paramilitary, or law enforcement forces”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f7b7e25-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f7b7e26-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
