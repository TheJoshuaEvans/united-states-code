{"tag":"section","attrib":{"id":"id8ff060a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2669a"},"text":"§ 2669a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diplomatic Telecommunications Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff060a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diplomatic Telecommunications Service financial management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In fiscal year 1995 and each succeeding fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff060a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State shall provide funds for the operation of the Diplomatic Telecommunications Service (DTS) in a sufficient amount to sustain the current level of support services being provided by the DTS, and no portion of such amount may be reprogrammed or transferred for any other purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff060a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all funds for the operation and enhancement of the DTS shall be directly available for use by the Diplomatic Telecommunications Service Program Office (DTS–PO); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff060a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the DTS–PO financial management officer shall be provided direct access to the Department of State financial management system to independently monitor and control the obligation and expenditure of all funds for the operation and enhancement of the DTS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DTS Policy Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 60 days after ","children":[{"tag":"date","attrib":{"date":"1994-08-26"},"text":"August 26, 1994","children":[],"tail":", the Secretary of State and the Director of the DTS–PO shall restructure the DTS Policy Board to provide for representation on the Board, during fiscal year 1995 and each succeeding fiscal year, by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff060aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the DTS–PO;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff060ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the senior information management official from each agency currently serving on the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff060ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a senior career information management official from each of the Department of Commerce and the Defense Intelligence Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff060ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a senior career information management official from each of 2 other Federal agencies served by the DTS, each of whom shall be appointed on a rotating basis by the Secretary of State and the Director of the DTS–PO for a 2-year term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DTS consolidation pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff060af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State and the Director of the DTS–PO shall carry out a program under which total DTS consolidation will be completed before ","children":[{"tag":"date","attrib":{"date":"1995-10-01"},"text":"October 1, 1995","children":[],"tail":", at not less than five embassies of medium to large size."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff060b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program required in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff060b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each participating embassy shall be provided with a full range of integrated information services, including message, data, and voice, without additional charge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff060b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combined transmission facility shall be established and jointly operated, with open access to all unclassified transmission equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff060b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unclassified packet switch communication system shall be installed and shall serve all foreign affairs agencies associated with the embassy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff060b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separate classified transmission systems (including MERCURY) shall be terminated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff060b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all foreign affairs agency systems requiring international communications capability shall obtain such capability solely through the DTS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff060b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1996-01-15"},"text":"January 15, 1996","children":[],"tail":", the Secretary of State and the Director of the DTS–PO shall submit to the Committees on Appropriations of the House and Senate a report describing the actions taken under the program required by this subsection. The report shall include a cost-benefit analysis for each embassy participating in the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DTS planning report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1995-01-15"},"text":"January 15, 1995","children":[],"tail":", the Secretary of State and the Director of the DTS–PO shall submit to the Committees on Appropriations a DTS planning report. The report shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff060b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed plan for carrying out the pilot program required by subsection (c), including an estimate of the funds required for such purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff060b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a comprehensive DTS strategy plan that contains detailed plans and schedules for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff060ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an overall DTS network configuration and security strategy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff060bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transition of the existing dedicated circuits and classified transmission systems to the unclassified packet switch communications system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff060bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of a basic level of voice service for all DTS customers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff060bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding of new initiatives and of replacement of current systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff060be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combining existing DTS network control centers, relay facilities, and overseas operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff060bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2669a/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the extensive reliance of DTS–PO on the full-time services of contractors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff060c0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/317/tV/s507"},"text":"Pub. L. 103–317, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1766"},"text":"108 Stat. 1766","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1335(m), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-789"},"text":"112 Stat. 2681–789","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff060c1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff060c2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ff060c3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" struck out “, the United States Information Agency,” after “Department of Commerce”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff060c4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ff060c5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
