{"tag":"section","attrib":{"id":"id8f6d267e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2220d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2220d"},"text":"§ 2220d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds for programs and activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f6d267f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2220d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151a"},"text":"section 2151a of this title","children":[],"tail":" unaffected by other provisions"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to use any of the funds hereafter made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151a"},"text":"section 2151a of this title","children":[],"tail":" to carry out the purposes of this subpart. Funds made available for such purposes may be used without regard to the provisions of sections 2151h(b) and 2151t(d) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f6d2680-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2220d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign currencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Foreign currencies owned by the United States and determined by the Secretary of the Treasury to be excess to the needs of the United States shall be used to the maximum extent possible in lieu of dollars in carrying out the provisions of this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f6d2681-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2220d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authorizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance authorized under this subpart shall be in addition to any allotments or grants that may be made under other authorizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f6d2682-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2220d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of funds to Administrator; annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Universities may accept and expend funds from other sources, public and private, in order to carry out the purposes of this subpart. All such funds, both prospective and inhand, shall be periodically disclosed to the Administrator as he shall by regulation require, but no less often than in an annual report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f6d2683-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 299, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/tIII/s312"},"text":"Pub. L. 94–161, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/865"},"text":"89 Stat. 865","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/tI/s102/c/2"},"text":"Pub. L. 95–424, title I, § 102(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/941"},"text":"92 Stat. 941","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f6d2684-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f6d2685-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f6d2686-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" substituted “sections 2151h(b) and 2151t(d) of this title” for “sections 2151h(b), 2171(a), and 2171(d) of this title”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f6d2687-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f6d2688-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/s605"},"text":"section 605 of Pub. L. 95–424","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f6d2689-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f6d268a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
