{"tag":"section","attrib":{"id":"id90843ba8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4858"},"text":null,"children":[{"tag":"num","attrib":{"value":"4858"},"text":"§ 4858.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training to improve perimeter security at United States diplomatic missions abroad","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90843ba9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4858/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the President should use the authority under chapter 8 of title II of the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349aa"},"text":"22 U.S.C. 2349aa","children":[],"tail":" et seq.] (relating to antiterrorism assistance) to improve perimeter security of United States diplomatic missions abroad."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90843baa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4858/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s139/20"},"text":"Pub. L. 103–236, title I, § 139(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/398"},"text":"108 Stat. 398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/c"},"text":"Pub. L. 103–415, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4299"},"text":"108 Stat. 4299","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90843bab-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIV/s408"},"text":"Pub. L. 99–399, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/866"},"text":"100 Stat. 866","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s139/20"},"text":"Pub. L. 103–236, title I, § 139(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/398"},"text":"108 Stat. 398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/c"},"text":"Pub. L. 103–415, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4299"},"text":"108 Stat. 4299","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90843bac-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90843bad-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90843bae-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Chapter 8 of title II of that Act probably means chapter 8 of part II of that Act, which is classified generally to part VIII (§ 2349aa et seq.) of subchapter II of chapter 32 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90843baf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/415"},"text":"Pub. L. 103–415","children":[],"tail":", struck out heading and text of subsec. (b). Text read as follows: “Not later than October 1 of each year, the President shall submit a report to the Congress on the progress and problems of improving perimeter security of United States diplomatic missions abroad.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
