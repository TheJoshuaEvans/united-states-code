{"tag":"section","attrib":{"id":"id8e9b57ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p–1"},"text":"§ 262p–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grassroots Collaboration Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e9b57f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal for establishment; private involvement; projects or policies for alleviation of poverty and promotion of environmental protection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director of the International Bank for Reconstruction and Development and the International Development Association to initiate discussions with other directors of such institutions and to propose the establishment of a Grassroots Collaboration Program to develop improved mechanisms for involving, directly or indirectly, nongovernmental organizations in the design, implementation, and monitoring of development projects financed by, or development policies established by, such bank or association in order to alleviate poverty and promote environmental protection, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e9b57f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encouraging nongovernmental organizations in borrowing countries to participate in all stages of project planning and country strategy activities to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e9b57f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize any adverse impact of such projects or activities on the poor people of such country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e9b57f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize any adverse impact of such projects or activities on the environment of such country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e9b57f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize the extent to which such projects or activities will benefit the poor people of such country;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b57f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the direct involvement of nongovernmental organizations in project design, implementation, or monitoring whenever such organizations have a distinct comparative advantage over other entities in providing such services by virtue of their grassroots involvement with poor people, especially women, in a borrowing country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b57f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing microenterprise credit for small scale economic activities through nongovernmental organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b57f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the enhancement of the institutional capacity of nongovernmental organizations in borrowing countries as development practitioners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b57f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing or supporting jointly funded intermediary mechanisms with nongovernmental organizations to facilitate increased collaboration between such bank or association and nongovernmental organizations in borrowing countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e9b57f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation and financing of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that the Grassroots Collaboration Program described in subsection (a) should be implemented and financed as part of the normal operations of the International Bank for Reconstruction and Development and the International Development Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e9b57fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexible financing; initial grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent the activities under the Grassroots Collaboration Program described in subsection (a) need more flexible financing, it is the sense of the Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e9b57fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such activities could be funded through a grant from the net income of the International Bank for Reconstruction and Development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b57fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an initial grant of not less than $50,000,000 should be made for such activities with subsequent annual allocations of such additional amounts as may be necessary to allow the Grassroots Collaboration Program to maximize collaboration with nongovernmental organizations in the alleviation of poverty and the protection of the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e9b57fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/240/tV/s541/d/4"},"text":"Pub. L. 101–240, title V, § 541(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2518"},"text":"103 Stat. 2518","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e9b57fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each annual report to the Congress by the National Advisory Council on International Monetary and Financial Policies shall describe the status of the establishment and operation of the Grassroots Collaboration Program described in subsection (a), the activities under taken by the Program and the sum of the amounts expended by the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e9b57ff-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXVI/s1602"},"text":"Pub. L. 95–118, title XVI, § 1602","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tI"},"text":"Pub. L. 100–202, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-131"},"text":"101 Stat. 1329–131","children":[],"tail":", 1329–134; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tV/s541/d/4"},"text":"Pub. L. 101–240, title V, § 541(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2518"},"text":"103 Stat. 2518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e9b5800-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e9b5801-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8e9b5802-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/s1602"},"text":"Section 1602 of Pub. L. 95–118","children":[],"tail":" is based on section 701 of title VII of H.R. 3750, One Hundredth Congress, as introduced "},{"tag":"date","attrib":{"date":"1987-12-11"},"text":"Dec. 11, 1987","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8e9b5803-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/240"},"text":"Pub. L. 101–240","children":[],"tail":" struck out subsec. (d) which related to initial reporting requirements by Secretary of the Treasury."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e9b5804-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8e9b5805-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–5"},"text":"section 262p–5 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
