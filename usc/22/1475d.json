{"tag":"section","attrib":{"id":"id8f06c3a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1475d"},"text":"§ 1475d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for disability or death","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A cultural exchange, international fair or exposition, or other exhibit or demonstration of United States economic accomplishments and cultural attainments, provided for under this chapter or the Mutual Educational and Cultural Exchange Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"22 U.S.C. 2451","children":[],"tail":" et seq.] shall not be considered a “public work” as that term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1651"},"text":"section 1651 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f06c3a2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-27/ch36"},"text":"Jan. 27, 1948, ch. 36","children":[],"tail":", title VIII, § 809, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tIII/s304/e"},"text":"Pub. L. 97–241, title III, § 304(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/293"},"text":"96 Stat. 293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f06c3a3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f06c3a4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib"