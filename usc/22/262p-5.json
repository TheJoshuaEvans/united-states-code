{"tag":"section","attrib":{"id":"id8ea03938-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p–5"},"text":"§ 262p–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this title and titles XIV and XV—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ea03939-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–5/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “multilateral development bank” means the International Bank for Reconstruction and Development, the International Development Association, and the regional multilateral development banks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ea0393a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–5/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “regional multilateral development bank” means the Inter-American Development Bank, the African Development Bank, the African Development Fund, and the Asian Development Bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ea0393b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXVI/s1622"},"text":"Pub. L. 95–118, title XVI, § 1622","children":[],"tail":", formerly § 1606, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tI"},"text":"Pub. L. 100–202, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-131"},"text":"101 Stat. 1329–131","children":[],"tail":", 1329–134; renumbered § 161