{"tag":"section","attrib":{"id":"id8ee09df1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–26"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–26"},"text":"§ 290g–26.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sixteenth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ee09df2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–26/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund is authorized to contribute on behalf of the United States $591,000,000 to the sixteenth replenishment of the resources of the Fund, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee09df3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–26/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $591,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee09df4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s227"},"text":"Pub. L. 94–302, title II, § 227","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/47/dF/tVII/s7070"},"text":"Pub. L. 118–47, div. F, title VII, § 7070","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/850"},"text":"138 Stat. 850","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
