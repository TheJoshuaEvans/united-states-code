{"tag":"section","attrib":{"id":"id907854eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4352"},"text":null,"children":[{"tag":"num","attrib":{"value":"4352"},"text":"§ 4352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for preparation of FRUS series","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id907854ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id907854ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4352/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id907854ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4352/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Historian of the Department of State shall be responsible for the preparation of the FRUS series, including the selection of records, in accordance with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id907854ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4352/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Advisory Committee on Historical Diplomatic Documentation shall review records, and shall advise and make recommendations to the Historian concerning all aspects of preparation and publication of the FRUS series, including, in accordance with the procedures contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4353"},"text":"section 4353 of this title","children":[],"tail":", the review and selection of records for inclusion in volumes of the series."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907854f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4352/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other departments, agencies, and other entities of the United States Government shall cooperate with the Office of the Historian by providing full and complete access to the records pertinent to United States foreign policy decisions and actions and by providing copies of selected records in accordance with the procedures developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4353"},"text":"section 4353 of this title","children":[],"tail":", except that no access to any record, and no provision of any copy of a record, shall be required in the case of any record that was prepared less than 20 years before the date of a request for such access or copy made by the Office of the Historian."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907854f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Archives and Records Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, the requirement for the National Archives and Records Administration to provide access to, and copies of, records to the Department of State for the FRUS series shall be governed by chapter 21 of title 44, by any agreement concluded between the Department of State and the National Archives and Records Administration, and, in the case of Presidential records, by section 2204 of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907854f2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title IV, § 402, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s198/a"},"text":"Pub. L. 102–138, title I, § 198(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/685"},"text":"105 Stat. 685","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLV/s5504/1"},"text":"Pub. L. 117–81, div. E, title LV, § 5504(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2376"},"text":"135 Stat. 2376","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907854f3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907854f4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id907854f5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “20” for “26”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id907854f6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id907854f7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Authority of Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, Secretary of State to have and exercise any authority vested by law in any official or office of Department of State and references to such officials or offices deemed to refer to Secretary of State or Department of State, as appropriate, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s161/d"},"text":"section 161(d) of Pub. L. 103–236","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
