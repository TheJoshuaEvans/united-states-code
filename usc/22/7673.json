{"tag":"section","attrib":{"id":"id90eac64e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673"},"text":null,"children":[{"tag":"num","attrib":{"value":"7673"},"text":"§ 7673.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90eac64f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Balanced funding requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90eac650-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Global AIDS Coordinator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac651-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide balanced funding for prevention activities for sexual transmission of HIV/AIDS; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac652-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that activities promoting abstinence, delay of sexual debut, monogamy, fidelity, and partner reduction are implemented and funded in a meaningful and equitable way in the strategy for each host country based on objective epidemiological evidence as to the source of infections and in consultation with the government of each host county ","children":[{"tag":"ref","attrib":{"idref":"fn002390"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002390"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “country”."}],"tail":" involved in HIV/AIDS prevention activities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac653-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention strategy","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac654-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Global AIDS Coordinator shall establish an HIV sexual transmission prevention strategy governing the expenditure of funds authorized under this chapter to prevent the sexual transmission of HIV in any host country with a generalized epidemic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac655-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In each host country described in subparagraph (A), if the strategy established under subparagraph (A) provides less than 50 percent of the funds described in subparagraph (A) for activities promoting abstinence, delay of sexual debut, monogamy, fidelity, and partner reduction, the Global AIDS Coordinator shall, not later than 30 days after the issuance of this strategy, report to the appropriate congressional committees on the justification for this decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac656-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Programs and activities that implement or purchase new prevention technologies or modalities, such as medical male circumcision, public education about risks to acquire HIV infection from blood exposures, promoting universal precautions, investigating suspected nosocomial infections, pre-exposure pharmaceutical prophylaxis to prevent transmission of HIV, or microbicides and programs and activities that provide counseling and testing for HIV or prevent mother-to-child prevention of HIV, shall not be included in determining compliance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac657-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", and annually thereafter as part of the annual report required under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b–2/e"},"text":"section 2151b–2(e) of this title","children":[],"tail":", the President shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac658-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a report on the implementation of paragraph (2) for the most recently concluded fiscal year to the appropriate congressional committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac659-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the report described in subparagraph (A) available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac65a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Orphans and vulnerable children","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For fiscal years 2009 through 2024 and fiscal year 2025 through March 25 of such fiscal year, not less than 10 percent of the amounts appropriated or otherwise made available to carry out the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b–2"},"text":"section 2151b–2 of this title","children":[],"tail":" for HIV/AIDS assistance for each such fiscal year shall be expended for assistance for orphans and other children affected by, or vulnerable to, HIV/AIDS, of which such amount at least 50 percent shall be provided through non-profit, nongovernmental organizations, including faith-based organizations, that implement programs on the community level."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac65b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of the fiscal years 2009 through 2024 and for fiscal year 2025 through March 25 of such fiscal year, more than half of the amounts appropriated or otherwise made available to carry out the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b–2"},"text":"section 2151b–2 of this title","children":[],"tail":" shall be expended for—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90eac65c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" antiretroviral treatment for HIV/AIDS;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac65d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clinical monitoring of HIV-seropositive people not in need of antiretroviral treatment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac65e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" care for associated opportunistic infections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac65f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nutrition and food support for people living with HIV/AIDS; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac660-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other essential HIV/AIDS-related medical care for people living with HIV/AIDS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac661-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment, prevention, and care goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of the fiscal years 2009 through 2013—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90eac662-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treatment goal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7672/a/3"},"text":"section 7672(a)(3) of this title","children":[],"tail":" shall be increased above 2,000,000 by at least the percentage increase in the amount appropriated for bilateral global HIV/AIDS assistance for such fiscal year compared with fiscal year 2008;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac663-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any increase in the treatment goal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7672/a/3"},"text":"section 7672(a)(3) of this title","children":[],"tail":" above the percentage increase in the amount appropriated for bilateral global HIV/AIDS assistance for such fiscal year compared with fiscal year 2008 shall be based on long-term requirements, epidemiological evidence, the share of treatment needs being met by partner governments and other sources of treatment funding, and other appropriate factors;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac664-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treatment goal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7672/a/3"},"text":"section 7672(a)(3) of this title","children":[],"tail":" shall be increased above the number calculated under paragraph (1) by the same percentage that the average United States Government cost per patient of providing treatment in countries receiving bilateral HIV/AIDS assistance has decreased compared with fiscal year 2008; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac665-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7673/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevention and care goals established in clauses (i) and (iv) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b–2/b/1/A"},"text":"section 2151b–2(b)(1)(A) of this title","children":[],"tail":" shall be increased consistent with epidemiological evidence and available resources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90eac666-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25/tIV/s403"},"text":"Pub. L. 108–25, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/746"},"text":"117 Stat. 746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/293/tIV/s403"},"text":"Pub. L. 110–293, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2966"},"text":"122 Stat. 2966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/56/s6"},"text":"Pub. L. 113–56, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-02"},"text":"Dec. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/654"},"text":"127 Stat. 654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/305/s4"},"text":"Pub. L. 115–305, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-11"},"text":"Dec. 11, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4403"},"text":"132 Stat. 4403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/47/dF/tVII/s7072/c"},"text":"Pub. L. 118–47, div. F, title VII, § 7072(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/853"},"text":"138 Stat. 853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90eac667-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90eac668-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90eac669-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(2)(A), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25"},"text":"Pub. L. 108–25","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/711"},"text":"117 Stat. 711","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7601"},"text":"section 7601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90eac66a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/s7072/c/1"},"text":"Pub. L. 118–47, § 7072(c)(1)","children":[],"tail":", substituted “2024 and fiscal year 2025 through March 25 of such fiscal year” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/s7072/c/2"},"text":"Pub. L. 118–47, § 7072(c)(2)","children":[],"tail":", substituted “2024 and for fiscal year 2025 through March 25 of such fiscal year” for “2023” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/305/s4/1"},"text":"Pub. L. 115–305, § 4(1)","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/305/s4/2"},"text":"Pub. L. 115–305, § 4(2)","children":[],"tail":", substituted “2023” for “2018” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/56/s6/a"},"text":"Pub. L. 113–56, § 6(a)","children":[],"tail":", substituted “2018” for “2013” and “amounts appropriated or otherwise made available to carry out the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b–2"},"text":"section 2151b–2 of this title","children":[],"tail":"” for “amounts appropriated pursuant to the authorization of appropriations under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7671"},"text":"section 7671 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/56/s6/b"},"text":"Pub. L. 113–56, § 6(b)","children":[],"tail":", substituted “2018” for “2013” and “amounts appropriated or otherwise made available to carry out the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b–2"},"text":"section 2151b–2 of this title","children":[],"tail":"” for “amounts appropriated for bilateral global HIV/AIDS assistance pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7671"},"text":"section 7671 of this title","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293/s403/1"},"text":"Pub. L. 110–293, § 403(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “For fiscal years 2006 through 2008, not less than 55 percent of the amounts appropriated pursuant to the authorization of appropriations under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7671"},"text":"section 7671 of this title","children":[],"tail":" for HIV/AIDS assistance for each such fiscal year shall be expended for therapeutic medical care of individuals infected with HIV, of which such amount at least 75 percent should be expended for the purchase and distribution of antiretroviral pharmaceuticals and at least 25 percent should be expended for related care. For fiscal years 2006 through 2008, not less than 33 percent of the amounts appropriated pursuant to the authorization of appropriations under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7671"},"text":"section 7671 of this title","children":[],"tail":" for HIV/AIDS prevention consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b–2/d"},"text":"section 2151b–2(d) of this title","children":[],"tail":" for each such fiscal year shall be expended for abstinence-until-marriage programs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293/s403/2"},"text":"Pub. L. 110–293, § 403(2)","children":[],"tail":", substituted “fiscal years 2009 through 2013” for “fiscal years 2006 through 2008” and “other children affected by, or vulnerable to,” for “vulnerable children affected by”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293/s403/3"},"text":"Pub. L. 110–293, § 403(3)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
