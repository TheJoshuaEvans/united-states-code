{"tag":"section","attrib":{"id":"id907f800c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4708"},"text":null,"children":[{"tag":"num","attrib":{"value":"4708"},"text":"§ 4708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" J. William Fulbright Foreign Scholarship Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The J. William Fulbright Foreign Scholarship Board shall advise and assist the President in the discharge of the scholarship program carried out pursuant to this chapter, in accordance with the guidelines set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4704"},"text":"section 4704 of this title","children":[],"tail":". The President may provide for such additional secretarial and staff assistance for the Board as may be required to carry out this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907f800d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/tVI/s608"},"text":"Pub. L. 99–93, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/442"},"text":"99 Stat. 442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tII/s204/c"},"text":"Pub. L. 101–246, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/50"},"text":"104 Stat. 50","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907f800e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907f800f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","at