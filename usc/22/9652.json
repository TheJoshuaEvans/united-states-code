{"tag":"section","attrib":{"id":"id9147b25c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652"},"text":null,"children":[{"tag":"num","attrib":{"value":"9652"},"text":"§ 9652.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance measures, evaluation, and learning","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9147b25d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall develop a performance measurement system to evaluate and monitor projects supported by the Corporation under subchapter II of this chapter and to guide future projects of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b25e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the performance measurement system required by subsection (a), the Corporation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b25f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a development impact measurement system, to be known as the Corporation’s Impact Quotient, which shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9147b260-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a metrics-based measurement system to assess a project’s expected outcomes and development impact on a country, a region, and populations throughout the sourcing, origination, management, monitoring, and evaluation stages of a project’s lifecycle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b261-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable the Corporation to assess development impact at both the project and portfolio level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b262-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance on when to take appropriate corrective measures to further development goals throughout a project’s lifecycle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b263-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform congressional notification requirements outlining the Corporation’s project development impacts;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b264-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a mechanism for ensuring that support provided by the Corporation under subchapter II of this chapter is in addition to private investment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b265-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop standards for, and a method for ensuring, appropriate financial performance of the Corporation’s portfolio;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b266-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop standards for, and a method for evaluating and documenting the development impacts of the Corporation’s portfolio, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9147b267-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measurement of the projected and ex post development impact of a project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b268-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information necessary to comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9653"},"text":"section 9653 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b269-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop standards for, and a method for ensuring, appropriate monitoring of the Corporation’s compliance with environmental and social standards consistent with the guidance published by the Corporation following broad consultation with appropriate stakeholders to include civil society; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b26a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop standards for, and a method for ensuring, appropriate monitoring of the Corporation’s portfolio, including standards for ensuring employees or agents of the Corporation identify and conduct in-person site visits of each high-risk loan, loan guarantee, and equity project, as necessary and appropriate, after the initial disbursement of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b26b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required performance measures update for Congressional Strategic Advisory Group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At any meeting of the Congressional Strategic Advisory Group, the Corporation shall be prepared discuss the standards developed in subsection (b) for all ongoing projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b26c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability of certain information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall make available to the public on a regular basis information about support provided by the Corporation under subchapter II of this chapter and performance metrics about such support on a country-by-country basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b26d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the performance measurement system required by subsection (a), the Corporation shall consult with the Development Advisory Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9613/i"},"text":"section 9613(i) of this title","children":[],"tail":" and other stakeholders and interested parties engaged in sustainable economic growth and development."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b26e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staffing for portfolio oversight and reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b26f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to maintain capacity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall maintain an adequate number of full-time personnel with appropriate expertise to fulfill its obligations under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9653"},"text":"section 9653 of this title","children":[],"tail":", including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9147b270-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring and evaluating the financial performance of the Corporation’s portfolio;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b271-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the development and strategic impact of investments throughout the program lifecycle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b272-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing required annual reporting on the Corporation’s portfolio of investments, including the information set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9653/a/6"},"text":"section 9653(a)(6) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b273-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring for compliance with all applicable laws and ethics requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b274-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Personnel assigned to carry out the obligations described in paragraph (1) shall possess demonstrable professional experience in relevant areas, such as development finance, financial analysis, investment portfolio management, monitoring and evaluation, impact measurement, or legal and ethics expertise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b275-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organizational structure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall maintain such personnel within 1 or more dedicated units or offices, which shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9147b276-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be functionally independent from investment origination teams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b277-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be managed by senior staff who report to the Chief Executive Officer or Deputy Chief Executive Officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b278-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be allocated resources sufficient to fulfill the Corporation’s obligations under this section and to support transparency and accountability to Congress and to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b279-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insulation from reductions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation may not reduce the staffing, funding, or organizational independence of the units or personnel responsible for fulfilling the obligations under this section unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9147b27a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief Executive Officer certifies in writing to the appropriate congressional committees that such reductions are necessary due to operational exigency, statutory change, or budgetary shortfall; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b27b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9652/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation includes in its annual report a detailed explanation of the impact of any such changes on its capacity to analyze and report on portfolio performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9147b27c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tIV/s1442"},"text":"Pub. L. 115–254, div. F, title IV, § 1442","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3504"},"text":"132 Stat. 3504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXVII/s8754"},"text":"Pub. L. 119–60, div. H, title LXXXVII, § 8754","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1964"},"text":"139 Stat. 1964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9147b27d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9147b27e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9147b27f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8754/1/A"},"text":"Pub. L. 119–60, § 8754(1)(A)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “develop a successor for the development impact measurement system of the Overseas Private Investment Corporation (as such system was in effect on the day before "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":");”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8754/1/C/i"},"text":"Pub. L. 119–60, § 8754(1)(C)(i)","children":[],"tail":", substituted “method for evaluating and documenting the development impacts” for “method for ensuring, appropriate development performance” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8754/1/B"},"text":"Pub. L. 119–60, § 8754(1)(B)","children":[],"tail":", (C)(ii), (D), added pars. (5) and (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8754/2"},"text":"Pub. L. 119–60, § 8754(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsecs. (c) and (d) as (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s8754/4"},"text":"Pub. L. 119–60, § 8754(4)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
