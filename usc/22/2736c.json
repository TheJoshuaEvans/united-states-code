{"tag":"section","attrib":{"id":"id9003733a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2736c"},"text":"§ 2736c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional development opportunities and tools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9003733b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expand provision of professional development and career advancement opportunities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9003733c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to expand professional development opportunities that support the mission needs of the Department, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9003733d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9003733e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private-public exchanges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9003733f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" detail assignments to relevant positions in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90037340-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private or international organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90037341-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and Tribal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90037342-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other branches of the Federal Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90037343-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional schools of international affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037344-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training for senior positions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90037345-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall offer, or sponsor members of the workforce to participate in, a Senior Executive Service candidate development program or other program that trains members on the skills required for appointment to senior positions in the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90037346-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining which members of the workforce are granted professional development or career advancement opportunities under subparagraph (A), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90037347-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure any program offered or sponsored by the Department under such subparagraph comports with the requirements of subpart C of part 412 of title 5, Code of Federal Regulations, or any successor thereto, including merit staffing and assessment requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90037348-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the number of expected vacancies in senior positions as a factor in determining the number of candidates to select for such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90037349-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understand how participation in any program offered or sponsored by the Department under such subparagraph differs by gender, race, national origin, disability status, or other demographic categories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9003734a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736c/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actively encourage participation from a range of demographic categories, especially from categories with consistently low participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9003734b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLIV/s5405"},"text":"Pub. L. 117–81, div. E, title LIV, § 5405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2373"},"text":"135 Stat. 2373","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9003734c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9003734d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id9003734e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary” and “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s5002"},"text":"section 5002 of Pub. L. 117–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s263c"},"text":"section 263c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
