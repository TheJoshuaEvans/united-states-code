{"tag":"section","attrib":{"id":"id9003725c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2734d"},"text":"§ 2734d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recruitment and retention of individuals who have lived, worked, or studied in predominantly Muslim countries or communities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9003725d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress finds that successful engagement, including robust public diplomacy, with predominantly Muslim countries and communities is critical for achieving United States foreign policy objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9003725e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the Department should recruit more employees that have a personal background in, and thorough understating ","children":[{"tag":"ref","attrib":{"idref":"fn002212"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002212"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “understanding”."}],"tail":" of, the cultures, languages, and history of the Middle East and wider Muslim world."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9003725f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recruitment and retention of certain individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make every effort to recruit and retain individuals that have lived, worked, or studied in predominantly Muslim countries or communities, including individuals who have studied at an Islamic institution of higher learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90037260-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/tVII/s713"},"text":"Pub. L. 114–323, title VII, § 713","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1945"},"text":"130 Stat. 1945","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90037261-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90037262-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id90037263-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Department” and “Secretary” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s2"},"text":"section 2 of Pub. L. 114–323","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
