{"tag":"section","attrib":{"id":"id90acab46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6105"},"text":null,"children":[{"tag":"num","attrib":{"value":"6105"},"text":"§ 6105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for repayments","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If any fellow fails to fulfill the fellow’s agreement to pay the United States Information Agency for the expenses incurred by the United States Information Agency in connection with the fellowship, a sum equal to the amount of the expenses of the fellowship shall be recoverable by the United States Information Agency from the fellow (or a legal representative) by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90acab47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6105/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setoff against accrued pay, compensation, amount of retirement credit, or other amount due the fellow from the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6105/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other method as is provided by law for the recovery of amounts owing to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90acab49-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tII/s256"},"text":"Pub. L. 103–236, title II, § 256","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/432"},"text":"108 Stat. 432","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90acab4a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90acab4b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id90acab4c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau) abolished and functions transferred to Secretary of State, see sections 6531 and 6532 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
