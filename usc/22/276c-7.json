{"tag":"section","attrib":{"id":"id8eac1fc8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"276c–7"},"text":"§ 276c–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internships of United States nationals at international organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eac1fc9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to bolster efforts to increase the number of United States citizens representative of the American people occupying positions in the United Nations system, agencies, and commissions, and in other international organizations, including by awarding grants to educational institutions and students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac1fca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Secretary of State shall submit a report to the appropriate congressional committees that identifies—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eac1fcb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of United States citizens who are involved in internship programs at international organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eac1fcc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of the individuals described in paragraph (1) among various international organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eac1fcd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–7/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grants, programs, and other activities that are being utilized to recruit and fund United States citizens to participate in internship programs at international organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac1fce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual referred to in subsection (a) is an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eac1fcf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–7/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is enrolled at or received their degree within two years from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8eac1fd0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–7/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8eac1fd1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–7/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education based outside the United States, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eac1fd2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–7/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a citizen of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac1fd3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $1,500,000 for the Department for fiscal year 2024 to carry out the grant program authorized under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eac1fd4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXVII/s6701"},"text":"Pub. L. 118–31, div. F, title LXVII, § 6701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1014"},"text":"137 Stat. 1014","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eac1fd5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eac1fd6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8eac1fd7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary”, “appropriate congressional committees”, and “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s6002"},"text":"section 6002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
