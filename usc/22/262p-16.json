{"tag":"section","attrib":{"id":"id8ea282d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p–16"},"text":"§ 262p–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States policy on World Bank Group and Asian Development Bank assistance to the People’s Republic of China","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ea282d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–16/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director at each international financial institution of the World Bank Group and at the Asian Development Bank to use the voice and vote of the United States at the respective institution to vote against the provision of any loan, extension of financial assistance, or technical assistance to the People’s Republic of China unless the Secretary of the Treasury has certified to the appropriate congressional committees that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ea282d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–16/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Government of the People’s Republic of China and any lender owned or controlled by the Government of the People’s Republic of China have demonstrated a commitment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ea282d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–16/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the rules and principles of the Paris Club, or of other similar coordinated multilateral initiatives on debt relief and debt restructuring in which the United States participates, including with respect to debt transparency and appropriate burden-sharing among all creditors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ea282d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–16/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the practice of presumptive public disclosure of the terms and conditions on which they extend credit to other governments (without regard to the form of any such extension of credit);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ea282d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–16/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to enforce any agreement terms that may impair their own or the borrowers’ capacity fully to implement any commitment described in subparagraph (A) or (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ea282d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–16/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to enter into any agreement containing terms that may impair their own or the borrowers’ capacity fully to implement any commitment described in subparagraph (A) or (B); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ea282d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–16/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan or assistance is important to the national interest of the United States, as described in a detailed explanation by the Secretary to accompany the certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ea282d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–16/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ea282d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–16/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate congressional committees” means the Committee on Financial Services of the House of Representatives and the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ea282da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–16/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" World Bank Group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “World Bank Group” means the International Bank for Reconstruction and Development, the International Development Association, the International Finance Corporation, and the Multilateral Investment Guarantee Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ea282db-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXVI/s1632"},"text":"Pub. L. 95–118, title XVI, § 1632","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVII/s5701"},"text":"Pub. L. 117–263, div. E, title LVII, § 5701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3407"},"text":"136 Stat. 3407","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ea282dc-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id8ea282dd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVII/s5701/b"},"text":"Pub. L. 117–263, div. E, title LVII, § 5701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3408"},"text":"136 Stat. 3408","children":[],"tail":", provided that, effective on the date that is 7 years after "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", this section is repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ea282de-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8ea282df-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLVII/s5701/b"},"text":"Pub. L. 117–263, div. E, title LVII, § 5701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3408"},"text":"136 Stat. 3408","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLVII/s5701/b"},"text":"“The amendment made by subsection (a) [enacting this section] is repealed effective on the date that is 7 years after the effective date of this section [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8ea282e0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–5"},"text":"section 262p–5 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
