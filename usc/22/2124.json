{"tag":"section","attrib":{"id":"id8f31a3ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124"},"text":null,"children":[{"tag":"num","attrib":{"value":"2124"},"text":"§ 2124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tourism Policy Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f31a3af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to ensure that the United States’ national interest in tourism is fully considered in Federal decision making, there is established a coordinating council to be known as the Tourism Policy Council (hereafter in this chapter referred to as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f31a3b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall consist of the following individuals:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f31a3b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Commerce, who shall serve as the Chairman of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Commerce for International Trade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner of the United States Customs Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President of the United States National Tourism Organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commissioner of the Immigration and Naturalization Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives of other Federal agencies which have affected interests at each meeting as deemed appropriate and invited by the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f31a3bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No additional compensation for Council members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Council shall serve without additional compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f31a3bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall conduct its first meeting not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":". Thereafter the Council shall meet not less than 2 times each year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f31a3be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Involvement of Federal agencies and departments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f31a3bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council shall coordinate national policies and programs relating to international travel and tourism, recreation, and national heritage resources, which involve Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council may request directly from any Federal department or agency such personnel, information, services, or facilities as deemed necessary by the Chairman and to the extent permitted by law and within the limits of available funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal departments and agencies may, in their discretion, detail to temporary duty with the Council such personnel as the Chairman may request for carrying out the functions of the Council. Each such detail of personnel shall be without loss of seniority, pay, or other employee status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f31a3c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closed meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Where necessary to prevent the public disclosure of non-public information which may be presented by a Council member, the Council may hold, at the discretion of the Chairman, a closed meeting which may exclude any individual who is not an officer or employee of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f31a3c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall submit an annual report for the preceding fiscal year to the President for transmittal to the Congress on or before December 31 of each year. The report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f31a3c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive and detailed report of the activities and accomplishments of the Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of Council efforts to coordinate the policies and programs of member’s agencies that have a significant effect on international travel and tourism, recreation, and national heritage resources, including progress toward resolving interagency conflicts and development of cooperative program activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of problems referred to the Council by State and local governments, the tourism industry, the United States National Tourism Organization, the Secretary of Commerce, along with a detailed summary of any action taken or anticipated to resolve such problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f31a3c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendation as deemed appropriate by the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f31a3c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2124/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The membership of the President of the United States National Tourism Organization on the Council shall not in itself make chapter 10 of title 5 applicable to the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f31a3c9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/63/tIII/s301"},"text":"Pub. L. 87–63, title III, § 301","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/288/s11"},"text":"Pub. L. 104–288, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3408"},"text":"110 Stat. 3408","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/165"},"text":"Pub. L. 117–286, § 4(a)(165)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4324"},"text":"136 Stat. 4324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f31a3ca-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f31a3cb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8f31a3cc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2124, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/63/tIII/s301"},"text":"Pub. L. 87–63, title III, § 301","children":[],"tail":", formerly § 4, "},{"tag":"date","attrib":{"date":"1961-06-29"},"text":"June 29, 1961","children":[],"tai