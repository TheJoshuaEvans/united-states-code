{"tag":"section","attrib":{"id":"id91560a8f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10401"},"text":null,"children":[{"tag":"num","attrib":{"value":"10401"},"text":"§ 10401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91560a90-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91560a91-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10401/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Armed Services of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560a92-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10401/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on Armed Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91560a93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AUKUS partnership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91560a94-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10401/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “AUKUS partnership” means the enhanced trilateral security partnership between Australia, the United Kingdom, and the United States announced in September 2021.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560a95-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10401/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pillars","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The AUKUS partnership includes the following two pillars:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91560a96-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10401/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pillar One is focused on developing a pathway for Australia to acquire conventionally armed, nuclear-powered submarines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560a97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10401/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pillar Two is focused on enhancing trilateral collaboration on advanced defense capabilities, including hypersonic and counter hypersonic capabilities, quantum technologies, undersea technologies, and artificial intelligence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91560a98-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Traffic in Arms Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “International Traffic in Arms Regulations” means subchapter M of chapter I of title 22, Code of Federal Regulations (or successor regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91560a99-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXIII/s1321"},"text":"Pub. L. 118–31, div. A, title XIII, § 1321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/501"},"text":"137 Stat. 501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91560a9a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id91560a9b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id91560a9c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXIII/s1351"},"text":"Pub. L. 118–31, div. A, title XIII, § 1351","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/514"},"text":"137 Stat. 514","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dA/tXIII/s1351"},"text":"“This part [part 3 (§§ 1351–1354) of subtitle B of title XIII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":", enacting subchapter III of this title and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8680"},"text":"section 8680 of Title 10","children":[],"tail":", Armed Forces] may be cited as the ‘AUKUS Submarine Transfer Authorization Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
