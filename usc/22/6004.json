{"tag":"section","attrib":{"id":"id90a5a665-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004"},"text":null,"children":[{"tag":"num","attrib":{"value":"6004"},"text":"§ 6004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for Cuban people","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90a5a666-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions of law affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section apply notwithstanding any other provision of law, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370/a"},"text":"section 2370(a) of this title","children":[],"tail":", and notwithstanding the exercise of authorities, before "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"October 23, 1992","children":[],"tail":", under section 5(b) of the Trading With the Enemy Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4305/b"},"text":"50 U.S.C. 4305(b)","children":[],"tail":"], the International Emergency Economic Powers Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.], or the Export Administration Act of 1979."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a5a667-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations of food","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this or any other Act shall prohibit donations of food to nongovernmental organizations or individuals in Cuba.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a5a668-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exports of medicines and medical supplies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Exports of medicines or medical supplies, instruments, or equipment to Cuba shall not be restricted—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a5a669-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except to the extent such restrictions would be permitted under section 5(m) ","children":[{"tag":"ref","attrib":{"idref":"fn002328"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002328"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Export Administration Act of 1979 or section 203(b)(2) of the International Emergency Economic Powers Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1702/b/2"},"text":"50 U.S.C. 1702(b)(2)","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a66a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except in a case in which there is a reasonable likelihood that the item to be exported will be used for purposes of torture or other human rights abuses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a66b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except in a case in which there is a reasonable likelihood that the item to be exported will be reexported; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a66c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except in a case in which the item to be exported could be used in the production of any biotechnological product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a5a66d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for certain exports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a5a66e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Onsite verifications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90a5a66f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), an export may be made under subsection (c) only if the President determines that the United States Government is able to verify, by onsite inspections and other appropriate means, that the exported item is to be used for the purposes for which it was intended and only for the use and benefit of the Cuban people.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90a5a670-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraph (A) does not apply to donations to nongovernmental organizations in Cuba of medicines for humanitarian purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a671-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Exports permitted under subsection (c) shall be made pursuant to specific licenses issued by the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a5a672-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telecommunications services and facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a5a673-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telecommunications services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Telecommunications services between the United States and Cuba shall be permitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a674-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telecommunications facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Telecommunications facilities are authorized in such quantity and of such quality as may be necessary to provide efficient and adequate telecommunications services between the United States and Cuba.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a675-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing of payments to Cuba","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90a5a676-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may provide for the issuance of licenses for the full or partial payment to Cuba of amounts due Cuba as a result of the provision of telecommunications services authorized by this subsection, in a manner that is consistent with the public interest and the purposes of this chapter, except that this paragraph shall not require any withdrawal from any account blocked pursuant to regulations issued under section 5(b) of the Trading With the Enemy Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4305/b"},"text":"50 U.S.C. 4305(b)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90a5a677-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If only partial payments are made to Cuba under subparagraph (A), the amounts withheld from Cuba shall be deposited in an account in a banking institution in the United States. Such account shall be blocked in the same manner as any other account containing funds in which Cuba has any interest, pursuant to regulations issued under section 5(b) of the Trading With the Enemy Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a678-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Federal Communications Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to supersede the authority of the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a679-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on investment in domestic telecommunications services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall be construed to authorize the investment by any United States person in the domestic telecommunications network within Cuba. For purposes of this paragraph, an “investment” in the domestic telecommunications network within Cuba includes the contribution (including by donation) of funds or anything of value to or for, and the making of loans to or for, such network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a67a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall submit to the Congress on a semiannual basis a report detailing payments made to Cuba by any United States person as a result of the provision of telecommunications services authorized by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a5a67b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct mail delivery to Cuba","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Postal Service shall take such actions as are necessary to provide direct mail service to and from Cuba, including, in the absence of common carrier service between the 2 countries, the use of charter service providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a5a67c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6004/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to support democracy in Cuba","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Government may provide assistance, through appropriate nongovernmental organizations, for the support of individuals and organizations to promote nonviolent democratic change in Cuba.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90a5a67d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tXVII/s1705"},"text":"Pub. L. 102–484, div. A, title XVII, § 1705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2577"},"text":"106 Stat. 2577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/114/tI/s102/g"},"text":"Pub. L. 104–114, title I, § 102(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/793"},"text":"110 Stat. 793","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90a5a67e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id90a5a67f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114/tII/s204/d/3"},"text":"Pub. L. 104–114, title II, § 204(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/810"},"text":"110 Stat. 810","children":[],"tail":", provided that on date on which President submits determination under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6063/c"},"text":"section 6063(c) of this title","children":[],"tail":" that democratically elected government in Cuba is in power, this section is amended by repealing subsection (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90a5a680-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90a5a681-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsec. (a), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Export Administration Act of 1979, referred to in subsecs. (a) and (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/72"},"text":"Pub. L. 96–72","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/503"},"text":"93 Stat. 503","children":[],"tail":", which was classified principally to chapter 56 (§ 4601 et seq.) of Title 50, War and National Defense, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":", except for sections 11A, 11B, and 11C thereof ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4611"},"text":"50 U.S.C. 4611","children":[],"tail":", 4612, 4613). Section 5 of the Act was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4604"},"text":"section 4604 of Title 50","children":[],"tail":" prior to repeal."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90a5a682-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (e)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114/s102/g"},"text":"Pub. L. 104–114, § 102(g)","children":[],"tail":", added pars. (5) and (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id90a5a683-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id90a5a684-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of congressional reporting functions of President under subsec. (e) of this section, see section 1 of Ex. Ord. No. 13313, ","children":[{"tag":"date","attrib":{"date":"2003-07-31"},"text":"July 31, 2003","children":[],"tail":", 68 F.R. 46075, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
