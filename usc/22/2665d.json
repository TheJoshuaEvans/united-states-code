{"tag":"section","attrib":{"id":"id8ff06067-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2665d"},"text":"§ 2665d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charles B. Rangel International Affairs Fellowship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff06068-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department a Charles B. Rangel International Affairs Fellowship Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff06069-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program required by subsection (a) shall continue to recruit and support outstanding individuals from diverse backgrounds to prepare them for careers in the Foreign Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff0606a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2665d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program required by subsection (a) shall be administered by the Department, consistent with existing law and regulations.","children":[],"tail"