{"tag":"section","attrib":{"id":"id90a7f050-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6037"},"text":null,"children":[{"tag":"num","attrib":{"value":"6037"},"text":"§ 6037.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Television broadcasting to Cuba","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90a7f051-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6037/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion to UHF","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the International Broadcasting Bureau shall implement a conversion of television broadcasting to Cuba under the Television Marti Service to ultra high frequency (UHF) broadcasting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a7f052-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6037/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 45 days after ","children":[{"tag":"date","attrib":{"date":"1996-03-12"},"text":"March 12, 1996","children":[],"tail":", and every three months thereafter until the conversion described in subsection (a) is fully implemented, the Director of the International Broadcasting Bureau shall submit a report to the appropriate congressional committees on the progress made in carrying out subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a7f053-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6037/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag"