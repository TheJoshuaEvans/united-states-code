{"tag":"section","attrib":{"id":"id8ecb1a64-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286qq"},"text":null,"children":[{"tag":"num","attrib":{"value":"286qq"},"text":"§ 286qq.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quota increase to 4,973,100,000 Special Drawing Rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ecb1a65-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286qq/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund may consent to an increase in the quota of the United States in the Fund equivalent to 4,973,100,000 Special Drawing Rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ecb1a66-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286qq/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject to appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided by subsection (a) shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ecb1a67-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s65"},"text":"July 31, 1945, ch. 339, § 65","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/32/tXIV/s1402"},"text":"Pub. L. 111–32, title XIV, § 1402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-24"},"text":"June 24, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1918"},"text":"123 Stat. 1918","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
