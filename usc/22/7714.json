{"tag":"section","attrib":{"id":"id90ed10a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7714"},"text":null,"children":[{"tag":"num","attrib":{"value":"7714"},"text":"§ 7714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with United States Agency for International Development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ed10a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall consult with the Administrator of the United States Agency for International Development in order to coordinate the activities of the Corporation with the activities of the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed10aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" USAID programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the United States Agency for International Development shall seek to ensure that appropriate programs of the Agency play a primary role in preparing candidate countries to become eligible countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ed10ab-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tVI/s615"},"text":"Pub. L. 108–199, div. D, title VI, § 615","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/224"},"text":"118 Stat. 224","children":[],"tail":".)———*"}],"tail":"\n"}],"tail":null}
