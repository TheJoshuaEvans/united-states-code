{"tag":"section","attrib":{"id":"id9030c437-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281"},"text":null,"children":[{"tag":"num","attrib":{"value":"3281"},"text":"§ 3281.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual Presidential report to Congress on governmental efforts to prevent proliferation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9030c438-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of Government activities; description of progress; assessment of impact of prog­ress; determinations regarding non-nuclear-weapon states; counterproductiveness of policies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall review all activities of Government departments and agencies relating to preventing proliferation and shall make a report to Congress in January of 1979 and annually in January of each year thereafter on the Government’s efforts to prevent proliferation. This report shall include but not be limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9030c439-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the progress made toward—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9030c43a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negotiating the initiatives contemplated in sections 3223 and 3224 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9030c43b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negotiating the international arrangements or other mutual undertakings contemplated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2153b"},"text":"section 2153b of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9030c43c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging non-nuclear-weapon states that are not party to the Treaty to adhere to the Treaty or, pending such adherence, to enter into comparable agreements with respect to safeguards and to foreswear the development of any nuclear explosive devices, and discouraging nuclear exports to non-nuclear-weapon states which have not taken such steps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9030c43d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening the safeguards of the IAEA as contemplated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3241"},"text":"section 3241 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9030c43e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renegotiating agreements for cooperation as contemplated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2153c/a"},"text":"section 2153c(a) of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9030c43f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the impact of the progress described in paragraph (1) on the non-proliferation policy of the United States; an explanation of the precise reasons why progress has not been made on any particular point and recommendations with respect to appropriate measures to encourage progress; and a statement of what legislative modifications, if any, are necessary in his judgment to achieve the non-proliferation policy of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9030c440-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a determination as to which non-nuclear-weapon states with which the United States has an agreement for cooperation in effect or under negotiation, if any, have—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9030c441-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detonated a nuclear device; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9030c442-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refused to accept the safeguards of the IAEA on all of their peaceful nuclear activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9030c443-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refused to give specific assurances that they will not manufacture or otherwise acquire any nuclear explosive device; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9030c444-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in activities involving source or special nuclear material and having direct significance for the manufacture or acquisition of nuclear explosive devices;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9030c445-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of whether any of the policies set forth in this chapter have, on balance, been counterproductive from the standpoint of preventing proliferation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9030c446-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the progress made toward establishing procedures to facilitate the timely processing of requests for subsequent arrangements and export licenses in order to enhance the reliability of the United States in meeting its commitments to supply nuclear reactors and fuel to nations which adhere to effective non-proliferation policies; ","children":[{"tag":"ref","attrib":{"idref":"fn002246"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002246"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “; and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9030c447-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the implementation of nuclear and nuclear-related dual-use export controls in the preceding calendar year, including a summary by type of commodity and destination of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9030c448-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" all transactions for which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9030c449-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an export license was issued for any good controlled under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2139a/c"},"text":"section 2139a(c) of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9030c44a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an export license was issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2139/b"},"text":"section 2139(b) of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9030c44b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approvals were issued under the Export Administration Act of 1979, or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2139/b/3"},"text":"section 2139(b)(3) of title 42","children":[],"tail":", for the retransfer of any item, technical data, component, or substance; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9030c44c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizations were made as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2077/b/2"},"text":"section 2077(b)(2) of title 42","children":[],"tail":" to engage, directly or indirectly, in the production of special nuclear material;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9030c44d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each instance in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9030c44e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sanction has been imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6301/a"},"text":"section 6301(a) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6303"},"text":"section 6303 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2799aa–1/b/1"},"text":"section 2799aa–1(b)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9030c44f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sales or leases have been denied under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2753/f"},"text":"section 2753(f) of this title","children":[],"tail":" or transactions prohibited by reason of acts relating to proliferation of nuclear explosive devices as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2780/d"},"text":"section 2780(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9030c450-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sanction has not been imposed by reason of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6301/c/2"},"text":"section 6301(c)(2) of this title","children":[],"tail":" or the imposition of a sanction has been delayed under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2799aa–1/b/4"},"text":"section 2799aa–1(b)(4) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9030c451-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/6/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a waiver of a sanction has been made under—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id9030c452-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/6/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/us