ildren":[],"tail":", the last sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2780/d"},"text":"section 2780(d) of this title","children":[],"tail":", or 2799aa–1(b)(1) "},{"tag":"ref","attrib":{"idref":"fn002247"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002247"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be preceded by “section”."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9030c456-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of those independent states of the former Soviet Union that are non-nuclear-weapon states and of the Baltic states towards achieving the objective of applying full scope safeguards to all their peaceful nuclear activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Portions of the information required by paragraph (6) may be submitted in classified form, as necessary. Any such information that may not be published or disclosed under section 12(c)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002248"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002248"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" See References in Text note below."}],"tail":" of the Export Administration Act of 1979 shall be submitted as confidential."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9030c457-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3281/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis of civil agreements for cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the first report required by this section, the President shall analyze each civil agreement for cooperation negotiated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2153"},"text":"section 2153 of title 42","children":[],"tail":", and shall discuss the scope and adequacy of the requirements and obligations relating to safeguards and other controls therein."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9030c458-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/242/tVI/s601"},"text":"Pub. L. 95–242, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-10"},"text":"Mar. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/150"},"text":"92 Stat. 150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVIII/s811"},"text":"Pub. L. 103–236, title VIII, § 811","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/507"},"text":"108 Stat. 507","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9030c459-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9030c45a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9030c45b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec