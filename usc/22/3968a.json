{"tag":"section","attrib":{"id":"id90522f21-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3968a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3968a"},"text":"§ 3968a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Locally-employed staff wages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90522f22-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3968a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Market-responsive staff wages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", and every 3 years thereafter, the Secretary shall establish and implement a prevailing wage rates goal for positions in the local compensation plan, as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3968"},"text":"section 3968 of this title","children":[],"tail":", at each diplomatic post that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90522f23-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3968a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on the specific recruiting and retention needs of each such post and local labor market conditions, as determined annually; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90522f24-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3968a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not less than the 50th percentile of the prevailing wage for comparable employment in the labor market surrounding each such post.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90522f25-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3968a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prevailing wage rate goal established under subsection (a) shall not apply if compliance with such subsection would be inconsistent with applicable United States law, the law in the locality of employment, or the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90522f26-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3968a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The analytical assumptions underlying the calculation of wage levels at each diplomatic post under subsection (a), and the data upon which such calculation is based—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90522f27-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3968a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be filed electronically and retained for not less than 5 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90522f28-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3968a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made available to the appropriate congressional committees upon request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90522f29-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/tIV/s401"},"text":"Pub. L. 114–323, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1926"},"text":"130 Stat. 1926","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXII/s6226/a"},"text":"Pub. L. 118–31, div. F, title LXII, § 6226(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/980"},"text":"137 Stat. 980","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90522f2a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90522f2b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90522f2c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of State Authorities Act, Fiscal Year 2017, and not as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90522f2d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" substituted “every 3 years” for “periodically” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90522f2e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id90522f2f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary” and “appropriate congressional committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s2"},"text":"section 2 of Pub. L. 114–323","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
