{"tag":"section","attrib":{"id":"id8f2ce9c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2075"},"text":null,"children":[{"tag":"num","attrib":{"value":"2075"},"text":"§ 2075.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center for Cultural and Technical Interchange Between North and South","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f2ce9c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2075/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Dante B. Fascell North-South Center Act of 1991” ","children":[{"tag":"ref","attrib":{"idref":"fn002085"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002085"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2ce9c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2075/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to promote better relations between the United States and the nations of Latin America and the Caribbean and Canada through cooperative study, training, and research, by supporting in Florida a Center for Cultural and Technical Interchange Between North and South where scholars and students in various fields from the nations of the hemisphere may study, give and receive training, exchange ideas and views, and conduct other activities consistent with the objectives of the Mutual Educational and Cultural Exchange Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"22 U.S.C. 2451","children":[],"tail":" et seq.] and other Acts promoting international, educational, cultural, scientific, and related activities of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2ce9c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2075/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dante B. Fascell North-South Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out the purpose of this section, the Director of the United States Information Agency shall provide for the operation in Florida of an educational institution which shall be known and designated as the Dante B. Fascell North-South Center, through arrangements with public, educational, or other nonprofit institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2ce9c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2075/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the United States Information Agency, in carrying out this section, may utilize the authorities of the Mutual Educational and Cultural Exchange Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"22 U.S.C. 2451","children":[],"tail":" et seq.]. "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2056/b"},"text":"Section 2056(b) of this title","children":[],"tail":" shall apply in the administration of this section. In order to carry out the purposes of this section, the Dante B. Fascell North-South Center is authorized to use funds made available under this section to acquire property and facilities, by construction, lease, or purchase."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2ce9c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2075/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $5,000,000 for fiscal year 1992 and $10,000,000 for each subsequent fiscal year to carry out this section. Amounts appropriated under this section are authorized to be available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f2f32b7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/tII/s208"},"text":"Pub. L. 102–138, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/694"},"text":"105 Stat. 694","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/29/s1"},"text":"Pub. L. 106–29, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-05-21"},"text":"May 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/54"},"text":"113 Stat. 54","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f2f32b8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f2f32b9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f2f32ba-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Mutual Educational and Cultural Exchange Act of 1961, referred to in subsecs. (b) and (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/256"},"text":"Pub. L. 87–256","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-21"},"text":"Sept. 21, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/527"},"text":"75 Stat. 527","children":[],"tail":", which is classified principally to chapter 33 (§ 2451 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"section 2451 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f2f32bb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/s208"},"text":"section 208 of Pub. L. 102–138","children":[],"tail":". Subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/s208"},"text":"section 208 of Pub. L. 102–138","children":[],"tail":" repealed a prior "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2075"},"text":"section 2075 of this title","children":[],"tail":". See Prior Provisions note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8f2f32bc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2075, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513/tII"},"text":"Pub. L. 101–513, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1984"},"text":"104 Stat. 1984","children":[],"tail":", was based on section 206 of title II of the House engrossed amendment (as passed the House of Representatives on "},{"tag":"date","attrib":{"date":"1990-05-24"},"text":"May 24, 1990","children":[],"tail":") to S. 2364, One Hundred First Congress, which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/101/513"},"text":"Pub. L. 101–513","children":[],"tail":", and which was cited as the “Center for Cultural and Technical Interchange between North and South Act of 1990”, established a North-South Center in Florida to promote better relations between the United States and the nations of Latin America and the Caribbean and Canada through study, training, exchange of ideas and views, and other activities in support of the objectives of the United States Information and Educational Exchange Act of 1948, prior to repeal, effective "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tII/s208/f"},"text":"Pub. L. 102–138, title II, § 208(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/694"},"text":"105 Stat. 694","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f2f32bd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/29/s1/1"},"text":"Pub. L. 106–29, § 1(1)","children":[],"tail":", added subsec. (a) and struck out heading and text of former subsec. (a). Text read as follows: “This section may be cited as the ‘North/South Center Act of 1991’.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/29/s1/2/A"},"text":"Pub. L. 106–29, § 1(2)(A)","children":[],"tail":", amended subsec. heading generally. Prior to amendment, heading read as follows: “North/South Center”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/29/s1/2/B"},"text":"Pub. L. 106–29, § 1(2)(B)","children":[],"tail":", substituted “which shall be known and designated as the Dante B. Fascell North-South Center,” for “known as the North/South Center,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/29/s1/3"},"text":"Pub. L. 106–29, § 1(3)","children":[],"tail":", substituted “Dante B. Fascell North-South Center” for “North/South Center”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f2f32be-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id8f2f32bf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/29/s2"},"text":"Pub. L. 106–29, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-05-21"},"text":"May 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/54"},"text":"113 Stat. 54","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/29/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Center","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in any other provision of law to the educational institution in Florida known as the North/South Center shall be deemed to be a reference to the ‘Dante B. Fascell North-South Center’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Short Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in any other provision of law to the North/South Center Act of 1991 shall be deemed to be a reference to the ‘Dante B. Fascell North-South Center Act of 1991’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id8f2f32c0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau) abolished and functions transferred to Secretary of State, see sections 6531 and 6532 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
