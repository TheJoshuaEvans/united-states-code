{"tag":"section","attrib":{"id":"id8eea1458-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s305"},"text":null,"children":[{"tag":"num","attrib":{"value":"305"},"text":"§ 305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Growth projections for new embassies and consulates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eea1459-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each new United States embassy compound (NEC) and new consulate compound project (NCC) in or not yet in the design phase as of ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", the Department shall project growth over the estimated life of the facility using all available and relevant data, including the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eea145a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Relevant historical trends for Department personnel and personnel from other agencies represented at the NEC or NCC that is to be constructed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eea145b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis of the tradeoffs between risk and the needs of United States Government policy conducted as part of the most recent Vital Presence Validation Process, if applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eea145c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s305/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reasonable assumptions about the strategic importance of the NEC or NCC, as the case may be, over the life of the building at issue.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eea145d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s305/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other data that would be helpful in projecting the future growth of NEC or NCC.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eea145e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of each Federal agency represented at a United States embassy or consulate shall provide to the Secretary, upon request, growth projections for the personnel of each such agency over the estimated life of each embassy or consulate, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eea145f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for estimates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department shall base its growth assumption for all NECs and NCCs on the estimates required under subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eea1460-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any congressional notification of site selection for a NEC or NCC submitted after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":" shall include the growth assumption used pursuant to subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eea1461-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLII/s5205"},"text":"Pub. L. 117–81, div. E, title LII, § 5205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2355"},"text":"135 Stat. 2355","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eea1462-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eea1463-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8eea1464-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of State Authorization Act of 2021 and also as part of the National Defense Authorization Act for Fiscal Year 2022, and not as part of the Foreign Service Buildings Act, 1926, which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eea1465-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8eea1466-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Department” and “Secretary” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s5002"},"text":"section 5002 of Pub. L. 117–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s263c"},"text":"section 263c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
