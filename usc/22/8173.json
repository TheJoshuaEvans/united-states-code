{"tag":"section","attrib":{"id":"id90f6ad3d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8173"},"text":null,"children":[{"tag":"num","attrib":{"value":"8173"},"text":"§ 8173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of reports on United States declarations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The reports required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8171"},"text":"section 8171 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8172"},"text":"section 8172 of this title","children":[],"tail":" shall present the reasons for each site, location, facility, and activity being declared or being removed from the declaration list and shall certify that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f6ad3e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8173/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each site, location, facility, and activity included in the list has been examined by each agency with national security equities with respect to such site, location, facility, or activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6ad3f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8173/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate measures have been taken to ensure that information of direct national security significance will not be compromised at any such site, location, facility, or activity in connection with an IAEA inspection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f6ad40-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/401/tII/s273"},"text":"Pub. L. 109–401, title II, § 273","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-18"},"text":"Dec. 18, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2752"},"text":"120 Stat. 2752","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
