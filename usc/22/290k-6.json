{"tag":"section","attrib":{"id":"id8ee2e7f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290k–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"290k–6"},"text":"§ 290k–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Unless authorized by law, neither the President nor any person or agency shall, on behalf of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ee2e7f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290k–6/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subscribe to additional shares of stock of the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee2e7f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290k–6/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vote for or agree to any amendment of the Convention which increases the obligations of the United States, or which changes the purpose or functions of the Agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee2e7f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290k–6/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a loan or provide other financing to the Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee2e7f8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tI"},"text":"Pub. L. 100–202, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/10