{"tag":"section","attrib":{"id":"id8e8f6fe9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262e"},"text":null,"children":[{"tag":"num","attrib":{"value":"262e"},"text":"§ 262e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparability of salaries and benefits of employees of international financial institutions with employees of American private business and governmental service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President shall direct the United States Executive Directors of such international financial institutions to take all appropriate actions to keep the salaries and benefits of the employees of such institutions to levels comparable to salaries and benefits of employees of private business and the United States Government in comparable positions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8e8f6fea-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tVII/s704"},"text":"Pub. L. 95–118, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-03"},"text":"Oct. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1071"},"text":"91 Stat. 1071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e8f6feb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e8f6fec-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8e8f6fed-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-03"},"text":"Oct. 3, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/118/s1001"},"text":"section 1001 of Pub. L. 95–118","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s282i"},"text":"section 282i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
