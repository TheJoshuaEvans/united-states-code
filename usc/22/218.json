{"tag":"section","attrib":{"id":"id8e85f9f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s218"},"text":null,"children":[{"tag":"num","attrib":{"value":"218"},"text":"§ 218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Returns as to passports issued, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All persons who shall be authorized to grant, issue, or verify passports, shall make return of the same to the Secretary of State, in such manner and as often as he shall require; and such returns shall specify the names and all other particulars of the persons to whom the same shall be granted, issued, or verified, as embraced in such passport.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8e85f9f2-2930-11f1-8918-be39dde81dc6"},"text":"(R.S. § 4077.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e85f9f3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e85f9f4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8e85f9f5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4077 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1866-05-30/ch102"},"text":"act May 30, 1866, ch. 102","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/54"},"text":"14 Stat. 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
