{"tag":"section","attrib":{"id":"id90c95a7c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6903"},"text":null,"children":[{"tag":"num","attrib":{"value":"6903"},"text":"§ 6903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c95a7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6903/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispute Settlement Understanding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Dispute Settlement Understanding” means the Understanding on Rules and Procedures Governing the Settlement of Disputes referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3511/d/16"},"text":"section 3511(d)(16) of title 19","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c95a7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6903/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government of the People’s Republic of China","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Government of the People’s Republic of China” means the central Government of the People’s Republic of China and any other governmental entity, including any provincial, prefectural, or local entity and any enterprise that is controlled by the central Government or any such governmental entity or as to which the central Government or any such governmental entity is entitled to receive a majority of the profits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c95a7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6903/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internationally recognized worker rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “internationally recognized worker rights” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2467/4"},"text":"section 2467(4) of title 19","children":[],"tail":" and includes the right to the elimination of the “worst forms of child labor”, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2467/6"},"text":"section 2467(6) of title 19","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c95a80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6903/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade Representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Trade Representative” means the United States Trade Representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c95a81-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6903/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" WTO; World Trade Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “WTO” and “World Trade Organization” mean the organization established pursuant to the WTO Agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c95a82-2930-11f1-8918-be39dde81dc6","i