{"tag":"section","attrib":{"id":"id904648a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3754"},"text":null,"children":[{"tag":"num","attrib":{"value":"3754"},"text":"§ 3754.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional restraints on property transfers and tax expenditures; formal apprisal of Panama","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904648a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3754/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Congress enacts this section in the exercise of its authority under Article IV, section 3, clause 2 of the Constitution of the United States to dispose of and make necessary rules and regulations with respect to property of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904648a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3754/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Prior to the transfer of property of the United States located in the Republic of Panama to the Republic of Panama pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3784"},"text":"section 3784 of this title","children":[],"tail":" the President shall formally advise the Government of Panama that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id904648aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3754/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in fulfilling its obligations under the Panama Canal Treaty of 1977, the United States shall make no payments to the Republic of Panama derived from tax revenues of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904648ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3754/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States retains full discretion and authority to determine whether and the extent to which tax revenues of the United States may be expended in exercising United States rights and carrying out United States responsibilities under the Panama Canal Treaty of 1977 and related agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904648ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3754/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no tax revenues of the United States shall be made available for obligations and expenditure after ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", for purposes of implementing the Panama Canal Treaty of 1977 and related agreements, unless hereafter specifically approved by the Congress through the authorization and appropriation process;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904648ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3754/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount expended by the Commission from funds available for the use of the Commission shall not exceed the total amount deposited in the Panama Canal Revolving Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904648ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3754/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foregoing paragraphs of this subsection do not apply to expenditures made by the United States in fulfilling United States obligations to transfer the remains of our honored dead from Mount Hope Cemetery in the former Canal Zone to an appropriate and dignified resting place in accordance with Reservation 3 to the Treaty Concerning the Permanent Neutrality and Operation of the Panama Canal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904648af-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1344"},"text":"Pub. L. 96–70, title I, § 1344","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/484"},"text":"93 Stat. 484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5428/c"},"text":"Pub. L. 100–203, title V, § 5428(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-274"},"text":"101 Stat. 1330–274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904648b0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904648b1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id904648b2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" substituted “available” for “appropriated to or” and “Panama Canal Revolving Fund” for “Panama Canal Commission Fund”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id904648b3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id904648b4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1988-01-01"},"text":"Jan. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/s5429"},"text":"section 5429 of Pub. L. 100–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3712"},"text":"section 3712 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id904648b5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id904648b6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested in President by subsec. (b) delegated to Secretary of State, see section 1–402 of Ex. Ord. No. 12215, ","children":[{"tag":"date","attrib":{"date":"1980-05-27"},"text":"May 27, 1980","children":[],"tail":", 45 F.R. 36044, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
