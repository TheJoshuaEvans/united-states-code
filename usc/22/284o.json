{"tag":"section","attrib":{"id":"id8ebcc1ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284o"},"text":null,"children":[{"tag":"num","attrib":{"value":"284o"},"text":"§ 284o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sixth replenishment; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc1ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor is authorized to agree on behalf of the United States to pay to the Association $3,240,000,000 as the United States contribution to the sixth replenishment of the resources of the Association: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That any commitment to make such contributions shall be made subject to obtaining the necessary appropriations."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc1f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contributions provided for in this section, there is authorized to be appropriated, without fiscal year limitation, $3,240,000,000 for payment by the Secretary of the Treasury: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That not more than $850,000,000 of such sum may be made available for the fiscal year 1982 and not more than $945,000,000 of such sum may be made available for the fiscal year 1983."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc1f1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s17"},"text":"Pub. L. 86–565, § 17","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXIII/s1321"},"text":"Pub. L. 97–35, title XIII, § 1321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/740"},"text":"95 Stat. 740","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ebcc1f2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ebcc1f3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8ebcc1f4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1372"},"text":"section 1372 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s290i"},"text":"section 290i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
