{"tag":"section","attrib":{"id":"id9123ff08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9269b"},"text":null,"children":[{"tag":"num","attrib":{"value":"9269b"},"text":"§ 9269b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers, exemptions, and termination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9123ff09-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9269b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9123ff0a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9269b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9123ff0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9269b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9265"},"text":"section 9265 of this title","children":[],"tail":", the President may suspend the application of any provision of or amendment made by this subtitle "},{"tag":"ref","attrib":{"idref":"fn002433"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002433"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" (other than "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9269d"},"text":"section 9269d of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9221b/e"},"text":"section 9221b(e) of this title","children":[],"tail":", as added by section 7121 "},{"tag":"ref","attrib":{"idref":"fn002433"},"text":"1","children":[],"tail":" of this title) with respect to an entity, individual, or transaction, for renewable periods of not more than 180 days each if, before such a suspension or renewal of such a suspension takes effect, the President submits to the appropriate congressional committees—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9123ff0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9269b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a certification that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9123ff0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9269b/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Government of North Korea has—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id9123ff0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9269b/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committed to the verifiable suspension of North Korea’s proliferation and testing of weapons of mass destruction, including systems designed in whole or in part for the delivery of such weapons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9123ff0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9269b/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has agreed to multilateral talks including the Government of the United States, with the goal of permanently and verifiably limiting North Korea’s weapons of mass destruction and ballistic missile programs; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9123ff10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9269b/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the suspension is vital to the national security interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123ff11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9269b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the President submits a certification under subparagraph (A)(ii), an explanation of the reasons the suspension is vital to the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123ff12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9269b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9123ff13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9269b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9265"},"text":"section 9265 of this title","children":[],"tail":", any requirement to impose sanctions under this subtitle "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":