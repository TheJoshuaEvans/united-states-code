{"tag":"section","attrib":{"id":"id8ee2e7ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290k–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"290k–5"},"text":"§ 290k–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Bretton Woods Agreements Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s286b"},"text":"section 286b of this title","children":[],"tail":" shall apply with respect to the Agency to the same extent as with respect to the Bank and the International Monetary Fund."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ee2e7ee-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tI"},"text":"Pub. L. 100–202, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-131"},"text":"101 Stat. 1329–131","children":[],"tail":", 1329–134; "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tV/s541/e/5"},"text":"Pub. L. 101–240, title V, § 541(e)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2518"},"text":"103 Stat. 2518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ee2e7ef-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ee2e7f0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ee2e7f1-2930-11f1-8918-be3