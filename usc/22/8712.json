{"tag":"section","attrib":{"id":"id910c3064-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712"},"text":null,"children":[{"tag":"num","attrib":{"value":"8712"},"text":"§ 8712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diplomatic efforts to expand multilateral sanctions regime","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id910c3065-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multilateral negotiations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress urges the President to intensify diplomatic efforts, both in appropriate international fora such as the United Nations and bilaterally with allies of the United States, for the purpose of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910c3066-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" expanding the United Nations Security Council sanctions regime to include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910c3067-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a prohibition on the issuance of visas to any official of the Government of Iran who is involved in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id910c3068-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human rights violations in or outside of Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910c3069-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of a nuclear weapons program and a ballistic missile capability in Iran; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910c306a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support by the Government of Iran for terrorist organizations, including Hamas and Hezbollah; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910c306b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a requirement that each member country of the United Nations—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id910c306c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit the Islamic Republic of Iran Shipping Lines from landing at seaports, and cargo flights of Iran Air from landing at airports, in that country because of the role of those organizations in proliferation and illegal arms sales; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910c306d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply the prohibitions described in clause (i) to other Iranian entities designated for the imposition of sanctions on or after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910c306e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding the range of sanctions imposed with respect to Iran by allies of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910c306f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding efforts to limit the development of petroleum resources and the importation of refined petroleum products by Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910c3070-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing additional initiatives to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910c3071-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the production of crude oil in countries other than Iran; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910c3072-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist countries that purchase or otherwise obtain crude oil or petroleum products from Iran to eliminate their dependence on crude oil and petroleum products from Iran; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910c3073-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminating the revenue generated by the Government of Iran from the sale of petrochemical products produced in Iran to other countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910c3074-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", and every 180 days thereafter, the President shall submit to the appropriate congressional committees a report on the extent to which diplomatic efforts described in subsection (a) have been successful that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id910c3075-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the countries that have agreed to impose sanctions or take other measures to further the policy set forth in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910c3076-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent of the implementation and enforcement of those sanctions or other measures by those countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910c3077-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria the President uses to determine whether a country has significantly reduced its crude oil purchases from Iran pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513a/d/4/D"},"text":"section 8513a(d)(4)(D) of this title","children":[],"tail":", as amended by section 504, including considerations of reductions both in terms of volume and price;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910c3078-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the countries that have not agreed to impose such sanctions or measures, including such countries granted exceptions for significant reductions in crude oil purchases pursuant to such section 8513a(d)(4)(D);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910c3079-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for additional measures that the United States could take to further diplomatic efforts described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910c307a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8712/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposition of any decision with respect to sanctions imposed with respect to Iran by the World Trade Organization or its predecessor organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910c307b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158/tI/s102"},"text":"Pub. L. 112–158, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1218"},"text":"126 Stat. 1218","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id910c307c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id910c307d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8785/a"},"text":"section 8785(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id910c307e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id910c307f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513a/d/4/D"},"text":"Section 8513a(d)(4)(D) of this title","children":[],"tail":", as amended by section 504, referred to in subsec. (b)(3), means "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513a/d/4/D"},"text":"section 8513a(d)(4)(D) of this title","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/158/s504"},"text":"section 504 of Pub. L. 112–158","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
