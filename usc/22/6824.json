{"tag":"section","attrib":{"id":"id90c4a134-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6824"},"text":null,"children":[{"tag":"num","attrib":{"value":"6824"},"text":"§ 6824.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c4a135-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6824/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There should be an Advisory Board to the Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a136-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6824/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Advisory Board should be drawn from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a137-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6824/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a broad range of individuals with experience and leadership in the fields of development, health care (especially HIV/AIDS), epidemiology, medicine, biomedical research, and social sciences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a138-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6824/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of relevant United Nations agencies and nongovernmental organizations with on-the-ground experience in affected countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c6ea29-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6824/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Board should provide advice and guidance to the Board of Trustees on the development and implementation of programs and projects to be assisted by the Trust Fund and on leveraging donations to the Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c6ea2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6824/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on payment of compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c6ea2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6824/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except for travel expenses (including per diem in lieu of subsistence), no member of the Advisory Board should receive compensation for services performed as a member of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c6ea2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6824/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law (including an international agreement), a representative of the United States on the Advisory Board may not accept compensation for services performed as a member of the Board, except that such representative may accept travel expenses, including per diem in lieu of subsistence, while away from the representative’s home or regular place of business in the performance of services for the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c6ea2d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/264/tI/s124"},"text":"Pub. L. 106–264, title I, § 124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-19"},"text":"Aug. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/756"},"text":"114 Stat. 756","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
