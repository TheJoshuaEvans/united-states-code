{"tag":"section","attrib":{"id":"id909022cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5505"},"text":null,"children":[{"tag":"num","attrib":{"value":"5505"},"text":"§ 5505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster training for State Department personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id909022cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall institute a supplemental program of training in disaster management for all consular officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id909022cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training improvements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id909022ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In expanding the training program under subsection (a), the Secretary of State shall consult with death and bereavement counselors concerning the particular demands posed by aviation tragedies and terrorist activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id909022cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In providing such additional training under subsection (a) the Secretary of State shall consider supplementing the current training program through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id909022d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5505/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing specialized training to create a team of “disaster specialists” to deploy immediately in a crisis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id909022d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5505/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing outside experts to be brought in during the initial phases to assist consular personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id909022d2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/604/tII/s206"},"text":"Pub. L. 101–604, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3084"},"text":"104 Stat. 3084","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
