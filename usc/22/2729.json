{"tag":"section","attrib":{"id":"id900101a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2729"},"text":null,"children":[{"tag":"num","attrib":{"value":"2729"},"text":"§ 2729.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Department records of overseas deaths of United States citizens from nonnatural causes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id900101a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2729/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, to the maximum extent practicable, collect, with respect to each foreign country, the following information with respect to each United States citizen who dies in that country from a nonnatural cause on or after ","children":[{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id900101a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2729/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date of death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id900101a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2729/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The locality where the death occurred (including the state or province and municipality, if available).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id900101a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2729/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cause of death, including information on the circumstances of the death, and including, if the death resulted from an act of terrorism, a statement disclosing that information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id900101a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2729/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id900101a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2729/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Database","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and maintain a database containing the information collected under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id900101aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2729/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning three months after ","children":[{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":", the Secretary, shall make available, on a country-by-country basis, on the Internet website of the Department’s Bureau of Consular Affairs, the information from the database described in subsection (b) with respect to deaths occurring since "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":", or occurring during the preceding three calendar years, whichever period is shorter. The information shall be updated at least every six months."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id900101ab-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 57, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tII/s204"},"text":"Pub. L. 107–228, div. A, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1363"},"text":"116 Stat. 1363","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
