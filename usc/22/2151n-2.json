{"tag":"section","attrib":{"id":"id8f5558c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151n–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2151n–2"},"text":"§ 2151n–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human Rights and Democracy Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f5558c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151n–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a Human Rights and Democracy Fund (in this section referred to as the “Fund”) to be administered by the Assistant Secretary of State for Democracy, Human Rights, and Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f5558c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151n–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of Fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Fund shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f5558ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151n–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support defenders of human rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5558cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151n–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the victims of human rights violations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5558cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151n–2/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to respond to human rights emergencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5558cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151n–2/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote and encourage the growth of democracy, including the support for nongovernmental organizations in foreign countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5558ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151n–2/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out such other related activities as are consistent with paragraphs (1) through (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f5558cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151n–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f5558d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151n–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts made available to carry out chapter 4 of part II of the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"22 U.S.C. 2346","children":[],"tail":" et seq.] for fiscal year 2003, $21,500,000 is authorized to be available to the Fund for carrying out the purposes described in subsection (b). Amounts made available to the Fund under this paragraph shall also be deemed to have been made available under section 116(e) of the Foreign Assistance Act of 1961 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151n/e"},"text":"22 U.S.C. 2151n(e)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5558d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151n–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds for the Documentation Center of Cambodia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount authorized to be available to the Fund under paragraph (1) for fiscal year 2003, $1,000,000 is authorized to be available for the Documentation Center of Cambodia for the purpose of collecting, cataloguing, and disseminating information about the atrocities committed by the Khmer Rouge against the Cambodian people.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5558d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151n–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Father John Kaiser Memorial Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount authorized to be available to the Fund under paragraph (1) for fiscal year 2003, $500,000 is authorized to be available to advance the extraordinary work and values of Father John Kaiser with respect to solving ethnic conflict and promoting government accountability and respect for human rights. The amount made available under this paragraph may be referred to as the “Father John Kaiser Memorial Fund”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f5558d3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tVI/s664"},"text":"Pub. L. 107–228, div. A, title VI, § 664","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1406"},"text":"116 Stat. 1406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f5558d4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f5558d5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f5558d6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Chapter 4 of part II of the Act is classified generally to part IV (§ 2346 et seq.) of subchapter II of this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f5558d7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Freedom Investment Act of 2002, and also as part of the Department of State Authorization Act, Fiscal Year 2003 and the Foreign Relations Authorization Act, Fiscal Year 2003, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f5558d8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f5558d9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tVI/s662"},"text":"Pub. L. 107–228, div. A, title VI, § 662","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1405"},"text":"116 Stat. 1405","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/228/dA/tVI/s662"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purposes of this subtitle [subtitle E (§§ 661–665) of title VI of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":", see Short Title of 2002 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":"] are the following:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To underscore that promoting and protecting human rights is in the national interests of the United States and is consistent with American values and beliefs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish a goal of devoting one percent of the funds available to the Department under ‘Diplomatic and Consular Programs’, other than such funds that will be made available for worldwide security upgrades and information resource management, to enhance the ability of the United States to promote respect for human rights and the protection of human rights defenders.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “Department” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s662"},"text":"section 662 of Pub. L. 107–228","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/s3"},"text":"section 3 of Pub. L. 107–228","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
