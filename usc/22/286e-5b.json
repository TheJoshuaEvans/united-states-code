{"tag":"section","attrib":{"id":"id8ec3edcc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–5b"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–5b"},"text":"§ 286e–5b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of amendments to Articles of Agreement of the Fund approved on ","children":[{"tag":"date","attrib":{"date":"1990-06-28"},"text":"June 28, 1990","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund may agree to and accept the amendments to the Articles of Agreement of the Fund as proposed in the resolution numbered 45–3 of the Board of Governors of the Fund that was approved by such Board on ","children":[{"tag":"date","attrib":{"date":"1990-06-28"},"text":"June 28, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ec3edcd-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s57"},"text":"July 31, 1945, ch. 339, § 57","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/511/tX/s1001"},"text":"Pub. L. 102–511, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3357"},"text":"106 Stat. 3357","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
