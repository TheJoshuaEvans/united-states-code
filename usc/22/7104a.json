{"tag":"section","attrib":{"id":"id90d2d11f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7104a"},"text":"§ 7104a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance plan and certification requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90d2d120-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an executive agency may not provide or enter into a grant, contract, or cooperative agreement if the estimated value of the services required to be performed under the grant, contract, or cooperative agreement outside the United States exceeds $500,000, unless a duly designated representative of the recipient of such grant, contract, or cooperative agreement certifies to the contracting or grant officer prior to receiving an award and on an annual basis thereafter, after having conducted due diligence, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d2d121-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient has implemented a plan to prevent the activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7104/g"},"text":"section 7104(g) of this title","children":[],"tail":", as amended by section 1702, and is in compliance with that plan;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d2d122-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient has implemented procedures to prevent any activities described in such ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7104/g"},"text":"section 7104(g) of this title","children":[],"tail":" and to monitor, detect, and terminate any subcontractor, subgrantee, or employee of the recipient engaging in any activities described in such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d2d123-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the best of the representative’s knowledge, neither the recipient, nor any subcontractor or subgrantee of the recipient or any agent of the recipient or of such a subcontractor or subgrantee, is engaged in any of the activities described in such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d2d124-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any plan or procedures implemented pursuant to subsection (a) shall be appropriate to the size and complexity of the grant, contract, or cooperative agreement and to the nature and scope of its activities, including the number of non-United States citizens expected to be employed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d2d125-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient shall provide a copy of the plan to the contracting or grant officer upon request, and as appropriate, shall post the useful and relevant contents of the plan or related materials on its website and at the workplace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d2d126-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, in consultation with the Secretary of State, the Attorney General, the Secretary of Defense, the Secretary of Labor, the Secretary of Homeland Security, the Administrator for the United States Agency for International Development, and the heads of such other executive agencies as the President deems appropriate, shall establish minimum requirements for contractor plans and procedures to be implemented pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90d2d127-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXVII/s1703"},"text":"Pub. L. 112–239, div. A, title XVII, § 1703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2094"},"text":"126 Stat. 2094","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90d2d128-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90d2d129-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90d2d12a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7104/g"},"text":"Section 7104(g) of this title","children":[],"tail":", as amended by section 1702, referred to in subsec. (a)(1), means "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7104/g"},"text":"section 7104(g) of this title","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1702"},"text":"section 1702 of Pub. L. 112–239","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90d2d12b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2013, and not as part of the Trafficking Victims Protection Act of 2000 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90d2d12c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90d2d12d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Requirements of section applicable to grants, contracts, and cooperative agreements entered into on or after the date that is 270 days after ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", and to task and delivery orders awarded on or after "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", pursuant to contracts entered before, on, or after such date, see "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7104d/c/1/B"},"text":"section 7104d(c)(1)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id90d2d12e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXVII/s1701"},"text":"Pub. L. 112–239, div. A, title XVII, § 1701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2092"},"text":"126 Stat. 2092","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/239/dA/tXVII/s1701"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [title XVII (§§ 1701–1708) of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":", enacting this section and sections 7104b to 7104d of this title, amending sections 7103 and 7104 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1351"},"text":"section 1351 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s2313"},"text":"section 2313 of Title 41","children":[],"tail":", Public Contracts, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":", Aliens and Nationality]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘executive agency’ has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s133"},"text":"section 133 of title 41","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcontractor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘subcontractor’ means a recipient of a contract at any tier under a grant, contract, or cooperative agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subgrantee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘subgrantee’ means a recipient of a grant at any tier under a grant or cooperative agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘United States’ has the meaning provided in section 103(12) [now 103(15)] of the Trafficking Victims Protection Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/12"},"text":"22 U.S.C. 7102(12)","children":[],"tail":" [now 7102(15)]).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
