{"tag":"section","attrib":{"id":"id8fd3b09c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2521a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2521a"},"text":"§ 2521a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonpartisan appointments","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out this chapter, no political test or political qualification may be used in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fd3b09d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2521a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selecting any person for enrollment as a volunteer or for appointment to a position at, or for assignment to (or for employment for assignment to), a duty station located abroad, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd3b09e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2521a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting or taking any other action with respect to any volunteer or any person assigned to such a duty station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fd3b09f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/tI/s25"},"text":"Pub. L. 87–293, title I, § 25","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tXI/s1105/a/2"},"text":"Pub. L. 99–83, title XI, § 1105(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/276"},"text":"99 Stat. 276","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fd3b0a0-2930-11f1-8918-be39dde81dc