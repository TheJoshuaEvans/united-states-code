{"tag":"section","attrib":{"id":"id915399b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302"},"text":null,"children":[{"tag":"num","attrib":{"value":"10302"},"text":"§ 10302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International cyberspace and digital policy strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id915399b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the President, acting through the Secretary, and in coordination with the heads of other relevant Federal departments and agencies, shall develop an international cyberspace and digital policy strategy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915399b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy required under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915399b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of actions and activities undertaken to support the policy described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10301/a"},"text":"section 10301(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a plan of action to guide the diplomacy of the Department with regard to foreign countries, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915399b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conducting bilateral and multilateral activities—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id915399b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and support the implementation of norms of responsible country behavior in cyberspace consistent with the commitments listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10301/b/5"},"text":"section 10301(b)(5) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915399ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the frequency and severity of cyberattacks on United States individuals, businesses, governmental agencies, and other organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915399bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce cybersecurity risks to United States and allied critical infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915399bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve allies’ and partners’ collaboration with the United States on cybersecurity issues, including information sharing, regulatory coordination and improvement, and joint investigatory and law enforcement operations related to cybercrime; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id915399bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to share best practices and advance proposals to strengthen civilian and private sector resiliency to threats and access to opportunities in cyberspace; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915399be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing the status of existing efforts in relevant multilateral fora, as appropriate, to obtain commitments on international norms regarding cyberspace;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of alternative concepts for international norms regarding cyberspace offered by foreign countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a detailed description, in consultation with the Office of the National Cyber Director and relevant Federal agencies, of new and evolving threats regarding cyberspace from foreign adversaries, state-sponsored actors, and non-state actors to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915399c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States national security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915399c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal and private sector cyberspace infrastructure of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915399c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intellectual property in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915399c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the privacy and security of citizens of the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a review of the policy tools available to the President to deter and de-escalate tensions with foreign countries, state-sponsored actors, and private actors regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915399c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" threats in cyberspace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915399c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which such tools have been used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915399c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether such tools have been effective deterrents;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of resources required to conduct activities to build responsible norms of international cyber behavior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review, in coordination with the Office of the National Cyber Director and the Office of Management and Budget, to determine whether the budgetary resources, technical expertise, legal authorities, and personnel available to the Department are adequate to achieve the actions and activities undertaken by the Department to support the policy described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10301/a"},"text":"section 10301(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review to determine whether the Department is properly organized and coordinated with other Federal agencies to achieve the objectives described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10301/b"},"text":"section 10301(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan of action, developed in coordination with the Department of Defense and in consultation with other relevant Federal departments and agencies as the President may direct, with respect to the inclusion of cyber issues in mutual defense agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915399cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of strategy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915399ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The strategy required under subsection (a) shall be available to the public in unclassified form, including through publication in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified annex","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The strategy required under subsection (a) may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915399d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the completion of the strategy required under subsection (a), the Secretary shall brief the Committee on Foreign Relations of the Senate, the Select Committee on Intelligence of the Senate, the Committee on Armed Services of the Senate, the Committee on Foreign Affairs of the House of Representatives, the Permanent Select Committee on Intelligence of the House of Representatives, and the Committee on Armed Services of the House of Representatives regarding the strategy, including any material contained in a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915399d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy required under subsection (a) shall be updated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915399d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 90 days after any material change to United States policy described in such strategy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10302/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after the inauguration of each new President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id915399d4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCV/s9503"},"text":"Pub. L. 117–263, div. I, title XCV, § 9503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3902"},"text":"136 Stat. 3902","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id915399d5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id915399d6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id915399d7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” and “Department” as used in this section mean the Secretary and Department of State, unless otherwise specified, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s9002"},"text":"section 9002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
