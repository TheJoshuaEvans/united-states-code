{"tag":"section","attrib":{"id":"id902c09ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3007"},"text":null,"children":[{"tag":"num","attrib":{"value":"3007"},"text":"§ 3007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations for Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id902c09ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization; disbursements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id902c09ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated to the Commission for each fiscal year such sums as may be necessary to enable it to carry out its duties and functions. Appropriations to the Commission are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902c09af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Appropriations to the Commission shall be disbursed on vouchers approved—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id902c09b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3007/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jointly by the Chairman and the Cochairman, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id902c09b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3007/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a majority of the members of the personnel and administration committee established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3008/a"},"text":"section 3008(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id902c09b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of foreign currencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1754/b"},"text":"section 1754(b) of this title","children":[],"tail":", the Commission shall be deemed to be a standing committee of the Congress and shall be entitled to use funds in accordance with such sections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id902c09b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Official reception and representational expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not to exceed $6,000 of the funds appropriated to the Commission for each fiscal year may be used for official reception and representational expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id902c09b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3007/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign travel for official purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Foreign travel for official purposes by Commission members and staff may be authorized by either the Chairman or the Cochairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id902c09b5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/304/s7"},"text":"Pub. L. 94–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-03"},"text":"June 3, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/662"},"text":"90 Stat. 662","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/534"},"text":"Pub. L. 94–534","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-17"},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2495"},"text":"90 Stat. 2495","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/426/tVII/s702"},"text":"Pub. L. 95–426, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-07"},"text":"Oct. 7, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/992"},"text":"92 Stat. 992","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/60/tIV/s401"},"text":"Pub. L. 96–60, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-15"},"text":"Aug. 15, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/403"},"text":"93 Stat. 403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/7"},"text":"Pub. L. 99–7","children":[],"tail":", §§ 3, 4, "},{"tag":"date","attrib":{"date":"1985-03-27"},"text":"Mar. 27, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/19"},"text":"99 Stat. 19","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id902c09b6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id902c09b7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id902c09b8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/7/s3"},"text":"Pub. L. 99–7, § 3","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “There is authorized to be appropriated to the Commission for each fiscal year and to remain available until expended $550,000 to assist in meeting the expenses of the Commission for the purpose of carrying out the provisions of this chapter, such appropriation to be disbursed on voucher to be approved by the Chairman of the Commission.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/7/s4"},"text":"Pub. L. 99–7, § 4","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/60"},"text":"Pub. L. 96–60","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/426"},"text":"Pub. L. 95–426","children":[],"tail":" substituted “$550,000” for “$350,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/534"},"text":"Pub. L. 94–534","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id902c09b9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id902c09ba-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/7"},"text":"Pub. L. 99–7","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-04-15"},"text":"Apr. 15, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/7/s6/a"},"text":"section 6(a) of Pub. L. 99–7","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3002"},"text":"section 3002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
