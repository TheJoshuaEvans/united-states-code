{"tag":"section","attrib":{"id":"id8e9b5816-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p–3"},"text":"§ 262p–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of women in economic, social and policy development activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e9b5817-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress hereby declares that it is the policy of the United States that multilateral development banks should—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e9b5818-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fully involve women in borrowing countries in the identification, planning, implementation, and evaluation of mainstream development activities financed by such banks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b5819-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognize and support women’s direct and indirect roles in the economic development of their countries and communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b581a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognize and support women’s direct and indirect roles in the education and social development of, the maintenance of the health of, and in the provision of adequate nutrition for, family members and communities, especially children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b581b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–3/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work to remove legal and customary barriers which impede the full participation of women in economic and social development, such as lack of access to credit, property rights, education, health care, and government services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b581c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–3/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve women’s groups in borrowing countries in project identification and preparation in order to factor their assessments of women’s economic and social needs into project design.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e9b581d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Instructions by Secretary of the Treasury to United States Executive Directors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e9b581e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Executive Director of the International Bank for Reconstruction and Development and the International Development Association to support attempts to strengthen the role of the Women in Development division in policy development, project design and implementation, and evaluation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b581f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Executive Directors of the regional multilateral development banks to support exploring the establishment of a mechanism, or the strengthening of any existing mechanism, within each of the respective banks, to advise, advocate, and promote the full intergration ","children":[{"tag":"ref","attrib":{"idref":"fn002009"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “integration”."}],"tail":" of women in the planning, design, implementation, and evaluation of lending activities both in borrowing countries and within the banks."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e9b5820-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each annual report to the Congress by the National Advisory Council on International Monetary and Financial Policies shall describe the actions taken by the multilateral development banks to implement the policies established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e9b5821-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXVI/s1604"},"text":"Pub. L. 95–118, title XVI, § 1604","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tI"},"text":"Pub. L. 100–202, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-131"},"text":"101 Stat. 1329–131","children":[],"tail":", 1329–134.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e9b5822-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e9b5823-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8e9b5824-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/s1604"},"text":"Section 1604 of Pub. L. 95–118","children":[],"tail":" is based on section 701 of title VII of H.R. 3750, One Hundredth Congress, as introduced "},{"tag":"date","attrib":{"date":"1987-12-11"},"text":"Dec. 11, 1987","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e9b5825-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8e9b5826-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–5"},"text":"section 262p–5 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
