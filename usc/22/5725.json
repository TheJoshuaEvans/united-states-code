{"tag":"section","attrib":{"id":"id90974ecd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725"},"text":null,"children":[{"tag":"num","attrib":{"value":"5725"},"text":"§ 5725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of State report regarding the autonomy of Hong Kong","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90974ece-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90974ecf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), the Secretary of State, on at least an annual basis, and in conjunction with the report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5731"},"text":"section 5731 of this title","children":[],"tail":", shall issue a certification to Congress that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90974ed0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicates whether Hong Kong continues to warrant treatment under United States law in the same manner as United States laws were applied to Hong Kong before ","children":[{"tag":"date","attrib":{"date":"1997-07-01"},"text":"July 1, 1997","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90974ed1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" addresses—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90974ed2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ed3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement cooperation, including extradition requests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ed4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sanctions enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ed5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" export controls, and any other agreements and forms of exchange involving dual use, critical, or other sensitive technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ed6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any formal treaties or agreements between the United States and Hong Kong;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ed7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other areas of bilateral cooperation that the Secretary determines to be relevant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ed8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" decision-making within the Government of Hong Kong, including executive, legislative, and judicial structures, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id90974ed9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/vii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" freedom of assembly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id90974eda-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/vii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" freedom of speech;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id90974edb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/vii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" freedom of expression; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id90974edc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/vii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" freedom of the press, including the Internet and social media;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974edd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" universal suffrage, including the ultimate aim of the selection of the Chief Executive and all members of the Legislative Council by universal suffrage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ede-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" judicial independence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974edf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" police and security functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ee0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ee1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laws or regulations regarding treason, secession, sedition, subversion against the Central People’s Government of the People’s Republic of China, or theft of state secrets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ee2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laws or regulations regarding foreign political organizations or bodies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ee3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/xiv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiv"},"text":"(xiv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laws or regulations regarding political organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ee4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/B/xv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xv"},"text":"(xv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other rights enumerated in the Universal Declaration of Human Rights, done at Paris ","children":[{"tag":"date","attrib":{"date":"1948-12-10"},"text":"December 10, 1948","children":[],"tail":", and the International Covenant on Civil and Political Rights, done at New York "},{"tag":"date","attrib":{"date":"1966-12-19"},"text":"December 19, 1966","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90974ee5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90974ee6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the degree of any erosions to Hong Kong’s autonomy in each category listed in subparagraph (B) resulting from actions by the Government of the People’s Republic of China that are inconsistent with its commitments under the Basic Law or the Joint Declaration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ee7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the specific impacts to any areas of cooperation between the United States and Hong Kong resulting from erosions of autonomy in Hong Kong or failures of the Government of Hong Kong to fulfill obligations to the United States under international agreements within the categories listed in subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90974ee8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of any specific actions taken by the United States Government in response to any erosion of autonomy or failures to fulfill obligations to the United States under international agreements identified in this certification and the report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5731"},"text":"section 5731 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90974ee9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factor for consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making each certification under paragraph (1), the Secretary of State should consider the terms, obligations, and expectations expressed in the Joint Declaration with respect to Hong Kong.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90974eea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional certifications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The certification under section (1) shall be issued annually, but the Secretary may issue additional certifications at any time if the Secretary determines it is warranted by circumstances in Hong Kong.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90974eeb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90974eec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State may waive the application of subsection (a) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90974eed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that such a waiver is in the national security interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90974eee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or before the date on which the waiver takes effect, the Secretary notifies the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives of the intent to waive such subsection;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90974eef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5725/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partial waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except for the list of actions described in subsection (a)(1)(C)(iii), the Secretary of State may waive relevant parts of the application of subsection (a) if the President issues an Executive order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5722"},"text":"section 5722 of this title","children":[],"tail":" that suspends the application of any particular United States law to Hong Kong."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90974ef0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/383/tII/s205"},"text":"Pub. L. 102–383, title II, § 205","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/76/s4/a/2"},"text":"Pub. L. 116–76, § 4(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-11-27"},"text":"Nov. 27, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1163"},"text":"133 Stat. 1163","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
