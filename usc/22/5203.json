{"tag":"section","attrib":{"id":"id9088f729-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5203"},"text":null,"children":[{"tag":"num","attrib":{"value":"5203"},"text":"§ 5203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9088f72a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall take the necessary steps and institute the necessary legal action to effectuate the policies and provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9088f72b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any district court of the United States for a district in which a violation of this chapter occurs shall have authority, upon petition of relief by the Attorney General, to grant injunctive and such other equitable relief as it shall deem necessary to enforce the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9088f72c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tX/s1004"},"text":"Pub. L. 100–204, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1407"},"text":"101 Stat. 1407","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
