{"tag":"section","attrib":{"id":"id8f95bd0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"2349aa–10"},"text":"§ 2349aa–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antiterrorism assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f95bd0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f95bd0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to foreign countries to procure explosives detection devices and other counterterrorism technology","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f95bd10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–10/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349aa–4/b"},"text":"section 2349aa–4(b) of this title","children":[],"tail":", up to $3,000,000 in any fiscal year may be made available—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f95bd11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–10/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to procure explosives detection devices and other counterterrorism technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f95bd12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–10/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for joint counterterrorism research and development projects on such technology conducted with NATO and major non-NATO allies under the auspices of the Technical Support Working Group of the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f95bd13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–10/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this subsection, the term “major non-NATO allies” means those countries designated as major non-NATO allies for purposes of section 2350a(i)(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002138"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002138"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 10."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f95bd14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to foreign countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law (except ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2371"},"text":"section 2371 of this title","children":[],"tail":") up to $1,000,000 in assistance may be provided to a foreign country for counterterrorism efforts in any fiscal year if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f95bd15-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–10/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such assistance is provided for the purpose of protecting the property of the United States Government or the life and property of any United States citizen, or furthering the apprehension of any individual involved in any act of terrorism against such property or persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f95bd16-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–10/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate committees of Congress are notified not later than 15 days prior to the provision of such assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f95bd17-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIII/s328"},"text":"Pub. L. 104–132, title III, § 328","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1257"},"text":"110 Stat. 1257","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f95bd18-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f95bd19-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f95bd1a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349aa–4"},"text":"Section 2349aa–4 of this title","children":[],"tail":", referred to in subsec. (b)(1), was in the original “section 575”, which was translated as meaning section 575 of the Foreign Assistance Act of 1961. Section 575 of the Act was renumbered section 574 by "},{"tag":"ref","attrib":{"href":"/us/pl/104/164/s121/d"},"text":"section 121(d) of Pub. L. 104–164","children":[],"tail":" without corresponding amendment to this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2350a"},"text":"Section 2350a of title 10","children":[],"tail":", referred to in subsec. (b)(2), was subsequently amended, and section 2350a(i)(3) no longer defines the term “major non-NATO ally”. However, such term is defined elsewhere in that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f95bd1b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s328"},"text":"section 328 of Pub. L. 104–132","children":[],"tail":". Subsec. (a) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/s328"},"text":"section 328 of Pub. L. 104–132","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349aa–2"},"text":"section 2349aa–2 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Antiterrorism and Effective Death Penalty Act of 1996, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f95bd1c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f95bd1d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Assistance” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIII/s329"},"text":"Pub. L. 104–132, title III, § 329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1258"},"text":"110 Stat. 1258","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/132/tIII/s329"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“For purposes of this title [enacting this section and sections 262p–4q, 2377, 2378, and 2781 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1189"},"text":"section 1189 of Title 8","children":[],"tail":", Aliens and Nationality, and sections 2332d and 2339B of Title 18, Crimes and Criminal Procedure, amending "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349aa–2"},"text":"section 2349aa–2 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s2339A"},"text":"section 2339A of Title 18","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44906"},"text":"section 44906 of Title 49","children":[],"tail":", Transportation, and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2377"},"text":"section 2377 of this title","children":[],"tail":" and sections 2332d and 2339B of Title 18]—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘assistance’ means assistance to or for the benefit of a government of any country that is provided by grant, concessional sale, guaranty, insurance, or by any other means on terms more favorable than generally available in the applicable market, whether in the form of a loan, lease, credit, debt relief, or otherwise, including subsidies for exports to such country and favorable tariff treatment of articles that are the growth, product, or manufacture of such country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘assistance’ does not include assistance of the type authorized under chapter 9 of part 1 of the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292"},"text":"22 U.S.C. 2292","children":[],"tail":" et seq.] (relating to international disaster assistance).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
