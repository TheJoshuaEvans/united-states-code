{"tag":"section","attrib":{"id":"id90f1f1cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7843"},"text":null,"children":[{"tag":"num","attrib":{"value":"7843"},"text":"§ 7843.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitating submission of applications for admission as a refugee","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall undertake to facilitate the submission of applications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1157"},"text":"section 1157 of title 8","children":[],"tail":" by citizens of North Korea seeking protection as refugees (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/42"},"text":"section 1101(a)(42) of title 8","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90f1f1cc-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/333/tIII/s303"},"text":"Pub. L. 108–333, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1296"},"text":"118 Stat. 1296","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
