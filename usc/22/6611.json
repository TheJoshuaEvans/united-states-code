{"tag":"section","attrib":{"id":"id90bfbec5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6611"},"text":null,"children":[{"tag":"num","attrib":{"value":"6611"},"text":"§ 6611.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reorganization authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90bfbec6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6611/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized, subject to the requirements of this chapter, to allocate or reallocate any function transferred to the Department under any subchapter of this chapter, and to establish, consolidate, alter, or discontinue such organizational entities within the Department as may be necessary or appropriate to carry out any reorganization under this chapter, but this subsection does not authorize the Secretary to modify the terms of any statute that establishes or defines the functions of any bureau, office, or officer of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bfbec7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6611/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements and limitations on reorganization plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The reorganization plan transmitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6601"},"text":"section 6601 of this title","children":[],"tail":" may not have the effect of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bfbec8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6611/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating a new executive department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbec9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6611/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing a function beyond the period authorized by law for its exercise or beyond the time when it would have terminated if the reorganization had not been made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbeca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6611/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizing a Federal agency to exercise a function which is not authorized by law at the time the plan is transmitted to Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbecb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6611/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating a new Federal agency which is not a component or part of an existing executive department or independent agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbecc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6611/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the term of an office beyond that provided by law for the office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90bfbecd-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XVI, § 1611, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-798"},"text":"112 Stat. 2681–798","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90bfbece-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90bfbecf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90bfbed0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this subdivision”, meaning subdiv. A of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-765"},"text":"112 Stat. 2681–765","children":[],"tail":", known as the Foreign Affairs Agencies Consolidation Act of 1998. For complete classification of this subdivision to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6501"},"text":"section 6501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
