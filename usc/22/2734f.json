{"tag":"section","attrib":{"id":"id90037270-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2734f"},"text":"§ 2734f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic staffing plan for the Department of State","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90037271-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", the Secretary shall submit to the appropriate congressional committees and the Committees on Appropriations of the Senate and the House of Representatives a comprehensive 5-year strategic staffing plan for the Department that is aligned with and furthers the objectives of the National Security Strategy of the United States of America issued in December 2017, or any subsequent strategy issued not later than 18 months after "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", which shall include the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90037272-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A dataset displaying comprehensive workforce data, including all shortages in bureaus described in GAO report GAO–19–220, for all current and planned employees of the Department, disaggregated by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90037273-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734f/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Foreign Service officer and Foreign Service specialist rank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90037274-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734f/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civil service job skill code, grade level, and bureau of assignment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90037275-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734f/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracted employees, including the equivalent job skill code and bureau of assignment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90037276-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734f/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees hired under schedule C of subpart C of part 213 of title 5, Code of Federal Regulations, including the equivalent grade and job skill code and bureau of assignment of such employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90037277-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734f/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overseas region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037278-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations on the number of Foreign Service officers disaggregated by service cone that should be posted at each United States diplomatic post and in the District of Columbia, with a detailed basis for such recommendations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037279-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations on the number of civil service officers that should be employed by the Department, with a detailed basis for such recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9003727a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The dataset required under subsection (a)(1) shall be maintained and updated on a regular basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9003727b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall lead the development of the plan required under subsection (a) but may consult or partner with private sector entities with expertise in labor economics, management, or human resources, as well as organizations familiar with the demands and needs of the Department’s workforce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9003727c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", the Secretary of State shall submit to the appropriate congressional committees a report regarding root causes of Foreign Service and civil service shortages, the effect of such shortages on national security objectives, and the Department’s plan to implement recommendations described in GAO–19–220."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9003727d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLIII/s5313"},"text":"Pub. L. 117–81, div. E, title LIII, § 5313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2365"},"text":"135 Stat. 2365","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9003727e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9003727f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id90037280-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary”, “appropriate congressional committees”, and “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s5002"},"text":"section 5002 of Pub. L. 117–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s263c"},"text":"section 263c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
