{"tag":"section","attrib":{"id":"id90af1c0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6206"},"text":null,"children":[{"tag":"num","attrib":{"value":"6206"},"text":"§ 6206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grantee corporate boards of directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90af1c0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporate board of directors of each grantee under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90af1c0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6206/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be bipartisan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6206/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, except as otherwise provided in this Act, have the sole responsibility to operate their respective grantees within the jurisdiction of their respective States of incorporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6206/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be composed of not fewer than 5 members, who shall be qualified individuals who are not employed in the public sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6206/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall appoint successors in the event of vacancies on their respective boards, in accordance with applicable bylaws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90af1c13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No employee of any grantee under this chapter may be a Federal employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90af1c14-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tIII/s307"},"text":"Pub. L. 103–236, title III, § 307","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCVII/s9704"},"text":"Pub. L. 117–263, div. I, title XCVII, § 9704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3914"},"text":"136 Stat. 3914","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90af1c15-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90af1c16-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90af1c17-2930-11f1-8918-be39dde81dc6"},"text