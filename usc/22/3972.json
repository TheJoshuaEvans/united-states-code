{"tag":"section","attrib":{"id":"id90522f41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3972"},"text":null,"children":[{"tag":"num","attrib":{"value":"3972"},"text":"§ 3972.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special differentials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90522f42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3972/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional work requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may pay special differentials, in addition to compensation otherwise authorized, to Foreign Service officers who are required because of the nature of their assignments to perform additional work on a regular basis in substantial excess of normal requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90522f43-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3972/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salary limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the United States Agency for International Development (USAID) shall limit the payment of special differentials to USAID Foreign Service criminal investigators to levels at which the aggregate of basic pay and special differential for any pay period would equal, for such criminal investigators, the bi-weekly pay limitations on premium pay regularly placed on other criminal investigators within the Federal law enforcement community. This provision shall be retroactive to ","children":[{"tag":"date","attrib":{"date":"2013-01-01"},"text":"January 1, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90522f44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3972/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensatory time off","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter, or in subchapter V of chapter 55 of title 5 shall preclude the granting of compensatory time off for Foreign Service officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90522f45-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s412"},"text":"Pub. L. 96–465, title I, § 412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2092"},"text":"94 Stat. 2092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s139/6"},"text":"Pub. L. 103–236, title I, § 139(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/398"},"text":"108 Stat. 398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/323/tII/s206"},"text":"Pub. L. 114–323, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1917"},"text":"130 Stat. 1917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90522f46-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90522f47-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90522f48-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323"},"text":"Pub. L. 114–323","children":[],"tail":" added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" struck out subsec. (b) which read as follows: “Before implementing any proposal to limit either the number of Foreign Service officers who may receive a special differential under subsection (a) of this section or the amounts of such special differentials, the Secretary shall submit such proposal to the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
