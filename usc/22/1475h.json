{"tag":"section","attrib":{"id":"id8f06c3cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1475h"},"text":"§ 1475h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overseas public diplomacy grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f06c3cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grant procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), the Department of State shall work to achieve full and open competition in the award of grants for carrying out its overseas public diplomacy functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f06c3cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Department of State may award an overseas public diplomacy grant under procedures other than competitive procedures when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f06c3ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such a grant is made under the Mutual Educational and Cultural Exchange Act of 1961 (commonly known as the Fulbright-Hays Act) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"22 U.S.C. 2451","children":[],"tail":" et seq.] or any statute which expressly authorizes or requires that a grant be made with a specified entity;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c3cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of an international agreement or treaty between the United States Government and a foreign government or international organization have the effect of requiring the use of procedures other than competitive procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c3d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475h/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recipient organization has developed particular expertise in the planning and administration of longstanding exchange programs important to United States foreign policy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c3d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475h/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" introducing competition would increase costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f06c3d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with grant guidelines","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f06c3d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":", overseas public diplomacy grants awarded by the Department of State shall substantially comply with Department of State grant guidelines and applicable circulars of the Office of Management and Budget."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c3d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Agency ","children":[{"tag":"ref","attrib":{"idref":"fn002070"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002070"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Department”."}],"tail":" determines that a grantee has not satisfied the requirement of paragraph (1), the Department of State shall notify the grantee of the suspension of payments under a grant unless compliance is achieved within 90 days of such notice."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c3d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475h/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Agency ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall suspend payments under any such grant which remains in noncompliance 90 days after notification under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f06c3d6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/tII/s212"},"text":"Pub. L. 102–138, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/695"},"text":"105 Stat. 695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1335(b), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-787"},"text":"112 Stat. 2681–787","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f06c3d7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f06c3d8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f06c3d9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Mutual Educational and Cultural Exchange Act of 1961, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/256"},"text":"Pub. L. 87–256","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-21"},"text":"Sept. 21, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/527"},"text":"75 Stat. 527","children":[],"tail":", which is classified principally to chapter 33 (§ 2451 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"section 2451 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f06c3da-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Foreign Relations Authorization Act, Fiscal Years 1992 and 1993, and not as part of the United States Information and Educational Exchange Act of 1948 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f06c3db-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/b/1"},"text":"Pub. L. 105–277, § 1335(b)(1)","children":[],"tail":", (2), substituted “Department of State” for “United States Information Agency” and inserted “for carrying out its overseas public diplomacy functions” after “grants”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/b/1"},"text":"Pub. L. 105–277, § 1335(b)(1)","children":[],"tail":", (3)(A), in introductory provisions, substituted “Department of State” for “United States Information Agency” and “an overseas public diplomacy grant” for “a grant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/b/3/B"},"text":"Pub. L. 105–277, § 1335(b)(3)(B)","children":[],"tail":", inserted “such” after “(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/b/1"},"text":"Pub. L. 105–277, § 1335(b)(1)","children":[],"tail":", (4), inserted “overseas public diplomacy” before “grants” and substituted “Department of State” for “United States Information Agency” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/b/1"},"text":"Pub. L. 105–277, § 1335(b)(1)","children":[],"tail":", substituted “Department of State” for “United States Information Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/b/5"},"text":"Pub. L. 105–277, § 1335(b)(5)","children":[],"tail":", inserted “such” before “grant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/b/6"},"text":"Pub. L. 105–277, § 1335(b)(6)","children":[],"tail":", struck out heading and text of subsec. (d). Text read as follows: “Not later than 90 days after "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", the Director of the United States Information Agency shall submit a detailed report to the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives on United States Information Agency action to comply with subsection (a) of this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f06c3dc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f06c3dd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
