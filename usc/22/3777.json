{"tag":"section","attrib":{"id":"id904891e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3777"},"text":null,"children":[{"tag":"num","attrib":{"value":"3777"},"text":"§ 3777.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation of accident or injury giving rise to claim","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, a claim may not be considered under this subpart, or an action for damages lie thereon, unless, prior to the departure from the Panama Canal of the vessel involved—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904891e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3777/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an investigation of the accident or injury giving rise to the claim has been completed, which shall include a hearing by the Board of Local Inspectors of the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904891ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3777/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis for the claim has been laid before the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904891eb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1417"},"text":"Pub. L. 96–70, title I, § 1417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/487"},"text":"93 Stat. 487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dC/tXXXV/s3544"},"text":"Pub. L. 104–201, div. C, title XXXV, § 3544","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2867"},"text":"110 Stat. 2867","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904891ec-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904891ed-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id904891ee-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “an investigation by the competent authorities of the accident or injury giving rise to the claim has been completed; and”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
