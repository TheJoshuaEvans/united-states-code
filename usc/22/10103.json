{"tag":"section","attrib":{"id":"id91514fc8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103"},"text":null,"children":[{"tag":"num","attrib":{"value":"10103"},"text":"§ 10103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91514fc9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall submit to the appropriate congressional committees, in accordance with subsection (b), a report that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91514fca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of each foreign person with respect to which the President imposed sanctions pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10102"},"text":"section 10102 of this title","children":[],"tail":" during the year preceding the submission of the report;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91514fcb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the type of sanctions imposed with respect to each such person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91514fcc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of foreign persons with respect to which the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91514fcd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposed sanctions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10102/a"},"text":"section 10102(a) of this title","children":[],"tail":" during that year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91514fce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminated sanctions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10102/g"},"text":"section 10102(g) of this title","children":[],"tail":" during that year;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91514fcf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dates on which such sanctions were imposed or terminated, as the case may be;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91514fd0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for imposing or terminating such sanctions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91514fd1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the efforts of the President to encourage the governments of other countries to impose sanctions that are similar to the sanctions authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10102"},"text":"section 10102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91514fd2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dates for submission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91514fd3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall submit the initial report under subsection (a) not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"December 23, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91514fd4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91514fd5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall submit a subsequent report under subsection (a) on December 10, or the first day thereafter on which both Houses of Congress are in session, of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91514fd6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the calendar year in which the initial report is submitted if the initial report is submitted before December 10 of that calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91514fd7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each calendar year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91514fd8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress notes that December 10 of each calendar year has been recognized in the United States and internationally since 1950 as “Human Rights Day”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91514fd9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91514fda-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report required by subsection (a) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91514fdb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The name of a foreign person to be included in the list required by subsection (a)(1) may be submitted in the classified annex authorized by paragraph (1) only if the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91514fdc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that it is vital for the national security interests of the United States to do so;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91514fdd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses the annex in a manner consistent with congressional intent and the purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91514fde-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 15 days before submitting the name in a classified annex, provides to the appropriate congressional committees notice of, and a justification for, including the name in the classified annex despite any publicly available credible information indicating that the person engaged in an activity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10102/a"},"text":"section 10102(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91514fdf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91514fe0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The unclassified portion of the report required by subsection (a) shall be made available to the public, including through publication in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91514fe1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of confidentiality requirement with respect to visa records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall publish the list required by subsection (a)(1) without regard to the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1202/f"},"text":"section 1202(f) of title 8","children":[],"tail":" with respect to confidentiality of records pertaining to the issuance or refusal of visas or permits to enter the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91514fe2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91514fe3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations, the Committee on Banking, Housing, and Urban Affairs, the Committee on Foreign Relations, and the Committee on the Judiciary of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91514fe4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10103/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations, the Committee on Financial Services, the Committee on Foreign Affairs, and the Committee on the Judiciary of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91514fe5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1264"},"text":"Pub. L. 114–328, div. A, title XII, § 1264","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2536"},"text":"130 Stat. 2536","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91514fe6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91514fe7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id91514fe8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly set out in a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2656"},"text":"section 2656 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
