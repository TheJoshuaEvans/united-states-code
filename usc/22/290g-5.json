{"tag":"section","attrib":{"id":"id8ede2c88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–5"},"text":"§ 290g–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Reserve banks as depository for the Fund; supervision","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any Federal Reserve bank which is requested to do so by the President shall act as a depository for the Fund, and the Board of Governors of the Federal Reserve System shall supervise and direct the carrying out of these functions by the Federal Reserve banks.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ede2c89-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s207"},"text":"Pub. L. 94–302, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-31"},"text":"May 31, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/594"},"text":"90 Stat. 594","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
