{"tag":"section","attrib":{"id":"id908db1cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5426"},"text":null,"children":[{"tag":"num","attrib":{"value":"5426"},"text":"§ 5426.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States policy of private financial support for Polish and Hungarian credit unions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908db1cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5426/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to facilitate the development of indigenous credit unions in Poland and Hungary, it is the policy of the United States that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db1ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5426/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States citizens, financial institutions (other than federally insured depository institutions), and other persons may make contributions and loans to, make capital deposits in, and provide other forms of financial and technical assistance to credit unions in Poland and Hungary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db1cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5426/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" federally insured depository institutions may provide technical assistance to credit unions in Poland and Hungary, to the extent that the provision of such assistance is prudent and not inconsistent with safe and sound banking practice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db1d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5426/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db1d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5426/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db1d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5426/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “credit union” means a member-owned, nonprofit, cooperative depository institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id908db1d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5426/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is formed to permit individuals in the field of membership specified in such institution’s charter to pool their savings, lend the savings to one another, and own the organization where they save, borrow, and obtain related financial services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908db1d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5426/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose members are united by a common bond and democratically operate the institution; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db1d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5426/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “federally insured depository institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id908db1d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5426/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any insured depository institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/c/2"},"text":"section 1813(c)(2) of title 12","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908db1d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5426/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any insured credit union (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752/7"},"text":"section 1752(7) of title 12","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908db1d8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tII/s206"},"text":"Pub. L. 101–179, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1310"},"text":"103 Stat. 1310","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id908db1d9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id908db1da-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id908db1db-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/s206"},"text":"section 206 of Pub. L. 101–179","children":[],"tail":". Subsec. (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/101/179/s206"},"text":"section 206 of Pub. L. 101–179","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1757"},"text":"section 1757 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
