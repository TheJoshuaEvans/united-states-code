{"tag":"section","attrib":{"id":"id8ff51b60-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2688"},"text":null,"children":[{"tag":"num","attrib":{"value":"2688"},"text":"§ 2688.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ambassadors; criteria regarding selection and confirmation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that the position of United States ambassador to a foreign country should be accorded to men and women possessing clearly demonstrated competence to perform ambassadorial duties. No individual should be accorded the position of United States ambassador to a foreign country primarily because of financial contributions to political campaigns.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ff51b61-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 18, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/141/tI/s104"},"text":"Pub. L. 94–141, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-29"},"text":"Nov. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/757"},"text":"89 Stat. 757","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/a"},"text":"Pub. L. 97–241, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/282"},"text":"96 Stat. 282","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
