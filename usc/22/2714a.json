{"tag":"section","attrib":{"id":"id8ffc4745-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2714a"},"text":"§ 2714a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation or denial of passport in case of certain unpaid taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ffc4746-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" to (d) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc4747-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to deny or revoke passport","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffc4748-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffc4749-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided under subparagraph (B), upon receiving a certification described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7345"},"text":"section 7345 of title 26","children":[],"tail":" from the Secretary of the Treasury, the Secretary of State shall not issue a passport to any individual who has a seriously delinquent tax debt described in such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc474a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency and humanitarian situations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), the Secretary of State may issue a passport, in emergency circumstances or for humanitarian reasons, to an individual described in such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc474b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffc474c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State may revoke a passport previously issued to any individual described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc474d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation for return to United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of State decides to revoke a passport under subparagraph (A), the Secretary of State, before revocation, may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8ffc474e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit a previously issued passport only for return travel to the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ffc474f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a limited passport that only permits return travel to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc4750-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hold harmless","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury, the Secretary of State, and any of their designees shall not be liable to an individual for any action with respect to a certification by the Commissioner of Internal Revenue under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7345"},"text":"section 7345 of title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc4751-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation or denial of passport in case of individual without social security account number","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffc4752-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffc4753-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided under subparagraph (B), upon receiving an application for a passport from an individual that either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8ffc4754-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the social security account number issued to that individual, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ffc4755-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an incorrect or invalid social security number willfully, intentionally, negligently, or recklessly provided by such individual,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary of State is authorized to deny such application and is authorized to not issue a passport to the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc4756-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency and humanitarian situations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), the Secretary of State may issue a passport, in emergency circumstances or for humanitarian reasons, to an individual described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc4757-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffc4758-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State may revoke a passport previously issued to any individual described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc4759-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation for return to United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of State decides to revoke a passport under subparagraph (A), the Secretary of State, before revocation, may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8ffc475a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit a previously issued passport only for return travel to the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ffc475b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a limited passport that only permits return travel to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc475c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of certification from record when debt ceases to be seriously delinquent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If pursuant to subsection (c) or (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7345"},"text":"section 7345 of title 26","children":[],"tail":" the Secretary of State receives from the Secretary of the Treasury a notice that an individual ceases to have a seriously delinquent tax debt, the Secretary of State shall remove from the individual’s record the certification with respect to such debt."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc475d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc475e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of, and amendments made by, this section shall take effect on ","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"December 4, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ffc475f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dC/tXXXII/s32101"},"text":"Pub. L. 114–94, div. C, title XXXII, § 32101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1729"},"text":"129 Stat. 1729","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ffc4760-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ffc4761-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ffc4762-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the amendments made by this section, referred to in subsec. (i), see Codification note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ffc4763-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32101"},"text":"section 32101 of Pub. L. 114–94","children":[],"tail":". Subsections (a) to (d) and (h) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s32101"},"text":"section 32101 of Pub. L. 114–94","children":[],"tail":" made the following amendments: subsection (a) enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7345"},"text":"section 7345 of Title 26","children":[],"tail":", Internal Revenue Code; subsection (b) amended sections 6320 and 6331 of Title 26; subsection (c) amended "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"section 6103 of Title 26","children":[],"tail":"; subsection (d) amended "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7508"},"text":"section 7508 of Title 26","children":[],"tail":"; and subsection (h) amended the analysis for subchapter D of chapter 75 of Title 26."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
