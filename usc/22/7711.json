{"tag":"section","attrib":{"id":"id90ed1062-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711"},"text":null,"children":[{"tag":"num","attrib":{"value":"7711"},"text":"§ 7711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ed1063-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for timely disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the last day of each fiscal quarter, the Corporation shall make available to the public the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed1064-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7704"},"text":"section 7704 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ed1065-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of each entity to which assistance is provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed1066-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of assistance provided to the entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed1067-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the program or project, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90ed1068-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of whether the program or project was solicited or unsolicited; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ed1069-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the objectives and measures for results of the program or project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed106a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For funds allocated or transferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7718/b"},"text":"section 7718(b) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ed106b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of each United States Government agency to which such funds are transferred or allocated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed106c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds transferred or allocated to such agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed106d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the program or project to be carried out by such agency with such funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed106e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board, acting through the Chief Executive Officer, shall make the information required to be disclosed under subsection (a) available to the public—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed106f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by publishing it on the website of the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1070-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by providing notice of the availability of such information in the Federal Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1071-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7711/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any other methods that the Board determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ed1072-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tVI/s612"},"text":"Pub. L. 108–199, div. D, title VI, § 612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/221"},"text":"118 Stat. 221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/167/tII/s206"},"text":"Pub. L. 115–167, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-04-23"},"text":"Apr. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1282"},"text":"132 Stat. 1282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ed1073-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ed1074-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90ed1075-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167/s206/a"},"text":"Pub. L. 115–167, § 206(a)","children":[],"tail":", in heading, inserted “timely” before “disclosure”, and in introductory provisions, substituted “Not later than 90 days after the last day of each fiscal quarter, the Corporation” for “The Corporation” and struck out “on at least a quarterly basis,” after “public”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167/s206/b"},"text":"Pub. L. 115–167, § 206(b)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, text read as follows: “The information required to be disclosed under subsection (a) shall be made available to the public by means of publication in the Federal Register and on the Internet website of the Corporation, as well as by any other methods that the Board determines appropriate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
