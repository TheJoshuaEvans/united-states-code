 1982 and 1983."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113"},"text":"Pub. L. 97–113","children":[],"tail":", §§ 113, 734(a)(1), substituted appropriations authorization of $42,000,000 for fiscal years 1982 and 1983 for appropriation of $34,000,000 for fiscal year 1981 and deleted prohibition against any training after "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", outside the United States without a prior Presidential report to the Speaker of the House and the Senate Foreign Relations Committee and justification for the training."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/533"},"text":"Pub. L. 96–533","children":[],"tail":" substituted appropriations authorization of $34,000,000 for fiscal year 1981 for authorization of $31,800,000 for fiscal year 1980, including prohibition against availability of any amount for Inter-American regional programs unless the foreign country participants collectively contribute an equivalent amount to carry out the programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/92"},"text":"Pub. L. 96–92","children":[],"tail":" substituted appropriations authorization of $31,800,000 for fiscal year 1980, for identical authorization for fiscal year 1979, and required collective contribution of an equivalent amount by the foreign countries participating in Inter-American regional programs before such amount became available from the appropriation for such programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/384"},"text":"Pub. L. 95–384","children":[],"tail":" substituted “$31,800,000 for the fiscal year 1979” for “$31,000,000 for the fiscal year 1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/92"},"text":"Pub. L. 95–92","children":[],"tail":" substituted “$31,000,000 for the fiscal year 1978” for “$27,000,000 for the fiscal year 1976 and $30,200,000 for the fiscal year 1977”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f937336-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f937337-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1301"},"text":"section 1301 of Pub. L. 99–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151–1"},"text":"section 2151–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f937338-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f937339-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":