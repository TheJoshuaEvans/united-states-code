{"tag":"section","attrib":{"id":"id8ea9af7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c"},"text":null,"children":[{"tag":"num","attrib":{"value":"276c"},"text":"§ 276c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Senate delegates to Conferences of the Interparliamentary Union","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":", Senate delegates to Conferences of the Interparliamentary Union shall be designated by the Presiding Officer of the Senate. Not less than two Senators so designated shall be members of the Committee on Foreign Relations."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ea9af80-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/474/tI"},"text":"Pub. L. 85–474, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/246"},"text":"72 Stat. 246","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/141/tII/s204/c"},"text":"Pub. L. 94–141, title II, § 204(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-29"},"text":"Nov. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/762"},"text":"89 Stat. 762","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ea9af81-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ea9af82-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ea9af83-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/141"},"text":"Pub. L. 94–141","children":[],"tail":" inserted at end “Not less than two Senators so designated shall be members of the Committee on Foreign Relations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
