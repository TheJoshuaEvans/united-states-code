{"tag":"section","attrib":{"id":"id90037281-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2734g"},"text":"§ 2734g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promoting transparency and accountability in the Department of State workforce","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90037282-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary should establish a mechanism to ensure that appointments or details of Department career employees to staff positions in the Office of the Secretary, the Office of the Deputy Secretary of State, the Office of the Counselor of the Department, any office of the Secretary’s Policy Planning Staff, and any office of an Under Secretary of State, and details to the National Security Council, are transparent, competitive, inclusive, and merit-based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90037283-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall submit a report to the appropriate congressional committees regarding the mechanism established pursuant to subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90037284-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90037285-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use transparent, competitive, inclusive, and merit-based processes for appointments and details to the staff positions specified in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037286-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that such positions are equally available to all employees of the Civil Service and the Foreign Service of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90037287-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCIV/s9404"},"text":"Pub. L. 117–263, div. I, title XCIV, § 9404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3896"},"text":"136 Stat. 3896","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90037288-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90037289-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9003728a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCIV/s9405"},"text":"Pub. L. 117–263, div. I, title XCIV, § 9405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3897"},"text":"136 Stat. 3897","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dI/tXCIV/s9405"},"text":"“Nothing in this title [enacting this section] may be construed as altering existing law regarding merit system principles.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id9003728b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary”, “Department”, and “appropriate congressional committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s9002"},"text":"section 9002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
