{"tag":"section","attrib":{"id":"id8f14f496-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1643j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1643j"},"text":"§ 1643j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to enable the Commission to pay its administrative expenses incurred in carrying out its functions under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f14f497-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title V, § 511, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/666"},"text":"Pub. L. 88–666","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-16"},"text":"Oct. 16, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1113"},"text":"78 Stat. 1113","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/262/s5"},"text":"Pub. L. 89–262, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-19"},"text":"Oct. 19, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/988"},"text":"79 Stat. 988","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f14f498-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f14f499-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f14f49a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/262"},"text":"Pub. L. 89–262","children":[],"tail":" redesignated subsec. (a) as the complete section, struck out limitation of amount of appropriations to aggregate amount of net proceeds realized from sale or liquidation of property of Government of Cuba and use of funds to pay administrative expenses of the Treasury Department in carrying out its functions, and eliminated subsec. (b) providing for vesting and liquidation of Cuban property."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
