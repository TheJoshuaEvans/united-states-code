{"tag":"section","attrib":{"id":"id90299983-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3001"},"text":null,"children":[{"tag":"num","attrib":{"value":"3001"},"text":"§ 3001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission on Security and Cooperation in Europe; establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established the Commission on Security and Cooperation in Europe (hereafter in this chapter referred to as the “Commission”).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90299984-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/304/s1"},"text":"Pub. L. 94–304, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-03"},"text":"June 3, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/661"},"text":"90 Stat. 661","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
