{"tag":"section","attrib":{"id":"id910e7b01-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8771"},"text":null,"children":[{"tag":"num","attrib":{"value":"8771"},"text":"§ 8771.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of citizens of Iran seeking education relating to the nuclear and energy sectors of Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id910e7b02-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8771/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall deny a visa to, and the Secretary of Homeland Security shall exclude from the United States, any alien who is a citizen of Iran that the Secretary of State determines seeks to enter the United States to participate in coursework at an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of title 20","children":[],"tail":") to prepare the alien for a career in the energy sector of Iran or in nuclear science or nuclear engineering or a related field in Iran."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7b03-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8771/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) applies with respect to visa applications filed on or after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910e7b04-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158/tV/s501"},"text":"Pub. L. 112–158, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1258"},"text":"126 Stat. 1258","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id910e7b05-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id910e7b06-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8785/a"},"text":"section 8785(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
