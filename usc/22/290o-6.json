{"tag":"section","attrib":{"id":"id8ee55957-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"290o–6"},"text":"§ 290o–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectiveness of Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Agreement shall have full force and effect in the United States, its territories and possessions, and the Commonwealth of Puerto Rico, upon acceptance of membership by the United States in the Bank and the entry into force of the Agreement.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ee55958-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/c/tVII/s708"},"text":"Pub. L. 104–208, div. A, title I, § 101(c) [title VII, § 708]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-121"},"text":"110 Stat. 3009–121","children":[],"tail":", 3009–180.)"}],"tail":"\n"}],"tail":null}
