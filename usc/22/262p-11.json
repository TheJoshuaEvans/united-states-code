{"tag":"section","attrib":{"id":"id8ea039a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–11"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p–11"},"text":"§ 262p–11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opposition to loans or funds for countries that support terrorism","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director at each of the International Financial Institutions ","children":[{"tag":"ref","attrib":{"idref":"fn002015"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002015"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s262r/c/2"},"text":"section 262r(c)(2) of this title","children":[],"tail":") to use the voice and vote of the United States to oppose the provision of loans or other use of the funds of the respective institution to any country the government of which the Secretary of State has determined, for purposes of section 4605(j) "},{"tag":"ref","attrib":{"idref":"fn002016"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002016"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 50, "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2371"},"text":"section 2371 of this title","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2780"},"text":"section 2780 of this title","children":[],"tail":", to be a government that has repeatedly provided support for acts of international terrorism."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ea039a3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":