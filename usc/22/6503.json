{"tag":"section","attrib":{"id":"id90bd74b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6503"},"text":null,"children":[{"tag":"num","attrib":{"value":"6503"},"text":"§ 6503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on budgetary cost savings resulting from reorganization","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall submit a report, together with the congressional presentation document for the budget of the Department of State for each of the fiscal years 2000 and 2001, to the appropriate congressional committees describing the total anticipated and achieved cost savings in budget outlays and budget authority related to the reorganization implemented under this chapter, including cost savings by each of the following categories:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bd74b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6503/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reductions in personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd74b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6503/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administrative consolidation, including procurement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd74ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6503/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Program consolidation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd74bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6503/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consolidation of real properties and leases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90bd74bc-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XI, § 1104, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-767"},"text":"112 Stat. 2681–767","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90bd74bd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90bd74be-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90bd74bf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this subdivision”, meaning subdiv. A of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-765"},"text":"112 Stat. 2681–765","children":[],"tail":", known as the Foreign Affairs Agencies Consolidation Act of 1998. For complete classification of this subdivision to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6501"},"text":"section 6501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
