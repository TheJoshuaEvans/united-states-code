{"tag":"section","attrib":{"id":"id90416654-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3645"},"text":null,"children":[{"tag":"num","attrib":{"value":"3645"},"text":"§ 3645.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction from basic pay of amounts due for supplies or services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission may deduct from the basic pay otherwise payable by the Commission to any officer or employee of the Commission any amount due from the officer or employee to the Commission or to any contractor of the Commission for transportation, board, supplies, or any other service. Any amount so deducted may be paid by the Commission to any contractor to whom it is due or may be credited by the Commission to any fund from which the Commission has expended such amount.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90416655-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1205"},"text":"Pub. L. 96–70, title I, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/462"},"text":"93 Stat. 462","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dC/tXXXV/s3529/1"},"text":"Pub. L. 104–106, div. C, title XXXV, § 3529(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/641"},"text":"110 Stat. 641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90416656-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90416657-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90416658-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “fund” for “appropriation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
