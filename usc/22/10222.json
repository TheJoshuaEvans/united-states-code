{"tag":"section","attrib":{"id":"id91515014-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222"},"text":null,"children":[{"tag":"num","attrib":{"value":"10222"},"text":"§ 10222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions with respect to human rights abuses and perpetration of a coup in Burma","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91515015-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the President shall impose the sanctions described in subsection (d) with respect to any foreign person that the President determines—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id91515016-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a senior official of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91515017-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Burmese military or security forces of Burma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91515018-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State Administration Council, the military-appointed cabinet at the level of Deputy Minister or higher, or a military-appointed minister of a Burmese state or region; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91515019-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity that primarily operates in the defense sector of the Burmese economy; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9151501a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a Burmese state-owned commercial enterprise (other than an entity described in subsections (c)(1) and (c)(2)) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9151501b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is operating in the industrial or extractive sectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9151501c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly financially benefits the Burmese military.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9151501d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional measure relating to facilitation of transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury may, in consultation with the Secretary of State, prohibit or impose strict conditions on the opening or maintaining in the United States of a correspondent account or payable-through account by a foreign financial institution that the President determines has, on or after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", knowingly conducted or facilitated a significant transaction or transactions on behalf of a foreign person subject to sanctions under this section imposed pursuant to subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9151501e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may impose the sanctions described in subsection (d) with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9151501f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Myanma Oil and Gas Enterprise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91515020-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any Burmese state-owned enterprise that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91515021-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not operating in the industrial or extractive sectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91515022-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly financially benefits the Burmese military;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91515023-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a spouse or adult child of any person described in subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91515024-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any foreign person that, leading up to, during, and since the ","children":[{"tag":"date","attrib":{"date":"2021-02-01"},"text":"February 1, 2021","children":[],"tail":", coup d’etat in Burma, is responsible for or has directly and knowingly engaged in—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91515025-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions or policies that significantly undermine democratic processes or institutions in Burma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91515026-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions or policies that significantly threaten the peace, security, or stability of Burma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91515027-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" actions or policies by a Burmese person that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91515028-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly prohibit, limit, or penalize the exercise of freedom of expression or assembly by people in Burma; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91515029-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit access to print, online, or broadcast media in Burma; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9151502a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the orchestration of arbitrary detention or torture in Burma or other serious human rights abuses in Burma; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9151502b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Burmese entity that provides materiel to the Burmese military.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9151502c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sanctions described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9151502d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Property blocking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may exercise all powers granted to the President by the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.) to the extent necessary to block and prohibit all transactions in all property and interests in property of the foreign person if such property and interests in property are in the United States, come within the United States, or are or come within the possession or control of a United States person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9151502e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign exchange","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may, pursuant to such regulations as the President may prescribe, prohibit any transactions in foreign exchange that are subject to the jurisdiction of the United States and in which the foreign person has any interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9151502f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visas, admission, or parole","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91515030-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An alien who is described in subsection (a) or (c) is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91515031-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inadmissible to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91515032-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ineligible for a visa or other documentation to enter the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91515033-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise ineligible to be admitted or paroled into the United States or to receive any other benefit under the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91515034-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current visas revoked","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91515035-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The issuing consular officer, the Secretary of State, or the Secretary of Homeland Security (or a designee of one of such Secretaries) shall, in accordance with section 221(i) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1201/i"},"text":"8 U.S.C. 1201(i)","children":[],"tail":"), revoke any visa or other entry documentation issued to an alien described in subparagraph (A) regardless of when the visa or other entry documentation is issued."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91539926-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of revocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A revocation under clause (i)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id91539927-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/d/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take effect immediately; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91539928-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/d/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall automatically cancel any other valid visa or entry documentation that is in the alien’s possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91539929-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and report on sanctions with respect to Burmese State-owned enterprise operating in the energy sector","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9153992a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the President shall conduct an assessment with respect to the Burmese state-owned enterprise described in subsection (c)(1), including relevant factors pertaining to the possible application of sanctions on such enterprise."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9153992b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon making the determination required by paragraph (1), the President shall submit to the appropriate congressional committees a report on the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9153992c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required by paragraph (2) shall be submitted in unclassified form but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9153992d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9153992e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for intelligence, law enforcement, and national security activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sanctions under this section shall not apply to any authorized intelligence, law enforcement, or national security activities of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9153992f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to comply with international obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sanctions under subsection (d)(3) shall not apply with respect to the admission of an alien if admitting or paroling the alien into the United States is necessary to permit the United States to comply with the Agreement regarding the Headquarters of the United Nations, signed at Lake Success ","children":[{"tag":"date","attrib":{"date":"1947-06-26"},"text":"June 26, 1947","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1947-11-21"},"text":"November 21, 1947","children":[],"tail":", between the United Nations and the United States, or other applicable international obligations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91539930-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception relating to the provision of humanitarian assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sanctions under this section may not be imposed with respect to transactions or the facilitation of transactions for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91539931-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of agricultural commodities, food, medicine, or medical devices to Burma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91539932-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of humanitarian assistance to the people of Burma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91539933-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial transactions relating to humanitarian assistance or for humanitarian purposes in Burma; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91539934-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transporting goods or services that are necessary to carry out operations relating to humanitarian assistance or humanitarian purposes in Burma.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91539935-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception relating to wind-down of projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sanctions under this section shall not be imposed with respect to transactions or the facilitation of transactions related to the disposition of investments pursuant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91539936-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agreements entered into between United States persons and the Government of Burma prior to ","children":[{"tag":"date","attrib":{"date":"1997-05-21"},"text":"May 21, 1997","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91539937-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the exercise of rights pursuant to such agreements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91539938-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transactions related to the subsequent operation of the assets encompassed by such disposed investments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91539939-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may, on a case-by-case basis waive the application of sanctions or restrictions imposed with respect to a foreign person under this section if the President certifies to the appropriate congressional committees at the time such waiver is to take effect that the waiver is in the national interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9153993a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation; penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9153993b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may exercise all authorities provided to the President under sections 203 and 205 of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1702"},"text":"50 U.S.C. 1702","children":[],"tail":" and 1704) to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9153993c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties provided for in subsections (b) and (c) of section 206 of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705"},"text":"50 U.S.C. 1705","children":[],"tail":") shall apply to a person that violates, attempts to violate, conspires to violate, or causes a violation of this section or any regulations promulgated under this section to the same extent that such penalties apply to a person that commits an unlawful act described in section 206(a) of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705/a"},"text":"50 U.S.C. 1705(a)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9153993d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", and annually thereafter for 8 years, the Secretary of State, in consultation with the Secretary of the Treasury, shall submit to the appropriate congressional committees a classified report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9153993e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the primary sources of income to which the Burmese military has access and that the United States has been unable to reach using sanctions authorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9153993f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10222/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the impact of the sanctions imposed pursuant to the authorities under this section on the Burmese people and the Burmese military.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91539940-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5571"},"text":"Pub. L. 117–263, div. E, title LV, § 5571","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3363"},"text":"136 Stat. 3363","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91539941-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91539942-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id91539943-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsec. (d)(1), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (d)(3)(A)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of Title 8, Aliens and Nationality. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
