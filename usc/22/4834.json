{"tag":"section","attrib":{"id":"id9081cb30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834"},"text":null,"children":[{"tag":"num","attrib":{"value":"4834"},"text":"§ 4834.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security Review Committee findings and report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9081cb31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Security Review Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9081cb32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the Report of Investigation prepared pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4833/b"},"text":"section 4833(b) of this title","children":[],"tail":", and all other evidence, reporting, and relevant information relating to a Serious Security Incident at a United States mission abroad, including an examination of the facts and circumstances surrounding any serious injuries, loss of life, or significant destruction of property resulting from the incident; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9081cb33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determine, in writing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9081cb34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the incident was security related and constituted a Serious Security Incident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9081cb35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the incident involved a diplomatic compound, motorcade, residence, or other mission facility—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9081cb36-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the security systems, security countermeasures, and security procedures operated as intended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9081cb37-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether such systems worked to materially mitigate the attack or were found to be inadequate to mitigate the threat and attack;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9081cb38-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the incident involved an individual or group of officers conducting an approved operation outside the mission, whether a valid process was followed in evaluating the requested operation and weighing the risk of the operation, which determination shall not seek to assign accountability for the incident unless the Security Review Committee determines that an official breached his or her duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9081cb39-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of intelligence and information availability, and whether the mission was aware of the general operating threat environment or any more specific threat intelligence or information and took that into account in ongoing and specific operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9081cb3a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other facts and circumstances that may be relevant to the appropriate security management of United States missions abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9081cb3b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9081cb3c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Secretary of State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after receiving the Report of Investigation prepared pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4833/b"},"text":"section 4833(b) of this title","children":[],"tail":", the Security Review Committee shall submit a report to the Secretary of State that includes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9081cb3d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9081cb3e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any related recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9081cb3f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after receiving the report pursuant to paragraph (1), the Secretary of State shall submit a copy of the report to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9081cb40-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9081cb41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Select Committee on Intelligence of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9081cb42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9081cb43-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9081cb44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Permanent Select Committee on Intelligence of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9081cb45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9081cb46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4834/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel recommendations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If in the course of conducting an investigation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4833"},"text":"section 4833 of this title","children":[],"tail":", the investigative team finds reasonable cause to believe any individual described in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4833/a/2/D"},"text":"section 4833(a)(2)(D) of this title","children":[],"tail":" has breached the duty of that individual or finds lesser failures on the part of an individual in the performance of his or her duties related to the incident, it shall be reported to the Security Review Committee. If the Security Review Committee finds reasonable cause to support the determination, it shall be reported to the Secretary for appropriate action."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9081cb47-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIII/s304"},"text":"Pub. L. 99–399, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/861"},"text":"100 Stat. 861","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s156/b"},"text":"Pub. L. 100–204, title I, § 156(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1354"},"text":"101 Stat. 1354","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/323/tI/s104/a"},"text":"Pub. L. 114–323, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1909"},"text":"130 Stat. 1909","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCIII/s9302/g"},"text":"Pub. L. 117–263, div. I, title XCIII, § 9302(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3887"},"text":"136 Stat. 3887","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9081cb48-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9081cb49-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9081cb4a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended section generally. Prior to amendment, section related to findings and recommendations by an Accountability Review Board."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s104/a/3"},"text":"Pub. L. 114–323, § 104(a)(3)","children":[],"tail":", in concluding provisions, substituted “has engaged in misconduct or unsatisfactorily performed the duties of employment of that individual as described in this subsection” for “has breached a duty of that individual” and struck out “to the performance of the duties of that individual” after “pertinent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s104/a/1"},"text":"Pub. L. 114–323, § 104(a)(1)","children":[],"tail":", in introductory provisions, substituted “If” for “Whenever” and “has engaged in misconduct or unsatisfactorily performed the duties of employment of that individual, and such misconduct or unsatisfactory performance has significantly contributed to the serious injury, loss of life, or significant destruction of property, or the serious breach of security that is the subject of the Board’s examination as described in subsection (a)” for “has breached the duty of that individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s104/a/2"},"text":"Pub. L. 114–323, § 104(a)(2)","children":[],"tail":", substituted “findings” for “finding” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" inserted “or surrounding the serious breach of security involving intelligence activities of a foreign government directed at a United States Government mission abroad (as the case may be)” after first reference to “mission abroad”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9081cb4b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9081cb4c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/tI/s104/b"},"text":"Pub. L. 114–323, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1910"},"text":"130 Stat. 1910","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/323/tI/s104/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply with respect to any Accountability Review Board that is convened under section 301 of the Diplomatic Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4831"},"text":"22 U.S.C. 4831","children":[],"tail":") on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
