{"tag":"section","attrib":{"id":"id8eb0dad6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–28"},"text":null,"children":[{"tag":"num","attrib":{"value":"277d–28"},"text":"§ 277d–28.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Department of State for use of the United States Section, International Boundary and Water Commission, United States and Mexico, not in excess of $300,000 for the initial cost of the work authorized in sections 277d–26 to 277d–28 of this title, and not to exceed $30,000 based on December 1975 prices, plus or minus such amounts as may be justified by reason of ordinary fluctuations in operation and maintenance costs involved therein, annually thereafter for necessary maintenance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eb0dad7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/411/s3"},"text":"Pub. L. 88–411, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-10"},"text":"Aug. 10, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/386"},"text":"78 Stat. 386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/126/s7/b"},"text":"Pub. L. 93–126, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-10-18"},"text":"Oct. 18, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/452"},"text":"87 Stat. 452","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/105/tV/s514/b"},"text":"Pub. L. 95–105, title V, § 514(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-17"},"text":"Aug. 17, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/862"},"text":"91 Stat. 862","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eb0dad8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eb0dad9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8eb0dada-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/105"},"text":"Pub. L. 95–105","children":[],"tail":" inserted “based on December 1975 prices, plus or minus such amounts as may be justified by reason of ordinary fluctuations in operation and maintenance costs involved therein,” after “$30,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/126"},"text":"Pub. L. 93–126","children":[],"tail":" substituted “$30,000” for “$20,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eb0dadb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8eb0dadc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/105"},"text":"Pub. L. 95–105","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"