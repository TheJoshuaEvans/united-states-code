{"tag":"section","attrib":{"id":"id8ee5592c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290n–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"290n–5"},"text":"§ 290n–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than February 1 of each year that occurs more than 1 year after the date of the establishment of the Commission, the Commission should submit an annual report to both the United States Government and the Government of Mexico regarding all activities of the Commission during the preceding calendar year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ee5592d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/400/s7"},"text":"Pub. L. 103–400, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4171"},"text":"108 Stat. 4171","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
