{"tag":"section","attrib":{"id":"id90aa61f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091"},"text":null,"children":[{"tag":"num","attrib":{"value":"6091"},"text":"§ 6091.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from United States of aliens who have confiscated property of United States nationals or who traffic in such property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90aa61f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grounds for exclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall deny a visa to, and the Attorney General shall exclude from the United States, any alien who the Secretary of State determines is a person who, after ","children":[{"tag":"date","attrib":{"date":"1996-03-12"},"text":"March 12, 1996","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90aa61f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has confiscated, or has directed or overseen the confiscation of, property a claim to which is owned by a United States national, or converts or has converted for personal gain confiscated property, a claim to which is owned by a United States national;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa61f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traffics in confiscated property, a claim to which is owned by a United States national;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa61f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a corporate officer, principal, or shareholder with a controlling interest of an entity which has been involved in the confiscation of property or trafficking in confiscated property, a claim to which is owned by a United States national; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa61f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a spouse, minor child, or agent of a person excludable under paragraph (1), (2), or (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90aa61f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section, the following terms have the following meanings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90aa61f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confiscated; confiscation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms “confiscated” and “confiscation” refer to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90aa61f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the nationalization, expropriation, or other seizure by the Cuban Government of ownership or control of property—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90aa61f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without the property having been returned or adequate and effective compensation provided; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90aa61fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without the claim to the property having been settled pursuant to an international claims settlement agreement or other mutually accepted settlement procedure; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90aa61fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the repudiation by the Cuban Government of, the default by the Cuban Government on, or the failure of the Cuban Government to pay—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90aa61fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a debt of any enterprise which has been nationalized, expropriated, or otherwise taken by the Cuban Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90aa61fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a debt which is a charge on property nationalized, expropriated, or otherwise taken by the Cuban Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90aa61fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a debt which was incurred by the Cuban Government in satisfaction or settlement of a confiscated property claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa61ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traffics","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90aa6200-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (B), a person “traffics” in confiscated property if that person knowingly and intentionally—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90aa6201-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id90aa6202-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfers, distributes, dispenses, brokers, or otherwise disposes of confiscated property,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id90aa6203-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchases, receives, obtains control of, or otherwise acquires confiscated property, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id90aa6204-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves (other than for routine maintenance), invests in (by contribution of funds or anything of value, other than for routine maintenance), or begins after ","children":[{"tag":"date","attrib":{"date":"1996-03-12"},"text":"March 12, 1996","children":[],"tail":", to manage, lease, possess, use, or hold an interest in confiscated property,"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90aa6205-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enters into a commercial arrangement using or otherwise benefiting from confiscated property, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90aa6206-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causes, directs, participates in, or profits from, trafficking (as described in clause (i) or (ii)) by another person, or otherwise engages in trafficking (as described in clause (i) or (ii)) through another person,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"without the authorization of any United States national who holds a claim to the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90aa6207-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “traffics” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90aa6208-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivery of international telecommunication signals to Cuba;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90aa6209-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trading or holding of securities publicly traded or held, unless the trading is with or by a person determined by the Secretary of the Treasury to be a specially designated national;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90aa620a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transactions and uses of property incident to lawful travel to Cuba, to the extent that such transactions and uses of property are necessary to the conduct of such travel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90aa620b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transactions and uses of property by a person who is both a citizen of Cuba and a resident of Cuba, and who is not an official of the Cuban Government or the ruling political party in Cuba.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90aa620c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply where the Secretary of State finds, on a case by case basis, that the entry into the United States of the person who would otherwise be excluded under this section is necessary for medical reasons or for purposes of litigation of an action under subchapter III.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90aa620d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90aa620e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies to aliens seeking to enter the United States on or after ","children":[{"tag":"date","attrib":{"date":"1996-03-12"},"text":"March 12, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa620f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6091/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trafficking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies only with respect to acts within the meaning of “traffics” that occur on or after ","children":[{"tag":"date","attrib":{"date":"1996-03-12"},"text":"March 12, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90aa6210-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114/tIV/s401"},"text":"Pub. L. 104–114, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/822"},"text":"110 Stat. 822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90aa6211-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90aa6212-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90aa6213-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter III, referred to in subsec. (c), was in the original “title III”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114"},"text":"Pub. L. 104–114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/814"},"text":"110 Stat. 814","children":[],"tail":", which enacted subchapter III of this chapter and sections 1643"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" and 1643m of this title and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1611"},"text":"section 1611 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure. For complete classification of title III to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90aa6214-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90aa6215-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reports on Determinations Under Title IV of the LIBERTAD Act","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXVIII, § 2802, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-845"},"text":"112 Stat. 2681–845","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tII/s209/b"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title II, § 209(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–423; "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tII/s216/b"},"text":"Pub. L. 107–228, div. A, title II, § 216(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1366"},"text":"116 Stat. 1366","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/228/dA/tII/s216/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":"] and every 3 months thereafter during the period ending "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"September 30, 2003","children":[],"tail":", the Secretary of State shall submit to the appropriate congressional committees [Committee on Foreign Affairs of the House of Representatives and Committee on Foreign Relations of the Senate] a report on the implementation of section 401 of the Cuban Liberty and Democratic Solidarity (LIBERTAD) Act of 1996 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6091"},"text":"22 U.S.C. 6091","children":[],"tail":"). Each report shall include—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unclassified list, by economic sector, of the number of entities then under review pursuant to that section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unclassified list of all entities and a classified list of all individuals that the Secretary of State has determined to be subject to that section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unclassified list of all entities and a classified list of all individuals that the Secretary of State has determined are no longer subject to that section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of the status of the review underway for the cases referred to in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an unclassified explanation of each determination of the Secretary of State under section 401(a) of that Act and each finding of the Secretary under section 401(c) of that Act—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" since the date of the enactment of this Act, in the case of the first report under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the preceding 3-month period, in the case of each subsequent report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection of Identity of Concerned Entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In preparing the report under subsection (a), the names of entities shall not be identified under paragraph (1) or (4).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
