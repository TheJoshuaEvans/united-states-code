{"tag":"section","attrib":{"id":"id8f720881-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2273"},"text":null,"children":[{"tag":"num","attrib":{"value":"2273"},"text":"§ 2273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peace process in Central America","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f720882-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2273/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strongly supports the initiatives taken by the Contadora group and the resulting Document of Objectives which has been agreed to by Costa Rica, El Salvador, Guatemala, Honduras, and Nicaragua and which sets forth a framework for negotiating a peaceful settlement to the conflict and turmoil in the region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f720883-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2273/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" finds that the United States should provide such assistance and support as may be appropriate in helping to reach comprehensive and verifiable final agreements, based on the Document of Objectives, which will ensure peaceful and enduring solutions to the Central American conflicts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f720884-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 463, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tVII/s701"},"text":"Pub. L. 99–83, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/235"},"text":"99 Stat. 235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f720885-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f720886-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f720887-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s463"},"text":"section 463 of Pub. L. 87–195","children":[],"tail":" is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2283"},"text":"section 2283 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
