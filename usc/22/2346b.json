{"tag":"section","attrib":{"id":"id8f9101d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2346b"},"text":"§ 2346b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f9101d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the funds appropriated to carry out this part, up to $75,000,000 for the fiscal year 1986 and up to $75,000,000 for the fiscal year 1987 may be made available for emergency use under this part when the national interests of the United States urgently require economic support to promote economic or political stability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9101d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2346b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any provision of this part or of an appropriations Act (including a joint resolution making continuing appropriations) which earmarks funds available to carry out this part for a specific country or purpose, up to 5 percent of each amount so earmarked may be used to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f9101d6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 533, formerly § 535, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tII/s202"},"text":"Pub. L. 97–113, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib"