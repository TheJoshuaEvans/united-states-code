{"tag":"section","attrib":{"id":"id8e9b57d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p"},"text":"§ 262p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impact adjustment lending programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e9b57d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of guidelines; impact statements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director of the International Bank for Reconstruction and Development and the International Development Association to initiate discussions with other directors of the respective institutions and to propose that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e9b57d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines be established which reflect clear and tangible concern for the impact adjustment lending programs, and the activities in support of which such lending is made, have and will have on human welfare; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b57da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impact statements be required which assess the effect an adjustment lending program, and the activities in support of which such lending is made, will have on the poor of the country to which such lending is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e9b57db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed contents of impact statements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the discussions referred to in subsection (a) with respect to the impact statement described in paragraph (2) of such subsection, the United States Executive Director should propose that such impact statements—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e9b57dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify what the projected effects of the adjustment loan will be on the poor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b57dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" explain what procedures have been or will be taken to strengthen the in-country capacity of the borrower to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e9b57de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor nutrition levels in a timely manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e9b57df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measure the impact an adjustment loan, and the policies and activities in support of which such loan is made, has on the living standards of the country’s population, especially the poorest; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b57e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" indicate specifically what steps the borrower will take to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e9b57e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigate any adverse effect the policies and activities in support of which an adjustment loan is made are expected to have on the living standards of the poor (including the use of the proceeds of any adjustment loan, project aid, or other compensatory measure to mitigate such effect); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e9b57e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize the extent of the participation of the poor in the economic benefits resulting from an adjustment loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e9b57e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to member governments by United States Executive Director of International Bank for Reconstruction and Development and by International Development Association","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director of the International Bank for Reconstruction and Development and the International Development Association to request the management of the respective institutions to prepare a report for distribution to member governments no later than ","children":[{"tag":"date","attrib":{"date":"1988-06-30"},"text":"June 30, 1988","children":[],"tail":", that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e9b57e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the impact on the poor of structural adjustment in countries to which structural adjustment lending has been made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9b57e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specifies the steps that have been or will be taken by the respective institution to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e9b57e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigate any adverse effect of adjustment lending, and the activities in support of which such lending is made, on the living standards of the poor in the countries to which such loans are made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e9b57e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the participation of the poor in the economic benefits resulting from adjustment lending and the activities in support of which such lending is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e9b57e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Adjustment lending” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262m–1"},"text":"section 262m–1 of this title","children":[],"tail":", the term “adjustment lending” means nonproject lending in support of structural macroeconomic reforms or sectoral economic reform."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e9b57e9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXVI/s1601"},"text":"Pub. L. 95–118, title XVI, § 1601","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tI"},"text":"Pub. L. 100–202, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-131"},"text":"101 Stat. 1329–131","children":[],"tail":", 1329–134.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e9b57ea-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e9b57eb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8e9b57ec-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/s1601"},"text":"Section 1601 of Pub. L. 95–118","children":[],"tail":" is based on section 701 of title VII of H.R. 3750, One Hundredth Congress, as introduced "},{"tag":"date","attrib":{"date":"1987-12-11"},"text":"Dec. 11, 1987","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e9b57ed-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8e9b57ee-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–5"},"text":"section 262p–5 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
