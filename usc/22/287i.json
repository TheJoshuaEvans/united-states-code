{"tag":"section","attrib":{"id":"id8ed700f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287i"},"text":null,"children":[{"tag":"num","attrib":{"value":"287i"},"text":"§ 287i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deduction of principal and interest from annual payment of assessed share of United States of budget","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be deducted from the annual payment of the assessed share of the United States of the budget of the United Nations an amount equal to the corresponding annual installment of principal and interest due to the United States on account of the loan made pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s287g"},"text":"section 287g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ed700fa-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/731/s3"},"text":"Pub. L. 87–731, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-02"},"text":"Oct. 2, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/696"},"text":"76 Stat. 696","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ed700fb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ed700fc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ed700fd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-12-20/ch583"},"text":"act Dec. 20, 1945, ch. 583","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/619"},"text":"59 Stat. 619","children":[],"tail":", known as the United Nations Participation Act of 1945, which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
