{"tag":"section","attrib":{"id":"id8ede2ccf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–18"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–18"},"text":"§ 290g–18.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eleventh replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ede2cd0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–18/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the African Development Fund is authorized to contribute on behalf of the United States $468,165,000 to the eleventh replenishment of the resources of the Fund, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ede2cd1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–18/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $468,165,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ede2cd2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s219"},"text":"Pub. L. 94–302, title II, § 219","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/32/tXI/s1109/b"},"text":"Pub. L. 111–32, title XI, § 1109(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-24"},"text":"June 24, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1901"},"text":"123 Stat. 1901","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
