{"tag":"section","attrib":{"id":"id910e7a2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742"},"text":null,"children":[{"tag":"num","attrib":{"value":"8742"},"text":"§ 8742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of, and imposition of sanctions with respect to, persons that support or conduct certain transactions with Iran’s Revolutionary Guard Corps or other sanctioned persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id910e7a2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7a2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", and every 180 days thereafter, the President shall submit to the appropriate congressional committees a report identifying foreign persons that the President determines, on or after "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", knowingly—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e7a2d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materially assist, sponsor, or provide financial, material, or technological support for, or goods or services in support of, Iran’s Revolutionary Guard Corps or any of its officials, agents, or affiliates the property and interests in property of which are blocked pursuant to the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7a2e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" engage in a significant transaction or transactions with Iran’s Revolutionary Guard Corps or any of its officials, agents, or affiliates—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id910e7a2f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property and interests in property of which are blocked pursuant to that Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910e7a30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8741/a/1"},"text":"section 8741(a)(1) of this title","children":[],"tail":" or pursuant to paragraph (4)(A) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513/c"},"text":"section 8513(c) of this title","children":[],"tail":", as added by section 312; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7a31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" engage in a significant transaction or transactions with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id910e7a32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person subject to financial sanctions pursuant to United Nations Security Council Resolution 1737 (2006), 1747 (2007), 1803 (2008), or 1929 (2010), or any other resolution that is adopted by the Security Council and imposes sanctions with respect to Iran or modifies such sanctions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910e7a33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person acting on behalf of or at the direction of, or owned or controlled by, a person described in clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A report submitted under paragraph (1) shall be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Barter transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of paragraph (1), the term “transaction” includes a barter transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7a36-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the President determines under subsection (a)(1) that a foreign person has knowingly engaged in an activity described in that subsection, the President—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7a37-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall impose 5 or more of the sanctions described in section 6(a) of the Iran Sanctions Act of 1996, as amended by section 204; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a38-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may impose additional sanctions pursuant to the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.) with respect to the person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7a39-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may terminate a sanction imposed with respect to a foreign person pursuant to subsection (b) if the President determines that the person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7a3a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no longer engages in the activity for which the sanction was imposed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a3b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has provided assurances to the President that the person will not engage in any activity described in subsection (a)(1) in the future.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7a3c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of imposition of sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7a3d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may waive the imposition of sanctions under subsection (b) with respect to a foreign person if the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e7a3e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id910e7a3f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that the person has ceased the activity for which sanctions would otherwise be imposed and has taken measures to prevent a recurrence of the activity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910e7a40-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that it is essential to the national security interests of the United States to do so; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7a41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submits to the appropriate congressional committees a report that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id910e7a42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the foreign person with respect to which the waiver applies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910e7a43-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the activity that would otherwise subject the foreign person to the imposition of sanctions under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910e7a44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth the reasons for the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A report submitted under paragraph (1)(B) shall be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7a46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of identifications and designations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this subchapter and subject to paragraph (2), the President shall not be required to make any identification of a foreign person under subsection (a) or any identification or designation of a foreign person under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8741/a"},"text":"section 8741(a) of this title","children":[],"tail":" if the President—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7a47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that doing so would cause damage to the national security of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies the appropriate congressional committees of the exercise of the authority provided under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7a49-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of provisions of Iran Sanctions Act of 1996","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following provisions of the Iran Sanctions Act of 1996, as amended by this Act, apply with respect to the imposition under subsection (b)(1) of sanctions relating to activities described in subsection (a)(1) to the same extent that such provisions apply with respect to the imposition of sanctions under section 5(a) of the Iran Sanctions Act of 1996:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7a4a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (c) and (e) of section 4.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a4b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (c), (d), and (f) of section 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a4c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 8.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 9.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a4e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 11.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a50-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (b) of section 13.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a51-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8742/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 14.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910e7a52-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158/tIII/s302"},"text":"Pub. L. 112–158, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1243"},"text":"126 Stat. 1243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id910e7a53-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id910e7a54-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8785/a"},"text":"section 8785(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id910e7a55-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id910e7a56-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsecs. (a)(1)(A), (B)(i) and (b)(2), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513/c"},"text":"Section 8513(c) of this title","children":[],"tail":", as added by section 312, referred to in subsec. (a)(1)(B)(ii), means "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513/c"},"text":"section 8513(c) of this title","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/112/158/s312"},"text":"section 312 of Pub. L. 112–158","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Iran Sanctions Act of 1996, referred to in subsecs. (b)(1) and (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/172"},"text":"Pub. L. 104–172","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-05"},"text":"Aug. 5, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1541"},"text":"110 Stat. 1541","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":", War and National Defense. Section 6(a) of the Act, as amended by section 204, is "},{"tag":"ref","attrib":{"href":"/us/pl/104/172/s6/a"},"text":"section 6(a) of Pub. L. 104–172","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/158/s204"},"text":"section 204 of Pub. L. 112–158","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158"},"text":"Pub. L. 112–158","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1214"},"text":"126 Stat. 1214","children":[],"tail":", known as the Iran Threat Reduction and Syria Human Rights Act of 2012, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8701"},"text":"section 8701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
