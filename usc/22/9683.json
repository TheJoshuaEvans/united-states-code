{"tag":"section","attrib":{"id":"id914a2337-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683"},"text":null,"children":[{"tag":"num","attrib":{"value":"9683"},"text":"§ 9683.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id914a2338-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective at the end of the transition period, there shall be transferred to the Corporation the functions, personnel, assets, and liabilities of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a2339-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Overseas Private Investment Corporation, as in existence on the day before ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a233a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the following elements of the United States Agency for International Development:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914a233b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Development Credit Authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914a233c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The existing Legacy Credit portfolio under the Urban Environment Program and any other direct loan programs and non-Development Credit Authority guaranty programs authorized by the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.) or other predecessor Acts, as in existence on "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", other than any sovereign loan guaranties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a233d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional transfer authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective at the end of the transition period, there is authorized to be transferred to the Corporation, with the concurrence of the Administrator of the United States Agency for International Development, the functions, personnel, assets, and liabilities of the following elements of the United States Agency for International Development:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a233e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Private Capital and Microenterprise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a233f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The enterprise funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a2340-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sovereign loan guaranty transfer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a2341-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective at the end of the transition period, there is authorized to be transferred to the Corporation or any other appropriate department or agency of the United States Government the loan accounts and the legal rights and responsibilities for the sovereign loan guaranty portfolio held by the United States Agency for International Development as in existence on the day before ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a2342-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion in reorganization plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall include in the reorganization plan submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9682"},"text":"section 9682 of this title","children":[],"tail":" a description of the transfer authorized under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a2343-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bilateral agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any bilateral agreement of the United States in effect on ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", that serves as the basis for programs of the Overseas Private Investment Corporation and the Development Credit Authority shall be considered as satisfying the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9631/a"},"text":"section 9631(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a2344-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the transition period, the agencies specified in subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a2345-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to administer the assets and obligations of those agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a2346-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9683/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such programs and activities authorized under this chapter as may be determined by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914a2347-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tVI/s1463"},"text":"Pub. L. 115–254, div. F, title VI, § 1463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3512"},"text":"132 Stat. 3512","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id914a2348-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id914a2349-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id914a234a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (a)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (e)(2), was in the original “this division”, meaning division F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3485"},"text":"132 Stat. 3485","children":[],"tail":", which is classified principally to this chapter. For complete classification of division F to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9601"},"text":"section 9601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id914a234b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id914a234c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Enhancement of Nongovernmental Sector in Poland and Hungary","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tIII/s302/b"},"text":"Pub. L. 101–179, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1311"},"text":"103 Stat. 1311","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/179/tIII/s302/b"},"text":"“In accordance with its mandate to foster private initiative and competition and enhance the ability of private enterprise to make its full contribution to the development process, the Overseas Private Investment Corporation shall support projects in Poland and Hungary which will result in enhancement of the nongovernmental sector and reduction of state involvement in the economy.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For transfer of functions, personnel, assets, and liabilities of the Overseas Private Investment Corporation to the United States International Development Finance Corporation and treatment of related references, see this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9686/d"},"text":"section 9686(d) of this title","children":[],"tail":".]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tIII/s302/c"},"text":"Pub. L. 101–179, title III, § 302(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1311"},"text":"103 Stat. 1311","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/179/tIII/s302/c"},"text":"“If the Foreign Operations, Export Financing, and Related Programs Appropriations Act, 1990 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/167"},"text":"Pub. L. 101–167","children":[],"tail":"], contains the same amendment that is made by subsection (a) of this section [amending former "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2199/f"},"text":"section 2199(f) of this title","children":[],"tail":" by inserting “, Poland, Hungary,” after “Yugoslavia”], the amendment made by that Act shall not be effective.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
