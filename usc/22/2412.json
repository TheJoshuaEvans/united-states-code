{"tag":"section","attrib":{"id":"id8fb727ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2412"},"text":null,"children":[{"tag":"num","attrib":{"value":"2412"},"text":"§ 2412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on foreign assistance appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fb727ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on appropriations in absence of or in excess of prior authorizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any provision of law enacted before ","children":[{"tag":"date","attrib":{"date":"1971-01-12"},"text":"January 12, 1971","children":[],"tail":", no money appropriated for foreign assistance (including foreign military sales) shall be available for obligation or expenditure—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fb727af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2412/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the appropriation thereof has been previously authorized by law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fb727b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2412/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in excess of an amount previously prescribed by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fb727b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that legislation enacted after the making of an appropriation for foreign assistance (including foreign military sales) authorizes the obligation or expenditure thereof, the limitation contained in subsection (a) shall have no effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fb727b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific repeal or modification of section","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall not be superseded except by a provision of law enacted after ","children":[{"tag":"date","attrib":{"date":"1971-01-12"},"text":"January 12, 1971","children":[],"tail":", which specifically repeals or modifies the provisions of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fb727b3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/672/s10"},"text":"Pub. L. 91–672, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-12"},"text":"Jan. 12, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2055"},"text":"84 Stat. 2055","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fb727b4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fb727b5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8fb727b6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", known as the Foreign Assistance Act of 1961, which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
