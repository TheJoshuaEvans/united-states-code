{"tag":"section","attrib":{"id":"id907f8030-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4715"},"text":null,"children":[{"tag":"num","attrib":{"value":"4715"},"text":"§ 4715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with Congressional Budget Act","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any authority provided by this chapter to enter into contracts shall be effective only—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id907f8031-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4715/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that the budget authority for the obligation to make outlays, which is created by the contract, has been provided in advance by an appropriation Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907f8032-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4715/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent or in such amounts as are provided in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907f8033-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/tVI/s615"},"text":"Pub. L. 99–93, title VI, § 615","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/444"},"text":"99 Stat. 444","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907f8034-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907f8035-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id907f8036-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Congressional Budget Act, referred to in section catchline, probably means the Congressional Budget Act of 1974, titles I through IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text":"Pub. L. 93–344","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/297"},"text":"88 Stat. 297","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of Title 2","children":[],"tail":", The Congress, and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
