{"tag":"section","attrib":{"id":"id8f803960-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2292b"},"text":"§ 2292b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disaster assistance coordination through a Special Coordinator for International Disaster Assistance; Presidential appointment and duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized to appoint a Special Coordinator for International Disaster Assistance whose responsibility shall be to promote maximum effectiveness and coordination in responses to foreign disasters by United States agencies and between the United States and other donors. Included among the Special Coordinator’s responsibilities shall be the formulation and updating of contingency plans for providing disaster relief.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f803961-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 493, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/tI/s101/3"},"text":"Pub. L. 94–161, title I, § 101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/849"},"text":"89 Stat. 849","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f803962-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f803963-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f803964-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
