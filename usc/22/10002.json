{"tag":"section","attrib":{"id":"id914edece-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002"},"text":null,"children":[{"tag":"num","attrib":{"value":"10002"},"text":"§ 10002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914edecf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support a civilian-led political transition in Sudan that results in a democratic government, which is accountable to its people, respects and promotes human rights, is at peace internally and with its neighbors, and can be a partner for regional stability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914eded0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the implementation of Sudan’s constitutional charter for the transitional period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914eded1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to pursue a strategy of calibrated engagement with Sudan that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914eded2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating an environment for free, fair, and credible democratic elections and a pluralistic and representative political system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914eded3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting reforms that improve transparency and accountability, remove restrictions on civil and political liberties, and strengthen the protection of human rights, including religious freedom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914eded4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthening civilian institutions, judicial independence, and the rule of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914eded5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" empowering civil society and independent media;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914eded6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting national reconciliation and enabling a just, comprehensive, and sustainable peace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914eded7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the role of women in government, the economy, and society, in recognition of the seminal role that women played in the social movement that ousted former president Omar al-Bashir;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914eded8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting accountability for genocide, war crimes, crimes against humanity, and sexual and gender-based violence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914eded9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the development of civilian oversight over and professionalization of the Sudanese security and intelligence services and strengthening accountability for human rights violations and abuses, corruption, or other abuses of power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ededa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting economic reform, private sector engagement, and inclusive economic development while combating corruption and illicit economic activity, including that which involves the Sudanese security and intelligence services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ededb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing unfettered humanitarian access across all regions of Sudan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ededc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting improved development outcomes, domestic resource mobilization, and catalyzing market-based solutions to improve access to health, education, water and sanitation, and livelihoods; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ededd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10002/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting responsible international and regional engagement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914edede-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1263"},"text":"Pub. L. 116–283, div. A, title XII, § 1263","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3968"},"text":"134 Stat. 3968","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
