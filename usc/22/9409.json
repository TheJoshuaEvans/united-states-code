{"tag":"section","attrib":{"id":"id9128b969-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9409"},"text":null,"children":[{"tag":"num","attrib":{"value":"9409"},"text":"§ 9409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on United States citizens detained by Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9128b96a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2017-08-02"},"text":"August 2, 2017","children":[],"tail":", and every 180 days thereafter, the President shall submit to the appropriate congressional committees and leadership a report on United States citizens, including United States citizens who are also citizens of other countries, detained by Iran or groups supported by Iran that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9128b96b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9409/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding any officials of the Government of Iran involved in any way in the detentions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b96c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9409/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of efforts the United States Government has taken to secure the swift release of those United States citizens.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9128b96d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required by subsection (a) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9128b96e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9409/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees and leadership defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees and leadership” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9128b96f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9409/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Finance, the Committee on Banking, Housing, and Urban Affairs, the Committee on Foreign Relations, and the majority and minority leaders of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b970-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9409/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Ways and Means, the Committee on Financial Services, the Committee on Foreign Affairs, and the Speaker, the majority leader, and the minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9128b971-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tI/s110"},"text":"Pub. L. 115–44, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/896"},"text":"131 Stat. 896","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9128b972-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9128b973-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id9128b974-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section to the Secretary of State, see section 1(a) of Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2017-10-11"},"text":"Oct. 11, 2017","children":[],"tail":", 82 F.R. 50051, set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9403"},"text":"section 9403 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
