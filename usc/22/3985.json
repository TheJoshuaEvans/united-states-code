{"tag":"section","attrib":{"id":"id905479a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3985"},"text":null,"children":[{"tag":"num","attrib":{"value":"3985"},"text":"§ 3985.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary details","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A period of duty of not more than six months in duration by a member of the Service shall be considered a temporary detail and shall not be considered an assignment within the meaning of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id905479a1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s505"},"text":"Pub. L. 96–465, title I, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2094"},"text":"94 Stat. 2094","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
