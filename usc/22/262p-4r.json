{"tag":"section","attrib":{"id":"id8ea0392d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4r"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p–4r"},"text":"§ 262p–4r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of authority of United States Executive Directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ea0392e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by the President","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President determines that a particular foreign country has taken or has committed to take actions that contribute to efforts of the United States to respond to, deter, or prevent acts of international terrorism, the Secretary may, consistent with other applicable provisions of law, instruct the United States Executive Director of each international financial institution to use the voice and vote of the Executive Director to support any loan or other utilization of the funds of the respective institutions for such country, or any public or private entity within such country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ea0392f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of voice and vote","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may instruct the United States Executive Director of each international financial institution to aggressively use the voice and vote of the Executive Director to require an auditing of disbursements at such institution to ensure that no funds are paid to persons who commit, threaten to commit, or support terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ea03930-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “international financial institution” means an institution described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262r/c/2"},"text":"section 262r(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ea03931-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s360"},"text":"Pub. L. 107–56, title III, § 360","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/329"},"text":"115 Stat. 329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVI/s6202"},"text":"Pub. L. 108–458, title VI, § 6202","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3746"},"text":"118 Stat. 3746","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ea03932-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ea03933-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ea03934-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6202"},"text":"Pub. L. 108–458, § 6202","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), inserted “the” after “utilization of the funds of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6202"},"text":"Pub. L. 108–458, § 6202","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), substituted “at such institution” for “at such institutions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ea03935-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ea03936-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":", as of the date of enactment of such Act, and no amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" that is inconsistent with such amendment to be deemed to have taken effect, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6205"},"text":"section 6205 of Pub. L. 108–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1828"},"text":"section 1828 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ea03937-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of the Treasury, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s302/b/5"},"text":"section 302(b)(5) of Pub. L. 107–56","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5311"},"text":"section 5311 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
