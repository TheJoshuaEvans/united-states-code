{"tag":"section","attrib":{"id":"id9062d166-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4063"},"text":null,"children":[{"tag":"num","attrib":{"value":"4063"},"text":"§ 4063.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annuity adjustment for recall service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9062d167-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4063/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full salary in lieu of annuity; contributions to Fund; resumption of annuity with cost-of-living adjustment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any annuitant recalled to duty in the Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3948/a"},"text":"section 3948(a) of this title","children":[],"tail":" shall, while so serving, be entitled in lieu of annuity to the full salary of the class in which serving. During such service the recalled annuitant shall make contributions to the Fund in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4045"},"text":"section 4045 of this title","children":[],"tail":". On the day following termination of the recall service, the former annuity shall be resumed, adjusted by any cost-of-living increases under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4065"},"text":"section 4065 of this title","children":[],"tail":" that became effective during the recall period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9062d168-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4063/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of contributions to Fund; election for supplemental annuity or determination of annuity anew; prior service counted as recall service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the recall service lasts less than one year, the contributions of the annuitant to the Fund during recall service shall be refunded in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4055"},"text":"section 4055 of this title","children":[],"tail":". If the recall service lasts more than one year, the annuitant may, in lieu of such refund, elect a supplemental annuity computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4046"},"text":"section 4046 of this title","children":[],"tail":" on the basis of service credit and average salary earned during the recall period irrespective of the number of years of service credit previously earned. If the recall service continues for at least 5 years, the annuitant may elect to have his or her annuity determined anew under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4046"},"text":"section 4046 of this title","children":[],"tail":" in lieu of any other benefits under this section. Any annuitant who is recalled under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3948"},"text":"section 3948 of this title","children":[],"tail":" may upon written application count as recall service any prior service that is creditable under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4056"},"text":"section 4056 of this title","children":[],"tail":" that was performed after the separation upon which his or her annuity is based."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9062d169-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4063/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annuitant subject to Foreign Service Pension System","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an annuitant becomes subject to part II of this subchapter by reason of recall service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9062d16a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4063/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (a) and (b) shall not apply to such annuitant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9062d16b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4063/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4064"},"text":"section 4064 of this title","children":[],"tail":" shall apply to the recall service as if such service were reemployment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9062d16c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s823"},"text":"Pub. L. 96–465, title I, § 823","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2122"},"text":"94 Stat. 2122","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tIV/s409"},"text":"Pub. L. 99–335, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/612"},"text":"100 Stat. 612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9062d16d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9062d16e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9062d16f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9062d170-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9062d171-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/s702/a"},"text":"section 702(a) of Pub. L. 99–335","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401"},"text":"section 8401 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
