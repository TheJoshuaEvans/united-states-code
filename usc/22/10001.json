{"tag":"section","attrib":{"id":"id914edea7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001"},"text":null,"children":[{"tag":"num","attrib":{"value":"10001"},"text":"§ 10001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided, in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914edea8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914edea9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edeaa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edeab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edeac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914edead-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International financial institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “international financial institutions” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914edeae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Monetary Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edeaf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Bank for Reconstruction and Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edeb0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Development Association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edeb1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Finance Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edeb2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Inter-American Development Bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edeb3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Asian Development Bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edeb4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Inter-American Investment Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edeb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the African Development Bank;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edeb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the European Bank for Reconstruction and Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edeb7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Multilateral Investment Guaranty Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edeb8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any multilateral financial institution, established after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", that could provide financial assistance to the Government of Sudan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914edeb9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sovereignty Council","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Sovereignty Council” means the governing body of Sudan during the transitional period that consists of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914edeba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 civilians selected by the Forces of Freedom and Change;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edebb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 members selected by the Transitional Military Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edebc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member selected by agreement between the Forces of Freedom and Change and the Transitional Military Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914edebd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sudanese security and intelligence services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Sudanese security and intelligence services” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914edebe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Sudan Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edebf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Rapid Support Forces,","children":[{"tag":"ref","attrib":{"idref":"fn002465"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002465"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edec0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sudan’s Popular Defense Forces and other paramilitary units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edec1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sudan’s police forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edec2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Intelligence Service, previously known as the National Intelligence and Security Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edec3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related entities, such as Sudan’s Military Industry Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914edec4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transitional period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “transitional period” means the 39-month period beginning on ","children":[{"tag":"date","attrib":{"date":"2019-08-17"},"text":"August 17, 2019","children":[],"tail":" (the date of the signing of Sudan’s constitutional charter), during which—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914edec5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the members of the Sovereignty Council described in paragraph (3)(B) select a chair of the Council for the first 21 months of the period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914edec6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10001/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the members of the Sovereignty Council described in paragraph (3)(A) select a chair of the Council for the remaining 18 months of the period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914edec7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1262"},"text":"Pub. L. 116–283, div. A, title XII, § 1262","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3967"},"text":"134 Stat. 3967","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id914edec8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id914edec9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id914edeca-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this subtitle”, meaning subtitle G (§§ 1261–1270E) of title XII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", known as the Sudan Democratic Transition, Accountability, and Fiscal Transparency Act of 2020, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id914edecb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id914edecc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1261"},"text":"Pub. L. 116–283, div. A, title XII, § 1261","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3967"},"text":"134 Stat. 3967","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tXII/s1261"},"text":"“This subtitle [subtitle G (§§ 1261–1270E) of title XII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", enacting this chapter and amending and repealing provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":", War and National Defense] may be cited as the ‘Sudan Democratic Transition, Accountability, and Fiscal Transparency Act of 2020’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id914edecd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Special Envoy for Sudan","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXII/s7204"},"text":"Pub. L. 118–159, div. G, title LXXII, § 7204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2529"},"text":"138 Stat. 2529","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dG/tLXXII/s7204"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall, with the advice and consent of the Senate, appoint a Special Envoy for Sudan at the Department (in this section referred to as the ‘Special Envoy’). The Special Envoy shall report directly to the Secretary [of State] and should not hold another position in the Department [of State] while holding the position of Special Envoy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Special Envoy shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lead United States diplomatic efforts to support negotiations and humanitarian response efforts related to alleviating the crisis in Sudan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for coordinating policy development and execution related to ending the conflict and a future path to national recovery and democratic transition in Sudan across all bureaus in the Department and coordinating with interagency partners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult regularly with the appropriate congressional committees [Committee on Foreign Relations of the Senate and Committee on Foreign Affairs of the House of Representatives] and keep such committees fully and currently informed on the status of diplomatic efforts and negotiations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staffing.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that the Special Envoy is staffed with personnel approved by the envoy, including through reassignment of positions responsible for issues related to Sudan that currently exist within the Department, encouraging details or assignment of employees of the Department from regional and functional bureaus with expertise relevant to Sudan, or through request for interagency details of individuals with relevant experience from other United States Government departments or agencies, including the Department of Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], the Department should brief the appropriate congressional committees on the number of full-time equivalent positions supporting the Special Envoy and the relevant expertise and duties of any employees of the Department serving as detailees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The position of the Special Envoy for Sudan shall terminate on the date that is 2 years after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
