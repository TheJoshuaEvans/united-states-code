{"tag":"section","attrib":{"id":"id910293c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8515"},"text":null,"children":[{"tag":"num","attrib":{"value":"8515"},"text":"§ 8515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on procurement contracts with persons that export sensitive technology to Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id910293c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8515/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), and pursuant to such regulations as the President may prescribe, the head of an executive agency may not enter into or renew a contract, on or after the date that is 90 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", for the procurement of goods or services with a person that exports sensitive technology to Iran."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910293c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8515/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization to exempt certain products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to exempt from the prohibition under subsection (a) only eligible products, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2518/4"},"text":"section 2518(4) of title 19","children":[],"tail":", of any foreign country or instrumentality designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2511/b"},"text":"section 2511(b) of title 19","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910293c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8515/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sensitive technology defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910293c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8515/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “sensitive technology” means hardware, software, telecommunications equipment, or any other technology, that the President determines is to be used specifically—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910293c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8515/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to restrict the free flow of unbiased information in Iran; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910293ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8515/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to disrupt, monitor, or otherwise restrict speech of the people of Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910293cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8515/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sensitive technology” does not include information or informational materials the exportation of which the President does not have the authority to regulate or prohibit pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1702/b/3"},"text":"section 1702(b)(3) of title 50","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910293cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8515/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government Accountability Office report on effect of procurement prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", the Comptroller General of the United States shall submit to the appropriate congressional committees, the Committee on Armed Services of the Senate, and the Committee on Armed Services of the House of Representatives, a report assessing the extent to which executive agencies would have entered into or renewed contracts for the procurement of goods or services with persons that export sensitive technology to Iran if the prohibition under subsection (a) were not in effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910293cd-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tI/s106"},"text":"Pub. L. 111–195, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1336"},"text":"124 Stat. 1336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id910293ce-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id910293cf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8551/a"},"text":"section 8551(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id910293d0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id910293d1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2010-09-23"},"text":"Sept. 23, 2010","children":[],"tail":", 75 F.R. 67025, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8501"},"text":"section 8501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
