{"tag":"section","attrib":{"id":"id903cab4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3510"},"text":null,"children":[{"tag":"num","attrib":{"value":"3510"},"text":"§ 3510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the President to carry out this chapter, in addition to funds otherwise available for such purpose, $12,000,000 for the fiscal year 1981. Funds appropriated under this section are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id903cab50-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53/tIV/s410"},"text":"Pub. L. 96–53, title IV, § 410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/376"},"text":"93 Stat. 376","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/533/tIII/s312"},"text":"Pub. L. 96–533, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3148"},"text":"94 Stat. 3148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903cab51-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id903cab52-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id903cab53-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":