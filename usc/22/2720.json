{"tag":"section","attrib":{"id":"id8ffeb862-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2720"},"text":null,"children":[{"tag":"num","attrib":{"value":"2720"},"text":"§ 2720.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closing of consular and diplomatic posts abroad","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ffeb863-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2720/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided under subsection (d) or in accordance with the procedures under subsections (b) and (c) of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb864-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2720/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no funds authorized to be appropriated to the Department of State shall be available to pay any expense related to the closing of any United States consular or diplomatic post abroad; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb865-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2720/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no funds authorized to be appropriated to the Department of State may be used to pay for any expense related to the Bureau of Administration of the Department of State (or to carrying out any of its functions) if any United States consular or diplomatic post is closed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb866-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2720/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post closing notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 45 days before the closing of any United States consular or diplomatic post abroad, the Secretary of State shall notify the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb867-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2720/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reprogramming treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available to pay any expense related to the closing of a consular or diplomatic post abroad shall be treated as a reprogramming of funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2706"},"text":"section 2706 of this title","children":[],"tail":" and shall not be available for obligation or expenditure except in compliance with the procedures applicable to such reprogramming."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb868-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2720/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of this section do not apply with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb869-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2720/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any post closed because of a break or downgrading of diplomatic relations between the United States and the country in which the post is located; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb86a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2720/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any post closed because there is a real and present threat to United States diplomatic or consular personnel in the city where the post is located, and a travel advisory warning against travel by United States citizens to that city has been issued by the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb86b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2720/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Consular or diplomatic post” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “consular or diplomatic post” does not include a post to which only personnel of agencies other than the Department of State are assigned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ffeb86c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 48, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s112/a/1"},"text":"Pub. L. 102–138, title I, § 112(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/654"},"text":"105 Stat. 654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ffeb86d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ffeb86e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8ffeb86f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 48 of act ","children":[{"tag":"date","attrib":{"date":"1956-08-01"},"text":"Aug. 1, 1956","children":[],"tail":", was set out as a Short Title of 1956 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s111/1"},"text":"Pub. L. 102–138, title I, § 111(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/654"},"text":"105 Stat. 654","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s122"},"text":"Pub. L. 100–204, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1339"},"text":"101 Stat. 1339","children":[],"tail":", and set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2656"},"text":"section 2656 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s112/b"},"text":"Pub. L. 102–138, title I, § 112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/655"},"text":"105 Stat. 655","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ffeb870-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ffeb871-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Authority of Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, Secretary of State to have and exercise any authority vested by law in any official or office of Department of State and references to such officials or offices deemed to refer to Secretary of State or Department of State, as appropriate, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s161/d"},"text":"section 161(d) of Pub. L. 103–236","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
