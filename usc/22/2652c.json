{"tag":"section","attrib":{"id":"id8fe6c288-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2652c"},"text":"§ 2652c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretary of State for Verification and Compliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fe6c289-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of position","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall designate one of the Assistant Secretaries of State authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a/c/1"},"text":"section 2651a(c)(1) of this title","children":[],"tail":" as the Assistant Secretary of State for Verification and Compliance. The Assistant Secretary shall report to the Under Secretary of State for Arms Control and International Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fe6c28a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Directive governing the Assistant Secretary of State","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fe6c28b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"November 29, 1999","children":[],"tail":", the Secretary of State shall issue a directive governing the position of the Assistant Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fe6c28c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of the directive","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The directive issued under paragraph (1) shall set forth, consistent with this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fe6c28d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duties of the Assistant Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fe6c28e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationships between the Assistant Secretary and other officials of the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fe6c28f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any delegation of authority from the Secretary of State to the Assistant Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fe6c290-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such matters as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fe6c291-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fe6c292-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall have as his principal responsibility the overall supervision (including oversight of policy and resources) within the Department of State of all matters relating to verification and compliance with international arms control, nonproliferation, and disarmament agreements or commitments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fe6c293-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of the Assistant Secretary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fe6c294-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary role","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraphs (B) and (C), the Assistant Secretary, or his designee, shall participate in all interagency groups or organizations within the executive branch of Government that assess, analyze, or review United States planned or ongoing policies, programs, or actions that have a direct bearing on verification or compliance matters, including interagency intelligence committees concerned with the development or exploitation of measurement or signals intelligence or other national technical means of verification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fe6c295-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) shall not apply to groups or organizations on which the Secretary of State or the Undersecretary of State for Arms Control and International Security sits, unless such official designates the Assistant Secretary to attend in his stead.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fe6c296-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security limitation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8fe6c297-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver by President","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may waive the provisions of subparagraph (A) if inclusion of the Assistant Secretary would not be in the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fe6c298-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver by others","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to an interagency group or organization, or meeting thereof, working with exceptionally sensitive information contained in compartments under the control of the Director of Central Intelligence, the Secretary of Defense, or the Secretary of Energy, such Director or Secretary, as the case may be, may waive the provision of subparagraph (A) if inclusion of the Assistant Secretary would not be in the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fe6c299-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of waiver to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any waiver of participation under clause (i) or (ii) shall be transmitted in writing to the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fe6c29a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to the intelligence community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary shall be the principal policy community representative to the intelligence community on verification and compliance matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fe6c29b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall have responsibility within the Department of State for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fe6c29c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all reports required pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2577"},"text":"section 2577 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fe6c29d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so much of the report required under paragraphs (4) through (6) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2593a/a"},"text":"section 2593a(a) of this title","children":[],"tail":" as relates to verification or compliance matters;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fe6c29e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" so much of the reports required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8003"},"text":"section 8003 of this title","children":[],"tail":" as relates to verification or compliance matters; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fe6c29f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2652c/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other reports being prepared by the Department of State as of ","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"November 29, 1999","children":[],"tail":", relating to arms control, nonproliferation, or disarmament verification or compliance matters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fe6c2a0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dB/tXI/s1112"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. B, title XI, § 1112]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–486; "},{"tag":"ref","attrib":{"href":"/us/pl/109/401/tI/s108"},"text":"Pub. L. 109–401, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-18"},"text":"Dec. 18, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2738"},"text":"120 Stat. 2738","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fe6c2a1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fe6c2a2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fe6c2a3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(4)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/401"},"text":"Pub. L. 109–401","children":[],"tail":" added subpar. (C) and redesignated former subpar. (C) as (D)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fe6c2a4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id8fe6c2a5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the intelligence community deemed to be a reference to the Director of National Intelligence. Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the Central Intelligence Agency deemed to be a reference to the Director of the Central Intelligence Agency. See section 1081(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8fe6c2a6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dB/tXI/s1102"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. B, title XI, § 1102]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–485, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/113/dB/s1000/a/7/dB/tXI/s1102"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [see Short Title of 1999 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2551"},"text":"section 2551 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate committees of congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘appropriate committees of Congress’ means the Committee on International Relations [now Committee on Foreign Affairs] and the Permanent Select Committee on Intelligence of the House of Representatives and the Committee on Foreign Relations and the Select Committee on Intelligence of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistant secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Assistant Secretary’ means the position of Assistant Secretary of State for Verification and Compliance designated under section 1112 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2652c"},"text":"22 U.S.C. 2652c","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Executive agency’ has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intelligence community","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘intelligence community’ has the meaning given the term in section 3(4) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s401a/4"},"text":"50 U.S.C. 401a(4)","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"50 U.S.C. 3003(4)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" START ","children":[{"tag":"inline","attrib":{},"text":"treaty or treaty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘START Treaty’ or ‘Treaty’ means the Treaty With the Union of Soviet Socialist Republics on the Reduction and Limitation of Strategic Offensive Arms, including all agreed statements, annexes, protocols, and memoranda, signed at Moscow on ","children":[{"tag":"date","attrib":{"date":"1991-07-31"},"text":"July 31, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" START ","children":[{"tag":"inline","attrib":{},"text":"ii treaty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘START II Treaty’ means the Treaty Between the United States of America and the Russian Federation on Further Reduction and Limitation of Strategic Offensive Arms, and related protocols and memorandum of understanding, signed at Moscow on ","children":[{"tag":"date","attrib":{"date":"1993-01-03"},"text":"January 3, 1993","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
