{"tag":"section","attrib":{"id":"id90dc6d7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7202"},"text":null,"children":[{"tag":"num","attrib":{"value":"7202"},"text":"§ 7202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90dc6d80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in sections 7203 and 7204 of this title and notwithstanding any other provision of law, the President may not impose a unilateral agricultural sanction or unilateral medical sanction against a foreign country or foreign entity, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dc6d81-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 60 days before the sanction is proposed to be imposed, the President submits a report to Congress that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90dc6d82-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7202/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the activity proposed to be prohibited, restricted, or conditioned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6d83-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7202/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the actions by the foreign country or foreign entity that justify the sanction; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6d84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is enacted into law a joint resolution stating the approval of Congress for the report submitted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6d85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall terminate any unilateral agricultural sanction or unilateral medical sanction that is in effect as of ","children":[{"tag":"date","attrib":{"date":"2000-10-28"},"text":"October 28, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90dc6d86-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tIX/s903"},"text":"Pub. L. 106–387, § 1(a) [title IX, § 903]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–68.)"}],"tail":"\n"}],"tail":null}
