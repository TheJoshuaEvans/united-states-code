{"tag":"section","attrib":{"id":"id907854cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4342"},"text":null,"children":[{"tag":"num","attrib":{"value":"4342"},"text":"§ 4342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on disposition of personal prop­erty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id907854d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as authorized under subsection (b), employees or members of their family shall not sell, assign, or otherwise dispose of personal property within a foreign country which was imported into or purchased within that foreign country and which, by virtue of the official status of the employee, was exempt from import limitation, customs duties, or taxes which would otherwise apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907854d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval by chief of mission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chief of mission to a foreign country, or a designee of such chief of mission, is authorized to approve within that foreign country sales, assignment, or other dispositions of property by employees under the chief of mission’s jurisdiction (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3927"},"text":"section 3927 of this title","children":[],"tail":") to the extent that such sale, assignment, or other disposition is in accordance with regulations and policies, rules, and procedures issued pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4343"},"text":"section 4343 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907854d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4342/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Violation of this section, or other importation, sale, or other disposition of personal property within a foreign country which violates its laws or regulations or governing international law and is prohibited by regulations and policies, rules, and procedures issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4343"},"text":"section 4343 of this title","children":[],"tail":", shall be grounds for disciplinary action against an employee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907854d3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title III, § 302, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s186/a"},"text":"Pub. L. 100–204, title I, § 186(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1368"},"text":"101 Stat. 1368","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907854d4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id907854d5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id907854d6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/s186/b"},"text":"section 186(b) of Pub. L. 100–204","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4741"},"text":"section 4741 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
