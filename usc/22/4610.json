{"tag":"section","attrib":{"id":"id907d0fc2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4610"},"text":null,"children":[{"tag":"num","attrib":{"value":"4610"},"text":"§ 4610.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissolution or liquidation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon dissolution or final liquidation of the Institute or of any legal entity created pursuant to this chapter, all income and assets of the Institute or other legal entity shall revert to the United States Treasury.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907d0fc3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXVII/s1711"},"text":"Pub. L. 98–525, title XVII, § 1711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2659"},"text":"98 Stat. 2659","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
