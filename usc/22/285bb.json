{"tag":"section","attrib":{"id":"id8ebf32ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"285bb"},"text":"§ 285bb.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional contribution to special funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf32ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285bb/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ebf32f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285bb/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Bank may contribute on behalf of the United States an amount equal to the amount appropriated under subsection (b), pursuant to the resolution of the Bank entitled “Seventh Replenishment of the Asian Development Fund”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ebf32f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285bb/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject to appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any commitment to make the contribution authorized by paragraph (1) shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf32f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285bb/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the contribution authorized by subsection (a), there are authorized to be appropriated such sums as may be necessary for payment by the Secretary of the Treasury, without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf32f3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s31"},"text":"Pub. L. 89–369, § 31","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tV/s582"},"text":"Pub. L. 108–199, div. D, title V, § 582","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/204"},"text":"118 Stat. 204","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
