{"tag":"section","attrib":{"id":"id8f5ef553-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j"},"text":null,"children":[{"tag":"num","attrib":{"value":"2152j"},"text":"§ 2152j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It shall be the policy of the United States to promote the meaningful participation of women in all aspects of overseas conflict prevention, management, and resolution, and post-conflict relief and recovery efforts, reinforced through diplomatic efforts and programs that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f5ef554-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate the perspectives and interests of affected women into conflict-prevention activities and strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef555-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage partner governments to adopt plans to improve the meaningful participation of women in peace and security processes and decision-making institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef556-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the physical safety, economic security, and dignity of women and girls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef557-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the equal access of women to aid distribution mechanisms and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef558-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and analyze gender data for the purpose of developing and enhancing early warning systems of conflict and violence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef559-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjust policies and programs to improve outcomes in gender equality and the empowerment of women; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef55a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152j/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor, analyze, and evaluate the efforts related to each strategy submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2152j–1"},"text":"section 2152j–1 of this title","children":[],"tail":" and the impact of such efforts."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f5ef55b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/68/s4"},"text":"Pub. L. 115–68, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-06"},"text":"Oct. 6, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1203"},"text":"131 Stat. 1203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f5ef55c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f5ef55d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f5ef55e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Women, Peace, and Security Act of 2017, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
