{"tag":"section","attrib":{"id":"id9069fcad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4081b"},"text":null,"children":[{"tag":"num","attrib":{"value":"4081b"},"text":"§ 4081b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presence of chiefs of mission at diplomatic posts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9069fcae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4081b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for arrival at diplomatic post within 60 days","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9069fcaf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4081b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require that to be eligible for payment of travel expenses for initial arrival at the assigned post, a chief of mission must arrive at the post not later than 60 days after the date on which the chief of mission was confirmed by the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9069fcb0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4081b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The restriction under paragraph (1) shall not apply to a chief of mission who arrives later than 60 days after confirmation by the Senate if the delay was caused by one or more of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9069fcb1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4081b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A flight delay that was outside of the control of the chief of mission or the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9069fcb2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4081b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A natural disaster, global health emergency, or other naturally occurring event that prevented the chief of mission from entering the country of the assigned post.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9069fcb3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4081b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Delay or refusal by the government of the host country to accept diplomatic accreditation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9069fcb4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4081b/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Family or medical emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9069fcb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4081b/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Extenuating circumstances beyond the control of the chief of mission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9069fcb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4081b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive the requirement under paragraph (1) upon a determination that extenuating circumstances warrant such a waiver and upon submission of a brief description of the determination to the appropriate congressional committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9069fcb7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4081b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":", and in each case that a chief of mission arrives at an assigned post more than 60 days after confirmation, the Secretary shall submit to the appropriate congressional committees a report identifying any chief of mission who arrived at the assigned post more than 60 days after confirmation by the Senate, and includes a description of the justification."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9069fcb8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4081b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifications on departures of chiefs of mission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2025-04-01"},"text":"April 1, 2025","children":[],"tail":", for 5 years, the Secretary shall notify the appropriate congressional committees of any chief of mission who has permanently departed from the assigned post within 90 days of the departure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9069fcb9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXII/s7202"},"text":"Pub. L. 118–159, div. G, title LXXII, § 7202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2528"},"text":"138 Stat. 2528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9069fcba-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9069fcbb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9069fcbc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of State Authorization Act for Fiscal Year 2025, and also as part of the Servicemember Quality of Life Improvement and National Defense Authorization Act for Fiscal Year 2025, and not as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9069fcbd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id9069fcbe-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary”, “Department”, and “appropriate congressional committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7002"},"text":"section 7002 of Pub. L. 118–159","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
