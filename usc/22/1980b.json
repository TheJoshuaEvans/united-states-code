{"tag":"section","attrib":{"id":"id8f2ce92b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1980b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1980b"},"text":"§ 1980b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions for imposition of conditions on U.S. fishing vessel found inconsistent with international law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f2ce92c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1980b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary of State finds that the government of any nation imposes conditions on the operation or transit of United States fishing vessels which the United States regards as being inconsistent with international law or an international agreement, the Secretary of State shall certify that fact to the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2ce92d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1980b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of a certification under subsection (a), the President shall direct the heads of Federal agencies to impose similar conditions on the operation or transit of fishing vessels registered under the laws of the nation which has imposed conditions on United States fishing vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2ce92e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1980b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Fishing vessel” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “fishing vessel” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101/12"},"text":"section 2101(12) of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2ce92f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1980b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions commensurate with conditions certified","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that any action taken by any Federal agency under subsection (b) should be commensurate with any conditions certified by the Secretary of State under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f2ce930-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-27/ch1018/s12"},"text":"Aug. 27, 1954, ch. 1018, § 12","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/43/tIV/s402/b"},"text":"Pub. L. 104–43, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/390"},"text":"109 Stat. 390","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3541/b/4"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3541(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2323"},"text":"132 Stat. 2323","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f2ce931-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f2ce932-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f2ce933-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 2101(12)” for “section 2101(11a)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
