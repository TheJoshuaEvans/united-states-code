{"tag":"section","attrib":{"id":"id8ff2d14e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2679a"},"text":"§ 2679a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff2d14f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for periods not in excess of five years; conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any contract for the procurement of property or services, or both, for the Department of State or the Foreign Service which is funded on the basis of annual appropriations may nevertheless be made for periods not in excess of 5 years when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff2d150-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriations are available and adequate for payment for the first fiscal year and for all potential cancellation costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff2d151-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of State determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff2d152-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need of the Government for the property or service being acquired over the period of the contract is reasonably firm and continuing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff2d153-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such a contract will serve the best interests of the United States by encouraging effective competition or promoting economies in performance and operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff2d154-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such a method of contracting will not inhibit small business participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff2d155-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancellation of contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event that funds are not made available for the continuation of such a contract into a subsequent fiscal year, the contract shall be cancelled and any cancellation costs incurred shall be paid from appropriations originally available for the performance of the contract, appropriations currently available for the acquisition of similar property or services and not otherwise obligated, or appropriations made for such cancellation payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff2d156-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 14, as added and renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tI/s121"},"text":"Pub. L. 97–241, title I, § 121","children":[],"tail":", title II, § 202(a), "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/280"},"text":"96 Stat. 280","children":[],"tail":", 282.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff2d157-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff2d158-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8ff2d159-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2679a, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841/s14"},"text":"Aug. 1, 1956, ch. 841, § 14","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1974-10-26"},"text":"Oct. 26, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/93/475/s10/a"},"text":"Pub. L. 93–475, § 10(a)","children":[],"tail":"–(d), "},{"tag":"ref","attrib":{"href":"/us/stat/88/1441"},"text":"88 Stat. 1441","children":[],"tail":"; amended "},{"tag":"date","attrib":{"date":"1975-11-29"},"text":"Nov. 29, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/141/tIV/s407/a"},"text":"Pub. L. 94–141, title IV, § 407(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/771"},"text":"89 Stat. 771","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"19