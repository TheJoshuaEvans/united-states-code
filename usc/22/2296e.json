{"tag":"section","attrib":{"id":"id8f851bc2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2296e"},"text":"§ 2296e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f851bc3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance through governments and nongovernmental organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance under this part may be provided to governments or through nongovernmental organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f851bc4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of economic support funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided, any funds that have been allocated under part IV of subchapter II of this chapter for assistance for the independent states of the former Soviet Union may be used in accordance with the provisions of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f851bc5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance under this part shall be provided on such terms and conditions as the President may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f851bc6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Available authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority in this part to provide assistance for the countries of the South Caucasus and Central Asia is in addition to the authority to provide such assistance under the FREEDOM Support Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5801"},"text":"22 U.S.C. 5801","children":[],"tail":" et seq.) or any other Act, and the authorities applicable to the provision of assistance under part XI of this subchapter may be used to provide assistance under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f851bc7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 499E, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/2/tV/s596/b"},"text":"Pub. L. 106–113, div. B, § 1000(a)(2) [title V, § 596(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–125.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f851bc8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f851bc9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f851bca-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The FREEDOM Support Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511"},"text":"Pub. L. 102–511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3320"},"text":"106 Stat. 3320","children":[],"tail":", also known as the Freedom for Russia and Emerging Eurasian Democracies and Open Markets Support Act of 1992. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5801"},"text":"section 5801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f851bcb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f851bcc-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
