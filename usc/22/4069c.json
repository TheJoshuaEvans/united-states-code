{"tag":"section","attrib":{"id":"id9065427b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c"},"text":null,"children":[{"tag":"num","attrib":{"value":"4069c"},"text":"§ 4069c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health benefits for certain former spouses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9065427c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c)(1), any individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9065427d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formerly married to an employee or former employee of the Foreign Service, whose marriage was dissolved by divorce or annulment before ","children":[{"tag":"date","attrib":{"date":"1985-05-07"},"text":"May 7, 1985","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9065427e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, at any time during the 18-month period before the divorce or annulment became final, was covered under a health benefits plan as a member of the family of such employee or former employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9065427f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was married to such employee for not less than 10 years during periods of government service by such employee, is eligible for coverage under a health benefits plan in accordance with the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90654280-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prerequisites for enrollment; notification of rights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90654281-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any individual eligible for coverage under subsection (a) may enroll in a health benefits plan for self alone or for self and family if, before the expiration of the 6-month period beginning on ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":", and in accordance with such procedures as the Director of the Office of Personnel Management shall by regulation prescribe, such individual—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90654282-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files an election for such enrollment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90654283-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arranges to pay currently into the Employees Health Benefits Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8909"},"text":"section 8909 of title 5","children":[],"tail":" an amount equal to the sum of the employee and agency contributions payable in the case of an employee enrolled under chapter 89 of such title in the same health benefits plan and with the same level of benefits."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90654284-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall, as soon as possible, take all steps practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90654285-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the identity and current address of each former spouse eligible for coverage under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90654286-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to notify each such former spouse of that individual’s rights under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90654287-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall waive the 6-month limitation set forth in paragraph (1) in any case in which the Secretary determines that the circumstances so warrant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90654288-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90654289-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any former spouse who remarries before age 55 is not eligible to make an election under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90678b7a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any former spouse enrolled in a health benefits plan pursuant to an election under subsection (b)(1) may continue the enrollment under the conditions of eligibility which the Director of the Office of Personnel Management shall by regulation prescribe, except that any former spouse who remarries before age 55 shall not be eligible for continued enrollment under this section after the end of the 31-day period beginning on the date of remarriage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90678b7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on coverage by more than one plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual may be covered by a health benefits plan under this section during any period in which such individual is enrolled in a health benefits plan under any other authority, nor may any individual be covered under more than one enrollment under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90678b7c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Health benefits plan” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section the term “health benefits plan” means an approved health benefits plan under chapter 89 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90678b7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Former spouses of United States Information Agency and Agency for International Development employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any individual who on ","children":[{"tag":"date","attrib":{"date":"1981-02-14"},"text":"February 14, 1981","children":[],"tail":", was an otherwise qualified former spouse pursuant to subsections (a), (b), and (c) of this section, but who was married to a former Foreign Service employee of the United States Information Agency or of the Agency for International Development, shall be entitled to benefits under this section if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90678b7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former employee retired from the Civil Service Retirement and Disability System on a date before his employing agency could legally participate in the Foreign Service Retirement and Disability System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90678b7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4069c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the marriage included at least five years during which the employee was assigned overseas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90678b80-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s832"},"text":"Pub. L. 96–465, title I, § 832","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s188/a"},"text":"Pub. L. 100–204, title I, § 188(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1371"},"text":"101 Stat. 1371","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s146/c"},"text":"Pub. L. 101–246, title I, § 146(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/37"},"text":"104 Stat. 37","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90678b81-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90678b82-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90678b83-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 832 of the Foreign Service Act of 1980 was enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238"},"text":"Pub. L. 100–238","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4069b–1"},"text":"section 4069b–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90678b84-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246"},"text":"Pub. L. 101–246","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90678b85-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id90678b86-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau) abolished and functions transferred to Secretary of State, see sections 6531 and 6532 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
