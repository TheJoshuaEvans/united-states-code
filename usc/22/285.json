{"tag":"section","attrib":{"id":"id8ebcc247-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285"},"text":null,"children":[{"tag":"num","attrib":{"value":"285"},"text":"§ 285.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of membership by United States in Asian Development Bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is hereby authorized to accept membership for the United States in the Asian Development Bank (hereinafter referred to as the “Bank”) provided for by the agreement establishing the Bank (hereinafter referred to as the “agreement”) deposited in the archives of the United Nations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ebcc248-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s2"},"text":"Pub. L. 89–369, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-16"},"text":"Mar. 16, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/71"},"text":"80 Stat. 71","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ebcc249-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ebcc24a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id8ebcc24b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s1"},"text":"Pub. L. 89–369, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-16"},"text":"Mar. 16, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/71"},"text":"80 Stat. 71","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/89/369/s1"},"text":"“That this Act [enacting this subchapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s24"},"text":"section 24 of Title 12","children":[],"tail":", Banks and Banking] may be cited as the ‘Asian Development Bank Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ebcc24c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Par Value Modification","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For Congressional direction that the Secretary of the Treasury maintain the value in terms of gold of the Asian Development Bank’s holdings of United States dollars following the establishment of a par value of the dollar at $38 for a fine troy ounce of gold pursuant to the Par Value Modification Act and for the authorization of the appropriations necessary to provide such maintenance of value, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5152"},"text":"section 5152 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
