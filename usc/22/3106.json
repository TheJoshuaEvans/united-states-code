{"tag":"section","attrib":{"id":"id902c0a2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3106"},"text":null,"children":[{"tag":"num","attrib":{"value":"3106"},"text":"§ 3106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of experts and administrative support services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id902c0a2d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any official designated by the President to carry out this chapter may procure the temporary or intermittent services of experts and consultants in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":". Persons so employed shall receive compensation at a rate not in excess of the maximum amount payable under such section. While away from his home or regular place of business and engaged in the performance of services in conjunction with the provisions of this chapter, any such person may be allowed travel expenses, including per diem in lieu of subsistence, as authorized by section 5703(b) "},{"tag":"ref","attrib":{"idref":"fn002240"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002240"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 5 for persons in the Government service employed intermittently."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id902c0a2e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of available Federal agency services, equipment, personnel, and facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any official designated by the President to carry out this chapter may use, on a reimbursable basis when appropriate (as determined by the President), the available services, equipment, personnel, and facilities of any agency or instrumentality of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id902c0a2f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/472/s7"},"text":"Pub. L. 94–472, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-11"},"text":"Oct. 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2064"},"text":"90 Stat. 2064","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id902c0a30-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id902c0a31-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id902c0a32-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"Section 5703 of title 5","children":[],"tail":", referred to in subsec. (a), was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/94/22/s4"},"text":"Pub. L. 94–22, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-05-19"},"text":"May 19, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/85"},"text":"89 Stat. 85","children":[],"tail":", and, as so amended, does not contain a subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
