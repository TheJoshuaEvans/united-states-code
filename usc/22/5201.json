{"tag":"section","attrib":{"id":"id9088f710-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5201"},"text":null,"children":[{"tag":"num","attrib":{"value":"5201"},"text":"§ 5201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings; determinations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9088f711-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9088f712-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5201/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Middle East terrorism accounted for 60 percent of total international terrorism in 1985;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9088f713-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5201/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Palestine Liberation Organization (hereafter in this chapter referred to as the “PLO”) was directly responsible for the murder of an American citizen on the Achille Lauro cruise liner in 1985, and a member of the PLO’s Executive Committee is under indictment in the United States for the murder of that American citizen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9088f714-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5201/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the PLO has been implicated in the murder of a United States Ambassador overseas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9088f715-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5201/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the PLO and its constituent groups have taken credit for, and been implicated in, the murders of dozens of American citizens abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9088f716-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5201/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the PLO covenant specifically states that “armed struggle is the only way to liberate Palestine, thus it is an overall strategy, not merely a tactical phase”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9088f717-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5201/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the PLO rededicated itself to the “continuing struggle in all its armed forms” at the Palestine National Council meeting in April 1987; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9088f718-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5201/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General has stated that “various elements of the Palestine Liberation Organization and its allies and affiliates are in the thick of international terror”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9088f719-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Therefore, the Congress determines that the PLO and its affiliates are a terrorist organization and a threat to the interests of the United States, its allies, and to international law and should not benefit from operating in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9088f71a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tX/s1002"},"text":"Pub. L. 100–204, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1406"},"text":"101 Stat. 1406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9088f71b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9088f71c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9088f71d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date and Termination","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tX/s1005"},"text":"Pub. L. 100–204, title X, § 1005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1407"},"text":"101 Stat. 1407","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/204/tX/s1005"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Provisions of this title [enacting this chapter] shall take effect 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of this title shall cease to have effect if the President certifies in writing to the President pro tempore of the Senate and the Speaker of the House that the Palestine Liberation Organization, its agents, or constituent groups thereof no longer practice or support terrorist actions anywhere in the world.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id9088f71e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tX/s1001"},"text":"Pub. L. 100–204, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1406"},"text":"101 Stat. 1406","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/204/tX/s1001"},"text":"“This title [enacting this chapter] may be cited as the ‘Anti-Terrorism Act of 1987’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
