{"tag":"section","attrib":{"id":"id8eb8076e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282o"},"text":null,"children":[{"tag":"num","attrib":{"value":"282o"},"text":"§ 282o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selective capital increase and amendment of the Articles of Agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eb8076f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vote authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Corporation is authorized to vote in favor of a resolution to increase the capital stock of the Corporation by $130,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eb80770-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment of the Articles of Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Corporation is authorized to agree to and accept an amendment to Article IV, Section 3(a) of the Articles of Agreement of the Corporation that achieves an increase in basic votes to 5.55 percent of total votes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eb80771-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch788/s17"},"text":"Aug. 11, 1955, ch. 788, § 17","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dI/tVII/s7081/b"},"text":"Pub. L. 112–74, div. I, title VII, § 7081(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1259"},"text":"125 Stat. 1259","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
