{"tag":"section","attrib":{"id":"id8e8ab5a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s261"},"text":null,"children":[{"tag":"num","attrib":{"value":"261"},"text":"§ 261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy as to settlement of disputes and disarmament","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is declared to be the policy of the United States to adjust and settle its international disputes through mediation or arbitration, to the end that war may be honorably avoided. It looks with apprehension and disfavor upon a general increase of armament throughout the world, but it realizes that no single nation can disarm, and that without a common agreement upon the subject every considerable power must maintain a relative standing in military strength.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8e8ab5a1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-29/ch417"},"text":"Aug. 29, 1916, ch. 417","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/618"},"text":"39 Stat. 618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e8ab5a2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e8ab5a3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id8e8ab5a4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/158/s1"},"text":"Pub. L. 111–158, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-04-26"},"text":"Apr. 26, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1121"},"text":"124 Stat. 1121","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/158/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–12"},"text":"section 262p–12 of this title","children":[],"tail":"] may be cited as the ‘Haiti Debt Relief and Earthquake Recovery Act of 2010’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id8e8ab5a5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/s1"},"text":"Pub. L. 95–118, § 1","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXIII/s1361/a"},"text":"Pub. L. 97–35, title XIII, § 1361(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/745"},"text":"95 Stat. 745","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/35/tXIII/s1361/a"},"text":"“This Act [enacting sections 262c, 262d, 262e to 262g–3, 282i, 284n, 285s, 285t, 286e–1f, and 290g–10 of this title, repealing sections 283y, 284m, and 290g–9 of this title, and enacting provisions set out as notes under 262c and 282i of this title] may be cited as the ‘International Financial Institutions Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
