{"tag":"section","attrib":{"id":"id8eac1fb4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"276c–6"},"text":"§ 276c–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supporting the employment of United States citizens by international organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eac1fb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eac1fb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department should continue to eliminate the unreasonable barriers United States nationals face to obtain employment in the United Nations Secretariat, funds, programs, and agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eac1fb7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department should bolster efforts to increase the number of qualified United States nationals who are candidates for leadership and oversight positions in the United Nations system, agencies, and commissions, and in other international organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac1fb8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to promote the employment and advancement of United States citizens by international organizations and bodies, including by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eac1fb9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing stipends, consultation, and analytical services to support United States citizen applicants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eac1fba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making grants for the purposes described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac1fbb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Using diplomatic programs funding to promote the employment of United States citizens by international organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated under the heading “Diplomatic Programs” in Acts making appropriations for the Department of State, Foreign Operations, and Related Programs are authorized to be appropriated for grants, programs, and activities described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac1fbc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy to establish junior professional program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eac1fbd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary, in coordination with the Secretary of the Treasury and other relevant cabinet members, shall publish a strategy for encouraging United States citizens to pursue careers with international organizations, particularly organizations that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8eac1fbe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set international scientific, technical, or commercial standards; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8eac1fbf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are involved in international finance and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eac1fc0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary, in coordination with the Secretary of the Treasury and other relevant cabinet members, shall submit a report to the appropriate congressional committees that identifies—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8eac1fc1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of United States citizens who are involved in relevant junior professional programs in an international organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8eac1fc2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of individuals described in subparagraph (A) among various international organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8eac1fc3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276c–6/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of pre-deployment training that are available to United States citizens through a junior professional program at an international organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eac1fc4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCVII/s9701"},"text":"Pub. L. 117–263, div. I, title XCVII, § 9701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3913"},"text":"136 Stat. 3913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eac1fc5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eac1fc6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8eac1fc7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Department”, “Secretary”, and “appropriate congressional committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s9002"},"text":"section 9002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
