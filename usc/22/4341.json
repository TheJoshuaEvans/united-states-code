{"tag":"section","attrib":{"id":"id907854b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341"},"text":null,"children":[{"tag":"num","attrib":{"value":"4341"},"text":"§ 4341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, the following terms have the following meanings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id907854ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “employee” means an individual who is under the jurisdiction of a chief of mission to a foreign country (as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3927"},"text":"section 3927 of this title","children":[],"tail":") and who is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id907854bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id907854bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of the United States Postal Service or of the Postal Regulatory Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id907854bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of a uniformed service who is not under the command of an area military commander; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id907854be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expert or consultant as authorized pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":" with the United States or any agency, department, or establishment thereof; but is not a national or permanent resident of the foreign country in which employed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907854bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “contractor” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id907854c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual employed by personal services contract pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2669/c"},"text":"section 2669(c) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2396/a/3"},"text":"section 2396(a)(3) of this title","children":[],"tail":", or pursuant to other similar authority, including, in the case of an organization performing services under such authority, an individual involved in the performance of such services; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id907854c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other individuals or firms providing goods or services by contract as are designated by regulations issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4343"},"text":"section 4343 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include a contractor with or under the supervision of an area military commander.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907854c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “charitable contribution” means a contribution or gift as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s170/c"},"text":"section 170(c) of title 26","children":[],"tail":", or other similar contribution or gift to a bona fide charitable foreign entity as determined pursuant to regulations or policies issued pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4343"},"text":"section 4343 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907854c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “chief of mission” has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3902/3"},"text":"section 3902(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907854c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “foreign country” means any country or territory, excluding the United States, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, the Trust Territory of the Pacific Islands, American Samoa, Guam, the Virgin Islands, and other territories or possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907854c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “personal property” means any item of personal property, including automobiles, computers, boats, audio and video equipment, and any other items acquired for personal use, but excluding items of minimal value as determined by regulation or policy issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4343"},"text":"section 4343 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907854c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4341/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “profit” means any proceeds (including cash and other valuable consideration but not including amounts of such proceeds given as charitable contributions) for the sale, disposition, or assignment of personal property in excess of the basis for such property. For purposes of this chapter, basis shall include initial price, inland and overseas transportation costs (if not reimbursed by the United States Government), shipping insurance, taxes, customs fees, duties or other charges, and capital improvements, but shall not include insurance on an item while in use, or maintenance and related costs. For purposes of computing profit, proceeds and costs shall be valued in United States dollars at the time of receipt or payment, at a rate of exchange as determined by regulation or policy issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4343"},"text":"section 4343 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907854c7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title III, § 301, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s186/a"},"text":"Pub. L. 100–204, title I, § 186(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1366"},"text":"101 Stat. 1366","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tVI/s604/f"},"text":"Pub. L. 109–435, title VI, § 604(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3242"},"text":"120 Stat. 3242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907854c8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907854c9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id907854ca-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435"},"text":"Pub. L. 109–435","children":[],"tail":" substituted “Postal Regulatory Commission” for “Postal Rate Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id907854cb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id907854cc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s186/b"},"text":"Pub. L. 100–204, title I, § 186(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1368"},"text":"101 Stat. 1368","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/204/tI/s186/b"},"text":"“This section [enacting this chapter] shall take effect 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id907854cd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id907854ce-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
