{"tag":"section","attrib":{"id":"id90712978-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4159"},"text":null,"children":[{"tag":"num","attrib":{"value":"4159"},"text":"§ 4159.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivor benefits for certain former spouses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90712979-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4159/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible participants; election of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any participant or former participant in the Foreign Service Retirement and Disability System who on ","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":", has a former spouse may, by a spousal agreement, elect to receive a reduced annuity and provide a survivor annuity for such former spouse under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4054/b"},"text":"section 4054(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9071297a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4159/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9071297b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4159/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the participant or former participant has not retired under such system on or before ","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":", an election under this section may be made at any time before retirement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9071297c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4159/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the participant or former participant has retired under such system on or before ","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":", an election under this section may be made within such period after "},{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":", as the Secretary of State may prescribe."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9071297d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4159/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of applying subchapter VIII of this chapter, any such election shall be treated the same as if it were a spousal agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4060/b/1"},"text":"section 4060(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9071297e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4159/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Portion of annuity as basis for benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An election under this section may provide for a survivor benefit based on all or any portion of that part of the annuity of the participant which is not designated or committed as a base for survivor benefits for a spouse or any other former spouse of the participant. The participant and his or her spouse may make an election under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4046/b/1/B"},"text":"section 4046(b)(1)(B) of this title","children":[],"tail":" prior to the time of retirement for the purpose of allowing an election to be made under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9071297f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4159/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of reduction; effective date","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the reduction in the participant’s annuity shall be determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4046/b/2"},"text":"section 4046(b)(2) of this title","children":[],"tail":". Such reduction shall be effective as of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90712980-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4159/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commencing date of the participant’s annuity, in the case of an election under subsection (b)(1), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90712981-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4159/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":", in the case of an election under subsection (b)(2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90712982-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4159/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the terms “former spouse”, “participant”, and “spousal agreement” have the meanings given such terms in sections 4043 and 4044 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90712983-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2109"},"text":"Pub. L. 96–465, title II, § 2109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2152"},"text":"94 Stat. 2152","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
