{"tag":"section","attrib":{"id":"id90b3d7e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6324"},"text":null,"children":[{"tag":"num","attrib":{"value":"6324"},"text":"§ 6324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b3d7e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6324/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “highly enriched uranium” means uranium enriched to 20 percent or more in the isotope U–235;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6324/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “IAEA” means the International Atomic Energy Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6324/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “near real time material accountancy” means a method of accounting for the location, quantity, and disposition of special fissionable material at facilities that store or process such material, in which verification of peaceful use is continuously achieved by means of frequent physical inventories and the use of in-process instrumentation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6324/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “special fissionable material” has the meaning given that term by Article XX(1) of the Statute of the International Atomic Energy Agency, done at the Headquarters of the United Nations on ","children":[{"tag":"date","attrib":{"date":"1956-10-26"},"text":"October 26, 1956","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6324/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “the Treaty” means the Treaty on the Non-Proliferation of Nuclear Weapons, signed at Washington, London, and Moscow on ","children":[{"tag":"date","attrib":{"date":"1968-07-01"},"text":"July 1, 1968","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6324/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “IAEA safeguards”, “non-nuclear-weapon state”, “nuclear explosive device”, and “special nuclear material” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6305"},"text":"section 6305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90b3d7eb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVIII/s844"},"text":"Pub. L. 103–236, title VIII, § 844","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/524"},"text":"108 Stat. 524","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
