{"tag":"section","attrib":{"id":"id9030c3fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3242"},"text":null,"children":[{"tag":"num","attrib":{"value":"3242"},"text":"§ 3242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Department of Energy, in consultation with the Commission, shall establish and operate a safeguards and physical security training program to be made available to persons from nations and groups of nations which have developed or acquired, or may be expected to develop or acquire, nuclear materials and equipment for use for peaceful purposes. Any such program shall include training in the most advanced safeguards and physical security techniques and technology, consistent with the national security interests of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9030c3ff-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/242/tII/s202"},"text":"Pub. L. 95–242, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-10"},"text":"Mar. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/124"},"text":"92 Stat. 124","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9030c400-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9030c401-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id9030c402-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-03-10"},"text":"Mar. 10, 1978","children":[],"tail":", except as otherwise provided and regardless of any requirements for the promulgation of implementing regulations, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/242/s603/c"},"text":"section 603(c) of Pub. L. 95–242","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3201"},"text":"section 3201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
