{"tag":"section","attrib":{"id":"id90c4a069-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6742"},"text":null,"children":[{"tag":"num","attrib":{"value":"6742"},"text":"§ 6742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition relating to low concentrations of Schedules 2 and 3 chemicals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c4a06a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6742/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter, no person located in the United States shall be required to report on, or to submit to, any routine inspection conducted for the purpose of verifying the production, possession, consumption, exportation, importation, or proposed production, possession, consumption, exportation, or importation of any substance that contains less than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a06b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6742/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent concentration of a Schedule 2 chemical; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a06c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6742/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent concentration of a Schedule 3 chemical.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a06d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6742/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard for measurement of concentration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The percent concentration of a chemical in a substance shall be measured on the basis of volume or total weight, which measurement yields the lesser percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c4a06e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/tIV/s402"},"text":"Pub. L. 105–277, div. I, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-881"},"text":"112 Stat. 2681–881","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90c4a06f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90c4a070-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90c4a071-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act” and was translated as reading “this division”, meaning div. I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-856"},"text":"112 Stat. 2681–856","children":[],"tail":", known as the Chemical Weapons Convention Implementation Act of 1998, to reflect the probable intent of Congress. For complete classification of division I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6701"},"text":"section 6701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
