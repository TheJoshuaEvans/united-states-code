ent by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/s702/a"},"text":"section 702(a) of Pub. L. 99–335","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401"},"text":"section 8401 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90595b60-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter effective ","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"Feb. 15, 1981","children":[],"tail":", except regarding the rights of former spouses to any annuity under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4054/a"},"text":"section 4054(a) of this title","children":[],"tail":" or except to the extent provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4159"},"text":"section 4159 of this title","children":[],"tail":", regarding rights of former spouses to receive survivor annuities under this subchapter, see section 2403(a) and (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90595b61-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Retirement Benefits for Foreign National Employees Engaging in Hostile Intelligence Activities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s158"},"text":"Pub. L. 100–204, title I, § 158","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1355"},"text":"101 Stat. 1355","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/204/tI/s158"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of State shall exercise the authorities available to him to ensure that the United States does not provide, directly or indirectly, any retirement benefits of any kind to any present or former foreign national employee of a United States diplomatic or consular post against whom the Secretary has convincing evidence that such employee has engaged in intelligence activities directed against the United States. To the extent practicable, the Secretary shall provide due process in implementing this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of State may waive the applicability of subsection (a) on a case-by-case basis with respect to an employee if he determines that it is vital to the national security of the United States to do so and he reports such waiver to the appropriate committees of the Congress.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90595b62-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Retirement Contributions and Procedures for Certain Participants","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For temporary provisions providing modified contributions and procedures for members of the Service participating in the Foreign Service Retirement and Disability System who are also required to pay employment taxes relating to benefits under title II of the Social Security Act, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"42 U.S.C. 401","children":[],"tail":" et seq., until they are covered by a new Government retirement system or "},{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", whichever is earlier, see title II of "},{"tag":"ref","attrib":{"href":"/us/pl/98/168"},"text":"Pub. L. 98–168","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8331"},"text":"section 8331 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id90595b63-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id90595b64-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to Secretary of State, see section 1 of Ex. Ord. No. 12293, ","children":[{"tag":"date","attrib":{"date":"1981-02-23"},"text":"Feb. 23, 1981","children":[],"tail":", 46 F.R. 13969, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
