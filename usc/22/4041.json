{"tag":"section","attrib":{"id":"id90595b58-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4041"},"text":null,"children":[{"tag":"num","attrib":{"value":"4041"},"text":"§ 4041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In accordance with such regulations as the President may prescribe, the Secretary of State shall administer the Foreign Service Retirement and Disability System (hereinafter in this part referred to as the “System”), originally established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-05-24/s18"},"text":"section 18 of the Act of May 24, 1924","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/43/144"},"text":"43 Stat. 144","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90595b59-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s801"},"text":"Pub. L. 96–465, title I, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2102"},"text":"94 Stat. 2102","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tIV/s402/a/2"},"text":"Pub. L. 99–335, title IV, § 402(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/609"},"text":"100 Stat. 609","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90595b5a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90595b5b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":