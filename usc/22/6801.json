children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-19"},"text":"Aug. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/749"},"text":"114 Stat. 749","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/264/tI/s101"},"text":"“This title [enacting this chapter and amending sections 2151b, 2222 and 2293 of this title] may be cited as the ‘Global AIDS Research and Relief Act of 2000’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
