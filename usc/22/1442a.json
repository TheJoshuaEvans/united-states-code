{"tag":"section","attrib":{"id":"id8efd266d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1442a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1442a"},"text":"§ 1442a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security measures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8efd266e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1442a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In coordination with other appropriate executive branch officials, the Secretary of State shall take all appropriate steps to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8efd266f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1442a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent any agent of a foreign power from participating in educational and cultural exchange programs under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8efd2670-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1442a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that no person who is involved in the research, development, design, testing, evaluation, or production of missiles or weapons of mass destruction is a participant in any program of educational or cultural exchange under this chapter if such person is employed by, or attached to, an entity within a country that has been identified by any element of the United States intelligence community (as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"section 3003(4) of title 50","children":[],"tail":") within the previous 5 years as having been involved in the proliferation of missiles or weapons of mass destruction; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8efd2671-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1442a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that no person who is involved in the research, development, design, testing, evaluation, or production of chemical or biological weapons for offensive purposes is a participant in any program of educational or cultural exchange under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8efd2672-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1442a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8efd2673-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1442a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “appropriate executive branch officials” means officials from the elements of the United States Government listed pursuant to section 101 of the Intelligence Authorization Act for Fiscal Year 1999 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/272"},"text":"Public Law 105–272","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8efd2674-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1442a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “agent of a foreign power” has the same meaning as set forth in section 1801(b)(1)(B) and (b)(2) of title 50, and does not include any person who acts in the capacity defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801/b/1/A"},"text":"section 1801(b)(1)(A) of title 50","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8efd2675-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-27/ch36"},"text":"Jan. 27, 1948, ch. 36","children":[],"tail":", title X, § 1012, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tIV/s403"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title IV, § 403]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–446.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8efd2676-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8efd2677-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8efd2678-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 101 of the Intelligence Authorization Act for Fiscal Year 1999, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/272/s101"},"text":"section 101 of Pub. L. 105–272","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"1998-10-20"},"text":"Oct. 20, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2397"},"text":"112 Stat. 2397","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
