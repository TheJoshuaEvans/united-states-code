{"tag":"section","attrib":{"id":"id90c6ea2f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6831"},"text":null,"children":[{"tag":"num","attrib":{"value":"6831"},"text":"§ 6831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c6ea30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6831/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports by Treasury Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c6ea31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6831/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2000-08-19"},"text":"August 19, 2000","children":[],"tail":", and annually thereafter for the duration of the Trust Fund, the Secretary of the Treasury shall submit to the appropriate committees of Congress a report on the Trust Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c6ea32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6831/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90c6ea33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6831/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the goals of the Trust Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c6ea34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6831/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs, projects, and activities, including any vaccination approaches, supported by the Trust Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c6ea35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6831/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private and governmental contributions to the Trust Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c6ea36-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6831/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria that have been established, acceptable to the Secretary of the Treasury and the Administrator of the United States Agency for International Development, that would be used to determine the programs and activities that should be assisted by the Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c6ea37-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6831/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO report on Trust Fund effectiveness","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2000-08-19"},"text":"August 19, 2000","children":[],"tail":", the Comptroller General of the United States shall submit to the appropriate committees of the Congress a report evaluating the effectiveness of the Trust Fund, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c6ea38-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6831/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the programs, projects, and activities described in subsection (a)(2)(B) in reducing the worldwide spread of AIDS; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c6ea39-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6831/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the merits of continued United States financial contributions to the Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c6ea3a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6831/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In subsection (a), the term “appropriate committees” means the Committee on Foreign Relations and the Committee on Appropriations of the Senate and the Committee on International Relations, the Committee on Banking and Financial Services, and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c6ea3b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/264/tI/s131"},"text":"Pub. L. 106–264, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-19"},"text":"Aug. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/757"},"text":"114 Stat. 757","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90c6ea3c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90c6ea3d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id90c6ea3e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Banking and Financial Services of House of Representatives abolished and replaced by Committee on Financial Services of House of Representatives, and jurisdiction over matters relating to securities and exchanges and insurance generally transferred from Committee on Energy and Commerce of House of Representatives by House Resolution No. 5, One Hundred Seventh Congress, ","children":[{"tag":"date","attrib":{"date":"2001-01-03"},"text":"Jan. 3, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
