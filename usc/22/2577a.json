{"tag":"section","attrib":{"id":"id8fd6214e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2577a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2577a"},"text":"§ 2577a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arms control verification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fd6214f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2577a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of working group","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President should establish a working group—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fd62150-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2577a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to examine verification approaches to a strategic arms reduction agreement and other arms control agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd62151-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2577a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess the relevance for such agreements of the verification provisions of the Treaty Between the United States and the Union of Soviet Socialist Republics on the Elimination of Their Intermediate-Range and Shorter-Range Missiles (signed at Washington, ","children":[{"tag":"date","attrib":{"date":"1987-12-08"},"text":"December 8, 1987","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fd62152-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2577a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information and data base","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fd62153-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2577a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Agency shall allocate sufficient resources to develop and maintain a comprehensive information and data base on verification concepts, research, technologies, and systems. The Agency shall collect, maintain, analyze, and disseminate information pertaining to arms control verification and monitoring, including information regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fd62154-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2577a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all current United States bilateral and multilateral arms treaties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fd62155-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2577a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed, prospective, and potential bilateral or multilateral arms treaties in the areas of nuclear, conventional, chemical, and space weapons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd62156-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2577a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Agency shall seek to improve United States verification and monitoring activities through the monitoring and support of relevant research and analysis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd62157-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2577a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Agency shall provide detailed information on the activities pursuant to this section in its annual report to the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fd62158-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/216/tI/s105"},"text":"Pub. L. 101–216, title I, § 105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-11"},"text":"Dec. 11, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1854"},"text":"103 Stat. 1854","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fd62159-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fd6215a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8fd6215b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Arms Control and Disarmament Amendments Act of 1989, and not as part of the Arms Control and Disarmament Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fd6215c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id8fd6215d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Agency”, referred to in subsec. (b), meaning the United States Arms Control and Disarmament Agency, abolished and functions transferred to Secretary of State, see sections 6511 and 6512 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
