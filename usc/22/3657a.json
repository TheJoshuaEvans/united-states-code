{"tag":"section","attrib":{"id":"id904166c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3657a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3657a"},"text":"§ 3657a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarters allowances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904166c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3657a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Position” and “employee” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraphs (2) and (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3651"},"text":"section 3651 of this title","children":[],"tail":", as used in this section—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id904166c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3657a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “position” means a civilian position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904166c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3657a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “employee” means an individual serving in a position in the Department of Defense whose permanent duty station is in the area which, before ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", was known as the Canal Zone."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904166c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3657a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under regulations prescribed by or under authority of the President, the Department of Defense may grant a quarters allowance in the case of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904166c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3657a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee who is a citizen of the United States and who, before ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":", was employed by the Panama Canal Company, the Canal Zone Government, or any other agency, in the area then known as the Canal Zone; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904166c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3657a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other employee who is a citizen of the United States and who (before, on, or after the effective date of this section) is or was recruited within the United States;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for whom adequate Government owned or leased quarters are not made available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904166c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3657a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of any quarters allowance granted to an employee under this section shall be determined in accordance with the regulations prescribed under subsection (b) of this section, except that such allowance for any period may not exceed the amount, if any, by which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904166c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3657a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id904166ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3657a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual expenses for rent and utilities incurred by the employee during such period while occupying quarters other than Government owned or leased quarters; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id904166cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3657a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maximum amount which would be authorized for such employee with respect to such period under the Department of State Standardized Regulations (Government Civilians, Foreign Areas) if such employee were covered by those regulations;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"exceeds","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904166cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3657a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated total cost of rent and utilities which the employee would have been charged if Government owned or leased quarters had been provided on a rental basis during such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904166cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3657a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of election under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3652/b"},"text":"section 3652(b) of this title","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall apply without regard to whether any election by the Department of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3652/b"},"text":"section 3652(b) of this title","children":[],"tail":" is then in effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904166ce-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1217a"},"text":"Pub. L. 96–70, title I, § 1217a","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/600/s1/a"},"text":"Pub. L. 98–600, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3145"},"text":"98 Stat. 3145","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904166cf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904166d0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id904166d1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of this section, referred to in subsec. (b)(2), see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/600/s2"},"text":"section 2 of Pub. L. 98–600","children":[],"tail":", set out below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id904166d2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id904166d3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/600/s2"},"text":"Pub. L. 98–600, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3146"},"text":"98 Stat. 3146","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/600/s2"},"text":"“The amendments made by this Act [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1984-10-01"},"text":"October 1, 1984","children":[],"tail":", and shall apply with respect to utility costs incurred, and rent payable for any period beginning, on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id904166d4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"id904166d5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 12520. Quarters Allowance to Department of Defense Employees in Panama","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12520, ","children":[{"tag":"date","attrib":{"date":"1985-06-19"},"text":"June 19, 1985","children":[],"tail":", 50 F.R. 25683, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including section 1217a of the Panama Canal Act of 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3657a"},"text":"22 U.S.C. 3657a","children":[],"tail":"), it is hereby ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. The Secretary of Defense is authorized to prescribe the regulations referred to in section 1217a of the Panama Canal Act of 1979 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3657a"},"text":"22 U.S.C. 3657a","children":[],"tail":"], relating to quarters allowances."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. The regulations prescribed under Section 1 shall be consistent with Article VII(4) of the Agreement in Implementation of Article IV of the Panama Canal Treaty and with all other relevant provisions of the Panama Canal Treaty and related agreements."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Ronald Reagan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
