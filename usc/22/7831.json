{"tag":"section","attrib":{"id":"id90ef8081-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7831"},"text":null,"children":[{"tag":"num","attrib":{"value":"7831"},"text":"§ 7831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on United States humanitarian assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ef8082-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7831/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2004-10-18"},"text":"October 18, 2004","children":[],"tail":", and annually thereafter through 2022, the Administrator of the United States Agency for International Development, in conjunction with the Secretary of State, shall submit to the appropriate congressional committees a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ef8083-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7831/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all activities to provide humanitarian assistance inside North Korea, and to North Koreans outside of North Korea, that receive United States funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8084-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7831/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any improvements in humanitarian transparency, monitoring, and access inside North Korea during the previous 1-year period, including progress toward meeting the conditions identified in subparagraphs (A) through (D) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7832/b/1"},"text":"section 7832(b)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8085-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7831/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific efforts to secure improved humanitarian transparency, monitoring, and access inside North Korea made by the United States and United States grantees, including the World Food Program, during the previous 1-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef8086-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7831/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Needs assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report shall include a needs assessment to inform the distribution of humanitarian assistance inside North Korea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef8087-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7831/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information required by subsection (a)(1) may be provided in classified form if necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ef8088-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/333/tII/s201"},"text":"Pub. L. 108–333, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1293"},"text":"118 Stat. 1293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dD/tV/s534/j"},"text":"Pub. L. 108–447, div. D, title V, § 534(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3007"},"text":"118 Stat. 3007","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/346/s9"},"text":"Pub. L. 110–346, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-07"},"text":"Oct. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3942"},"text":"122 Stat. 3942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/172/s8"},"text":"Pub. L. 112–172, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-16"},"text":"Aug. 16, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1309"},"text":"126 Stat. 1309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/198/s7/d"},"text":"Pub. L. 115–198, § 7(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-20"},"text":"July 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1523"},"text":"132 Stat. 1523","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ef8089-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ef808a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90ef808b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/198/s7/d/1"},"text":"Pub. L. 115–198, § 7(d)(1)","children":[],"tail":", substituted “2022” for “2017” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/198/s7/d/2"},"text":"Pub. L. 115–198, § 7(d)(2)","children":[],"tail":", (3), added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/172"},"text":"Pub. L. 112–172","children":[],"tail":" substituted “2017” for “2012” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/346"},"text":"Pub. L. 110–346","children":[],"tail":" substituted “annually thereafter through 2012” for “in each of the 2 years thereafter” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" substituted “subparagraphs (A) through (D) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7832/b/1"},"text":"section 7832(b)(1) of this title","children":[],"tail":"” for “paragraphs (1) through (4) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7832/b"},"text":"section 7832(b) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
