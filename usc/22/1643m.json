{"tag":"section","attrib":{"id":"id8f14f4a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1643m"},"text":null,"children":[{"tag":"num","attrib":{"value":"1643m"},"text":"§ 1643m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusivity of Foreign Claims Settlement Commission certification procedure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f14f4a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1643m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (b), neither any national of the United States who was eligible to file a claim under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1643b"},"text":"section 1643b of this title","children":[],"tail":" but did not timely file such claim under that section, nor any person who was ineligible to file a claim under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1643b"},"text":"section 1643b of this title","children":[],"tail":", nor any national of Cuba, including any agency, instrumentality, subdivision, or enterprise of the Government of Cuba or any local government of Cuba, nor any successor thereto, whether or not recognized by the United States, shall have a claim to, participate in, or otherwise have an interest in, the compensation proceeds or nonmonetary compensation paid or allocated to a national of the United States by virtue of a claim certified by the Commission under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1643f"},"text":"section 1643f of this title","children":[],"tail":", nor shall any district court of the United States have jurisdiction to adjudicate any such claim."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f14f4a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1643m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in subsection (a) shall be construed to detract from or otherwise affect any rights in the shares of capital stock of nationals of the United States owning claims certified by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1643f"},"text":"section 1643f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f14f4a5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title V, § 515, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/114/tIII/s304"},"text":"Pub. L. 104–114, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/821"},"text":"110 Stat. 821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f1764a6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f1764a7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8f1764a8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-08-01"},"text":"Aug. 1, 1996","children":[],"tail":", or date determined pursuant to suspension authority of President, see "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6085"},"text":"section 6085 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
