{"tag":"section","attrib":{"id":"id90fdd81e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441"},"text":null,"children":[{"tag":"num","attrib":{"value":"8441"},"text":"§ 8441.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90fdd81f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pakistan assistance strategy report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 45 days after ","children":[{"tag":"date","attrib":{"date":"2009-10-15"},"text":"October 15, 2009","children":[],"tail":", the Secretary of State shall submit to the appropriate congressional committees a report describing United States policy and strategy with respect to assistance to Pakistan under this chapter. The report shall include the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90fdd820-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the principal objectives of United States assistance to Pakistan to be provided under subchapter I of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fdd821-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A general description of the specific programs, projects, and activities designed to achieve the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8411"},"text":"section 8411 of this title","children":[],"tail":" and the respective funding levels for such programs, projects, and activities for fiscal years 2010 through 2014."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fdd822-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan for program monitoring, operations research, and impact evaluation research for assistance authorized under subchapter I of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fdd823-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the role to be played by Pakistani national, regional, and local officials and members of Pakistani civil society and local private sector, civic, religious, and tribal leaders in helping to identify and implement programs and projects for which assistance is to be provided under this chapter, and of consultations with such representatives in developing the strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fdd824-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the steps taken, or to be taken, to ensure assistance provided under this chapter is not awarded to individuals or entities affiliated with terrorist organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fdd825-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A projection of the levels of assistance to be provided to Pakistan under this chapter, broken down into the following categories as described in the annual “Report on the Criteria and Methodology for Determining the Eligibility of Candidate Countries for Millennium Challenge Account Assistance”:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90fdd826-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Civil liberties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd827-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Political rights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd828-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voice and accountability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd829-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Government effectiveness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd82a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rule of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd82b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Control of corruption.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd82c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Immunization rates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd82d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public expenditure on health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd82e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Girls’ primary education completion rate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd82f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public expenditure on primary education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd830-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Natural resource management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd831-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Business start-up.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd832-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Land rights and access.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd833-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Trade policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd834-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulatory quality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd835-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inflation control.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd836-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/6/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fiscal policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fdd837-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis for the suitable replacement for existing Pakistani helicopters, including recommendations for sustainment and training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90fdd838-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive regional strategy report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90fdd839-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the achievement of United States national security goals to eliminate terrorist threats and close safe havens in Pakistan requires the development of a comprehensive plan that utilizes all elements of national power, including in coordination and cooperation with other concerned governments, and that it is critical to Pakistan’s long-term prosperity and security to strengthen regional relationships among India, Pakistan, and Afghanistan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fdd83a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive regional security strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall develop a comprehensive interagency regional security strategy to eliminate terrorist threats and close safe havens in Pakistan, including by working with the Government of Pakistan and other relevant governments and organizations in the region and elsewhere, as appropriate, to best implement effective counterinsurgency and counterterrorism efforts in and near the border areas of Pakistan and Afghanistan, including the FATA, the NWFP, parts of Balochistan, and parts of Punjab.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fdd83b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90fdd83c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2009-10-15"},"text":"October 15, 2009","children":[],"tail":", the President shall submit to the appropriate congressional committees a report on the comprehensive regional security strategy required under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd83d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report shall include a copy of the comprehensive regional security strategy, including specifications of goals, and proposed timelines and budgets for implementation of the strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fdd83e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90fdd83f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations, the Committee on Armed Services, the Committee on Foreign Affairs, and the Permanent Select Committee on Intelligence of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90fdd840-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations, the Committee on Armed Services, the Committee on Foreign Relations, and the Select Committee on Intelligence of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90fdd841-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8441/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security-related assistance plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2009-10-15"},"text":"October 15, 2009","children":[],"tail":", the Secretary of State shall submit to the appropriate congressional committees a plan for the proposed use of amounts authorized for security-related assistance for each of the fiscal years 2010 through 2014. Such plan shall include an assessment of how the use of such amounts complements or otherwise is related to amounts described in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8424"},"text":"section 8424 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90fdd842-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/73/tIII/s301"},"text":"Pub. L. 111–73, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-15"},"text":"Oct. 15, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2075"},"text":"123 Stat. 2075","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90fdd843-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id90fdd844-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90fdd845-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of a Reporting Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2010-04-07"},"text":"Apr. 7, 2010","children":[],"tail":", 75 F.R. 19533, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby delegate to you the functions and authority conferred upon the President by section 301 of the Enhanced Partnership with Pakistan Act of 2009, "},{"tag":"ref","attrib":{"href":"/us/pl/111/73"},"text":"Public Law 111–73","children":[],"tail":", to make the specified report to the Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to notify the appropriate congressional committees and publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Barack Obama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
