{"tag":"section","attrib":{"id":"id8efd263c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1436"},"text":null,"children":[{"tag":"num","attrib":{"value":"1436"},"text":"§ 1436.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on disclosure of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall authorize the disclosure of any information or knowledge in any case in which such disclosure (1) is prohibited by any other law of the United States, or (2) is inconsistent with the security of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8efd263d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-27/ch36"},"text":"Jan. 27, 1948, ch. 36","children":[],"tail":", title X, § 1003, "},{"tag":"ref","attrib":{"href":"/us/stat/62/13"},"text":"62 Stat. 13","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
