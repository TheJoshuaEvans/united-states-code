{"tag":"section","attrib":{"id":"id910293a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514b"},"text":null,"children":[{"tag":"num","attrib":{"value":"8514b"},"text":"§ 8514b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions with respect to persons who engage in censorship or other related activities against citizens of Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id910293a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall impose sanctions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8514/c"},"text":"section 8514(c) of this title","children":[],"tail":" with respect to each person on the list required by subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910293a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of persons who engage in censorship","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910293aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", the President shall submit to the appropriate congressional committees a list of persons that the President determines have, on or after "},{"tag":"date","attrib":{"date":"2009-06-12"},"text":"June 12, 2009","children":[],"tail":", engaged in censorship or other activities with respect to Iran that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910293ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit, limit, or penalize the exercise of freedom of expression or assembly by citizens of Iran; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910293ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit access to print or broadcast media, including the facilitation or support of intentional frequency manipulation by the Government of Iran or an entity owned or controlled by that Government that would jam or restrict an international signal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910293ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates of list","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall submit to the appropriate congressional committees an updated list under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910293ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each time the President is required to submit an updated list to those committees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8514/b/2/A"},"text":"section 8514(b)(2)(A) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910293af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as new information becomes available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910293b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report; public availability","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910293b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The list required by paragraph (1) shall be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910293b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8514b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The unclassified portion of the list required by paragraph (1) shall be made available to the public and posted on the websites of the Department of the Treasury and the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910293b3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tI/s105B"},"text":"Pub. L. 111–195, title I, § 105B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/158/tIV/s403/b"},"text":"Pub. L. 112–158, title IV, § 403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1254"},"text":"126 Stat. 1254","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
