{"tag":"section","attrib":{"id":"id8ede2ccb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–17"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–17"},"text":"§ 290g–17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ede2ccc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–17/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Fund is authorized to contribute on behalf of the United States $407,000,000 to the tenth replenishment of the resources of the Fund, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ede2ccd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–17/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $407,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ede2cce-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s218"},"text":"Pub. L. 94–302, title II, § 218","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/102/tV/s599C/b"},"text":"Pub. L. 109–102, title V, § 599C(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-14"},"text":"Nov. 14, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2243"},"text":"119 Stat. 2243","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
