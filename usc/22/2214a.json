{"tag":"section","attrib":{"id":"id8f686bd0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2214a"},"text":"§ 2214a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":" In this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f686bd1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bd2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Agency” means the United States Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bd3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate congressional committees” means the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bd4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Business development services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “business development services” means support for the growth of micro, small, and medium-sized enterprises through training, technical assistance, marketing assistance, improved production technologies, and other related services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bd5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bd6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementing partner organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “implementing partner organization” means an entity eligible to receive assistance under this subpart which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f686bd7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States or an indigenous private voluntary organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686bd8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States or an indigenous credit union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686bd9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States or an indigenous cooperative organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686bda-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an indigenous governmental or nongovernmental organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686bdb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a micro, small, or medium-sized enterprise institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686bdc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial intermediary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686bdd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a practitioner institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bde-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Micro, small, and medium-sized enterprise institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “micro, small, and medium-sized enterprise institution” means an entity that provides services, including finance, training, or business development services, for micro, small, and medium-sized enterprises in foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686bdf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial intermediary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial intermediary” means the entity that acts as the intermediary between parties in a financial transaction, such as a bank, credit union, investment fund, a village savings and loan group, or an institution that provides financial services to a micro, small, or medium-sized enterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686be0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “office” means the office established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2211a/b/1"},"text":"section 2211a(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686be1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Practitioner institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “practitioner institution” means a not-for-profit entity, a financial intermediary, an information and communications technology firm with a mobile money platform, a village and savings loan group, or any other entity that provides financial or business development services authorized under section 252 that benefits micro, small, and medium-sized enterprise clients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f686be2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private voluntary organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “private voluntary organization” means a not-for-profit entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f686be3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages in and supports activities of an economic or social development or humanitarian nature for citizens in foreign countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f686be4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incorporated as such under the laws of the United States, including any of its states, territories or the District of Columbia, or of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f6adbe5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States-supported financial intermediary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States-supported financial intermediary” means a financial intermediary that has received funds made available under subchapter I of this chapter for fiscal year 1980 or any subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f6adbe6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Very poor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “very poor” means those individuals—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f6adbe7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" living in the bottom 50 percent below the poverty line established by the national government of the country in which those individuals live; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f6adbe8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2214a/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" living below the international poverty line (as defined by the International Bank for Reconstruction and Development and the International Development Association (collectively referred to as the ‘World Bank’)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f6adbe9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 259, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/484/s6"},"text":"Pub. L. 108–484, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3929"},"text":"118 Stat. 3929","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/i"},"text":"Pub. L. 115–428, § 4(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5515"},"text":"132 Stat. 5515","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f6adbea-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f6adbeb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f6adbec-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/i/1"},"text":"Pub. L. 115–428, § 4(i)(1)","children":[],"tail":", substituted “Committee on Foreign Affairs of the House of Representatives” for “Committee on International Relations of the House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/i/2"},"text":"Pub. L. 115–428, § 4(i)(2)","children":[],"tail":", substituted “micro, small, and medium-sized enterprises” for “microenterprises”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/i/3/A"},"text":"Pub. L. 115–428, § 4(i)(3)(A)","children":[],"tail":", substituted “micro, small, or medium-sized enterprise institution” for “microenterprise institution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/i/3/B"},"text":"Pub. L. 115–428, § 4(i)(3)(B)","children":[],"tail":", substituted “financial intermediary” for “microfinance institution”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/i/4"},"text":"Pub. L. 115–428, § 4(i)(4)","children":[],"tail":", added pars. (7) and (8) and struck out former pars. (7) and (8) which defined the terms “microenterprise institution” and “microfinance institution”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/i/5"},"text":"Pub. L. 115–428, § 4(i)(5)","children":[],"tail":"–(7), redesignated par. (10) as (9), struck out “of microenterprise development” before “established”, and struck out former par. (9) which defined the term “microfinance network”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/i/6"},"text":"Pub. L. 115–428, § 4(i)(6)","children":[],"tail":", (8), redesignated par. (11) as (10) and amended par. (10) generally. Prior to amendment, par. (10) defined the term “practitioner institution”. Former par. (10) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/i/6"},"text":"Pub. L. 115–428, § 4(i)(6)","children":[],"tail":", redesignated par. (12) as (11). Former par. (11) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/i/6"},"text":"Pub. L. 115–428, § 4(i)(6)","children":[],"tail":", (9), redesignated par. (13) as (12) and substituted “United states-supported financial intermediary” for “United States-supported microfinance institution” in heading and text. Former par. (12) redesignated (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (13), (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/i/6"},"text":"Pub. L. 115–428, § 4(i)(6)","children":[],"tail":", (10), redesignated par. (14) as (13) and amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “living on less than the equivalent of $1 per day (as calculated using the purchasing power parity (PPP) exchange rate method).” Former par. (13) redesignated (12)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f6adbed-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f6adbee-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Subchapter I Deemed To Include Certain Parts of Subchapter II","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to subchapter I of this chapter are deemed to include parts IV (§ 2346 et seq.), VI (§ 2348 et seq.), and VIII (§ 2349aa et seq.) of subchapter II of this chapter, and references to subchapter II are deemed to exclude such parts. See ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226/s202/b"},"text":"section 202(b) of Pub. L. 92–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"section 2346 of this title","children":[],"tail":", and sections 2348c and 2349aa–5 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id8f6adbef-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
