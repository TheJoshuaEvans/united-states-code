{"tag":"section","attrib":{"id":"id907a9ef8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4507"},"text":null,"children":[{"tag":"num","attrib":{"value":"4507"},"text":"§ 4507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal control of education prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing contained in this chapter may be construed to authorize any department, agency, officer, or employee of the United States to exercise any direction, supervision, or control over the curriculum, program of instruction or research, administration, or personnel of any educational institution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907a9ef9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/tVIII/s808"},"text":"Pub. L. 98–164, title VIII, § 808","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1050"},"text":"97 Stat. 1050","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
