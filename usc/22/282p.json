{"tag":"section","attrib":{"id":"id8eb80772-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282p"},"text":null,"children":[{"tag":"num","attrib":{"value":"282p"},"text":"§ 282p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital increases and amendment to the Articles of Agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eb80773-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Votes authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States Governor of the Corporation is authorized to vote in favor of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eb80774-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282p/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a resolution to increase the authorized capital stock of the Corporation by 16,999,998 shares, to implement the conversion of a portion of the retained earnings of the Corporation into paid-in capital, which will result in the United States being issued an additional 3,771,899 shares of capital stock, without any cash contribution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eb80775-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282p/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a resolution to increase the authorized capital stock of the Corporation on a general basis by 4,579,995 shares; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eb80776-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282p/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a resolution to increase the authorized capital stock of the Corporation on a selective basis by 919,998 shares.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eb80777-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment of the Articles of Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Corporation is authorized to agree to and accept an amendment to article II, section 2(c)(ii) of the Articles of Agreement of the Corporation that would increase the vote by which the Board of Governors of the Corporation may increase the capital stock of the Corporation from a four-fifths majority to an eighty-five percent majority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eb80778-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch788/s18"},"text":"Aug. 11, 1955, ch. 788, § 18","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dB/tXI/s21012/b/2"},"text":"Pub. L. 116–136, div. B, title XI, § 21012(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/594"},"text":"134 Stat. 594","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eb80779-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eb8077a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8eb8077b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purposes; Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dB/tXI/s21012/a"},"text":"Pub. L. 116–136, div. B, title XI, § 21012(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/593"},"text":"134 Stat. 593","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/136/dB/tXI/s21012/a"},"text":"“For purposes of strengthening the ability of foreign countries to prevent, prepare for, and respond to coronavirus and to the adverse economic impacts of coronavirus, in a manner that would protect the United States from the spread of coronavirus and mitigate an international economic crisis resulting from coronavirus that may pose a significant risk to the economy of the United States, each paragraph of subsection (b) [enacting this section and sections 284cc, 290g–25, and 290i–12 of this title and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s286e–2"},"text":"section 286e–2 of this title","children":[],"tail":"] shall take effect upon enactment of this Act ["},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “coronavirus” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s21012/a"},"text":"section 21012(a) of Pub. L. 116–136","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s23005"},"text":"section 23005 of Pub. L. 116–136","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s162b"},"text":"section 162b of Title 2","children":[],"tail":", The Congress.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
