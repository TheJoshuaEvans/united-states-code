{"tag":"section","attrib":{"id":"id90843ba6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4857"},"text":null,"children":[{"tag":"num","attrib":{"value":"4857"},"text":"§ 4857.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Panel on Overseas Security","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1986-08-27"},"text":"August 27, 1986","children":[],"tail":", the Secretary of State shall submit a report to the Congress on the implementation of the 91 recommendations contained in the final report of the Advisory Panel on Overseas Security. If any such recommendation has been rejected, the Secretary shall provide the reasons why that recommendation was rejected."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90843ba7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIV/s407"},"text":"Pub. L. 99–399, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/866"},"text":"100 Stat. 866","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
