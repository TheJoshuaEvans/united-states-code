{"tag":"section","attrib":{"id":"id90a7f046-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6036"},"text":null,"children":[{"tag":"num","attrib":{"value":"6036"},"text":"§ 6036.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance by independent states of former Soviet Union for Cuban Government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90a7f047-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6036/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1996-03-12"},"text":"March 12, 1996","children":[],"tail":", the President shall submit to the appropriate congressional committees a report detailing progress toward the withdrawal of personnel of any independent state of the former Soviet Union (within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5801"},"text":"section 5801 of this title","children":[],"tail":"), including advisers, technicians, and military personnel, from the Cienfuegos nuclear facility in Cuba."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a7f048-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6036/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (c) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a7f049-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6036/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilities at Lourdes, Cuba","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a7f04a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6036/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval of credits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress expresses its strong disapproval of the extension by Russia of credits equivalent to $200,000,000 in support of the intelligence facility at Lourdes, Cuba, in November 1994.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a7f04b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6036/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90a7f04c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114/tI/s106"},"text":"Pub. L. 104–114, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/795"},"text":"110 Stat. 795","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90a7f04d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90a7f04e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90a7f04f-2930-11f1-8918-be39dde81dc6"},"text":null,"children