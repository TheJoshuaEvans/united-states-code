{"tag":"section","attrib":{"id":"id8e8f7022-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j"},"text":null,"children":[{"tag":"num","attrib":{"value":"262j"},"text":"§ 262j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of renewable resources for energy production","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e8f7023-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion, etc., by United States in connection with international financial institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States Government, in connection with its voice and vote in the Inter-American Development Bank, the African Development Fund, and the Asian Development Bank, shall encourage such institutions—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e8f7024-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the decentralized production of renewable energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8f7025-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify renewable resources to produce energy in rural development projects and determine the feasibility of substituting them for systems using fossil fuel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8f7026-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train personnel in developing technologies for getting energy from renewable resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8f7027-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support research into the use of renewable resources, including hydropower, biomass, solar photovoltaic, and solar thermal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8f7028-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support an information network to make available to policymakers the full range of energy choices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8f7029-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to broaden their energy planning, analyses, and assessments to include consideration of the supply of, demand for, and possible uses of renewable resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8f702a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate with the Agency for International Development and other aid organizations in supporting effective rural energy programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e8f702b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Renewable resource” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “renewable resource” means any energy resource which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e8f702c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the needs of rural communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8f702d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" saves capital without wasting labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8f702e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is modest in scale and simple to install and maintain and which can be managed by local individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8f702f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is acceptable and affordable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8f7030-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262j/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not damage the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e8f7031-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/259/tVI/s602"},"text":"Pub. L. 96–259, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-03"},"text":"June 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/433"},"text":"94 Stat. 433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/375/tI/s112"},"text":"Pub. L. 97–375, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1821"},"text":"96 Stat. 1821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e91e132-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e91e133-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8e91e134-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/375"},"text":"Pub. L. 97–375","children":[],"tail":" struck out subsec. (c) which directed the Secretary of the Treasury, in consultation with the Director of the United States International Development Cooperation Agency, to report to Congress not later than six months after "},{"tag":"date","attrib":{"date":"1980-06-03"},"text":"June 3, 1980","children":[],"tail":", and annually thereafter on the progress toward achieving the goals set forth in this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e91e135-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8e91e136-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Statement of Findings Respecting Use of Renewable Resources for Energy Production in Poor and Developing Countries and Role of International Financial Institutions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/259/tVI/s601"},"text":"Pub. L. 96–259, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-03"},"text":"June 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/432"},"text":"94 Stat. 432","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/259/tVI/s601"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without an adequate supply of energy at affordable prices the world’s poor will continue to be deprived of jobs, food, water, shelter, and clothing, and poor countries will continue to be economically and politically unstable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dependence on increasingly expensive fossil fuel resources consumes too much of the capital available to poor countries with the result that funds are not available to meet the basic needs of poor people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in many developing countries the cost of large central generators and long distance electrical distribution makes it unlikely that rural energy by means of a national grid will contribute to meeting the needs of poor people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only one of eight rural inhabitants lives in an area which has access to electricity and even fewer rural inhabitants actually have or can afford electricity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wood, animal and agricultural waste, and other ‘noncommercial’ fuels still supply about half the total energy in developing countries and all but a seventh in rural sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" growing dependence of the world’s poor on wood for heating and cooking has forced the overcutting of forests and as a consequence erosion and loss of available agricultural land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recent initiatives by the international financial institutions to develop and utilize decentralized solar, hydro, biomass, geothermal, and wind energy should be significantly expanded to make renewable energy resources increasingly available to the world’s poor on a wide scale.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
