{"tag":"section","attrib":{"id":"id915d370d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10709"},"text":null,"children":[{"tag":"num","attrib":{"value":"10709"},"text":"§ 10709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relations between Kosovo and Serbia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id915d370e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915d370f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agreement on the Path to Normalization of Relations, which was agreed to by Kosovo and Serbia on ","children":[{"tag":"date","attrib":{"date":"2023-02-27"},"text":"February 27, 2023","children":[],"tail":", with the facilitation of the European Union, is a positive step forward in advancing normalization between the two countries;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915d3710-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serbia and Kosovo should seek to make immediate progress on the Implementation Annex to the agreement referred to in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915d3711-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10709/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" once sufficient progress has been made on the Implementation Annex, the United States should consider advancing initiatives to strengthen bilateral relations with both countries, which could include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915d3712-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10709/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing bilateral strategic dialogues with Kosovo and Serbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915d3713-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10709/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advancing concrete initiatives to deepen economic ties and investment with both countries; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915d3714-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10709/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States should continue to support a comprehensive final agreement between Kosovo and Serbia based on mutual recognition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915d3715-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States Government that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915d3716-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it shall not pursue any policy that advocates for land swaps, partition, or other forms of redrawing borders along ethnic lines in the Western Balkans as a means to settle disputes between nation states in the region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915d3717-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it should support pluralistic democracies in countries in the Western Balkans as a means to prevent a return to the ethnic strife that once characterized the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id915d3718-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIII/s8340"},"text":"Pub. L. 119–60, div. H, title LXXXIII, § 8340","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1877"},"text":"139 Stat. 1877","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
