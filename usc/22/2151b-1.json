{"tag":"section","attrib":{"id":"id8f4be27d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2151b–1"},"text":"§ 2151b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for malaria prevention, treatment, control, and elimination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f4be27e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f4be27f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151b–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the United States Agency for International Development, in coordination with the heads of other appropriate Federal agencies and nongovernmental organizations, shall provide assistance for the establishment and conduct of activities designed to prevent, treat, control, and eliminate malaria in countries with a high percentage of malaria cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f4be280-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151b–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of interaction among epidemics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance pursuant to paragraph (1), the Administrator should consider the interaction among the epidemics of HIV/AIDS, malaria, and tuberculosis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f4be281-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151b–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Activities referred to in paragraph (1) shall include the dissemination of information relating to the development of vaccines and therapeutic agents for the prevention of malaria (including information relating to participation in, and the results of, clinical trials for such vaccines and agents conducted by United States Government agencies) to appropriate officials in such countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f4be282-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f4be283-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151b–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out subsection (a) $50,000,000 for each of the fiscal years 2001 and 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f4be284-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151b–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to the authorization of appropriations under paragraph (1) are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f4be285-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/570/tI/s103"},"text":"Pub. L. 106–570, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3039"},"text":"114 Stat. 3039","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f4be286-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f4be287-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f4be288-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Assistance for International Malaria Control Act and also as part of the International Malaria Control Act of 2000, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f4be289-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f4be28a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/570/tI/s102"},"text":"Pub. L. 106–570, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/3039"},"text":"114 Stat. 3039","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/570/tI/s102"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The World Health Organization estimates that there are 300,000,000 to 500,000,000 cases of malaria each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" According to the World Health Organization, more than 1,000,000 persons are estimated to die due to malaria each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" According to the National Institutes of Health, about 40 percent of the world’s population is at risk of becoming infected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" About half of those who die each year from malaria are children under 9 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Malaria kills one child each 30 seconds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Although malaria is a public health problem in more than 90 countries, more than 90 percent of all malaria cases are in sub-Saharan Africa.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to Africa, large areas of Central and South America, Haiti and the Dominican Republic, the Indian subcontinent, Southeast Asia, and the Middle East are high risk malaria areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" These high risk areas represent many of the world’s poorest nations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Malaria is particularly dangerous during pregnancy. The disease causes severe anemia and is a major factor contributing to maternal deaths in malaria endemic regions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ‘Airport malaria’, the importing of malaria by international aircraft and other conveyances, is becoming more common, and the United Kingdom reported 2,364 cases of malaria in 1997, all of them imported by travelers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"“(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the United States, of the 1,400 cases of malaria reported to the Centers for Disease Control and Prevention in 1998, the vast majority were imported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"“(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Between 1970 and 1997, the malaria infection rate in the United States increased by about 40 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"“(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Malaria is caused by a single-cell parasite that is spread to humans by mosquitoes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"“(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No vaccine is available and treatment is hampered by development of drug-resistant parasites and insecticide-resistant mosquitoes.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
