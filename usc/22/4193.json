{"tag":"section","attrib":{"id":"id907129b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4193"},"text":null,"children":[{"tag":"num","attrib":{"value":"4193"},"text":"§ 4193.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protests","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Consuls and vice consuls shall have the right, in the ports or places to which they are severally appointed, of receiving the protests or declarations which captains, masters, crews, passengers, or merchants, who are citizens of the United States, may respectively choose to make there; and also such as any foreigner may choose to make before them relative to the personal interest of any citizen of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907129b1-2930-11f1-8918-be39dde81dc6"},"text":"(R.S. § 1707; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s39"},"text":"June 25, 1948, ch. 646, § 39","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/992"},"text":"62 Stat. 992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907129b2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907129b3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id907129b4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1707 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1792-04-14/ch24/s2"},"text":"act Apr. 14, 1792, ch. 24, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/1/255"},"text":"1 Stat. 255","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1173"},"text":"section 1173 of this title","children":[],"tail":", and prior thereto to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s73"},"text":"section 73 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id907129b5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1948—Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", repealed second sentence relating to authenticated copies of consular acts received as evidence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id907129b6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id907129b7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1948 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s38"},"text":"Act June 25, 1948, ch. 646, § 38","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/992"},"text":"62 Stat. 992","children":[],"tail":", provided that the amendment made by that act is effective "},{"tag":"date","attrib":{"date":"1948-09-