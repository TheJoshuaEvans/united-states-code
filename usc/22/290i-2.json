{"tag":"section","attrib":{"id":"id8ee09e70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"290i–2"},"text":"§ 290i–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director or Alternate Director; allowances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ee09e71-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President, by and with the advice and consent of the Senate, shall appoint a Director of the Bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee09e72-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director or Alternate Director representing the United States, if citizens of the United States, may, in the discretion of the President, receive such compensation, allowances, and other benefits as, together with those received from the Bank and from the African Development Fund, may not exceed those authorized for a chief of mission under the Foreign Service Act of 1980 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"22 U.S.C. 3901","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee09e73-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXIII/s1334"},"text":"Pub. L. 97–35, title XIII, § 1334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/741"},"text":"95 Stat. 741","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/z/2"},"text":"Pub. L. 112–166, § 2(z)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1289"},"text":"126 Stat. 1289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ee09e74-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ee09e75-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ee09e76-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Service Act of 1980, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2071"},"text":"94 Stat. 2071","children":[],"tail":", which is classified principally to chapter 52 (§ 3901 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ee09e77-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" added subsec. (a) and designated existing provisions as subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ee09e78-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ee09e79-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", and applicable to appointments made on and after that effective date, including any nomination pending in the Senate on that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s6/a"},"text":"section 6(a) of Pub. L. 112–166","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s113"},"text":"section 113 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8ee09e7a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8ee09e7b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to Secretary of the Treasury, see Ex. Ord. No. 12403, ","children":[{"tag":"date","attrib":{"date":"1983-02-08"},"te