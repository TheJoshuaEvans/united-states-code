{"tag":"section","attrib":{"id":"id91560aed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413"},"text":null,"children":[{"tag":"num","attrib":{"value":"10413"},"text":"§ 10413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting related to the AUKUS partnership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91560aee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on instruments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91560aef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the signature, conclusion, or other finalization of any non-binding instrument related to the AUKUS partnership, the President shall submit to the appropriate congressional committees the text of such instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91560af0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-duplication of efforts; rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent the text of a non-binding instrument is submitted to the appropriate congressional committees pursuant to paragraph (1), such text does not need to be submitted to Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s112b/a/1/A/ii"},"text":"section 112b(a)(1)(A)(ii) of title 1","children":[],"tail":", as amended by section 5947 of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023 ("},{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Public Law 117–263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/136/3476"},"text":"136 Stat. 3476","children":[],"tail":"). Paragraph (1) shall not be construed to relieve the executive branch of any other requirement of "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s112b"},"text":"section 112b of title 1","children":[],"tail":", as so amended, or any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91560af1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91560af2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “text”, with respect to a non-binding instrument, includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91560af3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any annex, appendix, codicil, side agreement, side letter, or any document of similar purpose or function to the aforementioned, regardless of the title of the document, that is entered into contemporaneously and in conjunction with the non-binding instrument; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560af4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any implementing agreement or arrangement, or any document of similar purpose or function to the aforementioned, regardless of the title of the document, that is entered into contemporaneously and in conjunction with the non-binding instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560af5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contemporaneously and in conjunction with","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in subparagraph (A), the term “contemporaneously and in conjunction with”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91560af6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be construed liberally; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560af7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be interpreted to require any action to have occurred simultaneously or on the same day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91560af8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on AUKUS partnership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91560af9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", and biennially thereafter, the Secretary of State, in coordination with the Secretary of Defense and other appropriate heads of agencies, shall submit to the appropriate congressional committees a report on the AUKUS partnership."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91560afa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required under paragraph (1) shall include the following elements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91560afb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91560afc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification of the defensive military capability gaps and capacity shortfalls that the AUKUS partnership seeks to offset.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560afd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation of the total cost to the United States associated with Pillar One of the AUKUS partnership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560afe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed explanation of how enhanced access to the industrial base of Australia is contributing to strengthening the United States strategic position in Asia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560aff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed explanation of the military and strategic benefit provided by the improved access provided by naval bases of Australia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560b00-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed assessment of how Australia’s sovereign conventionally armed nuclear attack submarines contribute to United States defense and deterrence objectives in the Indo-Pacific region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91560b01-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implement the AUKUS partnership","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91560b02-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Progress made on achieving the Optimal Pathway established for Australia’s development of conventionally armed, nuclear-powered submarines, including the following elements:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id91560b03-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of progress made by Australia, the United Kingdom, and the United States to conclude an Article 14 arrangement with the International Atomic Energy Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91560b04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the status of efforts of Australia, the United Kingdom, and the United States to build the supporting infrastructure to base conventionally armed, nuclear-powered attack submarines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91560b05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Updates on the efforts by Australia, the United Kingdom, and the United States to train a workforce that can build, sustain, and operate conventionally armed, nuclear-powered attack submarines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91560b06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of progress in establishing submarine support facilities capable of hosting rotational forces in western Australia by 2027.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91560b07-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of progress made in improving United States submarine production capabilities that will enable the United States to meet—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id91560b08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/i/V/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its objectives of providing up to five Virginia Class submarines to Australia by the early to mid-2030’s; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id91560b09-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/i/V/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States submarine production requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91560b0a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Progress made on Pillar Two of the AUKUS partnership, including the following elements:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id91560b0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An assessment of the efforts of Australia, the United Kingdom, and the United States to enhance collaboration across the following eight trilateral lines of effort:","children":[],"tail":null},{"tag":"item","attrib":{"id":"id91560b0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Underseas capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id91560b0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Quantum technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id91560b0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/ii/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Artificial intelligence and autonomy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id91560b0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/ii/I/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advanced cyber capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id91560b10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/ii/I/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hypersonic and counter-hypersonic capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id91560b11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/ii/I/ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"ff"},"text":"(ff)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Electronic warfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id91560b12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/ii/I/gg"},"text":null,"children":[{"tag":"num","attrib":{"value":"gg"},"text":"(gg)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Innovation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id91560b13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/ii/I/hh"},"text":null,"children":[{"tag":"num","attrib":{"value":"hh"},"text":"(hh)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information sharing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91560b14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10413/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of any new lines of effort established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91560b15-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXIII/s1333"},"text":"Pub. L. 118–31, div. A, title XIII, § 1333","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/506"},"text":"137 Stat. 506","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91560b16-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id91560b17-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id91560b18-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions and Authorities Under Sections 1333, 1342, 1352, and 1353 of the National Defense Authorization Act for Fiscal Year 2024","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2024-07-09"},"text":"July 9, 2024","children":[],"tail":", 89 F.R. 57337, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of State[,] the Secretary of Defense[,] the Secretary of Energy[, and] the Director of the Office of Management and Budget","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. (a) I hereby delegate to the Secretary of Defense, in consultation with the Secretary of Energy, the functions and authorities vested in the President by section 1352(g) of the National Defense Authorization Act for Fiscal Year 2024 ("},{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Public Law 118–31","children":[],"tail":") (the “Act”) ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s10431/g"},"text":"22 U.S.C. 10431(g)","children":[],"tail":"]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) I hereby delegate to the Secretary of Defense, in consultation with the Secretaries of State and Energy, the functions and authorities vested in the President by sections 1352(h)(4), 1352(d)(1), and 1352(e)(2)(A) of the Act.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) I hereby delegate the functions and authorities vested in the President by the following provisions of the Act as follows:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(i) to the Secretary of State, in consultation with the Secretaries of Defense and Energy, as appropriate, section 1333 of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10413"},"text":"22 U.S.C. 10413","children":[],"tail":"];"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(ii) to the Secretary of State, in consultation with the Secretaries of Defense and Energy, section 1342 of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10422"},"text":"22 U.S.C. 10422","children":[],"tail":"];"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(iii) to the Secretary of Defense, in consultation with the Secretary of Energy, section 1352(e)(2)(B) of the Act;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(iv) to the Secretary of Defense, in consultation with the Secretary of Energy, section 1352(e)(2)(C) of the Act;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(v) to the Secretary of Defense, in consultation with the Secretaries of State and Energy, section 1352(i) of the Act; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(vi) to the Secretary of Defense for funds allocated to the Department of Defense account and to the Secretary of Energy for funds allocated to the Department of Energy account, in coordination with the Director of the Office of Management and Budget, section 1353(d), (h), and (i) of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10432/d"},"text":"22 U.S.C. 10432(d)","children":[],"tail":", (h), (i)]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 2. The delegation in this memorandum shall apply to any provision of any future public law that is the same or substantially the same as the provision referenced in this memorandum."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 3. The Secretary of Defense is authorized and directed to publish this memorandum in the Federal Register."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"J.R. Biden, Jr.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
