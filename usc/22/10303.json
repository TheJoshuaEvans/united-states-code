{"tag":"section","attrib":{"id":"id915399d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303"},"text":null,"children":[{"tag":"num","attrib":{"value":"10303"},"text":"§ 10303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity recruitment and retention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id915399d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that improving computer programming language proficiency will improve—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915399da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cybersecurity effectiveness of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of foreign service officers to engage with foreign audiences on cybersecurity matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915399dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology talent acquisition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915399dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish positions within the Bureau of Global Talent Management that are solely dedicated to the recruitment and retention of Department personnel with backgrounds in cybersecurity, engineering, data science, application development, artificial intelligence, critical and emerging technology, and technology and digital policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the positions described in paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915399df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fulfill the critical need of the Department to recruit and retain employees for cybersecurity, digital, and technology positions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915399e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to actively recruit relevant candidates from academic institutions, the private sector, and related industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915399e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to work with the Office of Personnel Management and the United States Digital Service to develop and implement best strategies for recruiting and retaining technology talent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915399e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to inform and train supervisors at the Department on the use of the authorities listed in subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall submit a plan to the appropriate congressional committees that describes how the objectives and goals set forth in paragraphs (1) and (2) will be implemented."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $750,000 for each of the fiscal years 2023 through 2027 to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915399e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on hiring authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", and annually thereafter for the following 5 years, the Secretary shall submit a report to the appropriate congressional committees that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id915399e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the hiring authorities available to the Department to recruit and retain personnel with backgrounds in cybersecurity, engineering, data science, application development, artificial intelligence, critical and emerging technology, and technology and digital policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of which hiring authorities described in paragraph (1) have been used during the previous 5 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees in qualified positions hired, aggregated by position and grade level or pay band;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees who have been placed in qualified positions, aggregated by bureau and offices within the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of attrition of individuals who begin the hiring process and do not complete the process and a description of the reasons for such attrition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals who are interviewed by subject matter experts and the number of individuals who are not interviewed by subject matter experts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915399ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the attrition rate referred to in paragraph (5) by 5 percent each year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915399ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional hiring authorities needed to acquire needed technology talent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915399ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hiring personnel to hold public trust positions until such personnel can obtain the necessary security clearance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915399f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/c/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informing and training supervisors within the Department on the use of the authorities listed in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915399f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incentive pay for cybersecurity professionals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To increase the number of qualified candidates available to fulfill the cybersecurity needs of the Department, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915399f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include computer programming languages within the Recruitment Language Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide appropriate language incentive pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915399f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", and annually thereafter for the following 5 years, the Secretary shall provide a list to the appropriate congressional committees that identifies—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id915399f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the computer programming languages included within the Recruitment Language Program and the language incentive pay rate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915399f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10303/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals benefitting from the inclusion of such computer programming languages in the Recruitment Language Program and language incentive pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id915399f7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCV/s9506"},"text":"Pub. L. 117–263, div. I, title XCV, § 9506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3904"},"text":"136 Stat. 3904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id915399f8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id915399f9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id915399fa-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Department”, “Secretary”, and “appropriate congressional committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s9002"},"text":"section 9002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
