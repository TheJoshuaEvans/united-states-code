{"tag":"section","attrib":{"id":"id8feba53d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2656e"},"text":"§ 2656e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terrorism-related travel advisories","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall promptly advise the Congress whenever the Department of State issues a travel advisory, or other public warning notice for United States citizens traveling abroad, because of a terrorist threat or other security concern.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8feba53e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tV/s505"},"text":"Pub. L. 99–399, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/871"},"text":"100 Stat. 871","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
