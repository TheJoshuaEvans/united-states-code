{"tag":"section","attrib":{"id":"id90e1288e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7517"},"text":null,"children":[{"tag":"num","attrib":{"value":"7517"},"text":"§ 7517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authority to provide assistance under this subchapter is in addition to any other authority to provide assistance to the Government of Afghanistan.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90e1288f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/327/tI/s107"},"text":"Pub. L. 107–327, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-04"},"text":"Dec. 4, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2806"},"text":"116 Stat. 2806","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
