{"tag":"section","attrib":{"id":"id909022de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5508"},"text":null,"children":[{"tag":"num","attrib":{"value":"5508"},"text":"§ 5508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of Lockerbie experience","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id909022df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall compile an assessment of the Department of State response to the Pan American Airways Flight 103 aviation disaster over Lockerbie, Scotland, on ","children":[{"tag":"date","attrib":{"date":"1988-12-21"},"text":"December 21, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id909022e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall establish, based on the assessment compiled under subsection (a) and other relevant factors, guidelines for future Department of State responses to comparable disasters and shall distribute such guidelines to all United States diplomatic and consular posts abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id909022e1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/604/tII/s209"},"text":"Pub. L. 101–604, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3085"},"text":"104 Stat. 3085","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
