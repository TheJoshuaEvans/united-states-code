{"tag":"section","attrib":{"id":"id8eba5165-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"283z–13"},"text":"§ 283z–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ninth Capital Increase","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eba5166-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vote authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Bank is authorized to vote in favor of a resolution to increase the capital stock of the Bank by $70,000,000,000 as described in Resolution AG–7/10, “Report on the Ninth General Capital Increase in the resources of the Inter-American Development Bank” as approved by Governors on ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eba5167-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscription authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eba5168-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–13/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank may subscribe on behalf of the United States to 1,741,135 additional shares of the capital stock of the Bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eba5169-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–13/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any subscription by the United States to the capital stock of the Bank shall be effective only to such extent and in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eba516a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–13/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eba516b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–13/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the increase in the United States subscription to the Bank under subsection (b), there are authorized to be appropriated, without fiscal year limitation, $21,004,064,337 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eba516c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–13/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of the amount authorized to be appropriated under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8eba516d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–13/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $510,090,175 shall be for paid in shares of the Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8eba516e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–13/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,493,974,162 shall be for callable shares of the Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eba516f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/147/s41"},"text":"Pub. L. 86–147, § 41","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dI/tVII/s7081/c"},"text":"Pub. L. 112–74, div. I, title VII, § 7081(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1260"},"text":"125 Stat. 1260","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
