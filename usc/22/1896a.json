{"tag":"section","attrib":{"id":"id8f1e9179-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1896a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1896a"},"text":"§ 1896a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on commitments for technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No commitment for the calendar year 1955 or thereafter, with respect to contributions to the United Nations expanded program of technical assistance, shall be pledged on behalf of the United States until the Congress appropriates for said purpose.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f1e917a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1262/s101"},"text":"Sept. 3, 1954, ch. 1262, § 101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1221"},"text":"68 Stat. 1221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f1e917b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f1e917c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f1e917d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as a part of section 101 of the Mutual Security Appropriation Act, 1955. No other part of section 101 of the Mutual Security Appropriation Act, 1955, was classified to the Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
