{"tag":"section","attrib":{"id":"id907d0fcf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4701"},"text":null,"children":[{"tag":"num","attrib":{"value":"4701"},"text":"§ 4701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to establish an undergraduate scholarship program designed to bring students of limited financial means from developing countries to the United States for study at United States institutions of higher education.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907d0fd0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/tVI/s601"},"text":"Pub. L. 99–93, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/439"},"text":"99 Stat. 439","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
