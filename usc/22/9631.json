{"tag":"section","attrib":{"id":"id91456902-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9631"},"text":null,"children":[{"tag":"num","attrib":{"value":"9631"},"text":"§ 9631.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91456903-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9631/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bilateral agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may provide support under subchapter II of this chapter in connection with projects in any country the government of which has entered into an agreement with the United States authorizing the Corporation to provide such support in that country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91456904-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9631/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims settlement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91456905-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9631/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Claims arising as a result of support provided under subchapter II of this chapter or under predecessor authority may be settled, and disputes arising as a result thereof may be arbitrated with the consent of the parties, on such terms and conditions as the Corporation may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91456906-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9631/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlements conclusive","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payment made pursuant to any settlement pursuant to paragraph (1), or as a result of an arbitration award, shall be final and conclusive notwithstanding any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91456907-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9631/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption of compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each contract executed by such officer or officers as may be designated by the Board shall be conclusively presumed to be issued in compliance with the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91456908-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9631/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic payments and documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall implement policies to accept electronic documents and electronic payments in all of its programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91456909-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9631/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9145690a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9631/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation is obligated to consult with and collect input from current employees on plans to substantially reorganize the Corporation prior to implementation of such plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9145690b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9631/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation should consider preference, experience, and, when relevant, seniority when reassigning existing employees to new areas of work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9145690c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tIII/s1431"},"text":"Pub. L. 115–254, div. F, title III, § 1431","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3499"},"text":"132 Stat. 3499","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXVII/s8751"},"text":"Pub. L. 119–60, div. H, title LXXXVII, § 8751","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1963"},"text":"139 Stat. 1963","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9145690d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9145690e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9145690f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this division”, meaning division F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3485"},"text":"132 Stat. 3485","children":[],"tail":", which is classified principally to this chapter. For complete classification of division F to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9601"},"text":"section 9601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id91456910-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
