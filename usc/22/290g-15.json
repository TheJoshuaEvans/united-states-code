{"tag":"section","attrib":{"id":"id8ede2cbe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–15"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–15"},"text":"§ 290g–15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sixth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ede2cbf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund is authorized to contribute $405,000,000 to the sixth replenishment of the resources of the Fund, except that such authority shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ede2cc0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the United States contribution provided for in this section, there are authorized to be appropriated, without fiscal year limitation, $135,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ede2cc1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s216"},"text":"Pub. L. 94–302, title II, § 216","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/145/s125/c"},"text":"Pub. L. 102–145, § 125(c)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/266/s102"},"text":"Pub. L. 102–266, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-04-01"},"text":"Apr. 1, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/98"},"text":"106 Stat. 98","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ede2cc2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ede2cc3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ede2cc4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Subsequent Replenishment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/2/tV/s594"},"text":"Pub. L. 106–113, div. B, § 1000(a)(2) [title V, § 594]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–122, provided in part that the Secretary of the Treasury may contribute on behalf of the United States to the eighth replenishment of the resources of the African Development Fund, and authorized $300,000,000 to be appropriated without fiscal year limitation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
