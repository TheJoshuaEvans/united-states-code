{"tag":"section","attrib":{"id":"id91181853-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8926a"},"text":"§ 8926a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supporting the identification and recovery of abducted Ukrainian children","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91181854-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Abducted Ukrainian Children Recovery and Accountability Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91181855-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91181856-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" According to a White House press release, dated ","children":[{"tag":"date","attrib":{"date":"2025-03-25"},"text":"March 25, 2025","children":[],"tail":", “The United States and Ukraine agreed that the United States remains committed to helping achieve the exchange of prisoners of war, the release of civilian detainees, and the return of forcibly transferred Ukrainian children.”."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6147-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To implement the commitment referred to in paragraph (1), the United States Government requires an organized and resourced policy approach to assist Ukraine with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a6148-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigations of Russia’s abduction of Ukrainian children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6149-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rehabilitation and reintegration of children returned to Ukraine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a614a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" justice and accountability for perpetrators of the abductions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a614b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of technical assistance and advisory support","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a614c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Department of Justice and the Department of State are authorized—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a614d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide law enforcement and intelligence technical assistance, training, capacity building, and advisory support to the Government of Ukraine in support of the commitment described in subsection (b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a614e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance the objectives described in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a614f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The law enforcement and intelligence technical assistance authorized under paragraph (1)(A) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a6150-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training regarding the utilization of biometric identification technologies in abduction and trafficking in persons investigations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6151-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance with respect to collecting and analyzing open source intelligence information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6152-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in the development and use of secure communications technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6153-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance with respect to managing and securing relevant databases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6154-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the determination to provide assistance in any category identified in this subsection, the Secretary of State shall brief the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a6155-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of assistance determined to be obligated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6156-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of assistance to be utilized; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6157-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information on the technology operationalized to support the means identified in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a6158-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a6159-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nongovernmental organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of Justice and the Department of State may coordinate with nongovernmental organizations to carry out the assistance authorized under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a615a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Security Council may coordinate with appropriate representatives from the Department of Justice, the Department of State, the intelligence community (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of title 50","children":[],"tail":"), and other Federal agencies, as needed, to carry out the assistance authorized under subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a615b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rehabilitation and reintegration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a615c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State is authorized to provide support to the Government of Ukraine and nongovernmental organizations and local civil society groups in Ukraine for the purpose of providing Ukrainian children (including teenagers) who have been abducted, forcibly transferred, or held against their will by the Russian Federation with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a615d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical and psychological rehabilitation services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a615e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" family reunification and support services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a615f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services in support of the reintegration of such children into Ukrainian society, including case management, legal aid, and educational screening and placement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6160-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":", the Secretary of State shall submit a report to the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives that describes all current or planned foreign assistance programs that will provide the assistance authorized under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a6161-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Atrocity Crimes Advisory Group for Ukraine","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of State is authorized to support the Atrocity Crimes Advisory Group for Ukraine by providing technical assistance, capacity building, and advisory support to the Government of Ukraine’s Office of the Prosecutor General, and other relevant components of the Government of Ukraine, for the purpose of investigating and prosecuting cases involving abducted children, and other atrocity crimes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a6162-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Justice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of Justice is authorized to provide technical assistance, capacity building, and advisory support to the Government of Ukraine through its Office of Overseas Prosecutorial Development, Assistance, and Training, which shall be coordinated by the Resident Legal Adviser at the United States Embassy in Kyiv, for the purpose of investigating and prosecuting cases involving abducted children, and other atrocity crimes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a6163-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2025-12-18"},"text":"December 18, 2025","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a6164-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State, in coordination with the Attorney General, shall submit a report to the Committee on Foreign Relations of the Senate, the Committee on the Judiciary of the Senate, the Committee on Foreign Affairs of the House of Representatives, and the Committee on the Judiciary of the House of Representatives that describes current and planned United States Government support for the Government of Ukraine’s work to investigate and prosecute atrocity crimes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6165-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of State, in coordination with the Secretary of the Treasury, shall submit a report to the Committee on Foreign Relations of the Senate, the Committee on Banking, Housing, and Urban Affairs of the Senate, the Committee on Foreign Affairs of the House of Representatives, and the Committee on Financial Services of the House of Representatives that outlines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a6166-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any discrepancies between the sanctions regimes of the United States, the United Kingdom, and the European Union with respect to those responsible for the abduction of Ukrainian children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6167-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8926a/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts made by the United States Government to better align such sanction regimes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911a6168-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXIII/s8363"},"text":"Pub. L. 119–60, div. H, title LXXXIII, § 8363","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1885"},"text":"139 Stat. 1885","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911a6169-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911a616a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id911a616b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2026, and not as part of the Ukraine Freedom Support Act of 2014, which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
