{"tag":"section","attrib":{"id":"id902e537f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3145"},"text":null,"children":[{"tag":"num","attrib":{"value":"3145"},"text":"§ 3145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction of foreign direct investment and international financial data provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id902e5380-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3145/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act or the amendments made by this Act shall be construed to require any business enterprise or any of its officers, directors, shareholders, or employees, or any other person, to provide information beyond that which is required before ","children":[{"tag":"date","attrib":{"date":"1990-11-07"},"text":"November 7, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id902e5381-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3145/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All departments and agencies implementing this Act and the amendments made by this Act shall, with respect to surveys or questionnaires used in such implementation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id902e5382-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3145/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate questions that are no longer necessary,","children":[],"tail":"\n"}],"t