{"tag":"section","attrib":{"id":"id8faffbe4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2394–1a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2394–1a"},"text":"§ 2394–1a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classification of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All information contained in any report transmitted under this chapter shall be public information. However, in the case of any item of information to be included in any such report that the President, on an extraordinary basis, determines is clearly detrimental to the security of the United States, he shall explain in a supplemental report why publication of each specific item would be detrimental to the security of the United States. A supplemental report shall be transmitted to the Congress at the time the report is transmitted.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8faffbe5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 634B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/tV/s502/c"},"text":"Pub. L. 95–424, title V, § 502(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/959"},"text":"92 Stat. 959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8faffbe6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8faffbe7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText",