{"tag":"section","attrib":{"id":"id9073731f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4218"},"text":null,"children":[{"tag":"num","attrib":{"value":"4218"},"text":"§ 4218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False certificate as to ownership of property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any consul or vice consul falsely and knowingly certifies that property belonging to foreigners is property belonging to citizens of the United States, he shall be punishable by imprisonment for not more than three years, and by a fine of not more than $10,000.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90737320-2930-11f1-8918-be39dde81dc6"},"text":"(R.S. § 1737; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-04-05/ch1366/s3"},"text":"Apr. 5, 1906, ch. 1366, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/100"},"text":"34 Stat. 100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90737321-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90737322-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90737323-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1737 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1803-02-22/ch9/s7"},"text":"act Feb. 22, 1803, ch. 9, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/2/204"},"text":"2 Stat. 204","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to “commercial agent” and “vice-commercial agent” were omitted in view of the abolition of the grade of commercial agent by act ","children":[{"tag":"date","attrib":{"date":"1906-04-05"},"text":"Apr. 5, 1906","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1200"},"text":"section 1200 of this title","children":[],"tail":", and prior thereto to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s104"},"text":"section 104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
