{"tag":"section","attrib":{"id":"id90712924-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4152"},"text":null,"children":[{"tag":"num","attrib":{"value":"4152"},"text":"§ 4152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion to Foreign Service Schedule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90712925-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4152/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":", the Secretary shall, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4156"},"text":"section 4156 of this title","children":[],"tail":", convert to the appropriate class in the Foreign Service Schedule established under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3963"},"text":"section 3963 of this title","children":[],"tail":" those individuals in the Foreign Service who are serving immediately before "},{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":", under appointments at or below class 3 of the schedule established under section 412 or 414 of the Foreign Service Act of 1946, or at any class in the schedule established under section 415 of such Act, as—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90712926-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4152/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Foreign Service officers, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90712927-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4152/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Foreign Service Reserve officers with limited or unlimited tenure, and Foreign Service staff officers or employees, who the Secretary determines are available for worldwide assignment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90712928-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4152/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":", Foreign Service Reserve officers and staff officers and employees who the Secretary determines under subsection (a)(2) are not available for worldwide assignment shall also be converted, in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4156"},"text":"section 4156 of this title","children":[],"tail":", to the appropriate class in the Foreign Service Schedule established under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3963"},"text":"section 3963 of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90712929-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4152/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary certifies that there is a need for their services in the Foreign Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9071292a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4152/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" they agree in writing to accept availability for worldwide assignment as a condition of continued employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9071292b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2102"},"text":"Pub. L. 96–465, title II, § 2102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2148"},"text":"94 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9071292c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9071292d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9071292e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 412, 414 and 415 of the Foreign Service Act of 1946, referred to in subsec. (a), which were classified to sections 867, 869 and 870, respectively, of this title, were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2205/1"},"text":"Pub. L. 96–465, title II, § 2205(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2159"},"text":"94 Stat. 2159","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9071292f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsecs. (a) and (b), “","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":"” substituted for “the effective date of this Act” pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2403"},"text":"section 2403 of Pub. L. 96–465","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
