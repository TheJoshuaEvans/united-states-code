{"tag":"section","attrib":{"id":"id8eba510c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"283z–3"},"text":"§ 283z–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in authorized capital stock of Bank and increases in resources of Fund for Special Operations; United States share; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eba510d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eba510e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States Governor of the Bank is authorized to vote for resolutions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8eba510f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which were proposed by the Governors at a special meeting in February 1983;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8eba5110-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are pending before the Board of Governors of the Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8eba5111-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" which provide for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8eba5112-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increase in the authorized capital stock of the Bank and subscriptions thereto; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8eba5113-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increase in the resources of the Fund for Special Operations and contributions thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eba5114-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8eba5115-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon adoption of the resolutions specified in paragraph (1), the United States Governor of the Bank is authorized on behalf of the United States to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8eba5116-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subscribe to 427,396 shares of the increase in the authorized capital stock of the Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8eba5117-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribute $350,000,000 to the Fund for Special Operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8eba5118-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any commitment to make such subscriptions to paid-in and callable capital stock and to make such contributions to the Fund for Special Operations shall be effective only to such extent or in such amounts as are provided in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eba5119-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to pay for the increase in the United States subscription and contribution provided for in this section, there are authorized to be appropriated, without fiscal year limitation, for payment by the Secretary of the Treasury—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8eba511a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,155,862,744 for the United States subscriptions to the capital stock of the Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8eba511b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $350,000,000 for the United States share of the increase in the resources of the Fund for Special Operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eba511c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/147/s31"},"text":"Pub. L. 86–147, § 31","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title X, § 1001], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1284"},"text":"97 Stat. 1284","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
