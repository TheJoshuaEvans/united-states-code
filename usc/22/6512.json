{"tag":"section","attrib":{"id":"id90bd74c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6512"},"text":null,"children":[{"tag":"num","attrib":{"value":"6512"},"text":"§ 6512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions to Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are transferred to the Secretary of State all functions of the Director of the United States Arms Control and Disarmament Agency, and all functions of the United States Arms Control and Disarmament Agency and any office or component of such agency, under any statute, reorganization plan, Executive order, or other provision of law, as of the day before the effective date of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90bd74c8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XII, § 1212, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-767"},"text":"112 Stat. 2681–767","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90bd74c9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90bd74ca-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90bd74cb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of this subchapter, referred to in text, meaning the effective date of title XII of subdiv. A of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1201"},"text":"section 1201 of Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6511"},"text":"section 6511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
