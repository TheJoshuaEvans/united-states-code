{"tag":"section","attrib":{"id":"id8edbbc18-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290b"},"text":null,"children":[{"tag":"num","attrib":{"value":"290b"},"text":"§ 290b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; payment of salaries and expenses","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There are hereby authorized to be appropriated to the Department of State for contribution to the working capital fund of the organization the sum of $560,000 and as annual appropriations the following:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8edbbc19-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as may be necessary for the payment by the United States of its share of the expenses of the Organization as apportioned by the Health Assembly in accordance with article 56 of the constitution of the Organization, except that payments by the United States for any fiscal year of the Organization after 1958 shall not exceed 33⅓ per centum of the total assessments of active members of the Organization for such fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8edbbc1a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such additional sums, not to exceed $83,000 for the fiscal year beginning ","children":[{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":", as may be necessary to pay the expenses incident to participation by the United States in the activities of the Organization, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8edbbc1b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" salaries of the representative and alternate provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s290a"},"text":"section 290a of this title","children":[],"tail":", and appropriate staff, including personal services in the District of Columbia and elsewhere, without regard to the civil-service laws and chapter 51 and subchapter III of chapter 53 of title 5; services as authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"; under such rules and regulations as the Secretary of State may prescribe, allowances for living quarters, including heat, fuel, and light and cost of living allowances to persons temporarily stationed abroad; printing and binding without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s501"},"text":"section 501 of title 44","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8edbbc1c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other expenses as the Secretary of State deems necessary to participation by the United States in the activities of the Organization: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s287r"},"text":"section 287r of this title","children":[],"tail":", and regulations thereunder, applicable to expenses incurred pursuant to subchapter XVII of this chapter shall be applicable to any expenses incurred pursuant to this paragraph."}],"tail":"\n"}