{"tag":"section","attrib":{"id":"id90dc6dac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7206"},"text":null,"children":[{"tag":"num","attrib":{"value":"7206"},"text":"§ 7206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90dc6dad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A report described in section 7202(a)(1) or 7204(1) of this title shall be referred to the appropriate committee or committees of the House of Representatives and to the appropriate committee or committees of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6dae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral of joint resolution","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dc6daf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7206/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A joint resolution introduced in the Senate shall be referred to the Committee on Foreign Relations, and a joint resolution introduced in the House of Representatives shall be referred to the Committee on International Relations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6db0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7206/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A joint resolution referred to in paragraph (1) may not be reported before the eighth session day of Congress after the introduction of the joint resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90dc6db1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tIX/s907"},"text":"Pub. L. 106–387, § 1(a) [title IX, § 907]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–70.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90dc6db2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90dc6db3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id90dc6db4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
