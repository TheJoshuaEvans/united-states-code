{"tag":"section","attrib":{"id":"id8e8f6ffe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262g–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"262g–1"},"text":"§ 262g–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Targeting assistance to specific populations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e8f6fff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262g–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress finds that there is a need for concerted international efforts to deal with the problems of malnutrition, low life expectancy, childhood disease, underemployment, and low productivity in developing countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e8f7000-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262g–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to poorest populations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress notes with approval that the Inter-American Development Bank, under the terms of its Fifth Replenishment, has adopted the target that 50 percent of its lending benefit the poorest groups and has developed a usable methodology for determining the proportion of its lending which benefits such groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e8f7001-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXI/s1101"},"text":"Pub. L. 95–118, title XI, § 1101","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXIII/s1361/b"},"text":"Pub. L. 97–35, title XIII, § 1361(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/745"},"text":"95 Stat. 745","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e8f7002-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e8f7003-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8e8f7004-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1372"},"text":"section 1372 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s290i"},"text":"section 290i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
