{"tag":"section","attrib":{"id":"id8ebf3311-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285hh"},"text":null,"children":[{"tag":"num","attrib":{"value":"285hh"},"text":"§ 285hh.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Twelfth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf3312-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285hh/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank is authorized to contribute, on behalf of the United States, $177,440,000 to the twelfth replenishment of the resources of the Fund, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf3313-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285hh/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $177,440,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf3314-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s37"},"text":"Pub. L. 89–369, § 37","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dK/tVII/s7072/b"},"text":"Pub. L. 117–328, div. K, title VII, § 7072(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5092"},"text":"136 Stat. 5092","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
