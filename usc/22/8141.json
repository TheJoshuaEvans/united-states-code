{"tag":"section","attrib":{"id":"id90f6aceb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8141"},"text":null,"children":[{"tag":"num","attrib":{"value":"8141"},"text":"§ 8141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping violations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person willfully to fail or refuse—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f6acec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8141/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish or maintain any record required by any regulation prescribed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6aced-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8141/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit any report, notice, or other information to the United States Government in accordance with any regulation prescribed under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f6acee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8141/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permit access to or copying of any record by the United States Government in accordance with any regulation prescribed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f6acef-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/401/tII/s241"},"text":"Pub. L. 109–401, title II, § 241","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-18"},"text":"Dec. 18, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2747"},"text":"120 Stat. 2747","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
