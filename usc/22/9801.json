{"tag":"section","attrib":{"id":"id914c6dc2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9801"},"text":null,"children":[{"tag":"num","attrib":{"value":"9801"},"text":"§ 9801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914c6dc3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9801/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914c6dc4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9801/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6dc5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9801/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6dc6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9801/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant Federal department or agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"chil