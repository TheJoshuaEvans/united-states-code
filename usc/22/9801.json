text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3060"},"text":"133 Stat. 3060","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dJ/tV/s501"},"text":"“This title [enacting this chapter] may be cited as the ‘Global Fragility Act of 2019’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
