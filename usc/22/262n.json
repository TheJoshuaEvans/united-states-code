{"tag":"section","attrib":{"id":"id8e969c41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262n"},"text":null,"children":[{"tag":"num","attrib":{"value":"262n"},"text":"§ 262n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and policies respecting agricultural and commodity production","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress hereby finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e969c42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262n/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The financing of certain programs and projects by multilateral development banks has been of great concern insofar as the programs and projects have been detrimental to the interests of American farmers and the agribusiness sector.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e969c43-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262n/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An increase in rural income in developing countries will generally result in an increase in exports of United States agricultural and food products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e969c44-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXIV/s1401"},"text":"Pub. L. 95–118, title XIV, § 1401","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tI"},"text":"Pub. L. 100–202, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-131"},"text":"101 Stat. 1329–131","children":[],"tail":", 1329–134.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e969c45-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e969c46-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8e969c47-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/s1401"},"text":"Section 1401 of Pub. L. 95–118","children":[],"tail":" is based on section 701 of title VII of H.R. 3750, One Hundredth Congress, as introduced "},{"tag":"date","attrib":{"date":"1987-12-11"},"text":"Dec. 11, 1987","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e969c48-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8e969c49-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–5"},"text":"section 262p–5 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
