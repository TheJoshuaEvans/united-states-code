{"tag":"section","attrib":{"id":"id904d4d6f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3922c"},"text":"§ 3922c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integration of foreign economic policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904d4d70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in conjunction with the Under Secretary of Economic Growth, Energy, and the Environment, shall establish—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904d4d71-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign economic policy priorities for each regional bureau, including for individual countries, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d72-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies and guidance for integrating such foreign economic policy priorities throughout the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904d4d73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Assistant Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within each regional bureau of the Department, the Secretary shall task an existing Deputy Assistant Secretary with appropriate training and background in economic and commercial affairs with the responsibility for economic matters and interests within the responsibilities of each such regional bureau, including the integration of the foreign economic policy priorities established pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904d4d74-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish curriculum at the George P. Shultz National Foreign Affairs Training Center to develop the practical foreign economic policy expertise and skill sets of Foreign Service officers, including by making available distance-learning courses in commercial, economic, and business affairs, including in the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904d4d75-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The global business environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d76-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The economics of development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development and infrastructure finance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Current trade and investment agreements negotiations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922c/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Implementing existing multilateral and World Trade Organization agreements, and United States trade and investment agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d7a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922c/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Best practices for customs and export procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922c/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Market analysis and global supply chain management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904d4d7c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/tIV/s406"},"text":"Pub. L. 114–323, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1929"},"text":"130 Stat. 1929","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904d4d7d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904d4d7e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id904d4d7f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of State Authorities Act, Fiscal Year 2017, and not as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id904d4d80-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id904d4d81-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary”, “Department”, and “Foreign Service” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s2"},"text":"section 2 of Pub. L. 114–323","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
