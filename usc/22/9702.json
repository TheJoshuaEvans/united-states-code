{"tag":"section","attrib":{"id":"id914a2396-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9702"},"text":null,"children":[{"tag":"num","attrib":{"value":"9702"},"text":"§ 9702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recognition of Venezuela’s democratically elected National Assembly","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id914a2397-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress finds that Venezuela’s unicameral National Assembly convened on ","children":[{"tag":"date","attrib":{"date":"2016-01-06"},"text":"January 6, 2016","children":[],"tail":", following democratic elections that were held on "},{"tag":"date","attrib":{"date":"2015-12-06"},"text":"December 6, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a2398-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that Venezuela’s democratically elected National Assembly is the only national level democratic institution remaining in the country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a2399-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the policy of the United States to recognize the democratically elected National Assembly of Venezuela as the only legitimate national legislative body in Venezuela.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a239a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to Venezuela’s National Assembly","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, in coordination with the Administrator of the United States Agency for International Development, shall prioritize efforts to provide technical assistance to support the democratically elected National Assembly of Venezuela in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9731"},"text":"section 9731 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914a239b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tI/s112"},"text":"Pub. L. 116–94, div. J, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3031"},"text":"133 Stat. 3031","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
