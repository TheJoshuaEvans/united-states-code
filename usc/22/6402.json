{"tag":"section","attrib":{"id":"id90b64814-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402"},"text":null,"children":[{"tag":"num","attrib":{"value":"6402"},"text":"§ 6402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b64815-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ambassador at Large","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Ambassador at Large” means the Ambassador at Large for International Religious Freedom appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6411/b"},"text":"section 6411(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b64816-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Annual Report” means the Annual Report on International Religious Freedom described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6412/b"},"text":"section 6412(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b64817-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b64818-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate and the Committee on International Relations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b64819-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any determination made with respect to the taking of President ","children":[{"tag":"ref","attrib":{"idref":"fn002341"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002341"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Presidential”."}],"tail":" action under paragraphs (9) through (15) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6445/a"},"text":"section 6445(a) of this title","children":[],"tail":", the term includes the committees described in subparagraph (A) and, where appropriate, the Committee on Banking and Financial Services of the House of Representatives and the Committee on Banking, Housing, and Urban Affairs of the Senate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b6481a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commensurate action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commensurate action” means action taken by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6445/b"},"text":"section 6445(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b6481b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the United States Commission on International Religious Freedom established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6431/a"},"text":"section 6431(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b6481c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Country Reports on Human Rights Practices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Country Reports on Human Rights Practices” means the annual reports required to be submitted by the Department of State to Congress under sections 2151n(d) and 2304(b) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b6481d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Summary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Executive Summary” means the Executive Summary to the Annual Report, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6412/b/1/F"},"text":"section 6412(b)(1)(F) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b6481e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government or foreign government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “government” or “foreign government” includes any agency or instrumentality of the government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b6481f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human Rights Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Human Rights Reports” means all reports submitted by the Department of State to Congress under sections 2151n and 2304 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b64820-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b64821-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-state actor","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “non-state actor” means a nonsovereign entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b64822-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercises significant political power and territorial control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b64823-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is outside the control of a sovereign government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b64824-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" often employs violence in pursuit of its objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b64825-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Office” means the Office on International Religious Freedom established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6411/a"},"text":"section 6411(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b64826-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Particularly severe violations of religious freedom","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “particularly severe violations of religious freedom” means systematic, ongoing, egregious violations of religious freedom, including violations such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b64827-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" torture or cruel, inhuman, or degrading treatment or punishment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b64828-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prolonged detention without charges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b64829-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causing the disappearance of persons by the abduction or clandestine detention of those persons; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b6482a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/13/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other flagrant denial of the right to life, liberty, or the security of persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b6482b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Adviser","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Special Adviser” means the Special Adviser to the President on International Religious Freedom described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3021/i"},"text":"section 3021(i) of title 50","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002342"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002342"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b6482c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Watch List","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Special Watch List” means the Special Watch List described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6442/b/1/A/iii"},"text":"section 6442(b)(1)(A)(iii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b6482d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations of religious freedom","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “violations of religious freedom” means violations of the internationally recognized right to freedom of religion and religious belief and practice, as set forth in the international instruments referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6401/a/2"},"text":"section 6401(a)(2) of this title","children":[],"tail":" and as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6401/a/3"},"text":"section 6401(a)(3) of this title","children":[],"tail":", including violations such as—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b6482e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" arbitrary prohibitions on, restrictions of, or punishment for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90b6482f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/16/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assembling for peaceful religious activities such as worship, preaching, and prayer, including arbitrary registration requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90b64830-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/16/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" speaking freely about one’s religious beliefs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90b64831-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/16/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changing one’s religious beliefs and affiliation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90b64832-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/16/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not professing a particular religion, or any religion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90b64833-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/16/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possession and distribution of religious literature, including Bibles; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90b64834-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/16/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raising one’s children in the religious teachings and practices of one’s choice; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b64835-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6402/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any of the following acts if committed on account of an individual’s conscience, non-theistic views, or religious belief or practice: detention, interrogation, imposition of an onerous financial penalty, forced labor, forced mass resettlement, imprisonment, forced religious conversion, forcibly compelling non-believers or non-theists to recant their beliefs or to convert, beating, torture, mutilation, rape, enslavement, murder, and execution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90b64836-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292/s3"},"text":"Pub. L. 105–292, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2790"},"text":"112 Stat. 2790","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/281/s3"},"text":"Pub. L. 114–281, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1427"},"text":"130 Stat. 1427","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90b64837-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90b64838-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90b64839-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292"},"text":"Pub. L. 105–292","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2787"},"text":"112 Stat. 2787","children":[],"tail":", known as the International Religious Freedom Act of 1998, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6401"},"text":"section 6401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3021/i"},"text":"Section 3021(i) of title 50","children":[],"tail":", referred to in par. (14), was redesignated section 3021(k) by "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXVIII/s1841/g/1"},"text":"Pub. L. 110–53, title XVIII, § 1841(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/500"},"text":"121 Stat. 500","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90b6483a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Pars. (10) to (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/281/s3/2"},"text":"Pub. L. 114–281, § 3(2)","children":[],"tail":", (3), added pars. (10) and (11) and redesignated former pars. (10) to (12) as (12) to (14), respectively. Former par. (13) redesignated (16)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/281/s3/4"},"text":"Pub. L. 114–281, § 3(4)","children":[],"tail":", added par. (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/281/s3/1"},"text":"Pub. L. 114–281, § 3(1)","children":[],"tail":", redesignated par. (13) as (16)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (16)(A)(iv) to (vi). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/281/s3/5/A"},"text":"Pub. L. 114–281, § 3(5)(A)","children":[],"tail":", added cl. (iv) and redesignated former cls. (iv) and (v) as (v) and (vi), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (16)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/281/s3/5/B"},"text":"Pub. L. 114–281, § 3(5)(B)","children":[],"tail":", inserted “conscience, non-theistic views, or” after “an individual’s” and “forcibly compelling non-believers or non-theists to recant their beliefs or to convert,” after “forced religious conversion,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90b6483b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id90b6483c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Banking and Financial Services of House of Representatives abolished and replaced by Committee on Financial Services of House of Representatives, and jurisdiction over matters relating to securities and exchanges and insurance generally transferred from Committee on Energy and Commerce of House of Representatives by House Resolution No. 5, One Hundred Seventh Congress, ","children":[{"tag":"date","attrib":{"date":"2001-01-03"},"text":"Jan. 3, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
