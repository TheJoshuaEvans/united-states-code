{"tag":"section","attrib":{"id":"id90b3d7a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305"},"text":null,"children":[{"tag":"num","attrib":{"value":"6305"},"text":"§ 6305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b3d7a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “foreign person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d7a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is not a citizen of the United States or an alien admitted for permanent residence to the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d7a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation, partnership, or other nongovernment entity which is created or organized under the laws of a foreign country or which has its principal place of business outside the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “goods or technology” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d7a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nuclear materials and equipment and sensitive nuclear technology (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3203"},"text":"section 3203 of this title","children":[],"tail":"), all export items designated by the President pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2139a/c"},"text":"section 2139a(c) of title 42","children":[],"tail":", and all technical assistance requiring authorization under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2077/b"},"text":"section 2077(b) of title 42","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d7a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of exports from a country other than the United States, any goods or technology that, if exported from the United States, would be goods or technology described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “IAEA safeguards” means the safeguards set forth in an agreement between a country and the International Atomic Energy Agency, as authorized by Article III(A)(5) of the Statute of the International Atomic Energy Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “nuclear explosive device” means any device, whether assembled or disassembled, that is designed to produce an instantaneous release of an amount of nuclear energy from special nuclear material that is greater than the amount of energy that would be released from the detonation of one pound of trinitrotoluene (TNT);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “non-nuclear-weapon state” means any country which is not a nuclear-weapon state, as defined by Article IX (3) of the Treaty on the Non-Proliferation of Nuclear Weapons, signed at Washington, London, and Moscow on ","children":[{"tag":"date","attrib":{"date":"1968-07-01"},"text":"July 1, 1968","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “special nuclear material” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/aa"},"text":"section 2014(aa) of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “United States person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b3d7ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is a citizen of the United States or an alien admitted for permanent residence to the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b3d7ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation, partnership, or other nongovernment entity which is not a foreign person; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b3d7af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6305/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “unsafeguarded special nuclear material” means special nuclear material which is held in violation of IAEA safeguards or not subject to IAEA safeguards (excluding any quantity of material that could, if it were exported from the United States, be exported under a general license issued by the Nuclear Regulatory Commission).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90b3d7b0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVIII/s830"},"text":"Pub. L. 103–236, title VIII, § 830","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/521"},"text":"108 Stat. 521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90b3d7b1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90b3d7b2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90b3d7b3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original a reference to this part, meaning part B of title VIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", which is classified principally to this subchapter. For complete classification of part B to the Code, see Effective Date note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6301"},"text":"section 6301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90b3d7b4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90b3d7b5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s831"},"text":"section 831 of Pub. L. 103–236","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6301"},"text":"section 6301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
