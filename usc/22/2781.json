","children":[],"tail":" is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2785"},"text":"section 2785 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id901ffbb2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id901ffbb3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of the President under this section, see section 1(q) of Ex. Ord. No. 13637, ","children":[{"tag":"date","attrib":{"date":"2013-03-08"},"text":"Mar. 8, 2013","children":[],"tail":", 78 F.R. 16130, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":". Functions were previously delegated by Ex. Ord. No. 11958, which was formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and was revoked, subject to a savings provision, by section 4 of Ex. Ord. No. 13637."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
