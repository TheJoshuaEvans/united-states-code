{"tag":"section","attrib":{"id":"id901ffbaa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2781"},"text":null,"children":[{"tag":"num","attrib":{"value":"2781"},"text":"§ 2781.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions with countries not fully cooperating with United States antiterrorism efforts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id901ffbab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2781/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No defense article or defense service may be sold or licensed for export under this chapter in a fiscal year to a foreign country that the President determines and certifies to Congress, by May 15 of the calendar year in which that fiscal year begins, is not cooperating fully with United States antiterrorism efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id901ffbac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2781/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may waive the prohibition set forth in subsection (a) with respect to a specific transaction if the President determines that the transaction is important to the national interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id901ffbad-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 3, § 40A, as added "},{"t