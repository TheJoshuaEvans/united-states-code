{"tag":"section","attrib":{"id":"id91133576-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8807"},"text":null,"children":[{"tag":"num","attrib":{"value":"8807"},"text":"§ 8807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impositions of sanctions with respect to the Islamic Republic of Iran Broadcasting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91133577-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8807/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91133578-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8807/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Islamic Republic of Iran Broadcasting has contributed to the infringement of individuals’ human rights by broadcasting forced televised confession and show trials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91133579-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8807/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In March 2012, the European Council imposed sanctions on the President of the Islamic Republic of Iran Broadcasting, Ezzatollah Zargami, for broadcasting forced confessions of detainees and a series of “show trials” in August 2009 and December 2011 that constituted a clear violation of international law with respect to the right to a fair trial and due process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9113357a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8807/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9113357b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8807/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall, after ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9113357c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8807/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose sanctions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8514/c"},"text":"section 8514(c) of this title","children":[],"tail":" with respect to the Islamic Republic of Iran Broadcasting and the President of the Islamic Republic of Iran Broadcasting, Ezzatollah Zargami; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9113357d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8807/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the Islamic Republic of Iran Broadcasting and the President of the Islamic Republic of Iran Broadcasting, Ezzatollah Zargami, on the list of specially designated nationals and blocked persons maintained by the Office of Foreign Assets Control of the Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9113357e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8807/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement to impose sanctions under paragraph (1)(A) shall not include the authority to impose sanctions on the importation of goods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9113357f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8807/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of certain provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sections 8514(d) and 8551(b) of this title shall apply with respect to sanctions imposed under paragraph (1)(A) to the same extent that such sections apply with respect to the imposition of sanctions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8514/a"},"text":"section 8514(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91133580-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXII/s1248"},"text":"Pub. L. 112–239, div. A, title XII, § 1248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2015"},"text":"126 Stat. 2015","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91133581-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id91133582-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id91133583-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions and authorities vested in the President by this section, see Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2013-06-03"},"text":"June 3, 2013","children":[],"tail":", 78 F.R. 35545, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8801"},"text":"section 8801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
