{"tag":"section","attrib":{"id":"id9003728c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2734h"},"text":"§ 2734h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased accountability in assignment restrictions and reviews","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9003728d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9003728e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of policies to restrict personnel from serving in certain assignments may undermine the Department’s ability to deploy relevant cultural and linguistic skills at diplomatic posts abroad if not applied judiciously; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003728f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department should continuously evaluate all processes relating to assignment restrictions, assignment reviews, and preclusions at the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90037290-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of status","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90037291-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a status update for all Department personnel who, prior to ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", were subject to a prior assignment restriction, assignment review, or preclusion for whom a review or decision related to assignment is pending; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037292-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on an ongoing basis, provide a status update for any Department personnel who has been the subject of a pending assignment restriction or pending assignment review for more than 30 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90037293-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notification required under subsection (b) shall inform relevant personnel, as of the date of the notification—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90037294-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether any prior assignment restriction has been lifted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037295-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if their assignment status is subject to ongoing review, and an estimated date for completion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037296-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if they are subject to any other restrictions on their ability to serve at posts abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90037297-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjudication of ongoing assignment reviews","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90037298-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department shall establish a reasonable time limit for the Department to complete an assignment review and establish a deadline by which it must inform personnel of a decision related to such a review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037299-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For any personnel the Department determines are ineligible to serve in an assignment due to an assignment restriction or assignment review, a Security Appeal Panel shall convene not later than 120 days of an appeal being filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003729a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entry-level bidding process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department shall include a description of the assignment review process and critical human intelligence threat posts in a briefing to new officers as part of their entry-level bidding process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003729b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Points of contact","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department shall designate points of contact in the Bureau of Diplomatic Security and Bureau of Global Talent Management to answer employee and Career Development Officer questions about assignment restrictions, assignment reviews, and preclusions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9003729c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security appeal panel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Security Appeal Panel shall be comprised of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9003729d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of an office responsible for human resources or discrimination who reports directly to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003729e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Principal Deputy Assistant Secretary for the Bureau of Global Talent Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003729f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Principal Deputy Assistant Secretary for the Bureau of Intelligence and Research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id900372a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Assistant Secretary or Deputy, or equivalent, from a third bureau as designated by the Under Secretary for Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id900372a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative from the geographic bureau to which the restriction applies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id900372a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a representative from the Office of the Legal Adviser and a representative from the Bureau of Diplomatic Security, who shall serve as non-voting advisors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id900372a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id900372a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734h/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FAM update","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Secretary shall amend all relevant provisions of the Foreign Affairs Manual, and any associated or related policies of the Department, to comply with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id900372a5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXI/s6115"},"text":"Pub. L. 118–31, div. F, title LXI, § 6115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/969"},"text":"137 Stat. 969","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id900372a6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id900372a7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id900372a8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s6115"},"text":"section 6115 of Pub. L. 118–31","children":[],"tail":". Subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/s6115"},"text":"section 6115 of Pub. L. 118–31","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2734c"},"text":"section 2734c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id900372a9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id900372aa-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Department” and “Secretary” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s6002"},"text":"section 6002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
