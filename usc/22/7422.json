{"tag":"section","attrib":{"id":"id90dc6e4b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422"},"text":null,"children":[{"tag":"num","attrib":{"value":"7422"},"text":"§ 7422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver and termination of prohibitions of this subchapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90dc6e4c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to initially waive section 7424","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President is authorized to waive the prohibitions and requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7424"},"text":"section 7424 of this title","children":[],"tail":" for a single period of 1 year. A waiver under this subsection may be issued only if the President at least 15 days in advance of exercising such authority—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dc6e4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies the appropriate congressional committees of the intention to exercise such authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6e4e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determines and reports to the appropriate congressional committees that the International Criminal Court has entered into a binding agreement that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90dc6e4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prohibits the International Criminal Court from seeking to exercise jurisdiction over the following persons with respect to actions undertaken by them in an official capacity:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90dc6e50-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered United States persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90dc6e51-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered allied persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90dc6e52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who were covered United States persons or covered allied persons; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6e53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that no person described in subparagraph (A) will be arrested, detained, prosecuted, or imprisoned by or on behalf of the International Criminal Court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6e54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to extend waiver of section 7424","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President is authorized to waive the prohibitions and requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7424"},"text":"section 7424 of this title","children":[],"tail":" for successive periods of 1 year each upon the expiration of a previous waiver pursuant to subsection (a) or this subsection. A waiver under this subsection may be issued only if the President at least 15 days in advance of exercising such authority—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dc6e55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies the appropriate congressional committees of the intention to exercise such authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6e56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determines and reports to the appropriate congressional committees that the International Criminal Court—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90dc6e57-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" remains party to, and has continued to abide by, a binding agreement that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90dc6e58-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prohibits the International Criminal Court from seeking to exercise jurisdiction over the following persons with respect to actions undertaken by them in an official capacity:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id90dc6e59-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered United States persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id90dc6e5a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered allied persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id90dc6e5b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/b/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who were covered United States persons or covered allied persons; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90dc6e5c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that no person described in clause (i) will be arrested, detained, prosecuted, or imprisoned by or on behalf of the International Criminal Court; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6e5d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has taken no steps to arrest, detain, prosecute, or imprison any person described in clause (i) of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6e5e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to waive sections 7423 and 7425 with respect to an investigation or prosecution of a named individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President is authorized to waive the prohibitions and requirements of sections 7423 and 7425 of this title to the degree such prohibitions and requirements would prevent United States cooperation with an investigation or prosecution of a named individual by the International Criminal Court. A waiver under this subsection may be issued only if the President at least 15 days in advance of exercising such authority—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dc6e5f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies the appropriate congressional committees of the intention to exercise such authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6e60-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determines and reports to the appropriate congressional committees that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90dc6e61-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a waiver pursuant to subsection (a) or (b) of the prohibitions and requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7424"},"text":"section 7424 of this title","children":[],"tail":" is in effect;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6e62-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is reason to believe that the named individual committed the crime or crimes that are the subject of the International Criminal Court’s investigation or prosecution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6e63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the national interest of the United States for the International Criminal Court’s investigation or prosecution of the named individual to proceed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6e64-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in investigating events related to actions by the named individual, none of the following persons will be investigated, arrested, detained, prosecuted, or imprisoned by or on behalf of the International Criminal Court with respect to actions undertaken by them in an official capacity:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90dc6e65-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Covered United States persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90dc6e66-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Covered allied persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90dc6e67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/c/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals who were covered United States persons or covered allied persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6e68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of waiver pursuant to subsection (c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any waiver or waivers exercised pursuant to subsection (c) of the prohibitions and requirements of sections 7423 and 7425 of this title shall terminate at any time that a waiver pursuant to subsection (a) or (b) of the prohibitions and requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7424"},"text":"section 7424 of this title","children":[],"tail":" expires and is not extended pursuant to subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6e69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7422/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of prohibitions of this subchapter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibitions and requirements of sections 7423, 7424, and 7425 of this title shall cease to apply, and the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7427"},"text":"section 7427 of this title","children":[],"tail":" shall terminate, if the United States becomes a party to the International Criminal Court pursuant to a treaty made under article II, section 2, clause 2 of the Constitution of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90dc6e6a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206/tII/s2003"},"text":"Pub. L. 107–206, title II, § 2003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/901"},"text":"116 Stat. 901","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXII/s1212/b/1"},"text":"Pub. L. 110–181, div. A, title XII, § 1212(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/371"},"text":"122 Stat. 371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90dc6e6b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90dc6e6c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90dc6e6d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1212/b/1/A"},"text":"Pub. L. 110–181, § 1212(b)(1)(A)","children":[],"tail":", (B), substituted “section 7424” for “sections 7424 and 7426” in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c)(2)(A), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1212/b/1/C"},"text":"Pub. L. 110–181, § 1212(b)(1)(C)","children":[],"tail":", (D), substituted “section 7424” for “sections 7424 and 7426”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1212/b/1/E"},"text":"Pub. L. 110–181, § 1212(b)(1)(E)","children":[],"tail":", substituted “and 7425” for “7425, and 7426”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
