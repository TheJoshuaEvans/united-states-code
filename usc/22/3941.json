{"tag":"section","attrib":{"id":"id904fbe21-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3941"},"text":null,"children":[{"tag":"num","attrib":{"value":"3941"},"text":"§ 3941.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904fbe22-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3941/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizenship requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Only citizens of the United States may be appointed to the Service, other than for service abroad as a consular agent or as a foreign national employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904fbe23-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3941/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904fbe24-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3941/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe, as appropriate, written, oral, physical, foreign language, and other examinations for appointment to the Service (other than as a chief of mission or ambassador at large).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904fbe25-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3941/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that the Board of Examiners for the Foreign Service annually offers the oral assessment examinations described in paragraph (1) in cities, chosen on a rotating basis, located in at least three different time zones across the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904fbe26-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3941/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veteran or disabled veteran","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The fact that an applicant for appointment as a Foreign Service officer candidate is a veteran or disabled veteran shall be considered an affirmative factor in making such appointments. As used in this subsection, the term “veteran or disabled veteran” means an individual who is a preference eligible under subparagraph (A), (B), or (C) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2108/3"},"text":"section 2108(3) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904fbe27-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3941/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Career and noncareer appointments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904fbe28-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3941/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Service serving under career appointments are career members of the Service. Members of the Service serving under limited appointments are either career candidates or noncareer members of the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904fbe29-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3941/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chiefs of mission, ambassadors at large, and ministers serve at the pleasure of the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904fbe2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3941/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An appointment as a Foreign Service officer is a career appointment. Foreign Service employees serving as career candidates or career members of the Service shall not represent to the income tax authorities of the District of Columbia or any other State or locality that they are exempt from income taxation on the basis of holding a Presidential appointment subject to Senate confirmation or that they are exempt on the basis of serving in an appointment whose tenure is at the pleasure of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904fbe2b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s301"},"text":"Pub. L. 96–465, title I, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2083"},"text":"94 Stat. 2083","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s179/a"},"text":"Pub. L. 100–204, title I, § 179(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1362"},"text":"101 Stat. 1362","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLIV/s5406/b"},"text":"Pub. L. 117–81, div. E, title LIV, § 5406(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2374"},"text":"135 Stat. 2374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904fbe2c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904fbe2d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id904fbe2e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" inserted sentence at end relating to exemption from income taxation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id904fbe2f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id904fbe30-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s179/b"},"text":"Pub. L. 100–204, title I, § 179(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1363"},"text":"101 Stat. 1363","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/204/tI/s179/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to tax years beginning after ","children":[{"tag":"date","attrib":{"date":"1987-12-31"},"text":"December 31, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id904fbe31-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Foreign Service Examination","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s153/g"},"text":"Pub. L. 101–246, title I, § 153(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/44"},"text":"104 Stat. 44","children":[],"tail":", required the Secretary of State to enter into a contract with a private organization for a comprehensive review and evaluation of the Foreign Service examination related to cultural, racial, ethnic, and sexual bias issues, and no later than 18 months after "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", submit a report to Congress containing the findings of the review and evaluation, together with the comments of the Secretary and measures which the Secretary has initiated to respond to any adverse findings of such review."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
