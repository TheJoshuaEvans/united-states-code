{"tag":"section","attrib":{"id":"id9024ddbe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2797b"},"text":"§ 2797b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of missile equipment or technology by foreign persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9024ddbf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9024ddc0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsections (c) through (g),","children":[{"tag":"ref","attrib":{"idref":"fn002233"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002233"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" if the President determines that a foreign person, after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":", knowingly—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9024ddc1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exports, transfers, or otherwise engages in the trade of any MTCR equipment or technology that contributes to the acquisition, design, development, or production of missiles in a country that is not an MTCR adherent and would be, if it were United States-origin equipment or technology, subject to the jurisdiction of the United States under this chapter,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024ddc2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conspires to or attempts to engage in such export, transfer, or trade, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024ddc3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitates such export, transfer, or trade by any other person,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"or if the President has made a determination with respect to a foreign person under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4612/b/1"},"text":"section 4612(b)(1) of title 50","children":[],"tail":", then the President shall impose on that foreign person the applicable sanctions under paragraph (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9024ddc4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The sanctions which apply to a foreign person under paragraph (1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9024ddc5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the item involved in the export, transfer, or trade is within category II of the MTCR Annex, then the President shall deny, for a period of 2 years—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9024ddc6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States Government contracts relating to missile equipment or technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9024ddc7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licenses for the transfer to such foreign person of missile equipment or technology controlled under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024ddc8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the item involved in the export, transfer, or trade is within category I of the MTCR Annex, then the President shall deny, for a period of not less than 2 years—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9024ddc9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all United States Government contracts with such foreign person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9024ddca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licenses for the transfer to such foreign person of all items on the United States Munitions List.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024ddcb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, in addition to actions taken under subparagraphs (A) and (B), the President determines that the export, transfer, or trade has substantially contributed to the design, development, or production of missiles in a country that is not an MTCR adherent, then the President shall prohibit, for a period of not less than 2 years, the importation into the United States of products produced by that foreign person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9024ddcc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability with respect to MTCR adherents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9024ddcd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), subsection (a) does not apply with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9024ddce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any export, transfer, or trading activity that is authorized by the laws of an MTCR adherent, if such authorization is not obtained by misrepresentation or fraud; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024ddcf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any export, transfer, or trade of an item to an end user in a country that is an MTCR adherent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9024ddd0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), subsection (a) shall apply to an entity subordinate to a government that engages in exports or transfers described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2295a/b/3/A"},"text":"section 2295a(b)(3)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9024ddd1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of enforcement actions by MTCR adherents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sanctions set forth in subsection (a) may not be imposed under this section on a person with respect to acts described in such subsection or, if such sanctions are in effect against a person on account of such acts, such sanctions shall be terminated, if an MTCR adherent is taking judicial or other enforcement action against that person with respect to such acts, or that person has been found by the government of an MTCR adherent to be innocent of wrongdoing with respect to such acts, and if the President certifies to the Committee on Foreign Relations of the Senate and the Committee on International Relations of the House of Representatives that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9024ddd2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for any judicial or other enforcement action taken by the MTCR adherent, such action has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9024ddd3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" been comprehensive; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024ddd4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" been performed to the satisfaction of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9024ddd5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any finding of innocence of wrongdoing, the United States is satisfied with the basis for such finding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9024ddd6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory opinions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, in consultation with the Secretary of Defense and the Secretary of Commerce, may, upon the request of any person, issue an advisory opinion to that person as to whether a proposed activity by that person would subject that person to sanctions under this section. Any person who relies in good faith on such an advisory opinion which states that the proposed activity would not subject a person to such sanctions, and any person who thereafter engages in such activity, may not be made subject to such sanctions on account of such activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9024ddd7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver and report to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9024ddd8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any case other than one in which an advisory opinion has been issued under subsection (d) stating that a proposed activity would not subject a person to sanctions under this section, the President may waive the application of subsection (a) to a foreign person if the President determines that such waiver is essential to the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9024ddd9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event that the President decides to apply the waiver described in paragraph (1), the President shall so notify the Committee on Armed Services and the Committee on Foreign Relations of the Senate and the Committee on Armed Services and the Committee on Foreign Affairs of the House of Representatives not less than 45 working days before issuing the waiver. Such notification shall include a report fully articulating the rationale and circumstances which led the President to apply the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9024ddda-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presumption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether to apply sanctions under subsection (a) to a foreign person involved in the export, transfer, or trade of an item on the MTCR Annex, it should be a rebuttable presumption that such item is designed for use in a missile listed in the MTCR Annex if the President determines that the final destination of the item is a country the government of which the Secretary of State has determined, for purposes of 4605(j)(1)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002234"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002234"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be preceded by “section”."}],"tail":" of title 50, has repeatedly provided support for acts of international terrorism."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9024dddb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may waive the imposition of sanctions under paragraph (1) on a person with respect to a product or service if the President certifies to the Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9024dddc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product or service is essential to the national security of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9024dddd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such person is a sole source supplier of the product or service, the product or service is not available from any alternative reliable supplier, and the need for the product or service cannot be met in a timely manner by improved manufacturing processes or technological developments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9024ddde-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall not apply the sanction under this section prohibiting the importation of the products of a foreign person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9024dddf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of procurement of defense articles or defense services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9024dde0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under existing contracts or subcontracts, including the exercise of options for production quantities to satisfy requirements essential to the national security of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024dde1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the President determines that the person to which the sanctions would be applied is a sole source supplier of the defense articles and services, that the defense articles or services are essential to the national security of the United States, and that alternative sources are not readily or reasonably available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024dde2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the President determines that such articles or services are essential to the national security of the United States under defense coproduction agreements or NATO Programs of Cooperation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9024dde3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to products or services provided under contracts entered into before the date on which the President publishes his intention to impose the sanctions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9024dde4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9024dde5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" spare parts,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024dde6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" component parts, but not finished products, essential to United States products or production,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024dde7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/h/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" routine services and maintenance of products, to the extent that alternative sources are not readily or reasonably available, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9024dde8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2797b/h/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and technology essential to United States products or production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9024dde9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 7, § 73, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXVII/s1703"},"text":"Pub. L. 101–510, div. A, title XVII, § 1703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1746"},"text":"104 Stat. 1746","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tIII/s323/a"},"text":"Pub. L. 102–138, title III, § 323(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/711"},"text":"105 Stat. 711","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVII"},"text":"Pub. L. 103–236, title VII","children":[],"tail":", §§ 714(a)(7), 734(b), "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/497"},"text":"108 Stat. 497","children":[],"tail":", 505; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXIV/s1408/d"},"text":"Pub. L. 104–106, div. A, title XIV, § 1408(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/494"},"text":"110 Stat. 494","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XII, § 1225(a)(8), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-773"},"text":"112 Stat. 2681–773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dB/tXI/s1136/b"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. B, title XI, § 1136(b), (c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–495; "},{"tag":"ref","attrib":{"href":"/us/pl/113/276/tII/s208/a/5"},"text":"Pub. L. 113–276, title II, § 208(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2993"},"text":"128 Stat. 2993","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9024ddea-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9024ddeb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9024ddec-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsections (f) and (g), referred to in subsec. (a)(1), were redesignated subsecs. (g) and (h), respectively, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVII/s734/b/1"},"text":"Pub. L. 103–236, title VII, § 734(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/505"},"text":"108 Stat. 505","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1)(A), (2)(A)(ii), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1321"},"text":"82 Stat. 1321","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9024dded-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/276"},"text":"Pub. L. 113–276","children":[],"tail":" substituted “the Committee on Armed Services and the Committee on Foreign Affairs of the House of Representatives” for “the Committee on National Security and the Committee on International Relations of the House of Representatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/tXI/s1136/b"},"text":"Pub. L. 106–113, § 1000(a)(7) [title XI, § 1136(b)]","children":[],"tail":", designated existing provisions as par. (1), inserted par. heading, in introductory provisions, substituted “Except as provided in paragraph (2), subsection (a)” for “Subsection (a)”, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/tXI/s1136/c"},"text":"Pub. L. 106–113, § 1000(a)(7) [title XI, § 1136(c)]","children":[],"tail":", inserted before period at end “, and if the President certifies to the Committee on Foreign Relations of the Senate and the Committee on International Relations of the House of Representatives that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) for any judicial or other enforcement action taken by the MTCR adherent, such action has—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) been comprehensive; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) been performed to the satisfaction of the United States; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) with respect to any finding of innocence of wrongdoing, the United States is satisfied with the basis for such finding”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “and the Secretary of Commerce” for “, the Secretary of Commerce, and the Director of the United States Arms Control and Disarmament Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “the Committee on Armed Services and the Committee on Foreign Relations of the Senate and the Committee on National Security and the Committee on International Relations of the House of Representatives” for “the Congress” and “45 working days” for “20 working days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/s714/a/7"},"text":"Pub. L. 103–236, § 714(a)(7)","children":[],"tail":", substituted “, the Secretary of Commerce, and the Director of the United States Arms Control and Disarmament Agency,” for “and the Secretary of Commerce,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/s734/b"},"text":"Pub. L. 103–236, § 734(b)","children":[],"tail":", added subsec. (f) and redesignated former subsecs. (f) and (g) as (g) and (h), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138"},"text":"Pub. L. 102–138","children":[],"tail":" inserted “acquisition,” before “design,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9024ddee-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id9024ddef-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9024ddf0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-04-01"},"text":"Apr. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1201"},"text":"section 1201 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6511"},"text":"section 6511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9024ddf1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Space Cooperation With Russian Persons","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/280/tVII/s708"},"text":"Pub. L. 106–280, title VII, § 708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/862"},"text":"114 Stat. 862","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/112/s4/e/2"},"text":"Pub. L. 109–112, § 4(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-22"},"text":"Nov. 22, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2370"},"text":"119 Stat. 2370","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/112/s4/e/2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Certification.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall submit each year to the appropriate committees of Congress [Committee on Foreign Relations of the Senate and Committee on Foreign Affairs of the House of Representatives], with respect to each Russian person described in paragraph (2), a certification that the reports required to be submitted to Congress during the preceding calendar year under section 2 of the Iran and Syria Nonproliferation Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/178"},"text":"Public Law 106–178","children":[],"tail":") [now Iran, North Korea, and Syria Nonproliferation Act] ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note] do not identify that person on account of a transfer to Iran of goods, services, or technology described in section 2(a)(1)(B) of such Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The certification requirement under paragraph (1) applies with respect to each Russian person that, as of the date of the certification, is a party to an agreement relating to commercial cooperation on MTCR equipment or technology with a United States person pursuant to an arms export license that was issued at any time since ","children":[{"tag":"date","attrib":{"date":"2000-01-01"},"text":"January 1, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No activity or transfer which specifically has been the subject of a Presidential determination pursuant to section 5(a)(1), (2), or (3) of the Iran and Syria Nonproliferation Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/178"},"text":"Public Law 106–178","children":[],"tail":") [now Iran, North Korea, and Syria Nonproliferation Act] ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note] shall cause a Russian person to be considered as having been identified in the reports submitted during the preceding calendar year under section 2 of that Act for the purposes of the certification required under paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commencement and termination of requirement.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Times for submission","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall submit—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first certification under paragraph (1) not later than 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each annual certification thereafter on the anniversary of the first submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No certification is required under paragraph (1) after termination of cooperation under the specific license, or 5 years after the date on which the first certification is submitted, whichever is the earlier date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Existing Licenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, at any time after the issuance of a license under section 36(c) of the Arms Export Control Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2776/c"},"text":"22 U.S.C. 2776(c)","children":[],"tail":"] relating to the use, development, or co-production of commercial rocket engine technology with a foreign person, the President determines that the foreign person has engaged in any action described in section 73(a)(1) of the Arms Export Control Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2797b/a/1"},"text":"22 U.S.C. 2797b(a)(1)","children":[],"tail":") since the date the license was issued, the President may terminate the license."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report on Export Licensing of MTCR Items Under","children":[],"tail":" $50,000,000.—"}],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9024ddf2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"[Amended ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2797"},"text":"section 2797 of this title","children":[],"tail":".]"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign person","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘foreign person’ has the meaning given the term in section 74(7) of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2797c/7"},"text":"22 U.S.C. 2797c(7)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" MTCR ","children":[{"tag":"inline","attrib":{},"text":"equipment or technology","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘MTCR equipment or technology’ has the meaning given the term in section 74(5) of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2797c/5"},"text":"22 U.S.C. 2797c(5)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Person","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘person’ has the meaning given the term in section 74(8) of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2797c/8"},"text":"22 U.S.C. 2797c(8)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states person","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘United States person’ has the meaning given the term in section 74(6) of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2797c/6"},"text":"22 U.S.C. 2797c(6)","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9024ddf3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id9024ddf4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions of the President under this section, see Ex. Ord. No. 12851, § 2(a), ","children":[{"tag":"date","attrib":{"date":"1993-06-11"},"text":"June 11, 1993","children":[],"tail":", 58 F.R. 33181, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2797"},"text":"section 2797 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
