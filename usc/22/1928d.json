{"tag":"section","attrib":{"id":"id8f25bcd3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1928d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1928d"},"text":"§ 1928d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Auditing and accounting","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The certificate of the Chairman of the House delegation and the Senate delegation of the NATO Parliamentary Assembly shall on and after ","children":[{"tag":"date","attrib":{"date":"1956-07-11"},"text":"July 11, 1956","children":[],"tail":", be final and conclusive upon the accounting officers in the auditing of the accounts of the United States Group of the NATO Parliamentary Assembly."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f25bcd4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-07-11/ch562/s4"},"text":"July 11, 1956, ch. 562, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/524"},"text":"70 Stat. 524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/137"},"text":"Pub. L. 90–137","children":[],"tail":", pt. IV, § 401(a)(2), "},{"tag":"date","attrib":{"date":"1967-11-14"},"text":"Nov. 14, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/463"},"text":"81 Stat. 463","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tVII/s701/b/1"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title VII, § 701(b)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–459.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f25bcd5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f25bcd6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f25bcd7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was not enacted as part of the Mutual Security Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f25bcd8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" substituted “NATO Parliamentary Assembly” for “North Atlantic Assembly” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/137"},"text":"Pub. L. 90–137","children":[],"tail":" substituted “North Atlantic Assembly” for “North Atlantic Treaty Parliamentary Conference” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
