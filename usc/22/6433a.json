{"tag":"section","attrib":{"id":"id90b8b901-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6433a"},"text":"§ 6433a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90b8b902-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b8b903-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b8b904-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b8b905-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b8b906-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b8b907-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b908-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the United States Commission on International Religious Freedom established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6431"},"text":"section 6431 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b909-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commissioner” means a member of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b90a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vice Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Vice Chair” means the Vice Chair of the Commission who was appointed to such position by an elected official from the political party that is different from the political party of the elected official who appointed the Chair of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b8b90b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic policy and organizational review planning process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2015-10-16"},"text":"October 16, 2015","children":[],"tail":", and not less frequently than biennially thereafter, the Chair and Vice Chair of the Commission, in coordination with the Commissioners, the Ambassador-at-Large for International Religious Freedom, Commission staff, and others jointly selected by the Chair and Vice Chair, shall carry out a strategic policy and organizational review planning process that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b8b90c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the duties set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6432"},"text":"section 6432 of this title","children":[],"tail":" and the powers set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6432a"},"text":"section 6432a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b90d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation of a written description of prioritized actions that the Commission is required to complete to fulfill the strategic plan required under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b90e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the scope, content, and timing of the Commission’s annual report and any required changes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b90f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the personnel policies set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6432b"},"text":"section 6432b of this title","children":[],"tail":" and any required changes to such policies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b8b910-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unanimous agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b8b911-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the greatest extent possible, the Chair, Vice Chair, and all of the Commissioners shall ensure that this section is implemented in a manner that results in unanimous agreement among the Commissioners with regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b8b912-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategic policy and organizational review planning process required under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b8b913-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategic plan required under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b914-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative approval process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If unanimous agreement under paragraph (1) is not possible, items for inclusion in the strategic plan may, at the joint discretion of the Chair and Vice Chair, be approved by an affirmative vote of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90b8b915-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of Commissioners appointed by an elected official from the political party of the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90b8b916-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of Commissioners appointed by an elected official from the political party that is not the party of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b8b917-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of strategic plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", and every 2 years thereafter, the Chair and Vice Chair of the Commission shall jointly submit, to the appropriate congressional committees, a written strategic plan that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b8b918-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of prioritized actions for the Commission for a period of time to be specified by the Commissioners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b919-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any changes the Commission considers necessary with regard to the scope, content, and timing of the Commission’s annual report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b91a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any changes the Commission considers necessary with regard to personnel matters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b91b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission’s funding requirements for the period covered by the strategic plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b8b91c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pending issues","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The strategic plan required under subsection (d) may identify any issues or proposals that have not yet been resolved by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b8b91d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of personnel provisions and annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding section ","children":[{"tag":"ref","attrib":{"idref":"fn002344"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002344"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “sections”."}],"tail":" 6432b(a) and 6533(a) of this title, the Commission is authorized to implement provisions related to personnel and the Commission’s annual report that are included in the strategic plan submitted pursuant to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b8b91e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional oversight","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon request, the Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b8b91f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available for inspection any information and documents requested by the appropriate congressional committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b8b920-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6433a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond to any requests to provide testimony before the appropriate congressional committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90b8b921-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/71/s4"},"text":"Pub. L. 114–71, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-10-16"},"text":"Oct. 16, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/563"},"text":"129 Stat. 563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tVIII/s807"},"text":"Pub. L. 116–94, div. J, title VIII, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3079"},"text":"133 Stat. 3079","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90b8b922-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90b8b923-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90b8b924-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", referred to in subsec. (d), was in the original “the date of the enactment of this Act”, and was translated as referring to the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":", which amended subsec. (d), to reflect the probable intent of Congress. See 2019 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90b8b925-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the United States Commission on International Religious Freedom Reauthorization Act of 2015, and not as part of the International Religious Freedom Act of 1998 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90b8b926-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":", in introductory provisions, substituted “Not later than 180 days after "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", and every 2 years thereafter” for “Not later than 180 days after "},{"tag":"date","attrib":{"date":"2015-10-16"},"text":"October 16, 2015","children":[],"tail":", and not less frequently than biennially thereafter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
