{"tag":"section","attrib":{"id":"id8f7deefe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291m"},"text":null,"children":[{"tag":"num","attrib":{"value":"2291m"},"text":"§ 2291m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to provide assistance to build the capacity of foreign law enforcement agencies with respect to covered synthetic drugs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f7deeff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2420"},"text":"section 2420 of this title","children":[],"tail":", the Secretary of State shall establish a program to provide assistance to strengthen the capacity of law enforcement agencies of the countries described in subsection (c) to help such agencies to identify, track, and improve their forensics detection capabilities with respect to covered synthetic drugs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7def00-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall prioritize technical assistance, and the provision of equipment, as appropriate, under subsection (a) among those countries described in subsection (c) in which such assistance and equipment would have the most impact in reducing illicit use of covered synthetic drugs in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7def01-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Countries described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The foreign countries described in this subsection are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7def02-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" countries that are producers of covered synthetic drugs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7def03-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" countries whose pharmaceutical and chemical industries are known to be exploited for development or procurement of precursors of covered synthetic drugs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7def04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291m/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" major drug-transit countries for covered synthetic drugs as defined by the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7def05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No assistance may be provided to the People’s Republic of China or to any of its law enforcement agencies pursuant to the program authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7def06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291m/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary of State to carry out this section $4,000,000 for each of fiscal years 2023 through 2027.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f7def07-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5553"},"text":"Pub. L. 117–263, div. E, title LV, § 5553","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3341"},"text":"136 Stat. 3341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f7def08-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f7def09-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f7def0a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Fighting Emerging Narcotics Through Additional Nations to Yield Lasting Results Act, also known as the FENTANYL Results Act, and also as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f7def0b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f7def0c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in subtitle C (§§ 5551–5558) of title LV of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", or the amendments made by that subtitle, to be construed as affecting the prioritization of extradition requests, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5557"},"text":"section 5557 of Pub. L. 117–263","children":[],"tail":", set out as a note under section 2291"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8f7def0d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “covered synthetic drug” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5558"},"text":"section 5558 of Pub. L. 117–263","children":[],"tail":", set out as a note under section 2291"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
