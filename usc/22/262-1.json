{"tag":"section","attrib":{"id":"id8e8ab5a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"262–1"},"text":"§ 262–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction relating to United States accession to any new international criminal tribunal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e8ab5a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States shall not become a party to any new international criminal tribunal, nor give legal effect to the jurisdiction of such a tribunal over any matter described in subsection (b), except pursuant to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e8ab5aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a treaty made under Article II, section 2, clause 2 of the Constitution of the United States on or after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8ab5ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any statute enacted by Congress on or after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e8ab5ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The jurisdiction described in this section is jurisdiction over—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e8ab5ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons found, property located, or acts or omissions committed, within the territory of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8ab5ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nationals of the United States, wherever found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e8d26af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section precludes sharing information, expertise, or other forms of assistance with such tribunal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e8d26b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “New international criminal tribunal” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “new international criminal tribunal” means any permanent international criminal tribunal established on or after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"October 21, 1998","children":[],"tail":", and does not include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e8d26b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Tribunal for the Prosecution of Persons Responsible for Serious Violations of International Humanitarian Law in the Territory of the Former Yugoslavia, as established by United Nations Security Council Resolution 827 of ","children":[{"tag":"date","attrib":{"date":"1993-05-25"},"text":"May 25, 1993","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8d26b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Tribunal for the Prosecution of Persons Responsible for Genocide and Other Serious Violations of International Humanitarian Law Committed in the Territory of Rwanda and Rwandan Citizens Responsible for Genocide and Other Such Violations Committed in the Territory of Neighboring States, as established by United Nations Security Council Resolution 955 of ","children":[{"tag":"date","attrib":{"date":"1994-11-08"},"text":"November 8, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e8d26b3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXV, § 2502, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-836"},"text":"112 Stat. 2681–836","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e8d26b4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e8d26b5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8e8d26b6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Restriction Relating to United States Accession to the International Criminal Court","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tVII/s705"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title VII, § 705]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–460, formerly set out as a note under this section, was transferred and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7401"},"text":"section 7401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8e8d26b7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition on Extradition or Transfer of United States Citizens to the International Criminal Court","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tVII/s706"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title VII, § 706]","children":[],"tail"