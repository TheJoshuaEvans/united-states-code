{"tag":"section","attrib":{"id":"id90e128a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7552"},"text":null,"children":[{"tag":"num","attrib":{"value":"7552"},"text":"§ 7552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress regarding protecting Afghanistan’s President","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e128a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7552/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any United States physical protection force provided for the personal security of the President of Afghanistan should be composed of United States diplomatic security, law-enforcement, or military personnel, and should not utilize private contracted personnel to provide actual physical protection services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e128a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7552/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States allies should be invited to volunteer active-duty military or law enforcement personnel to participate in such a protection force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e128aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7552/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such a protection force should be limited in duration and should be succeeded by qualified Afghan security forces as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90e128ab-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/327/tIII/s302"},"text":"Pub. L. 107–327, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-04"},"text":"Dec. 4, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2812"},"text":"116 Stat. 2812","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
