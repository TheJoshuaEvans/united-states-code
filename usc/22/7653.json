{"tag":"section","attrib":{"id":"id90eac5e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7653"},"text":null,"children":[{"tag":"num","attrib":{"value":"7653"},"text":"§ 7653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports on prevention of mother-to-child transmission of the HIV infection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90eac5e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7653/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", and annually thereafter for a period of 10 years, the President shall submit to appropriate congressional committees a report on the activities of relevant executive branch agencies during the reporting period to assist in the prevention of mother-to-child transmission of the HIV infection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac5e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7653/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90eac5ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7653/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of whether or not all relevant executive branch agencies have met the goal described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7652/b/1"},"text":"section 7652(b)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac5eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7653/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of efforts made by the relevant executive branch agencies to expand those activities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac5ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7653/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the number of sites supported for the prevention of mother-to-child transmission of the HIV infection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac5ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7653/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific activities supported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac5ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7653/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of women tested and counseled; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac5ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7653/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of women receiving preventative drug therapies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac5f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7653/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting period defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “reporting period” means, in the case of the initial report, the period since ","children":[{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", and, in the case of any subsequent report, the period since the date of submission of the most recent report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90eac5f1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25/tIII/s313"},"text":"Pub. L. 108–25, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/741"},"text":"117 Stat. 741","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/293/tIII/s308"},"text":"Pub. L. 110–293, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2964"},"text":"122 Stat. 2964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90eac5f2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90eac5f3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90eac5f4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293"},"text":"Pub. L. 110–293","children":[],"tail":" substituted “10 years” for “5 years”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id90eac5f5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id90eac5f6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":", and Memorandum of President of "},{"tag":"date","attrib":{"date":"2004-02-23"},"text":"Feb. 23, 2004","children":[],"tail":", 69 F.R. 9509, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7611"},"text":"section 7611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
