{"tag":"section","attrib":{"id":"id906c6e28-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102"},"text":null,"children":[{"tag":"num","attrib":{"value":"4102"},"text":"§ 4102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906c6e29-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Authority” means the Federal Labor Relations Authority, described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7104/a"},"text":"section 7104(a) of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Board” means the Foreign Service Labor Relations Board, established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4106/a"},"text":"section 4106(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “collective bargaining” means the performance of the mutual obligation of the management representative of the Department and of the exclusive representative of employees to meet at reasonable times and to consult and bargain in a good-faith effort to reach agreement with respect to the conditions of employment affecting employees, and to execute, if requested by either party, a written document incorporating any collective bargaining agreement reached, but this obligation does not compel either party to agree to a proposal or to make a concession;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “collective bargaining agreement” means an agreement entered into as a result of collective bargaining under the provisions of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e2d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “conditions of employment” means personnel policies, practices, and matters, whether established by regulation or otherwise, affecting working conditions, but does not include policies, practices, and matters—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id906c6e2e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to political activities prohibited abroad or prohibited under subchapter III of chapter 73 of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6e2f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to the designation or classification of any position under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3981"},"text":"section 3981 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6e30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent such matters are specifically provided for by Federal statute; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6e31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to Government-wide or multiagency responsibility of the Secretary affecting the rights, benefits, or obligations of individuals employed in agencies other than those which are authorized to utilize the Foreign Service personnel system;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “confidential employee” means an employee who acts in a confidential capacity with respect to an individual who formulates or effectuates management policies in the field of labor-management relations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “dues” means dues, fees, and assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id906c6e35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Service who is a citizen of the United States, wherever serving, other than a management official, a confidential employee, a consular agent, a member of the Service who is a United States citizen (other than a family member) employed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3951"},"text":"section 3951 of this title","children":[],"tail":", or any individual who participates in a strike in violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7311"},"text":"section 7311 of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6e36-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a former member of the Service as described in subparagraph (A) whose employment has ceased because of an unfair labor practice under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4115"},"text":"section 4115 of this title","children":[],"tail":" and who has not obtained any other regular and substantially equivalent employment, as determined under regulations prescribed by the Board;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e37-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “exclusive representative” means any labor organization which is certified as the exclusive representative of employees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4111"},"text":"section 4111 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e38-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “General Counsel” means the General Counsel of the Authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e39-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “labor organization” means an organization composed in whole or in part of employees, in which employees participate and pay dues, and which has as a purpose dealing with the Department concerning grievances (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4131"},"text":"section 4131 of this title","children":[],"tail":") and conditions of employment, but does not include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id906c6e3a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization which, by its constitution, bylaws, tacit agreement among its members, or otherwise, denies membership because of race, color, creed, national origin, sex, age, preferential or nonpreferential civil service status, political affiliation, marital status, or disability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6e3b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization which advocates the overthrow of the constitutional form of government of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6e3c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization sponsored by the Department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6e3d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/11/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organization which participates in the conduct of a strike against the Government or any agency thereof or imposes a duty or obligation to conduct, assist, or participate in such a strike;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e3e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “management official” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id906c6e3f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a chief of mission or principal officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6e40-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving in a position to which appointed by the President, by and with the advice and consent of the Senate, or by the President alone;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6e41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occupies a position which in the sole judgment of the Secretary is of comparable importance to the offices mentioned in subparagraph (A) or (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6e42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/12/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving as a deputy to any individual described by subparagraph (A), (B), or (C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6e43-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/12/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assigned to carry out functions of the Inspector General of the Department of State and the Foreign Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3929"},"text":"section 3929 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906c6e44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/12/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in the administration of this subchapter or in the formulation of the personnel policies and programs of the Department;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Panel” means the Foreign Service Impasse Disputes Panel, established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4110/a"},"text":"section 4110(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4102/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person” means an individual, a labor organization, or an agency to which this subchapter applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id906c6e47-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s1002"},"text":"Pub. L. 96–465, title I, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2129"},"text":"94 Stat. 2129","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s180/a/9"},"text":"Pub. L. 103–236, title I, § 180(a)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/416"},"text":"108 Stat. 416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCII/s9219/3"},"text":"Pub. L. 117–263, div. I, title XCII, § 9219(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3879"},"text":"136 Stat. 3879","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id906c6e48-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id906c6e49-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id906c6e4a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (11)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “disability” for “handicapping condition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (8)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" inserted “a member of the Service who is a United States citizen (other than a family member) employed under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3951"},"text":"section 3951 of this title","children":[],"tail":",”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
