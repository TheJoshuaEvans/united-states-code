{"tag":"section","attrib":{"id":"id91218e52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241"},"text":null,"children":[{"tag":"num","attrib":{"value":"9241"},"text":"§ 9241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy to promote North Korean human rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91218e53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2018-10-25"},"text":"October 25, 2018","children":[],"tail":", and periodically thereafter, the Secretary of State, in coordination with other appropriate Federal departments and agencies, shall submit to the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives a report that details a United States strategy to promote initiatives to enhance international awareness of and to address the human rights situation in North Korea."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218e54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under subsection (a) should include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218e55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of countries that forcibly repatriate refugees from North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218e56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of countries where North Korean laborers work, including countries the governments of which have formal arrangements with the Government of North Korea or any person acting for or on behalf of that Government to employ North Korean workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe57-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of foreign persons that knowingly employ North Korean laborers, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9214/g/1/C"},"text":"section 9214(g)(1)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9123fe58-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under subsection (a) should include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9123fe59-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to enhance bilateral and multilateral outreach, including sustained engagement with the governments of partners and allies with overseas posts to routinely demarche or brief those governments on North Korea human rights issues, including forced labor, trafficking, and repatriation of citizens of North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe5a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public affairs and public diplomacy campaigns, including options to work with news organizations and media outlets to publish opinion pieces and secure public speaking opportunities for United States Government officials on issues related to the human rights situation in North Korea, including forced labor, trafficking, and repatriation of citizens of North Korea; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe5b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities to coordinate and collaborate with appropriate nongovernmental organizations and private sector entities to raise awareness and provide assistance to North Korean defectors throughout the world.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9123fe5c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tIII/s302"},"text":"Pub. L. 114–122, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/112"},"text":"130 Stat. 112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s321/a/1"},"text":"Pub. L. 115–44, title III, § 321(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/951"},"text":"131 Stat. 951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/272/tIII/s303/c/2"},"text":"Pub. L. 115–272, title III, § 303(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-25"},"text":"Oct. 25, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4157"},"text":"132 Stat. 4157","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXI/s7122/b/4"},"text":"Pub. L. 116–92, div. F, title LXXI, § 7122(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2248"},"text":"133 Stat. 2248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9123fe5d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9123fe5e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9123fe5f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “section 9214(g)(1)(C)” for “section 9214(b)(1)(M)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/272"},"text":"Pub. L. 115–272","children":[],"tail":" substituted “Not later than 120 days after "},{"tag":"date","attrib":{"date":"2018-10-25"},"text":"October 25, 2018","children":[],"tail":", and periodically thereafter” for “Not later than 180 days after "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"February 18, 2016","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44"},"text":"Pub. L. 115–44","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9123fe60-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9123fe61-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Determinations; Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s321/a/2"},"text":"Pub. L. 115–44, title III, § 321(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/951"},"text":"131 Stat. 951","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/44/tIII/s321/a/2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“With respect to any country identified in section 302(b)(2) of the North Korea Sanctions and Policy Enhancement Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9241/b/2"},"text":"22 U.S.C. 9241(b)(2)","children":[],"tail":"), as amended by paragraph (1), the report required under section 302(a) of such Act shall—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a determination whether each person identified in section 302(b)(3) of such Act (as amended by paragraph (1)) who is a national or a citizen of such identified country meets the criteria for sanctions under—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 111 of the Trafficking Victims Protection Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7108"},"text":"22 U.S.C. 7108","children":[],"tail":") (relating to the prevention of trafficking in persons); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 104(a) or 104(b)(1) of the North Korea Sanctions and Policy Enhancement Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9214/a"},"text":"22 U.S.C. 9214(a)","children":[],"tail":"[, (b)(1)]), as amended by section 101 of this Act;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be included in the report required under section 110(b) of the Trafficking Victims Protection Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7107/b"},"text":"22 U.S.C. 7107(b)","children":[],"tail":") (relating to the annual report on trafficking in persons); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be considered in any determination that the government of such country has made serious and sustained efforts to eliminate severe forms of trafficking in persons, as such term is defined for purposes of the Trafficking Victims Protection Act of 2000 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7101"},"text":"22 U.S.C. 7101","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
