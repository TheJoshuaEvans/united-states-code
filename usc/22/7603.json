{"tag":"section","attrib":{"id":"id90e39a59-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603"},"text":null,"children":[{"tag":"num","attrib":{"value":"7603"},"text":"§ 7603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purpose of this chapter is to strengthen and enhance United States leadership and the effectiveness of the United States response to the HIV/AIDS, tuberculosis, and malaria pandemics and other related and preventable infectious diseases as part of the overall United States health and development agenda by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e39a5a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing comprehensive, coordinated, and integrated 5-year, global strategies to combat HIV/AIDS, tuberculosis, and malaria by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e39a5b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building on progress and successes to date;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e39a5c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving harmonization of United States efforts with national strategies of partner governments and other public and private entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e39a5d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emphasizing capacity building initiatives in order to promote a transition toward greater sustainability through the support of country-driven efforts;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e39a5e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing increased resources for bilateral and multilateral efforts to fight HIV/AIDS, tuberculosis, and malaria as integrated components of United States development assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e39a5f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" intensifying efforts to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e39a60-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent HIV infection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e39a61-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the continued support for, and expanded access to, treatment and care programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e39a62-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the effectiveness of prevention, treatment, and care programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e39a63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address the particular vulnerabilities of girls and women;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e39a64-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the expansion of private sector efforts and expanding public-private sector partnerships to combat HIV/AIDS, tuberculosis, and malaria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e39a65-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reinforcing efforts to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e39a66-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop safe and effective vaccines, microbicides, and other prevention and treatment technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e39a67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve diagnostics capabilities for HIV/AIDS, tuberculosis, and malaria; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e39a68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" helping partner countries to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e39a69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen health systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e39a6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand health workforce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e39a6b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7603/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address infrastructural weaknesses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90e39a6c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25/s4"},"text":"Pub. L. 108–25, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/717"},"text":"117 Stat. 717","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/293/s4"},"text":"Pub. L. 110–293, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2922"},"text":"122 Stat. 2922","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90e39a6d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90e39a6e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90e39a6f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25"},"text":"Pub. L. 108–25","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/711"},"text":"117 Stat. 711","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7601"},"text":"section 7601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90e39a70-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293"},"text":"Pub. L. 110–293","children":[],"tail":" amended section generally. Prior to amendment, section stated the purpose of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
