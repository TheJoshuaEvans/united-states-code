{"tag":"section","attrib":{"id":"id8fcef5c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507i"},"text":null,"children":[{"tag":"num","attrib":{"value":"2507i"},"text":"§ 2507i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fcef5c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall annually through ","children":[{"tag":"date","attrib":{"date":"2018-09-30"},"text":"September 30, 2018","children":[],"tail":", submit to the Committee on Foreign Relations and the Committee on Appropriations of the Senate and the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives a report summarizing information on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fcef5c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sexual assault of volunteers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef5c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other crimes against volunteers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef5c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507i/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of arrests, prosecutions, and incarcerations for crimes involving Peace Corps volunteers for every country in which volunteers serve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef5c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507i/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual rate of early termination of volunteers, including demographic data associated with such early termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef5c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2011-11-21"},"text":"November 21, 2011","children":[],"tail":", the Comptroller General of the United States shall submit to the Committee on Foreign Relations and the Committee on Appropriations of the Senate and the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives a report evaluating the quality and accessibility of health care provided through the Department of Labor to returned volunteers upon their separation from the Peace Corps."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef5c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to communications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fcef5c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall determine the level of access to communication, including cellular and Internet access, of each volunteer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef5ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than six months after ","children":[{"tag":"date","attrib":{"date":"2011-11-21"},"text":"November 21, 2011","children":[],"tail":", the President shall submit to the Committee on Foreign Relations and the Committee on Appropriations of the Senate and the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives a report on the costs, feasibility, and benefits of providing all volunteers with access to adequate communication, including cellular service and Internet access."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fcef5cb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/tI/s8I"},"text":"Pub. L. 87–293, title I, § 8I","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/57/s2"},"text":"Pub. L. 112–57, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-21"},"text":"Nov. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/743"},"text":"125 Stat. 743","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
