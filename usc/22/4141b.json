{"tag":"section","attrib":{"id":"id90712912-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4141b"},"text":null,"children":[{"tag":"num","attrib":{"value":"4141b"},"text":"§ 4141b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Together with the annual submission required under section 3905(d)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002295"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002295"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the Secretary of State shall submit a report to the Congress concerning the implementation of the program established under this subchapter. Such report accompanied by such other information as the Secretary considers appropriate, shall include specific information concerning the completion rates of interns in the program, interns who took the Foreign Service examination, interns who passed the examination, former interns appointed to the Foreign Service, assignments of former interns, and the advancement of former interns through the Foreign Service System."},{"tag":"ref","attrib":{"idref":"fn002296"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002296"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":null}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90712913-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s1203"},"text":"Pub. L. 96–465, title I, § 1203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s149/b"},"text":"Pub. L. 101–246, title I, § 149(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/41"},"text":"104 Stat. 41","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90712914-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90712915-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90712916-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3905/d/2"},"text":"Section 3905(d)(2) of this title","children":[],"tail":", referred to in text, was omitted from the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
