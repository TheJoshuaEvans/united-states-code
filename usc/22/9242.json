{"tag":"section","attrib":{"id":"id9123fe77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9242"},"text":null,"children":[{"tag":"num","attrib":{"value":"9242"},"text":"§ 9242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on North Korean prison camps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9123fe78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9242/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall submit to the appropriate congressional committees a report that describes, with respect to each political prison camp in North Korea, to the extent information is available—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9123fe79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9242/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the camp’s estimated prisoner population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe7a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9242/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the camp’s geographical coordinates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9242/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for the confinement of the prisoners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe7c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9242/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the camp’s primary industries and products, and the end users of any goods produced in the camp;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9242/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individuals and agencies responsible for conditions in the camp;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9242/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions under which prisoners are confined, with respect to the adequacy of food, shelter, medical care, working conditions, and reports of ill-treatment of prisoners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9242/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imagery, to include satellite imagery of the camp, in a format that, if published, would not compromise the sources and methods used by the United States intelligence community to capture geospatial imagery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9123fe80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9242/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required under subsection (a) may be included in the first human rights report required to be submitted to Congress after ","children":[{"tag":"date","attrib":{"date":"2016-02-18"},"text":"February 18, 2016","children":[],"tail":", under sections 2151n(d) and 2304(b) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9123fe81-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tIII/s303"},"text":"Pub. L. 114–122, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/113"},"text":"130 Stat. 113","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
