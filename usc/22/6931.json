{"tag":"section","attrib":{"id":"id90cbcbea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6931"},"text":null,"children":[{"tag":"num","attrib":{"value":"6931"},"text":"§ 6931.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review within the WTO","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the objective of the United States to obtain as part of the Protocol of Accession of the People’s Republic of China to the WTO, an annual review within the WTO of the compliance by the People’s Republic of China with its terms of accession to the WTO.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90cbcbeb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286/dB/tIV/s401"},"text":"Pub. L. 106–286, div. B, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/900"},"text":"114 Stat. 900","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
