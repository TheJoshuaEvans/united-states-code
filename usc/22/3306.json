{"tag":"section","attrib":{"id":"id90330ec2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3306"},"text":null,"children":[{"tag":"num","attrib":{"value":"3306"},"text":"§ 3306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services to United States citizens on Taiwan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90330ec3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Institute may authorize any of its employees on Taiwan—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90330ec4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer to or take from any person an oath, affirmation, affidavit, or deposition, and to perform any notarial act which any notary public is required or authorized by law to perform within the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90330ec5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To ","children":[{"tag":"ref","attrib":{"idref":"fn002251"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002251"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" act as provisional conservator of the personal estates of deceased United States citizens; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90330ec6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist and protect the interests of United States persons by performing other acts such as are authorized to be performed outside the United States for consular purposes by such laws of the United States as the President may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90330ec7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acts by authorized employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Acts performed by authorized employees of the Institute under this section shall be valid, and of like force and effect within the United States, as if performed by any other person authorized under the laws of the United States to perform such acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90330ec8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/8/s7"},"text":"Pub. L. 96–8, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-04-10"},"text":"Apr. 10, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/17"},"text":"93 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90330ec9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90330eca-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90330ecb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective as of ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"January 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/8/s18"},"text":"section 18 of Pub. L. 96–8","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3301"},"text":"section 3301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
