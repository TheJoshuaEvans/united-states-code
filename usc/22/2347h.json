{"tag":"section","attrib":{"id":"id8f937368-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2347h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2347h"},"text":"§ 2347h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human rights report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f937369-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2347h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than March 1 of each year, the Secretary of State shall submit to the Speaker of the House of Representatives and the Committee on Foreign Relations of the Senate a report describing, to the extent practicable, any involvement of a foreign military or defense ministry civilian participant in education and training activities under this part in a violation of internationally recognized human rights reported under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151n/d"},"text":"section 2151n(d) of this title","children":[],"tail":" subsequent to such participation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f93736a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2347h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report described in subsection (a) shall be in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f93736b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 549, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXII/s1212/a"},"text":"Pub. L. 107–228, div. B, title XII, § 1212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1428"},"text":"116 Stat. 1428","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
