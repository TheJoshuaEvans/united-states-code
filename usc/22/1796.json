{"tag":"section","attrib":{"id":"id8f1e9135-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1796"},"text":null,"children":[{"tag":"num","attrib":{"value":"1796"},"text":"§ 1796.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in Joint Commission on Rural Reconstruction in China","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized to continue to participate in the Joint Commission on Rural Reconstruction in China and to appoint citizens of the United States to the Commission.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f1e9136-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-26/ch937"},"text":"Aug. 26, 1954, ch. 937","children":[],"tail":", ch. IV, § 536, "},{"tag":"ref","attrib":{"href":"/us/stat/68/861"},"text":"68 Stat. 861","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
