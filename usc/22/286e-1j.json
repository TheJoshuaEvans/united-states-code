{"tag":"section","attrib":{"id":"id8ec17d87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1j"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–1j"},"text":"§ 286e–1j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional increase in capital stock of Bank; subscription to additional shares; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ec17d88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States Governor of the Bank is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ec17d89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to vote for an increase of seventy thousand shares in the authorized capital stock of the Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ec17d8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to subscribe on behalf of the United States to twelve thousand four hundred and fifty-three additional shares of the capital stock of the Bank, except that any subscription to such additional shares shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ec17d8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the increase in the United States subscription to the Bank provided for in this section, there are authorized to be appropriated, without fiscal year limitation, $1,502,267,655 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ec17d8c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s51"},"text":"July 31, 1945, ch. 339, § 51","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/190/s101/i/tI"},"text":"Pub. L. 99–190, § 101(i) [title I, (a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1291"},"text":"99 Stat. 1291","children":[],"tail":", 1294.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ec17d8d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ec17d8e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ec17d8f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 51 of act ","children":[{"tag":"date","attrib":{"date":"1945-07-31"},"text":"July 31, 1945","children":[],"tail":", is based on section 301 of title III of H.R. 2253, Ninety-ninth Congress, as reported "},{"tag":"date","attrib":{"date":"1985-05-15"},"text":"May 15, 1985","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/99/190"},"text":"Pub. L. 99–190","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
