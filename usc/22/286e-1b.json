{"tag":"section","attrib":{"id":"id8ec17d4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1b"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–1b"},"text":"§ 286e–1b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in quota of United States; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ec17d50-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Fund is authorized to consent to an increase of $1,035,000,000 in the quota of the United States in the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ec17d51-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay the increase in the United States subscription to the Fund provided for in this section, there is hereby authorized to be appropriated $1,035,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ec17d52-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s20"},"text":"July 31, 1945, ch. 339, § 20","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/31"},"text":"Pub. L. 89–31","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-06-02"},"text":"June 2, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/119"},"text":"79 Stat. 119","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
