{"tag":"section","attrib":{"id":"id90e1285c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514"},"text":null,"children":[{"tag":"num","attrib":{"value":"7514"},"text":"§ 7514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90e1285d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall designate, within the Department of State, a coordinator who shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e1285e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designing an overall strategy to advance United States interests in Afghanistan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e1285f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring program and policy coordination among agencies of the United States Government in carrying out the policies set forth in this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e12860-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuing coordination with other countries and international organizations with respect to assistance to Afghanistan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e12861-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that United States assistance programs for Afghanistan are consistent with this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e12862-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring proper management, implementation, and oversight by agencies responsible for assistance programs for Afghanistan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e12863-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolving policy and program disputes among United States Government agencies with respect to United States assistance for Afghanistan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e12864-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rank and status of the coordinator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The coordinator designated under subsection (a) shall have the rank and status of ambassador.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e12865-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e12866-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The coordinator designated under subsection (a) shall annually submit the Afghanistan assistance plan of the Administration to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e12867-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e12868-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on International Relations of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e12869-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e1286a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e1286b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assistance plan submitted under paragraph (1) shall describe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e1286c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the plan relates to the strategy provided pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7554"},"text":"section 7554 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e1286d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the plan builds upon United States assistance provided to Afghanistan since 2001.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e1286e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with international community","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e1286f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The coordinator designated under subsection (a) shall work with the international community and the Government of Afghanistan to ensure that assistance to Afghanistan is implemented in a coherent, consistent, and efficient manner to prevent duplication and waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e12870-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7514/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International financial institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The coordinator designated under subsection (a), under the direction of the Secretary of State, shall work through the Secretary of the Treasury and the United States Executive Directors at the international financial institutions (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262r/c/2"},"text":"section 262r(c)(2) of this title","children":[],"tail":") to coordinate United States assistance for Afghanistan with international financial institutions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90e12871-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/327/tI/s104"},"text":"Pub. L. 107–327, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-04"},"text":"Dec. 4, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2804"},"text":"116 Stat. 2804","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVII/s7104/c/2"},"text":"Pub. L. 108–458, title VII, § 7104(c)(2)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3781"},"text":"118 Stat. 3781","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90e12872-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90e12873-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90e12874-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s7104/c/2"},"text":"Pub. L. 108–458, § 7104(c)(2)","children":[],"tail":", substituted “shall” for “is strongly urged to” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s7104/d"},"text":"Pub. L. 108–458, § 7104(d)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90e12875-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id90e12876-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90e12877-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVII/s7104/c/1"},"text":"Pub. L. 108–458, title VII, § 7104(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3781"},"text":"118 Stat. 3781","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/458/tVII/s7104/c/1"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Final Report of the National Commission on Terrorist Attacks Upon the United States criticized the provision of United States assistance to Afghanistan for being too inflexible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Afghanistan Freedom Support Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7501"},"text":"22 U.S.C. 7501","children":[],"tail":" et seq.) contains provisions that provide for flexibility in the provision of assistance for Afghanistan and are not subject to the requirements of typical foreign assistance programs and provide for the designation of a coordinator to oversee United States assistance for Afghanistan.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
