{"tag":"section","attrib":{"id":"id8f01e16e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1465d"},"text":"§ 1465d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from other government agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f01e16f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to assist the Broadcasting Board of Governors in carrying out the purposes set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1465"},"text":"section 1465 of this title","children":[],"tail":", any agency or instrumentality of the United States may sell, loan, lease, or grant property (including interests therein) and may perform administrative and technical support and services at the request of the Board. Support and services shall be provided on a reimbursable basis. Any reimbursement shall be credited to the appropriation from which the property, support, or services was derived."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f01e170-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1465d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may carry out the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1465a"},"text":"section 1465a of this title","children":[],"tail":" by means of grants, leases, or contracts (subject to the availability of appropriations), or such other means as the Board determines will be most effective."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f01e171-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/111/s6"},"text":"Pub. L. 98–111, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-10-04"},"text":"Oct. 4, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/751"},"text":"97 Stat. 751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1324(1), (2), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-781"},"text":"112 Stat. 2681–781","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f01e172-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id8f01e173-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section repealed upon transmittal of determination by President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6063/c/3"},"text":"section 6063(c)(3) of this title","children":[],"tail":" that democratically elected government in Cuba is in power, see "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6037/c"},"text":"section 6037(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f01e174-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f01e175-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Radio Broadcasting to Cuba Act which comprises this subchapter, and not as part of the United States Information and Educational Exchange Act of 1948 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f01e176-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “Broadcasting Board of Governors” for “United States Information Agency” and “Board” for “Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1324/2"},"text":"Pub. L. 105–277, § 1324(2)","children":[],"tail":", substituted “Board” for “Agency” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f045277-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id8f045278-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Broadcasting Board of Governors renamed United States Agency for Global Media pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6204/a/21"},"text":"section 6204(a)(21) of this title","children":[],"tail":". The renaming was effectuated by notice to congressional appropriations committees dated "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", and became effective "},{"tag":"date","attrib":{"date":"2018-08-22"},"text":"Aug. 22, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f045279-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
