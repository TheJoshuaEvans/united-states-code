{"tag":"section","attrib":{"id":"id8ff2d111-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2672"},"text":null,"children":[{"tag":"num","attrib":{"value":"2672"},"text":"§ 2672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in international activities; restriction; expenses","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of State is authorized to—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff2d112-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for participation by the United States in international activities which arise from time to time in the conduct of foreign affairs for which provision has not been made by the terms of any treaty, convention, or special Act of Congress: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That this subsection shall not be construed as granting authority to accept membership for the United States in any international organization, or to participate in the activities of any international organization for more than one year without approval by the Congress; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff2d113-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2672/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pay the expenses of participation in activities in which the United States participates by authority of subsection (a) of this section, including, but not limited to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff2d114-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2672/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employment of aliens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff2d115-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2672/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Travel expenses without regard to the Standardized Government Travel Regulations and to the rates of per diem allowances in lieu of subsistence expenses under subchapter I of chapter 57 of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff2d116-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2672/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Travel expenses of persons serving without compensation in an advisory capacity while away from their homes or regular places of business not in excess of those authorized for regular officers and employees traveling in connection with said international activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff2d117-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2672/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rental of quarters by contract or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff2d118-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 5, "},{"tag":"ref","attrib":{"href":"/us/stat/70/891"},"text":"70 Stat. 891","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/a"},"text":"Pub. L. 97–241, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/282"},"text":"96 Stat. 282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff2d119-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff2d11a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ff2d11b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(2), “subchapter I of chapter 57 of title 5” substituted for “the Travel Expense Act of 1949, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s835–842"},"text":"5 U.S.C. 835–842","children":[],"tail":"),” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s170j"},"text":"section 170j of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
