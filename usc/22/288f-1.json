{"tag":"section","attrib":{"id":"id8ed97199-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s288f–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"288f–1"},"text":"§ 288f–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" European Space Agency and Organization of Eastern Caribbean States; extension of privileges, exemptions, and immunities to members","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this subchapter may be extended to the European Space Agency and to the Organization of Eastern Caribbean States (including any office established in the United States by that organization) in the same manner, to the same extent, and subject to the same conditions, as they may be extended to a public international organization in which the United States participates pursuant to any treaty or under the authority of any Act of Congress authorizing such participation or making an appropriation for such participation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ed9719a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-12-29/ch652"},"text":"Dec. 29, 1945, ch. 652","children":[],"tail":", title I, § 11, as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/353"},"text":"Pub. L. 89–353","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-02-02"},"text":"Feb. 2, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/5"},"text":"80 Stat. 5","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/164/tI/s120"},"text":"Pub. L. 98–164, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1023"},"text":"97 Stat. 1023","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/362"},"text":"Pub. L. 100–362","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-06"},"text":"July 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/819"},"text":"102 Stat. 819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ed9719b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ed9719c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ed9719d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-12-29/ch652"},"text":"act Dec. 29, 1945, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/669"},"text":"59 Stat. 669","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s288"},"text":"section 288 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ed9719e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/362"},"text":"Pub. L. 100–362","children":[],"tail":" inserted “and to the Organization of Eastern Caribbean States (including any office established in the United States by that organization)” after “European Space Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164"},"text":"Pub. L. 98–164","children":[],"tail":" substituted “Space Agency” for “Space Research Organization”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8ed9719f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ed971a0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For executive orders designating certain international organizations as public international organizations entitled to enjoy the privileges, exemptions, and immunities conferred by the International Organizations Immunities Act (this subchapter), see notes set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s288"},"text":"section 288 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
