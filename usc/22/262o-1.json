{"tag":"section","attrib":{"id":"id8e969c7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"262o–1"},"text":"§ 262o–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military spending by recipient countries; military involvement in economies of recipient countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e969c80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of commitment to achieving certain goals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e990d81-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002008"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002008"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" In general"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Directors of the international financial institutions (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262r/c/2"},"text":"section 262r(c)(2) of this title","children":[],"tail":") to promote growth in the international economy by taking into account, when considering whether to support or oppose loan proposals at these institutions, the extent to which the recipient government has demonstrated a commitment to achieving the following goals:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e990d82-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o–1/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide accurate and complete data on the annual expenditures and receipts of the armed forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e990d83-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o–1/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish good and publicly accountable governance, including an end to excessive military involvement in the economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e990d84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o–1/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make substantial reductions in excessive military spending and forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e990d85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Steps to achieve goals required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Directors of the international financial institutions (as so defined) to promote a policy at each institution under which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e990d86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the respective institution monitors closely and, through regular policy consultations with recipient governments, seeks to influence the composition of public expenditure in favor of funding growth and development priorities and away from unproductive expenditure, including excessive military expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e990d87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the respective institution supports lending operations which assist efforts of recipient governments to promote good governance, including public participation, and reduce military expenditures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e990d88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allocation of resources and the extension of credit by the respective institution takes into account the performance of recipient governments in the areas of good governance, ending excessive military involvement in the economy and reducing excessive military expenditures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e990d89-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXV/s1502"},"text":"Pub. L. 95–118, title XV, § 1502","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/306/tV/s526/d"},"text":"Pub. L. 103–306, title V, § 526(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1633"},"text":"108 Stat. 1633","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e990d8a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e990d8b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8e990d8c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–5"},"text":"section 262p–5 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
