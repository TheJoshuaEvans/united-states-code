{"tag":"section","attrib":{"id":"id90843bc4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4862"},"text":null,"children":[{"tag":"num","attrib":{"value":"4862"},"text":"§ 4862.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds for facilities in Israel, Jerusalem, or West Bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"None of the funds authorized to be appropriated by this Act may be obligated or expended for site acquisition, development, or construction of any facility in Israel, Jerusalem, or the West Bank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90843bc5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIV/s414"},"text":"Pub. L. 99–399, title IV, § 414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/868"},"text":"100 Stat. 868","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90843bc6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90843bc7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90843bc8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399"},"text":"Pub. L. 99–399","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":",