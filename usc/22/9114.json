{"tag":"section","attrib":{"id":"id911cd1d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9114"},"text":null,"children":[{"tag":"num","attrib":{"value":"9114"},"text":"§ 9114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to congressional representatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911cd1d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall submit written notification to the Member of Congress and Senators, or Resident Commissioner or Delegate, as appropriate, representing the legal residence of a left-behind parent if such parent—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd1d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports an abduction to the Central Authority of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consents to such notification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911cd1d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of any person who is a left-behind parent, including a left-behind parent who previously reported an abduction to the Central Authority of the United States before ","children":[{"tag":"date","attrib":{"date":"2014-08-08"},"text":"August 8, 2014","children":[],"tail":", the notification required under subsection (a) shall be provided as soon as is practicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911cd1d7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150/tI/s104"},"text":"Pub. L. 113–150, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1816"},"text":"128 Stat. 1816","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
