{"tag":"section","attrib":{"id":"id90acab67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202"},"text":null,"children":[{"tag":"num","attrib":{"value":"6202"},"text":"§ 6202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and principles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90acab68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadcasting standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"United States international broadcasting shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90acab69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with the broad foreign policy objectives of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with the international telecommunications policies and treaty obligations of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab6b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not duplicate the activities of private United States broadcasters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab6c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not duplicate the activities of government supported broadcasting entities of other democratic nations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab6d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be conducted in accordance with the highest professional standards of broadcast journalism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab6e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be based on reliable information about its potential audience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab6f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designed so as to effectively reach a significant audience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote respect for human rights, including freedom of religion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90acab71-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadcasting principles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"United States international broadcasting shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90acab72-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" news which is consistently reliable and authoritative, accurate, objective, and comprehensive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a balanced and comprehensive projection of United States thought and institutions, reflecting the diversity of United States culture and society;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab74-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clear and effective presentation of the policies of the United States Government and responsible discussion and opinion on those policies, including editorials, broadcast by the Voice of America, which present the views of the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab75-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability to provide a surge capacity to support United States foreign policy objectives during crises abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab76-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programming to meet needs which remain unserved by the totality of media voices available to the people of certain nations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about developments in each significant region of the world;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a variety of opinions and voices from within particular nations and regions prevented by censorship or repression from speaking to their fellow countrymen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reliable research capacity to meet the criteria under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab7a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate transmitter and relay capacity to support the activities described in this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and technical support for independent indigenous media through government agencies or private United States entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90acab7c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voice of America broadcasts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The long-range interests of the United States are served by communicating directly with the peoples of the world by radio. To be effective, the Voice of America must win the attention and respect of listeners. These principles will therefore govern Voice of America (VOA) broadcasts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90acab7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" VOA will serve as a consistently reliable and authoritative source of news. VOA news will be accurate, objective, and comprehensive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" VOA will represent America, not any single segment of American society, and will therefore present a balanced and comprehensive projection of significant American thought and institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6202/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" VOA will present the policies of the United States clearly and effectively, and will also present responsible discussions and opinion on these policies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90acab80-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tIII/s303"},"text":"Pub. L. 103–236, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/433"},"text":"108 Stat. 433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/p"},"text":"Pub. L. 103–415, § 1(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4301"},"text":"108 Stat. 4301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1323(d), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-778"},"text":"112 Stat. 2681–778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/292/tV/s502"},"text":"Pub. L. 105–292, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2811"},"text":"112 Stat. 2811","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1299Q/b"},"text":"Pub. L. 116–283, div. A, title XII, § 1299Q(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4021"},"text":"134 Stat. 4021","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90acab81-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90acab82-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90acab83-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1299Q/b"},"text":"Pub. L. 116–283, div. A, title XII, § 1299Q(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4021"},"text":"134 Stat. 4021","children":[],"tail":", which directed amendment of this section and was not executed, was itself amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tXIII/s1301"},"text":"Pub. L. 116–260, div. O, title XIII, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2158"},"text":"134 Stat. 2158","children":[],"tail":", to make it effective 90 days after "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":". However, the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" could not be executed because it was enacted before the provision from "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" that it amended."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90acab84-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/b/1"},"text":"Pub. L. 116–283, § 1299Q(b)(1)","children":[],"tail":", which directed insertion of “, including editorial independence” in subsec. (a) “before the semicolon at the end”, was not executed because subsec. (a) contains 6 pars. that have a semicolon at the end and the probable intent of Congress could not be determined."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/b/2"},"text":"Pub. L. 116–283, § 1299Q(b)(2)","children":[],"tail":", which directed amendment of subsec. (b) by inserting “, including editorial independence,” after “programing”, was not executed because the word “programing” did not appear and the word “programming” at the beginning of par. (5) could not be clearly identified as the intended target."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292"},"text":"Pub. L. 105–292","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1323/d/1"},"text":"Pub. L. 105–277, § 1323(d)(1)","children":[],"tail":", which directed amendment of par. (3) by inserting “, including editorials, broadcast by the Voice of America, which present the views of the United States Government” after “policies”, was executed by making insertion after “policies” the second time it appears to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1323/d/2"},"text":"Pub. L. 105–277, § 1323(d)(2)","children":[],"tail":", (3), added par. (4) and redesignated former pars. (4) to (9) as (5) to (10), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/415"},"text":"Pub. L. 103–415","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90acab85-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90acab86-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90acab87-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Broadcasting Information on States","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXIV, § 2420, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-835"},"text":"112 Stat. 2681–835","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dG"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Voice of America shall devote programming each day to broadcasting information on the individual States of the United States. The broadcasts shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the products, tourism, and cultural and educational facilities of each State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the potential for trade with each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discussions with State officials with respect to the matters described in paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":"], the Broadcasting Board of Governors of the United States Information Agency shall submit a report to Congress detailing the actions that have been taken to carry out subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘State’ means any of the several States of the United States, the District of Columbia, or any commonwealth or territory of the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
