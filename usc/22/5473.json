{"tag":"section","attrib":{"id":"id908db260-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5473"},"text":null,"children":[{"tag":"num","attrib":{"value":"5473"},"text":"§ 5473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on environmental problems in Poland and Hungary","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The first report submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5474"},"text":"section 5474 of this title","children":[],"tail":" shall include the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db261-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5473/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of problems","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An overall assessment of the environmental problems facing Poland and Hungary, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id908db262-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5473/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a relative ranking of the severity of the problems and their effects on both human health and the general environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908db263-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5473/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a listing of the geographical areas of each country that have suffered the heaviest environmental damage, and a description of the source and scope of the damage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908db264-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5473/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the environmental performance of leading industrial polluters in those countries and the expected effect on pollution levels of industrial modernization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db265-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5473/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities and costs for action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An analysis of the priorities that Poland and Hungary should each assign in addressing its environmental problems, and an estimate of the capital and human resources required to undertake a comprehensive program of environmental protection in that country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db266-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5473/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of United States and multilateral assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A statement of strategy for United States assistance for the next 5 years to address environmental problems in Poland and Hungary, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id908db267-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5473/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for appropriate levels and forms of bilateral financial and technical assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908db268-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5473/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations concerning United States participation in cooperative multilateral undertakings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908db269-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5473/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the feasibility of debt-for-nature swaps as a technique of environmental protection in each country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908db26a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5473/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for minimizing further environmental damage to Krakow, and for the protection and restoration of historic sites in that city.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908db26b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tVII/s703"},"text":"Pub. L. 101–179, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1321"},"text":"103 Stat. 1321","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
