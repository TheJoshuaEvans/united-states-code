{"tag":"section","attrib":{"id":"id8ed24568-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"287b–1"},"text":"§ 287b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional report on other United States contributions to the United Nations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ed24569-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", and annually thereafter, the Director of the Office of Management and Budget shall submit to Congress a report on all assessed and voluntary contributions with a value greater than $100,000, including in-kind, of the United States Government to the United Nations and its affiliated agencies and related bodies during the previous fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ed2456a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under subsection (a) shall include the following elements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ed2456b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287b–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of all assessed and voluntary contributions, including in-kind, of the United States Government to the United Nations and its affiliated agencies and related bodies during the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ed2456c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287b–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The approximate percentage of United States Government contributions to each United Nations affiliated agency or body in such fiscal year when compared with all contributions to each such agency or body from any source in such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ed2456d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287b–1/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each such United States Government contribution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ed2456e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287b–1/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of each such contribution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ed2456f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287b–1/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of each such contribution (including whether assessed or voluntary);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ed24570-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287b–1/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the department or agency of the United States Government responsible for each such contribution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ed24571-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287b–1/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose of each such contribution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ed24572-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287b–1/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United Nations or its affiliated agency or related body receiving the contribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ed24573-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287b–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope of initial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first report required under subsection (a) shall include the information required under this section for the previous 3 fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ed24574-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287b–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 14 days after submitting a report required under subsection (a), the Director of the Office of Management and Budget shall post a public version of such report on a text-based, searchable, and publicly available Internet Web site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ed24575-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/tIII/s312"},"text":"Pub. L. 114–323, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1925"},"text":"130 Stat. 1925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ed24576-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ed24577-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ed24578-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of State Authorities Act, Fiscal Year 2017, and not as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-12-20/ch583"},"text":"act Dec. 20, 1945, ch. 583","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/619"},"text":"59 Stat. 619","children":[],"tail":", known as the United Nations Participation Act of 1945, which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
