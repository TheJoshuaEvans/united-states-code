{"tag":"section","attrib":{"id":"id914c6e1e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808"},"text":null,"children":[{"tag":"num","attrib":{"value":"9808"},"text":"§ 9808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id914c6e1f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention and Stabilization Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914c6e20-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund, which shall be known as the “Prevention and Stabilization Fund” (in this subsection referred to as “The Fund”), to be administered by the Department of State and USAID, as appropriate, to support stabilization of conflict-affected areas and to mitigate fragility, including through the Global Fragility Strategy established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9803"},"text":"section 9803 of this title","children":[],"tail":", which shall replace the Relief and Recovery Fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6e21-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Fund $200,000,000 for each of the fiscal years 2020 through 2024.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6e22-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of the Fund","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914c6e23-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts authorized to be appropriated to the Fund shall be used—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id914c6e24-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support stabilization of conflict-affected areas and prevent global fragility, including through the Global Fragility Strategy established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9803"},"text":"section 9803 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id914c6e25-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance to areas liberated or at risk from, or under the control of, the Islamic State of Iraq and Syria, other terrorist organizations, or violent extremist organizations, including for stabilization assistance for vulnerable ethnic and religious minority communities affected by conflict.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6e26-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts in addition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts authorized to be appropriated to the Fund under this section are in addition to any funds otherwise made available for the purposes described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6e27-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds may not be obligated under this section unless the congressional committees specified in section 634A of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394–1"},"text":"22 U.S.C. 2394–1","children":[],"tail":") are notified of the amount and nature of such proposed obligation at least 15 days in advance of such proposed obligation, in accordance with the procedures applicable to notifications regarding reprogrammings pursuant to such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914c6e28-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complex Crisis Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914c6e29-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund, which shall be known as the “Complex Crises Fund” (in this subsection referred to as the “Fund”), to be administered by USAID, to support programs and activities to prevent or respond to emerging or unforeseen events overseas, including to support the Global Fragility Strategy established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9803"},"text":"section 9803 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6e2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Fund $30,000,000 for each of the fiscal years 2020 through 2024, which shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6e2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of the Fund","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914c6e2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, except section 620M of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2378d"},"text":"22 U.S.C. 2378d","children":[],"tail":"), amounts in the Fund may be used to carry out the provisions of the Foreign Assistance Act of 1961 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.) to support programs and activities to prevent or respond to emerging or unforeseen foreign challenges and complex crises overseas, including through the Global Fragility Strategy established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9803"},"text":"section 9803 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6e2d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts in addition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts authorized to be appropriated to the Fund are in addition to any amounts otherwise made available for the purposes described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6e2e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914c6e2f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund may not be expended for lethal assistance or to respond to natural disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914c6e30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than five percent of the amounts in the Fund may be used for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6e31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Agency for International Development shall notify the appropriate congressional committees not less than five days prior to the obligation of amounts in the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6e32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notification requirement under paragraph (5) may be waived if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914ede33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notification by the deadline specified in such paragraph would pose a substantial risk to human health or welfare; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914ede34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the appropriate congressional committees—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id914ede35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are notified as early as practicable but in no event later than three days after an obligation of amounts from the Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id914ede36-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9808/b/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are provided with an explanation of the emergency circumstances that necessitated such waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914ede37-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tV/s509"},"text":"Pub. L. 116–94, div. J, title V, § 509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3066"},"text":"133 Stat. 3066","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id914ede38-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id914ede39-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id914ede3a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (b)(3)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
