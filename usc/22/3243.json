{"tag":"section","attrib":{"id":"id9030c403-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3243"},"text":null,"children":[{"tag":"num","attrib":{"value":"3243"},"text":"§ 3243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The United States shall seek to negotiate with other nations and groups of nations to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9030c404-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3243/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt general principles and procedures, including common international sanctions, to be followed in the event that a nation violates any material obligation with respect to the peaceful use of nuclear materials and equipment or nuclear technology, or in the event that any nation violates the principles of the Treaty, including the detonation by a non-­nuclear-weapon state of a nuclear explosive device; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9030c405-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3243/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish international procedures to be followed in the event of diversion, theft, or sabotage of nuclear materials or sabotage of nuclear facilities, and for recovering nuclear materials that have been lost or stolen, or obtained or used by a nation or by any person or group in contravention of the principles of the Treaty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9030c406-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/242/tII/s203"},"text":"Pub. L. 95–242, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-10"},"text":"Mar. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/124"},"text":"92 Stat. 124","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9030c407-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9030c408-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id9030c409-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-03-10"},"text":"Mar. 10, 1978","children":[],"tail":", except as otherwise provided and regardless of any requirements for the promulgation of implementing regulations, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/242/s603/c"},"text":"section 603(c) of Pub. L. 95–242","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3201"},"text":"section 3201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
