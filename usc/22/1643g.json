{"tag":"section","attrib":{"id":"id8f14f48d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1643g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1643g"},"text":"§ 1643g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall transfer or otherwise make available to the Commission such records and documents relating to claims authorized by this subchapter as may be required by the Commission in carrying out its functions under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f14f48e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title V, § 508, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/666"},"text":"Pub. L. 88–666","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-16"},"text":"Oct. 16, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1112"},"text":"78 Stat. 1112","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
