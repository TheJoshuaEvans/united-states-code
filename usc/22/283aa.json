{"tag":"section","attrib":{"id":"id8eba5171-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"283aa"},"text":"§ 283aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is hereby authorized to accept membership for the United States in the Inter-American Investment Corporation (hereinafter in this subchapter referred to as the “Corporation”) provided for by the agreement establishing the Corporation (hereinafter in this subchapter referred to as the “agreement”) deposited in the archives of the Inter-American Development Bank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eba5172-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s101/1/tI"},"text":"Pub. L. 98–473, title I, § 101(1) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1884"},"text":"98 Stat. 1884","children":[],"tail":", 1885.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eba5173-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eba5174-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8eba5175-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 202 of title II of S. 2416, Ninety-eighth Congress, as introduced ","children":[{"tag":"date","attrib":{"date":"1984-03-13"},"text":"Mar. 13, 1984","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eba5176-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id8eba5177-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 201 of title II of S. 2416, as introduced in the Senate ","children":[{"tag":"date","attrib":{"date":"1984-03-13"},"text":"Mar. 13, 1984","children":[],"tail":", and as enacted into permanent law by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s101/1/tI"},"text":"Pub. L. 98–473, title I, § 101(1) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1885"},"text":"98 Stat. 1885","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/473/tI/s101/1/tI"},"text":"“This title [enacting this subchapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s276c–2"},"text":"section 276c–2 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s24"},"text":"section 24 of Title 12","children":[],"tail":", Banks and Banking] may be cited as the ‘Inter-American Investment Corporation Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
