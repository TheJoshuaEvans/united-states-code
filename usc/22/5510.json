{"tag":"section","attrib":{"id":"id909022e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5510"},"text":null,"children":[{"tag":"num","attrib":{"value":"5510"},"text":"§ 5510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Government compensation for victims of terrorism","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id909022e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall submit to the Congress, not later than one year after ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":", recommendations on whether or not legislation should be enacted to authorize the United States to provide monetary and tax relief as compensation to United States citizens who are victims of terrorism."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id909022e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may establish a board to develop criteria for compensation and to recommend changes to existing laws to establish a single comprehensive approach to victim compensation for terrorist acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id909022e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5510/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income tax benefit for victims of Lockerbie terrorism","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id909022e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5510/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), in the case of any individual whose death was a direct result of the Pan American Airways Flight 103 terrorist disaster over Lockerbie, Scotland, on ","children":[{"tag":"date","attrib":{"date":"1988-12-21"},"text":"December 21, 1988","children":[],"tail":", any tax imposed by subtitle A of title 26 shall not apply—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id909022e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5510/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the taxable year which includes ","children":[{"tag":"date","attrib":{"date":"1988-12-21"},"text":"December 21, 1988","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id909022ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5510/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the prior taxable year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id909022eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5510/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no case may the tax benefit pursuant to paragraph (1) for any taxable year, for any individual, exceed an amount equal to 28 percent of the annual rate of basic pay at Level V of the Executive Schedule of the United States as of ","children":[{"tag":"date","attrib":{"date":"1988-12-21"},"text":"December 21, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id909022ec-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/604/tII/s211"},"text":"Pub. L. 101–604, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3085"},"text":"104 Stat. 3085","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id909022ed-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id909022ee-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id909022ef-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level V of the Executive Schedule, referred to in subsec. (c)(2), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5316"},"text":"section 5316 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
