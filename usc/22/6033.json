{"tag":"section","attrib":{"id":"id90a7f02f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6033"},"text":null,"children":[{"tag":"num","attrib":{"value":"6033"},"text":"§ 6033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against indirect financing of Cuba","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90a7f030-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6033/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no loan, credit, or other financing may be extended knowingly by a United States national, a permanent resident alien, or a United States agency to any person for the purpose of financing transactions involving any confiscated property the claim to which is owned by a United States national as of ","children":[{"tag":"date","attrib":{"date":"1996-03-12"},"text":"March 12, 1996","children":[],"tail":", except for financing by the United States national owning such claim for a transaction permitted under United States law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a7f031-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6033/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension and termination of prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a7f032-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6033/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to suspend the prohibition contained in subsection (a) upon a determination made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6063/c/1"},"text":"section 6063(c)(1) of this title","children":[],"tail":" that a transition government in Cuba is in power."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a7f033-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6033/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibition contained in subsection (a) shall cease to apply on the date on which the economic embargo of Cuba terminates as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6064"},"text":"section 6064 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a7f034-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6033/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Violations of subsection (a) shall be punishable by such civil penalties as are applicable to violations of the Cuban Assets Control Regulations set forth in part 515 of title 31, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a7f035-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6033/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a7f036-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6033/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “permanent resident alien” means an alien lawfully admitted for permanent residence into the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a7f037-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6033/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “United States agency” has the meaning given the term “agency” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/1"},"text":"section 551(1) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90a7f038-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114/tI/s103"},"text":"Pub. L. 104–114, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/794"},"text":"110 Stat. 794","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
