{"tag":"section","attrib":{"id":"id910e7a0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741"},"text":null,"children":[{"tag":"num","attrib":{"value":"8741"},"text":"§ 8741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of, and imposition of sanctions with respect to, officials, agents, and affiliates of Iran’s Revolutionary Guard Corps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id910e7a0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", and as appropriate thereafter, the President shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7a0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify foreign persons that are officials, agents, or affiliates of Iran’s Revolutionary Guard Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each foreign person identified under paragraph (1) that is not already designated for the imposition of sanctions pursuant to the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e7a0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate that foreign person for the imposition of sanctions pursuant to that Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7a10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" block and prohibit all transactions in all property and interests in property of that foreign person if such property and interests in property are in the United States, come within the United States, or are or come within the possession or control of a United States person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7a11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for investigation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In identifying foreign persons pursuant to subsection (a)(1) as officials, agents, or affiliates of Iran’s Revolutionary Guard Corps, the President shall give priority to investigating—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7a12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign persons or entities identified under section 560.304 of title 31, Code of Federal Regulations (relating to the definition of the Government of Iran); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign persons for which there is a reasonable basis to find that the person has conducted or attempted to conduct one or more sensitive transactions or activities described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7a14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sensitive transactions and activities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A sensitive transaction or activity described in this subsection is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7a15-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial transaction or series of transactions valued at more than $1,000,000 in the aggregate in any 12-month period involving a non-Iranian financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a16-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transaction to facilitate the manufacture, importation, exportation, or transfer of items needed for the development by Iran of nuclear, chemical, biological, or advanced conventional weapons, including ballistic missiles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a17-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transaction relating to the manufacture, procurement, or sale of goods, services, and technology relating to Iran’s energy sector, including a transaction relating to the development of the energy resources of Iran, the exportation of petroleum products from Iran, the importation of refined petroleum to Iran, or the development of refining capacity available to Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a18-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transaction relating to the manufacture, procurement, or sale of goods, services, and technology relating to Iran’s petrochemical sector; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a19-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transaction relating to the procurement of sensitive technologies (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8515/c"},"text":"section 8515(c) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7a1a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from United States","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7a1b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary of State shall deny a visa to, and the Secretary of Homeland Security shall exclude from the United States, any alien who, on or after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", is a foreign person designated pursuant to subsection (a) for the imposition of sanctions pursuant to the International Emergency Economic Powers Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a1c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory exceptions to comply with international obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirement to deny visas to and exclude aliens from the United States pursuant to paragraph (1) shall be subject to such regulations as the President may prescribe, including regulatory exceptions to permit the United States to comply with the Agreement between the United Nations and the United States of America regarding the Headquarters of the United Nations, signed ","children":[{"tag":"date","attrib":{"date":"1947-06-26"},"text":"June 26, 1947","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1947-11-21"},"text":"November 21, 1947","children":[],"tail":", and other applicable international obligations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7a1d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of imposition of sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910e7a1e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may waive the application of subsection (a) or (d) with respect to a foreign person if the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910e7a1f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that it is vital to the national security interests of the United States to do so; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910e7a20-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submits to the appropriate congressional committees a report that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id910e7a21-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the foreign person with respect to which the waiver applies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910e7a22-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth the reasons for the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910e7a23-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A report submitted under paragraph (1)(B) shall be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910e7a24-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8741/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to remove any sanction of the United States in force with respect to Iran’s Revolutionary Guard Corps as of ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910e7a25-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158/tIII/s301"},"text":"Pub. L. 112–158, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1241"},"text":"126 Stat. 1241","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id910e7a26-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id910e7a27-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8785/a"},"text":"section 8785(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id910e7a28-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id910e7a29-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsecs. (a)(2) and (d)(1), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
