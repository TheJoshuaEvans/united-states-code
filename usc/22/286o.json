{"tag":"section","attrib":{"id":"id8ec65f3b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286o"},"text":null,"children":[{"tag":"num","attrib":{"value":"286o"},"text":"§ 286o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration as part of the Exchange Stabilization Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ec65f3c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Drawing Rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Special Drawing Rights allocated to the United States pursuant to article XVIII of the Articles of Agreement of the Fund, and Special Drawing Rights otherwise acquired by the United States, shall be credited to the account of, and administered as part of, the Exchange Stabilization Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5302"},"text":"section 5302 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ec65f3d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit in and withdrawal from Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proceeds resulting from the use of Special Drawing Rights by the United States, and payments of interest to the United States pursuant to article XX, article XXIV, and article XXV of the Articles of Agreement of the Fund, shall be deposited in the Exchange Stabilization Fund. Currency payments by the United States in return for Special Drawing Rights, and payments of charges or assessments pursuant to article XX, article XXIV, and article XXV of the Articles of Agreement of the Fund, shall be made from the resources of the Exchange Stabilization Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ec65f3e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/349/s3"},"text":"Pub. L. 90–349, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/188"},"text":"82 Stat. 188","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/564/s5/1"},"text":"Pub. L. 94–564, § 5(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2661"},"text":"90 Stat. 2661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ec65f3f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ec65f40-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ec65f41-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5302"},"text":"section 5302 of title 31","children":[],"tail":"” substituted for “section 10 of the Gold Reserve Act of 1934, as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s822a"},"text":"31 U.S.C. 822a","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339"},"text":"act July 31, 1945, ch. 339","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/512"},"text":"59 Stat. 512","children":[],"tail":", known as the Bretton Woods Agreement Act, which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ec65f42-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/564/s5/1"},"text":"Pub. L. 94–564, § 5(1)","children":[],"tail":", substituted “article XVIII” for “article XXIV”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/564/s5/2"},"text":"Pub. L. 94–564, § 5(2)","children":[],"tail":", substituted “article XX, article XXIV, and XXV” for “article XXVI, article XXX, and article XXXI” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ec65f43-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ec65f44-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","att