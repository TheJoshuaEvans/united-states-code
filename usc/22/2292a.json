{"tag":"section","attrib":{"id":"id8f803947-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2292a"},"text":"§ 2292a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f803948-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the President to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292"},"text":"section 2292 of this title","children":[],"tail":", $3,905,460,000 for each of the fiscal years 2024 through 2028, of which up to $1,757,457,000 should be made available to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292/c"},"text":"section 2292(c) of this title","children":[],"tail":". Amounts appropriated under this section are authorized to remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f803949-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent appropriations for reimbursement of additional fiscal year obligations charged against appropriation account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available to carry out this part, up to $50,000,000 in any fiscal year may be obligated against appropriations under subchapter I of this chapter (other than this part) for use in providing assistance in accordance with the authorities and general policies of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292"},"text":"section 2292 of this title","children":[],"tail":". Amounts subsequently appropriated under this part with respect to a disaster may be used to reimburse any appropriation account against which obligations were incurred under this subsection with respect to that disaster."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f80394a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts in addition to other amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts authorized to be appropriated pursuant to the authorizations of appropriations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292/c"},"text":"section 2292(c) of this title","children":[],"tail":" are in addition to funds otherwise available for such purposes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f80394b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f80394c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the policy of the United States that the funds made available to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292"},"text":"section 2292 of this title","children":[],"tail":" are intended to provide the President with the greatest possible flexibility to address disaster-related needs as they arise and to prepare for and reduce the impact of natural and man-made disasters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f80394d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that any amendments to applicable legal provisions contained in this chapter are not intended to limit such authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f80394e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2292a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than March 1 of each fiscal year, the President shall submit to the Committee on Foreign Relations and the Committee on Appropriations of the Senate and the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives a report that describes the activities undertaken by the President over the course of the prior fiscal year pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292/c"},"text":"section 2292(c) of this title","children":[],"tail":", including the amounts of assistance provided, intended beneficiaries, monitoring and evaluation strategies, anticipated outcomes, and, as practicable, actual outcomes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f80394f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 492, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/tI/s101/3"},"text":"Pub. L. 94–161, title I, § 101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/849"},"text":"89 Stat. 849","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/88/tI/s119"},"text":"Pub. L. 95–88, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/541"},"text":"91 Stat. 541","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/tI/s118/b"},"text":"Pub. L. 95–424, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/953"},"text":"92 Stat. 953","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/tI/s115"},"text":"Pub. L. 96–53, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/365"},"text":"93 Stat. 365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/533/tIV"},"text":"Pub. L. 96–533, title IV","children":[],"tail":", §§ 403, 404(a), "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3150"},"text":"94 Stat. 3150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tV/s503"},"text":"Pub. L. 97–113, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1539"},"text":"95 Stat. 1539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tIV/s404"},"text":"Pub. L. 99–83, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/219"},"text":"99 Stat. 219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/195/s7/c/2"},"text":"Pub. L. 114–195, § 7(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-20"},"text":"July 20, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/681"},"text":"130 Stat. 681","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/266/s2/b"},"text":"Pub. L. 115–266, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-11"},"text":"Oct. 11, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3755"},"text":"132 Stat. 3755","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5588/g/2"},"text":"Pub. L. 117–263, div. E, title LV, § 5588(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3379"},"text":"136 Stat. 3379","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f803950-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f803951-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f803952-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d)(2), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", known as the Foreign Assistance Act of 1961. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f803953-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “$3,905,460,000 for each of the fiscal years 2024 through 2028, of which up to $1,757,457,000” for “$2,794,184,000 for each of fiscal years 2017 through 2023, of which up to $1,257,382,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/266"},"text":"Pub. L. 115–266","children":[],"tail":" substituted “fiscal years 2017 through 2023” for “fiscal years 2017 and 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/195/s7/c/2/A"},"text":"Pub. L. 114–195, § 7(c)(2)(A)","children":[],"tail":", which directed substitution of “$2,794,184,000 for each of fiscal years 2017 and 2018, of which up to $1,257,382,000 should be made available to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292/c"},"text":"section 2292(c) of this title","children":[],"tail":".” for “$25,000,000 for the fiscal year 1986 and $25,000,000 for the fiscal year 1987.”, was executed by making the substitution for “$25,000,000 for fiscal year 1986 and $25,000,000 for fiscal year 1987.” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/195/s7/c/2/B"},"text":"Pub. L. 114–195, § 7(c)(2)(B)","children":[],"tail":", added subsecs. (c) to (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" substituted provisions authorizing appropriations of $25,000,000 for fiscal years 1986 and 1987, for provisions authorizing appropriations of $27,000,000 for fiscal years 1982 and 1983."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113"},"text":"Pub. L. 97–113","children":[],"tail":" substituted appropriations authorization of $27,000,000 for fiscal years 1982 and 1983, for appropriation of $25,000,000 for fiscal year 1981."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/533"},"text":"Pub. L. 96–533","children":[],"tail":", §§ 403, 404(a)(1), substituted appropriations authorization of “$25,000,000 for the fiscal year 1981” for such authorization of “$21,800,000 for the fiscal year 1980” and designated existing provisions as subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/533/s404/a/2"},"text":"Pub. L. 96–533, § 404(a)(2)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":" substituted “$21,800,000” for “$25,000,000” and “1980” for “1979”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" substituted “the fiscal year 1979” for “each of the fiscal years 1977 and 1978” and struck out provision requiring the President to submit quarterly reports to the Committee on Foreign Relations of the Senate and to the Speaker of the House of Representatives on the programming and obligation of funds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88"},"text":"Pub. L. 95–88","children":[],"tail":" substituted “fiscal years 1977 and 1978” for “fiscal years 1976 and 1977”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f803954-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f803955-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Subchapter I Deemed To Include Certain Parts of Subchapter II","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to subchapter I of this chapter are deemed to include parts IV (§ 2346 et seq.), VI (§ 2348 et seq.), and VIII (§ 2349aa et seq.) of subchapter II of this chapter, and references to subchapter II are deemed to exclude such parts. See ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226/s202/b"},"text":"section 202(b) of Pub. L. 92–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"section 2346 of this title","children":[],"tail":", and sections 2348c and 2349aa–5 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfA