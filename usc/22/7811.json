{"tag":"section","attrib":{"id":"id90ef8011-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7811"},"text":null,"children":[{"tag":"num","attrib":{"value":"7811"},"text":"§ 7811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress regarding negotiations with North Korea","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the human rights of North Koreans should remain a key element in future negotiations between the United States, North Korea, and other concerned parties in Northeast Asia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90ef8012-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/333/tI/s101"},"text":"Pub. L. 108–333, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1290"},"text":"118 Stat. 1290","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
