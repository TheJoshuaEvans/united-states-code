55","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/dH/tVII/s7027"},"text":"Pub. L. 111–8, div. H, title VII, § 7027","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/871"},"text":"123 Stat. 871","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dJ/tVI/s628"},"text":"Pub. L. 110–161, div. J, title VI, § 628","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2325"},"text":"121 Stat. 2325","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/102/tV/s529"},"text":"Pub. L. 109–102, title V, § 529","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-14"},"text":"Nov. 14, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2206"},"text":"119 Stat. 2206","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dD/tV/s529"},"text":"Pub. L. 108–447, div. D, title V, § 529","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3003"},"text":"118 Stat. 3003","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tV/s529"},"text":"Pub. L. 108–199, div. D, title V, § 529","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/178"},"text":"118 Stat. 178","children":[],"tail":"."}],"tail":"\n"},{"tag":"