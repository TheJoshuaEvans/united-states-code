11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f9ce86a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f9ce86b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (b), and (d), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", known as the Foreign Assistance Act of 1961. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Mutual Security Act of 1954, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-26/ch937"},"text":"act Aug. 26, 1954, ch. 937","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/832"},"text":"68 Stat. 832","children":[],"tail":", as amended by acts "},{"tag":"ref","attrib":{"href":"/us/act/1955-07-08/ch301"},"text":"July 8, 1955, ch. 301","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/283"},"text":"69 Stat. 283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-18/ch627"},"text":"July 18, 1956, ch. 627","children":[],"tail":", §§ 2 to 11, "},{"tag":"ref","attrib":{"href":"/us/stat/70/555"},"text":"70 Stat. 555","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1957-08-14"},"text":"Aug. 14, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/141"},"text":"Pub. L. 85–141","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/355"},"text":"71 Stat. 355","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1958-06-30"},"text":"June 30, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/477"},"text":"Pub. L. 85–477","children":[],"tail":", ch. 1, §§ 101 to 103, ch. II, §§ 201 to 205, ch. III, § 301, ch. IV, § 401, ch. V, § 501, "},{"tag":"ref","attrib":{"href":"/us/stat/72/261"},"text":"72 Stat. 261","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1959-07-24"},"text":"July 24, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/108/s2"},"text":"Pub. L. 86–108, § 2","children":[],"tail":", ch. 1, § 101, ch. II, §§ 201 to 205(a) to (i), (k) to (n), ch. III, § 301, ch. IV, § 401(a) to (k), (m), "},{"tag":"ref","attrib":{"href":"/us/stat/73/246"},"text":"73 Stat. 246","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1960-05-14"},"text":"May 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/472"},"text":"Pub. L. 86–472","children":[],"tail":", ch. I to V, "},{"tag":"ref","attrib":{"href":"/us/stat/74/134"},"text":"74 Stat. 134","children":[],"tail":", which was principally classified to chapter 24 (§ 1750 et seq.) of this title and which was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-18/ch627/s8/m"},"text":"act July 18, 1956, ch. 627, § 8(m)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/559"},"text":"70 Stat. 559","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/141"},"text":"Pub. L. 85–141","children":[],"tail":", §§ 2(e), 3, 4(b), 11(d), "},{"tag":"date","attrib":{"date":"1957-08-14"},"text":"Aug. 14, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/356"},"text":"71 Stat. 356","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/108"},"text":"Pub. L. 86–108","children":[],"tail":", ch. II, §§ 205(j), ch. IV, 401(1), "},{"tag":"date","attrib":{"date":"1959-07-24"},"text":"July 24, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/250"},"text":"73 Stat. 250","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/472"},"text":"Pub. L. 86–472","children":[],"tail":", ch. II, §§ 203(d), 204(k), "},{"tag":"date","attrib":{"date":"1960-05-14"},"text":"May 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/138"},"text":"74 Stat. 138","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 642(a)(2), "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/460"},"text":"75 Stat. 460","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/94/329/tII/s212/b/1"},"text":"Pub. L. 94–329, title II, § 212(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/745"},"text":"90 Stat. 745","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s228"},"text":"Pub. L. 104–127, title II, § 228","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/963"},"text":"110 Stat. 963","children":[],"tail":", except for sections 1754, 1783, 1796, 1853, 1928, and 1937 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1754"},"text":"section 1754 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Food for Peace Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"act July 10, 1954, ch. 469","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/454"},"text":"68 Stat. 454","children":[],"tail":", which is classified principally to chapter 41 (§ 1691 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f9ce86c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" substituted “Food for Peace Act” for “Agricultural Trade Development and Assistance Act of 1954”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/175"},"text":"Pub. L. 91–175","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/583"},"text":"Pub. L. 89–583","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/171"},"text":"Pub. L. 89–171","children":[],"tail":" redesignated subsec. (c) as (b) and prohibited dollar funds made available pursuant to this chapter from being expended for goods and services when United States-owned foreign currencies are available for such purposes unless the administrative official approving the voucher certifies as to the reason for the use of dollars in each case."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/638"},"text":"Pub. L. 88–638","children":[],"tail":" redesignated subsec. (b), as added by "},{"tag":"ref","attrib":{"href":"/us/pl/88/205"},"text":"Pub. L. 88–205","children":[],"tail":", as subsec. (t) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1704"},"text":"section 1704 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/633"},"text":"Pub. L. 88–633","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/205"},"text":"Pub. L. 88–205","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f9ce86d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f9ce86e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Subchapter I Deemed To Include Certain Parts of Subchapter II","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to subchapter I of this chapter are deemed to include parts IV (§ 2346 et seq.), VI (§ 2348 et seq.), and VIII (§ 2349aa et seq.) of subchapter II of this chapter, and references to subchapter II are deemed to exclude such parts. See ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226/s202/b"},"text":"section 202(b) of Pub. L. 92–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"section 2346 of this title","children":[],"tail":", and sections 2348c and 2349aa–5 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f9ce86f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f9ce870-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separate Accounts for Local Currencies and Cash Transfers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/dF/tVII/s7026"},"text":"Pub. L. 118–47, div. F, title VII, § 7026","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/776"},"text":"138 Stat. 776","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/47/dF/tVII/s7026"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separate Accounts for Local Currencies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If assistance is furnished to the government of a foreign country under chapters 1 and 10 of part I [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq., "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2293"},"text":"22 U.S.C. 2293","children":[],"tail":" et seq.] or chapter 4 of part II ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"22 U.S.C. 2346","children":[],"tail":" et seq.] of the Foreign Assistance Act of 1961 under agreements which result in the generation of local currencies of that country, the Administrator of the United States Agency for International Development shall—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that local currencies be deposited in a separate account established by that government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enter into an agreement with that government which sets forth—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the local currencies to be generated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms and conditions under which the currencies so deposited may be utilized, consistent with this section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish by agreement with that government the responsibilities of USAID [United States Agency for International Development] and that government to monitor and account for deposits into and disbursements from the separate account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uses of local currencies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As may be agreed upon with the foreign government, local currencies deposited in a separate account pursuant to subsection (a), or an equivalent amount of local currencies, shall be used only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to carry out chapter 1 or 10 of part I or chapter 4 of part II of the Foreign Assistance Act of 1961 (as the case may be), for such purposes as—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project and sector assistance activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" debt and deficit financing; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the administrative requirements of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Programming accountability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"USAID shall take all necessary steps to ensure that the equivalent of the local currencies disbursed pursuant to subsection (a)(2)(A) from the separate account established pursuant to subsection (a)(1) are used for the purposes agreed upon pursuant to subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of assistance programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon termination of assistance to a country under chapter 1 or 10 of part I or chapter 4 of part II of the Foreign Assistance Act of 1961 (as the case may be), any unencumbered balances of funds which remain in a separate account established pursuant to subsection (a) shall be disposed of for such purposes as may be agreed to by the government of that country and the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separate Accounts for Cash Transfers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If assistance is made available to the government of a foreign country, under chapter 1 or 10 of part I [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq., "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2293"},"text":"22 U.S.C. 2293","children":[],"tail":" et seq.] or chapter 4 of part II ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"22 U.S.C. 2346","children":[],"tail":" et seq.] of the Foreign Assistance Act of 1961, as cash transfer assistance or as nonproject sector assistance, that country shall be required to maintain such funds in a separate account and not commingle with any other funds."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of other provisions of law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Such funds may be obligated and expended notwithstanding provisions of law which are inconsistent with the nature of this assistance, including provisions which are referenced in the Joint Explanatory Statement of the Committee of Conference accompanying House Joint Resolution 648 (House Report No. 98–1159).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At least 15 days prior to obligating any such cash transfer or nonproject sector assistance, the President shall submit a notification through the regular notification procedures of the Committees on Appropriations, which shall include a detailed description of how the funds proposed to be made available will be used, with a discussion of the United States interests that will be served by such assistance (including, as appropriate, a description of the economic policy reforms that will be promoted by such assistance).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nonproject sector assistance funds may be exempt from the requirements of paragraph (1) only through the regular notification procedures of the Committees on Appropriations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dK/tVII/s7026"},"text":"Pub. L. 117–328, div. K, title VII, § 7026","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5019"},"text":"136 Stat. 5019","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dK/tVII/s7026"},"text":"Pub. L. 117–103, div. K, title VII, § 7026","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/609"},"text":"136 Stat. 609","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dK/tVII/s7026"},"text":"Pub. L. 116–260, div. K, title VII, § 7026","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1737"},"text":"134 Stat. 1737","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dG/tVII/s7026"},"text":"Pub. L. 116–94, div. G, title VII, § 7026","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2859"},"text":"133 Stat. 2859","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6/dF/tVII/s7026"},"text":"Pub. L. 116–6, div. F, title VII, § 7026","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-15"},"text":"Feb. 15, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/312"},"text":"133 Stat. 312","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dK/tVII/s7026"},"text":"Pub. L. 115–141, div. K, title VII, § 7026","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/877"},"text":"132 Stat. 877","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/dJ/tVII/s7026"},"text":"Pub. L. 115–31, div. J, title VII, § 7026","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/633"},"te