{"tag":"section","attrib":{"id":"id903a3aa8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3424"},"text":null,"children":[{"tag":"num","attrib":{"value":"3424"},"text":"§ 3424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreimbursed costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id903a3aa9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3424/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative and technical support and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any agency of the United States Government is authorized to provide administrative and technical support and services to the Multinational Force and Observers, without reimbursement and upon such terms and conditions as the President may direct, when the provision of such support or services would not result in significant incremental costs to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a3aaa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3424/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs to be kept at minimum level","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provision by the United States to the Multinational Force and Observers under the authority of this subchapter or any other law of any property, support, or services, including the provision of military and civilian personnel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3422"},"text":"section 3422 of this title","children":[],"tail":", on other than a reimbursable basis shall be kept to a minimum."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a3aab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3424/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military training of armed forces of other countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may provide military training to members of the armed forces of other countries participating in the Multinational Force and Observers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a3aac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3424/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903a3aad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3424/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States may use contractors to provide logistical support to the Multinational Force and Observers under this section in lieu of providing such support through a logistical support unit comprised of members of the United States Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3aae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3424/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsections (a) and (b) and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3426/b"},"text":"section 3426(b) of this title","children":[],"tail":", support by a contractor under this subsection may be provided without reimbursement whenever the President determines that such action enhances or supports the national security interests of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903a3aaf-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/132/s5"},"text":"Pub. L. 97–132, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1695"},"text":"95 Stat. 1695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXII/s1211"},"text":"Pub. L. 107–107, div. A, title XII, § 1211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1248"},"text":"115 Stat. 1248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903a3ab0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id903a3ab1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id903a3ab2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
