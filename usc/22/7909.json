{"tag":"section","attrib":{"id":"id90f1f261-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909"},"text":null,"children":[{"tag":"num","attrib":{"value":"7909"},"text":"§ 7909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for the Clean Technology Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f1f262-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For fiscal year 2010, up to $300,000,000 is authorized to be appropriated for a United States contribution to the Clean Technology Fund (the Fund).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f263-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limits on country access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall use the voice and vote of the United States to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f1f264-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Fund does not provide more than 15 percent of Fund resources to any one country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f1f265-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prior to the obligation of funds, recipient countries submit to the governing body of the Fund, and the governing body of the Fund appropriately reviews and considers, an investment plan that will achieve significant net reductions in national-level greenhouse gas emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f1f266-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The investment plan for a recipient country, whose borrowing status is classified by the World Bank as “International Development Association (IDA) blend”, shall have at least 15 percent of its total cost for public sector activities contributed from the public funds of the recipient country, and any recipient country whose borrowing status is classified by the World Bank as “International Bank for Reconstruction and Development (IBRD) Only” status, shall have at least 25 percent of its total cost for public sector activities contributed from public funds of the recipient country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f1f267-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance made available by the Fund is used exclusively to support the deployment of clean energy technologies in developing countries (including, where appropriate, through the provision of technical support or support for policy or institutional reforms) in a manner that achieves substantial net reductions in greenhouse gas emissions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f268-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/dK/tVII/s7034/i"},"text":"Pub. L. 113–76, div. K, title VII, § 7034(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/514"},"text":"128 Stat. 514","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f269-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f1f26a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “net reductions” refers to the extent to which a project or program supported under this section results in lower greenhouse gas emissions than would be emitted by the same entity or sector in the same country in the absence of the Fund’s project, taking into account, unless impracticable, effects beyond the physical boundaries of the project or program that result from project or program activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f1f26b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public sector activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “public sector activities” may include sovereign loans assumed by the recipient country to contribute to the financing of the investment plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f1f26c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clean energy technology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “clean energy technology” means a technology that, as compared with technologies being deployed at that time for widespread commercial use in the country involved—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90f1f26d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieves substantial reductions in greenhouse gas emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f1f26e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not result in significant incremental adverse effects on public health or the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f1f26f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does one or more of the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id90f1f270-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/4/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generates electricity or useful thermal energy from a renewable resource;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id90f1f271-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/4/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially increases the energy efficiency of buildings, industrial, or agricultural processes, or of electricity transmission, distribution, or end-use consumption; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id90f1f272-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7909/4/C/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially increases the energy efficiency of the transportation system or increases utilization of transportation fuels that have lifecycle greenhouse gas emissions that are substantially lower than those attributable to fossil fuel-based alternatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f1f273-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/117/dF/tVII/s7081/g"},"text":"Pub. L. 111–117, div. F, title VII, § 7081(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-12-16"},"text":"Dec. 16, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3398"},"text":"123 Stat. 3398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/dK/tVII/s7034/i"},"text":"Pub. L. 113–76, div. K, title VII, § 7034(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/514"},"text":"128 Stat. 514","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90f1f274-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90f1f275-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90f1f276-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of State, Foreign Operations, and Related Programs Appropriations Act, 2010, and also as part of the Consolidated Appropriations Act, 2010, and not as part of part C of the Global Environmental Protection Assistance Act of 1989 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90f1f277-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76"},"text":"Pub. L. 113–76","children":[],"tail":" struck out par. (3), which established a reporting requirement for operations and governance of the Fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90f1f278-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90f1f279-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuation of Prior Law","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dJ/tVII/s7060/c/9"},"text":"Pub. L. 113–235, div. J, title VII, § 7060(c)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2672"},"text":"128 Stat. 2672","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/235/dJ/tVII/s7060/c/9"},"text":"“Section 7081(g)(2) and (4) of division F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/117"},"text":"Public Law 111–117","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7909/2"},"text":"22 U.S.C. 7909(2)","children":[],"tail":", (4)] shall continue in effect during fiscal year 2015 as if part of this Act [div. J of "},{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2573"},"text":"128 Stat. 2573","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior continuations were contained in the following acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/dK/tVII/s7060/c/9"},"text":"Pub. L. 113–76, div. K, title VII, § 7060(c)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/554"},"text":"128 Stat. 554","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dI/tVII/s7062/c/8"},"text":"Pub. L. 112–74, div. I, title VII, § 7062(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1250"},"text":"125 Stat. 1250","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
