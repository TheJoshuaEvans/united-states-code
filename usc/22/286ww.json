{"tag":"section","attrib":{"id":"id8ecb1a9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286ww"},"text":null,"children":[{"tag":"num","attrib":{"value":"286ww"},"text":"§ 286ww.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of amendments to Articles of Agreement of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund may accept the amendments to the Articles of Agreement of the Fund as proposed in resolution 66–2 of the Board of Governors of the Fund.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ecb1a9b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s71"},"text":"July 31, 1945, ch. 339, § 71","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dK/tIX/s9002"},"text":"Pub. L. 114–113, div. K, title IX, § 9002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2830"},"text":"129 Stat. 2830","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
