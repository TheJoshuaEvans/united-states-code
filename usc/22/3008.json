{"tag":"section","attrib":{"id":"id902c09bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3008"},"text":null,"children":[{"tag":"num","attrib":{"value":"3008"},"text":"§ 3008.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission staff","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id902c09bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3008/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel and administration committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall have a personnel and administration committee composed of the Chairman, the Cochairman, the senior Commission member from the minority party in the House of Representatives, and the senior Commission member from the minority party in the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id902c09bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3008/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All decisions pertaining to the hiring, firing, and fixing of pay of Commission staff personnel shall be by a majority vote of the personnel and administration committee, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id902c09be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3008/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman shall be entitled to appoint and fix the pay of the staff director, and the Cochairman shall be entitled to appoint and fix the pay of his senior staff person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902c09bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3008/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman and Cochairman each shall have the authority to appoint, with the approval of the personnel and administration committee, at least four professional staff members who shall be responsible to the Chairman or the Cochairman (as the case may be) who appointed them.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The personnel and administration committee may appoint and fix the pay of such other staff personnel as it deems desirable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id902c09c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3008/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All staff appointments shall be made without regard to the provisions of title 5 governing appointments in the competitive service, and without regard to the provisions of chapter 51 and subchapter III of chapter 53 of such title relating to classification and general schedule pay rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id902c09c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3008/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission employees as congressional employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id902c09c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3008/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of pay and other employment benefits, rights, and privileges and for all other purposes, any employee of the Commission shall be considered to be a congressional employee as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2107"},"text":"section 2107 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902c09c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3008/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of section 3304(i)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002238"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002238"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 5, staff personnel of the Commission shall be considered as if they are in positions in which they are paid by the Secretary of the Senate or the Chief Administrative Officer of the House of Representatives."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902c09c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3008/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of paragraphs (1) and (2) of this subsection shall be effective as of ","children":[{"tag":"date","attrib":{"date":"1976-06-03"},"text":"June 3, 1976","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id902c09c5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/304/s8"},"text":"Pub. L. 94–304, § 8","children":[],"tail":", "},{"tag":"date","attrib