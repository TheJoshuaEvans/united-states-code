304/c/1"},"text":"section 3304(c)(1) of title 5","children":[],"tail":" prior to the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s16/a"},"text":"Pub. L. 104–65, § 16(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/703"},"text":"109 Stat. 703","children":[],"tail":", which struck out "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3304/c"},"text":"section 3304(c) of title 5","children":[],"tail":" and redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3304/d"},"text":"section 3304(d) of title 5","children":[],"tail":" as section 3304(c), and by "},{"tag":"ref","attrib":{"href":"/us/pl/118/188/s2/a/1/A"},"text":"Pub. L. 118–188, § 2(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2644"},"text":"138 Stat. 2644","children":[],"tail":", which redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3304/c"},"text":"section 3304(c) of title 5","children":[],"tail":" as section 3304(i). Prior to these amendments, section 3304(c)(1) related to acquisition of competitive status by an individual who served for at least 3 years in the legislative branch in a position in which he was paid by the Secretary of the Senate or the Clerk of the House of Representatives. After amendment, "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3304/i/1"},"text":"section 3304(i)(1) of title 5","children":[],"tail":" defines “technician”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id902c09c9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/188"},"text":"Pub. L. 118–188","children":[],"tail":" substituted “3304(i)(1)” for “3304(c)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer” for “Clerk”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/7"},"text":"Pub. L. 99–7","children":[],"tail":", in amending section generally, added subsecs. (a) and (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/7"},"text":"Pub. L. 99–7","children":[],"tail":", in amending section generally, designated existing provisions as subsec. (c) and substituted “All staff appointments shall be made” for “The Commission may appoint and fix the pay of such staff personnel as it deems desirable,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/7"},"text":"Pub. L. 99–7","children":[],"tail":", in amending section generally, added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id902c09ca-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id902c09cb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/7"},"text":"Pub. L. 99–7","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-04-15"},"text":"Apr. 15, 1985","children":[],"tail":", except for enactment of subsec. (d) which was effective "},{"tag":"date","attrib":{"date":"1976-06-03"},"text":"June 3, 1976","children":[],"tail":", see section 6(a), (b)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/99/7"},"text":"Pub. L. 99–7","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3002"},"text":"section 3002 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
