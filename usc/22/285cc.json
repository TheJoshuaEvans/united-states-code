{"tag":"section","attrib":{"id":"id8ebf32f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"285cc"},"text":"§ 285cc.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eighth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf32f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285cc/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank is authorized to contribute on behalf of the United States $461,000,000 to the eighth replenishment of the resources of the Fund, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf32f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285cc/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $461,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf32f7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s32"},"text":"Pub. L. 89–369, § 32","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/102/tV/s599C/c"},"text":"Pub. L. 109–102, title V, § 599C(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-14"},"text":"Nov. 14, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2243"},"text":"119 Stat. 2243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ebf32f8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ebf32f9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ebf32fa-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/102/tV/s599C/c"},"text":"Pub. L. 109–102, title V, § 599C(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-14"},"text":"Nov. 14, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2243"},"text":"119 Stat. 2243","children":[],"tail":", which directed that this section be added at the end of “the Asian Development Fund Act, "},{"tag":"ref","attrib":{"href":"/us/pl/92/245"},"text":"Public Law 92–245","children":[],"tail":", as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s285"},"text":"22 U.S.C. 285","children":[],"tail":" et seq.)”, was executed by adding this section at the end of the Asian Development Bank Act, "},{"tag":"ref","attrib":{"href":"/us/pl/89/369"},"text":"Pub. L. 89–369","children":[],"tail":", which is classified to this subchapter, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
