{"tag":"section","attrib":{"id":"id90737361-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4301"},"text":null,"children":[{"tag":"num","attrib":{"value":"4301"},"text":"§ 4301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of findings and policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90737362-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress finds that the operation in the United States of foreign missions and public international organizations and the official missions to such organizations, including the permissible scope of their activities and the location and size of their facilities, is a proper subject for the exercise of Federal jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90737363-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress declares that it is the policy of the United States to support the secure and efficient operation of United States missions abroad, to facilitate the secure and efficient operation in the United States of foreign missions and public international organizations and the official missions to such organizations, and to assist in obtaining appropriate benefits, privileges, and immunities for those missions and organizations and to require their observance of corresponding obligations in accordance with international law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90737364-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of foreign missions in United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The treatment to be accorded to a foreign mission in the United States shall be determined by the Secretary after due consideration of the benefits, privileges, and immunities provided to missions of the United States in the country or territory represented by that foreign mission, as well as matters relating to the protection of the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90737365-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title II, § 201, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/b"},"text":"Pub. L. 97–241, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/283"},"text":"96 Stat. 283","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/93/tI/s127/a"},"text":"Pub. L. 99–93, title I, § 127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/418"},"text":"99 Stat. 418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90737366-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90737367-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90737368-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93"},"text":"Pub. L. 99–93","children":[],"tail":" inserted “, as well as matters relating to the protection of the interests of the United States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90737369-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id9073736a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s204"},"text":"Pub. L. 97–241, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/291"},"text":"96 Stat. 291","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/241/tII/s204"},"text":"“The amendments made by this title [see Short Title note below] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"October 1, 1982","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id9073736b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/tVI/s601"},"text":"Pub. L. 98–164, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1042"},"text":"97 Stat. 1042","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/164/tVI/s601"},"text":"“This title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4304a"},"text":"section 4304a of this title","children":[],"tail":", amending sections 254e and 4303 of this title, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4303"},"text":"section 4303 of this title","children":[],"tail":"] may be cited as the ‘Foreign Missions Amendments Act of 1983’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id9073736c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s201"},"text":"Pub. L. 97–241, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/282"},"text":"96 Stat. 282","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/241/tII/s201"},"text":"“This title [enacting this chapter, amending sections 254a, 254b, 254c, 2662, and 2684 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1364"},"text":"section 1364 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, and enacting provisions set out as a note under this section] may be cited as the ‘Foreign Missions Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9073736d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"United States Department of State Freedom of Expression","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s133"},"text":"Pub. L. 100–204, title I, § 133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1344"},"text":"101 Stat. 1344","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/204/tI/s133"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Congress finds that the United States Department of State, on ","children":[{"tag":"date","attrib":{"date":"1987-09-15"},"text":"September 15, 1987","children":[],"tail":", declared itself to be a temporary foreign diplomatic mission for the purpose of denying free speech to American citizens who planned to protest the tyranny of the Soviet regime."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is not in the national security interest of the United States for the Department of State to declare, and it shall not declare, itself to be a foreign diplomatic mission.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9073736e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"United States-Soviet Reciprocity in Matters Relating to Embassies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s134"},"text":"Pub. L. 101–246, title I, § 134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/33"},"text":"104 Stat. 33","children":[],"tail":", authorized Secretary of State to allow Soviet mission to United States to occupy, on a reciprocal basis, a consulate facility in United States, provided that United States mission in Kiev would be able to occupy an interim facility intended for conduct of unclassified activities, and required Secretary of State to submit to Congress a long-term plan for acquiring secure permanent facilities for United States mission in Kiev, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/199/tV/s502/c/1"},"text":"Pub. L. 103–199, title V, § 502(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2326"},"text":"107 Stat. 2326","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s153/a"},"text":"Pub. L. 100–204, title I, § 153(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1353"},"text":"101 Stat. 1353","children":[],"tail":", authorized Secretary of State to obtain full cooperation of Soviet government, on a reciprocal basis, in areas of diplomatic and consular finance, access to goods, and use of real property and prohibited Secretary of State from allowing Soviet mission to United States to occupy any new consulate in United States until United States mission in Kiev was able to occupy secure permanent facilities, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/199/tV/s502/e/1"},"text":"Pub. L. 103–199, title V, § 502(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2326"},"text":"107 Stat. 2326","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/s153/d"},"text":"Section 153(d) of Pub. L. 100–204","children":[],"tail":" was also repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s139/15"},"text":"Pub. L. 103–236, title I, § 139(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/398"},"text":"108 Stat. 398","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
