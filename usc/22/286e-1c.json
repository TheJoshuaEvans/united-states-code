{"tag":"section","attrib":{"id":"id8ec17d53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1c"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–1c"},"text":"§ 286e–1c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional increase in quota of United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ec17d54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Fund is authorized to consent to an increase of $1,540,000,000 in the quota of the United States in the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ec17d55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay the increase in the United States quota in the Fund provided for in this section, there is hereby authorized to be appropriated $1,540,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ec17d56-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s22"},"text":"July 31, 1945, ch. 339, § 22","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/599"},"text":"Pub. L. 91–599","children":[],"tail":", ch. 1, § 1, "},{"tag":"date","attrib":{"date":"1970-12-30"},"text":"Dec. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1657"},"text":"84 Stat. 1657","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
