{"tag":"section","attrib":{"id":"id908db26c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5474"},"text":null,"children":[{"tag":"num","attrib":{"value":"5474"},"text":"§ 5474.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual SEED Program report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908db26d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5474/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db26e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5474/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to provide the President with maximum flexibility and opportunity for innovation in implementation of the SEED Program, this chapter sets forth general goals and modalities for the support of democracy and economic pluralism in Eastern Europe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db26f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5474/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prompt United States action in devising specific measures to achieve the goals outlined in this chapter will be crucial in generating the public awareness, and the international commitment, necessary for United States leadership of a successful multilateral program of assistance in Eastern Europe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db270-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5474/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clear-cut delineation of such United States actions at an early date is integral to United States leadership of this effort.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db271-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5474/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial SEED Program report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Accordingly, the first report pursuant to subsection (c) ","children":[{"tag":"ref","attrib":{"idref":"fn002318"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002318"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall be a comprehensive report that includes a full description of all SEED Actions taken pursuant to each provision of this chapter since "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"November 28, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908db272-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tVII/s704"},"text":"Pub. L. 101–179, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1321"},"text":"103 Stat. 1321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dI/tVII/s7034/n"},"text":"Pub. L. 112–74, div. I, title VII, § 7034(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1217"},"text":"125 Stat. 1217","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id908db273-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id908db274-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id908db275-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179"},"text":"Pub. L. 101–179","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1298"},"text":"103 Stat. 1298","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5401"},"text":"section 5401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c), referred to in subsec. (b), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dI/tVII/s7034/n"},"text":"Pub. L. 112–74, div. I, title VII, § 7034(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1217"},"text":"125 Stat. 1217","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id908db276-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74"},"text":"Pub. L. 112–74","children":[],"tail":" struck out subsec. (c), which required President to submit annual SEED Program report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
