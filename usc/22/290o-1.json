{"tag":"section","attrib":{"id":"id8ee5593c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"290o–1"},"text":"§ 290o–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governor and alternate Governor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ee5593d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the inaugural meeting of the Board of Governors of the Bank, the Governor and the alternate for the Governor of the International Bank for Reconstruction and Development, appointed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s286a"},"text":"section 286a of this title","children":[],"tail":", shall serve ex-officio as a Governor and the alternate for the Governor, respectively, of the Bank. The President, by and with the advice and consent of the Senate, shall appoint a Governor of the Bank and an alternate for the Governor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee5593e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who serves as a governor of the Bank or as an alternate for the Governor may not receive any salary or other compensation from the United States by reason of such service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee5593f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/c/tVII/s703"},"text":"Pub. L. 104–208, div. A, title I, § 101(c) [title VII, § 703]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-121"},"text":"110 Stat. 3009–121","children":[],"tail":", 3009–179.)"}],"tail":"\n"}],"tail":null}
