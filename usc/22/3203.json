{"tag":"section","attrib":{"id":"id902e53ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3203"},"text":null,"children":[{"tag":"num","attrib":{"value":"3203"},"text":"§ 3203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id902e53ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id902e53ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3203/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Commission” means the Nuclear Regulatory Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902e53ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3203/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “IAEA” means International Atomic Energy Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902e53af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3203/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “nuclear materials and equipment” means source material, special nuclear material, production facilities, utilization facilities, and components, items or substances determined to have significance for nuclear explosive purposes pursuant to subsection 109b ","children":[{"tag":"ref","attrib":{"idref":"fn002244"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002244"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in the original. Probably should be “section 109(b)”."}],"tail":" of the 1954 Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2139/b"},"text":"42 U.S.C. 2139(b)","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902e53b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3203/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “physical security measures” means measures to reasonably ensure that source or special nuclear material will only be used for authorized purposes and to prevent theft and sabotage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902e53b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3203/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “sensitive nuclear technology” means any information (including information incorporated in a production or utilization facility or important component part thereof) which is not available to the public and which is important to the design, construction, fabrication, operation or maintenance of a uranium enrichment or nuclear fuel reprocessing facility or a facility for the production of heavy water, but shall not include Restricted Data controlled pursuant to chapter 12 of the 1954 Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2161"},"text":"42 U.S.C. 2161","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902e53b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3203/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “1954 Act” means the Atomic Energy Act of 1954, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"42 U.S.C. 2011","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id902e53b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3203/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “the Treaty” means the Treaty on the Non-Proliferation of Nuclear Weapons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id902e53b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All other terms used in this chapter not defined in this section shall have the meanings ascribed to them by the 1954 Act, the Energy Reorganization Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5801"},"text":"42 U.S.C. 5801","children":[],"tail":" et seq.], and the Treaty."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id902e53b5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/242/s4"},"text":"Pub. L. 95–242, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-10"},"text":"Mar. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/121"},"text":"92 Stat. 121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XII, § 1225(e)(1), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-775"},"text":"112 Stat. 2681–775","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id902e53b6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id902e53b7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id902e53b8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/242"},"text":"Pub. L. 95–242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-03-10"},"text":"Mar. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/120"},"text":"92 Stat. 120","children":[],"tail":", known as the Nuclear Non-Proliferation Act of 1978. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3201"},"text":"section 3201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Atomic Energy Act of 1954, as amended, referred to in subsec. (a)(5), (6), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"act Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/919"},"text":"68 Stat. 919","children":[],"tail":", which is classified principally to chapter 23 (§ 2011 et seq.) of Title 42, The Public Health and Welfare. Chapter 12 of the 1954 Act is classified generally to subchapter XI (§ 2161 et seq.) of division A of chapter 23 of Title 42. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Energy Reorganization Act of 1974, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/438"},"text":"Pub. L. 93–438","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-11"},"text":"Oct. 11, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1233"},"text":"88 Stat. 1233","children":[],"tail":", which is classified principally to chapter 73 (§ 5801 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5801"},"text":"section 5801 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id902e53b9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" redesignated pars. (3) to (8) as (2) to (7), respectively, and struck out former par. (2) which read as follows: “ ‘Director’ means the Director of the Arms Control and Disarmament Agency;”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id902e53ba-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id902e53bb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-04-01"},"text":"Apr. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1201"},"text":"section 1201 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6511"},"text":"section 6511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id902e53bc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1978-03-10"},"text":"Mar. 10, 1978","children":[],"tail":", except as otherwise provided and regardless of any requirements for the promulgation of implementing regulations, see "},{"tag":"ref","attrib":{"href":"/us/pl/95/242/s603/c"},"text":"section 603(c) of Pub. L. 95–242","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3201"},"text":"section 3201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
