{"tag":"section","attrib":{"id":"id8f530e2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2151e"},"text":"§ 2151e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f530e2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out activities under this part, the President shall place special emphasis on the use of relatively smaller, cost-saving, labor-using technologies that are generally most appropriate for the small farms, small businesses, and small incomes of the poor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f530e2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2151e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds made available to carry out this part should be used to the extent practicable for activities in the field of appropriate technology, including support of an expanded and coordinated private effort to promote the development and dissemination of appropriate technology in developing countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f530e2d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 107, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/tIII/s306/2"},"text":"Pub. L. 94–161, title III, § 306(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/859"},"text":"89 Stat. 859","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/tI/s107"},"text":"Pub. L. 95–424, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/947"},"text":"92 Stat. 947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f530e2e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f530e2f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8f530e30-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2151e, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 107, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/189/s2/3"},"text":"Pub. L. 93–189, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-17"},"text":"Dec. 17, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/715"},"text":"87 Stat. 715","children":[],"tail":", authorized additional appropriations of $39,000,000 for fiscal years 1974, and 1975, for assistance to select countries and organizations in support of general economy of recipient countries as for development programs conducted by private international organizations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/s306/1"},"text":"section 306(1) of Pub. L. 94–161","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151d"},"text":"section 2151d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f530e31-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" designated existing provisions as subsec. (a), substituted provisions mandating that the President place special emphasis on the use of relatively smaller, cost-saving, labor-using technologies generally more appropriate for small farms, small businesses and small incomes of the poor, for provisions authorizing the use of $20,000,000 for activities in the field of intermediate technology, directing the Agency for International Development to prepare a proposal to carry out this section and to keep Congress informed, and to implement such proposal, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f530e32-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f530e33-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/s605"},"text":"section 605 of Pub. L. 95–424","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children