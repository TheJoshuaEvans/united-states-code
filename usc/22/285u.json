{"tag":"section","attrib":{"id":"id8ebf32b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285u"},"text":null,"children":[{"tag":"num","attrib":{"value":"285u"},"text":"§ 285u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional contribution to special funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf32b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285u/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Bank is authorized to contribute on behalf of the United States $378,250,000 to the Asian Development Fund, a special fund of the Bank, except that any commitment to make such contribution shall be made subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf32ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285u/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; maximum available for certain years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the United States contribution to the Asian Development Fund provided for in this section, there are authorized to be appropriated, without fiscal year limitation, $378,250,000 for payment by the Secretary of the Treasury: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That not more than $111,250,000 of such sum may be made available for the fiscal year 1982, and not more than $44,500,000 of such sum may be made available for the fiscal year 1983."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf32bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285u/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of keeping to a minimum the cost to the United States, the Secretary of the Treasury—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ebf32bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285u/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall pay the United States contribution to the Asian Development Fund authorized by this section by letter of credit in four annual installments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ebf32bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285u/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take the steps necessary to obtain a certification from the Bank that any undisbursed balances resulting from drawdowns on such letter of credit will not exceed at any time the United States share of expected disbursement requirements for the following three-month period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf32be-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s24"},"text":"Pub. L. 89–369, § 24","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/259/tII/s201"},"text":"Pub. L. 96–259, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-03"},"text":"June 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/430"},"text":"94 Stat. 430","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXIII/s1352/b"},"text":"Pub. L. 97–35, title XIII, § 1352(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/744"},"text":"95 Stat. 744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ebf32bf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ebf32c0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ebf32c1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" inserted provision limiting amount of appropriations for fiscal years 1982 and 1983."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ebf32c2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ebf32c3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", except that any funds authorized to be appropriated shall not be available for use or obligation prior to "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1372"},"text":"section 1372 of Pub. L. 97–35","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s290i"},"text":"section 290i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
