{"tag":"section","attrib":{"id":"id8f95bd2d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2349bb–2"},"text":"§ 2349bb–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transit interdiction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f95bd2e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance under this part, the President shall ensure that, beginning in fiscal year 2007, not less than one-quarter of the total of such assistance is obligated for the purpose of enhancing the capabilities of friendly countries to detect and interdict proliferation-related shipments of cargo to non-State actors and States of proliferation concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f95bd2f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority to certain countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Priority shall be given in the apportionment of the assistance described under subsection (a) to any friendly country that has been determined by the Secretary of State to be a country frequently transited by proliferation-related shipments of cargo.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f95bd30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to promote cooperation regarding the interdiction of weapons of mass destruction and related materials and delivery systems, the President is authorized to conclude agreements, including reciprocal maritime agreements, with other countries to facilitate effective measures to prevent the transportation of such items to non-state actors and states of proliferation concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f95bd31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination and notice to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall notify the Committee on International Relations of the House of Representatives and the Committee on Foreign Relations of the Senate in writing not more than 30 days after making a determination that any friendly country has been determined to be a country eligible for priority consideration of any assistance under subsection (a). Such determination shall set forth the reasons for such determination, and may be submitted in classified and unclassified form, as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f95bd32-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 583, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/280/tIII/s301"},"text":"Pub. L. 106–280, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/852"},"text":"114 Stat. 852","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/472/s10/c"},"text":"Pub. L. 109–472, § 10(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-11"},"text":"Jan. 11, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3557"},"text":"120 Stat. 3557","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f95bd33-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f95bd34-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f95bd35-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/472/s10/c/1"},"text":"Pub. L. 109–472, § 10(c)(1)","children":[],"tail":", substituted “shall ensure that, beginning in fiscal year 2007,” for “should ensure that”, “obligated” for “expended”, and “to non-State actors and States of proliferation concern” for “that originate from, and are destined for, other countries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/472/s10/c/2"},"text":"Pub. L. 109–472, § 10(c)(2)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f95bd36-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id8f95bd37-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f95bd38-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f95bd39-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
