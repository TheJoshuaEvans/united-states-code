{"tag":"section","attrib":{"id":"id8ed97160-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287t"},"text":null,"children":[{"tag":"num","attrib":{"value":"287t"},"text":"§ 287t.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against disclosure of information or knowledge","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In adopting this subchapter, it is the understanding of the Congress that the constitution of the Organization does not require, nor does this subchapter authorize, the disclosure of any information or knowledge in any case in which such disclosure is prohibited by any law of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ed97161-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-30/ch700/s8"},"text":"July 30, 1946, ch. 700, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/714"},"text":"60 Stat. 714","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ed97162-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ed97163-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ed97164-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The constitution of the Organization, referred to in text, is the constitution of the United Nations Educational, Scientific, and Cultural Organization, which is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s287m"},"text":"section 287m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
