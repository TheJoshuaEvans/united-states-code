{"tag":"section","attrib":{"id":"id90d08798-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b"},"text":null,"children":[{"tag":"num","attrib":{"value":"7103b"},"text":"§ 7103b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivors of Human Trafficking Empowerment Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90d08799-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Survivors of Human Trafficking Empowerment Act”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d0879a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the United States Advisory Council on Human Trafficking (referred to in this section as the “Council”), which shall provide advice and recommendations to the Senior Policy Operating Group established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7103/g"},"text":"section 7103(g) of this title","children":[],"tail":" (referred to in this section as the “Group”) and the President’s Interagency Task Force to Monitor and Combat Trafficking established under section 7103(a) of such title (referred to in this section as the “Task Force”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d0879b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d0879c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall be composed of not less than 8 and not more than 14 individuals who are survivors of human trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d0879d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation of survivors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent practicable, members of the Council shall be survivors of trafficking, who shall accurately reflect the diverse backgrounds of survivors of trafficking, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90d0879e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" survivors of sex trafficking and survivors of labor trafficking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90d0879f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" survivors who are United States citizens and survivors who are aliens lawfully present in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d087a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", the President shall appoint the members of the Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d087a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term; reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each member of the Council shall serve for a term of 2 years and may be reappointed by the President to serve 1 additional 2-year term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d087a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d087a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a nongovernmental advisory body to the Group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d087a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet, at its own discretion or at the request of the Group, not less frequently than annually to review Federal Government policy and programs intended to combat human trafficking, including programs relating to the provision of services for victims and serve as a point of contact for Federal agencies reaching out to human trafficking survivors for input on programming and policies relating to human trafficking in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d087a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulate assessments and recommendations to ensure that policy and programming efforts of the Federal Government conform, to the extent practicable, to the best practices in the field of human trafficking prevention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d087a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet with the Group not less frequently than annually, and not later than 45 days before a meeting with the Task Force, to formally present the findings and recommendations of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d087a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", and each year thereafter until the date described in subsection (h),"},{"tag":"ref","attrib":{"idref":"fn002366"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002366"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the Council shall submit a report that contains the findings derived from the reviews conducted pursuant to subsection (d)(2) to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d087a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chair of the Task Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d087a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the members of the Group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d087aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Foreign Affairs, Homeland Security, Appropriations, and the Judiciary of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d087ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Foreign Relations, Appropriations, Homeland Security and Governmental Affairs, and the Judiciary of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d087ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee status","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Council—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d087ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be considered employees of the Federal Government for any purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d087ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall receive travel expenses, including per diem in lieu of subsistence, in accordance with the applicable provisions under subchapter I of chapter 57 of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d087af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may each receive compensation for each day such member is engaged in the actual performance of the duties of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d087b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7103b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of FACA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Council shall not be subject to the requirements under the Federal Advisory Committee Act (5 U.S.C. App.).","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90d087b1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/tI/s115"},"text":"Pub. L. 114–22, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/243"},"text":"129 Stat. 243","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/425/tI/s114"},"text":"Pub. L. 115–425, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-08"},"text":"Jan. 8, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5477"},"text":"132 Stat. 5477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1299R/c/1"},"text":"Pub. L. 116–283, div. A, title XII, § 1299R(c)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4027"},"text":"134 Stat. 4027","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/348/tI/s102"},"text":"Pub. L. 117–348, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6215"},"text":"136 Stat. 6215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90d087b2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90d087b3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90d087b4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (h), referred to in subsec. (e), was struck out by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/348/tI/s102"},"text":"Pub. L. 117–348, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6215"},"text":"136 Stat. 6215","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsec. (g), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90d087b5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as the Survivors of Human Trafficking Empowerment Act, and not as part of the Trafficking Victims Protection Act of 2000 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90d087b6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/348"},"text":"Pub. L. 117–348","children":[],"tail":" struck out subsec. (h). Prior to amendment, text read as follows: “The Council shall terminate on "},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299R/c/2"},"text":"Pub. L. 116–283, § 1299R(c)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299R/c/1"},"text":"Pub. L. 116–283, § 1299R(c)(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2021-09-30"},"text":"September 30, 2021","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/s114/1"},"text":"Pub. L. 115–425, § 114(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “shall not receive compensation other than reimbursement of travel expenses and per diem allowance in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/s114/2"},"text":"Pub. L. 115–425, § 114(2)","children":[],"tail":", substituted “2021” for “2020”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90d087b7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"id90d087b8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Severability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/348/tIII/s301"},"text":"Pub. L. 117–348, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6224"},"text":"136 Stat. 6224","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/348/tIII/s301"},"text":"“If any provision of this Act [see Short Title of 2023 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7101"},"text":"section 7101 of this title","children":[],"tail":"] or amendment made by this Act, or the application of such provision or amendment to any person or circumstance, is held to be unconstitutional, the remainder of this Act and the amendments made by this Act, and the application of the provision or amendment to any other person or circumstance, shall not be affected.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
