{"tag":"section","attrib":{"id":"id8efab591-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1381"},"text":null,"children":[{"tag":"num","attrib":{"value":"1381"},"text":"§ 1381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention by United States of title to real and personal property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall remain vested in the Government of the United States or its agencies or instrumentalities all the right, title, and interest of the said Government or its agencies or instrumentalities to all real and personal property within the Philippine Islands as may now be vested in, or later be acquired by the Government of the United States or any of its agencies or instrumentalities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8efab592-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-03/ch536/s2"},"text":"July 3, 1946, ch. 536, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/418"},"text":"60 Stat. 418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8efab593-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8efab594-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id8efab595-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-03/ch536/s1"},"text":"Act July 3, 1946, ch. 536, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/418"},"text":"60 Stat. 418","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1946-07-03/ch536/s1"},"text":"“This Act [enacting this subchapter] may be cited as the ‘Philippine Property Act of 1946’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
