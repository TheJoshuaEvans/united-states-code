{"tag":"section","attrib":{"id":"id8f1764c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1644e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1644e"},"text":"§ 1644e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offsets","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In determining the amount of any claim, the Commission shall deduct all amounts the claimant has received from any source on account of the same loss or losses, including any amount claimant received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4132/a"},"text":"section 4132(a) of title 50","children":[],"tail":", for losses which occurred as a direct consequence of special measures directed against such property in any area covered under this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f1764c7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title VI, § 605, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/542"},"text":"Pub. L. 94–542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2511"},"text":"90 Stat. 2511","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
