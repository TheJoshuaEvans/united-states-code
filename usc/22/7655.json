{"tag":"section","attrib":{"id":"id90eac60a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655"},"text":null,"children":[{"tag":"num","attrib":{"value":"7655"},"text":"§ 7655.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program on family survival partnerships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90eac60b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to authorize the President to establish a program, through a public-private partnership, for the provision of medical care and support services to HIV positive parents and their children identified through existing programs to prevent mother-to-child transmission of HIV in countries with or at risk for severe HIV epidemic with particular attention to resource constrained countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac60c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90eac60d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to establish a program for the award of grants to eligible administrative organizations to enable such organizations to award subgrants to eligible entities to expand activities to prevent the mother-to-child transmission of HIV by providing medical care and support services to HIV infected parents and their children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac60e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts provided under a grant awarded under paragraph (1) shall be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac60f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award subgrants to eligible entities to enable such entities to carry out activities described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac610-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for administrative support and subgrant management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac611-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for administrative data collection and reporting concerning grant activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac612-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the monitoring and evaluation of grant activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac613-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for training and technical assistance for subgrantees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac614-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote sustainability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac615-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subgrants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90eac616-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization awarded a grant under subsection (b) shall use amounts received under the grant to award subgrants to eligible entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac617-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a subgrant under paragraph (1), an entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac618-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a local health organization, an international organization, or a partnership of such organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac619-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demonstrate to the awarding organization that such entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90eac61a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is currently administering a proven intervention to prevent mother-to-child transmission of HIV in countries with or at risk for severe HIV epidemic with particular attention to resource constrained countries, as determined by the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90eac61b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated support for the proposed program from relevant government entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90eac61c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is able to provide HIV care, including antiretroviral treatment when medically indicated, to HIV positive women, men, and children with the support of the project funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac61d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local health and international organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (2)(A)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac61e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “local health organization” means a public sector health system, nongovernmental organization, institution of higher education, community-based organization, or nonprofit health system that provides directly, or has a clear link with a provider for the indirect provision of, primary health care services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac61f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “international organization” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90eac620-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit international entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90eac621-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an international charitable institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90eac622-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private voluntary international entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90eac623-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multilateral institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac624-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding subgrants under this subsection, the organization shall give priority to eligible applicants that are currently administering a program of proven intervention to HIV positive individuals to prevent mother-to-child transmission in countries with or at risk for severe HIV epidemic with particular attention to resource constrained countries, and who are currently administering a program to HIV positive women, men, and children to provide life-long care in family-centered care programs using non-Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac625-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of subgrant recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding subgrants under this subsection, the organization should—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac626-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider applicants from a range of health care settings, program approaches, and geographic locations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac627-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate, award not less than 1 grant to an applicant to fund a national system of health care delivery to HIV positive families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac628-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of subgrant funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity awarded a subgrant under this subsection shall use subgrant funds to expand activities to prevent mother-to-child transmission of HIV by providing medical treatment and care and support services to parents and their children, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90eac629-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing treatment and therapy, when medically indicated, to HIV-infected women, their children, and families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac62a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hiring and training of local personnel, including physicians, nurses, other health care providers, counselors, social workers, outreach personnel, laboratory technicians, data managers, and administrative support personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac62b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying laboratory costs, including costs related to necessary equipment and diagnostic testing and monitoring (including rapid testing), complete blood counts, standard chemistries, and liver function testing for infants, children, and parents, and costs related to the purchase of necessary laboratory equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac62c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing pharmaceuticals for HIV-related conditions, including antiretroviral therapies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac62d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding support services, including adherence and psychosocial support services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac62e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operational support activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90eac62f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/c/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting community outreach and capacity building activities, including activities to raise the awareness of individuals of the program carried out by the subgrantee, other communications activities in support of the program, local advisory board functions, and transportation necessary to ensure program participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac630-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall require that each organization awarded a grant under subsection (b)(1) to submit an annual report that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90eac631-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of programs funded under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac632-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benchmarks of success of programs funded under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac633-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations of how best to proceed with the programs funded under this section upon the expiration of funding under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac634-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the President, from amounts authorized to be appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7671"},"text":"section 7671 of this title","children":[],"tail":", such sums as may be necessary for each of the fiscal years 2004 through 2008 to carry out the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac635-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7655/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization shall ensure that not more than 7 percent of the amount of a grant received under this section by the organization is used for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90eac636-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25/tIII/s315"},"text":"Pub. L. 108–25, title III, § 315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/743"},"text":"117 Stat. 743","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90eac637-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id90eac638-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id90eac639-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
