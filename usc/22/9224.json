{"tag":"section","attrib":{"id":"id91218dd7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224"},"text":null,"children":[{"tag":"num","attrib":{"value":"9224"},"text":"§ 9224.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement sanctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91218dd8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in this section, the head of an executive agency may not procure, or enter into any contract for the procurement of, any goods or services from any person designated under section 9214(a) or (g) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218dd9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Acquisition Regulation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218dda-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Acquisition Regulation issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1303/a/1"},"text":"section 1303(a)(1) of title 41","children":[],"tail":" shall be revised to require that each person that is a prospective contractor submit a certification that such person does not engage in any activity described in section 9214(a) or (g) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218ddb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The revision required under paragraph (1) shall apply with respect to contracts for which solicitations are issued on or after the date that is 90 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-18"},"text":"February 18, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218ddc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218ddd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion on list","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of General Services shall include, on the List of Parties Excluded from Federal Procurement and Nonprocurement Programs maintained by the Administrator under part 9 of the Federal Acquisition Regulation, each person that is debarred, suspended, or proposed for debarment or suspension by the head of an executive agency on the basis of a determination of a false certification under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218dde-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract termination; suspension","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the head of an executive agency determines that a person has submitted a false certification under subsection (b) after the date on which the Federal Acquisition Regulation is revised to implement the requirements of this section, the head of such executive agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91218ddf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate any contract with such person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218de0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" debar or suspend such person from eligibility for Federal contracts for a period of not longer than 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218de1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any debarment or suspension under paragraph (2)(B) shall be subject to the procedures that apply to debarment and suspension under subpart 9.4 of the Federal Acquisition Regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218de2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification regarding certain products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedies specified in subsection (c) shall not apply with respect to the procurement of any eligible product (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2518/4"},"text":"section 2518(4) of title 19","children":[],"tail":" of any foreign country or instrumentality designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2511/b"},"text":"section 2511(b) of title 19","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218de3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection may be construed to limit the use of other remedies available to the head of an executive agency or any other official of the Federal Government on the basis of a determination of a false certification under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218de4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9224/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive agency defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “executive agency” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s133"},"text":"section 133 of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91218de5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tII/s204"},"text":"Pub. L. 114–122, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/107"},"text":"130 Stat. 107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXI/s7122/b/3"},"text":"Pub. L. 116–92, div. F, title LXXI, § 7122(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2248"},"text":"133 Stat. 2248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91218de6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91218de7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id91218de8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsecs. (a), (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" inserted “or (g)” after “section 9214(a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id91218de9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id91218dea-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Assessment and Authority To Terminate or Prohibit Contracts for Procurement From Chinese Companies Providing Support to the Democratic People’s Republic of Korea","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s888"},"text":"Pub. L. 115–91, div. A, title VIII, § 888","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1507"},"text":"131 Stat. 1507","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dA/tVIII/s888"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, in consultation with the Secretary of State, the Secretary of the Treasury, and the Director of National Intelligence, shall conduct an assessment of trade between the People’s Republic of China and the Democratic People’s Republic of Korea, including elements deemed to be important to United States national security and defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assessment required by paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the composition of all trade between China and the Democratic People’s Republic of Korea, including trade in goods and services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify whether any Chinese commercial entities that are engaged in such trade materially support illicit activities on the part of North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the extent to which the United States Government procures goods or services from any commercial entity identified under subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a list of commercial entities identified under subparagraph (B) that provide defense goods or services for the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the ramifications to United States national security, including any impacts to the defense industrial base, Department of Defense acquisition programs, and Department of Defense logistics or supply chains, of prohibiting procurements from commercial entities listed under subparagraph (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":"], the Secretary of Defense shall submit to Congress a report on the assessment required by paragraph (1). The report shall be submitted in unclassified form, but may contain a classified annex."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may terminate existing contracts or prohibit the award of contracts for the procurement of goods or services for the Department of Defense from a Chinese commercial entity included on the list described under subsection (a)(2)(D) based on a determination informed by the assessment required under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall submit to the appropriate committees of Congress a notification of, and detailed justification for, any exercise of the authority in subsection (b) not less than 30 days before the date on which the authority is exercised.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Committees of Congress Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘appropriate committees of Congress’ means—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Committee on Foreign Relations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services and the Committee on Foreign Affairs of the House of Representatives.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
