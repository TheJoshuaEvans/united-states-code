{"tag":"section","attrib":{"id":"id90aa6123-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064"},"text":null,"children":[{"tag":"num","attrib":{"value":"6064"},"text":"§ 6064.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of economic embargo of Cuba","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90aa6124-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon submitting a determination to the appropriate congressional committees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6063/c/1"},"text":"section 6063(c)(1) of this title","children":[],"tail":" that a transition government in Cuba is in power, the President, after consultation with the Congress, is authorized to take steps to suspend the economic embargo of Cuba and to suspend the right of action created in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6082"},"text":"section 6082 of this title","children":[],"tail":" with respect to actions thereafter filed against the Cuban Government, to the extent that such steps contribute to a stable foundation for a democratically elected government in Cuba."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90aa6125-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of certain provisions of law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the President may suspend the enforcement of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90aa6126-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370/a"},"text":"section 2370(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6127-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370/f"},"text":"section 2370(f) of this title","children":[],"tail":" with respect to the “Republic of Cuba”;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6128-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 6003, 6004(d), and 6005 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6129-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 902(c) of the Food Security Act of 1985; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa612a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prohibitions on transactions described in part 515 of title 31, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90aa612b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional Presidential actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon submitting a determination to the appropriate congressional committees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6063/c/3"},"text":"section 6063(c)(3) of this title","children":[],"tail":" that a democratically elected government in Cuba is in power, the President shall take steps to terminate the economic embargo of Cuba, including the restrictions under part 515 of title 31, Code of Federal Regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90aa612c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conforming amendments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the date on which the President submits a determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6063/c/3"},"text":"section 6063(c)(3) of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90aa612d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370/a"},"text":"section 2370(a) of this title","children":[],"tail":" is repealed;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa612e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370/f"},"text":"section 2370(f) of this title","children":[],"tail":" is amended by striking “Republic of Cuba”;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa612f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 6003, 6004(d), and 6005 of this title are repealed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6130-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 902(c) of the Food Security Act of 1985 is repealed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90aa6131-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of suspension of economic embargo","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90aa6132-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President takes action under subsection (a) to suspend the economic embargo of Cuba, the President shall immediately so notify the Congress. The President shall report to the Congress no less frequently than every 6 months thereafter, until he submits a determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6063/c/3"},"text":"section 6063(c)(3) of this title","children":[],"tail":" that a democratically elected government in Cuba is in power, on the progress being made by Cuba toward the establishment of such a democratically elected government. The action of the President under subsection (a) shall cease to be effective upon the enactment of a joint resolution described in paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6133-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint resolutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this subsection, the term “joint resolution” means only a joint resolution of the 2 Houses of Congress, the matter after the resolving clause of which is as follows: “That the Congress disapproves the action of the President under section 204(a) of the Cuban Liberty and Democratic Solidarity (LIBERTAD) Act of 1996 to suspend the economic embargo of Cuba, notice of which was submitted to the Congress on __.”, with the blank space being filled with the appropriate date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6134-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral to committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Joint resolutions introduced in the House of Representatives shall be referred to the Committee on International Relations and joint resolutions introduced in the Senate shall be referred to the Committee on Foreign Relations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6135-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90aa6136-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any joint resolution shall be considered in the Senate in accordance with the provisions of section 601(b) of the International Security Assistance and Arms Export Control Act of 1976.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90aa6137-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of expediting the consideration and enactment of joint resolutions, a motion to proceed to the consideration of any joint resolution after it has been reported by the appropriate committee shall be treated as highly privileged in the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90aa6138-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6064/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 1 joint resolution may be considered in the House of Representatives and the Senate in the 6-month period beginning on the date on which the President notifies the Congress under paragraph (1) of the action taken under subsection (a), and in each 6-month period thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90aa6139-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114/tII/s204"},"text":"Pub. L. 104–114, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/810"},"text":"110 Stat. 810","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90aa613a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90aa613b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90aa613c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 902(c) of the Food Security Act of 1985, referred to in subsecs. (b)(4) and (d)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s902/c"},"text":"section 902(c) of Pub. L. 99–198","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1446g"},"text":"section 1446g of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 204(a) of the Cuban Liberty and Democratic Solidarity (LIBERTAD) Act of 1996, referred to in subsec. (e)(2), is subsec. (a) of this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 601(b) of the International Security Assistance and Arms Export Control Act of 1976, referred to in subsec. (e)(4)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329/s601/b"},"text":"section 601(b) of Pub. L. 94–329","children":[],"tail":", title VI, "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/765"},"text":"90 Stat. 765","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90aa613d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id90aa613e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
