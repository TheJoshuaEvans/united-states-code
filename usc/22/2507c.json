{"tag":"section","attrib":{"id":"id8fcef57c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2507c"},"text":"§ 2507c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Victim Advocacy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fcef57d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Office of Victims ","children":[{"tag":"ref","attrib":{"idref":"fn002170"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002170"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Victim”."}],"tail":" Advocacy"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fcef57e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish an Office of Victim Advocacy in Peace Corps headquarters headed by a full-time Victim’s Advocate who shall report directly to the Director. The Office of Victim Advocacy may deploy personnel abroad when necessary to help assist victims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef57f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Peace Corps Medical Officers, Safety and Security Officers, and program staff may not serve as Victim’s Advocates. The Victim’s Advocate referred to in paragraph (1) may not have any other duties in the Peace Corps that are not reasonably connected to victim advocacy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef580-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Victim’s Advocate and any additional Victim’s Advocates shall be exempt from the limitations specified in subparagraphs (A) and (B) of paragraph (2) and paragraph (5) under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2506/a"},"text":"section 2506(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef581-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fcef582-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victims of sexual assault","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Victim Advocacy shall help develop and update the sexual assault risk-reduction and response training described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2507a"},"text":"section 2507a of this title","children":[],"tail":" and the sexual assault policy described in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2507b"},"text":"section 2507b of this title","children":[],"tail":", ensure that volunteers who are victims of sexual assault receive services specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2507b/c"},"text":"section 2507b(c) of this title","children":[],"tail":", and facilitate their access to such services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef583-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other crimes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to assisting victims of sexual assault in accordance with paragraph (1), the Office of Victim Advocacy shall assist volunteers who are victims of crime by making such victims aware of the services available to them and facilitating their access to such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef584-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Victim Advocacy shall give priority to cases involving serious crimes, including sexual assault and stalking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef585-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Victim Advocacy shall provide to volunteers who are victims regular updates on the status of their cases if such volunteers have opted to pursue prosecution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef586-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Victim Advocacy shall assist volunteers who are victims of crime and whose service has terminated in receiving the services specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2507b/c"},"text":"section 2507b(c) of this title","children":[],"tail":" requested by such volunteer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef587-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policymaking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Peace Corps shall include the head of the Office of Victim Advocacy in agency-wide policymaking processes in the same manner and to the same extent as the directors or associate directors of other offices within the Peace Corps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fcef588-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/tI/s8C"},"text":"Pub. L. 87–293, title I, § 8C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/57/s2"},"text":"Pub. L. 112–57, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-21"},"text":"Nov. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/739"},"text":"125 Stat. 739","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/256/tIII/s304"},"text":"Pub. L. 115–256, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-09"},"text":"Oct. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3658"},"text":"132 Stat. 3658","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fcef589-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fcef58a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fcef58b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/256/s304/1"},"text":"Pub. L. 115–256, § 304(1)","children":[],"tail":", (2), substituted “Victim’s Advocate” for “victim advocate” and “Victim’s Advocates” for “victim advocates” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/256/s304/3"},"text":"Pub. L. 115–256, § 304(3)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, text read as follows: “This section shall cease to be effective on "},{"tag":"date","attrib":{"date":"2018-10-01"},"text":"October 1, 2018","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
