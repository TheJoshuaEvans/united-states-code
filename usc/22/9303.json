{"tag":"section","attrib":{"id":"id9126483c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303"},"text":null,"children":[{"tag":"num","attrib":{"value":"9303"},"text":"§ 9303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9126483d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9126483e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9126483f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91264840-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91264841-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91264842-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91264843-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91264844-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feed the Future Innovation Labs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Feed the Future Innovation Labs” means research partnerships led by United States universities that advance solutions to reduce global hunger, poverty, and malnutrition, including in response to shocks and stresses to food and nutrition security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91264845-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food and nutrition security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “food and nutrition security” means access to, and availability, utilization, and stability of, sufficient food to meet caloric and nutritional needs for an active and healthy life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91264846-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “food system” means the intact or whole unit made up of interrelated components of people, behaviors, relationships, and material goods that interact in the production, processing, packaging, transporting, trade, marketing, consumption, and use of food, feed, and fiber through aquaculture, farming, wild fisheries, forestry, and pastoralism that operates within and is influenced by social, political, economic, and environmental contexts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91264847-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global Food Security Strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Global Food Security Strategy” means the strategy developed and implemented pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9304/a"},"text":"section 9304(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91264848-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Key stakeholders","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “key stakeholders” means actors engaged in efforts to advance global food security programs and objectives, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91264849-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant Federal departments and agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9126484a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national and local governments in target countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9126484b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other bilateral donors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9126484c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international and regional organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9126484d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international, regional, and local financial institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9126484e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international, regional, and local private voluntary, nongovernmental, faith-based, and civil society organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9126484f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector, including agribusinesses and relevant commodities groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91264850-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local agricultural producers, including farmer and fisher organizations, cooperatives, small-scale producers, youth, and women; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91264851-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural research and academic institutions, including land-grant universities and extension services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91264852-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Malnutrition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “malnutrition” means poor nutritional status caused by nutritional deficiency or excess.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91264853-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant Federal departments and agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “relevant Federal departments and agencies” means the United States Agency for International Development, the Department of Agriculture, the Department of Commerce, the Department of State, the Department of the Treasury, the Millennium Challenge Corporation, the United States International Development Finance Corporation, the Peace Corps, the Office of the United States Trade Representative, the United States African Development Foundation, the Inter-American Foundation, the United States Geological Survey, and any other department or agency specified by the President for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91264854-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resilience","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “resilience” means the ability of people, households, communities, countries, and agriculture and food systems to mitigate, adapt to, and recover from shocks and stresses to food security, including global food catastrophes, in a manner that reduces chronic vulnerability and facilitates inclusive growth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91264855-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small-scale producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “small-scale producer” means farmers, pastoralists, foresters, and artisanal fishing communities that have a low asset base and limited resources, including land, capital, skills and labor, and, in the case of farmers, typically farm on fewer than 5 hectares of land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91264856-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stunting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “stunting” refers to a condition that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91264857-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is measured by a height-to-age ratio that is more than 2 standard deviations below the median for the population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91264858-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manifests in children who are younger than 2 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91264859-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a process that can continue in children after they reach 2 years of age, resulting in an individual being “stunted”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9126485a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/11/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a marker of an environment deficient in the various needs that allow for a child’s healthy growth, including nutrition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9126485b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/11/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is associated with long-term poor health, delayed motor development, impaired cognitive function, and decreased immunity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9126485c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sustainable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sustainable” means the ability of a target country, community, implementing partner, or intended beneficiary to maintain, over time, the programs authorized and outcomes achieved pursuant to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9126485d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “target country” means a developing country that is selected to participate in food and nutrition security and agriculture-led economic growth programs under the Global Food Security Strategy pursuant to the selection criteria described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9304/a/2"},"text":"section 9304(a)(2) of this title","children":[],"tail":", including criteria such as the potential for agriculture-led economic growth, government commitment to agricultural investment and policy reform, opportunities for partnerships and regional synergies, the level of need, and resource availability."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9126485e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wasting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “wasting” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9126485f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a life-threatening condition attributable to poor nutrient intake or disease that is characterized by a rapid deterioration in nutritional status over a short period of time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91264860-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9303/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of children, is characterized by low weight for height and weakened immunity, increasing their risk of death due to greater frequency and severity of common infection, particularly when severe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91264861-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/195/s4"},"text":"Pub. L. 114–195, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-20"},"text":"July 20, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/676"},"text":"130 Stat. 676","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tVI/s1470/s"},"text":"Pub. L. 115–254, div. F, title VI, § 1470(s)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3519"},"text":"132 Stat. 3519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5588/c"},"text":"Pub. L. 117–263, div. E, title LV, § 5588(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3376"},"text":"136 Stat. 3376","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91264862-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91264863-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id91264864-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5588/c/1"},"text":"Pub. L. 117–263, § 5588(c)(1)","children":[],"tail":", inserted “, including in response to shocks and stresses to food and nutrition security” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5588/c/2"},"text":"Pub. L. 117–263, § 5588(c)(2)","children":[],"tail":", (3), added par. (4) and redesignated former pars. (4) and (5) as (5) and (6), respectively. Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5588/c/4"},"text":"Pub. L. 117–263, § 5588(c)(4)","children":[],"tail":", amended subpar. (H) generally. Prior to amendment, subpar. (H) read as follows: “agricultural producers, including farmer organizations, cooperatives, small-scale producers, and women; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5588/c/2"},"text":"Pub. L. 117–263, § 5588(c)(2)","children":[],"tail":", redesignated par. (6) as (7). Former par. (7) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5588/c/5"},"text":"Pub. L. 117–263, § 5588(c)(5)","children":[],"tail":", which directed amendment of “paragraph (7), as redesignated” by inserting “the Inter-American Foundation,” after “United States African Development Foundation,” was executed by making the amendment in par. (8), as redesignated, to reflect the probable intent of Congress. Par. (7), as redesignated by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5588/c/2"},"text":"Pub. L. 117–263, § 5588(c)(2)","children":[],"tail":", does not contain the words “United States African Development Foundation,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5588/c/2"},"text":"Pub. L. 117–263, § 5588(c)(2)","children":[],"tail":", redesignated par. (7) as (8). Former par. (8) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5588/c/2"},"text":"Pub. L. 117–263, § 5588(c)(2)","children":[],"tail":", (6), redesignated par. (8) as (9) and inserted “agriculture and food” before “systems” and “, including global food catastrophes,” after “food security”. Former par. (9) redesignated (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5588/c/2"},"text":"Pub. L. 117–263, § 5588(c)(2)","children":[],"tail":", (7), redesignated par. (9) as (10) and substituted “artisanal fishing communities” for “fishers”. Former par. (10) redesignated (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5588/c/2"},"text":"Pub. L. 117–263, § 5588(c)(2)","children":[],"tail":", redesignated par. (10) as (11). Former par. (11) redesignated (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5588/c/8"},"text":"Pub. L. 117–263, § 5588(c)(8)","children":[],"tail":", amended subpars. (D) and (E) generally. Prior to amendment, subpars. (D) and (E) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) is a sign of chronic malnutrition; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) can lead to long-term poor health, delayed motor development, impaired cognitive function, and decreased immunity.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5588/c/2"},"text":"Pub. L. 117–263, § 5588(c)(2)","children":[],"tail":", redesignated par. (11) as (12). Former par. (12) redesignated (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"t