{"tag":"section","attrib":{"id":"id91074ee8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8604"},"text":null,"children":[{"tag":"num","attrib":{"value":"8604"},"text":"§ 8604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports required","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91074ee9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on Israel’s qualitative military edge (QME)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91074eea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8604/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2012-07-27"},"text":"July 27, 2012","children":[],"tail":", the President shall submit to the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives a report on the status of Israel’s qualitative military edge in light of current trends and instability in the region."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074eeb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8604/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substitution for quadrennial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If submitted within one year of the date that the first quadrennial report required by section 201(c)(2) of the Naval Vessel Transfer Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/429"},"text":"Public Law 110–429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2776"},"text":"22 U.S.C. 2776","children":[],"tail":" note) is due to be submitted, the report required by paragraph (1) may substitute for such quadrennial report."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91074eec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on other matters","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2012-07-27"},"text":"July 27, 2012","children":[],"tail":", the President shall submit to the appropriate congressional committees a report on each of the following matters:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id91074eed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8604/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Taking into account the Government of Israel’s urgent requirement for F–35 aircraft, actions to improve the process relating to its purchase of F–35 aircraft, particularly with respect to cost efficiency and timely delivery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074eee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8604/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Efforts to expand cooperation between the United States and Israel in homeland security, counter-terrorism, maritime security, energy, cyber-security, and other related areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074eef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8604/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Actions to integrate Israel into the defense of the Eastern Mediterranean.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91074ef0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/150/s6"},"text":"Pub. L. 112–150, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-27"},"text":"July 27, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1148"},"text":"126 Stat. 1148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91074ef1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id91074ef2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id91074ef3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Certain Functions Under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/150/s6"},"text":"Section 6 of Public Law 112–150","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2013-01-15"},"text":"Jan. 15, 2013","children":[],"tail":", 78 F.R. 5705, provided that:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby delegate to you all functions conferred upon the President by subsections (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/112/150/s6"},"text":"section 6 of Public Law 112–150","children":[],"tail":". You will exercise these functions in coordination with the Secretary of Defense."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Barack Obama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
