{"tag":"section","attrib":{"id":"id8eb0dac6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–23"},"text":null,"children":[{"tag":"num","attrib":{"value":"277d–23"},"text":"§ 277d–23.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation; exclusion from gross income","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No amount received as an award under subsection a. and subsections b. (1) and (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s277d–19"},"text":"section 277d–19 of this title","children":[],"tail":" shall be included in gross income for purposes of chapter 1 of title 26. However, amounts received under subsection b. (1) shall be included in gross income to the extent that such amounts are not used within one year of the receipt thereof to purchase replacement housing or facilities."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eb0dac7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/300/s7"},"text":"Pub. L. 88–300, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-04-29"},"text":"Apr. 29, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/186"},"text":"78 Stat. 186","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eb0dac8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eb0dac9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8eb0daca-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”, which for purposes of codification was translated as “title 26” thus requiring no change in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
