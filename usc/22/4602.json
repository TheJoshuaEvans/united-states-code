{"tag":"section","attrib":{"id":"id907a9f18-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4602"},"text":null,"children":[{"tag":"num","attrib":{"value":"4602"},"text":"§ 4602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id907a9f19-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4602/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Institute” means the United States Institute of Peace established by this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907a9f1a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4602/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Board” means the Board of Directors of the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907a9f1b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXVII/s1703"},"text":"Pub. L. 98–525, title XVII, § 1703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2651"},"text":"98 Stat. 2651","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
