{"tag":"section","attrib":{"id":"id90a5a730-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6032"},"text":null,"children":[{"tag":"num","attrib":{"value":"6032"},"text":"§ 6032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of economic embargo of Cuba","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90a5a731-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a5a732-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6032/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions by other countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress hereby reaffirms section 1704(a) of the Cuban Democracy Act of 1992 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6003/a"},"text":"22 U.S.C. 6003(a)","children":[],"tail":"], which states that the President should encourage foreign countries to restrict trade and credit relations with Cuba in a manner consistent with the purposes of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6001"},"text":"22 U.S.C. 6001","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a7f023-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6032/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions on other countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress further urges the President to take immediate steps to apply the sanctions described in section 1704(b)(1) of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6003/b/1"},"text":"22 U.S.C. 6003(b)(1)","children":[],"tail":"] against countries assisting Cuba."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a7f024-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diplomatic efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State should ensure that United States diplomatic personnel abroad understand and, in their contacts with foreign officials, are communicating the reasons for the United States economic embargo of Cuba, and are urging foreign governments to cooperate more effectively with the embargo.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a7f025-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6032/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall instruct the Secretary of the Treasury and the Attorney General to enforce fully the Cuban Assets Control Regulations set forth in part 515 of title 31, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a7f026-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6032/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a7f027-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6032/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of visas to certain Cuban nationals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that the President should instruct the Secretary of State and the Attorney General to enforce fully existing regulations to deny visas to Cuban nationals considered by the Secretary of State to be officers or employees of the Cuban Government or of the Communist Party of Cuba.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a7f028-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6032/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":", (g) Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a7f029-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6032/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Codification of economic embargo","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The economic embargo of Cuba, as in effect on ","children":[{"tag":"date","attrib":{"date":"1996-03-01"},"text":"March 1, 1996","children":[],"tail":", including all restrictions under part 515 of title 31, Code of Federal Regulations, shall be in effect on "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"March 12, 1996","children":[],"tail":", and shall remain in effect, subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6064"},"text":"section 6064 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90a7f02a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114/tI/s102"},"text":"Pub. L. 104–114, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/792"},"text":"110 Stat. 792","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90a7f02b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90a7f02c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90a7f02d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Cuban Democracy Act of 1992, referred to in subsec. (a), is title XVII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2575"},"text":"106 Stat. 2575","children":[],"tail":", which is classified principally to chapter 69 (§ 6001 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6001"},"text":"section 6001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90a7f02e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114/s102"},"text":"section 102 of Pub. L. 104–114","children":[],"tail":". Subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/114/s102"},"text":"section 102 of Pub. L. 104–114","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4315"},"text":"section 4315 of Title 50","children":[],"tail":", War and National Defense. Subsecs. (f) and (g) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/114/s102"},"text":"section 102 of Pub. L. 104–114","children":[],"tail":" amended sections 6003 and 6004 of this title, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
