{"tag":"section","attrib":{"id":"id8f74521a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2284"},"text":null,"children":[{"tag":"num","attrib":{"value":"2284"},"text":"§ 2284.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible countries","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order for a foreign country to be eligible to participate in a debt-for-nature exchange under this part, the Administrator of the Agency for International Development shall determine that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f74521b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2284/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the host country is fully committed to the long-term viability of the program or project that is to be undertaken through the debt-for-nature exchange;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f74521c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2284/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a long-term plan has been prepared by the host country, or private conservation group, which adequately provides for the long-term viability of the program or project that is to be undertaken through the debt-for-nature exchange or that such a plan will be prepared in a timely manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f74521d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2284/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a government agency or a local nongovernmental organization, or combination thereof, in the host country with the capability, commitment, and record of environmental concern to oversee the long-term viability of the program or project that is to be undertaken through the debt-for-nature exchange.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f74521e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 464 [474], as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tVII/s711"},"text":"Pub. L. 101–240, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2522"},"text":"103 Stat. 2522","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f74521f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f745220-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f745221-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s464"},"text":"section 464 of Pub. L. 87–195","children":[],"tail":" is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2274"},"text":"section 2274 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
