{"tag":"section","attrib":{"id":"id8e8f7017-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262h"},"text":null,"children":[{"tag":"num","attrib":{"value":"262h"},"text":"§ 262h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opposition by United States Executive Directors of international financial institutions to assistance for production or extraction of export commodities or minerals in surplus on world markets","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Directors of the International Bank for Reconstruction and Development, the International Development Association, the International Finance Corporation, the Inter-American Development Bank, the International Monetary Fund, the Asian Development Bank, the Inter-American Investment Corporation, the African Development Bank, and the African Development Fund to use the voice and vote of the United States to oppose any assistance by such institutions, using funds appropriated or otherwise made available pursuant to any provision of law, for the production or extraction of any commodity or mineral for export, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e8f7018-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such commodity or mineral, as the case may be, is in surplus on world markets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e8f7019-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the export of such commodity or mineral, as the case may be, would cause substantial injury to the United States producers of the same, similar, or competing commodity or mineral.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e8f701a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/472/s22"},"text":"Pub. L. 99–472, § 22","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-15"},"text":"Oct. 15, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1210"},"text":"100 Stat. 1210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e8f701b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e8f701c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"id8e8f701d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/dF/tVII/s7025/c"},"text":"Pub. L. 118–47, div. F, title VII, § 7025(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/775"},"text":"138 Stat. 775","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/47/dF/tVII/s7025/c"},"text":"“The Secretary of the Treasury shall instruct the United States executive director of each international financial institution to use the voice and vote of the United States to oppose any assistance by such institution, using funds appropriated or otherwise made available by this Act [div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47"},"text":"Pub. L. 118–47","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/729"},"text":"138 Stat. 729","children":[],"tail":", see Tables for classification], for the production or extraction of any commodity or mineral for export, if it is in surplus on world markets and if the assistance will cause substantial injury to United States producers of the same, similar, or competing commodity.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dK/tVII/s7025/c"},"text":"Pub. L. 117–328, div. K, title VII, § 7025(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5018"},"text":"136 Stat. 5018","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dK/tVII/s7025/c"},"text":"Pub. L. 117–103, div. K, title VII, § 7025(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/609"},"text":"136 Stat. 609","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dK/tVII/s7025/c"},"text":"Pub. L. 116–260, div. K, title VII, § 7025(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1736"},"text":"134 Stat. 1736","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dG/tVII/s7025/c"},"text":"Pub. L. 116–94, div. G, title VII, § 7025(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"tex