{"tag":"section","attrib":{"id":"id8ed700c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"287e–2"},"text":"§ 287e–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for goods and services provided by the United States to the United Nations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ed700c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to obtain reimbursement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ed700c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), the President shall seek and obtain in a timely fashion a commitment from the United Nations to provide reimbursement to the United States from the United Nations whenever the United States Government furnishes assistance pursuant to the provisions of law described in subsection (c)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ed700c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the United Nations when the assistance is designed to facilitate or assist in carrying out an assessed peacekeeping operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ed700c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any United Nations peacekeeping operation that is authorized by the United Nations Security Council under Chapter VI or Chapter VII of the United Nations Charter and paid for by peacekeeping or regular budget assessment of the United Nations members; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ed700c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any country participating in any operation authorized by the United Nations Security Council under Chapter VI or Chapter VII of the United Nations Charter and paid for by peacekeeping assessments of United Nations members when the assistance is designed to facilitate or assist the participation of that country in the operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ed700c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ed700c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirement in paragraph (1) shall not apply to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8ed700c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" goods and services provided to the United States Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ed700ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance having a value of less than $3,000,000 per fiscal year per operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ed700cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance furnished before ","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"November 29, 1999","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ed700cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" salaries and expenses of civilian police and other civilian and military monitors where United Nations policy is to require payment by contributing members for similar assistance to United Nations peacekeeping operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ed700cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any assistance commitment made before ","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"November 29, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ed700ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployments of United States military forces","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of subsection (d)(1)(B) shall not apply to the deployment of United States military forces when the President determines that such deployment is important to the security interests of the United States. The cost of such deployment shall be included in the data provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2348d"},"text":"section 2348d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ed700cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ed700d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any reimbursement under this subsection shall be determined at the usual rate established by the United Nations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ed700d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Reimbursement under this subsection may include credits against the United States assessed contributions for United Nations peacekeeping operations, if the expenses incurred by any United States department or agency providing the assistance have first been reimbursed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ed700d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of reimbursements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ed700d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of any reimbursement paid the United States under subsection (a) shall be credited to the current applicable appropriation, fund, or account of the United States department or agency providing the assistance for which the reimbursement is paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ed700d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts credited under paragraph (1) shall be merged with the appropriations, or with appropriations in the fund or account, to which credited and shall be available for the same purposes, and subject to the same conditions and limitations, as the appropriations with which merged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ed700d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) applies to assistance provided under the following provisions of law:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ed700d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 287d and 287d–1 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ed700d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 2261, 2318(a)(1), 2321j, 2348a(c), and 2357 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ed700d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other provisions of law pursuant to which assistance is provided by the United States to carry out the mandate of an assessed United Nations peacekeeping operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ed700d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ed700da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ed700db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may authorize the furnishing of assistance covered by this section without regard to subsection (a) if the President determines, and so notifies in writing the Committee on Foreign Relations of the Senate and the Speaker of the House of Representatives, that to do so is important to the security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ed700dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When exercising the authorities of subparagraph (A), the President shall notify the Committee on Foreign Relations of the Senate and the Committee on International Relations of the House of Representatives in accordance with the procedures applicable to reprogramming notifications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394–1"},"text":"section 2394–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ed700dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding a notice under paragraph (1) with respect to assistance covered by this section, subsection (a) shall apply to the furnishing of the assistance if, not later than 15 calendar days after receipt of a notification under that paragraph, the Congress enacts a joint resolution disapproving the determination of the President contained in the notification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ed700de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any joint resolution described in paragraph (2) shall be considered in the Senate in accordance with the provisions of section 601(b) of the International Security Assistance and Arms Export Control Act of 1976.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ed700df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other reimbursement authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall preclude the President from seeking reimbursement for assistance covered by this section that is in addition to the reimbursement sought for the assistance under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ed700e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287e–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “assistance” includes personnel, services, supplies, equipment, facilities, and other assistance if such assistance is provided by the Department of Defense or any other United States Government agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ed700e1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-12-20/ch583/s10"},"text":"Dec. 20, 1945, ch. 583, § 10","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tVII/s723"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title VII, § 723]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–463.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ed700e2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ed700e3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ed700e4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 601(b) of the International Security Assistance and Arms Export Control Act of 1976, referred to in subsec. (d)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329/s601/b"},"text":"section 601(b) of Pub. L. 94–329","children":[],"tail":", title VI, "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/765"},"text":"90 Stat. 765","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ed700e5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id8ed700e6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
