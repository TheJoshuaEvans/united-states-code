{"tag":"section","attrib":{"id":"id90deded5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7501"},"text":null,"children":[{"tag":"num","attrib":{"value":"7501"},"text":"§ 7501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter, the term “Government of Afghanistan” includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90deded6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of any political subdivision of Afghanistan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90deded7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any agency or instrumentality of the Government of Afghanistan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90deded8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/327/s1/c"},"text":"Pub. L. 107–327, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-04"},"text":"Dec. 4, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2797"},"text":"116 Stat. 2797","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90deded9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90dededa-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id90dededb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVII/s7104/a"},"text":"Pub. L. 108–458, title VII, § 7104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3780"},"text":"118 Stat. 3780","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/458/tVII/s7104/a"},"text":"“This section [enacting sections 7536a and 7555 of this title, amending sections 7513, 7514, 7518, 7536, 7537, 7538, and 7554 of this title, repealing ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2374"},"text":"section 2374 of this title","children":[],"tail":", and enacting provisions set out as notes under sections 7511, 7513, 7514, and 7536 of this title] may be cited as the ‘Afghanistan Freedom Support Act Amendments of 2004’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id90dededc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/327/s1/a"},"text":"Pub. L. 107–327, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-04"},"text":"Dec. 4, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2797"},"text":"116 Stat. 2797","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/327/s1/a"},"text":"“This Act [enacting this chapter] may be cited as the ‘Afghanistan Freedom Support Act of 2002’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
