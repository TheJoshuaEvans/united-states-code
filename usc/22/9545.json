{"tag":"section","attrib":{"id":"id913256a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9545"},"text":null,"children":[{"tag":"num","attrib":{"value":"9545"},"text":"§ 9545.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on Russian Federation influence on elections in Europe and Eurasia","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id913256a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9545/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2017-08-02"},"text":"August 2, 2017","children":[],"tail":", and annually thereafter, the President shall submit to the appropriate congressional committees and leadership a report on funds provided by, or funds the use of which was directed by, the Government of the Russian Federation or any Russian person with the intention of influencing the outcome of any election or campaign in any country in Europe or Eurasia during the preceding year, including through direct support to any political party, candidate, lobbying campaign, nongovernmental organization, or civic organization."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id913256aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9545/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report required by subsection (a) shall be submitted in unclassified form but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id913256ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9545/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id913256ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9545/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees and leadership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees and leadership” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id913256ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9545/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on Banking, Housing, and Urban Affairs, the Committee on Armed Services, the Committee on Homeland Security and Governmental Affairs, the Committee on Appropriations, the Select Committee on Intelligence, and the majority and minority leaders of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9545/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs, the Committee on Financial Services, the Committee on Armed Services, the Committee on Homeland Security, the Committee on Appropriations, the Permanent Select Committee on Intelligence, and the Speaker, the majority leader, and the minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9545/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Russian person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Russian person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id913256b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9545/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is a citizen or national of the Russian Federation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9545/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity organized under the laws of the Russian Federation or otherwise subject to the jurisdiction of the Government of the Russian Federation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id913256b2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tII/s256"},"text":"Pub. L. 115–44, title II, § 256","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/930"},"text":"131 Stat. 930","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
