{"tag":"section","attrib":{"id":"id8f93735e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2347f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2347f"},"text":"§ 2347f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The selection of foreign personnel for training under this part shall be made in consultation with the United States defense attache to the relevant country.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f93735f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 547, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/280/tII/s202"},"text":"Pub. L. 106–280, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-06"},"text":"Oct. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/851"},"text":"114 Stat. 851","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
