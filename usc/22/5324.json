{"tag":"section","attrib":{"id":"id9088f788-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5324"},"text":null,"children":[{"tag":"num","attrib":{"value":"5324"},"text":"§ 5324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9088f789-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5324/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing growth in the developing world is a major goal of international economic policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9088f78a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5324/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is necessary to broaden the range of options in dealing with the debt problem to include improved mechanisms to restructure existing debt;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9088f78b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5324/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" active consideration of a new multilateral authority to improve the management of the debt problem and to share the burdens of adjustment more equitably must be undertaken; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9088f78c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5324/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" countries with strong current account surpluses bear a major responsibility for providing the financial resources needed for growth in the developing world.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9088f78d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIII/s3104"},"text":"Pub. L. 100–418, title III, § 3104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1376"},"text":"102 Stat. 1376","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
