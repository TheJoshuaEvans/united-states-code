{"tag":"section","attrib":{"id":"id90f91e41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401"},"text":null,"children":[{"tag":"num","attrib":{"value":"8401"},"text":"§ 8401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f91e42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this chapter, the term “appropriate congressional committees” means the Committees on Appropriations and Foreign Relations of the Senate and the Committees on Appropriations and Foreign Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e43-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counterinsurgency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “counterinsurgency” means efforts to defeat organized movements that seek to overthrow the duly constituted Governments of Pakistan and Afghanistan through violent means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counterterrorism","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “counterterrorism” means efforts to combat al Qaeda and other foreign terrorist organizations that are designated by the Secretary of State in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1189"},"text":"section 1189 of title 8","children":[],"tail":", or other individuals and entities engaged in terrorist activity or support for such activity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f91e45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FATA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “FATA” means the Federally Administered Tribal Areas of Pakistan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb6736-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frontier Crimes Regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Frontier Crimes Regulation” means the Frontier Crimes Regulation, codified under British law in 1901, and applicable to the FATA.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb6737-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impact evaluation research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “impact evaluation research” means the application of research methods and statistical analysis to measure the extent to which change in a population-based outcome can be attributed to program intervention instead of other environmental factors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb6738-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Major defense equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “major defense equipment” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2794/6"},"text":"section 2794(6) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb6739-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NWFP","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “NWFP” means the North West Frontier Province of Pakistan, which has Peshawar as its provincial capital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb673a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operations research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “operations research” means the application of social science research methods, statistical analysis, and other appropriate scientific methods to judge, compare, and improve policies and program outcomes, from the earliest stages of defining and designing programs through their development and implementation, with the objective of the rapid dissemination of conclusions and concrete impact on programming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb673b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security forces of Pakistan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “security forces of Pakistan” means the military and intelligence services of the Government of Pakistan, including the Armed Forces, Inter-Services Intelligence Directorate, Intelligence Bureau, police forces, levies, Frontier Corps, and Frontier Constabulary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb673c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security-related assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “security-related assistance”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90fb673d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90fb673e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/11/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant assistance to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2763"},"text":"section 2763 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90fb673f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/11/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance under chapter 2 of part II of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2311"},"text":"22 U.S.C. 2311","children":[],"tail":" et. seq "},{"tag":"ref","attrib":{"idref":"fn002402"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002402"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “et seq.”."}],"tail":"); but"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90fb6740-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90fb6741-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/11/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance authorized to be appropriated or otherwise made available under any provision of law that is funded from accounts within budget function 050 (National Defense); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90fb6742-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8401/11/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts appropriated or otherwise available to the Pakistan Counterinsurgency Capability Fund established under the Supplemental Appropriations Act, 2009 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/32"},"text":"Public Law 111–32","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90fb6743-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/73/s2"},"text":"Pub. L. 111–73, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-15"},"text":"Oct. 15, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2060"},"text":"123 Stat. 2060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90fb6744-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90fb6745-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90fb6746-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in par. (11)(A)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Chapter 2 of part II of the Act is classified generally to part II (§ 2311 et seq.) of subchapter II of chapter 32 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Supplemental Appropriations Act, 2009, referred to in par. (11)(B)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/32"},"text":"Pub. L. 111–32","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-24"},"text":"June 24, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1859"},"text":"123 Stat. 1859","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90fb6747-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id90fb6748-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/73/s1/a"},"text":"Pub. L. 111–73, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-15"},"text":"Oct. 15, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2060"},"text":"123 Stat. 2060","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/73/s1/a"},"text":"“This Act [enacting this chapter] may be cited as the ‘Enhanced Partnership with Pakistan Act of 2009’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
