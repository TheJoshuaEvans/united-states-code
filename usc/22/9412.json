{"tag":"section","attrib":{"id":"id9128b996-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9412"},"text":null,"children":[{"tag":"num","attrib":{"value":"9412"},"text":"§ 9412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on Iranian expenditures supporting foreign military and terrorist activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9128b997-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002443"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002443"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There is no subsec. (b)."}],"tail":" Report"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9128b998-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9412/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Director of National Intelligence shall submit to the congressional intelligence committees a report describing Iranian expenditures in the previous calendar year on military and terrorist activities outside the country, including each of the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9128b999-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9412/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount spent in such calendar year on activities by the Islamic Revolutionary Guard Corps, including activities providing support for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9128b99a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9412/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hizballah;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9128b99b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9412/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Houthi rebels in Yemen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9128b99c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9412/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hamas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9128b99d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9412/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proxy forces in Iraq and Syria; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9128b99e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9412/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity or country the Director determines to be relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9128b99f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9412/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount spent in such calendar year for ballistic missile research and testing or other activities that the Director determines are destabilizing to the Middle East region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b9a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9412/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required under subsection (a) ","children":[{"tag":"ref","attrib":{"idref":"fn002444"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002444"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “paragraph (1)”."}],"tail":" shall be submitted in unclassified form, but may include a classified annex."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9128b9a1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dE/tLXVII/s6705"},"text":"Pub. L. 116–92, div. E, title LXVII, § 6705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2224"},"text":"133 Stat. 2224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dF/tLXIX/s6901/a"},"text":"Pub. L. 118–159, div. F, title LXIX, § 6901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2516"},"text":"138 Stat. 2516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dF/tLXVIII/s6801/b/4"},"text":"Pub. L. 119–60, div. F, title LXVIII, § 6801(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1653"},"text":"139 Stat. 1653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9128b9a2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9128b9a3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9128b9a4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Damon Paul Nelson and Matthew Young Pollard Intelligence Authorization Act for Fiscal Years 2018, 2019, and 2020, and also as part of the National Defense Authorization Act for Fiscal Year 2020, and not as part of the Countering Iran’s Destabilizing Activities Act of 2017 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9128b9a5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s6801/b/4/A"},"text":"Pub. L. 119–60, § 6801(b)(4)(A)","children":[],"tail":", struck out “and annual briefing” before “on Iranian expenditures” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s6801/b/4/B"},"text":"Pub. L. 119–60, § 6801(b)(4)(B)","children":[],"tail":", struck out subsec. (b). Prior to amendment, text of subsec. (b) read as follows: “Following the submission of the report under subsection (a), the Director shall annually provide a briefing to the congressional intelligence committees on the information described in such subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" struck out “, and not less frequently than once each year thereafter provide a briefing to Congress,” after “a report” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9128b9a6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9128b9a7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continued Congressional Oversight of Iranian Expenditures Supporting Foreign Military and Terrorist Activities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dF/tLXIV/s6436"},"text":"Pub. L. 118–159, div. F, title LXIV, § 6436","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2492"},"text":"138 Stat. 2492","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dF/tLXIV/s6436"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Appropriate Committees of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘appropriate committees of Congress’ means—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the congressional intelligence committees [Select Committee on Intelligence of the Senate and Permanent Select Committee on Intelligence of the House of Representatives];","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on the Judiciary, and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs, the Committee on the Judiciary, and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Update Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], the Director of National Intelligence shall submit to the appropriate committees of Congress an update to the report submitted under section 6705 of the Damon Paul Nelson and Matthew Young Pollard Intelligence Authorization Act for Fiscal Years 2018, 2019, and 2020 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9412"},"text":"22 U.S.C. 9412","children":[],"tail":") to reflect current occurrences, circumstances, and expenditures."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The update submitted pursuant to subsection (b) shall be submitted in unclassified form, but may include a classified annex.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id9128b9a8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Congressional intelligence committees” means the Select Committee on Intelligence of the Senate and the Permanent Select Committee on Intelligence of the House of Representatives, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s5003"},"text":"section 5003 of Pub. L. 116–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
