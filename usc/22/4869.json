{"tag":"section","attrib":{"id":"id90868552-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4869"},"text":null,"children":[{"tag":"num","attrib":{"value":"4869"},"text":"§ 4869.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counter-intelligence training for certain Diplomatic Security special agents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90868553-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4869/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Diplomatic Security special agents who are assigned to positions with a primary counterintelligence role or a diplomatic post rated as High or Critical for Human Intelligence on the Department of State’s Security Environment Threat List shall receive specific and substantive mandatory counter-intelligence training that is developed and conducted in consultation with the heads of relevant elements of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90868554-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4869/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence community defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “intelligence community” has the meaning given that term in 3003(4) of title 50.”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90868555-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIV"},"text":"Pub. L. 99–399, title IV","children":[],"tail":", §418, as added "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tV/s5504/a"},"text":"Pub. L. 119–60, div. E, title V, § 5504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1600"},"text":"139 Stat. 1600","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
