{"tag":"section","attrib":{"id":"id8fd3b0a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2522"},"text":null,"children":[{"tag":"num","attrib":{"value":"2522"},"text":"§ 2522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fd3b0a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2522/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “abroad” means any area outside the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd3b0a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2522/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “function” includes any duty, obligation, right, power, authority, responsibility, privilege, discretion, activity, and program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd3b0a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2522/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “health care” includes all appropriate examinations, preventive, curative and restorative health and medical care, and supplementary services when necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd3b0aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2522/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “medical officer” means a physician, nurse practitioner, physician’s assistant, or registered nurse with the professional qualifications, expertise, and abilities consistent with the needs of the Peace Corps and the post to which he or she is assigned, as determined by the Director of the Peace Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd3b0ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2522/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The word “transportation” in sections 2504(b), 2504(m),","children":[{"tag":"ref","attrib":{"idref":"fn002177"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002177"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. See References in Text note below."}],"tail":" and 2505(2) of this title includes transportation of not to exceed three hundred pounds per person of unaccompanied necessary personal and household effects."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd3b0ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2522/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States” means the several States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd3b0ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2522/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States Government agency” includes any department, board, wholly or partly owned corporation, or instrumentality, commission, or establishment of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fd3b0ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2522/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this chapter or any other Act, the period of any individual’s service as a volunteer under this chapter shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8fd3b0af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2522/8/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except for the purposes of section 2504(f) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, any period of training under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2507/a"},"text":"section 2507(a) of this title","children":[],"tail":" prior to enrollment as a volunteer under this chapter; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fd3b0b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2522/8/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period between enrollment as a volunteer and the termination of service as such volunteer by the President or by death or resignation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fd3b0b1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/tI/s26"},"text":"Pub. L. 87–293, title I, § 26","children":[],"tail":", formerly § 25, "},{"tag":"date","attrib":{"date":"1961-09-22"},"text":"Sept. 22, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/624"},"text":"75 Stat. 624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/572/s4"},"text":"Pub. L. 89–572, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-13"},"text":"Sept. 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/765"},"text":"80 Stat. 765","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/352/s8"},"text":"Pub. L. 91–352, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-07-24"},"text":"July 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/465"},"text":"84 Stat. 465","children":[],"tail":"; renumbered § 26, "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tXI/s1105/a/1"},"text":"Pub. L. 99–83, title XI, § 1105(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/276"},"text":"99 Stat. 276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/256/tIII/s306"},"text":"Pub. L. 115–256, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-09"},"text":"Oct. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3659"},"text":"132 Stat. 3659","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fd3b0b2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fd3b0b3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8fd3b0b4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in introductory provisions and par. (8), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293"},"text":"Pub. L. 87–293","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-22"},"text":"Sept. 22, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/612"},"text":"75 Stat. 612","children":[],"tail":", known as the Peace Corps Act. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2501"},"text":"section 2501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2504/m"},"text":"Section 2504(m) of this title","children":[],"tail":", referred to in par. (5), was redesignated section 2504(n) by "},{"tag":"ref","attrib":{"href":"/us/pl/115/256/tI/s101/a/1/B"},"text":"Pub. L. 115–256, title I, § 101(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-09"},"text":"Oct. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3651"},"text":"132 Stat. 3651","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2504/f"},"text":"Section 2504(f) of this title","children":[],"tail":", referred to in par. (8)(i), was redesignated section 2504(g) by "},{"tag":"ref","attrib":{"href":"/us/pl/115/256/tI/s101/a/1/B"},"text":"Pub. L. 115–256, title I, § 101(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-09"},"text":"Oct. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3651"},"text":"132 Stat. 3651","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8fd3b0b5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/s26"},"text":"section 26 of Pub. L. 87–293","children":[],"tail":" was renumbered section 27 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2523"},"text":"section 2523 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fd3b0b6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/256"},"text":"Pub. L. 115–256","children":[],"tail":" inserted introductory provisions, redesignated subsecs. (a), (b), (c), (d), (e), (f), and (g) as pars. (1), (6), (2), (3), (8), (7), and (5), respectively, so as to appear in numerical order, realigned margins, and added par. (4) defining “medical officer” after par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/352"},"text":"Pub. L. 91–352","children":[],"tail":" inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2504/m"},"text":"section 2504(m) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/572"},"text":"Pub. L. 89–572","children":[],"tail":" struck out territories from definition of “United States”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
