{"tag":"section","attrib":{"id":"id8eb807c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283k"},"text":null,"children":[{"tag":"num","attrib":{"value":"283k"},"text":"§ 283k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eb807c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital stock of Inter-American Development Bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated, without fiscal year limitation, for payment of the increased United States subscription to the capital stock of the Inter-American Development Bank, $411,760,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eb807c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund for Special Operations of the Inter-American Development Bank","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated, for payment of the increased United States subscription to the Fund for Special Operations of the Inter-American Development Bank, $50,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eb807c3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/259/s2"},"text":"Pub. L. 88–259, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-01-22"},"text":"Jan. 22, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/