{"tag":"section","attrib":{"id":"id8ff2d121-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2672b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2672b"},"text":"§ 2672b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of Alternate United States Commissioners; travel expenses and other allowances","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Alternate United States Commissioners shall receive no compensation for their services. They may be paid travel expenses and per diem in lieu of subsistence at the rates authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" when engaged in the performance of their duties."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ff2d122-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/471/tII/s202"},"text":"Pub. L. 92–471, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-09"},"text":"Oct. 9, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/787"},"text":"86 Stat. 787","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
