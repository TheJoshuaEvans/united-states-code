{"tag":"section","attrib":{"id":"id8f686b70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2211c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2211c"},"text":"§ 2211c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Poverty measurement methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator of the Agency, in consultation with financial intermediaries and other appropriate organizations, should have in place at least 1 method for implementing partners to use to assess poverty levels of their current incoming or prospective clients.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f686b71-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 254, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/484/s3"},"text":"Pub. L. 108–484, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3926"},"text":"118 Stat. 3926","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/428/s4/d"},"text":"Pub. L. 115–428, § 4(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5514"},"text":"132 Stat. 5514","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f686b72-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f686b73-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f686b74-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/428"},"text":"Pub. L. 115–428","children":[],"tail":" amended section generally. Prior to amendment, section related to development of poverty measurement methods and application of methods."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
