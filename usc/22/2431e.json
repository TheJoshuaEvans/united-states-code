{"tag":"section","attrib":{"id":"id8fbe5436-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2431e"},"text":"§ 2431e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of debt owed to United States as result of credits extended under title I of Food for Peace Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fbe5437-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to reduce debt","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe5438-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the President may reduce the amount owed to the United States (or any agency of the United States) that is outstanding as of ","children":[{"tag":"date","attrib":{"date":"2019-01-14"},"text":"January 14, 2019","children":[],"tail":", as a result of any credits extended under title I of the Food for Peace Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1701"},"text":"7 U.S.C. 1701","children":[],"tail":" et seq.) to a country eligible for benefits from the Facility."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5439-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe543a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the cost (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a/5"},"text":"section 661a(5) of title 2","children":[],"tail":") for the reduction of any debt pursuant to this section, there are authorized to be appropriated to the President—"}],"tail":null},{"tag":"clause","attrib":{"id":"id8fbe543b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 1999;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fbe543c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fbe543d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2001.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe543e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided by this section shall be available only to the extent that appropriations for the cost (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a/5"},"text":"section 661a(5) of title 2","children":[],"tail":") of the modification of any debt pursuant to this section are made in advance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe543f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of debt reduction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe5440-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any debt reduction pursuant to subsection (a) shall be accomplished at the direction of the Facility by the exchange of a new obligation for obligations of the type referred to in subsection (a) outstanding as of the date specified in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5441-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of obligations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe5442-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Facility shall notify the Commodity Credit Corporation of an agreement entered into under paragraph (1) with an eligible country to exchange a new obligation for outstanding obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe5443-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the direction of the Facility, the old obligations that are the subject of the agreement shall be canceled and a new debt obligation shall be established for the country relating to the agreement, and the Commodity Credit Corporation shall make an adjustment in its accounts to reflect the debt reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe5444-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional terms and conditions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe5445-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following additional terms and conditions shall apply to the reduction of debt under subsection (a)(1) in the same manner as such terms and conditions apply to the reduction of debt under section 604(a)(1) of the Food for Peace Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738c/a/1"},"text":"7 U.S.C. 1738c(a)(1)","children":[],"tail":"]:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe5446-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions relating to repayment of principal under section 605 of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738d"},"text":"7 U.S.C. 1738d","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe5447-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions relating to interest on new obligations under section 606 of such Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738e"},"text":"7 U.S.C. 1738e","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5448-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the application of the provisions relating to repayment of principal under section 605 of the Food for Peace Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738d"},"text":"7 U.S.C. 1738d","children":[],"tail":"] to the reduction of debt under subsection (a)(1) (in accordance with paragraph (1)(A) of this subsection), repayment of principal on a new obligation established under subsection (b) may be made in the local currency of the beneficiary country and deposited in the Conservation Fund of the country in the same manner as the provisions relating to payment of interest on new obligations under section 606 of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738e"},"text":"7 U.S.C. 1738e","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbe5449-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. V, § 807, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/214/s1"},"text":"Pub. L. 105–214, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/888"},"text":"112 Stat. 888","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/323/s3/b"},"text":"Pub. L. 108–323, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-06"},"text":"Oct. 6, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1219"},"text":"118 Stat. 1219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/b/1"},"text":"Pub. L. 110–246, title III, § 3001(b)(1)","children":[],"tail":", (2)(Q), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1820"},"text":"122 Stat. 1820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/440"},"text":"Pub. L. 115–440","children":[],"tail":", §§ 6, 9(b)(3), "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5582"},"text":"132 Stat. 5582","children":[],"tail":", 5584.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fbe544a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fbe544b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8fbe544c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food for Peace Act, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"act July 10, 1954, ch. 469","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/454"},"text":"68 Stat. 454","children":[],"tail":". Title I of the Act is classified generally to subchapter II (§ 1701 et seq.) of chapter 41 of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fbe544d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s6"},"text":"Pub. L. 115–440, § 6","children":[],"tail":", substituted “outstanding as of "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"January 14, 2019","children":[],"tail":",” for “outstanding as of "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s9/b/3"},"text":"Pub. L. 115–440, § 9(b)(3)","children":[],"tail":", substituted “Conservation Fund” for “Tropical Forest Fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" substituted “Food for Peace Act” for “Agricultural Trade Development and Assistance Act of 1954” in section catchline and wherever appearing in subsecs. (a)(1) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/323"},"text":"Pub. L. 108–323","children":[],"tail":" designated existing provisions as par. (1), redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1), and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fbe544e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8fbe544f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8fbe5450-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8fbe5451-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under subsec. (a) of this section, see section 1 of Ex. Ord. No. 13345, ","children":[{"tag":"date","attrib":{"date":"2004-07-08"},"text":"July 8, 2004","children":[],"tail":", 69 F.R. 41901, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738"},"text":"section 1738 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
