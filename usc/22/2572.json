{"tag":"section","attrib":{"id":"id8fd62110-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2572"},"text":null,"children":[{"tag":"num","attrib":{"value":"2572"},"text":"§ 2572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patents; availability to general public; protection of background rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All research within the United States contracted for, sponsored, cosponsored, or authorized under authority of this chapter, shall be provided for in such manner that all information as to uses, products, processes, patents, and other developments resulting from such research developed by Government expenditure will (with such exceptions and limitations, if any, as the Secretary of State may find to be necessary in the public interest) be available to the general public. This section shall not be so construed as to deprive the owner of any background patent relating thereto of such rights as he may have thereunder.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8fd62111-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/297/tIII/s302"},"text":"Pub. L. 87–297, title III, § 302","children":[],"tail":", formerly § 32, "},{"tag":"date","attrib":{"date":"1961-09-26"},"text":"Sept. 26, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/634"},"text":"75 Stat. 634","children":[],"tail":"; renumbered § 302 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XII, § 1223(7), (21), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-769"},"text":"112 Stat. 2681–769","children":[],"tail":", 2681–772.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fd62112-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fd62113-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fd62114-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1223/7"},"text":"Pub. L. 105–277, § 1223(7)","children":[],"tail":", substituted “Secretary of State” for “Director” and “section” for “subsection”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fd62115-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8fd62116-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-04-01"},"text":"Apr. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1201"},"text":"section 1201 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6511"},"text":"section 6511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
