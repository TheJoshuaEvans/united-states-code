{"tag":"section","attrib":{"id":"id91218d7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b"},"text":null,"children":[{"tag":"num","attrib":{"value":"9221b"},"text":"§ 9221b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions with respect to foreign financial institutions that provide financial services to certain sanctioned persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91218d7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall impose one or more of the sanctions described in subsection (b) with respect to a foreign financial institution that the Secretary determines, in consultation with the Secretary of State, knowingly, on or after the date that is 120 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", provides significant financial services to any person designated for the imposition of sanctions with respect to North Korea under—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218d7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (a), (b), or (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9214"},"text":"section 9214 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable Executive order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d81-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable United Nations Security Council resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218d82-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sanctions that may be imposed with respect to a foreign financial institution subject to subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218d83-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset blocking","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may block and prohibit, pursuant to the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.), all transactions in all property and interests in property of the foreign financial institution if such property and interests in property are in the United States, come within the United States, or are or come within the possession or control of a United States person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on correspondent and payable-through accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prohibit, or impose strict conditions on, the opening or maintaining in the United States of a correspondent account or a payable-through account by the foreign financial institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218d85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation; penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218d86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may exercise all authorities provided under sections 203 and 205 of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1702"},"text":"50 U.S.C. 1702","children":[],"tail":" and 1704) to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person that violates, attempts to violate, conspires to violate, or causes a violation of this section or any regulation, license, or order issued to carry out this section shall be subject to the penalties set forth in subsections (b) and (c) of section 206 of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705"},"text":"50 U.S.C. 1705","children":[],"tail":") to the same extent as a person that commits an unlawful act described in subsection (a) of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218d88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the President shall, as appropriate, prescribe regulations to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218d89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception relating to importation of goods","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218d8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9254/b"},"text":"section 9254(b) of this title","children":[],"tail":" or any provision of this section, the authorities and requirements to impose sanctions under this section shall not include the authority or a requirement to impose sanctions on the importation of goods."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “good” means any article, natural or manmade substance, material, supply or manufactured product, including inspection and test equipment, and excluding technical data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218d8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218d8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Account; correspondent account; payable-through account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “account”, “correspondent account”, and “payable-through account” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5318A"},"text":"section 5318A of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d8e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign financial institution” has the meaning given that term in section 510.309 of title 31, Code of Federal Regulations (or any corresponding similar regulation or ruling).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d8f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Knowingly","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “knowingly”, with respect to conduct, a circumstance, or a result, means that a person has actual knowledge, or should have known, of the conduct, the circumstance, or the result.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91218d90-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tII/s201B"},"text":"Pub. L. 114–122, title II, § 201B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXI/s7121/a"},"text":"Pub. L. 116–92, div. F, title LXXI, § 7121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2245"},"text":"133 Stat. 2245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91218d91-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91218d92-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id91218d93-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsec. (b)(1), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id91218d94-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id91218d95-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions and authorities under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s7121"},"text":"section 7121 of Pub. L. 116–92","children":[],"tail":" with respect to this section delegated to Secretary of the Treasury, in consultation with the Secretary of State, by section 1(b)(iii) of Memorandum of President of the United States, "},{"tag":"date","attrib":{"date":"2020-02-21"},"text":"Feb. 21, 2020","children":[],"tail":", 85 F.R. 13717, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s286yy"},"text":"section 286yy of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
