{"tag":"section","attrib":{"id":"id91587c31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603"},"text":null,"children":[{"tag":"num","attrib":{"value":"10603"},"text":"§ 10603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governance of the Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91587c32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be in the Foundation an Executive Director, who shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91587c33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage the Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to, and be under the direct authority, of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91587c35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Directors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91587c36-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation shall be governed by a Board of Directors, which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c37-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall perform the functions specified to be carried out by the Board under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c38-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may prescribe, amend, and repeal bylaws, rules, regulations, and procedures governing the manner in which the business of the Foundation may be conducted and in which the powers granted to it by law may be exercised.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c39-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c3a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, the Administrator of the United States Agency for International Development, the Secretary of the Interior, the Chief of the United States Forest Service, and the head of one other relevant Federal department or agency, as determined by the Secretary, or the Senate-confirmed designees of such officials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c3b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 8 other individuals, who shall be appointed by the Secretary, in consultation with the members of the Board described in subparagraph (A), the Speaker and Minority Leader of the House of Representatives, and the President Pro Tempore and Minority Leader of the Senate, of whom—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91587c3c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members shall be private-sector donors making financial contributions to the Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c3d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members shall be independent experts who, in addition to meeting the qualification requirements described in paragraph (3), represent diverse points of view and diverse geographies, to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c3e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Board appointed pursuant to paragraph (2)(B) shall be knowledgeable and experienced in matters relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c3f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c40-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protected area management and the conservation of global biodiversity, fish and wildlife, ecosystem restoration, adaptation, and resilience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grantmaking in support of international conservation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political affiliation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 of the members appointed to the Board pursuant to paragraph (2)(B) may be affiliated with the same political party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c43-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual with business interests, financial holdings, or controlling interests in any entity that has sought support, or is receiving support, from the Foundation may not be appointed to the Board during the 5-year period immediately preceding such appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall elect, from among its members, a Chairperson, who shall serve for a 2-year term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms; vacancies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91587c47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of service of each member of the Board appointed pursuant to paragraph (2)(B) shall be not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial appointed directors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the initial members of the Board appointed pursuant to paragraph (2)(B)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id91587c49-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/7/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members, including at least 2 private-sector donors making financial contributions to the Foundation, shall serve for 4 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91587c4a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/7/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members shall serve for 5 years, as determined by the Chairperson of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c4b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any vacancy in the Board—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91587c4c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be filled in the manner in which the original appointment was made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not affect the power of the remaining appointed members of the Board to execute the duties of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c4e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the current membership of the Board, including the Secretary or the Secretary’s designee, shall constitute a quorum for the transaction of Foundation business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c50-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall meet not less frequently than annually at the call of the Chairperson. Such meetings may be in person, virtual, or hybrid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c51-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the Board is established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10602/a"},"text":"section 10602(a) of this title","children":[],"tail":", the Secretary of State shall convene a meeting of the ex-officio members of the Board and the appointed members of the Board to incorporate the Foundation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any member of the Board appointed pursuant to paragraph (2)(B) who misses 3 consecutive regularly scheduled meetings may be removed by a majority vote of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of expenses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Board shall serve without pay, but may be reimbursed for the actual and necessary traveling and subsistence expenses incurred in the performance of the duties of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Expenses incurred outside the United States may be reimbursed under this paragraph if at least 2 members of the Board concurrently incurred such expenses. Such reimbursements—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91587c56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be available exclusively for actual costs incurred by members of the Board up to the published daily per diem rate for lodging, meals, and incidentals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c57-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not include first-class, business-class, or travel in any class other than economy class or coach class.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c58-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All other expenses, including salaries for officers and staff of the Foundation, shall be established by a majority vote of the Board, as proposed by the Executive Director on no less than an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c59-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Not Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appointment as a member of the Board and employment by the Foundation does not constitute employment by, or the holding of an office of, the United States for purposes of any Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c5a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c5b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish bylaws for the Foundation in accordance with paragraph (13);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c5c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide overall direction for the activities of the Foundation and establish priority activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c5d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out any other necessary activities of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c5e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/12/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the performance of the Executive Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c5f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/12/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take steps to limit the administrative expenses of the Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c60-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/12/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than annually, consult and coordinate with stakeholders qualified to provide advice, assistance, and information regarding effective protected and conserved area management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c61-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bylaws","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c62-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The bylaws required to be established under paragraph (12)(A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91587c63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific duties of the Executive Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c64-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies and procedures for the selection of members of the Board and officers, employees, agents, and contractors of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c65-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" policies, including ethical standards, for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id91587c66-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acceptance, solicitation, and disposition of donations and grants to the Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91587c67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposition of assets of the Foundation upon the dissolution of the Foundation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies that subject all implementing partners, employees, fellows, trainees, and other agents of the Foundation (including ex-officio members of the Board and appointed members of the Board) to stringent ethical and conflict of interest standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" removal and exclusion procedures for implementing partners, employees, fellows, trainees, and other agents of the Foundation (including ex-officio members of the Board and appointed members of the Board) who fail to uphold the ethical and conflict of interest standards established pursuant to clause (iii);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" policies for winding down the activities of the Foundation upon its dissolution, including a plan—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id91587c6b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/A/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to return unspent appropriations to the Treasury of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91587c6c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/A/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to donate unspent private and philanthropic contributions to projects that align with the goals and requirements described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10606"},"text":"section 10606 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c6d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies for vetting implementing partners and grantees to ensure the Foundation does not provide grants to for profit entities whose primary objective is activities other than conservation activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c6e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clawback policies and procedures to be incorporated into grant agreements to ensure compliance with the policies referred to in clause (vii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c6f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall ensure that the bylaws of the Foundation and the activities carried out under such bylaws do not—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91587c70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect unfavorably on the ability of the Foundation to carry out activities in a fair and objective manner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c71-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/b/13/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compromise, or appear to compromise, the integrity of any governmental agency or program, or any officer or employee employed by, or involved in, a governmental agency or program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91587c72-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foundation staff","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Officers and employees of the Foundation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91587c73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be employees of, or hold any office in, the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c74-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not serve in the employ of any nongovernmental organization, project, or person related to or affiliated with any grantee of the Foundation while employed by the Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c75-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not receive compensation from any other source for work performed in carrying out the duties of the Foundation while employed by the Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c76-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should not receive a salary at a rate that is greater than the maximum rate of basic pay authorized for positions at level I of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5312"},"text":"section 5312 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91587c77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation and conflicts of interests","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91587c78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lobby for political or policy issues; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c7a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate or intervene in any political campaign in any country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial interests","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As determined by the Board and set forth in the bylaws established pursuant to subsection (b)(13), and consistent with best practices, any member of the Board or officer or employee of the Foundation shall be prohibited from participating, directly or indirectly, in the consideration or determination of any question before the Foundation affecting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c7c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial interests of such member of the Board, or officer or employee of the Foundation, not including such member’s Foundation expenses and compensation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interests of any corporation, partnership, entity, or organization in which such member of the Board, officer, or employee has any fiduciary obligation or direct or indirect financial interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac56e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recusals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any member of the Board that has a business, financial, or familial interest in an organization or community seeking support from the Foundation shall recuse himself or herself from all deliberations, meetings, and decisions concerning the consideration and decision relating to such support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac56f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project ineligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation may not provide support to individuals or entities with business, financial, or familial ties to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915ac570-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a current member of the Board; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac571-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10603/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a former member of the Board during the 5-year period immediately following the last day of the former member’s term on the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id915ac572-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLI/s5103"},"text":"Pub. L. 118–159, div. E, title LI, § 5103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2412"},"text":"138 Stat. 2412","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id915ac573-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id915ac574-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id915ac575-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(1)(A), was in the original “this title” and was translated as reading “this subtitle”, meaning subtitle A (§§ 5101–5109) of title LI of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2410"},"text":"138 Stat. 2410","children":[],"tail":", known as the United States Foundation for International Conservation Act of 2024, which is classified generally to this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
