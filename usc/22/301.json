{"tag":"section","attrib":{"id":"id8eea1424-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s301"},"text":null,"children":[{"tag":"num","attrib":{"value":"301"},"text":"§ 301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lease or rental arrangements of not less than ten years; approval by Secretary; delegation of authority; information to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eea1425-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of this chapter or any other Act, no lease or other rental arrangement for a period of less than ten years, and requiring an annual payment in excess of $100,000 shall be entered into by the Secretary of State for the purpose of renting or leasing offices, buildings, grounds, or living quarters for the use of the Foreign Service abroad, unless such lease or other rental arrangement is approved by the Secretary. The Secretary may delegate his authority under this section only to the Deputy Under Secretary of State for Administration or to the Director of the Office of Foreign Buildings. The Secretary shall keep the Congress fully and currently informed with respect to leases or other rental arrangements approved under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eea1426-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance payments for long-term leases and lease purchase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, subject to the availability of appropriations, make advance payments for long-term leases and lease-purchase agreements, if the Secretary or his designee determines, in each case, that such payments are in the interest of the United States Government in carrying out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eea1427-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-07/ch250/s10"},"text":"May 7, 1926, ch. 250, § 10","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/89/636/s4"},"text":"Pub. L. 89–636, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-10"},"text":"Oct. 10, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/882"},"text":"80 Stat. 882","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s115/a"},"text":"Pub. L. 102–138, title I, § 115(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/655"},"text":"105 Stat. 655","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCVII/s9709"},"text":"Pub. L. 117–263, div. I, title XCVII, § 9709","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3919"},"text":"136 Stat. 3919","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eea1428-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eea1429-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8eea142a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “$100,000” for “$50,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138"},"text":"Pub. L. 102–138","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, substituted “$50,000” for “$25,000,”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eea142b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8eea142c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Authority of Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, Secretary of State to have and exercise any authority vested by law in any official or office of Department of State and references to such officials or offices deemed to refer to Secretary of State or Department of State, as appropriate, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s161/d"},"text":"section 161(d) of Pub. L. 103–236","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
