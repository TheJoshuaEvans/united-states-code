{"tag":"section","attrib":{"id":"id8f06c3a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1475e"},"text":"§ 1475e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of English-teaching program fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f06c3a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":" or any other law or limitation of authority, fees and receipts described in subsection (b) are authorized to be credited each fiscal year for authorized purposes to the appropriate appropriations of the United States Information Agency to such extent as may be provided in advance in appropriations acts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f06c3a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees and receipts described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The fees and receipts described in this subsection are fees and payments received by or for the use of the United States Information Agency from or in connection with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f06c3a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" English-teaching and library services,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c3aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educational advising and counseling,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c3ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exchange Visitor Program Services,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c3ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advertising and business ventures of the Voice of America and the International Broadcasting Bureau,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c3ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperating international organizations, and ","children":[{"tag":"ref","attrib":{"idref":"fn002069"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002069"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should appear at end of par. (6)."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c3ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475e/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agency-produced publications,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f06c3af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1475e/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount not to exceed $100,000 of the payments from motion picture and television programs produced or conducted by or on behalf of the Agency under the authority of this chapter or the Mutual Education and Cultural Exchange Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"22 U.S.C. 2451","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f06c3b0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-27/ch36"},"text":"Jan. 27, 1948, ch. 36","children":[],"tail":", title VIII, § 810, as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tIII/s304/e"},"text":"Pub. L. 97–241, title III, § 304(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/293"},"text":"96 Stat. 293","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tII/s203"},"text":"Pub. L. 100–204, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1373"},"text":"101 Stat. 1373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tII/s208"},"text":"Pub. L. 101–246, title II, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/53"},"text":"104 Stat. 53","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXIV, § 2412, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-832"},"text":"112 Stat. 2681–832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f06c3b1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f06c3b2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f06c3b3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Mutual Education and Cultural Exchange Act of 1961, referred to in subsec. (b)(7), probably means the Mutual Educational and Cultural Exchange Act of 1961, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/256"},"text":"Pub. L. 87–256","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-21"},"text":"Sept. 21, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/527"},"text":"75 Stat. 527","children":[],"tail":", which is classified principally to chapter 33 (§ 2451 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"section 2451 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f06c3b4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":" or any other law or limitation of authority, fees received by or for the use of the United States Information Agency from or in connection with English-teaching and library services, and Agency-produced publications, and not to exceed $100,000 of payments from motion picture and television programs, produced or conducted by or on behalf of the Agency under the authority of this chapter or the Mutual Educational and Cultural Exchange Act of 1961 is authorized to be credited each fiscal year to the appropriate appropriation of the United States Information Agency to such extent as may be provided in advance in an appropriation Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246"},"text":"Pub. L. 101–246","children":[],"tail":" amended section catchline and text generally. Prior to amendment, section read as follows: “Notwithstanding the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302/b"},"text":"section 3302(b) of title 31","children":[],"tail":" or any other law or limitation of authority, all payments received by or for the use of the United States Information Agency from or in connection with English-teaching and library services conducted by or on behalf of the Agency under the authority of this chapter or the Mutual Educational and Cultural Exchange Act of 1961 may be credited to the Agency’s applicable appropriation to such extent as may be provided in advance in an appropriation Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" amended section generally, changing structure of section from one consisting of subsecs. (a) and (b) to one consisting of one paragraph."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f06c3b5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id8f06c3b6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau) abolished and functions transferred to Secretary of State, see sections 6531 and 6532 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
