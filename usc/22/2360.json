{"tag":"section","attrib":{"id":"id8f9a7843-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2360"},"text":null,"children":[{"tag":"num","attrib":{"value":"2360"},"text":"§ 2360.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds between accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f9a7844-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2360/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Necessity of transfer; limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the President determines it to be necessary for the purposes of this chapter, not to exceed 10 per centum of the funds made available for any provision of this chapter (except funds made available pursuant to subpart IV of part II of subchapter I of this chapter or for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2763"},"text":"section 2763 of this title","children":[],"tail":") may be transferred to, and consolidated with, the funds made available for any provision of this chapter (except funds made available under part II of subchapter II of this chapter), and may be used for any of the purposes for which such funds may be used, except that the total in the provision for the benefit of which the transfer is made shall not be increased by more than 20 per centum of the amount of funds made available for such provision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9a7845-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2360/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Augmentation of other appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority contained in this section and in sections 2261, 2318 and 2364 of this title, shall not be used to augment appropriations made available pursuant to sections 2396(g)(1) and 2397 of this title or used otherwise to finance activities which normally would be financed from appropriations for administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f9a7846-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2360/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military and development assistance purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds which the President has notified Congress pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2413"},"text":"section 2413 of this title","children":[],"tail":" that he intends to provide in military assistance to any country may be transferred to, and consolidated with, any other funds he has notified Congress pursuant to such section that he intends to provide to that country for development assistance purposes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f9a7847-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 610, "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/442"},"text":"75 Stat. 442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/565"},"text":"Pub. L. 87–565","children":[],"tail":", pt. III, § 301(a), "},{"tag":"date","attrib":{"date":"1962-08-01"},"text":"Aug. 1, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/260"},"text":"76 Stat. 260","children":[],"tail":