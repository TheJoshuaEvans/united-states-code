90-11-21"},"text":"Nov. 21, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3356"},"text":"104 Stat. 3356","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f9a7848-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f9a7849-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f9a784a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", known as the Foreign Assistance Act of 1961. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f9a784b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/623"},"text":"Pub. L. 101–623","children":[],"tail":" inserted “or for "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2763"},"text":"section 2763 of this title","children":[],"tail":"” after “subchapter I of this chapter” and struck out “other” after second reference to “funds made available for any”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/384"},"text":"Pub. L. 95–384","children":[],"tail":" struck out provisions authorizing transfer and consolidation of not to exceed $9,000,000 of the funds appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2242"},"text":"section 2242 of this title","children":[],"tail":" with the funds appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2397/a"},"text":"section 2397(a) of this title","children":[],"tail":" to be available solely for additional administrative expenses incurred in connection with programs in Vietnam."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/559/s19/a/1"},"text":"Pub. L. 93–559, § 19(a)(1)","children":[],"tail":", inserted provisions excepting funds made available under part II of subchapter II of this chapter from the designation of funds subject to consolidation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/559/s19/a/2"},"text":"Pub. L. 93–559, § 19(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/175"},"text":"Pub. L. 91–175","children":[],"tail":" inserted provision excepting funds made available pursuant to subpart IV of part II of subchapter I of this chapter form the designation of funds subject to consolidation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/137"},"text":"Pub. L. 90–137","children":[],"tail":" increased limitation on funds available for transfer from $5,000,000 to $9,000,000."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/583"},"text":"Pub. L. 89–583","children":[],"tail":" substituted provisions authorizing transfer of $5,000,000 for administrative expenses for any fiscal year incurred in connection with programs in Vietnam for provisions authorizing transfer of $1,400,000 for administrative expenses for fiscal year 1966 incurred in connection with programs in the Republic of Vietnam."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/371"},"text":"Pub. L. 89–371","children":[],"tail":" authorized transfer of $1,400,000 for administrative expenses for fiscal year 1966 incurred in connection with programs in the Republic of Vietnam."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/565"},"text":"Pub. L. 87–565","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f9a784c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f9a784d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/623/s10/b"},"text":"Pub. L. 101–623, § 10(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-21"},"text":"Nov. 21, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3356"},"text":"104 Stat. 3356","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/623/s10/b"},"text":"“The amendments made by subsection (a) [amending this section] apply with respect to funds made available for fiscal year 1991 or any fiscal year thereafter.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f9a784e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f9a784f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
