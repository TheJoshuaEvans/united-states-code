{"tag":"section","attrib":{"id":"id90a5a6ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6010"},"text":null,"children":[{"tag":"num","attrib":{"value":"6010"},"text":"§ 6010.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “United States person” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this chapter, the term “United States person” means any United States citizen or alien admitted for permanent residence in the United States, and any corporation, partnership, or other organization organized under the laws of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90a5a6bb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tXVII/s1711"},"text":"Pub. L. 102–484, div. A, title XVII, § 1711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2581"},"text":"106 Stat. 2581","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
