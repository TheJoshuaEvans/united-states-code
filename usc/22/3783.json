{"tag":"section","attrib":{"id":"id90489210-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3783"},"text":null,"children":[{"tag":"num","attrib":{"value":"3783"},"text":"§ 3783.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of property of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No property of the United States located in the Republic of Panama may be disposed of except pursuant to law enacted by the Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90489211-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1503"},"text":"Pub. L. 96–70, title I, § 1503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/488"},"text":"93 Stat. 488","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
