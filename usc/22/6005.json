{"tag":"section","attrib":{"id":"id90a5a685-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005"},"text":null,"children":[{"tag":"num","attrib":{"value":"6005"},"text":"§ 6005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90a5a686-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on certain transactions between certain United States firms and Cuba","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a5a687-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no license may be issued for any transaction described in section 515.559 of title 31, Code of Federal Regulations, as in effect on ","children":[{"tag":"date","attrib":{"date":"1989-07-01"},"text":"July 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a688-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability to existing contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not affect any contract entered into before ","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"October 23, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a5a689-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions on vessels","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a5a68a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels engaging in trade","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning on the 61st day after ","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"October 23, 1992","children":[],"tail":", a vessel which enters a port or place in Cuba to engage in the trade of goods or services may not, within 180 days after departure from such port or place in Cuba, load or unload any freight at any place in the United States, except pursuant to a license issued by the Secretary of the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a68b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels carrying goods or passengers to or from Cuba","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as specifically authorized by the Secretary of the Treasury, a vessel carrying goods or passengers to or from Cuba or carrying goods in which Cuba or a Cuban national has any interest may not enter a United States port.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a68c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of ship stores general license","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No commodities which may be exported under a general license described in section 771.9 of title 15, Code of Federal Regulations, as in effect on ","children":[{"tag":"date","attrib":{"date":"1992-05-01"},"text":"May 1, 1992","children":[],"tail":", may be exported under a general license to any vessel carrying goods or passengers to or from Cuba or carrying goods in which Cuba or a Cuban national has an interest."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a68d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90a5a68e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “vessel” includes every description of water craft or other contrivance used, or capable of being used, as a means of transportation in water, but does not include aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90a5a68f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “United States” includes the territories and possessions of the United States and the customs waters of the United States (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1401"},"text":"section 1401 of title 19","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90a5a690-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Cuban national” means a national of Cuba, as the term “national” is defined in section 515.302 of title 31, Code of Federal Regulations, as of ","children":[{"tag":"date","attrib":{"date":"1992-08-01"},"text":"August 1, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a5a691-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on remittances to Cuba","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish strict limits on remittances to Cuba by United States persons for the purpose of financing the travel of Cubans to the United States, in order to ensure that such remittances reflect only the reasonable costs associated with such travel, and are not used by the Government of Cuba as a means of gaining access to United States currency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a5a692-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6005/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of applicability of sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibitions contained in subsections (a), (b), and (c) shall not apply with respect to any activity otherwise permitted by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6004"},"text":"section 6004 of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6006"},"text":"section 6006 of this title","children":[],"tail":" or any activity which may not be regulated or prohibited under section 5(b)(4) of the Trading With the Enemy Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4305/b/4"},"text":"50 U.S.C. 4305(b)(4)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90a5a693-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tXVII/s1706"},"text":"Pub. L. 102–484, div. A, title XVII, § 1706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2578"},"text":"106 Stat. 2578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90a5a694-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id90a5a695-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114/tII/s204/d/3"},"text":"Pub. L. 104–114, title II, § 204(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/810"},"text":"110 Stat. 810","children":[],"tail":", provided that on date on which President submits determination under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6063/c/3"},"text":"section 6063(c)(3) of this title","children":[],"tail":" that democratically elected government in Cuba is in power, this section is repealed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
