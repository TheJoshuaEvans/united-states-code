{"tag":"section","attrib":{"id":"id8eb34c94-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277g–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"277g–2"},"text":"§ 277g–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Administrator of Environmental Protection Agency and other authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall consult with the Administrator of the Environmental Protection Agency and other concerned Federal, State, and local government officials in implementing sections 277g to 277g–3 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eb34c95-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/465/s4"},"text":"Pub. L. 100–465, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-03"},"text":"Oct. 3, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2273"},"text":"102 Stat. 2273","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
