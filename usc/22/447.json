{"tag":"section","attrib":{"id":"id8eec84d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s447"},"text":null,"children":[{"tag":"num","attrib":{"value":"447"},"text":"§ 447.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eec84d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s447/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonds, securities, or other obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the President shall have issued a proclamation under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s441/a"},"text":"section 441(a) of this title","children":[],"tail":", it shall thereafter be unlawful for any person within the United States to purchase, sell, or exchange bonds, securities, or other obligations of the government of any state named in such proclamation, or of any political subdivision of any such state, or of any person acting for or on behalf of the government of any such state, or political subdivision thereof, issued after the date of such proclamation, or to make any loan or extend any credit (other than necessary credits accruing in connection with the transmission of telegraph, cable, wireless and telephone services) to any such government, political subdivision, or person. The provisions of this subsection shall also apply to the sale by any person within the United States to any person in a state named in any such proclamation of any articles or materials listed in a proclamation referred to in or issued under the authority of section 452(i) "},{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eec84d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s447/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal or adjustment of indebtedness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of this section shall not apply to a renewal or adjustment of such indebtedness as may exist on the date of such proclamation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eec84d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s447/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fine and imprisonment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whoever shall knowingly violate any of the provisions of this section or of any regulations issued thereunder shall, upon conviction thereof, be fined not more than $50,000 or imprisoned for not more than five years, or both. Should the violation be by a corporation, organization, or association, each officer or director thereof participating in the violation shall be liable to the penalty herein prescribed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eec84d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s447/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of proclamation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever any proclamation issued under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s441/a"},"text":"section 441(a) of this title","children":[],"tail":" shall have been revoked with respect to any state the provisions of this section shall thereupon cease to apply with respect to such state, except as to offenses committed prior to such revocation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eec84d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s447/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wartime","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not be operative when the United States is at war.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eec84d7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-11-04/ch2/s7"},"text":"Nov. 4, 1939, ch. 2, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/8"},"text":"54 Stat. 8","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-02-21/ch104"},"text":"Feb. 21, 1942, ch. 104","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/95"},"text":"56 Stat. 95","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eec84d8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eec84d9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8eec84da-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s452/i"},"text":"Section 452(i) of this title","children":[],"tail":", referred to in subsec. (a), was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-26/ch937/tV/s542/a/12"},"text":"act Aug. 26, 1954, ch. 937, title V, § 542(a)(12)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/861"},"text":"68 Stat. 861","children":[],"tail":". See former section 1934(a) and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778/a"},"text":"section 2778(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8eec84db-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1942—Subsec. (e). Joint Res. ","children":[{"tag":"date","attrib":{"date":"1942-02-21"},"text":"Feb. 21, 1942","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eec84dc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8eec84dd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Operation of Section Postponed Until July 1, 1953","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Joint Res. ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-07-03/ch570/s1/b/7"},"text":"July 3, 1952, ch. 570, § 1(b)(7)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/333"},"text":"66 Stat. 333","children":[],"tail":", as amended by Joint Res. "},{"tag":"ref","attrib":{"href":"/us/act/1953-03-31/ch13/s1"},"text":"Mar. 31, 1953, ch. 13, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/18"},"text":"67 Stat. 18","children":[],"tail":", provided that this section which is normally operative in time of peace shall not be operative by reason of the termination of a state of war on "},{"tag":"date","attrib":{"date":"1952-04-28"},"text":"Apr. 28, 1952","children":[],"tail":", but rather (in addition to being inoperative, in accordance with their terms, in time of war) shall continue to be inoperative until 6 months after the termination of the national emergency proclaimed by the President on "},{"tag":"date","attrib":{"date":"1950-12-16"},"text":"Dec. 16, 1950","children":[],"tail":", 1950 Proc. 2914, 15 F.R. 9029, set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1"},"text":"section 1 of Title 50","children":[],"tail":", War and National Defense, or until such earlier date or dates as the Congress may provide, but in no event beyond "},{"tag":"date","attrib":{"date":"1953-04-01"},"text":"Apr. 1, 1953","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8eec84de-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Prior Acts Continuing Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 6 of Joint Res. ","children":[{"tag":"date","attrib":{"date":"1952-07-03"},"text":"July 3, 1952","children":[],"tail":", repealed Joint Res. "},{"tag":"ref","attrib":{"href":"/us/act/1952-04-14/ch204"},"text":"Apr. 14, 1952, ch. 204","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/54"},"text":"66 Stat. 54","children":[],"tail":" as amended by Joint Res. "},{"tag":"ref","attrib":{"href":"/us/act/1952-05-28/ch339"},"text":"May 28, 1952, ch. 339","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/96"},"text":"66 Stat. 96","children":[],"tail":"; Joint Res. "},{"tag":"ref","attrib":{"href":"/us/act/1952-06-14/ch437"},"text":"June 14, 1952, ch. 437","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/137"},"text":"66 Stat. 137","children":[],"tail":"; Joint Res. "},{"tag":"ref","attrib":{"href":"/us/act/1952-06-30/ch526"},"text":"June 30, 1952, ch. 526","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/296"},"text":"66 Stat. 296","children":[],"tail":", which continued provisions until "},{"tag":"date","attrib":{"date":"1952-07-03"},"text":"July 3, 1952","children":[],"tail":". This repeal shall take effect as of "},{"tag":"date","attrib":{"date":"1952-06-16"},"text":"June 16, 1952","children":[],"tail":", by section 7 of Joint Res. "},{"tag":"date","attrib":{"date":"1952-07-03"},"text":"July 3, 1952","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
