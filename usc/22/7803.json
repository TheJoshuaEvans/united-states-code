{"tag":"section","attrib":{"id":"id90ef8003-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7803"},"text":null,"children":[{"tag":"num","attrib":{"value":"7803"},"text":"§ 7803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ef8004-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7803/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ef8005-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7803/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ef8006-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7803/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8007-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7803/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" China","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “China” means the People’s Republic of China.","children":[],"tail":"\n"}],"tail":"\n"}],"