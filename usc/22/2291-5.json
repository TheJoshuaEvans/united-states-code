{"tag":"section","attrib":{"id":"id8f7934b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"2291–5"},"text":"§ 2291–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of nonlethal equipment to foreign law enforcement organizations for cooperative illicit narcotics control activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f7934b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7934b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Administrator of the Drug Enforcement Administration, in consultation with the Secretary of State, may transfer or lease each year nonlethal equipment to foreign law enforcement organizations for the purpose of establishing and carrying out cooperative illicit narcotics control activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7934b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f7934ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291–5/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may transfer or lease equipment under paragraph (1) only if the equipment is not designated as a munitions item or controlled on the United States Munitions List pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778"},"text":"section 2778 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f7934bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291–5/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The value of each piece of equipment transferred or leased under paragraph (1) may not exceed $100,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7934bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall provide for the maintenance and repair of any equipment transferred or leased under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7934bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291–5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the export of any item authorized for transfer under subsection (a), the Administrator shall provide written notice to the Committee on Foreign Relations of the Senate and the Committee on International Relations of the House of Representatives in accordance with the procedures applicable to reprogramming notifications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394–1"},"text":"section 2394–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7934be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291–5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7934bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291–5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all United States law enforcement personnel serving in Mexico should be accredited the same status under the Vienna Convention on Diplomatic Immunity as other diplomatic personnel serving at United States posts in Mexico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7934c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291–5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all Mexican narcotics law enforcement personnel serving in the United States should be accorded the same diplomatic status as Drug Enforcement Administration personnel serving in Mexico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f7934c1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tVIII/s843"},"text":"Pub. L. 105–277, div. C, title VIII, § 843","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-704"},"text":"112 Stat. 2681–704","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f7934c2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f7934c3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f7934c4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Western Hemisphere Drug Elimination Act, and also as part of the Omnibus Consolidated and Emergency Supplemental Appropriations Act, 1999, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f7934c5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id8f7934c6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
