{"tag":"section","attrib":{"id":"id8ff2d1a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2680–1"},"text":"§ 2680–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for responses to questions from congressional committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff2d1a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An officer or employee of the Department of State to whom a written or oral question is addressed by any member of a committee specified in subsection (b), acting within his official capacity, shall respond to such question within 21 days unless the Secretary of State submits a letter to such member explaining why a timely response cannot be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff2d1a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The committees referred to in subsection (a) are the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff2d1a4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s196"},"text":"Pub. L. 102–138, title I, § 196","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/684"},"text":"105 Stat. 684","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
