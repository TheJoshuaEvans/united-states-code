{"tag":"section","attrib":{"id":"id8ebf330d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285gg"},"text":null,"children":[{"tag":"num","attrib":{"value":"285gg"},"text":"§ 285gg.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eleventh replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf330e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285gg/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank is authorized to contribute, on behalf of the United States, $189,580,000 to the eleventh replenishment of the resources of the Fund, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf330f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285gg/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $189,580,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf3310-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s36"},"text":"Pub. L. 89–369, § 36","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dK/tVII/s7083/a"},"text":"Pub. L. 115–141, div. K, title VII, § 7083(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/965"},"text":"132 Stat. 965","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
