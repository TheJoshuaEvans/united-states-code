{"tag":"section","attrib":{"id":"id8eec8523-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s463"},"text":null,"children":[{"tag":"num","attrib":{"value":"463"},"text":"§ 463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bonds from armed vessels on clearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The owners or consignees of every armed vessel sailing out of the ports of, or under the jurisdiction of, the United States, belonging wholly or in part to citizens thereof, shall, before clearing out the same, give bond to the United States, with sufficient sureties, in double the amount of the value of the vessel and cargo on board, including her armament, conditioned that the vessel shall not be employed by such owners to cruise or commit hostilities against the subjects, citizens, or property of any foreign prince or state, or of any colony, district, or people, with whom the United States are at peace.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eec8524-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s16"},"text":"Mar. 4, 1909, ch. 321, § 16","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1091"},"text":"35 Stat. 1091","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eec8525-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eec8526-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8eec8527-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s28"},"text":"section 28 of title 18","children":[],"tail":" prior to the general revision and enactment of Title 18, Crimes and Criminal Procedure, by "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch645/s1"},"text":"act June 25, 1948, ch. 645, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/683"},"text":"62 Stat. 683","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8eec8528-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section was derived from R.S. § 5289 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1818-04-20/ch88/s10"},"text":"act Apr. 20, 1818, ch. 88, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/3/449"},"text":"3 Stat. 449","children":[],"tail":"), which was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1909-03-04/ch321/s341"},"text":"act Mar. 4, 1909, ch. 321, § 341","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/1153"},"text":"35 Stat. 1153","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
