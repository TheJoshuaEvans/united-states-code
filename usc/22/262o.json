{"tag":"section","attrib":{"id":"id8e969c68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o"},"text":null,"children":[{"tag":"num","attrib":{"value":"262o"},"text":"§ 262o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiations concerning replenishment or increase in capital; annual reports on implementation of lending policy goals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e969c69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In any negotiations concerning replenishment or an increase in capital for any multilateral development bank, the Secretary of the Treasury shall propose, as a principal point for negotiations, the following institutional reforms:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e969c6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The establishment of a unified program within each multilateral development bank to assess the extent to which bank lending benefits the least advantaged members of society, particularly women and the poor, and to increase the extent to which such members benefit from future bank lending.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e969c6b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The establishment of an office or other administrative procedures within each multilateral development bank to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e969c6c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide in-country liaison services for nongovernmental organizations operating at the community level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e969c6d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the impact of project and nonproject lending on local populations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e969c6e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure compliance with loan conditionalities, especially loan conditionalities relating to the protection of the quality of life of the poor and the rights of aboriginal minorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e969c6f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A major increase in the number of members of the professional staff of each regional multilateral development bank with training in environmental or social impact analysis or natural science, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e969c70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment of additional permanent professional staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e969c71-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training programs for existing staff members in these subject areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e969c72-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to the International Bank for Reconstruction and Development, the establishment of a program for policy-based lending to promote the sustainable use of renewable resources and the protection of the environment in borrowing countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e969c73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An increase in the length of any review period established by any multilateral development bank for board review of staff recommendations by such time as would be sufficient to allow the governments of member countries to review and comment on the staff recommendations before any action is taken by the board of directors of such bank on the recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e969c74-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Treasury shall instruct the United States Executive Director of each multilateral development bank to request the management of such bank to prepare an annual report which identifies and describes the most exemplary lending practices or loan components implemented during the preceding year with respect to each of the following lending policy goals for each major borrowing country or country group:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e969c75-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Benefit to the poor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e969c76-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Involvement of nongovernmental organizations and local and indigenous populations in loan design, implementation, planning, and monitoring.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e969c77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Integration of, consideration of, and concern for environmental quality and the sustainable use of natural resources into loan design, implementation, planning, and monitoring.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e969c78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262o/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recognition of and support for the economic and social development of women.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e969c79-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXV/s1501"},"text":"Pub. L. 95–118, title XV, § 1501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tI"},"text":"Pub. L. 100–202, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-131"},"text":"101 Stat. 1329–131","children":[],"tail":", 1329–134.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e969c7a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e969c7b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8e969c7c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/s1501"},"text":"Section 1501 of Pub. L. 95–118","children":[],"tail":" is based on section 701 of title VII of H.R. 3750, One Hundredth Congress, as introduced "},{"tag":"date","attrib":{"date":"1987-12-11"},"text":"Dec. 11, 1987","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8e969c7d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8e969c7e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–5"},"text":"section 262p–5 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
