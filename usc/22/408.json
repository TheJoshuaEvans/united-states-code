{"tag":"section","attrib":{"id":"id8eea148f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s408"},"text":null,"children":[{"tag":"num","attrib":{"value":"408"},"text":"§ 408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of land and naval forces to prevent exportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may employ such part of the land or naval forces of the United States as he may deem necessary to carry out the purposes of sections 401 to 408 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eea1490-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-06-15/ch30"},"text":"June 15, 1917, ch. 30","children":[],"tail":", title VI, § 8, "},{"tag":"ref","attrib":{"href":"/us/stat/40/225"},"text":"40 Stat. 225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eea1491-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8eea1492-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8eea1493-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Air Force","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For transfer of certain functions insofar as they pertain to the Air Force, and to the extent that they were not previously transferred to the Secretary of the Air Force from the Secretary of the Army, see Secretary of Defense Transfer Order No. 40 [App. A(1)], ","children":[{"tag":"date","attrib":{"date":"1949-07-22"},"text":"July 22, 1949","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
