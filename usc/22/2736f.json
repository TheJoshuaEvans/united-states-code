{"tag":"section","attrib":{"id":"id90037367-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2736f"},"text":"§ 2736f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Efforts to improve retention and prevent retaliation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90037368-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Streamlined reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Secretary shall establish a single point of initial reporting for allegations of discrimination, and harassment that provides an initial review of the allegations and, if necessary, the ability to file multiple claims based on a single complaint."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e369-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required annual surveys","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e36a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", and annually thereafter, the Secretary shall conduct an annual employee satisfaction survey to assess the level of job satisfaction, work environment, and overall employee experience within the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e36b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Open-ended responses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The survey required under paragraph (1) shall include options for open-ended responses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e36c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey questions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The survey shall include questions regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9005e36d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work-life balance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e36e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation and benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e36f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career development opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e370-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance evaluation and promotion process, including fairness and transparency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e371-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communication channels and effectiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e372-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leadership and management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e373-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizational culture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e374-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awareness and effectiveness of complaint measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e375-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accessibility and accommodations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e376-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" availability of transportation to and from a work station;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e377-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information technology infrastructure functionality and accessibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e378-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee’s understanding of the Department’s structure, mission, and goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e379-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alignment and relevance of work to the Department’s mission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e37a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sense of empowerment to affect positive change; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e37b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/b/3/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experiences with harassment, discrimination, retaliation, and other events that contribute to attrition and negatively impact work culture and productivity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e37c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required exit surveys","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e37d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Secretary shall develop and implement a standardized, confidential exit survey process that includes anonymous feedback and exit interviews with employees who voluntarily separate from the Department, whether through resignation, retirement, or other means."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e37e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The exit surveys conducted pursuant to paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9005e37f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be designed to gather insights and feedback from departing employees regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9005e380-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" their reasons for leaving, including caretaking responsibilities, career limitations for partner or spouse, and discrimination, harassment, or retaliation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9005e381-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" their overall experience with the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9005e382-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any suggestions for improvement; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e383-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include questions related to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9005e384-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee’s reasons for leaving;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9005e385-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" job satisfaction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9005e386-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9005e387-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional growth opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9005e388-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leadership effectiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9005e389-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suggestions for enhancing the Department’s performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9005e38a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, the name and industry of the employee’s future employer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e38b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilation of results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall compile and analyze the anonymized exit survey data collected pursuant to this paragraph to identify trends, common themes, and areas needing improvement within the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e38c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot surveys","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":", the Secretary shall conduct a Department-wide survey for Locally Employed Staff regarding retention, training, promotion, and other matters, including harassment, discrimination, and retaliation, that includes workforce perspectives on the accessibility and effectiveness of complaint measures."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e38d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the conclusion of each survey conducted pursuant to this section, the Secretary shall make the key findings available to the Department workforce and shall submit them to the appropriate congressional committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e38e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retaliation prevention efforts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e38f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee evaluation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9005e390-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If there is a pending investigation of discrimination or harassment against a superior who is responsible for rating or reviewing the complainant employee, the complainant shall be reviewed by the superior’s supervisor or other Department employee as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e391-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This paragraph shall take effect 90 days after ","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"December 22, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e392-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736f/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retaliation prevention guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any Department employee against whom an allegation of discrimination or harassment has been made shall receive written guidance (a “retaliation hold”) on the types of actions that can be considered retaliation against the complainant employee. The employee’s immediate supervisor shall also receive the retaliation hold guidance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9005e393-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXII/s6211"},"text":"Pub. L. 118–31, div. F, title LXII, § 6211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/976"},"text":"137 Stat. 976","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9005e394-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9005e395-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id9005e396-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary”, “Department”, and “appropriate congressional committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s6002"},"text":"section 6002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
