{"tag":"section","attrib":{"id":"id8ebcc207-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284r"},"text":null,"children":[{"tag":"num","attrib":{"value":"284r"},"text":"§ 284r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eighth replenishment; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc208-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor is hereby authorized to agree on behalf of the United States to pay to the Association $2,875,000,000 to the eighth replenishment of the resources of the Association, except that any commitment to make such contributions shall be made subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc209-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $2,875,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc20a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s20"},"text":"Pub. L. 86–565, § 20","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/e/tI"},"text":"Pub. L. 100–202, § 101(e) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-131"},"text":"101 Stat. 1329–131","children":[],"tail":", 1329–134.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ebcc20b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ebcc20c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ebcc20d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s20"},"text":"Section 20 of Pub. L. 86–565","children":[],"tail":" is based on section 101 of title I of H.R. 3750, One Hundredth Congress, as introduced "},{"tag":"date","attrib":{"date":"1987-12-11"},"text":"Dec. 11, 1987","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
