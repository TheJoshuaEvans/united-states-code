{"tag":"section","attrib":{"id":"id90c4a127-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6823"},"text":null,"children":[{"tag":"num","attrib":{"value":"6823"},"text":"§ 6823.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c4a128-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6823/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of an Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Trustees, in consultation with the appropriate officials of the Bank, should appoint an Administrator who should be responsible for managing the day-to-day operations of the Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a129-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6823/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to solicit and accept contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Trust Fund should be authorized to solicit and accept contributions from governments, the private sector, and nongovernmental entities of all kinds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a12a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6823/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability of funds and criteria for programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the negotiations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6821/a"},"text":"section 6821(a) of this title","children":[],"tail":", the Secretary of the Treasury shall, consistent with subsection (d)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a12b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6823/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such actions as are necessary to ensure that the Bank or the Association will have in effect adequate procedures and standards to account for and monitor the use of funds contributed to the Trust Fund, including the cost of administering the Trust Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a12c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6823/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek agreement on the criteria that should be used to determine the programs and activities that should be assisted by the Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a12d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6823/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of projects and recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board of Trustees should establish—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a12e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6823/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria for the selection of projects to receive support from the Trust Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a12f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6823/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standards and criteria regarding qualifications of recipients of such support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a130-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6823/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such rules and procedures as may be necessary for cost-effective management of the Trust Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a131-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6823/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such rules and procedures as may be necessary to ensure transparency and accountability in the grant-making process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a132-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6823/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency of operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board of Trustees should ensure full and prompt public disclosure of the proposed objectives, financial organization, and operations of the Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c4a133-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/264/tI/s123"},"text":"Pub. L. 106–264, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-19"},"text":"Aug. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/756"},"text":"114 Stat. 756","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
