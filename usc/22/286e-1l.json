{"tag":"section","attrib":{"id":"id8ec17d99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1l"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–1l"},"text":"§ 286e–1l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quota increase to 8,608,500,000 Special Drawing Rights","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund may consent to an increase in the quota of the United States in the Fund equivalent to 8,608,500,000 Special Drawing Rights, limited to such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ec17d9a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s56"},"text":"July 31, 1945, ch. 339, § 56","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/511/tX/s1001"},"text":"Pub. L. 102–511, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3357"},"text":"106 Stat. 3357","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
