{"tag":"section","attrib":{"id":"id908db209-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5451"},"text":null,"children":[{"tag":"num","attrib":{"value":"5451"},"text":"§ 5451.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance in support of democratic institutions in Poland and Hungary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908db20a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5451/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts otherwise available for such purposes, there are authorized to be appropriated to carry out chapter 4 of part II of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"22 U.S.C. 2346","children":[],"tail":" and following; relating to the economic support fund) $12,000,000 for the 3-year period beginning "},{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":", which shall be available only for the support of democratic institutions and activities in Poland and Hungary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db20b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5451/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance may be provided under this section notwithstanding any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908db20c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tV/s501"},"text":"Pub. L. 101–179, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1317"},"text":"103 Stat. 1317","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id908db20d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id908db20e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id908db20f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Chapter 4 of part II of the Foreign Assistance Act of 1961 is classified to part IV (§ 2346 et seq.) of subchapter II of chapter 32 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
