{"tag":"section","attrib":{"id":"id90dc6d96-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7204"},"text":null,"children":[{"tag":"num","attrib":{"value":"7204"},"text":"§ 7204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of sanctions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any unilateral agricultural sanction or unilateral medical sanction that is imposed pursuant to the procedures described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7202/a"},"text":"section 7202(a) of this title","children":[],"tail":" shall terminate not later than 2 years after the date on which the sanction became effective unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dc6d97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7204/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 60 days before the date of termination of the sanction, the President submits to Congress a report containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90dc6d98-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7204/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendation of the President for the continuation of the sanction for an additional period of not to exceed 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6d99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7204/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the request of the President for approval by Congress of the recommendation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6d9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7204/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is enacted into law a joint resolution stating the approval of Congress for the report submitted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90dc6d9b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tIX/s905"},"text":"Pub. L. 106–387, § 1(a) [title IX, § 905]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–69.)"}],"tail":"\n"}],"tail":null}
