{"tag":"section","attrib":{"id":"id8ff78b93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2695a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2695a"},"text":"§ 2695a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign language services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff78b94-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2695a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surcharge for certain foreign language services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary of State is authorized to require the payment of an appropriate fee, surcharge, or reimbursement for providing other Federal agencies with foreign language translation and interpretation services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff78b95-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2695a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds collected under the authority of subsection (a) shall be deposited as an offsetting collection to any Department of State appropriation to recover the cost of providing translation or interpretation services in any foreign language. Such funds may remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff78b96-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s193"},"text":"Pub. L. 103–236, title I, § 193","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/419"},"text":"108 Stat. 419","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
