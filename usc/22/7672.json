{"tag":"section","attrib":{"id":"id90eac644-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7672"},"text":null,"children":[{"tag":"num","attrib":{"value":"7672"},"text":"§ 7672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90eac645-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in HIV/AIDS antiretroviral treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is a sense of the Congress that an urgent priority of United States assistance programs to fight HIV/AIDS should be the rapid increase in distribution of antiretroviral treatment so that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90eac646-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7672/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the end of fiscal year 2004, at least 500,000 individuals with HIV/AIDS are receiving antiretroviral treatment through United States assistance programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac647-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7672/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the end of fiscal year 2005, at least 1,000,000 such individuals are receiving such treatment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac648-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7672/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the end of fiscal year 2006, at least 2,000,000 such individuals are receiving such treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac649-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7672/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective distribution of HIV/AIDS funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that, of the amounts appropriated pursuant to the authorization of appropriations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7671"},"text":"section 7671 of this title","children":[],"tail":" for HIV/AIDS assistance, 10 percent should be used for orphans and vulnerable children."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90eac64a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25/tIV/s402"},"text":"Pub. L. 108–25, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/745"},"text":"117 Stat. 745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/293/tIV/s402"},"text":"Pub. L. 110–293, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2966"},"text":"122 Stat. 2966","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90eac64b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90eac64c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90eac64d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293"},"text":"Pub. L. 110–293","children":[],"tail":" substituted “10 percent should be used” for “an effective distribution of such amounts would be—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 55 percent of such amounts for treatment of individuals with HIV/AIDS;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 15 percent of such amounts for palliative care of individuals with HIV/AIDS;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) 20 percent of such amounts for HIV/AIDS prevention consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b–2/d"},"text":"section 2151b–2(d) of this title","children":[],"tail":", of which such amount at least 33 percent should be expended for abstinence-until-marriage programs; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) 10 percent of such amounts”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
