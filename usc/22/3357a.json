{"tag":"section","attrib":{"id":"id9037efef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3357a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3357a"},"text":"§ 3357a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy on Taiwan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9037eff0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3357a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with the Taiwan Relations Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3301"},"text":"22 U.S.C. 3301","children":[],"tail":" et."},{"tag":"ref","attrib":{"idref":"fn002256"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002256"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should not appear."}],"tail":" seq.), it shall be the policy of the United States to maintain the capacity of the United States to resist a fait accompli that would jeopardize the security of the people on Taiwan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9037eff1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3357a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fait accompli defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “fait accompli” refers to the resort to force by the People’s Republic of China to invade and seize control of Taiwan before the United States can respond effectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9037eff2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tXII/s1263"},"text":"Pub. L. 117–263, div. A, title XII, § 1263","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2858"},"text":"136 Stat. 2858","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9037eff3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9037eff4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9037eff5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Taiwan Relations Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/8"},"text":"Pub. L. 96–8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-04-10"},"text":"Apr. 10, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/14"},"text":"93 Stat. 14","children":[],"tail":", which is classified generally to chapter 48 (§ 3301 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3301"},"text":"section 3301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9037eff6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":"), but not as part of the Taiwan Enhanced Resilience Act ("},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV"},"text":"Pub. L. 117–263, div. E, title LV","children":[],"tail":", subtitle A) which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
