{"tag":"section","attrib":{"id":"id90464898-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3752"},"text":null,"children":[{"tag":"num","attrib":{"value":"3752"},"text":"§ 3752.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transactions with Republic of Panama","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90464899-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3752/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission assistance on reimbursable basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, on a reimbursable basis, provide to the Republic of Panama materials, supplies, equipment, work, or services, including water and electric power, requested by the Republic of Panama, at such rates as may be agreed upon by the Commission and the Republic of Panama. Payment for such materials, supplies, equipment, work, or services may be made by direct payment by the Republic of Panama to the Commission or by offset against amounts due the Republic of Panama by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9046489a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3752/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission assistance on nonreimbursable basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may provide office space, equipment, supplies, personnel, and other in-kind services to the Panama Canal Authority on a nonreimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9046489b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3752/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other department of agency assistance on reimbursable basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any executive department or agency of the United States may, on a reimbursable basis, provide to the Panama Canal Authority materials, supplies, equipment, work, or services requested by the Panama Canal Authority, at such rates as may be agreed upon by that department or agency and the Panama Canal Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9046489c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1342"},"text":"Pub. L. 96–70, title I, § 1342","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/483"},"text":"93 Stat. 483","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dC/tXXXV/s3542"},"text":"Pub. L. 105–85, div. C, title XXXV, § 3542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2072"},"text":"111 Stat. 2072","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9046489d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9046489e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9046489f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
