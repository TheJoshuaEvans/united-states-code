{"tag":"section","attrib":{"id":"id904d4d60-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3922b"},"text":"§ 3922b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public diplomacy training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904d4d61-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following should be the policy of the United States:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904d4d62-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Foreign Service should recruit individuals with expertise and professional experience in public diplomacy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d63-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States chiefs of mission should have a prominent role in the formulation of public diplomacy strategies for the countries and regions to which they are assigned and should be accountable for the operation and success of public diplomacy efforts at their posts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d64-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Initial and subsequent training of Foreign Service officers should be enhanced to include information and training on public diplomacy and the tools and technology of mass communication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904d4d65-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904d4d66-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the recruitment, training, and assignment of members of the Foreign Service, the Secretary of State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id904d4d67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should emphasize the importance of public diplomacy and applicable skills and techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id904d4d68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should consider the priority recruitment into the Foreign Service, including at middle-level entry, of individuals with expertise and professional experience in public diplomacy, mass communications, or journalism; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id904d4d69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922b/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall give special consideration to individuals with language facility and experience in particular countries and regions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4d6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3922b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Languages of special interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall seek to increase the number of Foreign Service officers proficient in languages spoken in countries with predominantly Muslim populations. Such increase should be accomplished through the recruitment of new officers and incentives for officers in service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904d4d6b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVII/s7110"},"text":"Pub. L. 108–458, title VII, § 7110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3793"},"text":"118 Stat. 3793","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904d4d6c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904d4d6d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id904d4d6e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s7110"},"text":"section 7110 of Pub. L. 108–458","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s7110"},"text":"section 7110 of Pub. L. 108–458","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4003"},"text":"section 4003 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Intelligence Reform and Terrorism Prevention Act of 2004, and also as part of the 9/11 Commission Implementation Act of 2004, and not as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
