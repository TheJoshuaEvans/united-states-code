{"tag":"section","attrib":{"id":"id91133558-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806"},"text":null,"children":[{"tag":"num","attrib":{"value":"8806"},"text":"§ 8806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions with respect to foreign financial institutions that facilitate financial transactions on behalf of specially designated nationals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91133559-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in this section, the President shall prohibit the opening, and prohibit or impose strict conditions on the maintaining, in the United States of a correspondent account or a payable-through account by a foreign financial institution that the President determines has, on or after the date that is 180 days after ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":", knowingly facilitated a significant financial transaction on behalf of any Iranian person included on the list of specially designated nationals and blocked persons maintained by the Office of Foreign Assets Control of the Department of the Treasury (other than an Iranian financial institution described in subsection (b))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9113355a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Iranian financial institutions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Iranian financial institution described in this subsection is an Iranian financial institution that has not been designated for the imposition of sanctions in connection with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9113355b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Iran’s proliferation of weapons of mass destruction or delivery systems for weapons of mass destruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9113355c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Iran’s support for international terrorism; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9113355d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Iran’s abuses of human rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9113355e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Humanitarian exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may not impose sanctions under subsection (a) with respect to any person for conducting or facilitating a transaction for the sale of agricultural commodities, food, medicine, or medical devices to Iran or for the provision of humanitarian assistance to the people of Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9113355f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of sanctions to petroleum and petroleum products","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91133560-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), subsection (a) shall apply with respect to a financial transaction for the purchase of petroleum or petroleum products from Iran only if, at the time of the transaction, a determination of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513a/d/4/B"},"text":"section 8513a(d)(4)(B) of this title","children":[],"tail":" that the price and supply of petroleum and petroleum products produced in countries other than Iran is sufficient to permit purchasers of petroleum and petroleum products from Iran to reduce significantly their purchases from Iran is in effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91133561-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain countries","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91133562-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply with respect to a financial transaction described in subparagraph (B) conducted or facilitated by a foreign financial institution if, at the time of the transaction, the exception under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513a/d/4/D/i"},"text":"section 8513a(d)(4)(D)(i) of this title","children":[],"tail":" applies to the country with primary jurisdiction over the foreign financial institution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91133563-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial transactions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A financial transaction conducted or facilitated by a foreign financial institution is described in this subparagraph if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91133564-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the financial transaction is only for trade in goods or services—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id91133565-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/d/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not otherwise subject to sanctions under the law of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91133566-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/d/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between the country with primary jurisdiction over the foreign financial institution and Iran; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91133567-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funds owed to Iran as a result of such trade are credited to an account located in the country with primary jurisdiction over the foreign financial institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91133568-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of sanctions to natural gas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall apply to a foreign financial institution that conducts or facilitates a financial transaction for the sale, supply, or transfer to or from Iran of natural gas unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91133569-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the financial transaction is only for trade in goods or services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9113356a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not otherwise subject to sanctions under the law of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9113356b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between the country with primary jurisdiction over the foreign financial institution and Iran; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9113356c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funds owed to Iran as a result of such trade are credited to an account located in the country with primary jurisdiction over the foreign financial institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9113356d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9113356e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may waive the imposition of sanctions under subsection (a) for a period of not more than 180 days, and may renew that waiver for additional periods of not more than 180 days, if the President—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9113356f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that such a waiver is vital to the national security of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91133570-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the appropriate congressional committees a report providing a justification for the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91133571-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8806/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report submitted under paragraph (1)(B) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91133572-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXII/s1247"},"text":"Pub. L. 112–239, div. A, title XII, § 1247","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2013"},"text":"126 Stat. 2013","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91133573-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id91133574-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id91133575-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions and authorities vested in the President by this section, see Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2013-06-03"},"text":"June 3, 2013","children":[],"tail":", 78 F.R. 35545, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8801"},"text":"section 8801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
