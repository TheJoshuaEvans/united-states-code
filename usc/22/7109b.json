{"tag":"section","attrib":{"id":"id90d7b2d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7109b"},"text":null,"children":[{"tag":"num","attrib":{"value":"7109b"},"text":"§ 7109b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential Award for Extraordinary Efforts To Combat Trafficking in Persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90d7b2d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7109b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of award","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President is authorized to establish an award, to be known as the “Presidential Award for Extraordinary Efforts To Combat Trafficking in Persons”, for extraordinary efforts to combat trafficking in persons. To the maximum extent practicable, the Secretary of State shall present the award annually to not more than 5 individuals or organizations, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d7b2d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7109b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals who are United States citizens or foreign nationals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d7b2d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7109b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States or foreign nongovernmental organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d7b2d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7109b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish procedures for selecting recipients of the award authorized under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d7b2d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7109b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ceremony","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall host an annual ceremony for recipients of the award authorized under subsection (a) as soon as practicable after the date on which the Secretary submits to Congress the report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7107/b/1"},"text":"section 7107(b)(1) of this title","children":[],"tail":". The Secretary of State may pay the travel costs of each recipient and a guest of each recipient who attends the ceremony."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d7b2d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7109b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated, for each of the fiscal years 2022 through 2027, such sums as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90d7b2da-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/386/dA/s112B"},"text":"Pub. L. 106–386, div. A, § 112B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/457/tI/s109"},"text":"Pub. L. 110–457, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5051"},"text":"122 Stat. 5051","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/347/tI/s105/d/2"},"text":"Pub. L. 117–347, title I, § 105(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6204"},"text":"136 Stat. 6204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90d7b2db-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90d7b2dc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90d7b2dd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/347"},"text":"Pub. L. 117–347","children":[],"tail":" substituted “2022 through 2027” for “2008 through 2011”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
