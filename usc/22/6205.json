{"tag":"section","attrib":{"id":"id90af1bcd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205"},"text":null,"children":[{"tag":"num","attrib":{"value":"6205"},"text":"§ 6205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the International Broadcasting Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90af1bce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The International Broadcasting Advisory Board (referred to in this section as the “Advisory Board”) shall advise the Chief Executive Officer of the United States Agency for Global Media, as appropriate. The Advisory Board as established shall exist within the executive branch as an entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s104"},"text":"section 104 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90af1bcf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of the Advisory Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90af1bd0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Board shall consist of seven members, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90af1bd1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six shall be appointed by the President, by and with the advice and consent of the Senate, in accordance with subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1bd2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1bd3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall designate, with the advice and consent of the Senate, one of the members appointed under paragraph (1)(A) as Chair of the Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1bd4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Party limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than three members of the Advisory Board appointed under paragraph (1)(A) may be affiliated with the same political party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1bd5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of office","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90af1bd6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), members of the Advisory Board shall serve for a single term of 4 years, except that, of the first group of members appointed under paragraph (1)(A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90af1bd7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members who are not affiliated with the same political party, shall be appointed for terms ending on the date that is 2 years after the date of the enactment of the U.S. Agency for Global Media Reform Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90af1bd8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members who are not affiliated with the same political party, shall be appointed for terms ending on the date that is 4 years after the date of the enactment of the U.S. Agency for Global Media Reform Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90af1bd9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two members who are not affiliated with the same political party, shall be appointed for terms ending on the date that is 6 years after the date of the enactment of the U.S. Agency for Global Media Reform Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1bda-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall serve as a member of the Advisory Board for the duration of his or her tenure as Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1bdb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90af1bdc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall appoint, with the advice and consent of the Senate, additional members to fill vacancies on the Advisory Board occurring before the expiration of a term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1bdd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any members appointed pursuant to subparagraph (A) shall serve for the remainder of such term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1bde-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service beyond term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any member whose term has expired shall continue to serve as a member of the Advisory Board until a qualified successor has been appointed and confirmed by the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1bdf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When there is a vacancy in the office of Secretary of State, the Acting Secretary of State shall serve as a member of the Advisory Board until a new Secretary of State is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90af1be0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of the Advisory Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In identifying individuals for appointment to the Advisory Board under subsection (a), the President shall appoint United States citizens—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90af1be1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, with the exception of the Secretary of State, are not regular, full-time employees of the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1be2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who are distinguished in the fields of public diplomacy, mass communications, print, broadcast or digital media, or foreign affairs, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90af1be3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual should be appointed from among a list of at least three individuals submitted by the Chair of the Committee on Foreign Affairs of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1be4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual should be appointed from among a list of at least three individuals submitted by the Ranking Member of the Committee on Foreign Affairs of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1be5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual should be appointed from among a list of at least three individuals submitted by the Chair of the Committee on Foreign Relations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1be6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual should be appointed from among a list of at least three individuals submitted by the Ranking Member of the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90af1be7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of the Advisory Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Advisory Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90af1be8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the Chief Executive Officer of the United States Agency for Global Media with advice and recommendations for improving the effectiveness and efficiency of the Agency and its programming;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1be9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet with the Chief Executive Officer at least four times annually, including twice in person as practicable, and at additional meetings at the request of the Chief Executive Officer or the Chair of the Advisory Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1bea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report periodically, or upon request, to the congressional committees specified in subsection (c)(2) regarding its advice and recommendations for improving the effectiveness and efficiency of the United States Agency for Global Media and its programming;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1beb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain information from the Chief Executive Officer, as needed, for the purposes of fulfilling the functions described in this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1bec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Chief Executive Officer regarding budget submissions and strategic plans before they are submitted to the Office of Management and Budget or to Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1bed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advise the Chief Executive Officer to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90af1bee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief Executive Officer fully respects the professional integrity and editorial independence of United States Agency for Global Media broadcasters, networks, and grantees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1bef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agency networks, broadcasters, and grantees adhere to the highest professional standards and ethics of journalism, including taking necessary actions to uphold professional standards to produce consistently reliable and authoritative, accurate, objective, and comprehensive news and information; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1bf0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide other strategic input to the Chief Executive Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90af1bf1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of heads of networks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90af1bf2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The heads of Voice of America, the Office of Cuba Broadcasting, RFE/RL, Inc., Radio Free Asia, the Middle East Broadcasting Networks, the Open Technology Fund, or of any other grantee authorized under this chapter may only be appointed or removed if such action has been approved by a majority vote of the Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1bf3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After consulting with the Chief Executive Officer, five or more members of the Advisory Board may unilaterally remove any such head of network or grantee network described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1bf4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90af1bf5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A quorum shall consist of four members of the Advisory Board (excluding the Secretary of State).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1bf6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), decisions of the Advisory Board shall be made by majority vote, a quorum being present.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1bf7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Closed sessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Board may meet in closed sessions in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90af1bf8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension and debarment of grantees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90af1bf9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3), a grantee may not be debarred or suspended without consultation with the Chief Executive Officer and a three-fourths majority vote of the Advisory Board in support of such action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1bfa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90af1bfb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grantee may not be suspended unless the Advisory Board determines that the criteria described in section 513.405 of title 22, Code of Federal Regulations, have been met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1bfc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspending official","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Board shall collectively serve as the suspending official (as described in section 513.105 of title 22, Code of Federal Regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1bfd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debarment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90af1bfe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for debarment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grantee may not be debarred unless the Advisory Board determines that one or more of the causes described in section 513.305 of title 22, Code of Federal Regulations, has been established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90af1bff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debarring official","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Board shall collectively serve as the debarring official (as described in section 513.105 of title 22, Code of Federal Regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90af1c00-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90af1c01-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Advisory Board, while attending meetings of the Advisory Board or while engaged in duties relating to such meetings or in other activities of the Advisory Board under this section (including travel time) shall be entitled to receive compensation equal to the daily equivalent of the compensation prescribed for level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c02-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While away from their homes or regular places of business, members of the Board may be allowed travel expenses, including per diem in lieu of subsistence, as authorized under section 5703 of such title for persons in the Government service employed intermittently.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90af1c03-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State is not entitled to any compensation under this chapter, but may be allowed travel expenses in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90af1c04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6205/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support staff","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer shall, from within existing United States Agency for Global Media personnel, provide the Advisory Board with an Executive Secretary and such administrative staff and support as may be necessary to enable the Advisory Board to carry out subsections (d) and (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90af1c05-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tIII/s306"},"text":"Pub. L. 103–236, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/436"},"text":"108 Stat. 436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1323(j), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-780"},"text":"112 Stat. 2681–780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1288/3"},"text":"Pub. L. 114–328, div. A, title XII, § 1288(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2551"},"text":"130 Stat. 2551","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1299Q/d"},"text":"Pub. L. 116–283, div. A, title XII, § 1299Q(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4022"},"text":"134 Stat. 4022","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXIV/s7401"},"text":"Pub. L. 118–159, div. G, title LXXIV, § 7401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2543"},"text":"138 Stat. 2543","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90af1c06-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90af1c07-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90af1c08-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the U.S. Agency for Global Media Reform Act, referred to in subsec. (b)(4)(A), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q"},"text":"section 1299Q of Pub. L. 116–283","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":". A bill with that Short Title, S. 3654, was introduced in the 115th Congress, 2nd Session, but was not enacted. Provisions similar to those in subsec. (b) of this section, as added by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q"},"text":"section 1299Q of Pub. L. 116–283","children":[],"tail":", were contained in section 3 of the bill."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (e)(1) and (f)(3), was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/432"},"text":"108 Stat. 432","children":[],"tail":", known as the United States International Broadcasting Act of 1994, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6201"},"text":"section 6201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90af1c09-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1299Q/d"},"text":"Pub. L. 116–283, div. A, title XII, § 1299Q(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4022"},"text":"134 Stat. 4022","children":[],"tail":", which amended this section, was itself amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tXIII/s1301"},"text":"Pub. L. 116–260, div. O, title XIII, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2158"},"text":"134 Stat. 2158","children":[],"tail":", to make it effective 90 days after "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":". However, the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" could not be executed because it was enacted before the provision from "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" that it amended."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90af1c0a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added subsec. (f) and redesignated former subsecs. (f) and (g) as (g) and (h), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/d/1"},"text":"Pub. L. 116–283, § 1299Q(d)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “Except as provided in subsection (b)(2), the International Broadcasting Advisory Board (referred to in this section as the ‘Advisory Board’) shall consist of five members, including the Secretary of State, appointed by the President and in accordance with subsection (d), to advise the Chief Executive Officer of the Broadcasting Board of Governors, as appropriate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/d/1"},"text":"Pub. L. 116–283, § 1299Q(d)(1)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which related to retention of existing BBG Board Members."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/d/1"},"text":"Pub. L. 116–283, § 1299Q(d)(1)","children":[],"tail":"–(3), redesignated subsec. (d) as (c), inserted “Advisory” before “Board” in subsec. heading and “who are” before “distinguished” in par. (2), and struck out former subsec. (c) which related to terms of office."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/d/4"},"text":"Pub. L. 116–283, § 1299Q(d)(4)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/d/4"},"text":"Pub. L. 116–283, § 1299Q(d)(4)","children":[],"tail":", added subsecs. (e) to (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended section generally. Prior to amendment, section related to the role of the Secretary of State in international broadcasting."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1323/j/1"},"text":"Pub. L. 105–277, § 1323(j)(1)","children":[],"tail":", substituted “Role of Secretary of State” for “Foreign policy guidance” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1323/j/2"},"text":"Pub. L. 105–277, § 1323(j)(2)","children":[],"tail":"–(4), designated existing provisions as subsec. (a), inserted heading, substituted “State” for “State, acting through the Director of the United States Information Agency,”, and inserted before period at end “, as the Secretary may deem appropriate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1323/j/5"},"text":"Pub. L. 105–277, § 1323(j)(5)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90af1c0b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90af1c0c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
