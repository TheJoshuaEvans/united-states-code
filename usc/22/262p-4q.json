{"tag":"section","attrib":{"id":"id8ea0391f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4q"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p–4q"},"text":"§ 262p–4q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opposition to assistance by international financial institutions to terrorist states","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ea03920-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States executive director of each international financial institution to use the voice and vote of the United States to oppose any loan or other use of the funds of the respective institution to or for a country for which the Secretary of State has made a determination under section 4605(j) ","children":[{"tag":"ref","attrib":{"idref":"fn002011"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002011"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 50 or "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2371"},"text":"section 2371 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ea03921-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “International financial institution” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “international financial institution” includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ea03922-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the International Bank for Reconstruction and Development, the International Development Association, and the International Monetary Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ea03923-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wherever applicable, the Inter-American Bank, the Asian Development Bank, the European Bank for Reconstruction and Development, the African Development Bank, and the African Development Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ea03924-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4q/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any similar institution established after ","children":[{"tag":"date","attrib":{"date":"1996-04-24"},"text":"April 24, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ea03925-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXVI/s1621"},"text":"Pub. L. 95–118, title XVI, § 1621","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tIII/s327"},"text":"Pub. L. 104–132, title III, § 327","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1257"},"text":"110 Stat. 1257","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes"