{"tag":"section","attrib":{"id":"id9001020c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2732c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2732c"},"text":"§ 2732c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of federally funded research and development center reports to Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after receiving a report or other written product provided to the Department by federally funded research and development centers (FFRDCs) and consultant groups that were supported by funds congressionally appropriated to the Department, the Secretary shall provide the appropriate congressional committees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9001020d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2732c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report or written product, including the original proposal for the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9001020e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2732c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount provided by the Department to the FFRDC; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9001020f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2732c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the value the Department derived from the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90010210-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tVI/s5601"},"text":"Pub. L. 119–60, div. E, title VI, § 5601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1603"},"text":"139 Stat. 1603","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90010211-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90010212-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id90010213-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Department”, “Appropriate Congresional Committees”, and “Secretary” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s5002"},"text":"section 5002 of Pub. L. 119–60","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
