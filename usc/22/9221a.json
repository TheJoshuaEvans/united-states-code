{"tag":"section","attrib":{"id":"id91218d73-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221a"},"text":null,"children":[{"tag":"num","attrib":{"value":"9221a"},"text":"§ 9221a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on indirect correspondent accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91218d74-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), if a United States financial institution has or obtains knowledge that a correspondent account established, maintained, administered, or managed by that institution for a foreign financial institution is being used by the foreign financial institution to provide significant financial services indirectly to any person, foreign government, or financial institution designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9214"},"text":"section 9214 of this title","children":[],"tail":", the United States financial institution shall ensure that such correspondent account is no longer used to provide such services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218d75-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A United States financial institution is authorized to process transfers of funds to or from North Korea, or for the direct or indirect benefit of any person, foreign government, or financial institution that is designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9214"},"text":"section 9214 of this title","children":[],"tail":", only if the transfer—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218d76-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arises from, and is ordinarily incident and necessary to give effect to, an underlying transaction that has been authorized by a specific or general license issued by the Secretary of the Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not involve debiting or crediting a North Korean account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218d78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218d79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correspondent account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “correspondent account” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5318A"},"text":"section 5318A of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d7a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States financial institution” means ","children":[{"tag":"ref","attrib":{"idref":"fn002427"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002427"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" has the meaning given that term in section 510.310 of title 31, Code of Federal Regulations, as in effect on "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"August 2, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218d7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9221a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign financial institution” has the meaning given that term in section 1010.605 of title 31, Code of Federal Regulations, as in effect on ","children":[{"tag":"date","attrib":{"date":"2017-08-02"},"text":"August 2, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91218d7c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tII/s201A"},"text":"Pub. L. 114–122, title II, § 201A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s312/a"},"text":"Pub. L. 115–44, title III, § 312(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/945"},"text":"131 Stat. 945","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
