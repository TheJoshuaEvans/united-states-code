{"tag":"section","attrib":{"id":"id903a3a14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386"},"text":null,"children":[{"tag":"num","attrib":{"value":"3386"},"text":"§ 3386.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taiwan fellows on detail from Government service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id903a3a15-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903a3a16-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With the approval of the Secretary of State, an agency head may detail, for a period of not more than 2 years, an employee of the agency of the United States Government who has been awarded a fellowship under this subchapter, to the American Institute in Taiwan for the purpose of assignment to Taiwan or an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3384/d/2/B"},"text":"section 3384(d)(2)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3a17-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each detailee shall enter into a written agreement with the Federal Government before receiving a fellowship, in which the fellow shall agree—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a3a18-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to continue in the service of the sponsoring agency at the end of fellowship for a period of at least 4 years (or at least 2 years if the fellowship duration is 1 year or shorter) unless the detailee is involuntarily separated from the service of such agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a3a19-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay to the American Institute in Taiwan, or the United States Government agency, as appropriate, any additional expenses incurred by the Federal Government in connection with the fellowship if the detailee voluntarily separates from service with the sponsoring agency before the end of the period for which the detailee has agreed to continue in the service of such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3a1a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The payment agreed to under paragraph (2)(B) may not be required from a detailee who leaves the service of the sponsoring agency to enter into the service of another agency of the United States Government unless the head of the sponsoring agency notifies the detailee before the effective date of entry into the service of the other agency that payment will be required under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a3a1b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status as Government employee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A detailee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903a3a1c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deemed, for the purpose of preserving allowances, privileges, rights, seniority, and other benefits, to be an employee of the sponsoring agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3a1d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to pay, allowances, and benefits from funds available to such agency, which is deemed to comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5536"},"text":"section 5536 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3a1e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be assigned to a position with an entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3384/d/2/A"},"text":"section 3384(d)(2)(A) of this title","children":[],"tail":" if acceptance of such position does not involve—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a3a1f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the taking of an oath of allegiance to another government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a3a20-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acceptance of compensation or other benefits from any foreign government by such detailee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a3a21-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of sponsoring agency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903a3a22-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal agency from which a detailee is detailed should provide the fellow allowances and benefits that are consistent with Department of State Standardized Regulations or other applicable rules and regulations, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a3a23-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a living quarters allowance to cover the cost of housing in Taiwan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a3a24-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cost of living allowance to cover any possible higher costs of living in Taiwan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a3a25-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a temporary quarters subsistence allowance for up to 7 days if the fellow is unable to find housing immediately upon arriving in Taiwan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a3a26-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an education allowance to assist parents in providing the fellow’s minor children with educational services ordinarily provided without charge by public schools in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a3a27-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" moving expenses to transport personal belongings of the fellow and his or her family in their move to Taiwan, which is comparable to the allowance given for American Institute in Taiwan employees assigned to Taiwan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a3a28-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an economy-class airline ticket to and from Taiwan for each fellow and the fellow’s immediate family.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3a29-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The American Institute in Taiwan and its implementing partner, with the approval of the Department of State, may modify the benefits set forth in paragraph (1) if such modification is warranted by fiscal circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a3a2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No financial liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The American Institute in Taiwan, the implementing partner, and Taiwan or non-public sector entities in Taiwan at which a fellow is detailed during the second year of the fellowship may not be held responsible for the pay, allowances, or any other benefit normally provided to the detailee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a3a2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fellows may be detailed under subsection (a)(1) without reimbursement to the United States by the American Institute in Taiwan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a3a2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3386/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowances and benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Detailees may be paid by the American Institute in Taiwan for the allowances and benefits listed in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903a3a2d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5532"},"text":"Pub. L. 117–263, div. E, title LV, § 5532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3330"},"text":"136 Stat. 3330","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
