{"tag":"section","attrib":{"id":"id8ff78bea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2701a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2701a"},"text":"§ 2701a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education allowance for dependents of Department of State employees located in United States territories","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff78beb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2701a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual employed by the Department at a location described in subsection (b) shall be eligible for a cost-of-living allowance for the education of the dependents of such employee in an amount that does not exceed the educational allowance authorized by the Secretary of Defense for such location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff78bec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2701a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A location is described in this subsection if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff78bed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2701a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such location is in a territory of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff78bee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2701a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of Defense has determined that schools available in such location are unable to adequately provide for the education of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff78bef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2701a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dependents of members of the Armed Forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff78bf0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2701a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dependents of employees of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff78bf1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXII/s6231"},"text":"Pub. L. 118–31, div. F, title LXII, § 6231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/983"},"text":"137 Stat. 983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff78bf2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff78bf3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8ff78bf4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s6002"},"text":"section 6002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
