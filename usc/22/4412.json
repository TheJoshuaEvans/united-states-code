{"tag":"section","attrib":{"id":"id907a9e69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4412"},"text":null,"children":[{"tag":"num","attrib":{"value":"4412"},"text":"§ 4412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to the Endowment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id907a9e6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization; funding; grant agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the United States Information Agency shall make an annual grant to the Endowment to enable the Endowment to carry out its purposes as specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4411/b"},"text":"section 4411(b) of this title","children":[],"tail":". Such grants shall be made with funds specifically appropriated for grants to the Endowment or with funds appropriated to the Agency for the “Salaries and Expenses” account. Such grants shall be made pursuant to a grant agreement between the Director and the Endowment which requires that grant funds will only be used for activities which the Board of Directors of the Endowment determines are consistent with the purposes described in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4411/b"},"text":"section 4411(b) of this title","children":[],"tail":", that the Endowment will allocate funds in accordance with subsection (e) of this section, and that the Endowment will otherwise comply with the requirements of this subchapter. The grant agreement may not require the Endowment to comply with requirements other than those specified in this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907a9e6b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds so granted may be used by the Endowment to carry out the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4411/b"},"text":"section 4411(b) of this title","children":[],"tail":", and otherwise applicable limitations on the purposes for which funds appropriated to the United States Information Agency may be used shall not apply to funds granted to the Endowment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907a9e6c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of Endowment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to make the Endowment an agency or establishment of the United States Government or to make the members of the Board of Directors of the Endowment, or the officers or employees of the Endowment, officers or employees of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907a9e6d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4412/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight procedures applicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Endowment and its grantees shall be subject to the appropriate oversight procedures of the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907a9e6e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4412/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts to Free Trade Union Institute and National Chamber Foundation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts made available to the Endowment for each of the fiscal years 1984 and 1985 to carry out programs in furtherance of the purposes of this Act—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id907a9e6f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4412/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $13,800,000 shall be for the Free Trade Union Institute; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907a9e70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4412/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $2,500,000 shall be to support private enterprise development programs of the National Chamber Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907a9e71-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4412/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent labor unions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall preclude the Endowment from making grants to independent labor unions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907a9e72-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/tV/s503"},"text":"Pub. L. 98–164, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1040"},"text":"97 Stat. 1040","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tII/s212"},"text":"Pub. L. 100–204, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1376"},"text":"101 Stat. 1376","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907a9e73-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907a9e74-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id907a9e75-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164"},"text":"Pub. L. 98–164","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1017"},"text":"97 Stat. 1017","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id907a9e76-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id907a9e77-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id907a9e78-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau) abolished and functions transferred to Secretary of State, see sections 6531 and 6532 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
