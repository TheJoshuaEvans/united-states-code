{"tag":"section","attrib":{"id":"id8ff0601a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2661"},"text":null,"children":[{"tag":"num","attrib":{"value":"2661"},"text":"§ 2661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of information for corporations, firms and individuals; expense of cablegrams and telephone service involved; appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1936-05-15"},"text":"May 15, 1936","children":[],"tail":", whenever the Secretary of State, in his discretion, procures information on behalf of corporations, firms, and individuals, the expense of cablegrams and telephone service involved may be charged against the respective appropriations for the service utilized; and reimbursement therefor shall be required from those for whom the information was procured and, when made, be credited to the appropriation under which the expenditure was charged."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Secretary of State is authorized to accept reimbursement from corporations, firms, and individuals for the expenses of travel, translation, printing, special experts, and other extraordinary expenses (including such expenses as salaries and other personnel expenses) incurred in pursuing a claim on their behalf against a foreign government or other foreign entity. Such reimbursements shall be credited to the appropriation account against which the expense was initially charged.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ff0601b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-15/ch405"},"text":"May 15, 1936, ch. 405","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1321"},"text":"49 Stat. 1321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s142/b"},"text":"Pub. L. 100–204, title I, § 142(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1350"},"text":"101 Stat. 1350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXII, § 2212(a), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-812"},"text":"112 Stat. 2681–812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff0601c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff0601d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ff0601e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s169"},"text":"section 169 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from the Department of State Appropriation Act, 1937, act ","children":[{"tag":"date","attrib":{"date":"1936-05-15"},"text":"May 15, 1936","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8ff0601f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1935-03-22/ch39"},"text":"Mar. 22, 1935, ch. 39","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/76"},"text":"49 Stat. 76","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1934-04-07/ch104"},"text":"Apr. 7, 1934, ch. 104","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/48/536"},"text":"48 Stat. 536","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1933-03-01/ch144"},"text":"Mar. 1, 1933, ch. 144","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/47/1379"},"text":"47 Stat. 1379","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1932-07-01/ch361"},"text":"July 1, 1932, ch. 361","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/47/487"},"text":"47 Stat. 487","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1931-02-23/ch280"},"text":"Feb. 23, 1931, ch. 280","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/46/1321"},"text":"46 Stat. 1321","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1930-04-18/ch184"},"text":"Apr. 18, 1930, ch. 184","childr