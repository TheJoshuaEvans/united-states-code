{"tag":"section","attrib":{"id":"id8eb0dac0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–20"},"text":null,"children":[{"tag":"num","attrib":{"value":"277d–20"},"text":"§ 277d–20.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on application for reimbursement or compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Application for reimbursement or compensation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s277d–19"},"text":"section 277d–19 of this title","children":[],"tail":" shall be submitted to the Commissioner within either one year from the date of acquisition or the date of vacating the premises by the applicant, whichever date is later. Applications not submitted within said period shall be forever barred."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eb0dac1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/300/s4"},"text":"Pub. L. 88–300, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-04-29"},"text":"Apr. 29, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/185"},"text":"78 Stat. 185","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
