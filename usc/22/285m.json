{"tag":"section","attrib":{"id":"id8ebf328b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285m"},"text":null,"children":[{"tag":"num","attrib":{"value":"285m"},"text":"§ 285m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal rights covering United States Special Resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States shall have the right to withdraw all or part of the United States Special Resources and any accrued resources derived therefrom under the procedures provided for in section 8.03 of the Special Funds Rules and Regulations of the Bank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ebf328c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s16"},"text":"Pub. L. 89–369, § 16","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/245/s1"},"text":"Pub. L. 92–245, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-03-10"},"text":"Mar. 10, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/58"},"text":"86 Stat. 58","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
