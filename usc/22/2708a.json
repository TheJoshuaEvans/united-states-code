{"tag":"section","attrib":{"id":"id8ffc46b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2708a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2708a"},"text":"§ 2708a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of Thomas Jefferson Star for Foreign Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ffc46b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2708a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to award","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President, upon the recommendation of the Secretary, may award a Thomas Jefferson Star for Foreign Service to any member of the Foreign Service or any other civilian employee of the Government of the United States who, while employed at, or assigned permanently or temporarily to, an official mission overseas or while traveling abroad on official business, incurred a wound or other injury or an illness (whether or not the wound, other injury, or illness resulted in death)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffc46b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2708a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the person was performing official duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc46b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2708a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the person was on the premises of a United States mission abroad; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc46b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2708a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by reason of the person’s status as a United States Government employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc46ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2708a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe the procedures for identifying and considering persons eligible for award of a Thomas Jefferson Star for Foreign Service and for selecting the persons to be recommended for the award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc46bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2708a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award in the event of death","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person selected for award of a Thomas Jefferson Star for Foreign Service dies before being presented the award, the award may be made and the star presented to the person’s family or to the person’s representative, as designated by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc46bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2708a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of award","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall prescribe the design of the Thomas Jefferson Star for Foreign Service. The award may not include a stipend or any other cash payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc46bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2708a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any expenses incurred in awarding a person a Thomas Jefferson Star for Foreign Service may be paid out of appropriations available at the time of the award for personnel of the department or agency of the United States Government in which the person was employed when the person incurred the wound, injury, or illness upon which the award is based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ffc46be-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 36A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tIII/s321"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title III, § 321]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–436; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tIII/s311"},"text":"Pub. L. 107–228, div. A, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1377"},"text":"116 Stat. 1377","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ffc46bf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ffc46c0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ffc46c1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" substituted “Thomas Jefferson Star for Foreign Service” for “Foreign Service star” in section catchline and wherever appearing in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
