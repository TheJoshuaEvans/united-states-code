{"tag":"section","attrib":{"id":"id8e81186a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212"},"text":null,"children":[{"tag":"num","attrib":{"value":"212"},"text":"§ 212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons entitled to passport","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No passport shall be granted or issued to or verified for any other persons than those owing allegiance, whether citizens or not, to the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8e81186b-2930-11f1-8918-be39dde81dc6"},"text":"(R.S. § 4076; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1902-06-14/ch1088/s2"},"text":"June 14, 1902, ch. 1088, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/32/386"},"text":"32 Stat. 386","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e81186c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e81186d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8e81186e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4076 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1866-05-30/ch102"},"text":"act May 30, 1866, ch. 102","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/14/54"},"text":"14 Stat. 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8e81186f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1902—Act ","children":[{"tag":"date","attrib":{"date":"1902-06-14"},"text":"June 14, 1902","children":[],"tail":", substituted “those owing allegiance, whether citizens or not, to the United States” for “citizens of the United States”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
