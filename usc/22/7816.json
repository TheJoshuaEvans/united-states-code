{"tag":"section","attrib":{"id":"id90ef804b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7816"},"text":null,"children":[{"tag":"num","attrib":{"value":"7816"},"text":"§ 7816.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of regional framework","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ef804c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7816/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress finds that human rights initiatives can be undertaken on a multilateral basis, such as the Organization for Security and Cooperation in Europe (OSCE), which established a regional framework for discussing human rights, scientific and educational cooperation, and economic and trade issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef804d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7816/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the United Sates ","children":[{"tag":"ref","attrib":{"idref":"fn002392"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002392"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “States”."}],"tail":" should explore the possibility of a regional human rights dialogue with North Korea that is modeled on the Helsinki process, engaging all countries in the region in a common commitment to respect human rights and fundamental freedoms."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ef804e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/333/tI/s106"},"text":"Pub. L. 108–333, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1292"},"text":"118 Stat. 1292","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
