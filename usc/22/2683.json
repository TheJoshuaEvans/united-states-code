{"tag":"section","attrib":{"id":"id8ff51b06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2683"},"text":null,"children":[{"tag":"num","attrib":{"value":"2683"},"text":"§ 2683.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assumption of obligations of operation of broadcasting facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Department of State shall assume all obligations of the Reconstruction Finance Corporation covering operations of said facilities, equipment, and appurtenant property outstanding at the date of transfer.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ff51b07-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-07-09/ch301/s3"},"text":"July 9, 1949, ch. 301, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/408"},"text":"63 Stat. 408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff51b08-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff51b09-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ff51b0a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s170c"},"text":"section 170c of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8ff51b0b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ff51b0c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Reconstruction Finance Corporation","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6(a) of Reorg. Plan No. 1 of 1957, eff. ","children":[{"tag":"date","attrib":{"date":"1957-06-30"},"text":"June 30, 1957","children":[],"tail":", 22 F.R. 4633, "},{"tag":"ref","attrib":{"href":"/us/stat/71/647"},"text":"71 Stat. 647","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s601"},"text":"section 601 of Title 15","children":[],"tail":", Commerce and Trade, abolished the Reconstruction Finance Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
