{"tag":"section","attrib":{"id":"id909e7ac0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5851"},"text":null,"children":[{"tag":"num","attrib":{"value":"5851"},"text":"§ 5851.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that it is in the national security interest of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id909e7ac1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5851/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to facilitate, on a priority basis—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id909e7ac2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5851/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation, storage, safeguarding, and destruction of nuclear and other weapons of mass destruction of the independent states of the former Soviet Union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id909e7ac3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5851/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevention of proliferation of weapons of mass destruction and destabilizing conventional weapons of the independent states, and the establishment of verifiable safeguards against the proliferation of such weapons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id909e7ac4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5851/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevention of diversion of weapons-related scientific expertise of the former Soviet Union to terrorist groups or third countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id909e7ac5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5851/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other efforts designed to reduce the military threat from the former Soviet Union;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id909e7ac6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5851/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the conversion of the massive defense-related industry and equipment of the independent states of the former Soviet Union for civilian purposes and uses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id909e7ac7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5851/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand military-to-military contacts between the United States and the independent states.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id909e7ac8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/tV/s501"},"text":"Pub. L. 102–511, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3338"},"text":"106 Stat. 3338","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
