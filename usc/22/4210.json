{"tag":"section","attrib":{"id":"id907372fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4210"},"text":null,"children":[{"tag":"num","attrib":{"value":"4210"},"text":"§ 4210.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for uncollected fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Every consul general, consul, or vice consul appointed to perform the duty of any such officer, who omits to collect any fees which he is entitled to charge for any official service, shall be liable to the United States therefor, as if he had collected the same; unless, upon good cause shown therefor, the Secretary of the Treasury shall think proper to remit the same.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907372ff-2930-11f1-8918-be39dde81dc6"},"text":"(R.S. § 1724; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-04-05/ch1366/s3"},"text":"Apr. 5, 1906, ch. 1366, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/100"},"text":"34 Stat. 100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90737300-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90737301-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90737302-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1724 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1856-08-18/ch127/s18"},"text":"act Aug. 18, 1856, ch. 127, § 18","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/58"},"text":"11 Stat. 58","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"References to “commercial agent” and “vice-commercial agent” were omitted in view of the abolition of the grade of commercial agent by act ","children":[{"tag":"date","attrib":{"date":"1906-04-05"},"text":"Apr. 5, 1906","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1190"},"text":"section 1190 of this title","children":[],"tail":", and prior thereto to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s93"},"text":"section 93 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
