{"tag":"section","attrib":{"id":"id8f2ce96d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2023"},"text":null,"children":[{"tag":"num","attrib":{"value":"2023"},"text":"§ 2023.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions and votes of representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The representatives provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2021"},"text":"section 2021 of this title","children":[],"tail":", when representing the United States in the organs of the Agency, shall, at all times, act in accordance with the instructions of the President, and such representatives shall, in accordance with such instructions, cast any and all votes under the Statute of the International Atomic Energy Agency."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f2ce96e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/177/s4"},"text":"Pub. L. 85–177, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-08-28"},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/454"},"text":"71 Stat. 454","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f2ce96f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f2ce970-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f2ce971-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Authority Under This Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Authority under this section to terminate if Senate refuses its advice and consent by a formal vote to an amendment to the Statute of the Agency, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2026"},"text":"section 2026 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
