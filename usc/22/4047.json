{"tag":"section","attrib":{"id":"id905e1649-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047"},"text":null,"children":[{"tag":"num","attrib":{"value":"4047"},"text":"§ 4047.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of annuity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id905e164a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of annuity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id905e164b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise provided in paragraph (2), the annuity of a participant who has met the eligibility requirements for an annuity shall commence on the first day of the month after—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id905e164c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separation from the Service occurs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905e164d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay ceases and the service and age requirements for entitlement to annuity are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905e164e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The annuity of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id905e164f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a participant who is retired and is eligible for benefits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4009/a"},"text":"section 4009(a) of this title","children":[],"tail":" or a participant who is retired under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4053"},"text":"section 4053 of this title","children":[],"tail":" or is otherwise involuntarily separated from the Service, except by removal for cause on charges of misconduct or delinquency,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905e1650-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a participant retiring under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4048"},"text":"section 4048 of this title","children":[],"tail":" due to a disability, and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905e1651-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a participant who serves 3 days or less in the month of retirement—","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall commence on the day after separation from the Service or the day after pay ceases and the requirements for entitlement to annuity are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id905e1652-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivor’s annuity; application; proof of eligibility; payment to estate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annuity to a survivor shall become effective as otherwise specified but shall not be paid until the survivor submits an application for such annuity, supported by such proof of eligibility as the Secretary of State may require. If such application or proof of eligibility is not submitted during the lifetime of an otherwise eligible individual, no annuity shall be due or payable to his or her estate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id905e1653-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual entitled to annuity from the Fund may decline to accept all or any part of the annuity by submitting a signed waiver to the Secretary of State. The waiver may be revoked in writing at any time. Payment of the annuity waived may not be made for the period during which the waiver was in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id905e1654-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of overpayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recovery of overpayments under this part may not be made from an individual when, in the judgment of the Secretary of State, the individual is without fault and recovery would be against equity and good conscience or administratively infeasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id905e1655-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternate forms of annuities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id905e1656-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State shall prescribe regulations under which any participant who has a life-threatening affliction or other critical medical condition may, at the time of retiring under this part (other than under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4048"},"text":"section 4048 of this title","children":[],"tail":"), elect annuity benefits under this section instead of any other benefits under this part (including survivor benefits) based on the service of the participant."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905e1657-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (3), the Secretary of State shall by regulation provide for such alternative forms of annuities as the Secretary considers appropriate, except that among the alternatives offered shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id905e1658-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an alternative which provides for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id905e1659-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of the lump-sum credit (excluding interest) to the participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id905e165a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of an annuity to the participant for life; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905e165b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a participant who is married at the time of retirement, an alternative which provides for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id905e165c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of the lump-sum credit (excluding interest) to the participant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id905e165d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of an annuity to the participant for life, with a survivor annuity payable for the life of a surviving spouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905e165e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each alternative provided for under paragraph (2) shall, to the extent practicable, be designed such that the total value of the benefits provided under such alternative (including any lump-sum credit) is actuarially equivalent to the value of the annuity which would otherwise be provided the participant under this part, as computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4046/a"},"text":"section 4046(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905e165f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A participant who, at the time of retiring under this part—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id905e1660-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is married, shall be ineligible to make an election under this section unless a waiver is made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4046/b/1/B"},"text":"section 4046(b)(1)(B) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905e1661-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a former spouse, shall be ineligible to make an election under this section if the former spouse is entitled to benefits under this part (based on the service of the participant) unless a waiver has been made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4046/b/1/C"},"text":"section 4046(b)(1)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905e1662-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A participant who is married at the time of retiring under this part and who makes an election under this section may, during the 18-month period beginning on the date of retirement, make the election provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4046/n"},"text":"section 4046(n) of this title","children":[],"tail":", subject to the deposit requirement thereunder."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905e1663-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4047/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, any lump-sum credit provided pursuant to an election under this subsection shall not preclude an individual from receiving any other benefits under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id905e1664-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s807"},"text":"Pub. L. 96–465, title I, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2109"},"text":"94 Stat. 2109","children":[],"tail":"; Ex. Ord. No. 12446, § 3(a), "},{"tag":"date","attrib":{"date":"1983-10-17"},"text":"Oct. 17, 1983","children":[],"tail":", 48 F.R. 48443; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tIV"},"text":"Pub. L. 99–335, title IV","children":[],"tail":", §§ 402(a)(2), 408, "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/609"},"text":"100 Stat. 609","children":[],"tail":", 612; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXI/s11002/b"},"text":"Pub. L. 103–66, title XI, § 11002(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/409"},"text":"107 Stat. 409","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id905e1665-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id905e1666-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id905e1667-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" substituted “any participant who has a life-threatening affliction or other critical medical condition” for “a participant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/s402/a/2"},"text":"Pub. L. 99–335, § 402(a)(2)","children":[],"tail":", substituted “part” for “subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/s408"},"text":"Pub. L. 99–335, § 408","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). Ex. Ord. No. 12446 amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “Except as otherwise provided, the annuity of a former participant who has met the eligibility requirements for an annuity shall commence on the day after separation from the Service or on the day after pay ceases. The annuity of a former participant who is entitled to a deferred annuity under this chapter shall become effective on the day he or she attains age 60.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id905e1668-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id905e1669-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"Oct. 1, 1994","children":[],"tail":", and applicable with respect to any annuity commencing on or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s11002/d"},"text":"section 11002(d) of Pub. L. 103–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8343a"},"text":"section 8343a of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id905e166a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335"},"text":"Pub. L. 99–335","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/s702/a"},"text":"section 702(a) of Pub. L. 99–335","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401"},"text":"section 8401 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id905e166b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by Ex. Ord. No. 12446 effective 30 days after ","children":[{"tag":"date","attrib":{"date":"1983-10-17"},"text":"Oct. 17, 1983","children":[],"tail":", see section 3(b) of Ex. Ord. No. 12446, set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4067"},"text":"section 4067 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
