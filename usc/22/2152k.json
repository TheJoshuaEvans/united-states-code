{"tag":"section","attrib":{"id":"id8f5ef59d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k"},"text":null,"children":[{"tag":"num","attrib":{"value":"2152k"},"text":"§ 2152k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to improve early childhood outcomes globally","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f5ef59e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f5ef59f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f5ef5a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef5a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early childhood development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “early childhood development” means the development and learning of a child younger than 8 years of age, including physical, cognitive, social, and emotional development and approaches to learning that allow a child to reach his or her full developmental potential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef5a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early childhood development program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “early childhood development program” means a program that seeks to ensure that every child has the conditions for healthy growth, nurturing family-based care, development and learning, and protection from violence, exploitation, abuse, and neglect, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f5ef5a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a health, safe water, sanitation, and hygiene program that serves pregnant women, children younger than 5 years of age, and the parents of such children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nutrition program, combined with stimulating child development activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" age appropriate cognitive stimulation, especially for newborns, infants, and toddlers, including an early childhood intervention program for children experiencing at-risk situations, developmental delays, disabilities, and behavioral and mental health conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an early learning (36 months and younger), preschool, and basic education program for children until they reach 8 years of age or complete primary school; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child protection program, with an emphasis on the promotion of permanent, safe, and nurturing families, rather than placement in residential care or institutions, including for children with disabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef5ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant Federal departments and agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “relevant Federal departments and agencies” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f5ef5ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Agency for International Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Department of Health and Human Services, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8f5ef5b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Centers for Disease Control and Prevention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f5ef5b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Institutes of Health;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Millennium Challenge Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Peace Corps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/4/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other department or agency specified by the President for the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef5b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residential care","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “residential care” means care provided in any non-family-based group setting, including orphanages, transit or interim care centers, children’s homes, children’s villages or cottage complexes, group homes, and boarding schools used primarily for care purposes as an alternative to a children’s home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f5ef5ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f5ef5bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support early childhood development in relevant foreign assistance programs, including by integrating evidence-based, efficient, and effective interventions into relevant strategies and programs, in coordination with partner countries, other donors, international organizations, international financial institutions, local and international nongovernmental organizations, private sector partners, and civil society, including faith-based and community-based organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef5bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to encourage partner countries to lead early childhood development initiatives that include incentives for building local capacity for continued implementation and measurable results, by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f5ef5bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scaling up the most effective, evidence-based, national interventions, including for the most vulnerable populations and children with disabilities and developmental delays, with a focus on adaptation to country resources, cultures, and languages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designing, implementing, monitoring, and evaluating programs in a manner that enhances their quality, transparency, equity, accountability, efficiency and effectiveness in improving child and family outcomes in partner countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilizing and expanding innovative public-private financing mechanisms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f5ef5c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f5ef5c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", the Administrator of the United States Agency for International Development on behalf of the President and in coordination with the Secretary of State, shall direct relevant Federal departments and agencies—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f5ef5c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to incorporate, to the extent practical and relevant, early childhood development into foreign assistance programs to be carried out during the following 5 fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote inclusive early childhood development in partner countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef5c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Administrator, the Secretary, and the heads of other relevant Federal departments and agencies as appropriate shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f5ef5c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build on the evidence and priorities outlined in “Advancing Protection and Care for Children in Adversity: A U.S. Government Strategy for International Assistance 2019–2023”, published in June 2019 (referred to in this section as “APCCA”);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, identify evidence-based strategic priorities, indicators, outcomes, and targets, particularly emphasizing the most vulnerable populations and children with disabilities and developmental delays, to support inclusive early childhood development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the design, implementation, and evaluation of pilot projects in partner countries, with the goal of taking such projects to scale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support inclusive early childhood development within all relevant sector strategies and public laws, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8f5ef5c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Global Water Strategy required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2152h/j"},"text":"section 2152h(j) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f5ef5ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the whole-of-government strategy required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9304"},"text":"section 9304 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f5ef5cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Basic Education Strategy set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151c/c"},"text":"section 2151c(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f5ef5cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the U.S. Government Global Nutrition Coordination Plan, 2016–2021; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f5ef5cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" APCCA; and others as appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve coordination with foreign governments and international and regional organizations with respect to official country policies and plans to improve early childhood development, maternal, newborn, and child health and nutrition care, basic education, water, sanitation and hygiene, and child protection plans which promote nurturing, appropriate, protective, and permanent family care, while reducing the percentage of children living outside of family care, including in residential care or on the street; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f5ef5cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with partner countries, other donors, international organizations, international financial institutions, local and international nongovernmental organizations, private sector partners and faith-based and community-based organizations, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f5ef5d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on the implementation of the strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Special Advisor for Children in Adversity shall include, in the annual report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2152g"},"text":"section 2152g of this title","children":[],"tail":", which shall be submitted to the appropriate congressional committees and made publicly available, a description of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f5ef5d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made toward integrating early childhood development interventions into relevant strategies and programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef5d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts made by relevant Federal departments and agencies to implement subsection (c), with a particular focus on the activities described in such subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef5d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress achieved during the reporting period toward meeting the goals, objectives, benchmarks, and timeframes described in subsection (c) at the program level, along with specific challenges or gaps that may require shifts in targeting or financing in the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f5ef5d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency task force","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Special Advisor for Assistance to Orphans and Vulnerable Children should establish and regularly convene an Interagency Working Group on Children in Adversity which, among other things, will coordinate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f5ef5d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intergovernmental and interagency monitoring, evaluation, and reporting of the activities carried out pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef5d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early childhood development initiatives that include children with a variety of needs and circumstances; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f5ef5d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2152k/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States Government early childhood development programs, strategies, and partnerships across relevant Federal departments and agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f5ef5d8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 137, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1283/b"},"text":"Pub. L. 116–283, div. A, title XII, § 1283(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3985"},"text":"134 Stat. 3985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f5ef5d9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f5ef5da-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f5ef5db-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in enactment of this section to be construed to restrict or abrogate any other authorization for United States Agency for International Development activities or programs, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1285"},"text":"section 1285 of Pub. L. 116–283","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2152f"},"text":"section 2152f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
