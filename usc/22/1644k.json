{"tag":"section","attrib":{"id":"id8f1764db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1644k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1644k"},"text":"§ 1644k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are hereby authorized to be appropriated such sums as may be necessary to enable the Commission and the Treasury Department of ","children":[{"tag":"ref","attrib":{"idref":"fn002074"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002074"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “to”."}],"tail":" pay their respective administrative expenses incurred in carrying out their functions under this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f1764dc-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title VI, § 611, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/542"},"text":"Pub. L. 94–542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-18"},"text":"Oct. 18, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2512"},"text":"90 Stat. 2512","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
