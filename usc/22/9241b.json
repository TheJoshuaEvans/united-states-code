{"tag":"section","attrib":{"id":"id9123fe66-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241b"},"text":null,"children":[{"tag":"num","attrib":{"value":"9241b"},"text":"§ 9241b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions on foreign persons employing North Korean labor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9123fe67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c), the President shall designate any person identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9241/b/3"},"text":"section 9241(b)(3) of this title","children":[],"tail":" for the imposition of sanctions under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9123fe68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9123fe69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall impose the sanctions described in paragraph (2) with respect to any person designated under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sanctions described in this paragraph are sanctions pursuant to the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.) to block and prohibit all transactions in property and interests in property of a person designated under subsection (a), if such property and interests in property are in the United States, come within the United States, or are or come within the possession or control of a United States person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9123fe6b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9123fe6c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not be designated under subsection (a) if the President certifies to the appropriate congressional committees that the President has received reliable assurances from such person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9123fe6d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employment of North Korean laborers does not result in the direct or indirect transfer of convertible currency, luxury goods, or other stores of value to the Government of North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123fe6e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all wages and benefits are provided directly to the laborers, and are held, as applicable, in accounts within the jurisdiction in which they reside in locally denominated currency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123fe6f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241b/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the laborers are subject to working conditions consistent with international standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recertification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date on which the President transmits to the appropriate congressional committees an initial certification under paragraph (1), and every 180 days thereafter, the President shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9123fe71-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit a recertification stating that the conditions described in such paragraph continue to be met; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123fe72-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9241b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such recertification cannot be transmitted, impose the sanctions described in subsection (b) beginning on the date on which the President determines that such recertification cannot be transmitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9123fe73-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tIII/s302B"},"text":"Pub. L. 114–122, title III, § 302B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s321/b/1"},"text":"Pub. L. 115–44, title III, § 321(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/952"},"text":"131 Stat. 952","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9123fe74-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9123fe75-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9123fe76-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsec. (b)(2), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
