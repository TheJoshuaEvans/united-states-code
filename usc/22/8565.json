{"tag":"section","attrib":{"id":"id9105051b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8565"},"text":null,"children":[{"tag":"num","attrib":{"value":"8565"},"text":"§ 8565.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions; waivers; implementation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9105051c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8565/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9105051d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8565/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for intelligence, law enforcement, and national security activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sanctions under sections 8563 and 8564 of this title shall not apply to any authorized intelligence, law enforcement, or national security activities of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9105051e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8565/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to comply with United Nations Headquarters agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sanctions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8563/c/2"},"text":"section 8563(c)(2) of this title","children":[],"tail":" shall not apply with respect to the admission of an individual to the United States if the admission of the individual is necessary to permit the United States to comply with the Agreement regarding the Headquarters of the United Nations, signed at Lake Success "},{"tag":"date","attrib":{"date":"1947-06-26"},"text":"June 26, 1947","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1947-11-21"},"text":"November 21, 1947","children":[],"tail":", between the United Nations and the United States, the Convention on Consular Relations, done at Vienna "},{"tag":"date","attrib":{"date":"1963-04-24"},"text":"April 24, 1963","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1967-03-19"},"text":"March 19, 1967","children":[],"tail":", or other applicable international obligations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9105051f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8565/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National interests waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may waive the application of sanctions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8563"},"text":"section 8563 of this title","children":[],"tail":" with respect to a person if the President—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id91050520-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8565/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that the waiver is in the national interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91050521-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8565/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the appropriate congressional committees a report on the waiver and the reasons for the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91050522-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8565/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation; penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91050523-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8565/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may exercise all authorities provided to the President under sections 1702 and 1704 of title 50 to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91050524-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8565/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person that violates, attempts to violate, conspires to violate, or causes a violation of section 8563(c)(1) or 8564(b) of this title or any regulation, license, or order issued to carry out either such section shall be subject to the penalties set forth in subsections (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705"},"text":"section 1705 of title 50","children":[],"tail":" to the same extent as a person that commits an unlawful act described in subsection (a) of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91050525-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dAA/tII/s206"},"text":"Pub. L. 117–328, div. AA, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5535"},"text":"136 Stat. 5535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91050526-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91050527-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id91050528-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Masih Alinejad Harassment and Unlawful Targeting Act of 2022, also known as the Masih Alinejad HUNT Act of 2022, and not as part of the Comprehensive Iran Sanctions, Accountability, and Divestment Act of 2010 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
