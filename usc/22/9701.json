{"tag":"section","attrib":{"id":"id914a2388-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9701"},"text":null,"children":[{"tag":"num","attrib":{"value":"9701"},"text":"§ 9701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings; sense of Congress in support of the Interim President of Venezuela","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id914a2389-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a238a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Venezuela’s electoral event on ","children":[{"tag":"date","attrib":{"date":"2018-05-20"},"text":"May 20, 2018","children":[],"tail":" was characterized by widespread fraud and did not comply with international standards for a free, fair, and transparent electoral process."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a238b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Given the fraudulent nature of Venezuela’s ","children":[{"tag":"date","attrib":{"date":"2018-05-20"},"text":"May 20, 2018","children":[],"tail":" electoral event, Nicolás Maduro’s tenure as President of Venezuela ended on "},{"tag":"date","attrib":{"date":"2019-01-10"},"text":"January 10, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a238c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Assembly of Venezuela approved a resolution on ","children":[{"tag":"date","attrib":{"date":"2019-01-15"},"text":"January 15, 2019","children":[],"tail":" that terminated Nicolás Maduro’s authority as the President of Venezuela."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a238d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9701/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On ","children":[{"tag":"date","attrib":{"date":"2019-01-23"},"text":"January 23, 2019","children":[],"tail":", the President of the National Assembly of Venezuela was sworn in as the Interim President of Venezuela."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a238e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a238f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the decisions by the United States Government, more than 50 governments around the world, the Organization of American States, the Inter-American Development Bank, and the European Parliament to recognize National Assembly President Juan Guaidó as the Interim President of Venezuela;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a2390-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the Interim President of Venezuela to advance efforts to hold democratic presidential elections in the shortest possible period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a2391-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9701/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Organization of American States, with support from the United States Government and partner governments, should provide diplomatic, technical, and financial support for a new presidential election in Venezuela that complies with international standards for a free, fair, and transparent electoral process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914a2392-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tI/s111"},"text":"Pub. L. 116–94, div. J, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3030"},"text":"133 Stat. 3030","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id914a2393-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id914a2394-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id914a2395-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tI/s101"},"text":"Pub. L. 116–94, div. J, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3030"},"text":"133 Stat. 3030","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dJ/tI/s101"},"text":"“This title [enacting this chapter and amending provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":", War and National Defense] may be cited as the ‘Venezuela Emergency Relief, Democracy Assistance, and Development Act of 2019’ or the ‘VERDAD Act of 2019’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
