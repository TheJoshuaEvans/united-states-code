{"tag":"section","attrib":{"id":"id8f93733a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2347b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2347b"},"text":"§ 2347b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Education and training activities conducted under this part shall be designed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f93733b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2347b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage effective and mutually beneficial relations and increased understanding between the United States and foreign countries in furtherance of the goals of international peace and security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f93733c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2347b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the ability of participating foreign countries to utilize their resources, including defense articles and defense services obtained by them from the United States, with maximum effectiveness, thereby contributing to greater self-reliance by such countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f93733d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2347b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the awareness of nationals of foreign countries participating in such activities of basic issues involving internationally recognized human rights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f93733e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 543, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/329/tI/s106/a"},"text":"Pub. L. 94–329, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/733"},"text":"90 Stat. 733","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/384/s11/b"},"text":"Pub. L. 95–384, § 11(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-26"},"text":"Sept. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/736"},"text":"92 Stat. 736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f93733f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f937340-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f937341-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/384"},"text":"Pub. L. 95–384","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
