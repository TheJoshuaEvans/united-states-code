{"tag":"section","attrib":{"id":"id8fc09d85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i"},"text":null,"children":[{"tag":"num","attrib":{"value":"2431i"},"text":"§ 2431i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fc09d86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprise for the Americas Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Enterprise for the Americas Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738i/a"},"text":"section 1738i(a) of title 7","children":[],"tail":" shall, in addition to carrying out the responsibilities of the Board under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738i/c"},"text":"section 1738i(c) of title 7","children":[],"tail":", carry out the duties described in subsection (c) of this section for the purposes of this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc09d87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fc09d88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Enterprise for the Americas Board shall be composed of an additional four members appointed by the President as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fc09d89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two representatives from the United States Government, including a representative of the International Forestry Division of the United States Forest Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fc09d8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two representatives from private nongovernmental environmental, scientific, forestry, or academic organizations with experience and expertise in preservation, maintenance, sustainable uses, and restoration of tropical forests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc09d8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738i/b/2"},"text":"section 1738i(b)(2) of title 7","children":[],"tail":", the Enterprise for the Americas Board shall be headed by a chairperson who shall be appointed by the President and shall be the representative from the Department of State appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738i/b/1/A"},"text":"section 1738i(b)(1)(A) of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc09d8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties described in this subsection are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fc09d8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advise the Secretary of State on the negotiations of Tropical Forest Agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc09d8e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Ensure, in consultation with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fc09d8f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of the beneficiary country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fc09d90-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental organizations of the beneficiary country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fc09d91-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental organizations of the region (if appropriate);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fc09d92-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental, scientific, forestry, and academic leaders of the beneficiary country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fc09d93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental, scientific, forestry, and academic leaders of the region (as appropriate),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that a suitable administering body is identified for each Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc09d94-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431i/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review the programs, operations, and fiscal audits of each administering body.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fc09d95-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. V, § 811, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/214/s1"},"text":"Pub. L. 105–214, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/892"},"text":"112 Stat. 892","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/26/s3"},"text":"Pub. L. 107–26, § 3","children":[],"tail":", "},{"tag":"d