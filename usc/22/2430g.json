{"tag":"section","attrib":{"id":"id8fbe5377-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2430g"},"text":"§ 2430g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Americas Framework Agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fbe5378-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State is authorized, in consultation with other appropriate Government officials, to enter into an Americas Framework Agreement with any eligible country concerning the operation and use of the Americas Fund for that country. In the negotiation of such Agreements, the Secretary shall consult with the Enterprise for the Americas Board in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430h"},"text":"section 2430h of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe5379-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of Agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Americas Framework Agreement with an eligible country shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe537a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that country to establish an Americas Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe537b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that country to make interest payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430e/b/1"},"text":"section 2430e(b)(1) of this title","children":[],"tail":" into an Americas Fund;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe537c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that country to make prompt disbursements from the Americas Fund to the administering body described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe537d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when appropriate, seek to maintain the value of the local currency resources of the Americas Fund in terms of United States dollars;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe537e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify, in accordance with subsection (d), the purposes for which amounts in an Americas Fund may be used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe537f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain reasonable provisions for the enforcement of the terms of the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe5380-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administering body","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe5381-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds disbursed from the Americas Fund in each beneficiary country shall be administered by a body constituted under the laws of that country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5382-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The administering body shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe5383-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more individuals appointed by the United States Government,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe5384-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more individuals appointed by the government of the beneficiary country, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe5385-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" individuals who represent a broad range of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8fbe5386-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental nongovernmental organizations of the beneficiary country,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fbe5387-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child survival and child development nongovernmental organizations of the beneficiary country,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fbe5388-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local community development nongovernmental organizations of the beneficiary country, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fbe5389-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific or academic organizations or institutions of the beneficiary country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A majority of the members of the administering body shall be individuals described in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe538a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The administering body—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe538b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall receive proposals for grant assistance from eligible grant recipients (as determined under subsection (e)) and make grants to eligible grant recipients in accordance with the priorities agreed upon in the Americas Framework Agreement, consistent with subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe538c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be responsible for the management of the program and oversight of grant activities funded from resources of the Americas Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe538d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be subject, on an annual basis, to an audit of financial statements conducted in accordance with generally accepted auditing standards by an independent auditor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe538e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be required to grant to representatives of the United States Government Accountability Office such access to books and records associated with operations of the Americas Fund as the Comptroller General of the United States may request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe538f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall present an annual program for review each year by the Enterprise for the Americas Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe5390-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall submit a report each year on the activities that it undertook during the previous year to the Chair of the Enterprise for the Americas Board and to the government of the beneficiary country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe5391-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants from an Americas Fund shall be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe5392-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that link the conservation and sustainable use of natural resources with local community development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5393-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child survival and other child development activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe5394-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made from an Americas Fund shall be made to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe5395-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nongovernmental environmental, conservation, child survival and child development, development, and indigenous peoples organizations of the beneficiary country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5396-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate local or regional entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe5397-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in exceptional circumstances, the government of the beneficiary country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe5398-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of larger grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any grant of more than $100,000 from an Americas Fund shall be subject to veto by the Government of the United States or the government of the beneficiary country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbe5399-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430g/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event that a country ceases to meet the eligibility requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430b/a"},"text":"section 2430b(a) of this title","children":[],"tail":", as determined by the President pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430b/b"},"text":"section 2430b(b) of this title","children":[],"tail":", then grants from the Americas Fund for that country may only be made to nongovernmental organizations until such time as the President determines that such country meets the eligibility requirements set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2430b/a"},"text":"section 2430b(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbe539a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. IV, § 708, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/549/tVI/s602/a"},"text":"Pub. L. 102–549, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3667"},"text":"106 Stat. 3667","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fbe539b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fbe539c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8fbe539d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s708"},"text":"section 708 of Pub. L. 87–195","children":[],"tail":", pt. IV, "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/464"},"text":"75 Stat. 464","children":[],"tail":", amended sections 1041, 1112, 1136, 1148, and 1157 of this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/565"},"text":"Pub. L. 87–565","children":[],"tail":", pt. IV, § 401, "},{"tag":"date","attrib":{"date":"1962-08-01"},"text":"Aug. 1, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/263"},"text":"76 Stat. 263","children":[],"tail":", except insofar as section 708 affected sections 1041, 1112, 1136, 1148, and 1157."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fbe539e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
