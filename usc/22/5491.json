{"tag":"section","attrib":{"id":"id90902281-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5491"},"text":null,"children":[{"tag":"num","attrib":{"value":"5491"},"text":"§ 5491.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of SEED assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President should suspend all assistance to an East European country pursuant to this chapter if the President determines, and reports to the Congress, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90902282-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5491/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that country is engaged in international activities directly and fundamentally contrary to United States national security interests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90902283-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5491/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the president or any other government official of that country initiates martial law or a state of emergency for reasons other than to respond to a natural disaster or a foreign invasion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90902284-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5491/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member who was elected to that country’s parliament has been removed from that office or arrested through extraconstitutional processes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90902285-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tVIII/s801"},"text":"Pub. L. 101–179, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1322"},"text":"103 Stat. 1322","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90902286-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90902287-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90902288-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179"},"text":"Pub. L. 101–179","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1298"},"text":"103 Stat. 1298","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5401"},"text":"section 5401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
