{"tag":"section","attrib":{"id":"id9071291d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4151"},"text":null,"children":[{"tag":"num","attrib":{"value":"4151"},"text":"§ 4151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay and benefits pending conversion","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Until converted under the provisions of this subchapter, any individual who is in the Foreign Service before ","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":", and is serving under an appointment as a Foreign Service officer, Foreign Service information officer, Foreign Service Reserve officer with limited or unlimited tenure, or Foreign Service staff officer or employee, shall be treated for purposes of salary, allowances, and other matters as if such individual had been converted under section 4152 or 4153 of this title, as the case may be, on "},{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":", except that any adjustment of salary under this section shall take effect—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9071291e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4151/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual who is in the Foreign Service on ","children":[{"tag":"date","attrib":{"date":"1980-10-17"},"text":"October 17, 1980","children":[],"tail":", on the first day of the first pay period which begins on or after "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9071291f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4151/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual who is appointed to the Foreign Service after ","children":[{"tag":"date","attrib":{"date":"1980-10-17"},"text":"October 17, 1980","children":[],"tail":", on the date such appointment becomes effective."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90712920-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2101"},"text":"Pub. L. 96–465, title II, § 2101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2148"},"text":"94 Stat. 2148","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90712921-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90712922-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90712923-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"February 15, 1981","children":[],"tail":"” substituted in text for “the effective date of this Act” pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2403"},"text":"section 2403 of Pub. L. 96–465","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
