{"tag":"section","attrib":{"id":"id8ff9d615-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2705"},"text":null,"children":[{"tag":"num","attrib":{"value":"2705"},"text":"§ 2705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation of citizenship","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The following documents shall have the same force and effect as proof of United States citizenship as certificates of naturalization or of citizenship issued by the Attorney General or by a court having naturalization jurisdiction:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff9d616-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2705/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A passport, during its period of validity (if such period is the maximum period authorized by law), issued by the Secretary of State to a citizen of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff9d617-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2705/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report, designated as a “Report of Birth Abroad of a Citizen of the United States”, issued by a consular officer to document a citizen born abroad. For purposes of this paragraph, the term “consular officer” includes any United States citizen employee of the Department of State who is designated by the Secretary of State to adjudicate nationality abroad pursuant to such regulations as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff9d618-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 33, as added and renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tI/s117"},"text":"Pub. L. 97–241, title I, § 117","children":[],"tail":", title II, § 202(a), "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/279"},"text":"96 Stat. 279","children":[],"tail":", 282; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXII, § 2222(a), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-818"},"text":"112 Stat. 2681–818","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff9d619-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff9d61a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8ff9d61b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 33 of act ","children":[{"tag":"date","attrib":{"date":"1956-08-01"},"text":"Aug. 1, 1956","children":[],"tail":", was renumbered section 34 by "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/s117"},"text":"section 117 of Pub. L. 97–241","children":[],"tail":", and subsequently renumbered, and set out as a Short Title of 1956 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s111/1"},"text":"Pub. L. 102–138, title I, § 111(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/654"},"text":"105 Stat. 654","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ff9d61c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" inserted at end “For purposes of this paragraph, the term ‘consular officer’ includes any United States citizen employee of the Department of State who is designated by the Secretary of State to adjudicate nationality abroad pursuant to such regulations as the Secretary may prescribe.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff9d61d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ff9d61e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Record of Place of Birth for Taiwanese-Americans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s132"},"text":"Pub. L. 103–236, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/395"},"text":"108 Stat. 395","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/r"},"text":"Pub. L. 103–415, § 1(r)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4302"},"text":"108 Stat. 4302","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/415/s1/r"},"text":"“For purposes of the registration of birth or certification of nationality or issuance of a passport of a United States citizen born in Taiwan, the Secretary of State shall permit the place of birth to be recorded as Taiwan.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
