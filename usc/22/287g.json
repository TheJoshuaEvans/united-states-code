{"tag":"section","attrib":{"id":"id8ed700ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287g"},"text":null,"children":[{"tag":"num","attrib":{"value":"287g"},"text":"§ 287g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for loan to United Nations; restrictions on use of proceeds of loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated to the President, without fiscal-year limitation, out of any money in the Treasury not otherwise appropriated, $100,000,000 for a loan to the United Nations. The proceeds of such loan shall not be used to relieve members of the United Nations of their obligation to pay arrearages on payments of any United Nations assessments, and shall not be used to reduce regular or special assessments against any such members.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ed700f0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/731/s1"},"text":"Pub. L. 87–731, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-02"},"text":"Oct. 2, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/695"},"text":"76 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ed700f1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ed700f2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ed700f3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-12-20/ch583"},"text":"act Dec. 20, 1945, ch. 583","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/619"},"text":"59 Stat. 619","children":[],"tail":", known as the United Nations Participation Act of 1945, which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
