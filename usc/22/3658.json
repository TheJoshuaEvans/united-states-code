{"tag":"section","attrib":{"id":"id904166d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3658"},"text":null,"children":[{"tag":"num","attrib":{"value":"3658"},"text":"§ 3658.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits based on basic pay","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of determining—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904166d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3658/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts of compensation for disability or death under chapter 81 of title 5, relating to compensation for work injuries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904166d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3658/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits under subchapter III of chapter 83 or chapter 84 of title 5, relating to retirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904166d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3658/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts of insurance under chapter 87 of title 5, relating to life insurance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904166da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3658/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts of overtime pay or other premium pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904166db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3658/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual leave benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904166dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3658/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other benefits related to basic pay;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the basic pay of each employee shall include the rate of basic pay established for his position under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3642"},"text":"section 3642 of this title","children":[],"tail":" plus the amount of any additional compensation provided under section 3657(a) "},{"tag":"ref","attrib":{"idref":"fn002267"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002267"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904166dd-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1218"},"text":"Pub. L. 96–70, title I, § 1218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/466"},"text":"93 Stat. 466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dC/tXXXV/s3534"},"text":"Pub. L. 104–201, div. C, title XXXV, § 3534","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2863"},"text":"110 Stat. 2863","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"