{"tag":"section","attrib":{"id":"id8ffeb85b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2719d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2719d"},"text":"§ 2719d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Language incentive pay for civil service employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may provide special monetary incentives to acquire or retain proficiency in foreign languages to civil service employees who serve in domestic positions requiring critical language skills that are located in the 50 United States, the District of Columbia, and non-foreign areas (the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, and other United States territories and possessions). The amounts of such incentives should be similar to the language incentive pay provided to members of the Foreign Service pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4024/b/3"},"text":"section 4024(b)(3) of this title","children":[],"tail":", as amended by section 5206."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ffeb85c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tII/s5203"},"text":"Pub. L. 119–60, div. E, title II, § 5203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1591"},"text":"139 Stat. 1591","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ffeb85d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ffeb85e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ffeb85f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5206, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s5206"},"text":"section 5206 of Pub. L. 119–60","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4024"},"text":"section 4024 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ffeb860-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8ffeb861-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Secretary” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s5002"},"text":"section 5002 of Pub. L. 119–60","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
