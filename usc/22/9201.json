{"tag":"section","attrib":{"id":"id911cd261-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201"},"text":null,"children":[{"tag":"num","attrib":{"value":"9201"},"text":"§ 9201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings; purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911cd262-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd263-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Government of North Korea—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd264-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has repeatedly violated its commitments to the complete, verifiable, and irreversible dismantlement of its nuclear weapons programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd265-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has willfully violated multiple United Nations Security Council resolutions calling for North Korea to cease development, testing, and production of weapons of mass destruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd266-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Based on its past actions, including the transfer of sensitive nuclear and missile technology to state sponsors of terrorism, North Korea poses a grave risk for the proliferation of nuclear weapons and other weapons of mass destruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd267-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Government of North Korea has been implicated repeatedly in money laundering and other illicit activities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd268-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibited arms sales;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd269-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" narcotics trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd26a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the counterfeiting of United States currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd26b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant activities undermining cybersecurity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd26c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the counterfeiting of intellectual property of United States persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd26d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" North Korea has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd26e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unilaterally withdrawn from the Agreement Concerning a Military Armistice in Korea, signed at Panmunjom ","children":[{"tag":"date","attrib":{"date":"1953-07-27"},"text":"July 27, 1953","children":[],"tail":" (commonly referred to as the “Korean War Armistice Agreement”); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd26f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" committed provocations against South Korea—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911cd270-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by sinking the warship ","children":[{"tag":"i","attrib":{},"text":"Cheonan","children":[],"tail":" and killing 46 of her crew on "},{"tag":"date","attrib":{"date":"2010-03-26"},"text":"March 26, 2010","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911cd271-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by shelling Yeonpyeong Island and killing 4 South Korean civilians on ","children":[{"tag":"date","attrib":{"date":"2010-11-23"},"text":"November 23, 2010","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911cd272-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by its involvement in the “DarkSeoul” cyberattacks against the financial and communications interests of South Korea on ","children":[{"tag":"date","attrib":{"date":"2013-03-20"},"text":"March 20, 2013","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911cd273-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by planting land mines near a guard post in the South Korean portion of the demilitarized zone that maimed 2 South Korean soldiers on ","children":[{"tag":"date","attrib":{"date":"2015-08-04"},"text":"August 4, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd274-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" North Korea maintains a system of brutal political prison camps that contain as many as 200,000 men, women, and children, who are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd275-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" kept in atrocious living conditions with insufficient food, clothing, and medical care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd276-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under constant fear of torture or arbitrary execution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd277-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" North Korea has prioritized weapons programs and the procurement of luxury goods—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd278-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in defiance of United Nations Security Council Resolutions 1695 (2006), 1718 (2006), 1874 (2009), 2087 (2013), and 2094 (2013); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd279-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in gross disregard of the needs of the people of North Korea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd27a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Persons, including financial institutions, who engage in transactions with, or provide financial services to, the Government of North Korea and its financial institutions without establishing sufficient financial safeguards against North Korea’s use of such transactions to promote proliferation, weapons trafficking, human rights violations, illicit activity, and the purchase of luxury goods—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd27b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aid and abet North Korea’s misuse of the international financial system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd27c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violate the intent of the United Nations Security Council resolutions referred to in paragraph (6)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd27d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Government of North Korea has provided technical support and conducted destructive and coercive cyberattacks, including against Sony Pictures Entertainment and other United States persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd27e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The conduct of the Government of North Korea poses an imminent threat to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd27f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the security of the United States and its allies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd280-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the global economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd281-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety of members of the United States Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd282-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integrity of the global financial system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd283-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integrity of global nonproliferation programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd284-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/9/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the people of North Korea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd285-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Government of North Korea has sponsored acts of international terrorism, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd286-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempts to assassinate defectors and human rights activists; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd287-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the shipment of weapons to terrorists and state sponsors of terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911cd288-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd289-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use nonmilitary means to address the crisis described in subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd28a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide diplomatic leverage to negotiate necessary changes in the conduct of the Government of North Korea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd28b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ease the suffering of the people of North Korea; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd28c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9201/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reaffirm the purposes set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7802"},"text":"section 7802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911cd28d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/s2"},"text":"Pub. L. 114–122, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/94"},"text":"130 Stat. 94","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911cd28e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911cd28f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id911cd290-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122"},"text":"Pub. L. 114–122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/93"},"text":"130 Stat. 93","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id911cd291-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id911cd292-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tIV/s406"},"text":"Pub. L. 114–122, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/116"},"text":"130 Stat. 116","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/122/tIV/s406"},"text":"“Except as otherwise provided in this Act, this Act [see Short Title note below] and the amendments made by this Act shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id911cd293-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXI/s7101"},"text":"Pub. L. 116–92, div. F, title LXXI, § 7101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2244"},"text":"133 Stat. 2244","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dF/tLXXI/s7101"},"text":"“This title [enacting subchapter V of this chapter and sections 262p–13, 286yy, 9221b, and 9221c of this title, amending sections 7103, 9202, 9212, 9214, 9223, 9224, 9228, 9241, and 9251 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s312"},"text":"section 312 of Title 31","children":[],"tail":", Money and Finance, repealing sections 262p–13 and 286yy of this title, and enacting provisions set out as notes under sections 262p–13, 286yy, and 7101 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s3305"},"text":"section 3305 of Title 12","children":[],"tail":", Banks and Banking] may be cited as the ‘Otto Warmbier North Korea Nuclear Sanctions and Enforcement Act of 2019’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag