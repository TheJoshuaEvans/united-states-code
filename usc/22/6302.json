{"tag":"section","attrib":{"id":"id90b3d766-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6302"},"text":null,"children":[{"tag":"num","attrib":{"value":"6302"},"text":"§ 6302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of international financial institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States executive director to each of the international financial institutions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262d/a"},"text":"section 262d(a) of this title","children":[],"tail":" to use the voice and vote of the United States to oppose any use of the institution’s funds to promote the acquisition of unsafeguarded special nuclear material or the development, stockpiling, or use of any nuclear explosive device by any non-nuclear-weapon state."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90b3d767-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVIII/s823/a"},"text":"Pub. L. 103–236, title VIII, § 823(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/512"},"text":"108 Stat. 512","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90b3d768-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90b3d769-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90b3d76a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","