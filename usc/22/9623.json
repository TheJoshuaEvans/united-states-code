{"tag":"section","attrib":{"id":"id914568e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623"},"text":null,"children":[{"tag":"num","attrib":{"value":"9623"},"text":"§ 9623.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of losses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id914568e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for defaults on guaranteed loans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914568e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Corporation determines that the holder of a loan guaranteed by the Corporation suffers a loss as a result of a default by a borrower on the loan, the Corporation shall pay to the holder the percent of the loss, as specified in the guaranty contract, after the holder of the loan has made such further collection efforts and instituted such enforcement proceedings as the Corporation may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914568ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subrogation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon making a payment described in paragraph (1), the Corporation shall ensure the Corporation will be subrogated to all the rights of the recipient of the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914568eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall pursue recovery from the borrower of the amount of any payment made under paragraph (1) with respect to the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914568ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914568ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided by paragraph (2), compensation for insurance, reinsurance, or a guaranty issued under this subchapter shall not exceed the dollar value of the tangible or intangible contributions or commitments made in the project, plus interest, earnings, or profits actually accrued on such contributions or commitments, to the extent provided by such insurance, reinsurance, or guaranty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914568ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914568ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation may provide that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id914568f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate adjustments in the insured dollar value be made to reflect the replacement cost of project assets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id914568f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for a claim of loss under insurance of an equity investment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9621"},"text":"section 9621 of this title","children":[],"tail":" may be computed on the basis of the net book value attributable to the equity investment on the date of loss."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914568f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional limitation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914568f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (2)(A)(ii) and except as provided in subparagraph (B), the Corporation shall limit the amount of direct insurance and reinsurance issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9621"},"text":"section 9621 of this title","children":[],"tail":" with respect to a project so as to require that the insured and its affiliates bear the risk of loss for at least 10 percent of the amount of the Corporation’s exposure to that insured and its affiliates in the project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914568f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitation under subparagraph (A) shall not apply to direct insurance or reinsurance of loans provided by banks or other financial institutions to unrelated parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914568f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall take such action as may be appropriate to enforce any right accruing to the United States as a result of the issuance of any loan or guaranty under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914568f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9623/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to preclude any forbearance for the benefit of a borrower that may be agreed upon by the parties to a loan guaranteed by the Corporation if budget authority for any resulting costs to the United States Government (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":") is available."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914568f7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tII/s1423"},"text":"Pub. L. 115–254, div. F, title II, § 1423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3498"},"text":"132 Stat. 3498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id914568f8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id914568f9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section 7 years after ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9624"},"text":"section 9624 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
