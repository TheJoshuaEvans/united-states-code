{"tag":"section","attrib":{"id":"id904fbe92-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949"},"text":null,"children":[{"tag":"num","attrib":{"value":"3949"},"text":"§ 3949.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited appointments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904fbe93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A limited appointment in the Service, including an appointment of an individual who is an employee of an agency, may not exceed 5 years in duration and, except as provided in subsections (b) and (c), may not be extended or renewed. A limited appointment in the Service which is limited by its terms to a period of one year or less is a temporary appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904fbe94-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A limited appointment may be extended for continued service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904fbe95-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a consular agent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904fbe96-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3951/a"},"text":"section 3951(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904fbe97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as a career candidate, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id904fbe98-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continued service is determined appropriate to remedy a matter that would be cognizable as a grievance under subchapter XI; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id904fbe99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual is serving in the uniformed services (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4303"},"text":"section 4303 of title 38","children":[],"tail":") and the limited appointment expires in the course of such service;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904fbe9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a career employee in another Federal personnel system serving in a Foreign Service position on detail from another agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904fbe9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a foreign national employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904fbe9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in exceptional circumstances if the Secretary determines the needs of the Service require the extension of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id904fbe9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a limited noncareer appointment for a period not to exceed 1 year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id904fbe9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a limited appointment of a career candidate for the minimum time needed to resolve a grievance, claim, investigation, or complaint not otherwise provided for in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904fbe9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904fbea0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2) noncareer employees who have served for 5 consecutive years under a limited appointment under this section may be reappointed to a subsequent noncareer limited appointment if there is at least a 1-year break in service before such new appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904fbea1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3949/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive the 1-year break requirement under paragraph (1) in cases of special need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904fbea2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s309"},"text":"Pub. L. 96–465, title I, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2086"},"text":"94 Stat. 2086","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s176"},"text":"Pub. L. 100–204, title I, § 176","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1361"},"text":"101 Stat. 1361","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s180/a/1"},"text":"Pub. L. 103–236, title I, § 180(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/415"},"text":"108 Stat. 415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/hh"},"text":"Pub. L. 103–415, § 1(hh)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4303"},"text":"108 Stat. 4303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/323/tIV/s409"},"text":"Pub. L. 114–323, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1930"},"text":"130 Stat. 1930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904fbea3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904fbea4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id904fbea5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s409/1"},"text":"Pub. L. 114–323, § 409(1)","children":[],"tail":", substituted “subsections (b) and (c)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s409/2/A"},"text":"Pub. L. 114–323, § 409(2)(A)","children":[],"tail":", substituted “if—” for “if”, inserted subpar. (A) designation before “continued service” and “or” after semicolon at end, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s409/2/B"},"text":"Pub. L. 114–323, § 409(2)(B)","children":[],"tail":"–(D), added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s409/3"},"text":"Pub. L. 114–323, § 409(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/415"},"text":"Pub. L. 103–415","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" designated existing provisions as subsec. (a), substituted “subsection (b)” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3951/a"},"text":"section 3951(a) of this title","children":[],"tail":"”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
