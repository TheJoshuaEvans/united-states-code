{"tag":"section","attrib":{"id":"id9126489a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9306"},"text":null,"children":[{"tag":"num","attrib":{"value":"9306"},"text":"§ 9306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency Food Security Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be the policy of the United States, in coordination with other donors, regional governments, international organizations, and international financial institutions, to fully leverage, enhance, and expand the impact and reach of available United States humanitarian resources, including for food assistance, to mitigate the effects of manmade and natural disasters by utilizing innovative new approaches to delivering aid that support affected persons and the communities hosting them, build resilience and early recovery, and reduce opportunities for waste, fraud, and abuse.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9126489b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/195/s7"},"text":"Pub. L. 114–195, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-20"},"text":"July 20, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/680"},"text":"130 Stat. 680","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5588/g/1"},"text":"Pub. L. 117–263, div. E, title LV, § 5588(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3378"},"text":"136 Stat. 3378","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9126489c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9126489d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9126489e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/195/s7"},"text":"section 7 of Pub. L. 114–195","children":[],"tail":". Subsec. (c)(1) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/195/s7"},"text":"section 7 of Pub. L. 114–195","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292"},"text":"section 2292 of this title","children":[],"tail":" and subsec. (c)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/195/s7"},"text":"section 7 of Pub. L. 114–195","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2292a"},"text":"section 2292a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9126489f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" struck out subsec. (b) designation and heading before “It shall be” and struck out subsec. (a) which related to sense of Congress regarding challenges of providing international disaster assistance, especially in Syria."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
