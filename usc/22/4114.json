{"tag":"section","attrib":{"id":"id906c6edf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4114"},"text":null,"children":[{"tag":"num","attrib":{"value":"4114"},"text":"§ 4114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resolution of implementation disputes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id906c6ee0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grievance procedure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any dispute between the Department and the exclusive representative concerning the effect, interpretation, or a claim of breach of a collective bargaining agreement shall be resolved through procedures negotiated by the Department and the exclusive representative. Any procedures negotiated under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906c6ee1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be fair and simple,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6ee2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for expeditious processing, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6ee3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4114/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include provision for appeal to the Foreign Service Grievance Board by either party of any dispute not satisfactorily settled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906c6ee4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by Foreign Service Labor Relations Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Either party to an appeal under subsection (a)(3) may file with the Board an exception to the action of the Foreign Service Grievance Board in resolving the implementation dispute. If, upon review, the Board finds that the action is deficient—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906c6ee5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4114/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because it is contrary to any law, rule, or regulation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6ee6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4114/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on other grounds similar to those applied by Federal courts in private sector labor-management relations;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Board may take such action and make such recommendations concerning the Foreign Service Grievance Board action as it considers necessary, consistent with applicable laws, rules, and regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906c6ee7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time of filing exceptions; finality and binding nature of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If no exception to a Foreign Service Grievance Board action is filed under subsection (b) within 30 days after such action is communicated to the parties, such action shall become final and binding and shall be implemented by the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906c6ee8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4114/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Resolutions of disputes under this section shall not be subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id906c6ee9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s1014"},"text":"Pub. L. 96–465, title I, § 1014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2137"},"text":"94 Stat. 2137","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
