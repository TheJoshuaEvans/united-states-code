{"tag":"section","attrib":{"id":"id8ff060cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670"},"text":null,"children":[{"tag":"num","attrib":{"value":"2670"},"text":"§ 2670.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance on motor vehicles in foreign countries; tie lines and teletype equipment; ice and drinking water; excise taxes on negotiable instruments; remains of deceased persons; relief, protection, and burial of seamen; acknowledgement of services of foreign vessels and aircraft; rentals and leases","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of State is authorized to—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff060ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain insurance on official motor vehicles operated by the Department of State in foreign countries, and pay the expenses incident thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rent tie lines and teletype equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide ice and drinking water for United States Embassies and Consulates abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay excise taxes on negotiable instruments which are negotiated by the Department of State abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Omitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay expenses incident to the relief, protection, and burial of American seamen, and alien seamen from United States vessels in foreign countries and in the United States Territories and possessions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay the expenses incurred in the acknowledgment of the services of officers and crews of foreign vessels and aircraft in rescuing American seamen, airmen, or citizens from shipwreck or other catastrophe abroad or at sea;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rent or lease, for periods of less than ten years, such offices, buildings, grounds, and living quarters for the use of the Foreign Service abroad as he may deem necessary, and make payments therefor in advance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain, improve, and repair properties rented or leased pursuant to authority contained in subsection (h) of this section and furnish fuel, water, and utilities for such properties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide emergency medical attention and dietary supplements, and other emergency assistance, for United States citizens incarcerated abroad or destitute United States citizens abroad who are unable to obtain such services otherwise, such assistance to be provided on a reimbursable basis to the extent feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the availability of appropriated funds, obtain insurance on the historic and artistic articles of furniture, fixtures, and decorative objects which may from time-to-time be within the responsibility of the Fine Arts Committee of the Department of State for the Diplomatic Rooms of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make payments in advance, of the United States share of necessary expenses for international fisheries commissions, from appropriations available for such purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, maintain, and operate passport and dispatch agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff060db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2670/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay expenses to provide internet services in residences owned or leased by the United States Government in foreign countries for the use of Department personnel where Department personnel receive a post hardship differential equivalent to 30 percent or more above basic compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff060dc-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 3, "},{"tag":"ref","attrib":{"href":"/us/stat/70/890"},"text":"70 Stat. 890","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/45/s2"},"text":"Pub. L. 95–45, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-06-15"},"text":"June 15, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/221"},"text":"91 Stat. 221","children":[],"tail":"; 1977 Reorg. Plan No. 2, § 9(a)(7), 42 F.R. 62461, "},{"tag":"ref","attrib":{"href":"/us/stat/91/1639"},"text":"91 Stat. 1639","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/426/tI/s108/a"},"text":"Pub. L. 95–426, title I, § 108(a)","children":[],"tail":", "},