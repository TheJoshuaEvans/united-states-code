":"crossHeading","topic":"editorialNotes","id":"id8ff060de-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ff060df-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s170h"},"text":"section 170h of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e) of this section, relating to the payment of the actual expenses of preparing and transporting to their former homes the remains of persons, not United States Government employees, who die away from their homes while participating in international educational exchange activities under the jurisdiction of the Department of State, was omitted pursuant to Reorg. Plan No. 2 of 1977, § 9(a)(7), 42 F.R. 62461, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/91/1639"},"text":"91 Stat. 1639","children":[],"tail":", set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1461"},"text":"section 1461 of this title","children":[],"tail":", effective on or before "},{"tag":"date","attrib":{"date":"1978-07-01"},"text":"July 1, 1978","children":[],"tail":", at such time as specified by the President, which abolished the functions of the Secretary of State under subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ff060e0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (n). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" added subsec. (n)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (m). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" added subsec. (m)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/102/138"},"text":"Pub. L. 102–138","children":[],"tail":" added subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" added subsec. (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/426"},"text":"Pub. L. 95–426","children":[],"tail":" inserted “or destitute United States citizens abroad” after “incarcerated abroad”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/45"},"text":"Pub. L. 95–45","children":[],"tail":" added subsec. (j)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff060e1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ff060e2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" applicable with respect to officials, offices, and bureaus of Department of State when executive orders, regulations, or departmental directives implementing the amendments by sections 161 and 162 of "},{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" become effective, or 90 days after "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", whichever comes earlier, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s161/b"},"text":"section 161(b) of Pub. L. 103–236","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ff060e3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/426/tI/s108/b"},"text":"Pub. L. 95–426, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-07"},"text":"Oct. 7, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/966"},"text":"92 Stat. 966","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/426/tI/s108/b"},"text":"“The amendment made by this section [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ff060e4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Providing Medical Services or Related Support in Response to Coronavirus Pandemic","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/dB/tXI/s21008"},"text":"Pub. L. 116–136, div. B, title XI, § 21008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/592"},"text":"134 Stat. 592","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/136/dB/tXI/s21008"},"text":"“The Secretary of State, to prevent, prepare for, and respond to coronavirus, may exercise the authorities of section 3(j) of the State Department Basic Authorities Act of 1956 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2670/j"},"text":"22 U.S.C. 2670(j)","children":[],"tail":") to provide medical services or related support for private United States citizens, nationals, and permanent resident aliens abroad, or third country nationals connected to such persons or to the diplomatic or development missions of the United States abroad, who are unable to obtain such services or support otherwise: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such assistance shall be provided on a reimbursable basis to the extent feasible: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That such reimbursements may be credited to the applicable Department of State appropriation and shall remain available until expended: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That the Secretary shall prioritize providing medical services or related support to individuals eligible for the health program under section 904 of the Foreign Service Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4084"},"text":"22 U.S.C. 4084","children":[],"tail":"): "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That the authority made available pursuant to this section shall expire on "},{"tag":"date","attrib":{"date":"2022-09-30"},"text":"September 30, 2022","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “coronavirus” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/136/s21008"},"text":"section 21008 of Pub. L. 116–136","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/s23005"},"text":"section 23005 of Pub. L. 116–136","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s162b"},"text":"section 162b of Title 2","children":[],"tail":", The Congress.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
