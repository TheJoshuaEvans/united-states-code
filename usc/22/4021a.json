{"tag":"section","attrib":{"id":"id90595aa8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4021a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4021a"},"text":"§ 4021a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matters relating to the Foreign Service Institute","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90595aa9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4021a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director line of reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Foreign Service Institute shall report to the Assistant Secretary for Human Resources for all matters pertaining to the management, execution, and strategy of the training and instruction required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4021"},"text":"section 4021 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90595aaa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4021a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schools of instruction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foreign Service Institute shall consist of at least four schools of instruction, which shall provide instruction consistent with the requirements set forth in this subchapter. The schools of instruction shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90595aab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4021a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The School of Professional and Area Studies, which shall provide job-specific orientation, tradecraft, and area studies, as well as new-hire orientation programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90595aac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4021a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The School of Leadership and Management Studies, which shall provide leadership and crisis management training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90595aad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4021a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The School of Applied Information Technology Studies, which shall provide instruction to ensure information technology professionals have the up-to-date knowledge and skills required to operate and maintain the complex computer and technology systems employed by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90595aae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4021a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The School of Foreign Languages, which shall be responsible for providing language instruction as prescribed by law and at the direction of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90595aaf-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tI/s5137"},"text":"Pub. L. 119–60, div. E, title I, § 5137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1568"},"text":"139 Stat. 1568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90595ab0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90595ab1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90595ab2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of State Authorization Act for Fiscal Year 2026, and as part of the National Defense Authorization Act for Fiscal Year 2026, and not as part of the Foreign Service Act of 1980, which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90595ab3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id90595ab4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/132/s1/b"},"text":"Pub. L. 107–132, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-16"},"text":"Jan. 16, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2412"},"text":"115 Stat. 2412","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/132/s1/b"},"text":"“Any reference in any provision of law to the National Foreign Affairs Training Center or the Foreign Service Institute shall be considered to be a reference to the ‘George P. Shultz National Foreign Affairs Training Center’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id90595ab5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary” and “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s5002"},"text":"section 5002 of Pub. L. 119–60","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
