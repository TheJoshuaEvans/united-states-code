{"tag":"section","attrib":{"id":"id8ec3edbe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–3"},"text":"§ 286e–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers to stabilization fund of purchase of currencies or gold from International Monetary Fund; administration; utilization of fund resources for repayments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any purchases of currencies or gold by the United States from the International Monetary Fund may be transferred to and administered by the fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5302"},"text":"section 5302 of title 31","children":[],"tail":", for use in accordance with the provisions of that section. The Secretary of the Treasury is authorized to utilize the resources of that fund for the purpose of any repayments in connection with such transactions."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ec3edbf-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s18"},"text":"July 31, 1945, ch. 339, § 18","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/490/s1"},"text":"Pub. L. 87–490, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-06-19"},"text":"June 19, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/105"},"text":"76 Stat. 105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ec3edc0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ec3edc1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ec3edc2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5302"},"text":"Section 5302 of title 31","children":[],"tail":"” substituted in text for “section 10 of the Gold Reserve Act of 1934, as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s822a"},"text":"31 U.S.C. 822a","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
