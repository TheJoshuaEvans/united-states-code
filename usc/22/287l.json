{"tag":"section","attrib":{"id":"id8ed70108-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s287l"},"text":null,"children":[{"tag":"num","attrib":{"value":"287l"},"text":"§ 287l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration that United Nations take steps to give effect to advisory opinion of International Court of Justice on financial obligations of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the sense of the Congress that the United Nations should take immediate steps to give effect to the advisory opinion of the International Court of Justice on the financial obligations of members of the United Nations in order to assure prompt payment of all assessments, including assessments to cover the cost of operations to maintain or restore international peace and security.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ed70109-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/731/s6"},"text":"Pub. L. 87–731, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-02"},"text":"Oct. 2, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/696"},"text":"76 Stat. 696","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ed7010a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ed7010b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ed7010c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-12-20/ch583"},"text":"act Dec. 20, 1945, ch. 583","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/619"},"text":"59 Stat. 619","children":[],"tail":", known as the United Nations Participation Act of 1945, which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
