{"tag":"section","attrib":{"id":"id8ecb1aa0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286yy"},"text":null,"children":[{"tag":"num","attrib":{"value":"286yy"},"text":"§ 286yy.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opposition to assistance for any government that fails to implement sanctions on North Korea","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ecb1aa1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286yy/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director at each international financial institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262r/c"},"text":"section 262r(c) of this title","children":[],"tail":") that it is the policy of the United States to oppose the provision by that institution of financial assistance to a foreign government, other than assistance to support basic human needs, if the President determines that, in the year preceding consideration of approval of such assistance, the government has knowingly failed to adequately enforce sanctions under an applicable United Nations Security Council resolution (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9202"},"text":"section 9202 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ecb1aa2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286yy/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may waive subsection (a) for up to 180 days at a time with respect to a foreign government if the President—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ecb1aa3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286yy/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ecb1aa4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286yy/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the failure of the foreign government described in subsection (a) is due exclusively to a lack of capacity on the part of the foreign government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ecb1aa5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286yy/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreign government is taking effective steps to prevent recurrence of such failure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ecb1aa6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286yy/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver is in the national security interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ecb1aa7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286yy/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to Congress a report on the reasons for the determination under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ecb1aa8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s73"},"text":"July 31, 1945, ch. 339, § 73","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXI/s7124/a"},"text":"Pub. L. 116–92, div. F, title LXXI, § 7124(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2248"},"text":"133 Stat. 2248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ecb1aa9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id8ecb1aaa-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXI/s7124/b"},"text":"Pub. L. 116–92, div. F, title LXXI, § 7124(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2249"},"text":"133 Stat. 2249","children":[],"tail":", provided that, effective on the date that is 10 years after "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", this section is repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ecb1aab-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ecb1aac-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 73 of the Bretton Woods Agreements Act was enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s286zz"},"text":"section 286zz of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ecb1aad-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8ecb1aae-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXI/s7124/b"},"text":"Pub. L. 116–92, div. F, title LXXI, § 7124(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2249"},"text":"133 Stat. 2249","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/92/dF/tLXXI/s7124/b"},"text":"“Effective on the date that is 10 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"], section 73 of the Bretton Woods Agreements Act [this section], as added by subsection (a), is repealed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8ecb1aaf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ecb1ab0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Certain Functions and Authorities Under the National Defense Authorization Act for Fiscal Year 2020","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2020-02-21"},"text":"Feb. 21, 2020","children":[],"tail":", 85 F.R. 13717, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of State[,] the Secretary of the Treasury[,] the Secretary of Defense[,] the Secretary of Commerce[, and] the Director of National Intelligence","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby order as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. (a) I hereby delegate to the Secretary of State, in consultation with the Secretary of the Treasury, the functions and authorities vested in the President by the following provisions of the National Defense Authorization Act for Fiscal Year 2020 ("},{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Public Law 116–92","children":[],"tail":") (the “Act”):"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(i) section 7503(d) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9526"},"text":"22 U.S.C. 9526","children":[],"tail":" note];"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(ii) section 7503(f) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9526"},"text":"22 U.S.C. 9526","children":[],"tail":" note];"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(iii) section 7503(h) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9526"},"text":"22 U.S.C. 9526","children":[],"tail":" note];"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(iv) section 7124, with respect to section 73 of the Bretton Woods Agreements Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s286"},"text":"22 U.S.C. 286","children":[],"tail":" et seq.) ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s286yy"},"text":"22 U.S.C. 286yy","children":[],"tail":"], as amended by the Act;"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(v) section 7131 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9265"},"text":"22 U.S.C. 9265","children":[],"tail":"]; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(vi) section 7143, with respect to section 208 of the North Korea Sanctions and Policy Enhancement Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122"},"text":"Public Law 114–122","children":[],"tail":") (NKSPEA) ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9228"},"text":"22 U.S.C. 9228","children":[],"tail":"], as amended by the Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) I hereby delegate to the Secretary of the Treasury, in consultation with the Secretary of State, the functions and authorities vested in the President by the following provisions of the Act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(i) section 7503(c) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9526"},"text":"22 U.S.C. 9526","children":[],"tail":" note];"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(ii) section 7503(g) [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9526"},"text":"22 U.S.C. 9526","children":[],"tail":" note];"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(iii) section 7121, with respect to section 201B of NKSPEA [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9221b"},"text":"22 U.S.C. 9221b","children":[],"tail":"], as amended by the Act; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(iv) section 7122, with respect to section 104(g) of NKSPEA [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9214/g"},"text":"22 U.S.C. 9214(g)","children":[],"tail":"], as amended by the Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) I hereby delegate to the Secretary of the Treasury and the Secretary of Commerce the functions and authorities vested in the President by section 7132 of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9265a"},"text":"22 U.S.C. 9265a","children":[],"tail":"]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(d) I hereby delegate to the Secretary of the Treasury the functions and authorities vested in the President by section 7141 of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9269"},"text":"22 U.S.C. 9269","children":[],"tail":"]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(e) I hereby delegate to the Director of National Intelligence, in consultation with the Secretary of State and the Secretary of the Treasury, the functions and authorities vested in the President by section 7133 of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/stat/133/2253"},"text":"133 Stat. 2253","children":[],"tail":"]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(f) I hereby delegate to the Secretary of State, in consultation with the Secretary of Defense, the functions and authorities vested in the President by section 1227 of the Act [","children":[{"tag":"ref","attrib":{"href":"/us/stat/133/1646"},"text":"133 Stat. 1646","children":[],"tail":"]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 2. The delegations in this memorandum shall apply to any provisions of any future public laws that are the same or substantially the same as those provisions referenced in this memorandum."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec.","children":[],"tail":" 3. The Secretary of State is authorized and directed to publish this memorandum in the Federal Register."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Donald J. Trump.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
