{"tag":"section","attrib":{"id":"id910293d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8517"},"text":null,"children":[{"tag":"num","attrib":{"value":"8517"},"text":"§ 8517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased capacity for efforts to combat unlawful or terrorist financing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id910293d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910293d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8517/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The work of the Office of Terrorism and Financial Intelligence of the Department of the Treasury, which includes the Office of Foreign Assets Control and the Financial Crimes Enforcement Network, is critical to ensuring that the international financial system is not used for purposes of supporting terrorism and developing weapons of mass destruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910293d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8517/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury has designated, including most recently on ","children":[{"tag":"date","attrib":{"date":"2010-06-16"},"text":"June 16, 2010","children":[],"tail":", various Iranian individuals and banking, military, energy, and shipping entities as proliferators of weapons of mass destruction pursuant to Executive Order 13382 ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note), thereby blocking transactions subject to the jurisdiction of the United States by those individuals and entities and their supporters."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910293da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8517/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury has also identified an array of entities in the insurance, petroleum, and petrochemicals industries that the Secretary has determined to be owned or controlled by the Government of Iran and added those entities to the list contained in Appendix A to part 560 of title 31, Code of Federal Regulations (commonly known as the “Iranian Transactions Regulations”), thereby prohibiting transactions between United States persons and those entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910293db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for Office of Terrorism and Financial Intelligence","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary of the Treasury for the Office of Terrorism and Financial Intelligence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910293dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8517/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $102,613,000 for fiscal year 2011; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910293dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8517/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as may be necessary for each of the fiscal years 2012 and 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910293de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8517/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910293df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8517/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for Bureau of Industry and Security of the Department of Commerce","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Commerce for the Bureau of Industry and Security of the Department of Commerce—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910293e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8517/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $113,000,000 for fiscal year 2011; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910293e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8517/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as may be necessary for each of the fiscal years 2012 and 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910293e2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tI/s109"},"text":"Pub. L. 111–195, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1338"},"text":"124 Stat. 1338","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id910293e3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id910293e4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8551/a"},"text":"section 8551(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id910293e5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id910293e6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/s109"},"text":"section 109 of Pub. L. 111–195","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/111/195/s109"},"text":"section 109 of Pub. L. 111–195","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s310"},"text":"section 310 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
