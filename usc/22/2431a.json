{"tag":"section","attrib":{"id":"id8fbe53d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2431a"},"text":"§ 2431a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbe53d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administering body","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “administering body” means the entity provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431g/c"},"text":"section 2431g(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe53d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on International Relations and the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe53d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficiary country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “beneficiary country” means an eligible country with respect to which the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431d/a/1"},"text":"section 2431d(a)(1) of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431e/a/1"},"text":"section 2431e(a)(1) of this title","children":[],"tail":", or paragraph (1) or (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431f/a"},"text":"section 2431f(a) of this title","children":[],"tail":" is exercised."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the board referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431i"},"text":"section 2431i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Developing country with a tropical forest or coral reef","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “developing country with a tropical forest or coral reef” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe53d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8fbe53d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a country that has a per capita income of $725 or less in 1994 United States dollars (commonly referred to as “low-income country”), as determined and adjusted on an annual basis by the International Bank for Reconstruction and Development in its World Development Report; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fbe53da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a country that has a per capita income of more than $725 but less than $8,956 in 1994 United States dollars (commonly referred to as “middle-income country”), as determined and adjusted on an annual basis by the International Bank for Reconstruction and Development in its World Development Report; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe53db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a country that contains at least one tropical forest or coral reef that is globally outstanding in terms of its biological diversity or represents one of the larger intact blocks of tropical forests or coral reefs left, on a regional, continental, or global scale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible country” means a country designated by the President in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431c"},"text":"section 2431c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Conservation Agreement” or “Agreement” means a Conservation Agreement provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431g"},"text":"section 2431g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation Facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Conservation Facility” or “Facility” means the Conservation Facility established in the Department of the Treasury by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431b"},"text":"section 2431b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Conservation Fund” or “Fund” means a Conservation Fund provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2431h"},"text":"section 2431h of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coral","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “coral” means species of the phylum Cnidaria, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbe53e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all species of the orders Antipatharia (black corals), Scleractinia (stony corals), Alcyonacea (soft corals), Gorgonacea (horny corals), Stolonifera (organpipe corals and others), and Coenothecalia (blue coral), of the class Anthoza; ","children":[{"tag":"ref","attrib":{"idref":"fn002162"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002162"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Anthozoa;”."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbe53e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all species of the order Hydrocorallina (fire corals and hydrocorals) of the class Hydrozoa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coral reef","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “coral reef” means any reef or shoal composed primarily of coral.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbe53e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2431a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coral reef ecosystem","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “coral reef ecosystem” means any coral reef and any coastal marine ecosystem surrounding, or directly related to, a coral reef and important to maintaining the ecological integrity of that coral reef, such as seagrasses, mangroves, sandy seabed communities, and immediately adjacent coastal areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbe53e5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. V, § 803, as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/214/s1"},"text":"Pub. L. 105–214, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-29"},"text":"July 29, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/886"},"text":"112 Stat. 886","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/440"},"text":"Pub. L. 115–440","children":[],"tail":", §§ 3(b), 4(b), 8(e), 9(b)(1), "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5581"},"text":"132 Stat. 5581","children":[],"tail":", 5583, 5584.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fbe53e6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fbe53e7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8fbe53e8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s803"},"text":"section 803 of Pub. L. 87–195","children":[],"tail":", pt. V, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2433"},"text":"section 2433 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/329"},"text":"Pub. L. 94–329","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fbe53e9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s3/b/1/A"},"text":"Pub. L. 115–440, § 3(b)(1)(A)","children":[],"tail":", (B), substituted “tropical forest or coral reef” for “tropical forest” in heading and introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s3/b/1/C"},"text":"Pub. L. 115–440, § 3(b)(1)(C)","children":[],"tail":", substituted “tropical forest or coral reef” for “tropical forest” and “tropical forests or coral reefs” for “tropical forests”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s8/e"},"text":"Pub. L. 115–440, § 8(e)","children":[],"tail":", substituted “Conservation Agreement” for “Tropical Forest Agreement” in heading and in two places in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s4/b"},"text":"Pub. L. 115–440, § 4(b)","children":[],"tail":", substituted “Conservation Facility” for “Tropical Forest Facility” in heading and in two places in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s9/b/1"},"text":"Pub. L. 115–440, § 9(b)(1)","children":[],"tail":", substituted “Conservation Fund” for “Tropical Forest Fund” in heading and in two places in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (10) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/440/s3/b/2"},"text":"Pub. L. 115–440, § 3(b)(2)","children":[],"tail":", added pars. (10) to (12)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fbe53ea-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id8fbe53eb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on International Relations of House of Representatives changed to Committee on Foreign Affairs of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
