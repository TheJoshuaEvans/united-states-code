{"tag":"section","attrib":{"id":"id9123fe99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9251"},"text":null,"children":[{"tag":"num","attrib":{"value":"9251"},"text":"§ 9251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of sanctions and other measures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9123fe9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9251/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any sanction or other measure required under subchapter I, II, or III (or any amendment made by such subchapters) (other than section 9214(g), 9221b, or 9221c of this title) may be suspended for up to 1 year upon certification by the President to the appropriate congressional committees that the Government of North Korea has made progress toward—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9123fe9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9251/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verifiably ceasing its counterfeiting of United States currency, including the surrender or destruction of specialized materials and equipment used or particularly suitable for counterfeiting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9251/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking steps toward financial transparency to comply with generally accepted protocols to cease and prevent the laundering of monetary instruments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9251/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking steps toward verification of its compliance with applicable United Nations Security Council resolutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9251/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" taking steps toward accounting for and repatriating the citizens of other countries—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9123fe9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9251/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" abducted or unlawfully held captive by the Government of North Korea; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123fea0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9251/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detained in violation of the Agreement Concerning a Military Armistice in Korea, signed at Panmunjom ","children":[{"tag":"date","attrib":{"date":"1953-07-27"},"text":"July 27, 1953","children":[],"tail":" (commonly referred to as the “Korean War Armistice Agreement”);"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fea1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9251/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accepting and beginning to abide by internationally recognized standards for the distribution and monitoring of humanitarian aid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fea2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9251/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking verified steps to improve living conditions in its political prison camps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9123fea3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9251/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal of suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The suspension described in subsection (a) may be renewed for additional, consecutive 180-day periods after the President certifies to the appropriate congressional committees that the Government of North Korea has continued to comply with the conditions described in subsection (a) during the previous year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9123fea4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tIV/s401"},"text":"Pub. L. 114–122, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/114"},"text":"130 Stat. 114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dF/tLXXI/s7143/b/2"},"text":"Pub. L. 116–92, div. F, title LXXI, § 7143(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2256"},"text":"133 Stat. 2256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9123fea5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9123fea6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9123fea7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter I, II, or III (or any amendment made by such subchapters), referred to in subsec. (a), was in the original “title I, II, or III (or any amendment made by such titles)”, meaning titles I, II, and III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122"},"text":"Pub. L. 114–122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/98"},"text":"130 Stat. 98","children":[],"tail":", 101, 112. Titles I and III are classified principally to subchapters I and III, respectively, of this chapter. Title II is classified generally to subchapter II of this chapter. For complete classification of titles I, II, and III of "},{"tag":"ref","attrib":{"href":"/us/pl/114/122"},"text":"Pub. L. 114–122","children":[],"tail":" to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9123fea8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" inserted “(other than section 9214(g), 9221b, or 9221c of this title)” after “such subchapters)” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9123fea9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id9123feaa-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions and authorities of President under subsecs. (a) and (b) of this section delegated to Secretary of State, to be executed in consultation with Secretary of the Treasury when appropriate, by Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2016-05-18"},"text":"May 18, 2016","children":[],"tail":", 81 F.R. 37479, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9212"},"text":"section 9212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
