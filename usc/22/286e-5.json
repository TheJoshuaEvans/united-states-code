{"tag":"section","attrib":{"id":"id8ec3edc5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–5"},"text":"§ 286e–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments to Articles of Agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund is authorized to accept the amendments to the Articles of Agreement of the Fund approved in resolution numbered 31–4 of the Board of Governors of the Fund.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ec3edc6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s24"},"text":"July 31, 1945, ch. 339, § 24","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/564/s1"},"text":"Pub. L. 94–564, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2660"},"text":"90 Stat. 2660","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
