{"tag":"section","attrib":{"id":"id9123fe82-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243"},"text":null,"children":[{"tag":"num","attrib":{"value":"9243"},"text":"§ 9243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on and imposition of sanctions with respect to serious human rights abuses or censorship in North Korea","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9123fe83-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9123fe84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall submit to the appropriate congressional committees a report that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9123fe85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies each person the Secretary determines to be responsible for serious human rights abuses or censorship in North Korea and describes the conduct of that person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123fe86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes serious human rights abuses or censorship undertaken by the Government of North Korea or any person acting for or on behalf of that Government in the most recent year ending before the submission of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In preparing the report required under paragraph (1), the Secretary of State shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9123fe88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give due consideration to the findings of the United Nations Commission of Inquiry on Human Rights in North Korea; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123fe89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make specific findings with respect to the responsibility of Kim Jong Un, and of each individual who is a member of the National Defense Commission of North Korea or the Organization and Guidance Department of the Workers’ Party of Korea, for serious human rights abuses and censorship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission and form","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9123fe8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required under paragraph (1) shall be submitted not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2016-02-18"},"text":"February 18, 2016","children":[],"tail":", and every 180 days thereafter for a period not to exceed 3 years, and shall be included in each human rights report required under sections 2151n(d) and 2304(b) of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123fe8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required under paragraph (1) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9123fe8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall publish the unclassified part of the report required under paragraph (1) on the website of the Department of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9123fe8e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of persons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall designate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9214/a"},"text":"section 9214(a) of this title","children":[],"tail":" any person listed in the report required under subsection (a)(1) that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9123fe8f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly engages in, is responsible for, or facilitates censorship by the Government of North Korea; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe90-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly engages in, is responsible for, or facilitates serious human rights abuses by the Government of North Korea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9123fe91-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that the President should—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9123fe92-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek the prompt adoption by the United Nations Security Council of a resolution calling for the blocking of the assets of all persons responsible for severe human rights abuses or censorship in North Korea; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9123fe93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9243/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fully cooperate with the prosecution of any individual listed in the report required under subsection (a)(1) before any international tribunal that may be established to prosecute persons responsible for severe human rights abuses or censorship in North Korea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9123fe94-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tIII/s304"},"text":"Pub. L. 114–122, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/113"},"text":"130 Stat. 113","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9123fe95-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9123fe96-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id9123fe97-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions and authorities of President under subsec. (b) of this section delegated to Secretary of the Treasury, in consultation with Secretary of State, by Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2016-05-18"},"text":"May 18, 2016","children":[],"tail":", 81 F.R. 37479, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9212"},"text":"section 9212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
