{"tag":"section","attrib":{"id":"id913256b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546"},"text":null,"children":[{"tag":"num","attrib":{"value":"9546"},"text":"§ 9546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ukranian energy security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id913256b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id913256b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the Government of Ukraine in restoring its sovereign and territorial integrity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to condemn and oppose all of the destabilizing efforts by the Government of the Russian Federation in Ukraine in violation of its obligations and international commitments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to never recognize the illegal annexation of Crimea by the Government of the Russian Federation or the separation of any portion of Ukrainian territory through the use of military force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deter the Government of the Russian Federation from further destabilizing and invading Ukraine and other independent countries in Central and Eastern Europe and the Caucuses; ","children":[{"tag":"ref","attrib":{"idref":"fn002452"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002452"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Caucasus;”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in promoting reform in regulatory oversight and operations in Ukraine’s energy sector, including the establishment and empowerment of an independent regulatory organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage and support fair competition, market liberalization, and reliability in Ukraine’s energy sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help Ukraine and United States allies and partners in Europe reduce their dependence on Russian energy resources, especially natural gas, which the Government of the Russian Federation uses as a weapon to coerce, intimidate, and influence other countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to work with European Union member states and European Union institutions to promote energy security through developing diversified and liberalized energy markets that provide diversified sources, suppliers, and routes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to continue to oppose the NordStream 2 pipeline given its detrimental impacts on the European Union’s energy security, gas market development in Central and Eastern Europe, and energy reforms in Ukraine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the United States Government should prioritize the export of United States energy resources in order to create American jobs, help United States allies and partners, and strengthen United States foreign policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id913256bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan to promote energy security in Ukraine","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id913256c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, in coordination with the Administrator of the United States Agency for International Development and the Secretary of Energy, shall work with the Government of Ukraine to develop a plan to increase energy security in Ukraine, increase the amount of energy produced in Ukraine, and reduce Ukraine’s reliance on energy imports from the Russian Federation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan developed under paragraph (1) shall include strategies for market liberalization, effective regulation and oversight, supply diversification, energy reliability, and energy efficiency, such as through supporting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id913256c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promotion of advanced technology and modern operating practices in Ukraine’s oil and gas sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modern geophysical and meteorological survey work as needed followed by international tenders to help attract qualified investment into exploration and development of areas with untapped resources in Ukraine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a broadening of Ukraine’s electric power transmission interconnection with Europe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strengthening of Ukraine’s capability to maintain electric power grid stability and reliability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" independent regulatory oversight and operations of Ukraine’s gas market and electricity sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of primary gas law including pricing, tariff structure, and legal regulatory implementation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" privatization of government owned energy companies through credible legal frameworks and a transparent process compliant with international best practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procurement and transport of emergency fuel supplies, including reverse pipeline flows from Europe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provision of technical assistance for crisis planning, crisis response, and public outreach;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repair of infrastructure to enable the transport of fuel supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repair of power generating or power transmission equipment or facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved building energy efficiency and other measures designed to reduce energy demand in Ukraine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id913256cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of Ukraine Freedom Support Act of 2014 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8921"},"text":"22 U.S.C. 8921","children":[],"tail":" et seq.] provisions"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2017-08-02"},"text":"August 2, 2017","children":[],"tail":", the Secretary of State shall submit to the appropriate congressional committees a report detailing the status of implementing the provisions required under section 7(c) of the Ukraine Freedom Support Act of 2014 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8926/c"},"text":"22 U.S.C. 8926(c)","children":[],"tail":"), including detailing the plans required under that section, the level of funding that has been allocated to and expended for the strategies set forth under that section, and progress that has been made in implementing the strategies developed pursuant to that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2017-08-02"},"text":"August 2, 2017","children":[],"tail":", and every 180 days thereafter, the Secretary of State shall submit to the appropriate congressional committees a report detailing the plan developed under paragraph (1), the level of funding that has been allocated to and expended for the strategies set forth in paragraph (2), and progress that has been made in implementing the strategies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, or a designee of the Secretary, shall brief the appropriate congressional committees not later than 30 days after the submission of each report under subparagraph (B). In addition, the Department of State shall make relevant officials available upon request to brief the appropriate congressional committees on all available information that relates directly or indirectly to Ukraine or energy security in Eastern Europe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this paragraph, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id913256d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id913256d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id913256d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supporting efforts of countries in Europe and Eurasia to decrease their dependence on Russian sources of energy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id913256d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress makes the following findings:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id913256d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Government of the Russian Federation uses its strong position in the energy sector as leverage to manipulate the internal politics and foreign relations of the countries of Europe and Eurasia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This influence is based not only on the Russian Federation’s oil and natural gas resources, but also on its state-owned nuclear power and electricity companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id913256da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States should assist the efforts of the countries of Europe and Eurasia to enhance their energy security through diversification of energy supplies in order to lessen dependencies on Russian Federation energy resources and state-owned entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id913256db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Export-Import Bank of the United States and the United States International Development Finance Corporation should play key roles in supporting critical energy projects that contribute to that goal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id913256dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Countering Russian Influence Fund to provide technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Countering Russian Influence Fund pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9543"},"text":"section 9543 of this title","children":[],"tail":" shall be used to provide technical advice to countries described in subsection (b)(1) of such section designed to enhance energy security and lessen dependence on energy from Russian Federation sources."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id913256dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated for the Department of State a total of $30,000,000 for fiscal years 2018 and 2019 to carry out the strategies set forth in subsection (b)(2) and other activities under this section related to the promotion of energy security in Ukraine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id913256de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9546/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as affecting the responsibilities required and authorities provided under section 7 of the Ukraine Freedom Support Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8926"},"text":"22 U.S.C. 8926","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id913256df-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tII/s257"},"text":"Pub. L. 115–44, title II, § 257","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/931"},"text":"131 Stat. 931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tVI/s1470/t"},"text":"Pub. L. 115–254, div. F, title VI, § 1470(t)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3519"},"text":"132 Stat. 3519","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id913256e0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id913256e1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id913256e2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Ukr