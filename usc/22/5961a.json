{"tag":"section","attrib":{"id":"id90a33513-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5961a"},"text":"§ 5961a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for on-site managers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90a33514-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On-site manager requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before obligating any defense nuclear nonproliferation funds for a project described in subsection (b), the Secretary of Energy shall appoint one on-site manager for that project. The manager shall be appointed from among employees of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a33515-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects covered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) applies to a project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a33516-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be located in a state of the former Soviet Union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a33517-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which involves dismantlement, destruction, or storage facilities, or construction of a facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a33518-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the total contribution by the Department of Energy is expected to exceed $50,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a33519-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of on-site manager","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The on-site manager appointed under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a3351a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, in cooperation with representatives from governments of countries participating in the project, a list of those steps or activities critical to achieving the project’s disarmament or nonproliferation goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a3351b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a schedule for completing those steps or activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a3351c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet with all participants to seek assurances that those steps or activities are being completed on schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a3351d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend United States participation in a project when a non-United States participant fails to complete a scheduled step or activity on time, unless directed by the Secretary of Energy to resume United States participation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a3351e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to manage more than one project","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a3351f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), an employee of the Federal Government may serve as on-site manager for more than one project, including projects at different locations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a33520-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If such an employee serves as on-site manager for more than one project in a fiscal year, the total cost of the projects for that fiscal year may not exceed $150,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a33521-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Steps or activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Steps or activities referred to in subsection (c)(1) are those activities that, if not completed, will prevent a project from achieving its disarmament or nonproliferation goals, including, at a minimum, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a33522-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification and acquisition of permits (as defined in subsection (g)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a33523-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Verification that the items, substances, or capabilities to be dismantled, secured, or otherwise modified are available for dismantlement, securing, or modification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a33524-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Timely provision of financial, personnel, management, transportation, and other resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a33525-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any case in which the Secretary of Energy directs an on-site manager to resume United States participation in a project under subsection (c)(4), the Secretary shall concurrently notify Congress of such direction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a33526-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permit defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “permit” means any local or national permit for development, general construction, environmental, land use, or other purposes that is required in the state of the former Soviet Union in which the project is being or is proposed to be carried out.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a33527-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5961a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect six months after ","children":[{"tag":"date","attrib":{"date":"2003-11-24"},"text":"November 24, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90a33528-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dC/tXXXI/s3125"},"text":"Pub. L. 108–136, div. C, title XXXI, § 3125","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1748"},"text":"117 Stat. 1748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90a33529-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90a3352a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90a3352b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2004, and not as part of the Cooperative Threat Reduction Act of 1993 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
