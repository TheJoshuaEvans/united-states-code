{"tag":"section","attrib":{"id":"id904fbe7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3946"},"text":null,"children":[{"tag":"num","attrib":{"value":"3946"},"text":"§ 3946.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Career appointments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904fbe7c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3946/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trial period under limited appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before receiving a career appointment in the Service, an individual shall first serve under a limited appointment as a career candidate for a trial period of service prescribed by the Secretary. During such trial period of service, the Secretary shall decide whether—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904fbe7d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3946/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to offer a career appointment to the candidate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3943"},"text":"section 3943 of this title","children":[],"tail":", or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904fbe7e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3946/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recommend to the President that the candidate be given a career appointment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3942"},"text":"section 3942 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904fbe7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3946/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisions by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Decisions by the Secretary under subsection (a) shall be based upon the recommendations of boards, established by the Secretary and composed entirely or primarily of career members of the Service, which shall evaluate the fitness and aptitude of career candidates for the work of the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904fbe80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3946/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Service Grievance Board decisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to limit the authority of the Secretary or the Foreign Service Grievance Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4137"},"text":"section 4137 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904fbe81-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s306"},"text":"Pub. L. 96–465, title I, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2086"},"text":"94 Stat. 2086","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s181/c"},"text":"Pub. L. 100–204, title I, § 181(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1363"},"text":"101 Stat. 1363","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904fbe82-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904fbe83-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id904fbe84-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id904fbe85-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id904fbe86-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s181/e"},"text":"Pub. L. 100–204, title I, § 181(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1364"},"text":"101 Stat. 1364","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/204/tI/s181/e"},"text":"“The amendments made by this section [amending this section and sections 4010 and 4137 of this title] shall not apply with respect to any grievance in which the Board has issued a final decision pursuant to section 1107 of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4137"},"text":"22 U.S.C. 4137","children":[],"tail":") before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
