{"tag":"section","attrib":{"id":"id8ec17d9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1m"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–1m"},"text":"§ 286e–1m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quota increase to 10,622,500,000 Special Drawing Rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ec17d9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund may consent to an increase in the quota of the United States in the Fund equivalent to 10,622,500,000 Special Drawing Rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ec17d9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject to appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided by subsection (a) shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ec17d9e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s61"},"text":"July 31, 1945, ch. 339, § 61","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/d/tVI/s608"},"text":"Pub. L. 105–277, div. A, § 101(d) [title VI, § 608]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-150"},"text":"112 Stat. 2681–150","children":[],"tail":", 2681–224.)"}],"tail":"\n"}],"tail":null}
