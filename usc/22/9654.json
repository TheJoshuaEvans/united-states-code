{"tag":"section","attrib":{"id":"id9147b2a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9654"},"text":null,"children":[{"tag":"num","attrib":{"value":"9654"},"text":"§ 9654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicly available project information","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Corporation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b2a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9654/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain a user-friendly, publicly available, machine-readable database with detailed project-level information, as appropriate and to the extent practicable, including a description of the support provided by the Corporation under subchapter II of this chapter, which shall include, to the greatest extent feasible for each project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9147b2a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9654/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information included in the report to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9653"},"text":"section 9653 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b2a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9654/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project-level performance metrics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b2a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9654/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the development impact of the project, including anticipated impact prior to initiation of the project and assessed impact during and after the completion of the project; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b2a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9654/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a clear link to information about each project supported by the Corporation under subchapter II of this chapter on the internet website of the Department of State, “ForeignAssistance.gov”, or a successor website or other online publication.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9147b2a7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tIV/s1444"},"text":"Pub. L. 115–254, div. F, title IV, § 1444","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3506"},"text":"132 Stat. 3506","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXVII/s8756"},"text":"Pub. L. 119–60, div. H, title LXXXVII, § 8756","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1967"},"text":"139 Stat. 1967","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9147b2a8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9147b2a9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9147b2aa-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “maintain a user-friendly, publicly available, machine-readable database with detailed project-level information, as appropriate and to the extent practicable, including a description of the support provided by the Corporation under subchapter II of this chapter, including, to the extent feasible, the information included in the report to Congress under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9653"},"text":"section 9653 of this title","children":[],"tail":" and project-level performance metrics; and”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
