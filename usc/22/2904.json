{"tag":"section","attrib":{"id":"id9029995a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2904"},"text":null,"children":[{"tag":"num","attrib":{"value":"2904"},"text":"§ 2904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9029995b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of scholarly, cultural, and artistic activities; grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission is authorized to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9029995c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and carry out programs at public or private institutions for the promotion of scholarly, cultural, and artistic activities in Japan and the United States consistent with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2902/b"},"text":"section 2902(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9029995d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants to carry out such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9029995e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"ta