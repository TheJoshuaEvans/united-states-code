{"tag":"section","attrib":{"id":"id8fccaadc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2504a"},"text":"§ 2504a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care for volunteers at Peace Corps posts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fccaadd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall ensure that each overseas post has the services of a medical office that is consistent in size and scope with the needs of the Peace Corps at such post, including, if necessary, by detailing to any such post the licensed medical staff of other United States departments, agencies, or establishments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fccaade-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hiring criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting medical officers and support staff for overseas Peace Corps posts, the Director of the Peace Corps shall hire well-qualified and capable personnel to support the effectiveness of health care for Peace Corps volunteers by evaluating each candidate’s—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fccaadf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical training, experience, and accreditations or other qualifications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fccaae0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" record of performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fccaae1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fccaae2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding of the local language and culture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fccaae3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ability to work in the English language;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fccaae4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpersonal skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fccaae5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors that the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fccaae6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Peace Corps shall ensure that each Peace Corps medical officer serving in a malaria-endemic country receives training in the recognition of the side effects of such medications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fccaae7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fccaae8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Peace Corps, acting through the Associate Director of the Office of Health Services and the country directors, shall review and evaluate the performance and health care delivery of all Peace Corps medical staff, including medical officers, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fccaae9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure compliance with all relevant Peace Corps policies, practices, and guidelines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fccaaea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that medical staff complete the necessary continuing medical education to maintain their skills and satisfy licensing and credentialing standards, as designated by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fccaaeb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Peace Corps shall include, in the annual Peace Corps congressional budget justification, a confirmation that the review and evaluation of all Peace Corps medical staff required under paragraph (1) has been completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fccaaec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2504a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antimalarial drugs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Peace Corps shall consult with experts at the Centers for Disease Control and Prevention regarding recommendations for prescribing malaria prophylaxis, in order to provide the best standard of care within the context of the Peace Corps environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fccaaed-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/tI/s5A"},"text":"Pub. L. 87–293, title I, § 5A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/256/tI/s101/a/2"},"text":"Pub. L. 115–256, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-09"},"text":"Oct. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3651"},"text":"132 Stat. 3651","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
