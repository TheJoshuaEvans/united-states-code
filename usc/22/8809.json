{"tag":"section","attrib":{"id":"id91133590-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8809"},"text":null,"children":[{"tag":"num","attrib":{"value":"8809"},"text":"§ 8809.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation; penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91133591-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8809/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may exercise all authorities provided under sections 1702 and 1704 of title 50 to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91133592-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8809/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The penalties provided for in subsections (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705"},"text":"section 1705 of title 50","children":[],"tail":" shall apply to a person that violates, attempts to violate, conspires to violate, or causes a violation of this chapter or regulations prescribed under this chapter to the same extent that such penalties apply to a person that commits an unlawful act described in "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705/a"},"text":"section 1705(a) of title 50","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91133593-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8809/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of certain provisions of Iran Sanctions Act of 1996","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following provisions of the Iran Sanctions Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/172"},"text":"Public Law 104–172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note) shall apply with respect to the imposition of sanctions under sections 8803(d), 8804(a), and 8805(a) of this title to the same extent that such provisions apply with respect to the imposition of sanctions under section 5(a) of the Iran Sanctions Act of 1996, and, as appropriate, instead of sections 8803(i), 8804(g), and 8805(e) of this title:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id91133594-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8809/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (1)(A), (2)(A), and (2)(B)(i) of section 4(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91133595-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8809/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (c), (d), and (f) of section 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91133596-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8809/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 8.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91133597-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8809/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 11.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91133598-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8809/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 12.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91133599-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8809/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 13(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9113359a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXII/s1253"},"text":"Pub. L. 112–239, div. A, title XII, § 1253","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2017"},"text":"126 Stat. 2017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9113359b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9113359c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9113359d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b), was in the original “this subtitle”, meaning subtitle D (§§ 1241–1255) of title XII of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2004"},"text":"126 Stat. 2004","children":[],"tail":", known as the Iran Freedom and Counter-Proliferation Act of 2012, which is classified principally to this chapter. For complete classification of subtitle D to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8801"},"text":"section 8801 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9113359e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id9113359f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions and authorities vested in the President by this section, see Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2013-06-03"},"text":"June 3, 2013","children":[],"tail":", 78 F.R. 35545, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8801"},"text":"section 8801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
