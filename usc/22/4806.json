{"tag":"section","attrib":{"id":"id907f80b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4806"},"text":null,"children":[{"tag":"num","attrib":{"value":"4806"},"text":"§ 4806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of foreign consulates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall take into account security considerations in making determinations with respect to accreditation of all foreign consular personnel in the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907f80b2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tI/s107"},"text":"Pub. L. 99–399, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/858"},"text":"100 Stat. 858","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s162/g/5"},"text":"Pub. L. 103–236, title I, § 162(g)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/407"},"text":"108 Stat. 407","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907f80b3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907f80b4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id907f80b5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","at