{"tag":"section","attrib":{"id":"id8f176513-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1645j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1645j"},"text":"§ 1645j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement period","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission shall complete its affairs in connection with the settlement of claims pursuant to this subchapter not later than three years after the final date for the filing of claims as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1645b"},"text":"section 1645b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f176514-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title VII, § 711, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/606"},"text":"Pub. L. 96–606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-28"},"text":"Dec. 28, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3537"},"text":"94 Stat. 3537","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
