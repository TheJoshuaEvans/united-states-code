{"tag":"section","attrib":{"id":"id905479c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4002"},"text":null,"children":[{"tag":"num","attrib":{"value":"4002"},"text":"§ 4002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of selection boards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id905479ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of performance; recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish selection boards to evaluate the performance of members of the Senior Foreign Service and members of the Service assigned to a salary class in the Foreign Service Schedule. Selection boards shall, in accordance with precepts prescribed by the Secretary, rank the members of a salary class on the basis of relative performance and may make recommendations for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id905479cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotions in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4001"},"text":"section 4001 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905479cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awards of performance pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3965/c"},"text":"section 3965(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905479cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4002/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" denials of within-class step increases under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3966/a"},"text":"section 3966(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905479ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4002/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer or renewal of limited career extensions under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4007/b"},"text":"section 4007(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905479cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4002/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other actions as the Secretary may prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id905479d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public members; appointment of women and minority groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All selection boards established under this section shall include public members. The Secretary shall assure that a substantial number of women and members of minority groups are appointed to each selection board established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id905479d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualification for service on foreign service selection boards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No public members appointed pursuant to this section may be, at the time of their appointment or during their appointment, an agent of a foreign principal (as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s611/b"},"text":"section 611(b) of this title","children":[],"tail":") or a lobbyist for a foreign entity (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1602/6"},"text":"section 1602(6) of title 2","children":[],"tail":") or receive income from a government of a foreign country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id905479d2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s602"},"text":"Pub. L. 96–465, title I, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2095"},"text":"94 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s142"},"text":"Pub. L. 101–246, title I, § 142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/36"},"text":"104 Stat. 36","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s12/c"},"text":"Pub. L. 104–65, § 12(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/701"},"text":"109 Stat. 701","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id905479d3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id905479d4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id905479d5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65"},"text":"Pub. L. 104–65","children":[],"tail":" inserted “or a lobbyist for a foreign entity (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1602/6"},"text":"section 1602(6) of title 2","children":[],"tail":")” before “or receive income”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246"},"text":"Pub. L. 101–246","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id905479d6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id905479d7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65"},"text":"Pub. L. 104–65","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s24"},"text":"section 24 of Pub. L. 104–65","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1601"},"text":"section 1601 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
