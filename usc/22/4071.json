{"tag":"section","attrib":{"id":"id90678ba0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4071"},"text":null,"children":[{"tag":"num","attrib":{"value":"4071"},"text":"§ 4071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; application of Federal Employees’ Retirement System to Foreign Service Pension System participants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90678ba1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby established a Foreign Service Pension System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90678ba2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise specifically provided in this part or any other provision of law, the provisions of chapter 84 of title 5 shall apply to all participants in the Foreign Service Pension System and such participants shall be treated in all respects similar to persons whose participation in the Federal Employees’ Retirement System provided in that chapter is required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90678ba3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s851"},"text":"Pub. L. 96–465, title I, § 851","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tIV/s415"},"text":"Pub. L. 99–335, title IV, § 415","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/615"},"text":"100 Stat. 615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90678ba4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90678ba5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90678ba6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part effective ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/s702/a"},"text":"section 702(a) of Pub. L. 99–335","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401"},"text":"section 8401 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
