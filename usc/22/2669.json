:"/us/pl/109/313/s2/c/1"},"text":"Pub. L. 109–313, § 2(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1735"},"text":"120 Stat. 1735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff06098-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff06099-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ff0609a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of the amendment made by section 2711 of the Competition in Contracting Act of 1984, referred to in subsec. (h), is the effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/tVII/s2711"},"text":"section 2711 of title VII of Pub. L. 98–369","children":[],"tail":", div. B, "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1175"},"text":"98 Stat. 1175","children":[],"tail":", 1203, which amended section 253 of former Title 41, Public Contracts, applicable with respect to any solicitation for bids or proposals issued after "},{"tag":"date","attrib":{"date":"1985-03-31"},"text":"Mar. 31, 1985","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2751/a"},"text":"section 2751(a) of Pub. L. 98–369","children":[],"tail":", set out as an Effective Date of 1984 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4751"},"text":"section 4751 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ff0609b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s501"},"text":"section 501 of title 44","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/act/1919-03-01/s11"},"text":"section 11 of the Act of March 1, 1919","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t44/s111"},"text":"44 U.S.C. 111","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/90/620/s2/b"},"text":"Pub. L. 90–620, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1305"},"text":"82 Stat. 1305","children":[],"tail":", the first section of which enacted Title 44, Public Printing and Documents."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (h), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3304/a/2"},"text":"section 3304(a)(2) of title 41","children":[],"tail":"” substituted for “section 303(c)(2) of the Federal Property and Administrative Services Act of 1949” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s170g"},"text":"section 170g of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ff0609c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s413/b/1"},"text":"Pub. L. 108–447, § 413(b)(1)","children":[],"tail":", which directed the striking out of “and”, was executed by striking out “and” after semicolon, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/s413/b/3"},"text":"Pub. L. 108–447, § 413(b)(3)","children":[],"tail":", substituted semicolon for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (m). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s413/b/2"},"text":"Pub. L. 108–447, § 413(b)(2)","children":[],"tail":", (3), transferred subsec. (m) to appear after subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") and substituted semicolon for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (n). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s413/b/4"},"text":"Pub. L. 108–447, § 413(b)(4)","children":[],"tail":", substituted “; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/s413/a"},"text":"Pub. L. 108–447, § 413(a)","children":[],"tail":", added subsec. ("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (n). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" added subsec. (n)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", §§ 137, 180(b), which identically directed amendment of subsec. (c) by inserting before the period “; and such contracts are authorized to be negotiated, the terms of the contracts to be prescribed, and the work to be performed, where necessary, without regard to such statutory provisions as relate to the negotiation, making, and performance of contracts and performance of work in the United States”, were executed by making the insertion before the semicolon at end to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), (m). "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s162/k/4"},"text":"Pub. L. 103–236, § 162(k)(4)","children":[],"tail":", redesignated subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") relating to paying obligations arising under international agreements, conventions, and binational contracts as (m)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/102/138"},"text":"Pub. L. 102–138","children":[],"tail":" added subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") relating to paying obligations arising under international agreements, conventions, and binational contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/20"},"text":"Pub. L. 102–20","children":[],"tail":" added subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") relating to purchase of special purpose passenger motor vehicles."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsecs. (i) to (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246"},"text":"Pub. L. 101–246","children":[],"tail":" added subsecs. (i) to (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/s114"},"text":"Pub. L. 99–93, § 114","children":[],"tail":", in provision preceding subsec. (a) substituted “may use funds appropriated or otherwise available to the Secretary to” for “, when funds are appropriated therefor, may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/s118/a"},"text":"Pub. L. 99–93, § 118(a)","children":[],"tail":", inserted “for purposes of any law administered by the Office of Personnel Management (except that the Secretary may determine the applicability to such individuals of subsection (f) and of any other law administered by the Secretary concerning the employment of such individuals abroad)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/533/s303/a/1"},"text":"Pub. L. 98–533, § 303(a)(1)","children":[],"tail":", substituted “individuals or organizations” for “aliens” after “employ”, and “, and individuals employed by contract to perform such services shall not by virtue of such employment be considered to be employees of the United States Government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/533/s303/a/2"},"text":"Pub. L. 98–533, § 303(a)(2)","children":[],"tail":", added subsecs. (g) and (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/565"},"text":"Pub. L. 87–565","children":[],"tail":" added subsec. (