{"tag":"section","attrib":{"id":"id8fbbe338-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2430b"},"text":"§ 2430b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fbbe339-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for benefits from the Facility under this subchapter, a country must be a Latin American or Caribbean country—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbbe33a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose government is democratically elected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbbe33b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose government has not repeatedly provided support for acts of international terrorism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbbe33c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose government is not failing to cooperate on international narcotics control matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbbe33d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose government (including its military or other security forces) does not engage in a consistent pattern of gross violations of internationally recognized human rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbbe33e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that has in effect, has received approval for, or, as appropriate in exceptional circumstances, is making significant progress toward—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fbbe33f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430b/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an International Monetary Fund standby arrangement, extended Fund arrangement, or an arrangement under the structural adjustment facility or enhanced structural adjustment facility, or in exceptional circumstances, a Fund monitored program or its equivalent, unless the President determines (after consultation with the Enterprise for the Americas Board) that such an arrangement or program (or its equivalent) could reasonably be expected to have significant adverse social or environmental effects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fbbe340-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430b/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, structural or sectoral adjustment loans from the International Bank for Reconstruction and Development or the International Development Association, unless the President determines (after consultation with the Enterprise for the Americas Board) that the resulting adjustment requirements could reasonably be expected to have significant adverse social or environmental effects;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbbe341-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430b/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has put in place major investment reforms in conjunction with an Inter-American Development Bank loan or otherwise is implementing, or is making significant progress toward, an open investment regime; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbbe342-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430b/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate, has agreed with its commercial bank lenders on a satisfactory financing program, including, as appropriate, debt or debt service reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbbe343-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2430b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with subsection (a), the President shall determine whether a country is eligible to receive benefits under this subchapter. The President shall notify the appropriate congressional committees of his intention to designate a country as an eligible country at least 15 days in advance of any formal determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbbe344-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. IV, § 703, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/549/tVI/s602/a"},"text":"Pub. L. 102–549, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3664"},"text":"106 Stat. 3664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fbbe345-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fbbe346-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8fbbe347-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s703"},"text":"section 703 of Pub. L. 87–195","children":[],"tail":", pt. IV, "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/463"},"text":"75 Stat. 463","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1613d"},"text":"section 1613d of this title","children":[],"tail":" and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1613d"},"text":"section 1613d of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/87/565"},"text":"Pub. L. 87–565","children":[],"tail":", pt. IV, § 401, "},{"tag":"date","attrib":{"date":"1962-08-01"},"text":"Aug. 1, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/263"},"text":"76 Stat. 263","children":[],"tail":", except insofar as section 703 affected section 1613d."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8fbbe348-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8fbbe349-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see section 1 of Ex. Ord. No. 13345, ","children":[{"tag":"date","attrib":{"date":"2004-07-08"},"text":"July 8, 2004","children":[],"tail":", 69 F.R. 41901, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738"},"text":"section 1738 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
