{"tag":"section","attrib":{"id":"id8f14f443-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1642h"},"text":null,"children":[{"tag":"num","attrib":{"value":"1642h"},"text":"§ 1642h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against payment of award to certain persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No award shall be made on any claim under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1642c"},"text":"section 1642c of this title","children":[],"tail":" to or for the benefit of (1) any person who has been convicted of a violation of any provision of chapter 115 of title 18, or of any other crime involving disloyalty to the United States, or (2) any claimant whose claim under this subchapter is within the scope of subchapter III of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f14f444-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title IV, § 409, as added "},{"tag":"ref","attrib":{"href":"/us/pl/85/604/s1"},"text":"Pub. L. 85–604, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-08"},"text":"Aug. 8, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/529"},"text":"72 Stat. 529","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
