{"tag":"section","attrib":{"id":"id8eba5105-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"283z–2"},"text":"§ 283z–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution to Inter-American Development Bank; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eba5106-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank is authorized on behalf of the United States to contribute to the Fund for Special Operations $70,000,000: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That any commitment to make such contribution shall be made subject to obtaining the necessary appropriations."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eba5107-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283z–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for a portion of the increase in the United States subscription to the capital stock of the Bank provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s283z–1/a"},"text":"section 283z–1(a) of this title","children":[],"tail":" and for the United States contribution to the Fund for Special Operations provided for in this section, there are authorized to be appropriated, without fiscal year limitation, for payment by the Secretary of the Treasury, (1) $274,920,799 for the United States subscription, and (2) $70,000,000 for the United States contribution to the Fund for Special Operations: "},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That no funds may be made available for such contribution to the Fund for Special Operations for the fiscal year 1982."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eba5108-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/147/s30"},"text":"Pub. L. 86–147, § 30","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXIII/s1351/a"},"text":"Pub. L. 97–35, title XIII, § 1351(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/744"},"text":"95 Stat. 744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eba5109-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8eba510a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8eba510b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", except that any funds authorized to be appropriated shall not be available for use or obligation prior to "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1372"},"text":"section 1372 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s290i"},"text":"section 290i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
