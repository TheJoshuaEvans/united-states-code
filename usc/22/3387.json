{"tag":"section","attrib":{"id":"id903a3a2e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3387"},"text":null,"children":[{"tag":"num","attrib":{"value":"3387"},"text":"§ 3387.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id903a3a2f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3387/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the American Institute in Taiwan—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903a3a30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3387/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for fiscal year 2023, $2,900,000, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a3a31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3387/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $500,000 should be used to launch the Taiwan Fellowship Program through a competitive cooperative agreement with an appropriate implementing partner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a3a32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3387/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,300,000 should be used to fund a cooperative agreement with an appropriate implementing partner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a3a33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3387/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000 should be used for management expenses of the American Institute in Taiwan related to the management of the Taiwan Fellowship Program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903a3a34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3387/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for fiscal year 2024, and each succeeding fiscal year, $2,400,000, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903a3a35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3387/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,300,000 should be used for a cooperative agreement to the appropriate implementing partner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903a3a36-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3387/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000 should be used for management expenses of the American Institute in Taiwan related to the management of the Taiwan Fellowship Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a3a37-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3387/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The implementing partner selected to implement the Taiwan Fellowship Program may accept, use, and dispose of gifts or donations of services or property in carrying out such program, subject to the review and approval of the American Institute in Taiwan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903a3a38-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5533"},"text":"Pub. L. 117–263, div. E, title LV, § 5533","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3332"},"text":"136 Stat. 3332","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
