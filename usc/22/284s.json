{"tag":"section","attrib":{"id":"id8ebcc20e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284s"},"text":null,"children":[{"tag":"num","attrib":{"value":"284s"},"text":"§ 284s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ninth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc20f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor is hereby authorized to agree on behalf of the United States to pay to the Association $3,180,000,000 to the ninth replenishment of the resources of the Association, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc210-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $3,180,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc211-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s21"},"text":"Pub. L. 86–565, § 21","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/513/tV/s562/a/1"},"text":"Pub. L. 101–513, title V, § 562(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2032"},"text":"104 Stat. 2032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ebcc212-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ebcc213-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ebcc214-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Subsequent Replenishments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/2/tV/s594"},"text":"Pub. L. 106–113, div. B, § 1000(a)(2) [title V, § 594]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–122, provided in part that the Secretary of the Treasury may contribute on behalf of the United States to the twelfth replenishment of the International Development Association, and authorized $2,410,000,000 to be appropriated without fiscal year limitation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/118/tV/s560/a"},"text":"Pub. L. 105–118, title V, § 560(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-26"},"text":"Nov. 26, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2425"},"text":"111 Stat. 2425","children":[],"tail":", provided in part that the Secretary of the Treasury may contribute on behalf of the United States to the eleventh replenishment of the resources of the International Development Association, subject to obtaining the necessary appropriations, and authorized $1,600,000,000 to be appropriated without fiscal year limitation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/87/tV/s526"},"text":"Pub. L. 103–87, title V, § 526","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"Sept. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/952"},"text":"107 Stat. 952","children":[],"tail":", provided in part that the Secretary of the Treasury is authorized to agree on behalf of the United States to participate in the tenth replenishment of the resources of the International Development Association, subject to obtaining the necessary appropriations, and pursuant to the tenth replenishment authorized $2,500,000,000 to be appropriated."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
