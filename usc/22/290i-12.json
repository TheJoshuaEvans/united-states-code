{"tag":"section","attrib":{"id":"id8ee09eb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"290i–12"},"text":"§ 290i–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seventh capital increase","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ee09eb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscription authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ee09eb7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–12/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Bank may subscribe on behalf of the United States to 532,023 additional shares of the capital stock of the Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee09eb8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–12/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any subscription by the United States to the capital stock of the Bank shall be effective only to such extent and in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee09eb9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ee09eba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–12/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the increase in the United States subscription to the Bank under subsection (a), there are authorized to be appropriated, without fiscal year limitation, $7,286,587,008 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee09ebb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–12/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Share types","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount authorized to be appropriated under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ee09ebc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–12/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $437,190,016 shall be for paid in shares of the Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ee09ebd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290i–12/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,849,396,992 shall be for callable shares of the Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee09ebe-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXIII/s1345"},"text":"Pub. L. 97–35, title XIII, § 1345","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/136/dB/tXI/s21012/b/3"},"text":"Pub. L. 116–136, div. B, title XI, § 21012(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-27"},"text":"Mar. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/594"},"text":"134 Stat. 594","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
