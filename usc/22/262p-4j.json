{"tag":"section","attrib":{"id":"id8e9dc8d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p–4j"},"text":"§ 262p–4j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion of lending for environment","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director of the International Bank for Reconstruction and Development to initiate discussions with the other executive directors of such bank and the management of such bank and propose that, in order to reduce the future need for bank lending for reforestation and restoration of environmentally degraded areas, the bank establish a project and policy based environmental lending program (including a loan a portion of which could be used to reduce and restructure private debt), to be made available to interested countries with a demonstrated commitment to natural resource conservation, which would be based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e9dc8d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated long-term economic return which could be expected from the sustainable use and protection of tropical forests, including the value of tropical forests for indigenous people and for science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9dc8d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the value derived from such services as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e9dc8d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" watershed management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e9dc8d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" soil erosion control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e9dc8d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the maintenance and improvement of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8e9dc8d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fisheries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8e9dc8d9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water supply regulation for industrial development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8e9dc8da-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8e9dc8db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8e9dc8dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fodder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8e9dc8dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/2/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building materials for local communities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e9dc8de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extraction of naturally occurring products from locally controlled protected areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e9dc8df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indigenous knowledge of the management and use of natural resources; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e9dc8e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–4j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the long-term benefits expected to be derived from maintaining biological diversity and climate stabilization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attri