{"tag":"section","attrib":{"id":"id8ea9af67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s275"},"text":null,"children":[{"tag":"num","attrib":{"value":"275"},"text":"§ 275.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Hydrographic Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To enable the United States to become a member of the International Hydrographic Bureau, and for the first annual contribution of the United States toward the creation and maintenance of such bureau, there is hereby appropriated out of money in the Treasury not otherwise appropriated $2,500, or so much thereof as may be necessary, to be paid by the Secretary of State when the exact quota shall have been ascertained.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ea9af68-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-03-02/ch113"},"text":"Mar. 2, 1921, ch. 113","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/1215"},"text":"41 Stat. 1215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ea9af69-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ea9af6a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"appropriations","id":"id8ea9af6b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annual Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Annual appropriations to meet the obligations of membership in various international organizations were contained in acts listed in a note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s269a"},"text":"section 269a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
