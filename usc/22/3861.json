{"tag":"section","attrib":{"id":"id9048928f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861"},"text":null,"children":[{"tag":"num","attrib":{"value":"3861"},"text":"§ 3861.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90489290-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Panama Canal Acquisition Regulation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90489291-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commission shall establish by regulation a comprehensive procurement system. The regulation shall be known as the “Panama Canal Acquisition Regulation” (in this section referred to as the “Regulation”) and shall provide for the procurement of goods and services by the Commission in a manner that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90489292-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applies the fundamental operating principles and procedures in the Federal Acquisition Regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90489293-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses efficient commercial standards of practice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90489294-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is suitable for adoption and uninterrupted use by the Republic of Panama after the Canal Transfer Date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90489295-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Regulation shall contain provisions regarding the establishment of the Panama Canal Board of Contract Appeals described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3862"},"text":"section 3862 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90489296-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement to Regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall develop a Supplement to the Regulation (in this section referred to as the “Supplement”) that identifies both the provisions of Federal law applicable to procurement of goods and services by the Commission and the provisions of Federal law waived by the Commission under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90489297-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90489298-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Commission shall determine which provisions of Federal law should not apply to procurement by the Commission and may waive those laws for purposes of the Regulation and Supplement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90489299-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (1), the Commission may not waive—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9048929a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 21 of title 41;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9048929b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 71 of title 41, other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7104/b"},"text":"section 7104(b) of title 41","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9048929c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civil rights, environmental, or labor laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9048929d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Administrator for Federal Procurement Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing the Regulation and developing the Supplement, the Commission shall consult with the Administrator for Federal Procurement Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9048929e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3861/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Regulation and the Supplement shall take effect on the date of publication in the Federal Register, or ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":", whichever is earlier."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9048929f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tIII/s3101"},"text":"Pub. L. 96–70, title III, § 3101","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dC/tXXXV/s3541"},"text":"Pub. L. 105–85, div. C, title XXXV, § 3541","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2070"},"text":"111 Stat. 2070","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904892a0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904892a1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id904892a2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (c)(2)(A), “chapter 21 of title 41” substituted for “section 27 of the Office of Federal Procurement Policy Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s423"},"text":"41 U.S.C. 423","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (c)(2)(B), “chapter 71 of title 41, other than ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7104/b"},"text":"section 7104(b) of title 41","children":[],"tail":"” substituted for “the Contract Disputes Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s601"},"text":"41 U.S.C. 601","children":[],"tail":" et seq.), other than section 10(a) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s609/a"},"text":"41 U.S.C. 609(a)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id904892a3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3861, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tIII/s3101"},"text":"Pub. L. 96–70, title III, § 3101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/496"},"text":"93 Stat. 496","children":[],"tail":", related to disinterment, transportation, and reinterment of remains, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dC/tXXXV/s3546/a/5"},"text":"Pub. L. 104–201, div. C, title XXXV, § 3546(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2868"},"text":"110 Stat. 2868","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
