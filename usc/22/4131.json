{"tag":"section","attrib":{"id":"id906eb742-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131"},"text":null,"children":[{"tag":"num","attrib":{"value":"4131"},"text":"§ 4131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and applicability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id906eb743-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906eb744-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b), for purposes of this subchapter, the term “grievance” means any act, omission, or condition subject to the control of the Secretary which is alleged to deprive a member of the Service who is a citizen of the United States (other than a United States citizen employed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3951"},"text":"section 3951 of this title","children":[],"tail":" who is not a family member) of a right or benefit authorized by law or regulation or which is otherwise a source of concern or dissatisfaction to the member, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id906eb745-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separation of the member allegedly contrary to laws or regulations, or predicated upon alleged inaccuracy, omission, error, or falsely prejudicial character of information in any part of the official personnel record of the member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906eb746-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other alleged violation, misinterpretation, or misapplication of applicable laws, regulations, or published policy affecting the terms and conditions of the employment or career status of the member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906eb747-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allegedly wrongful disciplinary action against the member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906eb748-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dissatisfaction with respect to the working environment of the member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906eb749-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alleged inaccuracy, omission, error, or falsely prejudicial character of information in the official personnel record of the member which is or could be prejudicial to the member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906eb74a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" action alleged to be in the nature of reprisal or other interference with freedom of action in connection with participation by the member in procedures under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906eb74b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alleged denial of an allowance, premium pay, or other financial benefit to which the member claims entitlement under applicable laws or regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id906eb74c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any discrimination prohibited by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id906eb74d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1/H/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16"},"text":"section 2000e–16 of title 42","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id906eb74e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1/H/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s206/d"},"text":"section 206(d) of title 29","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id906eb74f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1/H/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s791"},"text":"section 791 of title 29","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id906eb750-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1/H/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 631 and 633a of title 29, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id906eb751-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/1/H/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rule, regulation, or policy directive prescribed under any provision of law described in clauses (i) through (iv).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906eb752-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The scope of grievances described in paragraph (1) may be modified by written agreement between the Department and the labor organization accorded recognition as the exclusive representative under subchapter X (hereinafter in this subchapter referred to as the “exclusive representative”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906eb753-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subchapter, the term “grievance” does not include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906eb754-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual assignment of a member under subchapter V, other than an assignment alleged to be contrary to law or regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906eb755-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the judgment of a selection board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4002"},"text":"section 4002 of this title","children":[],"tail":", a tenure board established under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3946/b"},"text":"section 3946(b) of this title","children":[],"tail":", or any other equivalent body established by laws or regulations which similarly evaluates the performance of members of the Service on a comparative basis;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906eb756-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expiration of a limited appointment, the termination of a limited appointment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4011"},"text":"section 4011 of this title","children":[],"tail":", or the denial of a limited career extension or of a renewal of a limited career extension under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4007/b"},"text":"section 4007(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906eb757-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any complaint or appeal where a specific statutory hearing procedure exists, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4139/a/2"},"text":"section 4139(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Nothing in this subsection shall exclude any act, omission, or condition alleged to violate any law, rule, regulation, or policy directive referred to in subsection (a)(1)(H) from such term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906eb758-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4131/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subchapter applies only with respect to the Department of State, Broadcasting ","children":[{"tag":"ref","attrib":{"idref":"fn002293"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002293"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “the Broadcasting”."}],"tail":" Board of Governors, the Agency for International Development, the Department of Agriculture, and the Department of Commerce."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id906eb759-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s1101"},"text":"Pub. L. 96–465, title I, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2142"},"text":"94 Stat. 2142","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tIII/s303/b"},"text":"Pub. L. 97–241, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/291"},"text":"96 Stat. 291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s153/a"},"text":"Pub. L. 102–138, title I, § 153(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/673"},"text":"105 Stat. 673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI"},"text":"Pub. L. 103–236, title I","children":[],"tail":", §§ 180(a)(10), 181(a)(4)(A), "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/416"},"text":"108 Stat. 416","children":[],"tail":", 417; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1335(k)(4), title XIV, § 1422(b)(4)(D), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-789"},"text":"112 Stat. 2681–789","children":[],"tail":", 2681–793.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id906eb75a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id906eb75b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id906eb75c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1422/b/4/D"},"text":"Pub. L. 105–277, § 1422(b)(4)(D)","children":[],"tail":", substituted “Agency for International Development” for “United States International Development Cooperation Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/k/4"},"text":"Pub. L. 105–277, § 1335(k)(4)","children":[],"tail":", substituted “Broadcasting Board of Governors,” for “the United States Information Agency,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/s180/a/10"},"text":"Pub. L. 103–236, § 180(a)(10)","children":[],"tail":", inserted “(other than a United States citizen employed under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3951"},"text":"section 3951 of this title","children":[],"tail":" who is not a family member)” after “citizen of the United States” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/s181/a/4"},"text":"Pub. L. 103–236, § 181(a)(4)","children":[],"tail":", made technical amendment to reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4011"},"text":"section 4011 of this title","children":[],"tail":" to reflect renumbering of corresponding section of original act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/s153/a/1"},"text":"Pub. L. 102–138, § 153(a)(1)","children":[],"tail":", added subpar. (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/s153/a/2"},"text":"Pub. L. 102–138, § 153(a)(2)","children":[],"tail":", in par. (4), substituted “section 4139(a)(2)” for “section 4139(b)” and inserted at end “Nothing in this subsection shall exclude any act, omission, or condition alleged to violate any law, rule, regulation, or policy directive referred to in subsection (a)(1)(H) from such term.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id906eb75d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id906eb75e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Broadcasting Board of Governors renamed United States Agency for Global Media pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6204/a/21"},"text":"section 6204(a)(21) of this title","children":[],"tail":". The renaming was effectuated by notice to congressional appropriations committees dated "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", and became effective "},{"tag":"date","attrib":{"date":"2018-08-22"},"text":"Aug. 22, 2018","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“United States Information Agency” substituted for “International Communication Agency” in subsec. (c), pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/241/s303/b"},"text":"section 303(b) of Pub. L. 97–241","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1461"},"text":"section 1461 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id906eb75f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/k/4"},"text":"section 1335(k)(4) of Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1422/b/4/D"},"text":"section 1422(b)(4)(D) of Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-04-01"},"text":"Apr. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1401"},"text":"section 1401 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6561"},"text":"section 6561 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id906eb760-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138"},"text":"Pub. L. 102–138","children":[],"tail":" not applicable with respect to any grievance, within the meaning of this section, arising before "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/s153/f"},"text":"section 153(f) of Pub. L. 102–138","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4115"},"text":"section 4115 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
