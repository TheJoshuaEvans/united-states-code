{"tag":"section","attrib":{"id":"id907f8083-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4803"},"text":null,"children":[{"tag":"num","attrib":{"value":"4803"},"text":"§ 4803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of high risk, high threat posts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id907f8084-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Department of State shall submit to the appropriate congressional committees and the Committees on Appropriations of the Senate and the House of Representatives a report, in classified form, that contains a list of diplomatic and consular posts designated as high risk, high threat posts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907f8085-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designations before opening or reopening posts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before opening or reopening a diplomatic or consular post, the Secretary shall determine if such post should be designated as a high risk, high threat post.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907f8086-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4803/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designating existing posts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall regularly review existing diplomatic and consular posts to determine if any such post should be designated as a high risk, high threat post if conditions at such post or the surrounding security environment require such a designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907f8087-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4803/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id907f8088-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4803/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate congressional committees” means the Committee on Foreign Affairs of the House of Representatives and the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907f8089-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4803/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High risk, high threat post","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “high risk, high threat post” means a United States diplomatic or consular post or other United States mission abroad, as determined by the Secretary, that, among other factors—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id907f808a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4803/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is located in a country—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id907f808b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4803/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with high to critical levels of political violence and terrorism; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id907f808c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4803/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of which lacks the ability or willingness to provide adequate security; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id907f808d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4803/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has mission physical security platforms that fall below the Department of State’s established standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907f808e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tI/s104"},"text":"Pub. L. 99–399, title I, § 104","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/323/tI/s101/a"},"text":"Pub. L. 114–323, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1907"},"text":"130 Stat. 1907","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/94/s2/a"},"text":"Pub. L. 115–94, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-18"},"text":"Dec. 18, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2038"},"text":"131 Stat. 2038","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907f808f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907f8090-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id907f8091-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 4803, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tI/s104/a"},"text":"Pub. L. 99–399, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/856"},"text":"100 Stat. 856","children":[],"tail":", established Bureau of Diplomatic Security in Department of State, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s162/g/3"},"text":"Pub. L. 103–236, title I, § 162(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/407"},"text":"108 Stat. 407","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/s104"},"text":"section 104 of Pub. L. 99–399","children":[],"tail":" enacted this section and amended former "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2652"},"text":"section 2652 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s162/g/3"},"text":"Pub. L. 103–236, title I, § 162(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/407"},"text":"108 Stat. 407","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id907f8092-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/94"},"text":"Pub. L. 115–94","children":[],"tail":" inserted “and the Committees on Appropriations of the Senate and the House of Representatives” after “appropriate congressional committees”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
