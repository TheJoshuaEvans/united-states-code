{"tag":"section","attrib":{"id":"id90037264-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2734e"},"text":"§ 2734e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual Report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", and annually thereafter, the Secretary of State shall submit to the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives and the Committee on Foreign Relations and the Committee on Appropriations of the Senate a report that contains the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90037265-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A rationale for the use of assignment restrictions by the Department of State, including specific case studies related to cleared United States Foreign Service and civil service employees of the Department that demonstrate country-specific restrictions serve a counterintelligence role beyond that which is already covered by the security clearance process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90037266-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The number of such Department employees subject to assignment restrictions over the previous year, with data disaggregated by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90037267-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification as a Foreign Service officer, civil service employee, eligible family member, or other employment status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90037268-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ethnicity, national origin, and race of the precluded employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90037269-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gender; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9003726a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the country of restriction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003726b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the considerations and criteria used by the Bureau of Diplomatic Security to determine whether an assignment restriction is warranted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003726c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of restrictions that were appealed and the success rate of such appeals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003726d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The impact of assignment restrictions in terms of unused language skills as measured by Foreign Service Institute language scores of such precluded employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9003726e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2734e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Measures taken to ensure the diversity of adjudicators and contracted investigators, with accompanying data on results.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9003726f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLIII/s5311/d"},"text":"Pub. L. 117–81, div. E, title LIII, § 5311(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2364"},"text":"135 Stat. 2364","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
