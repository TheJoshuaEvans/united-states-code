{"tag":"section","attrib":{"id":"id8fbbe2cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2427"},"text":null,"children":[{"tag":"num","attrib":{"value":"2427"},"text":"§ 2427.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fbbe2cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2427/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the President, in addition to funds otherwise available for such purposes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fbbe2cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2427/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $387,000,000 for fiscal year 1986 and $387,000,000 for fiscal year 1987 for necessary operating expenses of the agency primarily responsible for administering subchapter I of this chapter, of which $21,750,000 for the fiscal year 1987 is authorized for the necessary operating expenses of the Office of the Inspector General of the Agency for International Development and the remaining amount for the fiscal year is authorized for other necessary operating expenses of that agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fbbe2ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2427/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amounts as may be necessary for increases in salary, pay, retirement, and other employee benefits authorized by law, and for other nondiscretionary costs of such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fbbe2cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2427/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated under this section are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fbbe2d0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 667, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/tIII/s319"},"text":"Pub. L. 94–161, title III, § 319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/868"},"text":"89 Stat. 868","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/88/tI/s129/a"},"text":"Pub. L. 95–88, title I, § 129(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/543"},"text":"91 Stat. 543","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/tV/s506"},"text":"Pub. L. 95–424, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/960"},"text":"92 Stat. 960","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/tI/s120"},"text":"Pub. L. 96–53, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag"