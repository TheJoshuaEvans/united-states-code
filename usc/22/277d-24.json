{"tag":"section","attrib":{"id":"id8eb0dacb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–24"},"text":null,"children":[{"tag":"num","attrib":{"value":"277d–24"},"text":"§ 277d–24.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; exemption from administrative procedure provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in sections 277d–17 to 277d–25 of this title, the term “land” shall include interests in land, and the term “fair value” shall mean fair value of the interest acquired. The provisions of such sections shall be exempt from the operations of subchapter II of chapter 5, and chapter 7, of title 5.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eb0dacc-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/300/s8"},"text":"Pub. L. 88–300, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-04-29"},"text":"Apr. 29, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/186"},"text":"78 Stat. 186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eb0dacd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eb0dace-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8eb0dacf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Subchapter II of chapter 5, and chapter 7, of title 5” substituted in text for “the Administrative Procedure Act of ","children":[{"tag":"date","attrib":{"date":"1946-06-11"},"text":"June 11, 1946","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/60/237"},"text":"60 Stat. 237","children":[],"tail":"), as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1001–101"},"text":"5 U.S.C. 1001–101","children":[],"tail":"1)” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
