{"tag":"section","attrib":{"id":"id914a240c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731"},"text":null,"children":[{"tag":"num","attrib":{"value":"9731"},"text":"§ 9731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for international election observation and democratic civil society","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id914a240d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, in coordination with the Administrator of the United States Agency for International Development—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a240e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall work with the Organization of American States to ensure credible international observation of future elections in Venezuela that contributes to free, fair, and transparent democratic electoral processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a240f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall work with nongovernmental organizations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id914a2410-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen democratic governance and institutions, including the democratically elected National Assembly of Venezuela;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914a2411-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to defend internationally recognized human rights for the people of Venezuela, including support for efforts to document crimes against humanity and violations of human rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914a2412-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the efforts of independent media outlets to broadcast, distribute, and share information beyond the limited channels made available by the Maduro regime; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id914a2413-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to combat corruption and improve the transparency and accountability of institutions that are part of the Maduro regime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a2414-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engagement at the Organization of American States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, acting through the United States Permanent Representative to the Organization of American States, should advocate and build diplomatic support for sending an election observation mission to Venezuela to ensure that democratic electoral processes are organized and carried out in a free, fair, and transparent manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914c6d05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefing requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Secretary of State, in coordination with the Administrator of the United States Agency for International Development, shall provide a briefing on the strategy to carry out the activities described in subsection (a) to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id914c6d06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d07-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d09-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914c6d0a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914c6d0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary of State for fiscal year 2020, $17,500,000 to carry out the activities set forth in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914c6d0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9731/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to paragraph (1) are subject to the notification requirements applicable to expenditures from the Economic Support Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346/c"},"text":"section 2346(c) of this title","children":[],"tail":" and from the Development Assistance Fund under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2413/a"},"text":"section 2413(a) of this title","children":[],"tail":", to the extent that such funds are expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914c6d0d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tI/s143"},"text":"Pub. L. 116–94, div. J, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3038"},"text":"133 Stat. 3038","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
