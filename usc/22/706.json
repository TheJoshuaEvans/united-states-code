{"tag":"section","attrib":{"id":"id8ef3b058-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s706"},"text":null,"children":[{"tag":"num","attrib":{"value":"706"},"text":"§ 706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operative effect dependent upon Presidential finding","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall be operative with respect to the military, naval, or air forces of any foreign state only after a finding and declaration by the President that the powers and privileges provided herein are necessary for the maintenance of discipline. The President may at any time revoke such finding and declaration.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ef3b059-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-06-30/ch326/s6"},"text":"June 30, 1944, ch. 326, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/645"},"text":"58 Stat. 645","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ef3b05a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8ef3b05b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ef3b05c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Proclamation No. 2626","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Proc. No. 2626, ","children":[{"tag":"date","attrib":{"date":"1944-10-12"},"text":"Oct. 12, 1944","children":[],"tail":", 9 F.R. 12403, respecting activation by President, was revoked by Proc. No. 3107, "},{"tag":"date","attrib":{"date":"1955-08-09"},"text":"Aug. 9, 1955","children":[],"tail":", 20 F.R. 5805."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
