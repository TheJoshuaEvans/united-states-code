{"tag":"section","attrib":{"id":"id903cab17-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3506"},"text":null,"children":[{"tag":"num","attrib":{"value":"3506"},"text":"§ 3506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id903cab18-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment; compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Deputy Director of the Institute shall be appointed by the President, by and with the advice and consent of the Senate. The Deputy Director shall receive compensation at the rate payable for level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903cab19-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Deputy Director shall perform such duties and exercise such powers as the Director may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903cab1a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional positions; establishment by President; compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":nu