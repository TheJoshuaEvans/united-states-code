{"tag":"section","attrib":{"id":"id911cd1c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113"},"text":null,"children":[{"tag":"num","attrib":{"value":"9113"},"text":"§ 9113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bilateral procedures, including memoranda of understanding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911cd1c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd1c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2014-08-08"},"text":"August 8, 2014","children":[],"tail":", the Secretary of State shall initiate a process to develop and enter into appropriate bilateral procedures, including memoranda of understanding, as appropriate, with non-Convention countries that are unlikely to become Convention countries in the foreseeable future, or with Convention countries that have unresolved abduction cases that occurred before the Hague Abduction Convention entered into force with respect to the United States or that country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out paragraph (1), the Secretary of State shall give priority to countries with significant abduction cases and related issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911cd1c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The bilateral procedures described in subsection (a) should include provisions relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911cd1c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the identification of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911cd1c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Central Authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd1c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the judicial or administrative authority that will promptly adjudicate abduction and access cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd1c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the law enforcement agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911cd1ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the implementation of procedures to ensure the immediate enforcement of an order issued by the authority identified pursuant to subparagraph (B) to return an abducted child to a left-behind parent, including by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911cd1cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting an investigation to ascertain the location of the abducted child;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911cd1cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing protection to the abducted child after such child is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911cd1cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/b/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retrieving the abducted child and making the appropriate arrangements for such child to be returned to the child’s country of habitual residence;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of a protocol to effectuate the return of an abducted child identified in an abduction case not later than 6 weeks after the application with respect to the abduction case has been submitted to the judicial or administrative authority, as applicable, of the country in which the abducted child is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1cf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of a protocol for the establishment and protection of the rights of interim contact during pendency of abduction cases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911cd1d0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9113/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of a protocol to establish periodic visits between a United States embassy or consular official and an abducted child, in order to allow the official to ascertain the child’s location and welfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911cd1d1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150/tI/s103"},"text":"Pub. L. 113–150, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1815"},"text":"128 Stat. 1815","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
