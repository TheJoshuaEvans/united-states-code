{"tag":"section","attrib":{"id":"id905479a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001"},"text":null,"children":[{"tag":"num","attrib":{"value":"4001"},"text":"§ 4001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id905479a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Career members of the Senior Foreign Service are promoted by appointment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3942/a"},"text":"section 3942(a) of this title","children":[],"tail":" to a higher salary class in the Senior Foreign Service. Members of the Senior Foreign Service serving under career candidate appointments or noncareer appointments are promoted by appointment under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3943"},"text":"section 3943 of this title","children":[],"tail":" to a higher salary class in the Senior Foreign Service. Foreign Service officers, and Foreign Service personnel who are assigned to a class in the Foreign Service Schedule, are promoted by appointment under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3942/a"},"text":"section 3942(a) of this title","children":[],"tail":" as career members of the Senior Foreign Service or by assignment under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3964"},"text":"section 3964 of this title","children":[],"tail":" to a higher salary class in the Foreign Service Schedule."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id905479a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations and rankings of selection boards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4006/a"},"text":"section 4006(a) of this title","children":[],"tail":", promotions of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id905479a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the Senior Foreign Service, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905479a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the Service assigned to a salary class in the Foreign Service Schedule (including promotions of such members into the Senior Foreign Service),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be based upon the recommendations and rankings of selection boards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4002"},"text":"section 4002 of this title","children":[],"tail":", except that the Secretary may by regulation specify categories of career members, categories of career candidates, and other members of the Service assigned to salary classes in the Foreign Service Schedule who may receive promotions on the basis of satisfactory performance."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id905479a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility; request for promotion; time of consideration; withdrawal of request; basis for decision; affidavits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id905479a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promotions into the Senior Foreign Service shall be recommended by selection boards only from among career members of the Service assigned to class 1 in the Foreign Service Schedule who request that they be considered for promotion into the Senior Foreign Service. The Secretary shall prescribe the length of the period after such a request is made (within any applicable time in class limitation established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4007/a"},"text":"section 4007(a) of this title","children":[],"tail":") during which such members may be considered by selection boards for entry into the Senior Foreign Service. A request by a member for consideration for promotion into the Senior Foreign Service under this subsection may be withdrawn by the member, but if it is withdrawn, that member may not thereafter request consideration for promotion into the Senior Foreign Service."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905479aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Decisions by the Secretary on the numbers of individuals to be promoted into and retained in the Senior Foreign Service shall be based upon a systematic long-term projection of personnel flows and needs designed to provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id905479ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regular, predictable flow of recruitment in the Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905479ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective career development patterns to meet the needs of the Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905479ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regular, predictable flow of talent upward through the ranks and into the Senior Foreign Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905479ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The affidavit requirements of sections 3332 and 3333(a) of title 5 shall not apply with respect to a member of the Service who has previously complied with those requirements and who subsequently is promoted by appointment to any class in the Senior Foreign Service without a break in service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905479af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":", (5) Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/tVII/s715/b/5"},"text":"Pub. L. 114–323, title VII, § 715(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1946"},"text":"130 Stat. 1946","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id905479b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id905479b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The promotion, on or after ","children":[{"tag":"date","attrib":{"date":"2017-01-01"},"text":"January 1, 2017","children":[],"tail":", of any Foreign Service officer, appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3942/a/1"},"text":"section 3942(a)(1) of this title","children":[],"tail":", who has general responsibility for carrying out the functions of the Service to the Senior Foreign Service shall be contingent upon such individual completing at least one tour in—"}],"tail":null},{"tag":"clause","attrib":{"id":"id905479b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a global affairs bureau; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id905479b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a global affairs position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905479b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The requirements under subparagraph (A) shall not apply if the Secretary certifies that the individual proposed for promotion to the Senior Foreign Service—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id905479b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has met all other requirements applicable to such promotion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id905479b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was unable to complete a tour in a global affairs bureau or global affairs position because there was not a reasonable opportunity for such individual to be assigned to such a position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id905479b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id905479b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “global affairs bureau” means any bureau of the Department that is under the responsibility of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id905479b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary for Economic Growth, Energy, and Environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id905479ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary for Arms Control and International Security Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id905479bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary for Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id905479bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/C/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for International Organization Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id905479bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/C/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary for Public Diplomacy and Public Affairs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id905479be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/C/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary for Civilian, Security, Democracy, and Human Rights; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id905479bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4001/c/6/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “global affairs position” means any position funded with amounts appropriated to the Department under the heading “Diplomatic Policy and Support”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id905479c0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s601"},"text":"Pub. L. 96–465, title I, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2094"},"text":"94 Stat. 2094","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s185/b"},"text":"Pub. L. 100–204, title I, § 185(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1366"},"text":"101 Stat. 1366","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s180/a/6"},"text":"Pub. L. 103–236, title I, § 180(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/416"},"text":"108 Stat. 416","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tIII/s326"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title III, § 326]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–437; "},{"tag":"ref","attrib":{"href":"/us/pl/114/291/s6"},"text":"Pub. L. 114–291, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1498"},"text":"130 Stat. 1498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/323/tIV/s403"},"text":"Pub. L. 114–323, title IV, § 403","children":[],"tail":", title VII, § 715(b)(5), "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1927"},"text":"130 Stat. 1927","children":[],"tail":", 1946; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLIII/s5307"},"text":"Pub. L. 117–81, div. E, title LIII, § 5307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2362"},"text":"135 Stat. 2362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id905479c1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id905479c2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id905479c3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(6)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":", in introductory provisions, substituted “promotion, on or after "},{"tag":"date","attrib":{"date":"2017-01-01"},"text":"January 1, 2017","children":[],"tail":",” for “promotion” and “Foreign Service officer, appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3942/a/1"},"text":"section 3942(a)(1) of this title","children":[],"tail":", who has general responsibility for carrying out the functions of the Service” for “individual joining the Service on or after "},{"tag":"date","attrib":{"date":"2017-01-01"},"text":"January 1, 2017","children":[],"tail":",”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s715/b/5"},"text":"Pub. L. 114–323, § 715(b)(5)","children":[],"tail":", struck out par. (4) which read as follows: “Not later than "},{"tag":"date","attrib":{"date":"2001-03-01"},"text":"March 1, 2001","children":[],"tail":", and every four years thereafter, the Secretary of State shall submit a report to the Speaker of the House of Representatives and to the Committee on Foreign Relations of the Senate which shall include a workforce plan for the subsequent five years, including projected personnel needs, by grade and by skill. Each such plan shall include for each category the needs for foreign language proficiency, geographic and functional expertise, and specialist technical skills. Each workforce plan shall specifically account for the training needs of Foreign Service personnel and shall delineate an intake program of generalist and specialist Foreign Service personnel to meet projected future requirements.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/291"},"text":"Pub. L. 114–291","children":[],"tail":" substituted “include a workforce plan” for “include the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) A description of the steps taken and planned in furtherance of—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) maximum compatibility among agencies utilizing the Foreign Service personnel system, as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3923"},"text":"section 3923 of this title","children":[],"tail":", and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the development of uniform policies and procedures and consolidated personnel functions, as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3924"},"text":"section 3924 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) A workforce plan”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s715/b/5"},"text":"Pub. L. 114–323, § 715(b)(5)","children":[],"tail":", struck out par. (5) which read as follows: “If there are substantial modifications to any workforce plan under paragraph (4)(B) during any year in which a report under paragraph (4) is not required, a supplemental annual notification shall be submitted in the same manner as reports are required to be submitted under paragraph (4).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323/s403"},"text":"Pub. L. 114–323, § 403","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" added pars. (4) and (5) and struck out former par. (4), which required report not later than Mar. 1 of each year, describing steps taken and planned in furtherance of compatibility and development of uniform procedures and consolidated personnel functions, specifying upper and lower limits planned for recruitment, retention, and advancement of members, and specifying numbers of members assigned to positions more than one grade higher or lower than the member."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", which directed amendment of par. (2) by striking “and” the last place it appears and by inserting “and other members of the Service” after “categories of career candidates,”, was executed by striking “and” after “categories of career members,” and making the insertion in concluding provisions below par. (2), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/204"},"text":"Pub. L. 100–204","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id905479c4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id905479c5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reports Eliminated","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66/tII/s2241"},"text":"Pub. L. 104–66, title II, § 2241","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/733"},"text":"109 Stat. 733","children":[],"tail":", which provided that reports required under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4001/c/4"},"text":"section 4001(c)(4) of this title","children":[],"tail":" would not cover activities of the United States Information Agency, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1336(5), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-790"},"text":"112 Stat. 2681–790","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id905479c6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Language Training in Foreign Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s155"},"text":"Pub. L. 102–138, title I, § 155","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/675"},"text":"105 Stat. 675","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1335(q), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-789"},"text":"112 Stat. 2681–789","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dG"},"text":"“The Department of State and the Department of Commerce shall ensure that the precepts for promotion of Foreign Service employees provide that end-of-training reports for employees in full-time language training shall be weighed as heavily as the annual employee efficiency reports, in order to ensure that employees in language training are not disadvantaged in the promotion process.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id905479c7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Foreign Service Promotion Panels","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s163"},"text":"Pub. L. 101–246, title I, § 163","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/47"},"text":"104 Stat. 47","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/132/s1/b"},"text":"Pub. L. 107–132, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-16"},"text":"Jan. 16, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2412"},"text":"115 Stat. 2412","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/132/s1/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the sense of the Congress that, to the greatest extent possible, Foreign Service promotion panels should—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only promote candidates to the Senior Foreign Service who have demonstrated foreign language proficiency in at least one language at the General Professional Speaking Proficiency level, as defined by the George P. Shultz National Foreign Affairs Training Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strive for the objective stipulated in the Foreign Service Manual ‘to be able to use two foreign languages at a minimum professional level of proficiency of S–3/R–3, which is the general professional speaking proficiency level’; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have at least one person on each Foreign Service promotion panel who has attained at least the General Professional Speaking Proficiency level in one language level.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id905479c8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Language Proficiency in Employee Evaluation Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s164"},"text":"Pub. L. 101–246, title I, § 164","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/47"},"text":"104 Stat. 47","children":[],"tail":", required revision of employee and officer evaluation reports for Foreign Service officers of Department of State and Agency for International Development to include separate assessment of employee’s effectiveness in using foreign language and required that precedence in promotion be given to officers achieving certain levels of proficiency in foreign language, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s191/b"},"text":"Pub. L. 103–236, title I, § 191(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/418"},"text":"108 Stat. 418","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s191/a"},"text":"section 191(a) of Pub. L. 103–236","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3926"},"text":"section 3926 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
