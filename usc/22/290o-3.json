{"tag":"section","attrib":{"id":"id8ee55945-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290o–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"290o–3"},"text":"§ 290o–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Reserve Banks as depositories","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any Federal Reserve Bank which is requested to do so by the Bank may act as its depository, or as its fiscal agent, and the Board of Governors of the Federal Reserve System shall exercise general supervision over the carrying out of these functions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ee55946-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/c/tVII/s705"},"text":"Pub. L. 104–208, div. A, title I, § 101(c) [title VII, § 705]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-121"},"text":"110 Stat. 3009–121","children":[],"tail":", 3009–179.)"}],"tail":"\n"}],"tail":null}
