{"tag":"section","attrib":{"id":"id8fa1a46d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2370c–2"},"text":"§ 2370c–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fa1a46e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation of allegations regarding child soldiers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"United States missions abroad shall thoroughly investigate reports of the use of child soldiers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fa1a46f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information for annual Human Rights Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In preparing those portions of the annual Human Rights Report that relate to child soldiers under sections 2151n and 2304 of this title, the Secretary of State shall ensure that such reports include a description of the use of child soldiers in each foreign country, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fa1a470-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trends toward improvement in such country of the status of child soldiers or the continued or increased tolerance of such practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa1a471-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of the government of such country in engaging in or tolerating the use of child soldiers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fa1a472-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a country is notified pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370c–1/b/2"},"text":"section 2370c–1(b)(2) of this title","children":[],"tail":", or a waiver is granted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370c–1/c/1"},"text":"section 2370c–1(c)(1) of this title","children":[],"tail":", the President shall submit a report to the appropriate congressional committees not later than June 15 of the following year. The report shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fa1a473-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the countries receiving notification that they are in violation of the standards under sections 2370c to 2370c–2 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa1a474-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description and the amount of any assistance withheld under this title pursuant to the application to those countries of the prohibition in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370c–1/a"},"text":"section 2370c–1(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa1a475-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of any waivers or exceptions exercised under sections 2370c to 2370c–2 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa1a476-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c–2/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" justification for any such waivers and exceptions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa1a477-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c–2/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description and the amount of any assistance provided under sections 2370c to 2370c–2 of this title pursuant to the issuance of such waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fa1a478-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2370c–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to be included in annual trafficking in persons report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary of State notifies a country pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370c–1/b/2"},"text":"section 2370c–1(b)(2) of this title","children":[],"tail":", or the President grants a waiver pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370c–1/c/1"},"text":"section 2370c–1(c)(1) of this title","children":[],"tail":", the Secretary of State shall include, in each report required under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7107/b"},"text":"section 7107(b) of this title","children":[],"tail":", the information required to be included in the annual report to Congress under paragraphs (1) through (5) of subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fa1a479-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457/tIV/s405"},"text":"Pub. L. 110–457, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5090"},"text":"122 Stat. 5090","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/425/tII/s212/c"},"text":"Pub. L. 115–425, title II, § 212(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-08"},"text":"Jan. 8, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5486"},"text":"132 Stat. 5486","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fa1a47a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fa1a47b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8fa1a47c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 2370c to 2370c–2 of this title, referred to in subsec. (c)(1), (3), (5), was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Pub. L. 110–457","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5087"},"text":"122 Stat. 5087","children":[],"tail":", known as the Child Soldiers Prevention Act of 2008, which is classified principally to sections 2370c to 2370c–2 of this title. For complete classification of this Act to the Code, see Short Title of 2008 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8fa1a47d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Child Soldiers Prevention Act of 2008, and also as part of the William Wilberforce Trafficking Victims Protection Reauthorization Act of 2008, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fa1a47e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/s212/c/1/A"},"text":"Pub. L. 115–425, § 212(c)(1)(A)","children":[],"tail":", in introductory provisions, struck out “, during any of the 5 years following "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"December 23, 2008","children":[],"tail":",” after “If” and substituted “waiver” for “wavier”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/s212/c/1/B"},"text":"Pub. L. 115–425, § 212(c)(1)(B)","children":[],"tail":"–(D), added par. (2), redesignated former pars. (2) to (4) as (3) to (5), respectively, and in par. (5), inserted “and the amount” after “a description”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/s212/c/2"},"text":"Pub. L. 115–425, § 212(c)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fa1a47f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8fa1a480-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/457/s407"},"text":"section 407 of Pub. L. 110–457","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2370c"},"text":"section 2370c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8fa1a481-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8fa1a482-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2012-06-14"},"text":"June 14, 2012","children":[],"tail":", 77 F.R. 37551, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby delegate to you the functions conferred upon the President by section 405(c) of the Child Soldiers Prevention Act of 2008, title IV of the William Wilberforce Trafficking Victims Protection Reauthorization Act of 2008 ("},{"tag":"ref","attrib":{"href":"/us/pl/110/457"},"text":"Public Law 110–457","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Barack Obama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
