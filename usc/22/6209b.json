{"tag":"section","attrib":{"id":"id90b18db3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6209b"},"text":null,"children":[{"tag":"num","attrib":{"value":"6209b"},"text":"§ 6209b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of the Secretary of State in foreign policy guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To assist the Agency in carrying out its functions, the Chief Executive Officer shall regularly consult with and seek from the Secretary of State guidance on foreign policy issues.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90b18db4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tIII/s310B"},"text":"Pub. L. 103–236, title III, § 310B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1288/7"},"text":"Pub. L. 114–328, div. A, title XII, § 1288(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2554"},"text":"130 Stat. 2554","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1299Q/e/7"},"text":"Pub. L. 116–283, div. A, title XII, § 1299Q(e)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4025"},"text":"134 Stat. 4025","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90b18db5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90b18db6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}]