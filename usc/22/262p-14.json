{"tag":"section","attrib":{"id":"id8ea039cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262p–14"},"text":null,"children":[{"tag":"num","attrib":{"value":"262p–14"},"text":"§ 262p–14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support to enhance the capacity of fund members to evaluate the legal and financial terms of sovereign debt contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director at the International Monetary Fund to use the voice and vote of the United States to advocate that the Fund promote international standards and best practices with respect to sovereign debt contracts and provide technical assistance to Fund members, and in particular to lower middle-income countries and countries eligible to receive assistance from the International Development Association, seeking to enhance their capacity to evaluate the legal and financial terms of sovereign debt contracts with multilateral, bilateral, and private sector creditors.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ea039cd-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXVI/s1630"},"text":"Pub. L. 95–118, title XVI, § 1630","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXI/s6103/a"},"text":"Pub. L. 117–81, div. F, title LXI, § 6103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2384"},"text":"135 Stat. 2384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ea039ce-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id8ea039cf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6103/c"},"text":"section 6103(c) of Pub. L. 117–81","children":[],"tail":", see Termination Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ea039d0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"id8ea039d1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXI/s6103/c"},"text":"Pub. L. 117–81, div. F, title LXI, § 6103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2385"},"text":"135 Stat. 2385","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tVI/s5607/a"},"text":"Pub. L. 119–60, div. E, title VI, § 5607(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1605"},"text":"139 Stat. 1605","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dE/tVI/s5607/a"},"text":"“The amendment made by subsection (a) [enacting this section] shall have no force or effect after the 10-year period that begins with the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8ea039d2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–5"},"text":"section 262p–5 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
