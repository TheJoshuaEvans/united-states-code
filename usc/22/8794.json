{"tag":"section","attrib":{"id":"id9110eba7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8794"},"text":null,"children":[{"tag":"num","attrib":{"value":"8794"},"text":"§ 8794.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President may waive the requirement to include a person on a list required by section 8791, 8792, or 8793 of this title or to impose sanctions pursuant to any such section if the President—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9110eba8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8794/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that such a waiver is in the national security interests of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110eba9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8794/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the appropriate congressional committees a report on the reasons for that determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9110ebaa-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158/tVII/s705"},"text":"Pub. L. 112–158, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1268"},"text":"126 Stat. 1268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9110ebab-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id9110ebac-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8795"},"text":"section 8795 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
