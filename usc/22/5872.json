{"tag":"section","attrib":{"id":"id90a0c473-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5872"},"text":null,"children":[{"tag":"num","attrib":{"value":"5872"},"text":"§ 5872.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Space Commerce","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90a0c474-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5872/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade missions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Space Commerce of the Department of Commerce is authorized and encouraged to conduct one or more trade missions to appropriate independent states of the former Soviet Union for the purpose of familiarizing United States aerospace industry representatives with space hardware, space technologies, and space services that may be available from the independent states, and with the business practices and overall business climate in the independent states.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a0c475-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5872/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring negotiations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Space Commerce—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a0c476-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5872/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall monitor the progress of any discussions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5871/c/1"},"text":"section 5871(c)(1) of this title","children":[],"tail":" that are being conducted; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a0c477-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5872/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall advise the Administrator of the National Aeronautics and Space Administration as to the impact on United States industry of each potential acquisition of space hardware, space technology, or space services from the independent states of the former Soviet Union, specifically including any anticompetitive issues the Office may observe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90a0c478-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/tVI/s602"},"text":"Pub. L. 102–511, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3347"},"text":"106 Stat. 3347","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
