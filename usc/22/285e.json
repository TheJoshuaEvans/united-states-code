{"tag":"section","attrib":{"id":"id8ebcc268-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285e"},"text":null,"children":[{"tag":"num","attrib":{"value":"285e"},"text":"§ 285e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; income covered into Treasury","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc269-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby authorized to be appropriated, without fiscal year limitation, for the purchase of twenty thousand shares of capital stock of the Bank, $200,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc26a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any payment made to the United States by the Bank as a distribution of net income shall be covered into the Treasury as a miscellaneous receipt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc26b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s7"},"text":"Pub. L. 89–369, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-16"},"text":"Mar. 16, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/72"},"text":"80 Stat. 72","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
