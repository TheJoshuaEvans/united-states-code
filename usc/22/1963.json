{"tag":"section","attrib":{"id":"id8f280750-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1963"},"text":null,"children":[{"tag":"num","attrib":{"value":"1963"},"text":"§ 1963.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United Nations Emergency Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President should continue to furnish facilities and military assistance, within the provisions of applicable law and established policies, to the United Nations Emergency Force in the Middle East, with a view to maintaining the truce in that region.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f280751-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/7/s4"},"text":"Pub. L. 85–7, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-03-09"},"text":"Mar. 9, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/6"},"text":"71 Stat. 6","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
