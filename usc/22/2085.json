{"tag":"section","attrib":{"id":"id8f2f32fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2085"},"text":null,"children":[{"tag":"num","attrib":{"value":"2085"},"text":"§ 2085.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f2f32fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2085/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is authorized to be appropriated not to exceed $7,500,000 to provide for United States participation in Interama under this chapter, of which not to exceed $250,000 shall be available for expenditure in connection with the preparation of the report required to be submitted to the Congress under section 2(b) of this Act. Sums appropriated under this subsection shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2f32fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2085/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the amount authorized in subsection (a), there is authorized to be appropriated not to exceed $1,000,000 annually for each of the fiscal years 1968 and 1969 for the maintenance of United States installations and activities at Interama.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f2f32ff-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/355/s5"},"text":"Pub. L. 89–355, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-02-19"},"text":"Feb. 19, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/7"},"text":"80 Stat. 7","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f2f3300-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f2f3301-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f2f3302-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2(b) of this Act, referred to in subsec. (a), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/355/s2/b"},"text":"section 2(b) of Pub. L. 89–355","children":[],"tail":", which was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2082"},"text":"section 2082 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
