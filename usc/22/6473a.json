{"tag":"section","attrib":{"id":"id90bd744a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6473a"},"text":"§ 6473a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated persons list for particularly severe violations of religious freedom","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90bd744b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bd744c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, in coordination with the Ambassador at Large and in consultation with relevant government and nongovernment experts, shall establish and maintain a list of foreign individuals to whom a consular post has denied a visa on the grounds of particularly severe violations of religious freedom under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182/a/2/G"},"text":"section 1182(a)(2)(G) of title 8","children":[],"tail":", or who are subject to financial sanctions or other measures for particularly severe violations of freedom religion."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd744d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The list required under paragraph (1) shall be known as the “Designated Persons List for Particularly Severe Violations of Religious Freedom”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bd744e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bd744f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall submit a report to the appropriate congressional committees that contains the list required under subsection (a), including, with respect to each foreign individual on the list—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bd7450-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the individual and a description of the particularly severe violation of religious freedom committed by the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bd7451-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the country or other location in which such violation took place; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bd7452-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the actions taken pursuant to this chapter or any other Act or Executive order in response to such violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd7453-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission and updates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall submit to the appropriate congressional committees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bd7454-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial report required under paragraph (1) not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bd7455-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" updates to the report every 180 days thereafter and as new information becomes available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd7456-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required under paragraph (1) should be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd7457-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bd7458-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bd7459-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bd745a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Banking, Housing, and Urban Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bd745b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bd745c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bd745d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6473a/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Financial Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90bd745e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292/tVI/s605"},"text":"Pub. L. 105–292, title VI, § 605","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/281/tV/s501/2"},"text":"Pub. L. 114–281, title V, § 501(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1437"},"text":"130 Stat. 1437","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90bd745f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90bd7460-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90bd7461-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(1)(C), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292"},"text":"Pub. L. 105–292","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2787"},"text":"112 Stat. 2787","children":[],"tail":", known as the International Religious Freedom Act of 1998, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6401"},"text":"section 6401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id90bd7462-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292/s605"},"text":"section 605 of Pub. L. 105–292","children":[],"tail":" was renumbered section 606 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6474"},"text":"section 6474 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
