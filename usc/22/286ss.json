{"tag":"section","attrib":{"id":"id8ecb1a70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286ss"},"text":null,"children":[{"tag":"num","attrib":{"value":"286ss"},"text":"§ 286ss.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of amendment to Articles of Agreement of Fund approved on ","children":[{"tag":"date","attrib":{"date":"1997-10-22"},"text":"October 22, 1997","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund may agree to and accept the amendment to the Articles of Agreement of the Fund as proposed in the resolution numbered 52–4 of the Board of Governors of the Fund which was approved by such Board on ","children":[{"tag":"date","attrib":{"date":"1997-10-22"},"text":"October 22, 1997","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That not more than one year after the acceptance of such amendments to the Fund’s Articles of Agreement, the Secretary of the Treasury shall submit a report to the appropriate congressional committees analyzing Special Drawing Rights, to include a discussion of how those countries that significantly use or acquire Special Drawing Rights in accordance with Article XIX, Section 2(c), use or acquire them; the extent to which countries experiencing balance of payment difficulties exchange or use their Special Drawing Rights to acquire reserve currencies; and the manner in which those reserve currencies are acquired when utilizing Special Drawing Rights."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ecb1a71-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s67"},"text":"July 31, 1945, ch. 339, § 67","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/32/tXIV/s1402"},"text":"Pub. L. 111–32, title XIV, § 1402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-24"},"text":"June 24, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1918"},"text":"123 Stat. 1918","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/117/dF/tVII/s7034/q/1/A"},"text":"Pub. L. 111–117, div. F, title VII, § 7034(q)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-12-16"},"text":"Dec. 16, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3363"},"text":"123 Stat. 3363","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ecb1a72-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ecb1a73-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ecb1a74-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/117"},"text":"Pub. L. 111–117","children":[],"tail":" substituted “resolution numbered 52–4” for “resolution numbered 54–4”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ecb1a75-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ecb1a76-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/117/dF/tVII/s7034/q/1/B"},"text":"Pub. L. 111–117, div. F, title VII, § 7034(q)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-12-16"},"text":"Dec. 16, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3363"},"text":"123 Stat. 3363","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/117/dF/tVII/s7034/q/1/B"},"text":"“The amendment made by subparagraph (A) [amending this section] shall take effect as if included in the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/32/s1402"},"text":"section 1402 of Public Law 111–32","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
