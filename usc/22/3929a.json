{"tag":"section","attrib":{"id":"id904d4df4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3929a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3929a"},"text":"§ 3929a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abolishment of Inspector General of Department of State and Foreign Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3929"},"text":"section 3929 of this title","children":[],"tail":", the Inspector General of the Department of State and the Foreign Service is hereby abolished."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id904d4df5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/tI/s150/b"},"text":"Pub. L. 99–93, title I, § 150(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/427"},"text":"99 Stat. 427","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIV/s413/c"},"text":"Pub. L. 99–399, title IV, § 413(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/868"},"text":"100 Stat. 868","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904d4df6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904d4df7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id904d4df8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag