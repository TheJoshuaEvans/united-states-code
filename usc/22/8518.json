{"tag":"section","attrib":{"id":"id910293e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518"},"text":null,"children":[{"tag":"num","attrib":{"value":"8518"},"text":"§ 8518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on investments in the energy sector of Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id910293e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910293e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", the President shall submit to the appropriate congressional committees a report—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910293ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on investments in the energy sector of Iran that were made during the period described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910293eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that contains—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id910293ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the volume of energy-related resources (other than refined petroleum), including ethanol, that Iran imported during the period described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910293ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all significant known energy-related joint ventures, investments, and partnerships located outside Iran that involve Iranian entities in partnership with entities from other countries, including an identification of the entities from other countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910293ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an estimate of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id910293ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/a/1/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total value of each such joint venture, investment, and partnership; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id910293f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/a/1/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of each such joint venture, investment, and partnership owned by an Iranian entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910293f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The period described in this paragraph is the period beginning on ","children":[{"tag":"date","attrib":{"date":"2006-01-01"},"text":"January 1, 2006","children":[],"tail":", and ending on the date that is 60 days after "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id910293f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updated reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after submitting the report required by subsection (a), and every 180 days thereafter, the President shall submit to the appropriate congressional committees a report, covering the 180-day period beginning on the date that is 30 days before the date on which the preceding report was required to be submitted by this section, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id910293f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains the matters required in the report under subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id910293f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id910293f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the volume of crude oil and refined petroleum products imported to and exported from Iran (including through swaps and similar arrangements);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910293f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the persons selling and transporting crude oil and refined petroleum products described in subparagraph (A), the countries with primary jurisdiction over those persons, and the countries in which those products were refined;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910293f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sources of financing for imports to Iran of crude oil and refined petroleum products described in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id910293f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the involvement of foreign persons in efforts to assist Iran in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id910293f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing upstream oil and gas production capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910293fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" importing advanced technology to upgrade existing Iranian refineries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910293fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" converting existing chemical plants to petroleum refineries; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id910293fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8518/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining, upgrading, or expanding existing refineries or constructing new refineries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id910293fd-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tI/s110"},"text":"Pub. L. 111–195, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1338"},"text":"124 Stat. 1338","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/158/tII/s224"},"text":"Pub. L. 112–158, title II, § 224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1240"},"text":"126 Stat. 1240","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id910293fe-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id910293ff-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8551/a"},"text":"section 8551(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91029400-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id91029401-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158"},"text":"Pub. L. 112–158","children":[],"tail":" substituted “a report, covering the 180-day period beginning on the date that is 30 days before the date on which the preceding report was required to be submitted by this section, that—” for “a report containing the matters required in the report under subsection (a)(1) for the 180-day period beginning on the date that is 30 days before the date on which the preceding report was required to be submitted by this section.” and added pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id91029402-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id91029403-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to Secretary of State, see Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2010-09-23"},"text":"Sept. 23, 2010","children":[],"tail":", 75 F.R. 67025, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8501"},"text":"section 8501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
