{"tag":"section","attrib":{"id":"id909e7ad7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853"},"text":null,"children":[{"tag":"num","attrib":{"value":"5853"},"text":"§ 5853.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonproliferation and disarmament activities in independent states","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id909e7ad8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President is authorized to promote bilateral and multilateral nonproliferation and disarmament activities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id909e7ad9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by supporting the dismantlement and destruction of nuclear, biological, and chemical weapons, their delivery systems, and conventional weapons of the independent states of the former Soviet Union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id909e7ada-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by supporting bilateral and multilateral efforts to halt the proliferation of nuclear, biological, and chemical weapons, their delivery systems, related technologies, and other weapons of the independent states, including activities such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id909e7adb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the storage, transportation, and safeguarding of such weapons, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id909e7adc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase, barter, or other acquisition of such weapons or materials derived from such weapons;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id909e7add-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by establishing programs for safeguarding against the proliferation of nuclear, biological, chemical, and other weapons of the independent states;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id909e7ade-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by establishing programs for preventing diversion of weapons-related scientific and technical expertise of the independent states to terrorist groups or to third countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id909e7adf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by establishing science and technology centers in the independent states for the purpose of engaging weapons scientists and engineers of the independent states (in particular those who were previously involved in the design and production of nuclear, biological, and chemical weapons) in productive, nonmilitary undertakings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id909e7ae0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by establishing programs for facilitating the conversion of military technologies and capabilities and defense industries of the former Soviet Union into civilian activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id909e7ae1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Priority in carrying out this section shall be given to the activities described in paragraphs (1) through (5) of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id909e7ae2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of defense funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id909e7ae3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In recognition of the direct contributions to the national security interests of the United States of the programs and activities authorized by subsection (a), the President is authorized to make available for use in carrying out those programs and activities, in addition to amounts otherwise available for such purposes, funds made available pursuant to sections 108 and 109 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/229"},"text":"Public Law 102–229","children":[],"tail":" or under the amendments made by section 506(a) of this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id909e7ae4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5853/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds described in paragraph (1) may not be obligated for programs and activities under subsection (a) unless the Director of the Office of Management and Budget has determined that expenditures during fiscal year 1993 pursuant to such obligation shall be counted against the defense category of the discretionary spending limits for that fiscal year (as defined in section 665(a)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002324"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002324"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 2) for purposes of part C of the Balanced Budget and Emergency Deficit Control Act of 1985 ["},{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"2 U.S.C. 900","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id909e7ae5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/tV/s503"},"text":"Pub. L. 102–511, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3338"},"text":"106 Stat. 3338","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id909e7ae6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id909e7ae7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id909e7ae8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 108 and 109 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/229"},"text":"Public Law 102–229","children":[],"tail":", referred to in subsec. (c)(1), are sections 108 and 109 of "},{"tag":"ref","attrib":{"href":"/us/pl/102/229/tI"},"text":"Pub. L. 102–229, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1708"},"text":"105 Stat. 1708","children":[],"tail":", which are not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 506(a) of this Act, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s506/a"},"text":"section 506(a) of Pub. L. 102–511","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5856/a"},"text":"section 5856(a) of this title","children":[],"tail":" and was omitted from the Code. Section 506(a) directed amendment of "},{"tag":"ref","attrib":{"href":"/us/pl/102/228/s221"},"text":"section 221 of Pub. L. 102–228","children":[],"tail":", which was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2551"},"text":"section 2551 of this title","children":[],"tail":", but did not become effective pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5856/c"},"text":"section 5856(c) of this title","children":[],"tail":" and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tXIII/s1351/1"},"text":"Pub. L. 113–291, div. A, title XIII, § 1351(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3606"},"text":"128 Stat. 3606","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s665"},"text":"Section 665 of title 2","children":[],"tail":", referred to in subsec. (c)(2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tX/s10118/a"},"text":"Pub. L. 105–33, title X, § 10118(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/695"},"text":"111 Stat. 695","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Balanced Budget and Emergency Deficit Control Act of 1985, referred to in subsec. (c)(2), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1038"},"text":"99 Stat. 1038","children":[],"tail":". Part C of the Act is classified generally to subchapter I (§ 900 et seq.) of chapter 20 of Title 2, The Congress. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"section 900 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id909e7ae9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id909e7aea-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Funding for Science and Technology Centers in the Former Soviet Union","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dB/tXI/s1138"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. B, title XI, § 1138]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–496, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/113/dB/s1000/a/7/dB/tXI/s1138"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For fiscal year 2001 and subsequent fiscal years, funds made available under ‘Nonproliferation, Antiterrorism, Demining, and Related Programs’ accounts in annual foreign operations appropriations Acts are authorized to be available for science and technology centers in the independent states of the former Soviet Union assisted under section 503(a)(5) of the FREEDOM Support Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5853/a/5"},"text":"22 U.S.C. 5853(a)(5)","children":[],"tail":") or section 1412(b)(5) [former "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5902/b/5"},"text":"22 U.S.C. 5902(b)(5)","children":[],"tail":"] of the Former Soviet Union Demilitarization Act of 1992 (title XIV of "},{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Public Law 102–484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5901"},"text":"22 U.S.C. 5901","children":[],"tail":" et seq.), including the use of those and other funds by any Federal agency having expertise and programs related to the activities carried out by those centers, including the Departments of Agriculture, Commerce, and Health and Human Services and the Environmental Protection Agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts made available under any provision of law for the activities described in subsection (a) shall be available until expended and may be used notwithstanding any other provision of law.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id909e7aeb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Research and Exchange Activities by Science and Technology Centers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dB/tXI/s1139"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. B, title XI, § 1139]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–496, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/113/dB/s1000/a/7/dB/tXI/s1139"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Support for science and technology centers in the independent states of the former Soviet Union, as authorized by section 503(a)(5) of the FREEDOM Support Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5853/a/5"},"text":"22 U.S.C. 5853(a)(5)","children":[],"tail":") and section 1412(b) [former "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5902/b"},"text":"22 U.S.C. 5902(b)","children":[],"tail":"] of the Former Soviet Union Demilitarization Act of 1992 (title XIV of "},{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Public Law 102–484","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5901"},"text":"22 U.S.C. 5901","children":[],"tail":" et seq.), is authorized for activities described in subsection (b) to support the redirection of former Soviet weapons scientists, especially those with expertise in weapons of mass destruction (nuclear, radiological, chemical, biological), missile and other delivery systems, and other advanced technologies with military applications."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities Supported","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities supported under subsection (a) include—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any research activity involving the participation of former Soviet weapons scientists and civilian scientists and engineers, if the participation of the weapons scientists predominates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any program of international exchanges that would provide former Soviet weapons scientists exposure to, and the opportunity to develop relations with, research and industry partners.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id909e7aec-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id909e7aed-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President under this section delegated to Secretary of Defense by section 2 of Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"1992-12-30"},"text":"Dec. 30, 1992","children":[],"tail":", 58 F.R. 3193, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5852"},"text":"section 5852 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
