{"tag":"section","attrib":{"id":"id8ff51b54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2686a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2686a"},"text":"§ 2686a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of Special Coordinator for water policy negotiations and water resources policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff51b55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2686a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall designate a Special Coordinator—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff51b56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2686a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate the United States Government response to international water resource disputes and needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51b57-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2686a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to represent the United States Government, whenever appropriate, in multilateral fora in discussions concerning access to fresh water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51b58-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2686a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to formulate United States policy to assist in the resolution of international problems posed by the lack of fresh water supplies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51b59-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2686a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The individual designated under subsection (a) may carry out the functions of subsection (a) in addition to other assigned responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff51b5a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s180"},"text":"Pub. L. 102–138, title I, § 180","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/682"},"text":"105 Stat. 682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff51b5b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff51b5c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ff51b5d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Authority of Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise provided, Secretary of State to have and exercise any authority vested by law in any official or office of Department of State and references to such officials or offices deemed to refer to Secretary of State or Department of State, as appropriate, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/s161/d"},"text":"section 161(d) of Pub. L. 103–236","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"section 2651a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
