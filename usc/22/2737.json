{"tag":"section","attrib":{"id":"id9005e397-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737"},"text":null,"children":[{"tag":"num","attrib":{"value":"2737"},"text":"§ 2737.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of State paid Student Internship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9005e398-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish the Department of State Student Internship Program (referred to in this section as the “Program”) to offer internship opportunities at the Department to eligible students to raise awareness of the essential role of diplomacy in the conduct of United States foreign policy and the realization of United States foreign policy objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e399-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e39a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An applicant is eligible to participate in the Program if the applicant is enrolled at—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9005e39b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002/a"},"text":"section 1002(a) of title 20","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e39c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education based outside the United States, as determined by the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e39d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional eligibility criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An applicant in the Program should be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9005e39e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrolled at least half-time in an institution described in paragraph (1) or have graduated from such an institution within the six months preceding application to the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e39f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible to receive and hold an appropriate security clearance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish selection criteria for students to be admitted into the Program that includes a demonstrated interest in a career in foreign affairs and gives preference as appropriate to individuals who have not previously completed internships within the Department of State and the United States Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e3a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" widely advertise the Program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9005e3a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the internet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e3a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the Department’s Diplomats in Residence program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e3a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through other outreach and recruiting initiatives targeting undergraduate and graduate students; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct targeted outreach to encourage participation in the Program from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9005e3a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals belonging to an underrepresented group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e3a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" students enrolled at minority-serving institutions (which shall include any institution listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1067q/a"},"text":"section 1067q(a) of title 20","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e3aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9005e3ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abroad","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide housing assistance to any student participating in the Program whose permanent address is within the United States if the location of the internship in which such student is participating is outside of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e3ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide housing assistance to a student participating in the Program whose permanent address is within the United States if the location of the internship in which such student is participating is more than 50 miles away from such student’s permanent address.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide a student participating in the Program whose permanent address is within the United States with financial assistance that is sufficient to cover the travel costs of a single round trip by air, train, bus, or other appropriate transportation between the student’s permanent address and the location of the internship in which such student is participating if such location is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9005e3ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 50 miles from the student’s permanent address; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e3af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outside of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working with institutions of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, to the maximum extent practicable, shall structure internships to ensure that such internships satisfy criteria for academic credit at the institutions of higher education in which participants in such internships are enrolled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e3b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraphs (2) and (3), beginning not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9005e3b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall convert unpaid internship programs of the Department, including the Foreign Service Internship Program, to internship programs that offer compensation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e3b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon selection as a candidate for entry into an internship program of the Department, a participant in such internship program may refuse compensation, including if doing so allows such participant to receive college or university curricular credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3b5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The transition required under paragraph (1) shall not apply to unpaid internship programs of the Department that are part of the Virtual Student Federal Service internship program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3b6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9005e3b7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive the requirement under paragraph (1)(A) with respect to a particular unpaid internship program if the Secretary, not later than 30 days after making a determination that the conversion of such internship program to a compensated internship program would not be consistent with effective management goals, submits a report explaining such determination to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9005e3b8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate congressional committees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9005e3b9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9005e3ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9005e3bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id9005e3bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the reasons why converting an unpaid internship program of the Department to an internship program that offers compensation would not be consistent with effective management goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9005e3bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id9005e3be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide justification for maintaining such unpaid status indefinitely; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id9005e3bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/g/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any additional authorities or resources that would be necessary to convert such unpaid internship program to offer compensation in the future.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Secretary shall submit a report to the committees referred to in subsection (g)(3)(A) that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e3c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data, to the extent the collection of such information is permissible by law, regarding the number of students who applied to the Program, were offered a position, and participated, respectively, disaggregated by race, ethnicity, sex, institution of higher education, home State, State where each student graduated from high school, and disability status;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data regarding the number of security clearance investigations initiated for the students described in paragraph (1), including the timeline for such investigations, whether such investigations were completed, and when an interim security clearance was granted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on Program expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding the Department’s compliance with subsection (g); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of internship participants subsequently employed by the Department, if any, following their participation in the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary participation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e3c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to compel any student who is a participant in an internship program of the Department to participate in the collection of the data or divulge any personal information. Such students shall be informed that their participation in the data collection under this section is voluntary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy protection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any data collected under this section shall be subject to the relevant privacy protection statutes and regulations applicable to Federal employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special hiring authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary, in consultation with the Director of the Office of Personnel Management, with respect to the number of interns to be hired each year, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9005e3ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select, appoint, and employ individuals for up to 1 year through compensated internships in the excepted service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9005e3cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove any compensated intern employed pursuant to paragraph (1) without regard to the provisions of law governing appointments in the excepted service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Work hours flexibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Students participating in the Program may work fewer than 40 hours per week and a minimum of 24 hours per week to accommodate their academic schedules, provided that the total duration of the internship remains consistent with program requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2737/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mentorship program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and Administrator are authorized to establish a mentoring and coaching program that pairs Foreign Service or Civil Service employees with interns who choose to participate throughout the duration of their internship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9005e3ce-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCII/s9201"},"text":"Pub. L. 117–263, div. I, title XCII, § 9201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3861"},"text":"136 Stat. 3861","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXI/s7105/a"},"text":"Pub. L. 118–159, div. G, title LXXI, § 7105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2524"},"text":"138 Stat. 2524","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9005e3cf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9005e3d0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9005e3d1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7105/a/1"},"text":"Pub. L. 118–159, § 7105(a)(1)","children":[],"tail":", inserted “or have graduated from such an institution within the six months preceding application to the Program” after “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7105/a/2"},"text":"Pub. L. 118–159, § 7105(a)(2)","children":[],"tail":", inserted “and gives preference as appropriate to individuals who have not previously completed internships within the Department of State and the United States Agency for International Development” after “career in foreign affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (k), (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7105/a/3"},"text":"Pub. L. 118–159, § 7105(a)(3)","children":[],"tail":", added subsecs. (k) and ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9005e3d2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id9005e3d3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary”, “Department”, “appropriate congressional committees”, and “Administrator” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s9002"},"text":"section 9002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
