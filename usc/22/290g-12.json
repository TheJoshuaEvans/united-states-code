{"tag":"section","attrib":{"id":"id8ede2ca8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–12"},"text":"§ 290g–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorization for payment of United States contribution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ede2ca9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ede2caa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–12/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Fund is authorized to contribute on behalf of the United States $150,000,000 to the Fund as the United States contribution to the third replenishment of the resources of the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ede2cab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–12/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any commitment to make the contribution authorized in paragraph (1) shall be made subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ede2cac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in this section, there are authorized to be appropriated, without fiscal year limitation, $150,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ede2cad-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s213"},"text":"Pub. L. 94–302, title II, § 213","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title X, § 1003], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1286"},"text":"97 Stat. 1286","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
