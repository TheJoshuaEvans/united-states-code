{"tag":"section","attrib":{"id":"id8ebf32fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"285dd"},"text":"§ 285dd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ninth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf32fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285dd/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank is authorized to contribute, on behalf of the United States, $461,000,000 to the ninth replenishment of the resources of the Fund, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf32fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285dd/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $461,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf32fe-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s33"},"text":"Pub. L. 89–369, § 33","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/10/dB/tXI/s2126/e"},"text":"Pub. L. 112–10, div. B, title XI, § 2126(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-04-15"},"text":"Apr. 15, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/191"},"text":"125 Stat. 191","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
