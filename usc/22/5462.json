{"tag":"section","attrib":{"id":"id908db233-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5462"},"text":null,"children":[{"tag":"num","attrib":{"value":"5462"},"text":"§ 5462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SEED Information Center System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908db234-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5462/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish a SEED Information Center System, using existing Executive branch agencies and acting in cooperation with the Government of Poland and the Government of Hungary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db235-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5462/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db236-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5462/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The SEED Information Center System shall serve as a central clearinghouse mechanism for information relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id908db237-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5462/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business needs and opportunities in Eastern Europe, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908db238-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5462/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntary assistance to countries in Eastern Europe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db239-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5462/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private enterprise development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The SEED Information Center System shall be organized, among other purposes, to encourage—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id908db23a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5462/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the submission of economically sound proposals to the Polish-American Enterprise Fund and Hungarian-American Enterprise Fund, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908db23b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5462/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other sources of finance for the development of private enterprise in Eastern Europe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db23c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5462/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The SEED Information Center System shall be based jointly in Washington, District of Columbia; Warsaw, Poland; and Budapest, Hungary; and should it become appropriate, the capitals of other East European countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908db23d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tVI/s602"},"text":"Pub. L. 101–179, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1319"},"text":"103 Stat. 1319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id908db23e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id908db23f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id908db240-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section delegated to Secretary of Commerce by section 3 of Ex. Ord. No. 12703, ","children":[{"tag":"date","attrib":{"date":"1990-02-20"},"text":"Feb. 20, 1990","children":[],"tail":", 55 F.R. 6351, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5401"},"text":"section 5401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
