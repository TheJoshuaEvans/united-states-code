{"tag":"section","attrib":{"id":"id9102935c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b"},"text":null,"children":[{"tag":"num","attrib":{"value":"8513b"},"text":"§ 8513b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of, and reports on, mandatory sanctions with respect to financial institutions that engage in certain activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9102935d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", the Secretary of the Treasury shall revise the regulations prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513/c/1"},"text":"section 8513(c)(1) of this title","children":[],"tail":" to apply to a foreign financial institution described in subsection (b) to the same extent and in the same manner as those regulations apply to a foreign financial institution that the Secretary of the Treasury finds knowingly engages in an activity described in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513/c/2"},"text":"section 8513(c)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9102935e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign financial institutions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A foreign financial institution described in this subsection is a foreign financial institution, including an Iranian financial institution, that the Secretary of the Treasury finds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9102935f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly facilitates, or participates or assists in, an activity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513/c/2"},"text":"section 8513(c)(2) of this title","children":[],"tail":", including by acting on behalf of, at the direction of, or as an intermediary for, or otherwise assisting, another person with respect to the activity;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91029360-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attempts or conspires to facilitate or participate in such an activity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91029361-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned or controlled by a foreign financial institution that the Secretary finds knowingly engages in such an activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91029362-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91029363-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2012-08-10"},"text":"August 10, 2012","children":[],"tail":", and every 180 days thereafter, the Secretary of the Treasury shall submit to the appropriate congressional committees a report that contains a detailed description of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91029364-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of the regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513/c/1"},"text":"section 8513(c)(1) of this title","children":[],"tail":" on the financial system and economy of Iran and capital flows to and from Iran; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91029365-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ways in which funds move into and out of financial institutions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513/c/2/E/ii"},"text":"section 8513(c)(2)(E)(ii) of this title","children":[],"tail":", with specific attention to the use of other Iranian financial institutions and other foreign financial institutions to receive and transfer funds for financial institutions described in that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91029366-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report submitted under paragraph (1) shall be submitted in unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91029367-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91029368-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “financial institution” means a financial institution specified in subparagraph (A), (B), (C), (D), (E), (F), (G), (H), (I), (J), (K), (M), (N), (R), or (Z) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5312/a/2"},"text":"section 5312(a)(2) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91029369-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign financial institution” has the meaning of that term as determined by the Secretary of the Treasury pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8513/i"},"text":"section 8513(i) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9102936a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Iranian financial institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Iranian financial institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9102936b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial institution organized under the laws of Iran or any jurisdiction within Iran, including a foreign branch of such an institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9102936c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial institution located in Iran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9102936d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial institution, wherever located, owned or controlled by the Government of Iran; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9102936e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8513b/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial institution, wherever located, owned or controlled by a financial institution described in subparagraph (A), (B), or (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9102936f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tI/s104A"},"text":"Pub. L. 111–195, title I, § 104A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/158/tII/s216/a"},"text":"Pub. L. 112–158, title II, § 216(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1232"},"text":"126 Stat. 1232","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dF/tLXI/s6110/e/1/B"},"text":"Pub. L. 116–283, div. F, title LXI, § 6110(e)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4563"},"text":"134 Stat. 4563","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91029370-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91029371-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id91029372-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “(Z)” for “(Y)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
