{"tag":"section","attrib":{"id":"id8fa68631-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2378a"},"text":"§ 2378a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Depleted uranium ammunition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fa68632-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), none of the funds made available to carry out this chapter or any other Act may be made available to facilitate in any way the sale of M–833 antitank shells or any comparable antitank shells containing a depleted uranium penetrating component to any country other than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fa68633-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a country that is a member of the North Atlantic Treaty Organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa68634-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a country that has been designated as a major non-NATO ally (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2403/q"},"text":"section 2403(q) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fa68635-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Taiwan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fa68636-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2378a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibition contained in subsection (a) shall not apply with respect to the use of funds to facilitate the sale of antitank shells to a country if the President determines that to do so is in the national security interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fa68637-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 620J, formerly § 620G, as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/164/tI/s149"},"text":"Pub. L. 104–164, title I, § 149","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-21"},"text":"July 21, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1436"},"text":"110 Stat. 1436","children":[],"tail":"; renumbered § 620J, "},{"tag":"ref","attrib":{"href":"/us/pl/109/446/s2/b/1"},"text":"Pub. L. 109–446, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-21"},"text":"Dec. 21, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3318"},"text":"120 Stat. 3318","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fa68638-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fa68639-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"h