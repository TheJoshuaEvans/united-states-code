{"tag":"section","attrib":{"id":"id90ef80a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7833"},"text":null,"children":[{"tag":"num","attrib":{"value":"7833"},"text":"§ 7833.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance provided outside of North Korea","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ef80a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7833/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to provide assistance to support organizations or persons that provide humanitarian assistance to North Koreans who are outside of North Korea without the permission of the Government of North Korea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef80a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7833/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance provided under subsection (a) should be used to provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ef80a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7833/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" humanitarian assistance to North Korean refugees, defectors, migrants, and orphans outside of North Korea, which may include support for refugee camps or temporary settlements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef80a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7833/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" humanitarian assistance to North Korean women outside of North Korea who are victims of trafficking, as defined in section 7102(15) ","children":[{"tag":"ref","attrib":{"idref":"fn002393"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002393"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, or are in danger of being trafficked."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef80a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7833/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ef80a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7833/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to funds otherwise available for such purposes, there are authorized to be appropriated to the President $5,000,000 for each of the fiscal years 2018 through 2022 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f1a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7833/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to the authorization of appropriations under paragraph (1) are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f1f1a8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/333/tII/s203"},"text":"Pub. L. 108–333, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1294"},"text":"118 Stat. 1294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/346/s10"},"text":"Pub. L. 110–346, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-07"},"text":"Oct. 7, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3942"},"text":"122 Stat. 3942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/172/s9"},"text":"Pub. L. 112–172, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-16"},"text":"Aug. 16, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1309"},"text":"126 Stat. 1309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/4/tXII/s1212/b/2/B"},"text":"Pub. L. 113–4, title XII, § 1212(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-07"},"text":"Mar. 7, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/144"},"text":"127 Stat. 144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/198/s7/e"},"text":"Pub. L. 115–198, § 7(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-20"},"text":"July 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1524"},"text":"132 Stat. 1524","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90f1f1a9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","