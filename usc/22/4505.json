{"tag":"section","attrib":{"id":"id907a9eef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4505"},"text":null,"children":[{"tag":"num","attrib":{"value":"4505"},"text":"§ 4505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications; payments to eligible institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id907a9ef0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any institution seeking funding under this chapter shall prepare and submit an application to the Secretary of State once each fiscal year. Each such application shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id907a9ef1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a description of the purposes for which the payments will be used in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4504"},"text":"section 4504 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907a9ef2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such fiscal control and such accounting procedures as may be necessary (A) to ensure a proper accounting of Federal funds paid under this chapter, and (B) to ensure the verification of the costs of the continuing education and research programs conducted under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907a9ef3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments under this chapter may be made in installments, in advance, or by way of reimbursement, with necessary adjustments on account of overpayments and underpayments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907a9ef4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/tVIII/s806"},"text":"Pub. L. 98–164, title VIII, § 806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-22"},"text":"Nov. 22, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1050"},"text":"97 Stat. 1050","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
