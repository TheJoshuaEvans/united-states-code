{"tag":"section","attrib":{"id":"id9056ea52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4010a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4010a"},"text":"§ 4010a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reductions in force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9056ea53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4010a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization and regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may conduct reductions in force and shall prescribe regulations for the separation of members of the Service holding a career or career candidate appointment under subchapter III of this chapter, under such reductions in force which give due effect to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9056ea54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4010a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Organizational changes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9056ea55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4010a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Documented employee knowledge, skills, or competencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9056ea56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4010a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tenure of employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9056ea57-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4010a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Documented employee performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9056ea58-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4010a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military preference, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3501/a/3"},"text":"section 3501(a)(3) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9056ea59-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4010a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of retirement benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4009"},"text":"section 4009 of this title","children":[],"tail":" shall be applicable to any member of the Service holding a career or career candidate appointment under subchapter III of this chapter, who is separated under the provisions of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9056ea5a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4010a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grievance procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employee against whom action is taken under this section may elect either to file a grievance under subchapter XI or to appeal to the Merit Systems Protection Board under procedures prescribed by the Board. Grievances under subchapter XI shall be limited to cases of reprisal, interference in the conduct of an employee’s official duties, or similarly inappropriate use of the authority of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9056ea5b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s611"},"text":"Pub. L. 96–465, title I, § 611","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s181/a/2"},"text":"Pub. L. 103–236, title I, § 181(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/417"},"text":"108 Stat. 417","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/ii"},"text":"Pub. L. 103–415, § 1(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4303"},"text":"108 Stat. 4303","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9056ea5c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9056ea5d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id9056ea5e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/s611"},"text":"section 611 of Pub. L. 96–465","children":[],"tail":" was renumbered section 612 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4011"},"text":"section 4011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9056ea5f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/415"},"text":"Pub. L. 103–415","children":[],"tail":" made technical amendment relating to style of section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9056ea60-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9056ea61-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Notification of Intent To Reduce Personnel at Covered Diplomatic Posts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tI/s5177"},"text":"Pub. L. 119–60, div. E, title I, § 5177","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1590"},"text":"139 Stat. 1590","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dE/tI/s5177"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), not later than 30 days before the date on which the Secretary [of State] carries out a reduction in United States Foreign Service personnel of at least 10 percent at a covered diplomatic post, the Secretary shall submit to the appropriate congressional committees a notification of the intent to carry out such a reduction, which shall include a certification by the Secretary that such reduction will not negatively impact the ability of the United States to compete with the People’s Republic of China, the Islamic Republic of Iran, or the Russian Federation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not apply in the case of a security risk to personnel at a covered diplomatic post.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term ‘appropriate congressional committees’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘covered diplomatic post’ means a United States diplomatic post in a country in which the People’s Republic of China, the Islamic Republic of Iran, or the Russian Federation also have a diplomatic post.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9056ea62-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Employment Assistance Referral System for Certain Members of Foreign Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s179"},"text":"Pub. L. 103–236, title I, § 179","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/415"},"text":"108 Stat. 415","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/g"},"text":"Pub. L. 103–415, § 1(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4300"},"text":"108 Stat. 4300","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/415/s1/g"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Referral System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Certain members of the Foreign Service (as described in subsection (b)), may participate in the Office of Personnel Management’s Interagency Placement programs or any successor program. Such members of the Foreign Service shall be treated in the same manner as employees participating in such a program as of the effective date of this Act [","children":[{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Members of the Foreign Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term ‘members of the Foreign Service’ means any individuals holding career or career candidate appointments under chapter 3 of the Foreign Service Act of 1980 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3941"},"text":"22 U.S.C. 3941","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9056ea63-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Consultation With Director of Office of Personnel Management Prior to Prescribing Regulations for Reductions in Force","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s181/c"},"text":"Pub. L. 103–236, title I, § 181(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/418"},"text":"108 Stat. 418","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/415/s1/i"},"text":"Pub. L. 103–415, § 1(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-25"},"text":"Oct. 25, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4301"},"text":"108 Stat. 4301","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/415/s1/i"},"text":"“The Secretary of State (or in the case of any other agency authorized by law to utilize the Foreign Service personnel system, the head of that agency) shall consult with the Director of the Office of Personnel Management before prescribing regulations for reductions in force under section 611 of the Foreign Service Act of 1980 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4010a"},"text":"22 U.S.C. 4010a","children":[],"tail":"] (as added by subsection (a) of this section), and shall publish such regulations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
