{"tag":"section","attrib":{"id":"id90357fa1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3353"},"text":null,"children":[{"tag":"num","attrib":{"value":"3353"},"text":"§ 3353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International military education and training cooperation with Taiwan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90357fa2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State and the Secretary of Defense shall establish or expand a comprehensive training program with Taiwan designed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90357fa3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3353/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance interoperability and capabilities for joint operations between the United States and Taiwan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90357fa4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3353/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance rapport and deepen partnership between the militaries of the United States and Taiwan, and foster understanding of the United States among individuals in Taiwan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90357fa5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3353/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve Taiwan’s defense capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90357fa6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3353/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train future leaders of Taiwan, promote professional military education, civilian control of the military, and protection of human rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90357fa7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The training program required by subsection (a) should prioritize relevant and realistic training, including as necessary joint United States-Taiwan contingency tabletop exercises, war games, full-scale military exercises, and an enduring rotational United States military presence that assists Taiwan in maintaining force readiness and utilizing United States defense articles and services transferred from the United States to Taiwan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90357fa8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of participation of Taiwan in the International Military Education and Training program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State is authorized to provide training and education to relevant entities in Taiwan through the International Military Education and Training program authorized under chapter 5 of part II of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2347"},"text":"22 U.S.C. 2347","children":[],"tail":" et seq)."},{"tag":"ref","attrib":{"idref":"fn002254"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002254"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “seq.).”"}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90357fa9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5504"},"text":"Pub. L. 117–263, div. E, title LV, § 5504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3298"},"text":"136 Stat. 3298","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90357faa-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90357fab-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90357fac-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Chapter 5 of part II of the Act is classified generally to part V (§ 2347 et seq.) of subchapter II of chapter 32 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
