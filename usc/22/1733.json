{"tag":"section","attrib":{"id":"id8f19d592-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733"},"text":null,"children":[{"tag":"num","attrib":{"value":"1733"},"text":"§ 1733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Hostage Recovery Coordinator","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f19d593-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency Hostage Recovery Coordinator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f19d594-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2015-11-25"},"text":"November 25, 2015","children":[],"tail":", the President shall designate an existing Federal official to coordinate efforts to secure the release of United States persons who are hostages held abroad. For purposes of carrying out the duties described in paragraph (2), such official shall have the title of “Interagency Hostage Recovery Coordinator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f19d595-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coordinator shall have the following duties:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f19d596-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate activities of the Federal Government relating to each hostage situation described in paragraph (1) to ensure efforts to secure the release of hostages are properly resourced and correct lines of authority are established and maintained.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f19d597-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chair a fusion cell consisting of appropriate personnel of the Federal Government with purview over each hostage situation described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f19d598-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensure sufficient representation of each Federal agency and department at each fusion cell established under subparagraph (B) and issue procedures for adjudication and appeal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f19d599-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop processes and procedures to keep family members of hostages described in paragraph (1) informed of the status of such hostages, inform such family members of updates that do not compromise the national security of the United States, and coordinate with the Federal Government’s family engagement coordinator or other designated senior representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f19d59a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly report and briefing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f19d59b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f19d59c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On a quarterly basis, the Coordinator shall submit to the appropriate congressional committees a report that includes a summary of each hostage situation described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f19d59d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report under this ","children":[{"tag":"ref","attrib":{"idref":"fn002075"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002075"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “this” probably should not appear."}],"tail":" subparagraph (A) may be submitted in classified or unclassified form."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f19d59e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On a quarterly basis, the Coordinator shall provide to the Senators representing the State, and the Member, Delegate, or Resident Commissioner of the House of Representatives representing the district, where a hostage described in subsection (a)(1) resides a briefing with respect to the status of such hostage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f19d59f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f19d5a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on the Judiciary, the Permanent Select Committee on Intelligence, and the Committee on Foreign Affairs of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f19d5a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1733/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services, the Committee on the Judiciary, the Select Committee on Intelligence, and the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f19d5a2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1092"},"text":"Pub. L. 114–92, div. A, title X, § 1092","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1018"},"text":"129 Stat. 1018","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
