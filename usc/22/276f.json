{"tag":"section","attrib":{"id":"id8eac1fe5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276f"},"text":null,"children":[{"tag":"num","attrib":{"value":"276f"},"text":"§ 276f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States group of the Canada-United States Interparliamentary group shall submit to the Congress a report for each fiscal year for which an appropriation is made including its expenditures under such appropriation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eac1fe6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/42/s3"},"text":"Pub. L. 86–42, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-06-11"},"text":"June 11, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/73"},"text":"73 Stat. 73","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
