{"tag":"section","attrib":{"id":"id8e811870-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a"},"text":null,"children":[{"tag":"num","attrib":{"value":"212a"},"text":"§ 212a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction of passports for sex tourism","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e811871-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Following any conviction of an individual for a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2423"},"text":"section 2423 of title 18","children":[],"tail":", the Attorney General shall notify in a timely manner—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e811872-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State for appropriate action under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e811873-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Homeland Security for appropriate action under the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e811874-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to restrict passport","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e811875-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility for passport","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e811876-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall not issue a passport or passport card to an individual who is convicted of a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2423"},"text":"section 2423 of title 18","children":[],"tail":" during the covered period if the individual used a passport or passport card or otherwise crossed an international border in committing the offense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e811877-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Passport revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall revoke a passport or passport card previously issued to an individual described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e811878-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e811879-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency and humanitarian situations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), the Secretary of State may issue a passport or passport card, in emergency circumstances or for humanitarian reasons, to an individual described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e81187a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation for return to United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), the Secretary of State may, prior to revocation, limit a previously issued passport or passport card only for return travel to the United States, or may issue a limited passport or passport card that only permits return travel to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e81187b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e81187c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered period” means the period beginning on the date on which an individual is convicted of a violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2423"},"text":"section 2423 of title 18","children":[],"tail":" and ending on the later of—"}],"tail":null},{"tag":"clause","attrib":{"id":"id8e81187d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the individual is released from a sentence of imprisonment relating to the offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8e81187e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the end of a period of parole or other supervised release of the covered individual relating to the offense; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e81187f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s212a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “imprisonment” means being confined in or otherwise restricted to a jail, prison, half-way house, treatment facility, or another institution, on a full or part-time basis, pursuant to the sentence imposed as the result of a criminal conviction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e811880-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/457/tII/s236"},"text":"Pub. L. 110–457, title II, § 236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-12-23"},"text":"Dec. 23, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/5082"},"text":"122 Stat. 5082","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e811881-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e811882-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8e811883-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of Title 8, Aliens and Nationality. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
