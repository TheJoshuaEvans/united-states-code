{"tag":"section","attrib":{"id":"id8fab40cc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2381a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2381a"},"text":"§ 2381a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strengthened management practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fab40cd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2381a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of beliefs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress believes that United States foreign aid funds could be utilized more effectively by the application of advanced management decisionmaking, information and analysis techniques such as systems analysis, automatic data processing, benefit-cost studies, and information retrieval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fab40ce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2381a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management system; establishment; scope","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To meet this need, the President shall establish a management system that includes: the definition of objectives and programs for United States foreign assistance; the development of quantitative indicators of progress toward these objectives; the orderly consideration of alternative means for accomplishing such objectives; and the adoption of methods for comparing actual results of programs and projects with those anticipated when they were undertaken. The system should provide information to the agency and to Congress that relates agency resources, expenditures, and budget projections to such objectives and results in order to assist in the evaluation of program performance, the review of budgetary requests, and the setting of program priorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fab40cf-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 621A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/554"},"text":"Pub. L. 90–554","children":[],"tail":", pt. III, § 302(b), "},{"tag":"date","attrib":{"date":"1968-10-08"},"text":"Oct. 8, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/964"},"text":"82 Stat. 964","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/tV/s502/d/1"},"text":"Pub. L. 95–424, title V, § 502(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/959"},"text":"92 Stat. 959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fab40d0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fab40d1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fab40d2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" struck out subsec. (c) relating to annual reports to Congress by the President evaluating the progress made toward implementation of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fab40d3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8fab40d4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/s605"},"text":"section 605 of Pub. L. 95–424","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8fab40d5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8fab40d6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":