{"tag":"section","attrib":{"id":"id9147b221-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634"},"text":null,"children":[{"tag":"num","attrib":{"value":"9634"},"text":"§ 9634.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporate funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9147b222-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporate Capital Account","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Treasury of the United States a fund to be known as the “Corporate Capital Account” to carry out the purposes of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b223-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporate Capital Account shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b224-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fees charged and collected pursuant to subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b225-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amounts received pursuant to subsection (e);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b226-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investments and returns on such investments pursuant to subsection (g);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b227-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unexpended balances transferred to the Corporation pursuant to subsection (i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b228-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments received in connection with settlements of all insurance and reinsurance claims of the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b229-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other collections transferred to or earned by the Corporation, excluding the cost, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":", of loans and loan guaranties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b22a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fee authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees may be charged and collected for providing services in amounts to be determined by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b22b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b22c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to Acts making appropriations, the Corporation is authorized to pay—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9147b22d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":", of loans and loan guaranties;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b22e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative expenses of the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b22f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the cost of providing support authorized by subsections (c), (e), (f), and (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9621"},"text":"section 9621 of this title","children":[],"tail":"; "},{"tag":"ref","attrib":{"idref":"fn002458"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002458"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b230-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project-specific transaction costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b231-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Income and revenue","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to carry out the purposes of the Corporation, all collections transferred to or earned by the Corporation, excluding the cost, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":", of loans and loan guaranties, shall be deposited into the Corporate Capital Account and shall be available to carry out its purpose, including without limitation—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9147b232-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of all insurance and reinsurance claims of the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b233-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repayments to the Treasury of amounts borrowed under subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b234-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dividend payments to the Treasury under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b235-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b236-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All support provided pursuant to predecessor authorities or subchapter II of this chapter shall continue to constitute obligations of the United States, and the full faith and credit of the United States is hereby pledged for the full payment and performance of such obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b237-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to borrow","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation is authorized to borrow from the Treasury such sums as may be necessary to fulfill such obligations of the United States and any such borrowing shall be at a rate determined by the Secretary of the Treasury, taking into consideration the current average market yields on outstanding marketable obligations of the United States of comparable maturities, for a period jointly determined by the Corporation and the Secretary, and subject to such terms and conditions as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b238-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dividends","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board, in consultation with the Director of the Office of Management and Budget, shall annually assess a dividend payment to the Treasury if the Corporation’s insurance portfolio is more than 100 percent reserved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b239-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b23a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation may request the Secretary of the Treasury to invest such portion of the Corporate Capital Account as is not, in the Corporation’s judgment, required to meet the current needs of the Corporate Capital Account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b23b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of investments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such investments shall be made by the Secretary of the Treasury in public debt obligations, with maturities suitable to the needs of the Corporate Capital Account, as determined by the Corporation, and bearing interest at rates determined by the Secretary, taking into consideration current market yields on outstanding marketable obligations of the United States of comparable maturities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b23c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Interest earnings made pursuant to subsection (g), earnings collected related to equity investments, and amounts, excluding fees related to insurance or reinsurance, collected pursuant to subsection (c), shall not be collected for any fiscal year except to the extent provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b23d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer from predecessor agencies and programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"By the end of the transition period described in subchapter VI of this chapter, the unexpended balances, assets, and responsibilities of any agency specified in the plan required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9682"},"text":"section 9682 of this title","children":[],"tail":" shall be transferred to the Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b23e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to carry out this chapter, funds authorized to be appropriated to carry out the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.) may be transferred to the Corporation and funds authorized to be appropriated to the Corporation may be transferred to the Department of State and the United States Agency for International Development."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b23f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “project-specific transaction costs”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b240-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means those costs incurred by the Corporation for travel, legal expenses, and direct and indirect costs incurred in claims settlements associated with the provision of support under subchapter II of this chapter and shall not be considered administrative expenses for the purposes of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b241-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9634/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include information technology (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11101"},"text":"section 11101 of title 40","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9147b242-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tIII/s1434"},"text":"Pub. L. 115–254, div. F, title III, § 1434","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3501"},"text":"132 Stat. 3501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9147b243-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9147b244-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9147b245-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter VI of this chapter, referred to in subsec. (i), was in the original “title VI”, meaning title VI (§§ 1461–1470) of div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3510"},"text":"132 Stat. 3510","children":[],"tail":", which is classified principally to subchapter VI of this chapter and which repealed title IV of chapter 2 of part I of the Foreign Assistance Act of 1961 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2191"},"text":"22 U.S.C. 2191","children":[],"tail":" et seq.), other than subsections (g), ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), (m), and (n) of section 237 thereof ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2197/g"},"text":"22 U.S.C. 2197(g)","children":[],"tail":", ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), (m), (n)), among other amendments. For complete classification of title VI to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (j), was in the original “this division”, meaning division F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3485"},"text":"132 Stat. 3485","children":[],"tail":", which is classified principally to this chapter. For complete classification of division F to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9601"},"text":"section 9601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (j), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9147b246-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9147b247-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization for Collections","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dG/tVI"},"text":"Pub. L. 116–94, div. G, title VI","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2841"},"text":"133 Stat. 2841","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dG/tVI"},"text":"“That in this fiscal year, and each fiscal year thereafter, the Corporation shall collect the amounts described in section 1434(h) of the BUILD Act of 2018 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9634/h"},"text":"22 U.S.C. 9634(h)","children":[],"tail":"]”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
