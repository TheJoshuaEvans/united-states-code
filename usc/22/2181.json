"},{"tag":"ref","attrib":{"href":"/us/stat/81/450"},"text":"81 Stat. 450","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/554"},"text":"Pub. L. 90–554","children":[],"tail":", pt. I, § 103, "},{"tag":"date","attrib":{"date":"1968-10-08"},"text":"Oct. 8, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/960"},"text":"82 Stat. 960","children":[],"tail":", related to general authority for foreign investment guaranties by the President, prior to the general reorganization of this subpart by "},{"tag":"ref","attrib":{"href":"/us/pl/91/175"},"text":"Pub. L. 91–175","children":[],"tail":", pt. I, § 105, "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/807"},"text":"83 Stat. 807","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f613f49-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" substituted “, including essential urban development services, is” for “requirements are” after “The Congress recognizes that shelter” and, in the remainder of the section substituted “shelter” for “housing” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" generally revised the statement of policy to clarify that in developing countries, financing, materials and labor for most housing must be obtained from local sources, while United States capital and technical expertise can increase the availability of housing and related services for low-income people by demonstrating financial viability of credit systems for low-cost housing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88"},"text":"Pub. L. 95–88","children":[],"tail":" struck out provisions that the total face amount of guaranties issued under this section outstanding at any one time not exceed $430,000,000 and added "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2182/c"},"text":"section 2182(c) of this title","children":[],"tail":" to the enumeration of sections setting out the conditions under which guaranties shall be issued."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/161"},"text":"Pub. L. 94–161","children":[],"tail":" substituted “$430,000,000” for “$355,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/559"},"text":"Pub. L. 93–559","children":[],"tail":" substituted “$355,000,000” for “$305,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/189"},"text":"Pub. L. 93–189","children":[],"tail":" substituted “$305,000,000” for “$205,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226"},"text":"Pub. L. 92–226","children":[],"tail":" substituted “$205,000,000” for “$130,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f613f4a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f613f4b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/424/s605"},"text":"section 605 of Pub. L. 95–424","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f613f4c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Funds From Sale of Notes for Discharge of Liabilities Under Guaranties; Transfer of Funds and Cancellation of Notes and Interest","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/249/tI/s120"},"text":"Pub. L. 90–249, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-01-02"},"text":"Jan. 2, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/941"},"text":"81 Stat. 941","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/249/tI/s120"},"text":"“Hereafter, none of the funds obtained or authorized to be obtained from the sale of notes under authority of paragraph 111(c)(2) of the Economic Cooperation Act of 1948 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1509/c/2"},"text":"section 1509(c)(2) of this title","children":[],"tail":"] or paragraph 413(b)(4)(F) of the Mutual Security Act of 1954 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1933/b/4/F"},"text":"section 1933(b)(4)(F) of this title","children":[],"tail":"] may be used for the purposes of discharging liabilities under any guaranties (exclusive of informational media guaranties) issued under sections 221(b) and 224 of the Foreign Assistance Act of 1961 [subsec. (b) of this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2184"},"text":"section 2184 of this title","children":[],"tail":"], sections 202(b) and 413(b)(4) of the Mutual Security Act of 1954 [sections 1872(b) and 1933(b)(4) of this title] and section 111(b)(3) of the Economic Cooperation Act of 1948 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1509/b/3"},"text":"section 1509(b)(3) of this title","children":[],"tail":"]. Any portion of the funds in the reserve established pursuant to section 222(e) of the Foreign Assistance Act of 1961 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2182/e"},"text":"section 2182(e) of this title","children":[],"tail":"] which are attributable to the funds realized from the sale of notes specified in the preceding sentence shall be transferred to the general fund of the Treasury. The Secretary of the Treasury shall cancel all such notes and sums owing and unpaid thereon, including interest to date of cancellation.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
