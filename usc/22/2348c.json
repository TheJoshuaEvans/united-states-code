{"tag":"section","attrib":{"id":"id8f95bc78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2348c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2348c"},"text":"§ 2348c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except where expressly provided to the contrary, any reference in any law to subchapter I of this chapter shall be deemed to include reference to this part and any reference in any law to subchapter II of this chapter shall be deemed to exclude reference to this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f95bc79-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 553, formerly § 554, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/384/s12/a"},"text":"Pub. L. 95–384, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-26"},"text":"Sept. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/737"},"text":"92 Stat. 737","children":[],"tail":"; renumbered § 553, "},{"tag":"ref","attrib":{"href":"/us/pl/96/533/tI/s116/b"},"text":"Pub. L. 96–533, title I, § 116(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3140"},"text":"94 Stat. 3140","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f95bc7a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f95bc7b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f95bc7c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Subchapter I Deemed To Include Certain Parts of Subchapter II, and References to Subchapter II Deemed To Exclude Such Parts","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to subchapter I of this chapter are deemed to include parts IV (§ 2346 et seq.) and VIII (§ 2349aa et seq.) of subchapter II of this chapter, and references to subchapter II are deemed to exclude such parts. See ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226/s202/b"},"text":"section 202(b) of Pub. L. 92–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"section 2346 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349aa–5"},"text":"section 2349aa–5 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
