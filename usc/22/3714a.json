{"tag":"section","attrib":{"id":"id9043d7fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3714a"},"text":"§ 3714a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissolution of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9043d7fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9043d7ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commission shall conduct a study of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9043d800-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs associated with the dissolution of the Commission, including the composition, location, and costs of the office authorized to be established under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9043d801-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs and liabilities incurred or administered by the Commission that will not be paid before the date of that dissolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d802-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall submit to the Congress, by not later than ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", a report on the findings and conclusions of the study under this subsection. The report shall include an estimate of the period of time which may be required to close out the affairs of the Commission after the termination of the Panama Canal Treaty of 1977."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9043d803-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall during fiscal year 1998 establish an office to close out the affairs of the Commission that are still pending after the termination of the Panama Canal Treaty of 1977.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9043d804-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Panama Canal Commission Dissolution Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9043d805-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Treasury of the United States a fund to be known as the “Panama Canal Commission Dissolution Fund” (hereinafter in this section referred to as the “Fund”). The Fund shall be managed by the Commission until the termination of the Panama Canal Treaty of 1977 and by the office established under subsection (b) thereafter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d806-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9043d807-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (5), the Fund shall be available after ","children":[{"tag":"date","attrib":{"date":"1998-09-30"},"text":"September 30, 1998","children":[],"tail":", to pay—"}],"tail":null},{"tag":"clause","attrib":{"id":"id9043d808-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of operating the office established under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9043d809-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs and liabilities associated with dissolution of the Commission, including such costs incurred or identified after the termination of the Panama Canal Treaty of 1977.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9043d80a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments from the Fund made during the period beginning on ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":", and ending with the termination of the Panama Canal Treaty of 1977 shall be subject to the approval of the Board provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3612"},"text":"section 3612 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d80b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Fund shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9043d80c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such amounts as may be deposited into the Fund by the Commission, from amounts collected as toll receipts, to pay the costs described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9043d80d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts credited to the Fund under paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d80e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9043d80f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall invest excess amounts in the Fund in public debt securities with maturities suitable to the needs of the Fund, as determined by the manager of the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9043d810-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Securities invested under subparagraph (A) shall bear interest at rates determined by the Secretary of the Treasury, taking into consideration current market yields on outstanding marketable obligations of the United States of comparable maturity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9043d811-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest earned on securities invested under subparagraph (A) shall be credited to and form part of the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d812-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9043d813-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the Fund may not be obligated or expended in any fiscal year unless the obligation or expenditure is specifically authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9043d814-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The office established by subsection (b) is authorized to expend or obligate funds from the Fund for the purposes enumerated in clauses (i) and (ii) of paragraph (2)(A) until ","children":[{"tag":"date","attrib":{"date":"2004-10-01"},"text":"October 1, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9043d815-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3714a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Fund shall terminate on ","children":[{"tag":"date","attrib":{"date":"2004-10-01"},"text":"October 1, 2004","children":[],"tail":". Amounts in the Fund on that date shall be deposited in the general fund of the Treasury of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9043d816-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1305"},"text":"Pub. L. 96–70, title I, § 1305","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dC/tXXXV/s3521/a"},"text":"Pub. L. 102–484, div. C, title XXXV, § 3521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2656"},"text":"106 Stat. 2656","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXV/s3504/a"},"text":"Pub. L. 106–65, div. C, title XXXV, § 3504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/975"},"text":"113 Stat. 975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9043d817-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9043d818-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9043d819-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9043d81a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9043d81b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Operation of Office of Transition Administration and Oversight of Close-Out Activities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/dC/tXXXV/s3504/b"},"text":"Pub. L. 106–65, div. C, title XXXV, § 3504(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/975"},"text":"113 Stat. 975","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/65/dC/tXXXV/s3504/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation of the Office of Transition Administration.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Panama Canal Act of 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"22 U.S.C. 3601","children":[],"tail":" et seq.) shall continue to govern the Office of Transition Administration until "},{"tag":"date","attrib":{"date":"2004-10-01"},"text":"October 1, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procurement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of exercising authority under the procurement laws of the United States, the director of the Office of Transition Administration shall have the status of the head of an agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of Transition Administration shall have offices in the Republic of Panama and in the District of Columbia. Section 1110(b)(1) of the Panama Canal Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3620/b/1"},"text":"22 U.S.C. 3620(b)(1)","children":[],"tail":") does not apply to such office in the Republic of Panama."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Office of transition administration defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection the term ‘Office of Transition Administration’ means the office established under section 1305 of the Panama Canal Act of 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3714a"},"text":"22 U.S.C. 3714a","children":[],"tail":") to close out the affairs of the Panama Canal Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall be effective on and after the termination of the Panama Canal Treaty of 1977.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight of Close-Out Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Panama Canal Commission shall enter into an agreement with the head of a department or agency of the Federal Government to supervise the close out of the affairs of the Commission under section 1305 of the Panama Canal Act of 1979 and to certify the completion of that function.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
