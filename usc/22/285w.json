{"tag":"section","attrib":{"id":"id8ebf32c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285w"},"text":null,"children":[{"tag":"num","attrib":{"value":"285w"},"text":"§ 285w.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution to Asian Development Fund; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf32c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285w/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank is authorized to contribute on behalf of the United States $66,750,000 to the Asian Development Fund, a special fund of the Bank: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That any commitment to make such contribution shall be made subject to obtaining the necessary appropriations."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf32c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285w/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution to the Asian Development Fund provided for in this section, there is authorized to be appropriated, without fiscal year limitation, $66,750,000 for payment by the Secretary of the Treasury: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That no funds may be made available for such contribution for the fiscal year 1982."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf32c9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s26"},"text":"Pub. L. 89–369, § 26","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXIII/s1352/a"},"text":"Pub. L. 97–35, title XIII, § 1352(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/744"},"text":"95 Stat. 744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ebf32ca-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ebf32cb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8ebf32cc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", except that any funds authorized to be appropriated shall not be available for use or obligation prior to "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1372"},"text":"section 1372 of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s290i"},"text":"section 290i of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
