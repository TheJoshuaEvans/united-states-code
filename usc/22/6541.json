{"tag":"section","attrib":{"id":"id90bd74ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6541"},"text":null,"children":[{"tag":"num","attrib":{"value":"6541"},"text":"§ 6541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and declaration of purpose","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bd74f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6541/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is the policy of the United States to promote the right of freedom of opinion and expression, including the freedom “to seek, receive, and impart information and ideas through any media and regardless of frontiers”, in accordance with Article 19 of the Universal Declaration of Human Rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd74f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6541/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" open communication of information and ideas among the peoples of the world contributes to international peace and stability, and the promotion of such communication is in the interests of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd74f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6541/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the interest of the United States to support broadcasting to other nations consistent with the requirements of this part and the United States International Broadcasting Act of 1994 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6201"},"text":"22 U.S.C. 6201","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bd74f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6541/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international broadcasting is, and should remain, an essential instrument of United States foreign policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90bd74f4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1321, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-777"},"text":"112 Stat. 2681–777","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90bd74f5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90bd74f6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90bd74f7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This part, referred to in par. (3), was in the original “this chapter”, meaning chapter 3 (§§ 1321–1328) of title XIII of subdiv. A of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-777"},"text":"112 Stat. 2681–777","children":[],"tail":". For complete classification of chapter 3 to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The United States International Broadcasting Act of 1994, referred to in par. (3), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/432"},"text":"108 Stat. 432","children":[],"tail":", which is classified principally to chapter 71 (§ 6201 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6201"},"text":"section 6201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
