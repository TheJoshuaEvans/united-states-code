{"tag":"section","attrib":{"id":"id8ff51ab4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2680b"},"text":"§ 2680b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for certain monthly workers’ compensation payments and other payments for Department of State personnel under chief of mission authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff51ab5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of compensation for certain injuries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff51ab6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State or the head of any other Federal agency may pay an additional monthly monetary benefit, provided that the covered employee is receiving benefits under section 8105 or 8106 of title 5, and may determine the amount of each monthly monetary benefit amount by taking into account—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff51ab7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the severity of the qualifying injury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51ab8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the circumstances by which the covered employee became injured; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51ab9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the seniority of the covered employee, particularly for purposes of compensating for lost career growth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51aba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding chapter 81 of title 5, the total amount of monthly compensation increased under paragraph (1) may not exceed the monthly pay of the maximum rate of basic pay for GS–15 of the General Schedule under section 5332 of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51abb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs for treating qualifying injuries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State may pay the costs of or reimburse for diagnosing and treating—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff51abc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualifying injury of a covered employee for such costs, that are not otherwise covered by chapter 81 of title 5 or other provision of Federal law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51abd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a covered individual, or a covered dependent, for such costs that are not otherwise covered by Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51abe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information exchange","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To avoid duplicate or otherwise improper payments under this subsection, the Secretary of Labor, the Secretary of State, and, as appropriate, the head of any other Federal agency paying benefits under this section shall exchange information about the amounts paid for treatment of qualifying injuries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51abf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"December 20, 2019","children":[],"tail":", the Secretary of State shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff51ac0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe regulations ensuring the fair and equitable implementation of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51ac1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives such regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51ac2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff51ac3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered dependent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered dependent” means a family member (as defined by the Secretary of State) of an employee who, on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff51ac4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accompanies the employee to an assigned duty station in a foreign country under chief of mission authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51ac5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" becomes injured by reason of a qualifying injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51ac6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered employee” means an employee of the Federal Government who, on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", becomes injured by reason of a qualifying injury and was assigned to a duty station in the Republic of Cuba, the People’s Republic of China, or another foreign country designated by the Secretary of State pursuant to subsection (f), but does not include an individual receiving compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b"},"text":"section 3519b of title 50","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51ac7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered individual","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered individual” means an individual who, on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", becomes injured by reason of a qualifying injury and is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff51ac8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailed to a duty station in the Republic of Cuba, the People’s Republic of China, or another foreign country designated by the Secretary of State pursuant to subsection (f); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51ac9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affiliated with the Department of State, as determined by the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51aca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying injury","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying injury” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff51acb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a covered dependent, an injury incurred—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8ff51acc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during a period in which the covered dependent is accompanying an employee to an assigned duty station in the Republic of Cuba, the People’s Republic of China, or another foreign country designated by the Secretary of State pursuant to subsection (f);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ff51acd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with war, insurgency, hostile act, terrorist activity, or other incident designated by the Secretary of State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ff51ace-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was not the result of the willful misconduct of the covered dependent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51acf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to a covered employee or a covered individual, an injury incurred—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8ff51ad0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during a period of assignment to a duty station in the Republic of Cuba, the People’s Republic of China, or another country designated by the Secretary of State pursuant to subsection (f);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ff51ad1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with war, insurgency, hostile act, terrorist activity, or other incident designated by the Secretary of State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8ff51ad2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/e/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that was not the result of the willful misconduct of the covered employee or the covered individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51ad3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation by the Secretary of State of another foreign country or duty station","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State may designate another foreign country for the purposes of this section, provided that the Secretary reports such designation to the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives, and includes in such report a rationale for each such designation. The Secretary of State may not designate an added foreign country or duty station for purposes of providing additional monetary benefit pursuant to subsection (a), (b), or (i) for a qualifying injury to covered employees, covered dependents, or covered individuals under this section unless the Secretary of State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff51ad4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides to the Committees on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives 30 days’ notice of the designation of a particular additional country or duty station and the rationale for such addition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51ad5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides no such additional monetary benefit pursuant to subsection (a), (b), or (i) to covered employees, covered dependents, or covered individuals for a qualifying injury until the 30-day notice period expires, unless there is written agreement by both the Chair and Ranking Members of both the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives that there is no objection to proceeding with provision of such monetary benefit compensation in less than 30 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51ad6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s104"},"text":"section 104 of title 26","children":[],"tail":", amounts paid pursuant to this section shall be treated as amounts described in subsection (a)(5) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51ad7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff51ad8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of compensation provision","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (a) and (b) shall apply with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff51ad9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments made to covered employees (as defined in such section) under section 8105 or 8106 of title 5 beginning on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51ada-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diagnosis or treatment described in subsection (b) occurring on or after ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51adb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other payment provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payment under subsection (i) may be made available for a qualifying injury (as defined in such subsection) that occurs before, on, or after ","children":[{"tag":"date","attrib":{"date":"2021-10-08"},"text":"October 8, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51adc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall limit, modify, or otherwise supersede chapter 81 of title 5, the Defense Base Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1651"},"text":"42 U.S.C. 1651","children":[],"tail":" et seq.), or "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b"},"text":"section 3519b of title 50","children":[],"tail":". Monetary benefits and treatment expenses paid under this section shall not be considered payments under any workers’ compensation law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51add-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff51ade-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/h/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under subsections (a) and (b) in a fiscal year may only be made using amounts appropriated in advance specifically for payments under such paragraph in such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51adf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/h/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matter of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under subsections (a) and (b) using amounts appropriated for such purpose shall be made on a first come, first serve, or pro rata basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51ae0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/h/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of funding obligated for payments under subsections (a) and (b) may not exceed the amount specifically appropriated for providing payments under such paragraph during its period of availability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51ae1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other injuries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff51ae2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff51ae3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered dependent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered dependent” has the meaning given such term in subsection (e), except that the assigned duty station need not be in the Republic of Cuba, the People’s Republic of China, or another foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51ae4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered employee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered employee” has the meaning given such term in subsection (e), except that the assigned duty station need not be in the Republic of Cuba, the People’s Republic of China, or another foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51ae5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered individual","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered individual” has the meaning given such term in subsection (e), except that the assigned duty station need not be in the Republic of Cuba, the People’s Republic of China, or another foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51ae6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifying injury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualifying injury” has the meaning given such term in subsection (e), except that the assigned duty station need not be in the Republic of Cuba, the People’s Republic of China, or another foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51ae7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law but subject to paragraph (3), the Secretary of State or other agency head with an employee may provide payment to a covered dependent, a dependent of a former employee, a covered employee, a former employee, and a covered individual for a qualifying injury to the brain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51ae8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff51ae9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payment under paragraph (2) in a fiscal year may only be made using amounts appropriated in advance specifically for payments under such paragraph in such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51aea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matter of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under paragraph (2) using amounts appropriated for such purpose shall be made on a first come, first serve, or pro rata basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51aeb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of funding obligated for payments under paragraph (2) may not exceed the amount specifically appropriated for providing payments under such paragraph during its period of availability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51aec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff51aed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or other agency head described in paragraph (2) that provides payment under such paragraph shall prescribe regulations to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff51aee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations prescribed under subparagraph (A) shall include regulations detailing fair and equitable criteria for payment under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51aef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on other benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments made under paragraph (2) are supplemental to any other benefit furnished by the United States Government for which a covered dependent, dependent of a former employee, covered employee, former employee, or covered individual is entitled, and the receipt of such payments may not affect the eligibility of such a person to any other benefit furnished by the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51af0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680b/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of any Federal agency may exercise the authorities of this section, including to designate an incident, whether the incident occurred in the United States or abroad, for purposes of subparagraphs (A)(ii) and (B)(ii) of subsection (e)(4) when the incident affects United States Government employees of the agency or their dependents who are not under the security responsibility of the Secretary of State as set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4802"},"text":"section 4802 of this title","children":[],"tail":" or when operational control of overseas security responsibility for such employees or dependents has been delegated to the head of the agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff51af1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tIX/s901"},"text":"Pub. L. 116–94, div. J, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3079"},"text":"133 Stat. 3079","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXI/s1110"},"text":"Pub. L. 116–283, div. A, title XI, § 1110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3892"},"text":"134 Stat. 3892","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/46/s3/b"},"text":"Pub. L. 117–46, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-10-08"},"text":"Oct. 8, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/394"},"text":"135 Stat. 394","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dX/tVI/s603/b"},"text":"Pub. L. 117–103, div. X, title VI, § 603(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/995"},"text":"136 Stat. 995","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCII/s9216"},"text":"Pub. L. 117–263, div. I, title XCII, § 9216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3877"},"text":"136 Stat. 3877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tVI/s5604"},"text":"Pub. L. 119–60, div. E, title VI, § 5604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1603"},"text":"139 Stat. 1603","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff51af2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff51af3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ff51af4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Defense Base Act, referred to in subsec. (h)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-08-16/ch357"},"text":"act Aug. 16, 1941, ch. 357","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/622"},"text":"55 Stat. 622","children":[],"tail":", which is classified generally to chapter 11 (§ 1651 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1651"},"text":"section 1651 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ff51af5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s5604/1"},"text":"Pub. L. 119–60, § 5604(1)","children":[],"tail":", (2), substituted “"},{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"January 1, 2016","children":[],"tail":"” and “of an” for “of a” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s5604/1"},"text":"Pub. L. 119–60, § 5604(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"January 1, 2016","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(1)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s5604/1"},"text":"Pub. L. 119–60, § 5604(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2016-01-01"},"text":"January 1, 2016","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s5604/3"},"text":"Pub. L. 119–60, § 5604(3)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (i)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103"},"text":"Pub. L. 117–103","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1110/1"},"text":"Pub. L. 116–283, § 1110(1)","children":[],"tail":", inserted “or the head of any other Federal agency” after “The Secretary of State” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1110/2"},"text":"Pub. L. 116–283, § 1110(2)","children":[],"tail":", substituted “, the Secretary of State, and, as appropriate, the head of any other Federal agency paying benefits under this section” for “and the Secretary of State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1110/3"},"text":"Pub. L. 116–283, § 1110(3)","children":[],"tail":", substituted “the Federal Government” for “the Department of State” and inserted “, but does not include an individual receiving compensation under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b"},"text":"section 3519b of title 50","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/46/s3/b/1"},"text":"Pub. L. 117–46, § 3(b)(1)","children":[],"tail":", substituted “subsection (a), (b), or (i)” for “subsection (a) or (b)” in introductory provisions and in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/46/s3/b/2/A"},"text":"Pub. L. 117–46, § 3(b)(2)(A)","children":[],"tail":", substituted “Adjustment of compensation provision” for “In general” in heading and “Subsections (a) and (b)” for “This section” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/46/s3/b/2/C"},"text":"Pub. L. 117–46, § 3(b)(2)(C)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1110/4"},"text":"Pub. L. 116–283, § 1110(4)","children":[],"tail":", substituted “Nothing in this section shall limit, modify, or otherwise supersede chapter 81 of title 5, the Defense Base Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1651"},"text":"42 U.S.C. 1651","children":[],"tail":" et seq.), or "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3519b"},"text":"section 3519b of title 50","children":[],"tail":".” for “Nothing in this section shall modify or otherwise supersede chapter 81 of title 5 or chapter 11 of title 42.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/46/s3/b/2/B"},"text":"Pub. L. 117–46, § 3(b)(2)(B)","children":[],"tail":", redesignated par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/46/s3/b/3"},"text":"Pub. L. 117–46, § 3(b)(3)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff51af6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ff51af7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/46/s3/d"},"text":"Pub. L. 117–46, § 3(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-10-08"},"text":"Oct. 8, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/396"},"text":"135 Stat. 396","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/46/s3/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-10-08"},"text":"Oct. 8, 2021","children":[],"tail":"], the Secretary of State and each other agency head that makes a payment under subsection (i)(2) of section 901 of title IX of division J of the Further Consolidated Appropriations Act, 2020 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2680b"},"text":"22 U.S.C. 2680b","children":[],"tail":"), as added by subsection (b) of this section, shall prescribe regulations required under subsection (i)(4)(A) of such Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 210 days after the date of the enactment of this Act, the Secretary of State and the agency heads described in 