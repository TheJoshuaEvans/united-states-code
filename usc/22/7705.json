{"tag":"section","attrib":{"id":"id90eac6dc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7705"},"text":null,"children":[{"tag":"num","attrib":{"value":"7705"},"text":"§ 7705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Candidate countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90eac6dd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A country shall be a candidate country for purposes of eligibility to receive assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7704"},"text":"section 7704 of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90eac6de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the per capita income of the country in a fiscal year is equal to or less than the World Bank threshold for initiating the International Bank for Reconstruction and Development graduation process for the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90eac6df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (b), the country is not ineligible to receive United States economic assistance under part I of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.) by reason of the application of any provision of the Foreign Assistance Act of 1961 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.] or any other provision of law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac6e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of determining whether a country is eligible, pursuant to subsection (a)(2), to receive assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7704"},"text":"section 7704 of this title","children":[],"tail":", the exercise by the President, the Secretary of State, or any other officer or employee of the United States Government of any waiver or suspension of any provision of law referred to in subsection (a)(2), and notification to the appropriate congressional committees in accordance with such provision of law, shall be construed as satisfying the requirements under subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90eac6e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by the Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall determine whether a country is a candidate country for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90eac6e2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tVI/s606"},"text":"Pub. L. 108–199, div. D, title VI, § 606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/215"},"text":"118 Stat. 215","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/167/tII/s201"},"text":"Pub. L. 115–167, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-04-23"},"text":"Apr. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1278"},"text":"132 Stat. 1278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLI/s5122/b"},"text":"Pub. L. 118–159, div. E, title LI, § 5122(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2430"},"text":"138 Stat. 2430","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90eac6e3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90eac6e4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90eac6e5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of this title. Part I of the Act is classified generally to subchapter I (§ 2151 et seq.) of chapter 32 of this title. For provisions deeming references to subchapter I to include parts IV (§ 2346 et seq.), VI (§ 2348 et seq.), and VIII (§ 2349aa et seq.) of subchapter II of chapter 32, see "},{"tag":"ref","attrib":{"href":"/us/pl/92/226/s202/b"},"text":"section 202(b) of Pub. L. 92–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"section 2346 of this title","children":[],"tail":", and sections 2348c and 2349aa–5 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90eac6e6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" amended section generally. Prior to amendment, section related to candidate countries for purposes of eligibility for assistance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167/s201/a/1"},"text":"Pub. L. 115–167, § 201(a)(1)","children":[],"tail":", substituted “(4)” for “(3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167/s201/a/2"},"text":"Pub. L. 115–167, § 201(a)(2)","children":[],"tail":", substituted “Fiscal years 2005 through 2012” for “Fiscal year 2005 and subsequent fiscal years” in heading and “each of fiscal years 2005 through 2012” for “fiscal year 2005 or a subsequent fiscal year” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167/s201/a/3"},"text":"Pub. L. 115–167, § 201(a)(3)","children":[],"tail":", (4), added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167/s201/b/1"},"text":"Pub. L. 115–167, § 201(b)(1)","children":[],"tail":", substituted “Fiscal years 2006 through 2012” for “In general” in heading and “fiscal years 2006 through 2012” for “fiscal year 2006 or a subsequent fiscal year” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167/s201/b/2"},"text":"Pub. L. 115–167, § 201(b)(2)","children":[],"tail":", (3), added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167/s201/c"},"text":"Pub. L. 115–167, § 201(c)","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
