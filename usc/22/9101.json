{"tag":"section","attrib":{"id":"id911a6234-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101"},"text":null,"children":[{"tag":"num","attrib":{"value":"9101"},"text":"§ 9101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a6235-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abducted child","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “abducted child” means a child who is the victim of international child abduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6236-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “abduction” means the alleged wrongful removal of a child from the child’s country of habitual residence, or the wrongful retention of a child outside such country, in violation of a left-behind parent’s custodial rights, including the rights of a military parent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6237-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abduction case","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term abduction case ","children":[{"tag":"ref","attrib":{"idref":"fn002424"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002424"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The defined term probably should be within quotation marks."}],"tail":" means—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a6238-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a case that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911a6239-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been reported to the Central Authority of the United States by a left-behind parent for the resolution of an abduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911a623a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the criteria for an international child abduction under the Hague Abduction Convention, regardless of whether the country at issue is a Convention country; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a623b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any case reported involving an application filed with the Central Authority of the United States or directly with the foreign central authority by a parent seeking rights of access or return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a623c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access case","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “access case” means a case involving an application filed with the Central Authority of the United States by a parent seeking rights of access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a623d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Annual Report” means the Annual Report on International Child Abduction required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9111"},"text":"section 9111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a623e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “application” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a623f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Convention country, the application required pursuant to article 8 of the Hague Abduction Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6240-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a bilateral procedures country, the formal document required, pursuant to the provisions of the applicable arrangement, to request the return of an abducted child or to request rights of access, as applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6241-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a non-Convention country, the formal request by the Central Authority of the United States to the Central Authority of such country requesting the return of an abducted child or for rights of contact with an abducted child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6242-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate congressional committees” means the Committee on Foreign Relations of the Senate and the Committee on Foreign Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6243-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bilateral procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bilateral procedures” means any procedures established by, or pursuant to, a bilateral arrangement, including a Memorandum of Understanding between the United States and another country, to resolve abduction and access cases, including procedures to address interim contact matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6244-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bilateral procedures country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bilateral procedures country” means a country with which the United States has entered into bilateral procedures, including Memoranda of Understanding, with respect to child abductions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6245-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Central Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Central Authority” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a6246-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a Convention country, the meaning given such term in article 6 of the Hague Abduction Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6247-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a bilateral procedures country, the official entity designated by the government of the bilateral procedures country within the applicable memorandum of understanding pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9113/b/1"},"text":"section 9113(b)(1) of this title","children":[],"tail":" to discharge the duties imposed on the entity; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6248-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a non-Convention country, the foreign ministry or other appropriate authority of such country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6249-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “child” means an individual who has not attained 18 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a624a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convention country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Convention country” means a country for which the Hague Abduction Convention has entered into force with respect to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a624b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hague Abduction Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Hague Abduction Convention” means the Convention on the Civil Aspects of International Child Abduction, done at The Hague ","children":[{"tag":"date","attrib":{"date":"1980-10-25"},"text":"October 25, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a624c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim contact","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “interim contact” means the ability of a left-behind parent to communicate with or visit an abducted child during the pendency of an abduction case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a624d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Left-behind parent","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “left-behind parent” means an individual or legal custodian who alleges that an abduction has occurred that is in breach of rights of custody attributed to such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a624e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Convention country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “non-Convention country” means a country in which the Hague Abduction Convention has not entered into force with respect to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a624f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overseas military dependent child","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “overseas military dependent child” means a child whose habitual residence is the United States according to United States law even though the child is residing outside the United States with a military parent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6250-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overseas military parent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “overseas military parent” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a6251-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/18/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has custodial rights with respect to a child; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6252-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/18/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving outside the United States as a member of the United States Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6253-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pattern of noncompliance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a6254-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/19/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “pattern of noncompliance” means the persistent failure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911a6255-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/19/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a Convention country to implement and abide by provisions of the Hague Abduction Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911a6256-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/19/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a non-Convention country to abide by bilateral procedures that have been established between the United States and such country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911a6257-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/19/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a non-Convention country to work with the Central Authority of the United States to resolve abduction cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6258-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/19/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persistent failure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Persistent failure under subparagraph (A) may be evidenced in a given country by the presence of 1 or more of the following criteria:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911a6259-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/19/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Thirty percent or more of the total abduction cases in such country are unresolved abduction cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911a625a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/19/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Central Authority regularly fails to fulfill its responsibilities pursuant to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id911a625b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/19/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Hague Abduction Convention; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id911a625c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/19/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any bilateral procedures between the United States and such country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911a625d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/19/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The judicial or administrative branch, as applicable, of the national government of a Convention country or a bilateral procedures country fails to regularly implement and comply with the provisions of the Hague Abduction Convention or bilateral procedures, as applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911a625e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/19/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Law enforcement authorities regularly fail to enforce return orders or determinations of rights of access rendered by the judicial or administrative authorities of the government of the country in abduction cases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a625f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of access","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rights of access” means the establishment of rights of contact between a child and a parent seeking access in Convention countries—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a6260-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/20/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by operation of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6261-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/20/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through a judicial or administrative determination; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6262-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/20/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through a legally enforceable arrangement between the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6263-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of custody","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rights of custody” means rights of care and custody of a child, including the right to determine the place of residence of a child, under the laws of the country in which the child is a habitual resident—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a6264-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/21/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attributed to an individual or legal custodian; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a6265-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/21/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" arising—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911a6266-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/21/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by operation of law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911a6267-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/21/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through a judicial or administrative decision; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911a6268-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/21/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through a legally enforceable arrangement between the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6269-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights of interim contact","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rights of interim contact” means the rights of contact between a child and a left-behind parent, which has been provided as a provisional measure while an abduction case is pending, under the laws of the country in which the child is located—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a626a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/22/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by operation of law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a626b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/22/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through a judicial or administrative determination; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a626c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/22/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through a legally enforceable arrangement between the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a626d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unresolved abduction case","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a626e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/23/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the term “unresolved abduction case” means an abduction case that remains unresolved for a period that exceeds 12 months after the date on which the completed application for return of the child is submitted for determination to the judicial or administrative authority, as applicable, in the country in which the child is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a626f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/23/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resolution of case","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An abduction case shall be considered to be resolved if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id911a6270-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/23/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the child is returned to the country of habitual residence, pursuant to the Hague Abduction Convention or other appropriate bilateral procedures, if applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911a6271-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/23/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the judicial or administrative branch, as applicable, of the government of the country in which the child is located has implemented, and is complying with, the provisions of the Hague Abduction Convention or other bilateral procedures, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911a6272-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/23/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the left-behind parent reaches a voluntary arrangement with the other parent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911a6273-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/23/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the left-behind parent submits a written withdrawal of the application or the request for assistance to the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911a6274-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/23/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the left-behind parent cannot be located for 1 year despite the documented efforts of the Department of State to locate the parent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id911a6275-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9101/23/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the child or left-behind parent is deceased.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911cd176-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150/s3"},"text":"Pub. L. 113–150, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1809"},"text":"128 Stat. 1809","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXV/s7509/a"},"text":"Pub. L. 118–159, div. G, title LXXV, § 7509(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2550"},"text":"138 Stat. 2550","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911cd177-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911cd178-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id911cd179-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150"},"text":"Pub. L. 113–150","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1807"},"text":"126 Stat. 1807","children":[],"tail":", known as the Sean and David Goldman International Child Abduction Prevention and Return Act of 2014, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id911cd17a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7509/a/1"},"text":"Pub. L. 118–159, § 7509(a)(1)","children":[],"tail":", substituted “abduction case means—” for “ ‘abduction case’ means” in introductory provisions, inserted subpar. (A) designation before “a case”, redesignated former subpars. (A) and (B) as cls. (i) and (ii), respectively, of subpar. (A), and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7509/a/2"},"text":"Pub. L. 118–159, § 7509(a)(2)","children":[],"tail":", substituted “18” for “16”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id911cd17b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id911cd17c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150/s1/a"},"text":"Pub. L. 113–150, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1807"},"text":"128 Stat. 1807","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/150/s1/a"},"text":"“This Act [enacting this chapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s241"},"text":"section 241 of Title 6","children":[],"tail":", Domestic Security, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s11611"},"text":"section 11611 of Title 42","children":[],"tail":", The Public Health and Welfare, and enacting provisions set out as a note under this section] may be cited as the ‘Sean and David Goldman International Child Abduction Prevention and Return Act of 2014’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id911cd17d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings; Sense of Congress; Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/150/s2"},"text":"Pub. L. 113–150, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1807"},"text":"128 Stat. 1807","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/150/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sean Goldman, a United States citizen and resident of New Jersey, was abducted from the United States in 2004 and separated from his father, David Goldman, who spent nearly 6 years battling for the return of his son from Brazil before Sean was finally returned to Mr. Goldman’s custody on ","children":[{"tag":"date","attrib":{"date":"2009-12-24"},"text":"December 24, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of State’s Office of Children’s Issues, which serves as the Central Authority of the United States for the purposes of the 1980 Hague Convention on the Civil Aspects of International Child Abduction (referred to in this Act [see Short Title note above] as the ‘Hague Abduction Convention’), has received thousands of requests since 2007 for assistance in the return to the United States of children who have been wrongfully abducted by a parent or other legal guardian to another country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For a variety of reasons reflecting the significant obstacles to the recovery of abducted children, as well as the legal and factual complexity involving such cases, not all cases are reported to the Central Authority of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" More than 1,000 outgoing international child abductions are reported every year to the Central Authority of the United States, which depends solely on proactive reporting of abduction cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Only about one-half of the children abducted from the United States to countries with which the United States enjoys reciprocal obligations under the Hague Abduction Convention are returned to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States and other Convention countries have expressed their desire, through the Hague Abduction Convention, ‘to protect children internationally from the harmful effects of their wrongful removal or retention and to establish procedures to ensure their prompt return to the State of their habitual residence, as well as to secure protection for rights of access.’","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compliance by the United States and other Convention countries depends on the actions of their designated central authorities, the performance of their judicial systems as reflected in the legal process and decisions rendered to enforce or effectuate the Hague Abduction Convention, and the ability and willingness of their law enforcement authorities to ensure the swift enforcement of orders rendered pursuant to the Hague Abduction Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" According to data from the Department of State, approximately 40 percent of abduction cases involve children taken from the United States to countries with which the United States does not have reciprocal obligations under the Hague Abduction Convention or other arrangements relating to the resolution of abduction cases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" According to the Department of State’s April 2010 Report on Compliance with the Hague Convention on the Civil Aspects of International Child Abduction, ‘parental child abduction jeopardizes the child and has substantial long-term consequences for both the child and the left-behind parent.’","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Few left-behind parents have the extraordinary financial resources necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pursue individual civil or criminal remedies in both the United States and a foreign country, even if such remedies are available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage in repeated foreign travel to attempt to obtain the return of their children through diplomatic or other channels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"“(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Military parents often face additional complications in resolving abduction cases because of the challenges presented by their military obligations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"“(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to using the Hague Abduction Convention to achieve the return of abducted children, the United States has an array of Federal, State, and local law enforcement, criminal justice, and judicial tools at its disposal to prevent international abductions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"“(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies tasked with preventing international abductions have indicated that the most effective way to stop international child abductions is while they are in progress, rather than after the child has been removed to a foreign destination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"“(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Parental awareness of abductions in progress, rapid response by relevant law enforcement, and effective coordination among Federal, State, local, and international stakeholders are critical in preventing such abductions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"“(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A more robust application of domestic tools, in cooperation with international law enforcement entities and appropriate application of the Hague Abduction Convention could—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discourage some parents from attempting abductions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" block attempted abductions at ports of exit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help achieve the return of more abducted children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the sense of Congress that the United States should set a strong example for other Convention countries in the timely location and prompt resolution of cases involving children abducted abroad and brought to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this Act [see Short Title note above] are—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect children whose habitual residence is the United States from wrongful abduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist left-behind parents in quickly resolving cases and maintaining safe and predictable contact with their child while an abduction case is pending;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect the custodial rights of parents, including military parents, by providing the parents, the judicial system, and law enforcement authorities with the information they need to prevent unlawful abduction before it occurs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance the prompt resolution of abduction and access cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to detail an appropriate set of actions to be undertaken by the Secretary of State to address persistent problems in the resolution of abduction cases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a program to prevent wrongful abductions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase interagency coordination in preventing international child abduction by convening a working group composed of presidentially appointed and Senate confirmed officials from the Department of State, the Department of Homeland Security, and the Department of Justice.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
