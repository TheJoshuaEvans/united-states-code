{"tag":"section","attrib":{"id":"id8ffeb7ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2716"},"text":null,"children":[{"tag":"num","attrib":{"value":"2716"},"text":"§ 2716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt collection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ffeb7ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2716/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb7ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2716/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the availability of appropriations, the Secretary of State shall enter into contracts for collection services to recover indebtedness owed by a person, other than a foreign country, to the United States which arises out of activities of the Department of State and is delinquent by more than 90 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb7af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2716/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each contract entered into under this section shall provide that the person with whom the Secretary enters into such contract shall submit to the Secretary at least once every 180 days a status report on the success of the person in collecting debts. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3718"},"text":"Section 3718 of title 31","children":[],"tail":" shall apply to any such contract to the extent that such section is not inconsistent with this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb7b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2716/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of delinquent debt to credit reporting agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall, to the extent otherwise allowed by law, disclose to those credit reporting agencies to which the Secretary reports loan activity information concerning any debt of more than $100 owed by a person, other than a foreign country, to the United States which arises out of activities of the Department of State and is delinquent by more than 31 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ffeb7b1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 44, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/tI/s117/2"},"text":"Pub. L. 101–246, title I, § 117(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-02-16"},"text":"Feb. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/25"},"text":"104 Stat. 25","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ffeb7b2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ffeb7b3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8ffeb7b4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 44 of act ","children":[{"tag":"date","attrib":{"date":"1956-08-01"},"text":"Aug. 1, 1956","children":[],"tail":", was renumbered section 45 by "},{"tag":"ref","attrib":{"href":"/us/pl/101/246/s117/1"},"text":"section 117(1) of Pub. L. 101–246","children":[],"tail":", and subsequently renumbered, and set out as a Short Title of 1956 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s111/1"},"text":"Pub. L. 102–138, title I, § 111(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/654"},"text":"105 Stat. 654","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
