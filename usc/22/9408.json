{"tag":"section","attrib":{"id":"id9128b95b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9408"},"text":null,"children":[{"tag":"num","attrib":{"value":"9408"},"text":"§ 9408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on coordination of sanctions between the United States and the European Union","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9128b95c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2017-08-02"},"text":"August 2, 2017","children":[],"tail":", and every 180 days thereafter, the President shall submit to the appropriate congressional committees a report that includes the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9128b95d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9408/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of each instance, during the period specified in subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9128b95e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9408/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the United States has imposed sanctions with respect to a person for activity related to the proliferation of weapons of mass destruction or delivery systems for such weapons to or by Iran, support for acts of international terrorism by Iran, or human rights abuses in Iran, but in which the European Union has not imposed corresponding sanctions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9128b95f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9408/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the European Union has imposed sanctions with respect to a person for activity related to the proliferation of weapons of mass destruction or delivery systems for such weapons to or by Iran, support for acts of international terrorism by Iran, or human rights abuses in Iran, but in which the United States has not imposed corresponding sanctions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b960-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9408/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation for the reason for each discrepancy between sanctions imposed by the European Union and sanctions imposed by the United States described in subparagraphs (A) and (B) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9128b961-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period specified","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The period specified in this subsection is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9128b962-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9408/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the first report submitted under subsection (a), the period beginning on ","children":[{"tag":"date","attrib":{"date":"2017-08-02"},"text":"August 2, 2017","children":[],"tail":", and ending on the date the report is submitted; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b963-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9408/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a subsequent such report, the 180-day period preceding the submission of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9128b964-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9408/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required by subsection (a) shall be submitted in unclassified form but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9128b965-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tI/s109"},"text":"Pub. L. 115–44, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/895"},"text":"131 Stat. 895","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9128b966-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9128b967-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id9128b968-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section to the Secretary of State, in consultation with the Secretary of the Treasury, see section 1(b)(v) of Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2017-10-11"},"text":"Oct. 11, 2017","children":[],"tail":", 82 F.R. 50051, set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9403"},"text":"section 9403 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
