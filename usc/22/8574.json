{"tag":"section","attrib":{"id":"id91074e84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574"},"text":null,"children":[{"tag":"num","attrib":{"value":"8574"},"text":"§ 8574.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategy to counter role of the People’s Republic of China in evasion of sanctions with respect to Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91074e85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":", the Secretary of State, in consultation with the heads of other appropriate Federal agencies, shall submit to the appropriate congressional committees a written strategy, and provide to those committees an accompanying briefing, on the role of the People’s Republic of China in evasion of sanctions imposed by the United States with respect to Iranian-origin petroleum products that includes an assessment of options—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id91074e86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen the enforcement of such sanctions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074e87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand sanctions designations targeting the involvement of the People’s Republic of China in the production, transportation, storage, refining, and sale of Iranian-origin petroleum products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91074e88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy required by subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91074e89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description and assessment of the use of sanctions in effect before ","children":[{"tag":"date","attrib":{"date":"2024-04-24"},"text":"April 24, 2024","children":[],"tail":", to target individuals and entities of the People’s Republic of China that are directly or indirectly associated with smuggling of Iranian-origin petroleum products;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074e8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91074e8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Iranian-owned entities operating in the People’s Republic of China and involved in petroleum refining supply chains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the People’s Republic of China’s role in global petroleum refining supply chains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the People’s Republic of China leverages its role in global petroleum supply chains to achieve political objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e8e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the People’s Republic of China’s petroleum importing and exporting partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e8f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" what percent of the People’s Republic of China’s energy consumption is linked to illegally imported Iranian-origin petroleum products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e90-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" what level of influence the Chinese Communist Party holds over non-state, semi-independent “teapot” refineries;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074e91-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a detailed plan for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91074e92-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring the maritime domain for sanctionable activity related to smuggling of Iranian-origin petroleum products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e93-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifying the individuals, entities, and vessels engaging in sanctionable activity related to Iranian-origin petroleum products, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91074e94-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" vessels—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id91074e95-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transporting petrochemicals subject to sanctions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91074e96-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting ship-to-ship transfers of such petrochemicals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91074e97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with deactivated automatic identification systems; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91074e98-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that engage in “flag hopping” by changing national registries;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91074e99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" individuals or entities—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id91074e9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" storing petrochemicals subject to sanctions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id91074e9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refining or otherwise processing such petrochemicals; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91074e9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the use of port entry and docking permission of vessels subject to sanctions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074e9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" deterring individuals and entities from violating sanctions by educating and engaging—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91074e9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insurance providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91074e9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parent companies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91074ea0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vessel operators;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074ea1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborating with allies and partners of the United States engaged in the Arabian Peninsula, including through standing or new maritime task forces, to build sanctions enforcement capacity through assistance and training to defense and law enforcement services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074ea2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using public communications and global diplomatic engagements to highlight the role of illicit petroleum product smuggling in bolstering Iran’s support for terrorism and its nuclear program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91074ea3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91074ea4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of vessels smuggling Iranian-origin petroleum products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074ea5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of vessels smuggling such petroleum products destined for the People’s Republic of China;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074ea6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of vessels smuggling such petroleum products specifically from the Islamic Revolutionary Guard Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074ea7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interference by the People’s Republic of China with attempts by the United States to investigate or enforce sanctions on illicit Iranian petroleum product exports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074ea8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the use of sanctions with respect to insurers of entities that own or operate vessels involved in smuggling Iranian-origin petroleum products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074ea9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the personnel and resources needed to enforce sanctions with respect to Iranian-origin petroleum products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91074eaa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/b/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of smuggled illicit Iranian-origin petroleum products on global energy markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91074eab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8574/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The strategy required by subsection (a) shall be submitted in unclassified form, but may include a classified index.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91074eac-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/50/dJ/s5"},"text":"Pub. L. 118–50, div. J, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-04-24"},"text":"Apr. 24, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/967"},"text":"138 Stat. 967","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91074ead-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91074eae-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id91074eaf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Stop Harboring Iranian Petroleum Act, also known as the SHIP Act, and not as part of the Comprehensive Iran Sanctions, Accountability, and Divestment Act of 2010 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
