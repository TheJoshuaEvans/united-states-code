{"tag":"section","attrib":{"id":"id911a616c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8927"},"text":null,"children":[{"tag":"num","attrib":{"value":"8927"},"text":"§ 8927.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded broadcasting in countries of the former Soviet Union","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911a616d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8927/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2014-12-18"},"text":"December 18, 2014","children":[],"tail":", the Chairman of the Broadcasting Board of Governors shall submit to Congress a plan, including a cost estimate, for immediately and substantially increasing, and maintaining through fiscal year 2017, the quantity of Russian-language broadcasting into the countries of the former Soviet Union funded by the United States in order to counter Russian Federation propaganda."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a616e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8927/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization of broadcasting into Ukraine, Georgia, and Moldova","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan required by subsection (a) shall prioritize broadcasting into Ukraine, Georgia, and Moldova by the Voice of America and Radio Free Europe/Radio Liberty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a616f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8927/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the plan required by subsection (a), the Chairman shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a6170-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8927/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" near-term increases in Russian-language broadcasting for countries of the former Soviet Union (other than the countries specified in subsection (b)), including Latvia, Lithuania, and Estonia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6171-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8927/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases in broadcasting in other critical languages, including Ukrainian and Romanian languages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a6172-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8927/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Broadcasting defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “broadcasting” means the distribution of media content via radio broadcasting, television broadcasting, and Internet-based platforms, among other platforms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a6173-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8927/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a6174-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8927/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Broadcasting Board of Governors $10,000,000 for each of fiscal years 2016 through 2018 to carry out activities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a6175-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8927/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts authorized to be appropriated pursuant to paragraph (1) shall supplement and not supplant other amounts made available for activities described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911a6176-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/272/s8"},"text":"Pub. L. 113–272, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2964"},"text":"128 Stat. 2964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911a6177-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id911a6178-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id911a6179-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Broadcasting Board of Governors renamed United States Agency for Global Media pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6204/a/21"},"text":"section 6204(a)(21) of this title","children":[],"tail":". The renaming was effectuated by notice to congressional appropriations committees dated "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", and became effective "},{"tag":"date","attrib":{"date":"2018-08-22"},"text":"Aug. 22, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
