{"tag":"section","attrib":{"id":"id8fab40e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2383"},"text":null,"children":[{"tag":"num","attrib":{"value":"2383"},"text":"§ 2383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Secretary of Defense; priorities in procurement, delivery, and allocation of military equipment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fab40e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2383/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of assistance under subchapter II of this chapter, the Secretary of Defense shall have primary responsibility for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fab40e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2383/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the determination of military end-item requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fab40ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2383/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procurement of military equipment in a manner which permits its integration with service programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fab40eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2383/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supervision of end-item use by the recipient countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fab40ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2383/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supervision of the training of foreign military and related civilian personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fab40ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2383/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movement and delivery of military end-items; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fab40ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2383/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the Department of Defense, the performance of any other functions with respect to the furnishing of military assistance, education and training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fab40ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2383/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The establishment of priorities in the procurement, delivery, and allocation of military equipment shall be determined by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fab40f0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 623, "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/446"},"text":"75 Stat. 446","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/329/tI/s106/b/3"},"text":"Pub. L. 94–329, title I, § 106(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/733"},"text":"90 Stat. 733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fab40f1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fab40f2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fab40f3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329/s106/b/3/A"},"text":"Pub. L. 94–329, § 106(b)(3)(A)","children":[],"tail":", inserted “and related civilian” after “military”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329/s106/b/3/B"},"text":"Pub. L. 94–329, § 106(b)(3)(B)","children":[],"tail":", inserted “education and training” after “assistance”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fab40f4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8fab40f5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Subchapter II Deemed To Exclude Certain Parts of Subchapter II","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to subchapter II of this chapter are deemed to exclude parts IV (§ 2346 et seq.), VI (§ 2348 et seq.), and VIII (§ 2349aa et seq.) of subchapter II, and references to subchapter I of this chapter are deemed to include such parts. See ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226/s202/b"},"text":"section 202(b) of Pub. L. 92–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"section 2346 of this title","children":[],"tail":", and sections 2348c and 2349aa–5 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
