{"tag":"section","attrib":{"id":"id8f2f32c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2077"},"text":null,"children":[{"tag":"num","attrib":{"value":"2077"},"text":"§ 2077.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International University for the Americas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f2f32c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2077/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to promote economic integration and the consolidation and strengthening of democratic institutions in the Western Hemisphere, and to commemorate the 500th anniversary of the discovery of the Americas by Christopher Columbus through the establishment of an institution of higher education, which shall be known as the “International University for the Americas”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2f32c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2077/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, in consultation with other governments in the Western Hemisphere, shall determine the most appropriate location for the International University for the Americas. In making that determination, the Secretary shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f2f32c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2077/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location chosen is in the Americas and is easily accessible to all peoples in the region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f2f32c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2077/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the relevant government—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f2f32c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2077/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated a commitment to economic integration and democratic values though ","children":[{"tag":"ref","attrib":{"idref":"fn002086"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002086"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “through”."}],"tail":" its policies and programs; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f2f32c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2077/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has expressed an interest in that location being chosen as a site and has agreed to contribute some amount of assistance, either in cash or kind, toward the costs of developing the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2f32c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2077/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Faculty, students, and curriculum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the bylaws of the International University for the Americas, the Secretary of State shall ensure that they contain provisions to ensure that faculty and students are drawn from all the nations in the Western Hemisphere, and that the curriculum is designed to develop expertise in fields that will promote the economic integration of the Americas and the consolidation of democracy throughout the Hemisphere.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2f32ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2077/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The annual reports submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738m"},"text":"section 1738m of title 7","children":[],"tail":" shall include a progress report on the selection of a site and design for the establishment of the International University for the Americas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2f32cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2077/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds that are allocated for assistance for Latin America and the Caribbean under chapter 1 of part I of the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.] (relating to development assistance) and chapter 4 of part II of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"22 U.S.C. 2346","children":[],"tail":" et seq.] (relating to the economic support fund), $500,000 may be made available to carry out the site location and design phase of the International University for the Americas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f2f32cc-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/549/tVI/s604"},"text":"Pub. L. 102–549, title VI, § 604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3669"},"text":"106 Stat. 3669","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/b/1/A"},"text":"Pub. L. 110–246, title III, § 3001(b)(1)(A)","children":[],"tail":", (2)(O), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1820"},"text":"122 Stat. 1820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f2f32cd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f2f32ce-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f2f32cf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Chapter 1 of part I and chapter 4 of part II of the Act are classified generally to part I (§ 2151 et seq.) of subchapter I and part IV (§ 2346 et seq.) of subchapter II, respectively, of chapter 32 of this title. For provisions deeming references to part I of subchapter I to include a reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2293"},"text":"section 2293 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2293/d/1"},"text":"section 2293(d)(1) of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f2f32d0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738m"},"text":"section 1738m of title 7","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f2f32d1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f2f32d2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
