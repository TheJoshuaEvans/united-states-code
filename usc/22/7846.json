{"tag":"section","attrib":{"id":"id90f1f1e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7846"},"text":null,"children":[{"tag":"num","attrib":{"value":"7846"},"text":"§ 7846.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress on humanitarian coordination related to the Korean Peninsula","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f1f1e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7846/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any instability on the Korean Peninsula could have significant humanitarian and strategic impact on the region and for United States national interests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f1e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7846/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as such, the United States Government should work with countries sharing a land or maritime border with North Korea to develop long-term whole-of-government plans to coordinate efforts related to humanitarian assistance and human rights promotion and to effectively assimilate North Korean defectors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f1f1e9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/333/tIII/s306"},"text":"Pub. L. 108–333, title III, § 306","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/198/s6"},"text":"Pub. L. 115–198, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-20"},"text":"July 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1523"},"text":"132 Stat. 1523","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
