{"tag":"section","attrib":{"id":"id8f982e3a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–2a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2349bb–2a"},"text":"§ 2349bb–2a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International nonproliferation export control training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f982e3b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–2a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to furnish, on such terms and conditions consistent with this part (but whenever feasible on a reimbursable basis), education and training to appropriate military and civilian personnel of foreign countries for the purpose of enhancing the nonproliferation and export control capabilities of such personnel through their attendance in special courses of instruction conducted by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f982e3c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–2a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of courses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall have overall responsibility for the development and conduct of international nonproliferation education and training programs under this section, and may utilize other departments and agencies of the United States, as appropriate, to recommend personnel for the education and training and to administer specific courses of instruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f982e3d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–2a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Education and training activities conducted under this section shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f982e3e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–2a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a technical nature, emphasizing techniques for detecting, deterring, monitoring, interdicting, and countering proliferation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e3f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–2a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to encourage effective and mutually beneficial relations and increased understanding between the United States and friendly countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f982e40-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–2a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to improve the ability of friendly countries to utilize their resources with maximum effectiveness, thereby contributing to greater self-reliance by such countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f982e41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349bb–2a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority to certain countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting personnel for education and training pursuant to this section, priority should be given to personnel from countries determined by the Secretary of State to be countries frequently transited by proliferation-related shipments of cargo.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f982e42-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 584, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXIII/s1303/2"},"text":"Pub. L. 107–228, div. B, title XIII, § 1303(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1436"},"text":"116 Stat. 1436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f982e43-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f982e44-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8f982e45-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s584"},"text":"section 584 of Pub. L. 87–195","children":[],"tail":" was renumbered section 585 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349bb–3"},"text":"section 2349bb–3 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
