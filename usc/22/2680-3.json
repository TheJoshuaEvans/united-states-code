{"tag":"section","attrib":{"id":"id8ff2d1a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"2680–3"},"text":"§ 2680–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsiveness to Congressional Research Service inquiries and Congressional Budget Office inquiries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff2d1aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congressional Research Service and the Congressional Budget Office are charged with rendering effective and efficient service to Congress and responding expeditiously, effectively, and efficiently to the needs of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff2d1ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and Administrator shall ensure that for any inquiry or request from the Congressional Research Service or the Congressional Budget Office—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff51a9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an initial substantive response to the request is sent within 14 days of receipt of the inquiry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51a9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete answer responsive to the request is sent within 90 days of receipt of the inquiry, together with an explanation as to why the request was delayed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff51a9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–3/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congressional Research Service and Congressional Budget Office staff shall be treated as congressional staff for any briefings or informal discussions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff51a9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2680–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to disclose unclassified information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Administrator shall not refuse to provide information to the Congressional Research Service or the Congressional Budget Office on the basis that the Secretary or the Administrator deems such information to be sensitive but unclassified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff51aa0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXII/s7209"},"text":"Pub. L. 118–159, div. G, title LXXII, § 7209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2532"},"text":"138 Stat. 2532","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff51aa1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff51aa2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8ff51aa3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary” and “Administrator” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7002"},"text":"section 7002 of Pub. L. 118–159","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
