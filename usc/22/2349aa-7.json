{"tag":"section","attrib":{"id":"id8f95bce4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"2349aa–7"},"text":"§ 2349aa–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of all United States terrorism-related assistance to foreign countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f95bce5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall be responsible for coordinating all assistance related to international terrorism which is provided by the United States Government to foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f95bce6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLI/s5114/b/6"},"text":"Pub. L. 117–81, div. E, title LI, § 5114(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2352"},"text":"135 Stat. 2352","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f95bce7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349aa–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing contained in this section shall be construed to limit or impair the authority or responsibility of any other Federal agency with respect to law enforcement, domestic security operations, or intelligence activities as defined in Executive Order 12333.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f95bce8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/tV/s502"},"text":"Pub. L. 99–83, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/220"},"text":"99 Stat. 220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/399/tV/s503"},"text":"Pub. L. 99–399, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/871"},"text":"100 Stat. 871","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLI/s5114/b/6"},"text":"Pub. L. 117–81, div. E, title LI, § 5114(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2352"},"text":"135 Stat. 2352","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f95bce9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f95bcea-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f95bceb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 12333, referred to in subsec. (c), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f95bcec-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the International Security and Development Cooperation Act of 1985, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f95bced-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" struck out subsec. (b). Prior to amendment, text read as follows: “Not later than February 1 each year, the Secretary of State, in consultation with appropriate United States Government agencies, shall report to the appropriate committees of the Congress on the assistance related to international terrorism which was provided by the United States Government during the preceding fiscal year. Such reports may be provided on a classified basis to the extent necessary, and shall specify the amount and nature of the assistance provided.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/s503/1"},"text":"Pub. L. 99–399, § 503(1)","children":[],"tail":", substituted “terrorism-related” for “anti-terrorism” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/s503/2"},"text":"Pub. L. 99–399, § 503(2)","children":[],"tail":", substituted “assistance related to international terrorism which is provided by the United States Government to foreign countries” for “anti-terrorism assistance to foreign countries provided by the United States Government”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/s503/3"},"text":"Pub. L. 99–399, § 503(3)","children":[],"tail":", substituted “assistance related to international terrorism which was” for “anti-terrorism assistance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/s503/4"},"text":"Pub. L. 99–399, § 503(4)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f95bcee-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8f95bcef-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1301"},"text":"section 1301 of Pub. L. 99–83","children":[],"tail":", set out as an Effective Date of 1985 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151–1"},"text":"section 2151–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
