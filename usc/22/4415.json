{"tag":"section","attrib":{"id":"id907a9e9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4415"},"text":null,"children":[{"tag":"num","attrib":{"value":"4415"},"text":"§ 4415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Freedom of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id907a9e9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4415/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with Freedom of Information Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the fact that the Endowment is not an agency or establishment of the United States Government, the Endowment shall fully comply with all of the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907a9e9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4415/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication in Federal Register","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of complying pursuant to subsection (a) with section 552(a)(1) of such title, the Endowment shall make available to the Director of the United States Information Agency such records and other information as the Director determines may be necessary for such purposes. The Director shall cause such records and other information to be published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id907a9ea0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4415/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review by United States Information Agency","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id907a9ea1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4415/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event that the Endowment determines not to comply with a request for records under section 552, the Endowment shall submit a report to the Director of the United States Information Agency explaining the reasons for not complying with such request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907a9ea2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4415/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Director approves the determination not to comply with such request, the United States Information Agency shall assume full responsibility, including financial responsibility, for defending the Endowment in any litigation relating to such request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id907a9ea3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4415/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Director disapproves the determination not to comply with such request, the Endowment shall comply with such request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id907a9ea4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164/tV/s506"},"text":"Pub. L. 98–164, title V, § 506","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/93/tII/s210/a"},"text":"Pub. L. 99–93, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/432"},"text":"99 Stat. 432","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907a9ea5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id907a9ea6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id907a9ea7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"United States Information Agency (other than Broadcasting Board of Governors and International Broadcasting Bureau) abolished and functions transferred to Secretary of State, see sections 6531 and 6532 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
