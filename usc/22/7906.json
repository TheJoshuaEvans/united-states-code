{"tag":"section","attrib":{"id":"id90f1f23c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906"},"text":null,"children":[{"tag":"num","attrib":{"value":"7906"},"text":"§ 7906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology demonstration projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f1f23d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State, in coordination with the Secretary of Energy and the Administrator of the United States Agency for International Development, shall promote the adoption of technologies and practices that reduce greenhouse gas intensity in developing countries in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f1f23e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f1f23f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretaries and the Administrator shall plan, coordinate, and carry out, or provide assistance for the planning, coordination, or carrying out of, demonstration projects under this section in at least 10 eligible countries, as determined by the Secretaries and the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f240-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A country shall be eligible for assistance under this subsection if the Secretaries and the Administrator determine that the country has demonstrated a commitment to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f1f241-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" just governance, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90f1f242-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the rule of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f1f243-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respecting human and civil rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f1f244-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting private property rights; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f1f245-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combating corruption; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f1f246-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" economic freedom, including economic policies that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90f1f247-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage citizens and firms to participate in global trade and international capital markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f1f248-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote private sector growth and the sustainable management of natural resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90f1f249-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen market forces in the economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f24a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining which eligible countries to provide assistance to under paragraph (1), the Secretaries and the Administrator shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f1f24b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opportunity to reduce greenhouse gas intensity in the eligible country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f1f24c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the opportunity to generate economic growth in the eligible country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f24d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Demonstration projects under this section may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f1f24e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coal gasification, coal liquefaction, and clean coal projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f1f24f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carbon sequestration projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f1f250-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cogeneration technology initiatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f1f251-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renewable projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f1f252-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7906/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lower emission transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f1f253-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/240/tVII/s736"},"text":"Pub. L. 101–240, title VII, § 736","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXVI/s1611"},"text":"Pub. L. 109–58, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1116"},"text":"119 Stat. 1116","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90f1f254-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90f1f255-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90f1f256-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"Oct. 1, 2005","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/s739"},"text":"section 739 of Pub. L. 101–240","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7901"},"text":"section 7901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
