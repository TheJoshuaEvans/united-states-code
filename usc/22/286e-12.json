{"tag":"section","attrib":{"id":"id8ec3edf2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–12"},"text":"§ 286e–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution to Interest Subsidy Account of Enhanced Structural Adjustment Facility of International Monetary Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ec3edf3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contribution authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ec3edf4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–12/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the United States Governor of the Fund may contribute $150,000,000 to the Interest Subsidy Account of the Enhanced Structural Adjustment Facility of the Fund on behalf of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ec3edf5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–12/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund may not make a commitment to contribute any amount authorized to be contributed under paragraph (1) before an amount equal to such amount has been appropriated for such purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ec3edf6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To pay for the contribution authorized by subsection (a), there are authorized to be appropriated not to exceed $150,000,000, without fiscal year limitation, for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ec3edf7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s54"},"text":"July 31, 1945, ch. 339, § 54","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tIII/s301"},"text":"Pub. L. 101–240, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2500"},"text":"103 Stat. 2500","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
