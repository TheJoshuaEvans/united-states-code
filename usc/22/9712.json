{"tag":"section","attrib":{"id":"id914a23d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9712"},"text":null,"children":[{"tag":"num","attrib":{"value":"9712"},"text":"§ 9712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for efforts at the United Nations on the humanitarian crisis in Venezuela","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id914a23d2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that the United Nations humanitarian agencies should conduct and publish independent assessments of the humanitarian situation in Venezuela, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a23d3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9712/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent and impact of the shortages of food, medicine, and medical supplies in Venezuela;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a23d4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9712/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic health indicators in Venezuela, such as maternal and child mortality rates and the prevalence and treatment of communicable diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a23d5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9712/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts needed to resolve the shortages identified in paragraph (1) and to improve the health indicators referred to in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id914a23d6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United Nations Resident Coordinator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President should instruct the Permanent Representative to the United Nations to use the voice, vote, and influence of the United States at the United Nations to support the efforts of the Resident Coordinator for Venezuela in a manner that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id914a23d7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9712/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contributes to Venezuela’s long-term recovery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id914a23d8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9712/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advances humanitarian efforts in Venezuela and for Venezuelans residing in neighboring countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id914a23d9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dJ/tI/s122"},"text":"Pub. L. 116–94, div. J, title I, § 122","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3033"},"text":"133 Stat. 3033","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
