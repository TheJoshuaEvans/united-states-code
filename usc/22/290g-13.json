{"tag":"section","attrib":{"id":"id8ede2cae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–13"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–13"},"text":"§ 290g–13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authorization for payment of United States contribution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ede2caf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–13/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ede2cb0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–13/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Fund is authorized to contribute $225,000,000 to the fourth replenishment of the resources of the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ede2cb1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–13/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any commitment to make the contribution authorized in paragraph (1) shall be made subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ede2cb2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–13/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in this section, there are authorized to be appropriated, without fiscal year limitation, $225,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ede2cb3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s214"},"text":"Pub. L. 94–302, title II, § 214","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/190/s101/i/tI"},"text":"Pub. L. 99–190, § 101(i) [title I, (a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-19"},"text":"Dec. 19, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1291"},"text":"99 Stat. 1291","children":[],"tail":", 1294.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ede2cb4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ede2cb5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ede2cb6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/s214"},"text":"Section 214 of Pub. L. 94–302","children":[],"tail":" is based on section 201 of title II of H.R. 2253, Ninety-ninth Congress, as reported "},{"tag":"date","attrib":{"date":"1985-05-15"},"text":"May 15, 1985","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/99/190"},"text":"Pub. L. 99–190","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
