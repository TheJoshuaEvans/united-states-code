{"tag":"section","attrib":{"id":"id8f0dc7db-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1622f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1622f"},"text":"§ 1622f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support and services to Foreign Claims Settlement Commission of the United States by Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Attorney General shall provide necessary administrative support and services to the Commission. The Chairman shall prepare the budget requests, authorization documents, and legislative proposals for the Commission within the procedures established by the Department of Justice, and the Attorney General shall submit these items to the Director of the Office of Management and Budget as proposed by the Chairman.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f0dc7dc-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/209/tI/s106"},"text":"Pub. L. 96–209, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-14"},"text":"Mar. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/97"},"text":"94 Stat. 97","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f0dc7dd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f0dc7de-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f0dc7df-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the International Claims Settlement Act of 1949 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f0dc7e0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8f0dc7e1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-03-14"},"text":"Mar. 14, 1980","children":[],"tail":", see title VI of "},{"tag":"ref","attrib":{"href":"/us/pl/96/209"},"text":"Pub. L. 96–209","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1622a"},"text":"section 1622a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
