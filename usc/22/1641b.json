{"tag":"section","attrib":{"id":"id8f12a9c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1641b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1641b"},"text":"§ 1641b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claims of nationals of the United States against Bulgaria, Hungary, and Rumania","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission shall receive and determine in accordance with applicable substantive law, including international law, the validity and amounts of claims of nationals of the United States against the Governments of Bulgaria, Hungary, and Rumania, or any of them, arising out of the failure to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f12a9c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1641b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restore or pay compensation for property of nationals of the United States as required by article 23 of the treaty of peace with Bulgaria, articles 26 and 27 of the treaty of peace with Hungary, and articles 24 and 25 of the treaty of peace with Rumania. Awards under this paragraph shall be in amounts not to exceed two-thirds of the loss or damage actually sustained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f12a9c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1641b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay effective compensation for the nationalization, compulsory liquidation, or other taking, prior to ","children":[{"tag":"date","attrib":{"date":"1955-08-09"},"text":"August 9, 1955","children":[],"tail":", of property of nationals of the United States in Bulgaria, Hungary, and Rumania;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f12a9c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1641b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet obligations expressed in currency of the United States arising out of contractual or other rights acquired by nationals of the United States prior to ","children":[{"tag":"date","attrib":{"date":"1941-04-24"},"text":"April 24, 1941","children":[],"tail":", in the case of Bulgaria, and prior to "},{"tag":"date","attrib":{"date":"1939-09-01"},"text":"September 1, 1939","children":[],"tail":", in the case of Hungary and Rumania, and which became payable prior to "},{"tag":"date","attrib":{"date":"1947-09-15"},"text":"September 15, 1947","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f12a9ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1641b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay effective compensation for the nationalization, compulsory liquidation, or other taking of property of nationals of the United States in Bulgaria and Rumania, between ","children":[{"tag":"date","attrib":{"date":"1955-08-09"},"text":"August 9, 1955","children":[],"tail":", and the effective date of the claims agreement between the respective country and the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f12a9cb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1641b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay effective compensation for the nationalization, compulsory liquidation, or other taking of property of nationals of the United States in Hungary, between ","children":[{"tag":"date","attrib":{"date":"1955-08-09"},"text":"August 9, 1955","children":[],"tail":", and the date the United States-Hungarian Claims Agreement of "},{"tag":"date","attrib":{"date":"1973-03-06"},"text":"March 6, 1973","children":[],"tail":", enters into force."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f12a9cc-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title III, § 303, as added "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-09/ch645/s3"},"text":"Aug. 9, 1955, ch. 645, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/571"},"text":"69 Stat. 571","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/90/421/s1/9"},"text":"Pub. L. 90–421, § 1(9)","children":[],"tail":", (10), "},{"tag":"date","attrib":{"date":"1968-07-24"},"text":"July 24, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/422"},"text":"82 Stat. 422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/460/s1/2"},"text":"Pub. L. 93–460, § 1(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1974-10-20"},"text":"Oct. 20, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1386"},"text":"88 Stat. 1386","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f12a9cd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f12a9ce-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f12a9cf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/460/s1/3"},"text":"Pub. L. 93–460, § 1(3)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/421/s1/10"},"text":"Pub. L. 90–421, § 1(10)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
