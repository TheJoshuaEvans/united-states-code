{"tag":"section","attrib":{"id":"id8f851b75-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2295c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2295c"},"text":"§ 2295c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f851b76-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2295c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this part, there are authorized to be appropriated to the President for fiscal year 1993 $410,000,000, in addition to amounts otherwise available for assistance for the independent states of the former Soviet Union. Amounts appropriated pursuant to this subsection are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f851b77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2295c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f851b78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2295c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to transfer program funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), funds made available under subsection (a) may be transferred to, and merged with, funds appropriated for “Operating Expenses of the Agency for International Development”. Funds so transferred may be expended for administrative costs in carrying out this part, including reimbursement of the Department of State for its incremental costs associated with assistance provided under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f851b79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2295c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on amount transferred","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 2 percent of the funds made available for a fiscal year under subsection (a) may be transferred pursuant to paragraph (1) unless, at least 15 days before transferring any additional amount, the President notifies the appropriate congressional committees in accordance with the procedures applicable to reprogramming notifications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394–1"},"text":"section 2394–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f851b7a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 498C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/511/tII/s201"},"text":"Pub. L. 102–511, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3330"},"text":"106 Stat. 3330","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f851b7b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f851b7c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f851b7d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions of President under subsec. (b)(2), see section 3(b) of Ex. Ord. No. 12884, ","children":[{"tag":"date","attrib":{"date":"1993-12-01"},"text":"Dec. 1, 1993","children":[],"tail":", 58 F.R. 64099, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s5812"},"text":"section 5812 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
