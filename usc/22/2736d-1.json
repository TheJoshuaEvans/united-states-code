{"tag":"section","attrib":{"id":"id90037356-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736d–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2736d–1"},"text":"§ 2736d–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donald M. Payne International Development Fellowship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90037357-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736d–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department a Donald M. Payne International Development Fellowship Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90037358-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736d–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program required by subsection (a) shall continue to provide financial assistance, mentoring, and professional development opportunities to individuals pursuing careers in international development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90037359-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736d–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program required by subsection (a) shall be administered by the Department, consistent with existing law and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9003735a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dE/tI/s5136"},"text":"Pub. L. 119–60, div. E, title I, § 5136","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1568"},"text":"139 Stat. 1568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9003735b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9003735c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id9003735d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Department” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s5002"},"text":"section 5002 of Pub. L. 119–60","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
