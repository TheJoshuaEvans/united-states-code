{"tag":"section","attrib":{"id":"id8efab5b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1386"},"text":null,"children":[{"tag":"num","attrib":{"value":"1386"},"text":"§ 1386.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this subchapter the term “Philippine Government” shall mean “Government of the Commonwealth of the Philippines” until the date of independence, and thereafter it shall mean the “Government of the Republic of the Philippines”.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8efab5b4-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-03/ch536/s7"},"text":"July 3, 1946, ch. 536, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/420"},"text":"60 Stat. 420","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8efab5b5-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8efab5b6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8efab5b7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Date of independence, referred to in text, was ","children":[{"tag":"date","attrib":{"date":"1946-07-04"},"text":"July 4, 1946","children":[],"tail":" as recognized by 1946 Proc. No. 2695, eff. "},{"tag":"date","attrib":{"date":"1946-07-04"},"text":"July 4, 1946","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/