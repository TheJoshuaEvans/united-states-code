{"tag":"section","attrib":{"id":"id8ee558ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"290m–7"},"text":"§ 290m–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First capital increase","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ee558ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscription authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ee558ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–7/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury is authorized to subscribe on behalf of the United States to, and make payment for, 150,000 additional shares of the capital stock of the Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee558f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–7/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any subscription by the United States to the capital stock of the Bank shall be effective only to such extent and in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee558f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ee558f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–7/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the increase in the United States subscription to the Bank under subsection (a), there are authorized to be appropriated, without fiscal year limitation, $1,500,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee558f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–7/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amount authorized to be appropriated under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ee558f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–7/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $225,000,000 shall be for paid in shares of the Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ee558f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290m–7/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,275,000,000 shall be for callable shares of the Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee558f6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/182/tV/s547"},"text":"Pub. L. 103–182, title V, § 547","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVIII/s831"},"text":"Pub. L. 116–113, title VIII, § 831","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/96"},"text":"134 Stat. 96","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tVI/s601"},"text":"Pub. L. 116–113, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/78"},"text":"134 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tVI/s601/a/1"},"text":"Pub. L. 116–260, div. O, title VI, § 601(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2149"},"text":"134 Stat. 2149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ee558f7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ee558f8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ee558f9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s601/a/1"},"text":"Pub. L. 116–260, § 6