{"tag":"section","attrib":{"id":"id8ebf32ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"285ee"},"text":"§ 285ee.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fifth capital increase","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf3300-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285ee/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscription authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ebf3301-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285ee/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank may subscribe on behalf of the United States to 1,104,420 additional shares of the capital stock of the Bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ebf3302-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285ee/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any subscription by the United States to capital stock of the Bank shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf3303-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285ee/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ebf3304-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285ee/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the increase in the United States subscription to the Bank provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $13,323,173,083, for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ebf3305-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285ee/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Of the amount authorized to be appropriated under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ebf3306-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285ee/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $532,929,240 is authorized to be appropriated for paid-in shares of the Bank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ebf3307-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285ee/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $12,790,243,843 is authorized to be appropriated for callable shares of the Bank, for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf3308-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s34"},"text":"Pub. L. 89–369, § 34","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/10/dB/tXI/s2126/e"},"text":"Pub. L. 112–10, div. B, title XI, § 2126(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-04-15"},"text":"Apr. 15, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/191"},"text":"125 Stat. 191","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
