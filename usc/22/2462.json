{"tag":"section","attrib":{"id":"id8fc7c8f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2462"},"text":null,"children":[{"tag":"num","attrib":{"value":"2462"},"text":"§ 2462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of grant program for foreign study by American college students of limited financial means","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fc7c8f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2462/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations and under the authorities of the Mutual Educational and Cultural Exchange Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"22 U.S.C. 2451","children":[],"tail":" et seq.], the Secretary of State shall establish and carry out a program in each fiscal year to award grants of up to $5,000, to individuals who meet the requirements of subsection (b), toward the cost of up to one academic year of undergraduate study abroad. Grants under this Act shall be known as the “Benjamin A. Gilman International Scholarships”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc7c8f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2462/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual referred to in subsection (a) is an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fc7c8f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2462/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a student in good standing at an institution of higher education in the United States (as defined in section 101(a) of the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"20 U.S.C. 1001(a)","children":[],"tail":"]);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc7c8f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2462/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been accepted for up to one academic year of study on a program of study abroad approved for credit by the student’s home institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc7c8f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2462/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is receiving any need-based student assistance under title IV of the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"20 U.S.C. 1070","children":[],"tail":" et seq.]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc7c8f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2462/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a citizen or national of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc7c8f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2462/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application and selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fc7c8f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2462/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grant application and selection shall be carried out through accredited institutions of higher education in the United States or a combination of such institutions under such procedures as are established by the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc7c8fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2462/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In considering applications for grants under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fc7c8fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2462/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of financial need shall include the increased costs of study abroad; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fc7c8fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2462/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priority consideration shall be given to applicants who are receiving Federal Pell Grants under title IV of the Higher Education Act of 1965 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1070"},"text":"20 U.S.C. 1070","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fc7c8fd-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/309/tIII/s303"},"text":"Pub. L. 106–309, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1095"},"text":"114 Stat. 1095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fc7c8fe-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fc7c8ff-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8fc7c900-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Mutual Educational and Cultural Exchange Act of 1961, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/256"},"text":"Pub. L. 87–256","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-21"},"text":"Sept. 21, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/527"},"text":"75 Stat. 527","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"section 2451 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), probably means title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/309"},"text":"Pub. L. 106–309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1094"},"text":"114 Stat. 1094","children":[],"tail":", known as the International Academic Opportunity Act of 2000, which enacted this section and provisions set out as notes under this section. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Higher Education Act of 1965, referred to in subsecs. (b)(3) and (c)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/329"},"text":"Pub. L. 89–329","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-08"},"text":"Nov. 8, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1219"},"text":"79 Stat. 1219","children":[],"tail":". Title IV of the Act is classified generally to subchapter IV (§ 1070 et seq.) of chapter 28 of Title 20, Education. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of Title 20","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8fc7c901-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the International Academic Opportunity Act of 2000, and also as part of the Microenterprise for Self-Reliance and International Anti-Corruption Act of 2000, and not as part of the Mutual Educational and Cultural Exchange Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fc7c902-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8fc7c903-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"International Academic Opportunity","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/309/tIII"},"text":"Pub. L. 106–309, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1094"},"text":"114 Stat. 1094","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCVII/s9716/e"},"text":"Pub. L. 117–263, div. I, title XCVII, § 9716(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3922"},"text":"136 Stat. 3922","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dI/tXCVII/s9716/e"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"301"},"text":"“SEC. 301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This title [enacting this section and this note] may be cited as the ‘International Academic Opportunity Act of 2000’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"302"},"text":"“SEC. 302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" STATEMENT OF PURPOSE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“It is the purpose of this title to establish an undergraduate grant program for students of limited financial means from the United States to enable such students to study abroad. Such foreign study is intended to broaden the outlook and better prepare such students of demonstrated financial need to assume significant roles in the increasingly global economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"303"},"text":"“SEC. 303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ESTABLISHMENT OF GRANT PROGRAM FOR FOREIGN STUDY BY AMERICAN COLLEGE STUDENTS OF LIMITED FINANCIAL MEANS.","children":[],"tail":null},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8fc7c904-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“[Enacted this section.]","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{"status":"repealed"},"text":null,"children":[{"tag":"num","attrib":{"value":"304"},"text":"“[SEC. 304.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCVII/s9716/e"},"text":"Pub. L. 117–263, div. I, title XCVII, § 9716(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3922"},"text":"136 Stat. 3922","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"305"},"text":"“SEC. 305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AUTHORIZATION OF APPROPRIATIONS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“There are authorized to be appropriated $1,500,000 for each fiscal year to carry out this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"306"},"text":"“SEC. 306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EFFECTIVE DATE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This title shall take effect ","children":[{"tag":"date","attrib":{"date":"2000-10-01"},"text":"October 1, 2000","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
