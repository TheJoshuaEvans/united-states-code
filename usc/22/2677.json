{"tag":"section","attrib":{"id":"id8ff2d13b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2677"},"text":null,"children":[{"tag":"num","attrib":{"value":"2677"},"text":"§ 2677.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds for travel expenses and transportation of personal effects, household goods, or automobiles","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriated funds made available to the Department of State for expenses in connection with travel of personnel outside the continental United States, including travel of dependents and transportation of personal effects, household goods, or automobiles of such personnel shall be available for such expenses when any part of such travel or transportation begins in one fiscal year pursuant to travel orders issued in that year, notwithstanding the fact that such travel or transportation may not be completed during that same fiscal year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ff2d13c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 10, "},{"tag":"ref","attrib":{"href":"/us/stat/70/891"},"text":"70 Stat. 891","children":[],"tail":"; renumbered title I, "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tII/s202/a"},"text":"Pub. L. 97–241, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/282"},"text":"96 Stat. 282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff2d13d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff2d13e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ff2d13f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to section 170","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of Title 5 prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
