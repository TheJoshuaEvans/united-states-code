{"tag":"section","attrib":{"id":"id8f28072f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1944"},"text":null,"children":[{"tag":"num","attrib":{"value":"1944"},"text":"§ 1944.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconstruction assistance in Chile; authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the President not to exceed $100,000,000, which shall remain available until expended, for use, in addition to other funds available for such purposes, in the reconstruction and rehabilitation of Chile on such terms and conditions as the President may specify.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f280730-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/735/s3"},"text":"Pub. L. 86–735, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-09-08"},"text":"Sept. 8, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/870"},"text":"74 Stat. 870","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f280731-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f280732-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f280733-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was not enacted as part of the Mutual Security Act of 1954 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f280734-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f280735-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions of President under this section, see Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2001-05-30"},"text":"May 30, 2001","children":[],"tail":", 66 F.R. 30629, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1942"},"text":"section 1942 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
