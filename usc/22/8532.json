{"tag":"section","attrib":{"id":"id91029426-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532"},"text":null,"children":[{"tag":"num","attrib":{"value":"8532"},"text":"§ 8532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of State and local governments to divest from certain companies that invest in Iran","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91029427-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the United States should support the decision of any State or local government that for moral, prudential, or reputational reasons divests from, or prohibits the investment of assets of the State or local government in, a person that engages in investment activities in the energy sector of Iran, as long as Iran is subject to economic sanctions imposed by the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91029428-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to divest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, a State or local government may adopt and enforce measures that meet the requirements of subsection (d) to divest the assets of the State or local government from, or prohibit investment of the assets of the State or local government in, any person that the State or local government determines, using credible information available to the public, engages in investment activities in Iran described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91029429-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment activities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person engages in investment activities in Iran described in this subsection if the person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9102942a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an investment of $20,000,000 or more in the energy sector of Iran, including in a person that provides oil or liquified natural gas tankers, or products used to construct or maintain pipelines used to transport oil or liquified natural gas, for the energy sector of Iran; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9102942b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a financial institution that extends $20,000,000 or more in credit to another person, for 45 days or more, if that person will use the credit for investment in the energy sector of Iran.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9102942c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any measure taken by a State or local government under subsection (b) shall meet the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9102942d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State or local government shall provide written notice to each person to which a measure is to be applied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9102942e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The measure shall apply to a person not earlier than the date that is 90 days after the date on which written notice is provided to the person under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9102942f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity for hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State or local government shall provide an opportunity to comment in writing to each person to which a measure is to be applied. If the person demonstrates to the State or local government that the person does not engage in investment activities in Iran described in subsection (c), the measure shall not apply to the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91029430-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress on avoiding erroneous targeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that a State or local government should not adopt a measure under subsection (b) with respect to a person unless the State or local government has made every effort to avoid erroneously targeting the person and has verified that the person engages in investment activities in Iran described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91029431-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Department of Justice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after adopting a measure pursuant to subsection (b), a State or local government shall submit written notice to the Attorney General describing the measure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91029432-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonpreemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A measure of a State or local government authorized under subsection (b) or (i) is not preempted by any Federal law or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91029433-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91029434-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assets","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91029435-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term “assets” refers to public monies and includes any pension, retirement, annuity, or endowment fund, or similar instrument, that is controlled by a State or local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91029436-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “assets” does not include employee benefit plans covered by title I of the Employee Retirement Income Security Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1001"},"text":"29 U.S.C. 1001","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91029437-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The “investment” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91029438-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commitment or contribution of funds or property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91029439-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan or other extension of credit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9102943a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entry into or renewal of a contract for goods or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9102943b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9102943c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2) or subsection (i), this section applies to measures adopted by a State or local government before, on, or after ","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9102943d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (i), subsections (d) and (e) apply to measures adopted by a State or local government on or after ","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9102943e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for prior enacted measures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9102943f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section or any other provision of law, a State or local government may enforce a measure (without regard to the requirements of subsection (d), except as provided in paragraph (2)) adopted by the State or local government before ","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", that provides for the divestment of assets of the State or local government from, or prohibits the investment of the assets of the State or local government in, any person that the State or local government determines, using credible information available to the public, engages in investment activities in Iran (determined without regard to subsection (c)) or other business activities in Iran that are identified in the measure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91029440-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of notice requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A measure described in paragraph (1) shall be subject to the requirements of paragraphs (1) and (2) and the first sentence of paragraph (3) of subsection (d) on and after the date that is 2 years after ","children":[{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91029441-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8532/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this Act or any other provision of law authorizing sanctions with respect to Iran shall be construed to abridge the authority of a State to issue and enforce rules governing the safety, soundness, and solvency of a financial institution subject to its jurisdiction or the business of insurance pursuant to the Act of ","children":[{"tag":"date","attrib":{"date":"1945-03-09"},"text":"March 9, 1945","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1011"},"text":"15 U.S.C. 1011","children":[],"tail":" et seq.) (commonly known as the “McCarran-Ferguson Act”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91029442-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195/tII/s202"},"text":"Pub. L. 111–195, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1342"},"text":"124 Stat. 1342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/158/tII/s222/b"},"text":"Pub. L. 112–158, title II, § 222(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1239"},"text":"126 Stat. 1239","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91029443-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id91029444-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s8551/a"},"text":"section 8551(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91029445-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id91029446-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Employee Retirement Income Security Act of 1974, referred to in subsec. (g)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/406"},"text":"Pub. L. 93–406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-02"},"text":"Sept. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/829"},"text":"88 Stat. 829","children":[],"tail":". Title I of the Act is classified generally to subchapter I (§ 1001 et seq.) of chapter 18 of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1001"},"text":"section 1001 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (j), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/195"},"text":"Pub. L. 111–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-01"},"text":"July 1, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1312"},"text":"124 Stat. 1312","children":[],"tail":", which enacted this chapter, amended sections 287c, 2778, and 2780 of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–13"},"text":"section 80a–13 of Title 15","children":[],"tail":", Commerce and Trade, "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s310"},"text":"section 310 of Title 31","children":[],"tail":", Money and Finance, and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4315"},"text":"section 4315 of Title 50","children":[],"tail":", War and National Defense, enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s80a–13"},"text":"section 80a–13 of Title 15","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":", and amended provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8501"},"text":"section 8501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1945-03-09"},"text":"March 9, 1945","children":[],"tail":", referred to in subsec. (j), is "},{"tag":"ref","attrib":{"href":"/us/act/1945-03-09/ch20"},"text":"act Mar. 9, 1945, ch. 20","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/33"},"text":"59 Stat. 33","children":[],"tail":", popularly known as the McCarran-Ferguson Act, which is classified generally to chapter 20 (§ 1011 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1011"},"text":"section 1011 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id91029447-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158"},"text":"Pub. L. 112–158","children":[],"tail":" added subsec. (j)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
