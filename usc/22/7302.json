{"tag":"section","attrib":{"id":"id90dc6df4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302"},"text":null,"children":[{"tag":"num","attrib":{"value":"7302"},"text":"§ 7302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the Diplomatic Telecommunications Service Governance Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90dc6df5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governance Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dc6df6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Diplomatic Telecommunications Service Governance Board to direct and oversee the activities and performance of the DTS–PO.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6df7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Agent.—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90dc6df8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Management and Budget shall designate, from among the departments and agencies of the United States Government that use the DTS Network, a department or agency as the DTS–PO Executive Agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6df9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Agent designated under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90dc6dfa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nominate a Director of the DTS–PO for approval by the Governance Board in accordance with subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90dc6dfb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other duties as established by the Governance Board in the determination of written implementing arrangements and other relevant and appropriate governance processes and procedures under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6dfc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for implementing arrangements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the requirements of this chapter, the Governance Board shall determine the written implementing arrangements and other relevant and appropriate governance processes and procedures to manage, oversee, resource, or otherwise administer the DTS–PO.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6dfd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dc6dfe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office of Management and Budget shall designate from among the departments and agencies that use the DTS Network—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90dc6dff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four departments and agencies to each appoint one voting member of the Governance Board from the personnel of such departments and agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6e00-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other departments and agencies that the Director considers appropriate to each appoint one nonvoting member of the Governance Board from the personnel of such departments and agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6e01-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting and nonvoting members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Governance Board shall consist of voting members and nonvoting members as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90dc6e02-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The voting members shall consist of a Chair, who shall be designated by the Director of the Office of Management and Budget, and the four members appointed by departments and agencies designated under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90dc6e03-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonvoting members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The nonvoting members shall consist of the members appointed by departments and agencies designated under paragraph (1)(B) and shall act in an advisory capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6e04-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair duties and authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chair of the Governance Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dc6e05-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preside over all meetings and deliberations of the Governance Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6e06-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the Secretariat functions of the Governance Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6e07-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" propose bylaws governing the operation of the Governance Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6e08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum, decisions, meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A quorum of the Governance Board shall consist of the presence of the Chair and four voting members. The decisions of the Governance Board shall require a majority of the voting membership. The Chair shall convene a meeting of the Governance Board not less than four times each year to carry out the functions of the Governance Board. The Chair or any voting member may convene a meeting of the Governance Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6e09-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governance Board duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Governance Board shall have the following duties with respect to the DTS–PO:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90dc6e0a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To approve and monitor the plans, services, priorities, policies, and pricing methodology of the DTS–PO for bandwidth costs and projects carried out at the request of a department or agency that uses the DTS Network.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6e0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide to the DTS–PO Executive Agent the recommendation of the Governance Board with respect to the approval, disapproval, or modification of each annual budget request for the DTS–PO, prior to the submission of any such request by the Executive Agent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6e0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To review the performance of the DTS–PO against plans approved under paragraph (1) and the management activities and internal controls of the DTS–PO.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6e0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To require from the DTS–PO any plans, reports, documents, and records the Governance Board considers necessary to perform its oversight responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6e0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To conduct and evaluate independent audits of the DTS–PO.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6e0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To approve or disapprove the nomination of the Director of the DTS–PO by the Executive Agent with a majority vote of the Governance Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90dc6e10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To recommend to the Executive Agent the replacement of the Director of the DTS–PO with a majority vote of the Governance Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90dc6e11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7302/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governance Board shall ensure that those enhancements of, and the provision of service for, telecommunication capabilities that involve the national security interests of the United States receive the highest prioritization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90dc6e12-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/567/tIII/s322"},"text":"Pub. L. 106–567, title III, § 322","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tV/s501/a/1"},"text":"Pub. L. 111–259, title V, § 501(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2736"},"text":"124 Stat. 2736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90dc6e13-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90dc6e14-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id90dc6e15-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7302, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/567/tIII/s322"},"text":"Pub. L. 106–567, title III, § 322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-27"},"text":"Dec. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2843"},"text":"114 Stat. 2843","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tVIII/s811/b/5/E"},"text":"Pub. L. 107–306, title VIII, § 811(b)(5)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2425"},"text":"116 Stat. 2425","children":[],"tail":", which related to personnel, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tV/s501/a/1"},"text":"Pub. L. 111–259, title V, § 501(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2735"},"text":"124 Stat. 2735","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
