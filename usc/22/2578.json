{"tag":"section","attrib":{"id":"id8fd6215e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2578"},"text":null,"children":[{"tag":"num","attrib":{"value":"2578"},"text":"§ 2578.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiating records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fd6215f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2578/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall establish and maintain records for each arms control, nonproliferation, and disarmament agreement to which the United States is a party and which was under negotiation or in force on or after ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":", which shall include classified and unclassified materials such as instructions and guidance, position papers, reporting cables and memoranda of conversation, working papers, draft texts of the agreement, diplomatic notes, notes verbal, and other internal and external correspondence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fd62160-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2578/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negotiating and implementation records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In particular, the Secretary of State shall establish and maintain a negotiating and implementation record for each such agreement, which shall be comprehensive and detailed, and shall document all communications between the parties with respect to such agreement. Such records shall be maintained both in hard copy and magnetic media.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fd62161-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/297/tIII/s307"},"text":"Pub. L. 87–297, title III, § 307","children":[],"tail":", formerly § 38, as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVII/s713/a"},"text":"Pub. L. 103–236, title VII, § 713(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/496"},"text":"108 Stat. 496","children":[],"tail":"; renumbered § 307 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XII, § 1223(12), (21), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-770"},"text":"112 Stat. 2681–770","children":[],"tail":", 2681–772.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fd62162-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fd62163-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8fd62164-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2578, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/297/tIII/s38"},"text":"Pub. L. 87–297, title III, § 38","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/213/s3/b"},"text":"Pub. L. 100–213, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-24"},"text":"Dec. 24, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1445"},"text":"101 Stat. 1445","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/199/tIV/s401/a"},"text":"Pub. L. 103–199, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2324"},"text":"107 Stat. 2324","children":[],"tail":", related to reports on activities of Standing Consultative Commission, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVII/s704/2"},"text":"Pub. L. 103–236, title VII, § 704(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/492"},"text":"108 Stat. 492","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fd62165-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1223/12/A"},"text":"Pub. L. 105–277, § 1223(12)(A)","children":[],"tail":", substituted “Secretary of State” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1223/12/B"},"text":"Pub. L. 105–277, § 1223(12)(B)","children":[],"tail":", struck out heading and text of subsec. (c). Text read as follows: “In order to implement effectively this section, the Director shall ensure that Agency personnel participate throughout the negotiation and implementation phases of all arms control, nonproliferation, and disarmament agreements.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fd62166-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8fd62167-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-04-01"},"text":"Apr. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1201"},"text":"section 1201 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6511"},"text":"section 6511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
