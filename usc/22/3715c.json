{"tag":"section","attrib":{"id":"id9046483c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3715c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3715c"},"text":"§ 3715c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final evaluation of Fund; deficiency or surplus in Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9046483d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3715c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final evaluation of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"By ","children":[{"tag":"date","attrib":{"date":"1998-03-31"},"text":"March 31, 1998","children":[],"tail":", the Secretary of Labor shall, on the basis of an actuarial study conducted by experts or consultants whose services are procured by the Secretary of Labor by contract, make a final determination of the amounts estimated to be necessary to meet expenditures for workers’ compensation benefits and other payments described in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3715a/a"},"text":"section 3715a(a) of this title","children":[],"tail":", as calculated in accordance with the second sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3715a/b"},"text":"section 3715a(b) of this title","children":[],"tail":". Amounts in the Fund shall be used to pay for the final determination under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9046483e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3715c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deficiency or surplus in Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If amounts in the Fund are not sufficient to meet expenditures as determined by the Secretary of Labor under subsection (a) for workers’ compensation benefits and other payments described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3715a/a"},"text":"section 3715a(a) of this title","children":[],"tail":", then amounts in the Panama Canal Revolving Fund not otherwise obligated shall be transferred to the Fund to make up the deficiency. Any amounts remaining in the Fund in excess of the final determination amount as described in subsection (a) shall be transferred to the Panama Canal Revolving Fund, and may be used to satisfy lawful obligations of the Revolving Fund arising on or before "},{"tag":"date","attrib":{"date":"1999-12-31"},"text":"December 31, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9046483f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3715c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuity of Fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90464840-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3715c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the Fund (including amounts transferred as a result of the final determination made under subsection (a)) shall be maintained by the Secretary of the Treasury, shall be made available for transfer to the Employees’ Compensation Fund in such amounts as are requested by the Secretary of Labor pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3715b"},"text":"section 3715b of this title","children":[],"tail":", and may be discontinued only in accordance with paragraph (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90464841-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3715c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At such time as the Secretary of Labor certifies that no further liability exists for workers compensation benefits or other payments described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3715a/a"},"text":"section 3715a(a) of this title","children":[],"tail":", the Secretary of the Treasury may discontinue the Fund in the manner provided by law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90464842-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/705/s5"},"text":"Pub. L. 100–705, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-19"},"text":"Nov. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4686"},"text":"102 Stat. 4686","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dC/tXXXV/s3507"},"text":"Pub. L. 101–510, div. C, title XXXV, § 3507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1847"},"text":"104 Stat. 1847","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dC/tXXXV/s3545"},"text":"Pub. L. 105–85, div. C, title XXXV, § 3545","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2072"},"text":"111 Stat. 2072","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90464843-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90464844-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90464845-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Panama Canal Commission Compensation Fund Act of 1988, and not as part of the Panama Canal Act of 1979 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90464846-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" substituted “By "},{"tag":"date","attrib":{"date":"1998-03-31"},"text":"March 31, 1998","children":[],"tail":"” for “Upon the termination of the Panama Canal Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s3507/1"},"text":"Pub. L. 101–510, § 3507(1)","children":[],"tail":", struck out “Upon the termination of the Panama Canal Commission:” before subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s3507/2"},"text":"Pub. L. 101–510, § 3507(2)","children":[],"tail":", substituted “Upon the termination of the Panama Canal Commission, the Secretary of Labor” for “The Secretary of Labor” and struck out at end “The Secretary of the Treasury shall, in accordance with such final determination, transfer from the Fund to the Employee Compensation Fund amounts sufficient to meet expenditures for workers compensation benefits and other payments described in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3715a/a"},"text":"section 3715a(a) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s3507/3"},"text":"Pub. L. 101–510, § 3507(3)","children":[],"tail":", inserted “under subsection (a)” after “Secretary of Labor” and struck out “Employees Compensation” before “Fund to make up”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s3507/4"},"text":"Pub. L. 101–510, § 3507(4)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90464847-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90464848-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/705/s10"},"text":"section 10 of Pub. L. 100–705","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3612"},"text":"section 3612 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
