{"tag":"section","attrib":{"id":"id90416693-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3653"},"text":null,"children":[{"tag":"num","attrib":{"value":"3653"},"text":"§ 3653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment standards","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Commission shall establish written standards for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90416694-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3653/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the qualifications and fitness of employees and of candidates for employment in positions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90416695-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3653/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selecting individuals for appointment, promotion, or transfer to positions.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The standards shall conform to the provisions of this subpart, any regulations prescribed thereunder, and the Panama Canal Employment System.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90416696-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1213"},"text":"Pub. L. 96–70, title I, § 1213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/464"},"text":"93 Stat. 464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dC/tXXXV/s3531"},"text":"Pub. L. 104–201, div. C, title XXXV, § 3531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2863"},"text":"110 Stat. 2863","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90416697-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90416698-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90416699-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “The Commission” for “The head of each agency” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9041669a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9041669b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coordination of Pay and Employment Practices","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions requiring consultations with the Secretary of Defense for agencies under this subpart with respect to the establishment of rates of pay and other matters deemed appropriate by the Secretary in order to develop compatible or unified systems of basic pay and employment practices, see section 1–201 of Ex. Ord. No. 12215, ","children":[{"tag":"date","attrib":{"date":"1980-05-27"},"text":"May 27, 1980","children":[],"tail":", 45 F.R. 36043, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
