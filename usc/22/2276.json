{"tag":"section","attrib":{"id":"id8f7208af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2276"},"text":null,"children":[{"tag":"num","attrib":{"value":"2276"},"text":"§ 2276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Central American countries” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this part, the term “Central American countries” includes Belize, Costa Rica, El Salvador, Guatemala, Honduras, Nicaragua, Panama, and regional programs which benefit such countries.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f7208b0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 466, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tVII/s701"},"text":"Pub. L. 99–83, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/237"},"text":"99 Stat. 237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f7208b1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f7208b2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f7208b3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195/s466"},"text":"section 466 of Pub. L. 87–195","children":[],"tail":" is classified to "},{"tag":