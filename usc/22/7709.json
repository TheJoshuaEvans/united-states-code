{"tag":"section","attrib":{"id":"id90ed1037-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709"},"text":null,"children":[{"tag":"num","attrib":{"value":"7709"},"text":"§ 7709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional and public notification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ed1038-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional consultations and notifications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed1039-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board, acting through the Chief Executive Officer, shall consult with and notify the appropriate congressional committees not later than 15 days before taking any of the actions described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed103a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The actions described in this paragraph are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ed103b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing assistance for an eligible country under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7708/g"},"text":"section 7708(g) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed103c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" commencing negotiations with an eligible country to provide assistance for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90ed103d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Compact under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7704"},"text":"section 7704 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ed103e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7715"},"text":"section 7715 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed103f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" signing such a Compact or agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed1040-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminating assistance under such a Compact or agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1041-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic justification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any notification relating to the intent to negotiate or sign a Compact shall include a report describing the projected economic justification for the Compact, including, as applicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ed1042-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected economic rate of return of the Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed1043-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cost-benefit analysis of the Compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed1044-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the impact on beneficiary populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed1045-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood that the investment will catalyze private sector investments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed1046-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable economic factors that justify each project to be funded under such a Compact to the extent practicable and appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1047-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk management plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days before signing each concurrent Compact, as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7708"},"text":"section 7708 of this title","children":[],"tail":", the Board, acting through the Chief Executive Officer, shall consult with and provide to the appropriate congressional committees—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ed1048-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment and, as appropriate, the identification of potential measures to mitigate risks, of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90ed1049-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the countries’ commitment to regional integration and cross-border cooperation and capacity to carry out commitments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ed104a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" political and policy risks, including risks that could affect country eligibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ed104b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risks associated with realizing economic returns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ed104c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" time and completion risks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ed104d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost and financial risks; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed104e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of measures to be taken to mitigate any identified risks, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90ed104f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing other potential donors to finance projects or parts of projects as needed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90ed1050-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partnering with regional organizations to support and oversee effective cross-border cooperation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed1051-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional and public notification after entering into a Compact","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 10 days after entering into a Compact with an eligible country, the Board, acting through the Chief Executive Officer, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed1052-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the text of the Compact on the website of the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1053-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the appropriate congressional committees with a detailed summary of the Compact and, upon request, the text of the Compact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1054-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7709/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish in the Federal Register a detailed summary of the Compact and a notice of availability of the text of the Compact on the website of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ed1055-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tVI/s610"},"text":"Pub. L. 108–199, div. D, title VI, § 610","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/220"},"text":"118 Stat. 220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/167/tII/s205"},"text":"Pub. L. 115–167, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-04-23"},"text":"Apr. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1281"},"text":"132 Stat. 1281","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ed1056-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ed1057-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90ed1058-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167"},"text":"Pub. L. 115–167","children":[],"tail":" amended section generally. Prior to amendment, section related to Congressional and public notification of Compact."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
