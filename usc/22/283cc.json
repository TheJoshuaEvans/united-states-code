{"tag":"section","attrib":{"id":"id8eba517d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s283cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"283cc"},"text":"§ 283cc.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Bretton Woods Agreements Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s286b"},"text":"section 286b of this title","children":[],"tail":" shall apply with respect to the Corporation to the same extent as with respect to the International Bank for Reconstruction and Development and the International Monetary Fund."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eba517e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s101/1/tI"},"text":"Pub. L. 98–473, title I, § 101(1) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1884"},"text":"98 Stat. 1884","children":[],"tail":", 1885; "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tV/s541/e/3"},"text":"Pub. L. 101–240, title V, § 541(e)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2518"},"text":"103 Stat. 2518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8eba517f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8eba5180-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8eba5181-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 204 of title II of S. 2416, Ninety-eighth Congress, as introduced ","children":[{"tag":"date","attrib":{"date":"1984-03-13"},"text":"Mar. 13, 1984","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8eba5182-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/240"},"text":"Pub. L. 101–240","children":[],"tail":" struck out at end “Reports with respect to the Corporation under paragraphs (5) and (6) of subsection (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s286b"},"text":"section 286b of this title","children":[],"tail":" shall be included in the first and subsequent reports made thereunder after the United States accepts membership in the Corporation.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
