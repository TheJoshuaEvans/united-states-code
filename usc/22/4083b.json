{"tag":"section","attrib":{"id":"id9069fcdb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b"},"text":null,"children":[{"tag":"num","attrib":{"value":"4083b"},"text":"§ 4083b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overseas operations leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9069fcdc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9069fcdd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “agency” means an Executive agency (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":"), but does not include the Government Accountability Office."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9069fcde-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “employee” means an officer or an individual who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9069fcdf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" appointed in the civil service, the Foreign Service, or any appointment authority other than the uniformed services (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of title 37","children":[],"tail":"), by one of the following acting in an official capacity:"}],"tail":null},{"tag":"clause","attrib":{"id":"id9069fce0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9069fce1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Member or Members of Congress, or Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9069fce2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who is an employee under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id9069fce3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of a Government-controlled corporation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9069fce4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in the performance of a Federal function under authority of law or an Executive act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9069fce5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the supervision of an individual described in subparagraph (A) while engaged in the performance of the duties of his or her position; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9069fce6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “leave year” means the period beginning with the first day of the first complete pay period in a calendar year and ending with the day immediately before the first day of the first complete pay period in the following calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9069fce7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leave for overseas operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or other head of an agency may prescribe regulations to grant up to 10 days of paid leave, per leave year, to an employee of the agency serving abroad for the purpose of local holidays.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9069fce8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4083b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary authority of the Secretary or other agency head","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Use of the authority under subsection (b) is at the sole and exclusive discretion of the head of the agency concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9069fce9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s903b"},"text":"Pub. L. 96–465, title I, § 903b","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXII/s7215/a"},"text":"Pub. L. 118–159, div. G, title LXXII, § 7215(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2537"},"text":"138 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
