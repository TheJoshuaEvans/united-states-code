{"tag":"section","attrib":{"id":"id8ede2c7f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–3"},"text":"§ 290g–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific actions requiring Congressional authorization","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Unless Congress by law authorizes such action, neither the President nor any person or agency shall, on behalf of the United States:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ede2c80-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to an increase in the subscription of the United States to the Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ede2c81-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vote for or agree to any amendment of the agreement which increases the obligations of the United States, or which would change the purpose or functions of the Fund; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ede2c82-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a loan or provide other financing to the Fund, except that funds for technical assistance may be provided to the Fund by a United States agency created pursuant to an Act of Congress which is authorized by law to provide funds to international organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ede2c83-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s205"},"text":"Pub. L. 94–302, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-31"},"text":"May 31, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/594"},"text":"90 Stat. 594","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
