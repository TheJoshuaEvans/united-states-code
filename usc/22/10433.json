{"tag":"section","attrib":{"id":"id91587ba7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10433"},"text":null,"children":[{"tag":"num","attrib":{"value":"10433"},"text":"§ 10433.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees and leadership defined","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter, the term “appropriate congressional committees and leadership” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91587ba8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10433/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Speaker of the House of Representatives and the Committee on Foreign Affairs, the Committee on Armed Services, and the Committee on Appropriations of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587ba9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10433/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the majority leader of the Senate and the Committee on Foreign Relations, the Committee on Armed Services, and the Committee on Appropriations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91587baa-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXIII/s1354"},"text":"Pub. L. 118–31, div. A, title XIII, § 1354","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/522"},"text":"137 Stat. 522","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
