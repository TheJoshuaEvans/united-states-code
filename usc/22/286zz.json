{"tag":"section","attrib":{"id":"id8ecb1ab1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286zz"},"text":null,"children":[{"tag":"num","attrib":{"value":"286zz"},"text":"§ 286zz.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital stock increases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ecb1ab2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286zz/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increases authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The United States Governor of the Bank is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ecb1ab3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286zz/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ecb1ab4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286zz/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to vote in favor of a resolution to increase the capital stock of the Bank on a selective basis by 245,773 shares; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ecb1ab5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286zz/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to subscribe on behalf of the United States to 42,298 additional shares of the capital stock of the Bank, as part of the selective increase in the capital stock of the Bank, except that any subscription to such additional shares shall be effective only to the extent or in such amounts as are provided in advance in appropriations Acts; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ecb1ab6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286zz/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ecb1ab7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286zz/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to vote in favor of a resolution to increase the capital stock of the Bank on a general basis by 230,500 shares; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ecb1ab8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286zz/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to subscribe on behalf of the United States to 38,662 additional shares of the capital stock of the Bank, as part of the general increase in the capital stock of the Bank, except that any subscription to such additional shares shall be effective only to the extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ecb1ab9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286zz/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ecb1aba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286zz/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the increase in the United States subscription to the Bank under subsection (a)(2)(B), there are authorized to be appropriated, without fiscal year limitation, $4,663,990,370 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ecb1abb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286zz/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the amount authorized to be appropriated under paragraph (1), $932,798,074 shall be for paid in shares of the Bank, and $3,731,192,296 shall be for callable shares of the Bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ecb1abc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286zz/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the increase in the United States subscription to the Bank under subsection (a)(1)(B), there are authorized to be appropriated, without fiscal year limitation $5,102,619,230 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ecb1abd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286zz/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the amount authorized to be appropriated under paragraph (3), $306,157,153.80 shall be for paid in shares of the Bank, and $4,796,462,076.20 shall be for callable shares of the Bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ecb1abe-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s73"},"text":"July 31, 1945, ch. 339, § 73","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dP/tXIX/s1901"},"text":"Pub. L. 116–94, div. P, title XIX, § 1901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3222"},"text":"133 Stat. 3222","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ecb1abf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ecb1ac0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ecb1ac1-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 73 of the Bretton Woods Agreements Act was enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s286yy"},"text":"section 286yy of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
