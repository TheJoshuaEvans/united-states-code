{"tag":"section","attrib":{"id":"id8ef14041-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s701"},"text":null,"children":[{"tag":"num","attrib":{"value":"701"},"text":"§ 701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, unless the context clearly requires a different meaning—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ef14042-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Friendly foreign force” means any military, naval, or air force of any friendly foreign state with respect to which this chapter is operative by virtue of a Presidential declaration as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s706"},"text":"section 706 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ef14043-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Service court” means any military, naval, or air force court, or court martial or similar tribunal of any friendly foreign force within the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ef14044-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States” means the United States, its Territories, its insular possessions, the Canal Zone, and any other place subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ef14045-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-06-30/ch326/s1"},"text":"June 30, 1944, ch. 326, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/643"},"text":"58 Stat. 643","children":[],"tail":"; Proc. No. 2695, "},{"tag":"date","attrib":{"date":"1946-07-04"},"text":"July 4, 1946","children":[],"tail":", 11 F.R. 7517, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1352"},"text":"60 Stat. 1352","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ef14046-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ef14047-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ef14048-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of Canal Zone, referred to in subsec. (c), see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3602/b"},"text":"section 3602(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ef14049-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The phrase “(including the Philippine Islands)” omitted from the definition of the term “United States” in subsection (b), pursuant to 1946 Proc. No. 2695, which granted independence to the Philippine Islands under the authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1394"},"text":"section 1394 of this title","children":[],"tail":", under which section Proc. No. 2695 is set out as a note."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
