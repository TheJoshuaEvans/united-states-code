{"tag":"section","attrib":{"id":"id8ec8a8d1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"286ff"},"text":"§ 286ff.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund interest rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director of the Fund to propose and work for the adoption of Fund policies regarding the rate of remuneration paid on use of member’s quota subscriptions and the rate of charges on Fund drawings to bring those rates in line with market rates.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ec8a8d2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s48"},"text":"July 31, 1945, ch. 339, § 48","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title VIII, § 810], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1274"},"text":"97 Stat. 1274","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
