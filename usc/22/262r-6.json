{"tag":"section","attrib":{"id":"id8ea4f45a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262r–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"262r–6"},"text":"§ 262r–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on policies, operations, and management of international financial institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ea4f45b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262r–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tV/s599B/c"},"text":"Pub. L. 108–199, div. D, title V, § 599B(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/211"},"text":"118 Stat. 211","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ea4f45c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262r–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on United States supported policies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-11-06"},"text":"November 6, 2000","children":[],"tail":"], or "},{"tag":"date","attrib":{"date":"2000-10-31"},"text":"October 31, 2000","children":[],"tail":", whichever is later, and on October 31 of each year thereafter, the Secretary shall submit a report to the appropriate congressional committees on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ea4f45d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262r–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions taken by recipient countries, as a result of the assistance allocated to them by the multilateral development banks under programs referred to in section 802(b),","children":[{"tag":"ref","attrib":{"idref":"fn002020"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002020"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" to strengthen governance and reduce the opportunity for bribery and corruption; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ea4f45e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262r–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how International Development Association-financed projects contribute to the eventual graduation of a representative sample of countries from reliance on financing on concessionary terms and international development assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ea4f45f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262r–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ea4f460-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262r–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on debt relief","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-11-06"},"text":"November 6, 2000","children":[],"tail":"], the Secretary shall submit a report to the appropriate congressional committees on the history of debt relief programs led by, or coordinated with, international financial institutions, including but not limited to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ea4f461-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262r–6/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which poor countries and the poorest-of-the-poor benefit from debt relief, including measurable evidence of any such benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ea4f462-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262r–6/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which debt relief contributes to the graduation of a country from reliance on financing on concessionary terms and international development assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ea4f463-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/429/s101/a/tVIII/s803"},"text":"Pub. L. 106–429, § 101(a) [title VIII, § 803]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1900"},"text":"114 Stat. 1900","children":[],"tail":", 1900A–66; "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tV/s599B/c"},"text":"Pub. L. 108–199, div. D, title V, § 599B(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/211"},"text":"118 Stat. 211","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ea4f464-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ea4f465-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ea4f466-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 802(b), referred to in subsec. (b)(1), is section 101(a), [title VIII, § 802(b)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/429"},"text":"Pub. L. 106–429","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1900"},"text":"114 Stat. 1900","children":[],"tail":", 1900A–66, which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ea4f467-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of section 101(a) [title VIII, § 803] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/429"},"text":"Pub. L. 106–429","children":[],"tail":". Section 101(a) [title VIII, § 803(c)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/429"},"text":"Pub. L. 106–429","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s262r–4"},"text":"section 262r–4 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ea4f468-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199"},"text":"Pub. L. 108–199","children":[],"tail":" repealed heading and text of subsec. (a). Text read as follows: “Beginning 180 days after the date of enactment of this Act, or "},{"tag":"date","attrib":{"date":"2000-10-31"},"text":"October 31, 2000","children":[],"tail":", whichever is later, and on October 31 of each year thereafter, the Comptroller General of the United States shall submit to the appropriate congressional committees a report on the sufficiency of audits of the financial operations of each multilateral development bank conducted by persons or entities outside such bank.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ea4f469-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8ea4f46a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/429/s101/a/tVIII/s806"},"text":"Pub. L. 106–429, § 101(a) [title VIII, § 806]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1900"},"text":"114 Stat. 1900","children":[],"tail":", 1900A–68, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/429/s101/a/tVIII/s806"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this title [enacting this section and section 286","children":[{"tag":"i","attrib":{},"text":"oo","children":[],"tail":" of this title and amending sections 262r–4, 286nn, and 2169 of this title]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate congressional committees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘appropriate congressional committees’ means the Committee on Foreign Relations and the Committee on Appropriations of the Senate, and the Committee on Banking and Financial Services [now Committee on Financial Services] and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bank","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Bank’ means the International Bank for Reconstruction and Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Fund’ means the International Monetary Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"International financial institutions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘international financial institutions’ means the multilateral development banks and the International Monetary Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multilateral development banks","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘multilateral development banks’ means the International Bank for Reconstruction and Development, the International Development Association, the International Finance Corporation, the Inter-American Development Bank, the Asian Development Bank, the Inter-American Investment Corporation, the African Development Bank, the African Development Fund, the European Bank for Reconstruction and Development, and the Multilateral Investment Guaranty Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of the Treasury.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
