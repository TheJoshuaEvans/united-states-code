{"tag":"section","attrib":{"id":"id8f2ce98e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2027"},"text":null,"children":[{"tag":"num","attrib":{"value":"2027"},"text":"§ 2027.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual review by Secretary of State of programs and projects of the International Atomic Energy Agency; United States opposition to certain programs and projects of the Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f2ce98f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2027/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f2ce990-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2027/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall undertake a comprehensive annual review of all programs and projects of the International Atomic Energy Agency (IAEA) in the countries described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2227/a"},"text":"section 2227(a) of this title","children":[],"tail":" and shall determine if such programs and projects are consistent with United States nuclear nonproliferation and safety goals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f2ce991-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2027/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":", and on an annual basis thereafter for five years, the Secretary shall submit to Congress a report containing the results of the review under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f2ce992-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2027/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opposition to certain programs and projects of International Atomic Energy Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall direct the United States representative to the International Atomic Energy Agency to oppose programs of the Agency that are determined by the Secretary under the review conducted under subsection (a)(1) to be inconsistent with nuclear nonproliferation and safety goals of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f2ce993-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/dB/tXIII/s1343"},"text":"Pub. L. 107–228, div. B, title XIII, § 1343","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1452"},"text":"116 Stat. 1452","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f2ce994-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f2ce995-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f2ce996-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Iran Nuclear Proliferation Prevention Act of 2002, and also as part of the Security Assistance Act of 2002 and the Foreign Relations Authorization Act, Fiscal Year 2003, and not as part of the International Atomic Energy Agency Participation Act of 1957 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f2ce997-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8f2ce998-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Secretary” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s3"},"text":"section 3 of Pub. L. 107–228","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
