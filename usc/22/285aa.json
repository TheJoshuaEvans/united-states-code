{"tag":"section","attrib":{"id":"id8ebf32e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"285aa"},"text":"§ 285aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital increase","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf32ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285aa/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subscription authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ebf32eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285aa/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank may subscribe on behalf of the United States to 35,230 additional shares of the capital stock of the Bank. (2) Any subscription by the United States to the capital stock of the Bank shall be effective only to such extent or in such amounts as are provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf32ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285aa/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the increase in the United States subscription to the Bank provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $213,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf32ed-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s30"},"text":"Pub. L. 89–369, § 30","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/145/s125/b"},"text":"Pub. L. 102–145, § 125(b)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/266/s102"},"text":"Pub. L. 102–266, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-04-01"},"text":"Apr. 1, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/97"},"text":"106 Stat. 97","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
