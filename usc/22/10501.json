{"tag":"section","attrib":{"id":"id91587bad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10501"},"text":null,"children":[{"tag":"num","attrib":{"value":"10501"},"text":"§ 10501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91587bae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587baf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10501/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on Appropriations, the Committee on Banking, Housing, and Urban Affairs, and the Committee on the Judiciary of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587bb0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10501/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs, the Committee on Appropriations, the Committee on Financial Services, and the Committee on the Judiciary of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587bb1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “corrupt actor” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587bb2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10501/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign person or entity that is a government official or government entity responsible for, or complicit in, an act of corruption; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587bb3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10501/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any company, in which a person or entity described in subparagraph (A) has a significant stake, which is responsible for, or complicit in, an act of corruption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587bb4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “corruption” means the unlawful exercise of entrusted public power for private gain, including by bribery, nepotism, fraud, or embezzlement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587bb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “significant corruption” means corruption committed at a high level of government that has some or all of the following characteristics:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587bb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10501/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Illegitimately distorts major decision-making, such as policy or resource determinations, or other fundamental functions of governance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587bb7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10501/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Involves economically or socially large-scale government activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91587bb8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLIV/s5402"},"text":"Pub. L. 118–31, div. E, title LIV, § 5402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/944"},"text":"137 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91587bb9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id91587bba-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id91587bbb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLIV/s5401"},"text":"Pub. L. 118–31, div. E, title LIV, § 5401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/944"},"text":"137 Stat. 944","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dE/tLIV/s5401"},"text":"“This subtitle [subtitle A (§§ 5401–5406) of title LIV of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":", enacting this chapter] may be cited as the ‘Combating Global Corruption Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
