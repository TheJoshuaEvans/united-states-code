{"tag":"section","attrib":{"id":"id906c6e4b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4103"},"text":null,"children":[{"tag":"num","attrib":{"value":"4103"},"text":"§ 4103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id906c6e4c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Departments and agencies affected","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subchapter applies only with respect to the Department of State, the Broadcasting Board of Governors, the Agency for International Development, the Department of Agriculture, and the Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906c6e4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of subdivisions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may by Executive order exclude any subdivision of the Department from coverage under this subchapter if the President determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id906c6e4e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the subdivision has as a primary function intelligence, counterintelligence, investigative, or national security work, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id906c6e4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of this subchapter cannot be applied to that subdivision in a manner consistent with national security requirements and considerations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id906c6e50-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may by Executive order suspend any provision of this subchapter with respect to any post, bureau, office, or activity of the Department, if the President determines in writing that the suspension is necessary in the interest of national security because of an emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id906c6e51-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s1003"},"text":"Pub. L. 96–465, title I, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2130"},"text":"94 Stat. 2130","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tIII/s303/b"},"text":"Pub. L. 97–241, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/291"},"text":"96 Stat. 291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1335(k)(3), title XIV, § 1422(b)(4)(C), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-789"},"text":"112 Stat. 2681–789","children":[],"tail":", 2681–793.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id906c6e52-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id906c6e53-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id906c6e54-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1422/b/4/C"},"text":"Pub. L. 105–277, § 1422(b)(4)(C)","children":[],"tail":", substituted “Agency for International Development” for “United States International Development Cooperation Agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1335/k/3"},"text":"Pub. L. 105–277, § 1335(k)(3)","children":[],"tail":", substituted “Broadcasting Board of Governors” for “United States Information Agency”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id906c6e55-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id906c6e56-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Broadcasting 