{"tag":"section","attrib":{"id":"id8ec3ee14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286k–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"286k–1"},"text":"§ 286k–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities issued by Bank as exempt securities; reports filed with Security and Exchange Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ec3ee15-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286k–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any securities issued by International Bank for Reconstruction and Development (including any guaranty by the bank, whether or not limited in scope), and any securities guaranteed by the bank as to both principal and interest, shall be deemed to be exempted securities within the meaning of subsection (a)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77c"},"text":"section 77c of title 15","children":[],"tail":", and subsection (a)(12) of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"section 78c of title 15","children":[],"tail":". The bank shall file with the Securities and Exchange Commission such annual and other reports with regard to such securities as the Commission shall determine to be appropriate in view of the special character of the bank and its operations and necessary in the public interest or for the protection of investors."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ec3ee16-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286k–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/240/tV/s541/d/1"},"text":"Pub. L. 101–240, title V, § 541(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2518"},"text":"103 Stat. 2518","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ec3ee17-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s15"},"text":"July 31, 1945, ch. 339, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-29/ch276/s2"},"text":"June 29, 1949, ch. 276, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/298"},"text":"63 Stat. 298","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tV/s541/d/1"},"text":"Pub. L. 101–240, title V, § 541(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2518"},"text":"103 Stat. 2518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ec3ee18-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ec3ee19-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ec3ee1a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/240"},"text":"Pub. L. 101–240","children":[],"tail":" struck out subsec. (b) which related to contents of National Advisory Council reports provided for in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s286b"},"text":"section 286b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
