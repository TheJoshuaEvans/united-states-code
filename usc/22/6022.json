{"tag":"section","attrib":{"id":"id90a5a6e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6022"},"text":null,"children":[{"tag":"num","attrib":{"value":"6022"},"text":"§ 6022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a5a6e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6022/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the Cuban people in regaining their freedom and prosperity, as well as in joining the community of democratic countries that are flourishing in the Western Hemisphere;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a6e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6022/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen international sanctions against the Castro government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a6e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6022/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the continued national security of the United States in the face of continuing threats from the Castro government of terrorism, theft of property from United States nationals by the Castro government, and the political manipulation by the Castro government of the desire of Cubans to escape that results in mass migration to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a6e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6022/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the holding of free and fair democratic elections in Cuba, conducted under the supervision of internationally recognized observers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a6ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6022/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a policy framework for United States support to the Cuban people in response to the formation of a transition government or a democratically elected government in Cuba; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a6eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6022/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to protect United States nationals against confiscatory takings and the wrongful trafficking in property confiscated by the Castro regime.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90a5a6ec-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114/s3"},"text":"Pub. L. 104–114, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/788"},"text":"110 Stat. 788","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90a5a6ed-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90a5a6ee-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90a5a6ef-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114"},"text":"Pub. L. 104–114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/785"},"text":"110 Stat. 785","children":[],"tail":", known as the Cuban Liberty and Democratic Solidarity (LIBERTAD) Act of 1996, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6021"},"text":"section 6021 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
