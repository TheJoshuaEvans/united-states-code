{"tag":"section","attrib":{"id":"id904d4da8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3927b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3927b"},"text":"§ 3927b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement on chiefs of mission","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days following the end of each calendar quarter, the Secretary shall submit to the appropriate congressional committees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904d4da9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3927b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of every chief of mission or United States representative overseas with the rank of Ambassador who, during the prior quarter, was granted approval by the Under Secretary of State for Management to be outside a country of assignment for purposes other than official travel or temporary duty orders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904d4daa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3927b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of days each such chief of mission or United States representative overseas with the rank of Ambassador was outside a country of assignment during the previous quarter for purposes other than official travel or temporary duty orders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904d4dab-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dF/tLXII/s6209"},"text":"Pub. L. 118–31, div. F, title LXII, § 6209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/975"},"text":"137 Stat. 975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904d4dac-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904d4dad-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id904d4dae-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of State Authorization Act of 2023, and also as part of the National Defense Authorization Act for Fiscal Year 2024, and not as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id904d4daf-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id904d4db0-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary” and “appropriate congressional committees” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s6002"},"text":"section 6002 of Pub. L. 118–31","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
