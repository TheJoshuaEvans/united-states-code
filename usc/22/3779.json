{"tag":"section","attrib":{"id":"id904891f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3779"},"text":null,"children":[{"tag":"num","attrib":{"value":"3779"},"text":"§ 3779.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904891f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3779/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission is authorized to purchase insurance to protect the Commission against major and unpredictable revenue losses or expenses arising from catastrophic marine accidents or other unpredictable events.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904891fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3779/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904891fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3779/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission may by regulation require as a condition of transit through the Panama Canal or presence in the Panama Canal or waters adjacent thereto that any potential claimant under section 3771 or 3772 of this title be covered by insurance against the types of injuries described in those sections. The amount of insurance so required shall be specified in those regulations, but may not exceed $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904891fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3779/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a claim under section 3771 or 3772 of this title for which the Commission has required insurance under this subsection, the Commission’s liability shall be limited to the amount of damages in excess of the amount of insurance required by the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904891fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3779/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In regulations under this subsection, the Commission may prohibit consideration or payment by it of claims presented by or on behalf of an insurer or subrogee of a claimant in a case for which the Commission has required insurance under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904891fe-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1419"},"text":"Pub. L. 96–70, title I, § 1419","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/209/s6/a"},"text":"Pub. L. 99–209, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1717"},"text":"99 Stat. 1717","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tV/s5414"},"text":"Pub. L. 100–203, title V, § 5414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-270"},"text":"101 Stat. 1330–270","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dC/tXXXV/s3509/b"},"text":"Pub. L. 105–261, div. C, title XXXV, § 3509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2270"},"text":"112 Stat. 2270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904891ff-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90489200-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90489201-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" inserted “or other unpredictable events” after “marine accidents”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90489202-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90489203-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any claim arising on or after ","children":[{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/209/s7/b/1"},"text":"section 7(b)(1) of Pub. L. 99–209","children":[],"tail":", set out as an Effective Date of 1985 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3771"},"text":"section 3771 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
