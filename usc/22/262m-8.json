{"tag":"section","attrib":{"id":"id8e969c33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"262m–8"},"text":"§ 262m–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Climate change mitigation and greenhouse gas accounting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e969c34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of greenhouse gas accounting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall seek to ensure that multilateral development banks (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262r/c/4"},"text":"section 262r(c)(4) of this title","children":[],"tail":") adopt and implement greenhouse gas accounting in analyzing the benefits and costs of individual projects (excluding those with de minimus greenhouse gas emissions) for which funding is sought from the bank."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e969c35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of climate change mitigation activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall work to ensure that the multilateral development banks (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262r/c/4"},"text":"section 262r(c)(4) of this title","children":[],"tail":") expand their activities supporting climate change mitigation by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e969c36-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m–8/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significantly expanding support for investments in energy efficiency and renewable energy, including zero carbon technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e969c37-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m–8/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing all proposed infrastructure investments to ensure that all opportunities for integrating energy efficiency measures have been considered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e969c38-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m–8/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increasing the dialogue with the governments of developing countries regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8e969c39-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m–8/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analysis and policy measures needed for low carbon emission economic development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8e969c3a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m–8/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reforms needed to promote private sector investments in energy efficiency and renewable energy, including zero carbon technologies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e969c3b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m–8/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate low carbon emission economic development objectives into multilateral development bank country strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e969c3c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262m–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2009-06-24"},"text":"June 24, 2009","children":[],"tail":", and annually thereafter, the Secretary of the Treasury shall submit a report on the status of efforts to implement this section to the Committee on Foreign Relations and the Committee on Appropriations of the Senate and the Committee on Financial Services and the Committee on Appropriations of the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e969c3d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXIII/s1308"},"text":"Pub. L. 95–118, title XIII, § 1308","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/32/tXI/s1111"},"text":"Pub. L. 111–32, title XI, § 1111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-24"},"text":"June 24, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1903"},"text":"123 Stat. 1903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e969c3e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e969c3f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8e969c40-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/s1308"},"text":"section 1308 of Pub. L. 95–118","children":[],"tail":" was renumbered section 1307 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s262m–7"},"text":"section 262m–7 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
