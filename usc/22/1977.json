","attrib":{"href":"/us/pl/100/350/s2"},"text":"Pub. L. 100–350, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-27"},"text":"June 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/660"},"text":"102 Stat. 660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/627/tIII/s301"},"text":"Pub. L. 101–627, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4462"},"text":"104 Stat. 4462","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/43/tIV/s403"},"text":"Pub. L. 104–43, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-03"},"text":"Nov. 3, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/390"},"text":"109 Stat. 390","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/450/tI/s102"},"text":"Pub. L. 106–450, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-07"},"text":"Nov. 7, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1941"},"text":"114 Stat. 1941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tII/s209"},"text":"Pub. L. 107–228, div. A, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1365"},"text":"116 Stat. 1365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/219/tIII/s302"},"text":"Pub. L. 108–219, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-04-13"},"text":"Apr. 13, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/616"},"text":"118 Stat. 616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/323/tVII/s705"},"text":"Pub. L. 114–323, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1942"},"text":"130 Stat. 1942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLI/s5111/a"},"text":"Pub. L. 117–81, div. E, title LI, § 5111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2350"},"text":"135 Stat. 2350","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f2a77b2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f2a77b3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f2a77b4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" inserted heading and amended subsec. (e) generally. Prior to amendment, subsec. (e) read as follows: “The provisions of this section shall be effective until "},{"tag":"date","attrib":{"date":"2018-10-01"},"text":"October 1, 2018","children":[],"tail":"; except that payments may be made under this section only to such extent and in such amounts as are provided in advance in appropriation Acts.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323"},"text":"Pub. L. 114–323","children":[],"tail":" substituted “2018” for “2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/219"},"text":"Pub. L. 108–219","children":[],"tail":" substituted “2008” for “2003”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" substituted “Secretary of State” for “Secretary of Commerce”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/450/s102/b"},"text":"Pub. L. 106–450, § 102(b)","children":[],"tail":", substituted “Secretary of Commerce” for “Secretary of the Interior”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/450/s102/a"},"text":"Pub. L. 106–450, § 102(a)","children":[],"tail":", substituted “2003” for “2000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/s403/a"},"text":"Pub. L. 104–43, § 403(a)","children":[],"tail":", struck out after second sentence “The amount fixed by the Secretary shall be predicated upon at least 33⅓ per centum of the contribution by the Government.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/43/s403/b"},"text":"Pub. L. 104–43, § 403(b)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2000-10-01"},"text":"October 1, 2000","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/627"},"text":"Pub. L. 101–627","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/350"},"text":"Pub. L. 100–350","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1989-10-01"},"text":"October 1, 1989","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"October 1, 1988","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/151"},"text":"Pub. L. 100–151","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1988-10-01"},"text":"October 1, 1988","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/659"},"text":"Pub. L. 99–659","children":[],"tail":" substituted “Secretary of State” for “Secretary of Commerce”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364"},"text":"Pub. L. 98–364","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"October 1, 1984","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/68/s1/1"},"text":"Pub. L. 97–68, § 1(1)","children":[],"tail":", inserted provision that fees not currently needed for payments under this section be kept on deposit or invested in obligations of, or guaranteed by, the United States and that all revenues accruing from such deposits or investments be credited to the separate account established in the Treasury of the United States to carry out the provisions of this section."}],"tail":"\n"},{"tag":"p","attr