{"tag":"section","attrib":{"id":"id8f1c2040-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1741d"},"text":"§ 1741d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of imposition of sanctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f1c2041-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may impose the sanctions described in subsection (b) with respect to any foreign person the President determines, based on credible evidence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f1c2042-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is responsible for or is complicit in, or responsible for ordering, controlling, or otherwise directing, the hostage-taking of a United States national abroad or the unlawful or wrongful detention of a United States national abroad; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f1c2043-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly provides financial, material, or technological support for, or goods or services in support of, an activity described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f1c2044-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sanctions described in this subsection are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f1c2045-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility for visas, admission, or parole","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f1c2046-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visas, admission, or parole","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An alien described in subsection (a) may be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8f1c2047-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inadmissible to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f1c2048-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ineligible to receive a visa or other documentation to enter the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f1c2049-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise ineligible to be admitted or paroled into the United States or to receive any other benefit under the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f1c204a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current visas revoked","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8f1c204b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An alien described in subsection (a) may be subject to revocation of any visa or other entry documentation regardless of when the visa or other entry documentation is or was issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f1c204c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A revocation under clause (i) may—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id8f1c204d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take effect immediately; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id8f1c204e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cancel any other valid visa or entry documentation that is in the alien’s possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f1c204f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blocking of property","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f1c2050-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may exercise all of the powers granted to the President under the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" et seq.), to the extent necessary to block and prohibit all transactions in property and interests in property of a foreign person described in subsection (a) if such property and interests in property are in the United States, come within the United States, or are or come within the possession or control of a United States person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f1c2051-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of national emergency requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of section 202 of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":") shall not apply for purposes of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f1c2052-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f1c2053-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for intelligence activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sanctions under this section shall not apply to any activity subject to the reporting requirements under title V of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3091"},"text":"50 U.S.C. 3091","children":[],"tail":" et seq.) or any authorized intelligence activities of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f1c2054-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to comply with international obligations and for law enforcement activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sanctions under subsection (b)(1) shall not apply with respect to an alien if admitting or paroling the alien into the United States is necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f1c2055-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to permit the United States to comply with the Agreement regarding the Headquarters of the United Nations, signed at Lake Success ","children":[{"tag":"date","attrib":{"date":"1947-06-26"},"text":"June 26, 1947","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1947-11-21"},"text":"November 21, 1947","children":[],"tail":", between the United Nations and the United States, or other applicable international obligations; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f1c2056-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out or assist law enforcement activity in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f1c2057-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person that violates, attempts to violate, conspires to violate, or causes a violation of subsection (b)(2) or any regulation, license, or order issued to carry out that subsection shall be subject to the penalties set forth in subsections (b) and (c) of section 206 of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1705"},"text":"50 U.S.C. 1705","children":[],"tail":") to the same extent as a person that commits an unlawful act described in subsection (a) of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f1c2058-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may terminate the application of sanctions under this section with respect to a person if the President determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f1c2059-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information exists that the person did not engage in the activity for which sanctions were imposed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f1c205a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person has been prosecuted appropriately for the activity for which sanctions were imposed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f1c205b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person has credibly demonstrated a significant change in behavior, has paid an appropriate consequence for the activity for which sanctions were imposed, and has credibly committed to not engage in an activity described in subsection (a) in the future; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f1c205c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination of the sanctions is in the national security interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f1c205d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President terminates sanctions pursuant to subsection (d),","children":[{"tag":"ref","attrib":{"idref":"fn002076"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002076"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection (e),”."}],"tail":" the President shall report to the appropriate congressional committees a written justification for such termination within 15 days."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f1c205e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of regulatory authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may exercise all authorities provided under sections 203 and 205 of the International Emergency Economic Powers Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1702"},"text":"50 U.S.C. 1702","children":[],"tail":" and 1704) to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f1c205f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception relating to importation of goods","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f1c2060-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorities and requirements to impose sanctions authorized under this subchapter shall not include the authority or a requirement to impose sanctions on the importation of goods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f1c2061-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this paragraph, the term “good” means any article, natural or manmade substance, material, supply or manufactured product, including inspection and test equipment, and excluding technical data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f1c2062-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f1c2063-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f1c2064-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any citizen or national of a foreign country (including any such individual who is also a citizen or national of the United States); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f1c2065-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any entity not organized solely under the laws of the United States or existing solely in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f1c2066-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States person","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States person” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f1c2067-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is a United States citizen or an alien lawfully admitted for permanent residence to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f1c2068-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity organized under the laws of the United States or any jurisdiction within the United States, including a foreign branch of such an entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f1c2069-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1741d/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f1c206a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tIII/s306"},"text":"Pub. L. 116–260, div. FF, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3096"},"text":"134 Stat. 3096","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f1c206b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f1c206c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f1c206d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (b)(1)(A)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of Title 8, Aliens and Nationality. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The International Emergency Economic Powers Act, referred to in subsec. (b)(2)(A), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/223"},"text":"Pub. L. 95–223","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-12-28"},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1626"},"text":"91 Stat. 1626","children":[],"tail":", which is classified generally to chapter 35 (§ 1701 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"section 1701 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The National Security Act of 1947, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"act July 26, 1947, ch. 343","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/495"},"text":"61 Stat. 495","children":[],"tail":". Title V of the Act is classified generally to subchapter III (§ 3091 et seq.) of chapter 44 of Title 50, War and National Defense. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
