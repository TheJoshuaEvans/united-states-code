{"tag":"section","attrib":{"id":"id904fbe67-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3945"},"text":null,"children":[{"tag":"num","attrib":{"value":"3945"},"text":"§ 3945.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior Foreign Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904fbe68-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3945/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salary class","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appointment to the Senior Foreign Service shall be to a salary class established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3962"},"text":"section 3962 of this title","children":[],"tail":", and not to a position."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904fbe69-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3945/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual may not be given a limited appointment in the Senior Foreign Service if that appointment would cause the number of members of the Senior Foreign Service serving under limited appointments to exceed 5 percent of the total number of members of the Senior Foreign Service, except that (1) members of the Senior Foreign Service assigned to the Peace Corps shall be excluded in the calculation and application of this limitation, and (2) members of the Senior Foreign Service serving under limited appointments with reemployment rights under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3950"},"text":"section 3950 of this title","children":[],"tail":" as career appointees in the Senior Executive Service shall be considered to be career members of the Senior Foreign Service for purposes of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904fbe6a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3945/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments by Secretary of Commerce","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id904fbe6b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3945/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appointments to the Senior Foreign Service by the Secretary of Commerce shall be excluded in the calculation and application of the limitation in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904fbe6c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3945/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (3), no more than one individual (other than an individual with reemployment rights under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3950"},"text":"section 3950 of this title","children":[],"tail":" as a career appointee in the Senior Executive Service) may serve under a limited appointment in the Senior Foreign Service in the Department of Commerce at any time."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id904fbe6d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3945/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Commerce may appoint an individual to a limited appointment in the Senior Foreign Service for a specific position abroad if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id904fbe6e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3945/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no career member of the Service who has the necessary qualifications is available to serve in the position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id904fbe6f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3945/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual appointed has unique qualifications for the specific position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904fbe70-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3945/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recertification process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall by regulation establish a recertification process for members of the Senior Foreign Service that is equivalent to the recertification process for the Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393a"},"text":"section 3393a of title 5","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002273"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002273"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904fbe71-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s305"},"text":"Pub. L. 96–465, title I, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2086"},"text":"94 Stat. 2086","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/93/tI/s119/a"},"text":"Pub. L. 99–93, title I, § 119(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/412"},"text":"99 Stat. 412","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tV/s506/c/1"},"text":"Pub. L. 101–194, title V, § 506(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1759"},"text":"103 Stat. 1759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/280/s6/d/3"},"text":"Pub. L. 101–280, § 6(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-04"},"text":"May 4, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/160"},"text":"104 Stat. 160","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904fbe72-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904fbe73-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id904fbe74-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393a"},"text":"Section 3393a of title 5","children":[],"tail":", referred to in subsec. (d), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1321/a/1/B"},"text":"Pub. L. 107–296, title XIII, § 1321(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2296"},"text":"116 Stat. 2296","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id904fbe75-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280"},"text":"Pub. L. 101–280","children":[],"tail":" made technical correction to "},{"tag":"ref","attrib":{"href":"/us/pl/101/194"},"text":"Pub. L. 101–194","children":[],"tail":". See 1989 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194"},"text":"Pub. L. 101–194","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/280"},"text":"Pub. L. 101–280","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93"},"text":"Pub. L. 99–93","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id904fbe76-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id904fbe77-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194"},"text":"Pub. L. 101–194","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"Jan. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/s506/d"},"text":"section 506(d) of Pub. L. 101–194","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3151"},"text":"section 3151 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id904fbe78-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/tI/s119/c"},"text":"Pub. L. 99–93, title I, § 119(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/412"},"text":"99 Stat. 412","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/93/tI/s119/c"},"text":"“The amendments made by subsections (a) and (b) [amending this section and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"October 1, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id904fbe79-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"Feb. 15, 1981","children":[],"tail":", with an exception that appointments to the Senior Foreign Service by the Secretary of Commerce shall be excluded in the calculation and limitation in subsec. (b) of this section until "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", which was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/99/93/s119/b"},"text":"section 119(b) of Pub. L. 99–93","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2403"},"text":"section 2403 of Pub. L. 96–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id904fbe7a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Placement of Senior Foreign Service Personnel","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tIII/s324"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title III, § 324]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–437, required the Director General of the Foreign Service to submit a report on the first day of each fiscal quarter to the appropriate congressional committees containing the number of members of the Senior Foreign Service, the number of vacant positions designated for such members, and the number of those members not assigned to positions, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tVI/s671/4"},"text":"Pub. L. 107–228, div. A, title VI, § 671(4)","children":