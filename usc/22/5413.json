{"tag":"section","attrib":{"id":"id908b6844-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413"},"text":null,"children":[{"tag":"num","attrib":{"value":"5413"},"text":"§ 5413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908b6845-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural assistance strategy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908b6846-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A principal component of the SEED Program shall be the provision by the United States of food and other agricultural commodities and products to alleviate crucial shortages that may be created in an East European country by the transition from state-directed controls to a free market economy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6847-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from other countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to ensure the necessary quantity and diversity of agricultural assistance for that purpose, the United States shall take all appropriate steps to encourage parallel efforts by the European Community and other agricultural surplus countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6848-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Avoiding disincentives to private agricultural production and marketing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In participating in such multilateral agricultural assistance, the United States shall seek to strike a balance wherein agricultural commodities and products are supplied in such quantities as will be effective in overcoming severe shortages and dampening inflation but without impeding the development of incentives for private agricultural production and marketing in the recipient country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908b6849-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural assistance for Poland","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5411/b/3"},"text":"section 5411(b)(3) of this title","children":[],"tail":", the United States Government—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id908b684a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall make available to Poland, in coordination with the European Community, United States agricultural assistance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id908b684b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to alleviate immediate food shortages (such assistance to be specifically targeted toward elements of the Polish population most vulnerable to hunger and malnutrition, in particular the infirm, the elderly, and children), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id908b684c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the transition from state-directed controls to a free market economy, while avoiding disincentives to domestic agricultural production and reform; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b684d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to ensure the necessary quantity and diversity of such agricultural assistance, shall take all appropriate steps to encourage parallel efforts by the European Community and other agricultural surplus countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908b684e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FY 1990 minimum level of agricultural assistance for Poland","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (b) of this section, the level of assistance for Poland for fiscal year 1990 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431/b"},"text":"section 1431(b) of title 7","children":[],"tail":", the Food for Peace Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"7 U.S.C. 1691","children":[],"tail":" and following), and section 1736"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of title 7 should not be less than $125,000,000. Such assistance—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id908b684f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, shall be provided through nongovernmental organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908b6850-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall emphasize feed grains.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908b6851-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5413/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with budget requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (c) should not be construed to authorize or require any budgetary obligations or outlays that are inconsistent with House Concurrent Resolution 106 of the 101st Congress (setting forth the congressional budget for the United States Government for fiscal year 1990).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908b6852-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tI/s103"},"text":"Pub. L. 101–179, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1303"},"text":"103 Stat. 1303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/b/1/A"},"text":"Pub. L. 110–246, title III, § 3001(b)(1)(A)","children":[],"tail":", (2)(U), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1820"},"text":"122 Stat. 1820","children":[],"tail":", 1821.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id908b6853-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id908b6854-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id908b6855-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food for Peace Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"act July 10, 1954, ch. 469","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/454"},"text":"68 Stat. 454","children":[],"tail":", which is classified generally to chapter 41 (§ 1691 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"House Concurrent Resolution 106 of the 101st Congress, referred to in subsec. (d), is H. Con. Res. 106, ","children":[{"tag":"date","attrib":{"date":"1989-05-18"},"text":"May 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2450"},"text":"103 Stat. 2450","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id908b6856-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" substituted “Food for Peace Act” for “Agricultural Trade Development and Assistance Act of 1954” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id908b6857-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id908b6858-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
