{"tag":"section","attrib":{"id":"id90fb67ba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8421"},"text":null,"children":[{"tag":"num","attrib":{"value":"8421"},"text":"§ 8421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of assistance under this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90fb67bb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8421/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support Pakistan’s paramount national security need to fight and win the ongoing counterinsurgency within its borders in accordance with its national security interests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67bc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8421/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to work with the Government of Pakistan to improve Pakistan’s border security and control and help prevent any Pakistani territory from being used as a base or conduit for terrorist attacks in Pakistan, or elsewhere;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8421/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to work in close cooperation with the Government of Pakistan to coordinate action against extremist and terrorist targets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90fb67be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8421/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to help strengthen the institutions of democratic governance and promote control of military institutions by a democratically elected civilian government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90fb67bf-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/73/tII/s201"},"text":"Pub. L. 111–73, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-15"},"text":"Oct. 15, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2069"},"text":"123 Stat. 2069","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
