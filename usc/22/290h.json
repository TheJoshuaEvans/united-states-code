{"tag":"section","attrib":{"id":"id8ee09df6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290h"},"text":null,"children":[{"tag":"num","attrib":{"value":"290h"},"text":"§ 290h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ee09df7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social and economic development ultimately depends on the active participation of individuals within a society and on the enhancement of opportunities for those individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee09df8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of individuals and institutions in African countries can benefit by the provision of support for community-based self-help activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee09df9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by enacting title IX of chapter 2 of part I of the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2218"},"text":"22 U.S.C. 2218","children":[],"tail":"], and recent amendments to that Act, the Congress has sought to enable the poor to participate in the process of development;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee09dfa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Inter-American Foundation, established by Congress in the Foreign Assistance Act of 1969 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s290f"},"text":"22 U.S.C. 290f","children":[],"tail":"], to support the efforts of the people of Latin America and the Caribbean to solve their development problems, has demonstrated a successful approach to development; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ee09dfb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an African Development Foundation similar in structure to the Inter-American Foundation, but adapted to the specific needs of Africa, can complement current United States development programs in Africa.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee09dfc-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/533/tV/s502"},"text":"Pub. L. 96–533, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3151"},"text":"94 Stat. 3151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/2/tV/s586/h/1"},"text":"Pub. L. 106–113, div. B, § 1000(a)(2) [title V, § 586(h)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–119.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ee09dfd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"ro