{"tag":"section","attrib":{"id":"id8fad8a4b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2389"},"text":null,"children":[{"tag":"num","attrib":{"value":"2389"},"text":"§ 2389.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status and benefits of personnel assigned or detailed to foreign governments or international organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fad8a4c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2389/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowances, privileges, rights, seniority, and other benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any officer or employee, while assigned or detailed under section 2387 or 2388 of this title shall be considered, for the purpose of preserving his allowances, privileges, rights, seniority, and other benefits as such, an officer or employee of the United States Government and of the agency of the United States Government from which detailed or assigned, and he shall continue to receive compensation, allowances, and benefits from funds appropriated to that agency or made available to that agency under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fad8a4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2389/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation allowances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any officer or employee assigned, detailed, or appointed under section 2387, 2388, 2391, or 2384(d) ","children":[{"tag":"ref","attrib":{"idref":"fn002151"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002151"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title is authorized to receive under such regulations as the President may prescribe, representation allowances similar to those allowed under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4085"},"text":"section 4085 of this title","children":[],"tail":". The authorization of such allowances and other benefits and the payment thereof out of any appropriations available therefor shall be considered as meeting all the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5536"},"text":"section 5536 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fad8a4e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. III, § 629, "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/452"},"text":"75 Stat. 452","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/565"},"text":"Pub. L. 87–565","children":[],"tail":", pt. III, § 302(d), "},{"tag":"date","attrib":{"date":"1962-08-01"},"text":"Aug. 1, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/262"},"text":"76 Stat. 262","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/137"},"text":"Pub. L. 90–137","children":[],"tail":", pt. III, § 302(f), "},{"tag":"date","attrib":{"date":"1967-11-14"},"text":"Nov. 14, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/460"},"text":"81 Stat. 460","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2203/b"},"text":"Pub. L. 96–465, title II, § 2203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[]