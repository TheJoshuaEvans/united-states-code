{"tag":"section","attrib":{"id":"id8f6f974b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2261"},"text":null,"children":[{"tag":"num","attrib":{"value":"2261"},"text":"§ 2261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f6f974c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency assistance; reports to Speaker of House and committees of Senate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f6f974d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2261/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the President is authorized to use funds made available to carry out any provision of this chapter (other than the provisions of part I of this subchapter) in order to provide, for any unanticipated contingencies, assistance authorized by subchapter I of this chapter in accordance with the provisions applicable to the furnishing of such assistance, except that the authority of this subsection may not be used to authorize the use of more than $25,000,000 during any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f6f974e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2261/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall report promptly to the Speaker of the House of Representatives and to the Committee on Foreign Relations and the Committee on Appropriations of the Senate each time he exercises the authority contained in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f6f974f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113/tVII/s734/a/1"},"text":"Pub. L. 97–113, title VII, § 734(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1560"},"text":"95 Stat. 1560","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f6f9750-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2261/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against payment of gifts to foreign officials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No part of this fund shall be used to pay for any gifts to any officials of any foreign government made heretofore or hereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f6f9751-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 451, "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/434"},"text":"75 Stat. 434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/565"},"text":"Pub. L. 87–565","children":[],"tail":", pt. I, § 109, "},{"tag":"date","attrib":{"date":"1962-08-01"},"text":"Aug. 1, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/259"},"text":"76 Stat. 259","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/205"},"text":"Pub. L. 88–205","children":[],"tail":", pt. I, § 110, "},{"tag":"date","attrib":{"date":"1963-12-16"},"text":"Dec. 16, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/384"},"text":"77 Stat. 384","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/633"},"text":"Pub. L. 88–633","children":[],"tail":", pt. I, § 108, "},{"tag":"date","attrib":{"date":"1964-10-07"},"text":"Oct. 7, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1010"},"text":"78 Stat. 1010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/171"},"text":"Pub. L. 89–171","children":[],"tail":", pt. I, § 108, "},{"tag":"date","attrib":{"date":"1965-09-06"},"text":"Sept. 6, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/656"},"text":"79 Stat. 656","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/371/s2"},"text":"Pub. L. 89–371, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-03-18"},"text":"Mar. 18, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/74"},"text":"80 Stat. 74","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/583"},"text":"Pub. L. 89–583","children":[],"tail":", pt. I, § 109, "},{"tag":"date","attrib":{"date":"1966-09-19"},"text":"Sept. 19, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/801"},"text":"80 Stat. 801","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/137"},"text":"Pub. L. 90–137","children":[],"tail":", pt. I, § 112, "},{"tag":"date","attrib":{"date":"1967-11-14"},"text":"Nov. 14, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/455"},"text":"81 Stat. 455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/554"},"text":"Pub. L. 90–554","children":[],"tail":", pt. I, § 110, "},{"tag":"date","attrib":{"date":"1968-10-08"},"text":"Oct. 8, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/962"},"text":"82 Stat. 962","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/175"},"text":"Pub. L. 91–175","children":[],"tail":", pt. I, § 110, "},{"tag":"date","attrib":{"date":"1969-12-30"},"text":"Dec. 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/819"},"text":"83 Stat. 819","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/652/s6/a"},"text":"Pub. L. 91–652, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1942"},"text":"84 Stat. 1942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/226"},"text":"Pub. L. 92–226","children":[],"tail":", pt. I, § 108, "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/24"},"text":"86 Stat. 24","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/189/s10"},"text":"Pub. L. 93–189, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-17"},"text":"Dec. 17, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/719"},"text":"87 Stat. 719","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/559/s28/c"},"text":"Pub. L. 93–559, § 28(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-30"},"text":"Dec. 30, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1803"},"text":"88 Stat. 1803","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/329/tV/s503/2"},"text":"Pub. L. 94–329, title V, § 503(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-30"},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/763"},"text":"90 Stat. 763","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/92/s2"},"text":"Pub. L. 95–92, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/614"},"text":"91 Stat. 614","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/384/s2"},"text":"Pub. L. 95–384, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-26"},"text":"Sept. 26, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/730"},"text":"92 Stat. 730","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/92/s2/b"},"text":"Pub. L. 96–92, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-29"},"text":"Oct. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/701"},"text":"93 Stat. 701","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tVII/s734/a/1"},"text":"Pub. L. 97–113, title VII, § 734(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1560"},"text":"95 Stat. 1560","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/513/tV/s588"},"text":"Pub. L. 101–513, title V, § 588","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2056"},"text":"104 Stat. 2056","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f720852-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f720853-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f720854-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", known as the Foreign Assistance Act of 1961. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f720855-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513"},"text":"Pub. L. 101–513","children":[],"tail":" struck out “not to exceed $10,000,000 of” after “authorized to use” and “in any fiscal year” after “funds made available”, substituted “unanticipated contingencies” for “emergency purposes”, and directed the amendment of subsec. (a) by inserting before the period “, except that the authority of this subsection may not be used to authorize the use of more than $25,000,000 during any fiscal year”, which was executed by making the insertion before the period in par. (1) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113"},"text":"Pub. L. 97–113","children":[],"tail":" struck out subsec. (b) which required quarterly Presidential reports to Committees of Senate and Speaker of House on the programming and obligation of funds under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/92"},"text":"Pub. L. 96–92","children":[],"tail":" designated existing provisions as par. (1), substituted authorization of $10,000,000 when made available in any fiscal year for emergency purposes for appropriation authorization of $5,000,000 for emergency purposes in fiscal year 1979, and deleted provision making appropriated amounts available until expended."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/92"},"text":"Pub. L. 96–92","children":[],"tail":" added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/384"},"text":"Pub. L. 95–384","children":[],"tail":" substituted “fiscal year 1979 not to exceed $5,000,000” for “fiscal year 1978 not to exceed $5,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/92"},"text":"Pub. L. 95–92","children":[],"tail":" substituted provisions authorizing appropriations of not to exceed $5,000,000 for fiscal year 1978, for provisions authorizing appropriations of not to exceed $5,000,000 for fiscal years 1976 and 1977."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/329"},"text":"Pub. L. 94–329","children":[],"tail":" substituted “fiscal year 1976 not to exceed $5,000,000 and for the fiscal year 1977 not to exceed $5,000,000” for “fiscal year 1975 not to exceed $5,000,000,” and “authorized by subchapter I of this chapter for any emergency” for “authorized by this subchapter or by "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2399"},"text":"section 2399 of this title","children":[],"tail":" for any emergency” and inserted provision authorizing that funds appropriated remain available until expended."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/559"},"text":"Pub. L. 93–559","children":[],"tail":" substituted appropriations authorization of $5,000,000 for fiscal year 1975 for prior authorization of $30,000,000 for fiscal years 1974, and 1975, and authorized assistance under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2399"},"text":"section 2399 of this title","children":[],"tail":" and for any emergency purpose."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/559"},"text":"Pub. L. 93–559","children":[],"tail":" substantially reenacted subsec. (b) provisions, substituting “submit” for “provide”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/559"},"text":"Pub. L. 93–559","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/189"},"text":"Pub. L. 93–189","children":[],"tail":" substituted provisions authorizing the appropriation of not to exceed $30,000,000 for each of the fiscal years 1974 and 1975, for provisions authorizing the appropriation of not to exceed $30,000,000 for each of the fiscal years 1972 and 1973, substituted “to provide assistance authorized by this subchapter primarily for disaster relief purposes, in accordance with the provisions applicable to the furnishing of such assistance”, for “for use by the President for assistance authorized by this subchapter in accordance with the provisions applicable to the furnishing of such assistance, when he determines such use to be important to the national interest”, and struck out a proviso for the use of $15,000,000, in addition to any other available funds, out of the funds appropriated for fiscal year 1971 for the flood victims of the East Pakistan flood."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226"},"text":"Pub. L. 92–226","children":[],"tail":" authorized appropriations not to exceed $30,000,000 for fiscal years 1972 and 1973, and struck out provision for authorization of not to exceed $15,000,000 for fiscal year 1970, and not to exceed $30,000,000 for fiscal year 1971."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/652"},"text":"Pub. L. 91–652","children":[],"tail":" substituted “1971 not to exceed $30,000,000” for “1971 not to exceed $15,000,000”, and inserted proviso which required $15,000,000 of the amount authorized for the fiscal year 1971 to be used for the relief of cyclone, etc., victims in East Pakistan."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/175"},"text":"Pub. L. 91–175","children":[],"tail":" substituted “ fiscal year 1970 not to exceed $15,000,000, and for the fiscal year 1971 not to exceed $15,000,000” for “fiscal year 1968 not to exceed $50,000,000, and for the fiscal year 1969 not to exceed $10,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/554"},"text":"Pub. L. 90–554","children":[],"tail":" authorized an appropriation of $10,000,000 for fiscal year 1969."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/137"},"text":"Pub. L. 90–137","children":[],"tail":" substituted “1968” and “$50,000,000” for “1967” and “$110,000,000”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/583/s109/a"},"text":"Pub. L. 89–583, § 109(a)","children":[],"tail":", substituted “1967” and “$110,000,000” for “1966” and “$150,000,000”, respectively, and struck out second and third sentences which authorized withholding of assistance, from fiscal year 1966 funds, to any country permitting transportation of equipment, materials, or commodities to or from North Vietnam unless contrary to national interest of United States and authorized the appropriation of such sums, not to exceed $89,000,000, as may be necessary in the fiscal year 1966 for programs authorized by subchapters I and II of this chapter, to the President for use in Southeast Asia."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/371"},"text":"Pub. L. 89–371","children":[],"tail":" substituted “$150,000,000” for “$50,000,000” and authorized withholding of assistance, from fiscal 1966 funds, to any country permitting transportation of equipment, materials, or commodities to or from North Vietnam unless contrary to national interest of United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/583/s109/b"},"text":"Pub. L. 89–583, § 109(b)","children":[],"tail":", struck out “the first sentence of” before “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/171/s108/a"},"text":"Pub. L. 89–171, § 108(a)","children":[],"tail":", substituted “1966” and “$50,000,000” for “1965” and “$150,000,000”, respectively, and authorized the appropriation of such sums, not to exceed $89,000,000, as may be necessary in the fiscal year 1966 for programs authorized by subchapters I and II of this chapter, to the President for use in Southeast Asia."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/171/s108/b"},"text":"Pub. L. 89–171, § 108(b)","children":[],"tail":", substituted “the first sentence of subsection (a) of this section” for “this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/633"},"text":"Pub. L. 88–633","children":[],"tail":" substituted “1965” and “$150,000,000” for “1964” and “$160,000,000”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/205"},"text":"Pub. L. 88–205","children":[],"tail":" substituted “1964” and “$160,000,000” for “1963” and “$300,000,000”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/565/s109/a"},"text":"Pub. L. 87–565, § 109(a)","children":[],"tail":", substituted “1963” for “1962”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/565/s109/b"},"text":"Pub. L. 87–565, § 109(b)","children":[],"tail":", substituted “provide quarterly reports to” for “keep”, and “on the programing and the obligation” for “currently informed of the use”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f720856-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f720857-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Subchapter I Deemed To Include Certain Parts of Subchapter II","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to subchapter I of this chapter are deemed to include parts IV (§ 2346 et seq.), VI (§ 2348 et seq.), and VIII (§ 2349aa et seq.) of subchapter II of this chapter, and references to subchapter II are deemed to exclude such parts. See ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226/s202/b"},"text":"section 202(b) of Pub. L. 92–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"section 2346 of this title","children":[],"tail":", and sections 2348c and 2349aa–5 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f720858-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Part I Deemed To Include Section 2293","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References to part I of this subchapter are deemed to include a reference to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2293"},"text":"section 2293 of this title","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2293/d/1"},"text":"section 2293(d)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f720859-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriation for Disaster Relief of Unallocated Excess Foreign Currencies Held in Pakistan","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/652/s6/b"},"text":"Pub. L. 91–652, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1943"},"text":"84 Stat. 1943","children":[],"tail":", authorized the appropriation of excess foreign currencies held in Pakistan not allocated on "},{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":", for a period of one year from such date to help Pakistan withstand the disaster which had occurred."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f72085a-2930-11f1-8918-be39dde81dc6"},"text":null