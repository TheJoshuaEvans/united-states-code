{"tag":"section","attrib":{"id":"id8eb80768-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s282m"},"text":null,"children":[{"tag":"num","attrib":{"value":"282m"},"text":"§ 282m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to vote for capital increases necessary to support economic restructuring in independent states of former Soviet Union","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Corporation may vote in favor of any increase in the capital stock of the Corporation that may be needed to accommodate the requirements of the independent states of the former Soviet Union (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s5801"},"text":"section 5801 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eb80769-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch788/s15"},"text":"Aug. 11, 1955, ch. 788, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/511/tX/s1005"},"text":"Pub. L. 102–511, title X, § 1005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3361"},"text":"106 Stat. 3361","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
