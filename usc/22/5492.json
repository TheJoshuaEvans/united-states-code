{"tag":"section","attrib":{"id":"id90902289-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5492"},"text":null,"children":[{"tag":"num","attrib":{"value":"5492"},"text":"§ 5492.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of the Republic of Hungary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9090228a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5492/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9090228b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5492/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"1989-10-23"},"text":"October 23, 1989","children":[],"tail":", in a public ceremony in Budapest, the acting President of Hungary declared the Hungarian state to be an independent, democratic Republic of Hungary;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9090228c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5492/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this public ceremony was held on the 33d anniversary of Hungary’s 1956 revolution that was bloodily suppressed by Soviet troops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9090228d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5492/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this public ceremony was held in the same Kossuth Square where the first mass rally of the 1956 revolution was held;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9090228e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5492/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a further symbol of Hungary’s faithfulness to the legacy of the revolution of 1956, the declaration by the acting President was made from the same balcony from which Imre Nagy, the martyred Prime Minister of the revolutionary government of 1956, addressed the citizens of Budapest 33 years before;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9090228f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5492/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the heroic revolt and freedom fight of the Hungarian people in 1956 was an inspirational event, reminding a generation of Americans of the sacrifices people are willing to undertake as the price of liberty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90902290-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5492/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present efforts of the Hungarian people to validate the legacy of the revolution of 1956 by establishing a free, independent, and prosperous Hungary have gained the sympathy and admiration of the American people.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90902291-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5492/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declarations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90902292-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5492/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" congratulates the people of Hungary on the declaration of a Republic of Hungary committed to democratic principles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90902293-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5492/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expresses its desire to enhance the friendly relations between the people of Hungary and the people of the United States and between their respective governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90902294-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tVIII/s802"},"text":"Pub. L. 101–179, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1322"},"text":"103 Stat. 1322","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
