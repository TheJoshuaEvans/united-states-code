{"tag":"section","attrib":{"id":"id903f1d1c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622"},"text":null,"children":[{"tag":"num","attrib":{"value":"3622"},"text":"§ 3622.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Code of conduct for Commission personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id903f1d1d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oath; compliance with laws of United States regarding duties and responsibilities of Federal employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before assuming the duties of his office or employment, each member of the Board of the Commission and each officer and employee of the Commission shall take an oath to discharge faithfully the duties of his office or employment. All employees of the Commission shall be subject to the laws of the United States regarding duties and responsibilities of Federal employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1d1e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adoption of code of conduct; time limit; contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after all the members of the Board of the Commission have been appointed, the Board shall adopt a code of conduct applicable to the persons referred to in subsection (a) of this section. The code of conduct shall contain provisions substantially equivalent to those contained in part 735 of title 5 of the Code of Federal Regulations on ","children":[{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":". The code of conduct shall, at a minimum, contain provisions substantially equivalent to the following provisions of law:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id903f1d1f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of chapter 11 of title 18, relating to bribery, graft, or conflicts of interest, as appropriate to the employees concerned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1d20-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7352"},"text":"section 7352 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1d21-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 207, 208, 285, 508, 641, 645, 1001, 1917, and 2071 of title 18;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1d22-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1343, 1344, and 1349(b) of title 31;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1d23-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 131 of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1d24-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those provisions of the laws and regulations of the Republic of Panama which are substantially equivalent to those of the United States set forth in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1d25-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations by Commission respecting violations; recommendations for suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall investigate any allegations regarding the violation of the code of conduct adopted pursuant to subsection (b) of this section. The Commission may recommend that the President suspend from the performance of his duties any member of the Board of the Commission or any officer or employee of the Commission, pending judicial proceedings by appropriate authorities concerning such allegations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1d26-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measures to insure compliance with code of conduct","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall negotiate suitable arrangements with the Republic of Panama whereby each nation shall agree to take all measures within its legal authority to assure that members of the Board of the Commission comply with the code of conduct established pursuant to subsection (b) of this section. Without prejudice to such jurisdiction as the United States may have with respect to members of the Board, the provisions of law enumerated in subsection (b) of this section shall be enforced with respect to members of the Board only in accordance with such arrangements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1d27-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of post-employment restrictions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903f1d28-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s207"},"text":"Section 207 of title 18","children":[],"tail":" does not apply to a covered individual with respect to acts done in carrying out official duties as an officer or employee of the Panama Canal Authority."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1d29-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (1), a covered individual is an officer or employee of the Panama Canal Authority who was an officer or employee of the Commission (other than the Administrator) and whose employment with the Commission terminated at noon on the Canal Transfer Date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1d2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection is effective as of the Canal Transfer Date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1d2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consent for acceptance of employment by Panama Canal Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903f1d2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress consents to the following persons accepting civil employment (and compensation for that employment) with the Panama Canal Authority for which the consent of the Congress is required by the last paragraph of section 9 of article I of the Constitution of the United States, relating to acceptance of emoluments, offices, or titles from a foreign government:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id903f1d2d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retired members of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903f1d2e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of a reserve component of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id903f1d2f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Commissioned Reserve Corps ","children":[{"tag":"ref","attrib":{"idref":"fn002265"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002265"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" of the Public Health Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1d30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3622/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The consent of the Congress under paragraph (1) is effective without regard to subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s908"},"text":"section 908 of title 37","children":[],"tail":" (relating to approval required for employment of Reserve and retired members by foreign governments)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903f1d31-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1112"},"text":"Pub. L. 96–70, title I, § 1112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/459"},"text":"93 Stat. 459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dC/tXXXV"},"text":"Pub. L. 105–85, div. C, title XXXV","children":[],"tail":", §§ 3522, 3550(d)(2)(A), "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2064"},"text":"111 Stat. 2064","children":[],"tail":", 2074; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/31"},"text":"Pub. L. 117–286, § 4(c)(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4358"},"text":"136 Stat. 4358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903f1d32-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id903f1d33-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id903f1d34-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(4), “sections 1343, 1344, and 1349(b) of title 31” substituted for “","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-07-16/s5"},"text":"section 5 of the Act of July 16, 1914","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s638a"},"text":"31 U.S.C. 638a","children":[],"tail":"), as amended” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s4/b"},"text":"Pub. L. 97–258, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":", the first section of which enacted Title 31, Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id903f1d35-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 131 of title 5;” for “the Ethics in Government Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/stat/92/1824"},"text":"92 Stat. 1824","children":[],"tail":"), as amended;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s3550/d/2/A"},"text":"Pub. L. 105–85, § 3550(d)(2)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"October 1, 1979","children":[],"tail":"” for “the effective date of this Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s3522"},"text":"Pub. L. 105–85, § 3522","children":[],"tail":", added subsecs. (e) and (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id903f1d36-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id903f1d37-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to Reserve Corps of the Public Health Service deemed to be a reference to the Ready Reserve Corps, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s204/c/3"},"text":"section 204(c)(3) of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id903f1d38-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id903f1d39-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions vested in President by subsec. (d) of this section delegated to Secretary of State, see section 1–402 of Ex. Ord. No. 12215, ","children":[{"tag":"date","attrib":{"date":"1980-05-27"},"text":"May 27, 1980","children":[],"tail":", 45 F.R. 36044, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"section 3601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
