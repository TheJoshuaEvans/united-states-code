{"tag":"section","attrib":{"id":"id911a61a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9001"},"text":null,"children":[{"tag":"num","attrib":{"value":"9001"},"text":"§ 9001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and declarations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id911a61a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9001/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a61aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9001/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The international abduction or wrongful retention of children is harmful to their well-being.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9001/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons should not be permitted to obtain custody of children by virtue of their wrongful removal or retention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61ac-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9001/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" International abductions and retentions of children are increasing, and only concerted cooperation pursuant to an international agreement can effectively combat this problem.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61ad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9001/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Convention on the Civil Aspects of International Child Abduction, done at The Hague on ","children":[{"tag":"date","attrib":{"date":"1980-10-25"},"text":"October 25, 1980","children":[],"tail":", establishes legal rights and procedures for the prompt return of children who have been wrongfully removed or retained, as well as for securing the exercise of visitation rights. Children who are wrongfully removed or retained within the meaning of the Convention are to be promptly returned unless one of the narrow exceptions set forth in the Convention applies. The Convention provides a sound treaty framework to help resolve the problem of international abduction and retention of children and will deter such wrongful removals and retentions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id911a61ae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9001/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declarations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress makes the following declarations:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id911a61af-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9001/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the purpose of this chapter to establish procedures for the implementation of the Convention in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61b0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9001/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this chapter are in addition to and not in lieu of the provisions of the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61b1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9001/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In enacting this chapter the Congress recognizes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id911a61b2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9001/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the international character of the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id911a61b3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9001/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for uniform international interpretation of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id911a61b4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9001/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Convention and this chapter empower courts in the United States to determine only rights under the Convention and not the merits of any underlying child custody claims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id911a61b5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/300/s2"},"text":"Pub. L. 100–300, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/437"},"text":"102 Stat. 437","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id911a61b6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id911a61b7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id911a61b8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act” meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/300"},"text":"Pub. L. 100–300","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/437"},"text":"102 Stat. 437","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id911a61b9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s11601"},"text":"section 11601 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id911a61ba-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id911a61bb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/370/s1"},"text":"Pub. L. 108–370, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-25"},"text":"Oct. 25, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1750"},"text":"118 Stat. 1750","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/370/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9006"},"text":"section 9006 of this title","children":[],"tail":"] may be cited as the ‘Prevention of Child Abduction Partnership Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id911a61bc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/300/s1"},"text":"Pub. L. 100–300, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-29"},"text":"Apr. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/437"},"text":"102 Stat. 437","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/300/s1"},"text":"“This Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s663"},"text":"section 663 of Title 42","children":[],"tail":", The Public Health and Welfare] may be cited as the ‘International Child Abduction Remedies Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
