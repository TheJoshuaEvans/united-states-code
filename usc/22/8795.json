{"tag":"section","attrib":{"id":"id9110ebad-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795"},"text":null,"children":[{"tag":"num","attrib":{"value":"8795"},"text":"§ 8795.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9110ebae-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of this subchapter and any sanctions imposed pursuant to this subchapter shall terminate on the date on which the President submits to the appropriate congressional committees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9110ebaf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the certification described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110ebb0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a certification that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9110ebb1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government of Syria is democratically elected and representative of the people of Syria; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9110ebb2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a legitimate transitional government of Syria is in place.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9110ebb3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A certification described in this subsection is a certification by the President that the Government of Syria—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9110ebb4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has unconditionally released all political prisoners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110ebb5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has ceased its practices of violence, unlawful detention, torture, and abuse of citizens of Syria engaged in peaceful political activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110ebb6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has ceased its practice of procuring sensitive technology designed to restrict the free flow of unbiased information in Syria, or to disrupt, monitor, or otherwise restrict the right of citizens of Syria to freedom of expression;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110ebb7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has ceased providing support for foreign terrorist organizations and no longer allows such organizations, including Hamas, Hezbollah, and Palestinian Islamic Jihad, to maintain facilities in territory under the control of the Government of Syria; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110ebb8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has ceased the development and deployment of medium- and long-range surface-to-surface ballistic missiles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110ebb9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not pursuing or engaged in the research, development, acquisition, production, transfer, or deployment of biological, chemical, or nuclear weapons, and has provided credible assurances that it will not engage in such activities in the future; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9110ebba-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has agreed to allow the United Nations and other international observers to verify that the Government of Syria is not engaging in such activities and to assess the credibility of the assurances provided by that Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9110ebbb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8795/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of sanctions after election of democratic government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the President submits to the appropriate congressional committees the certification described in subsection (a)(2), the President may suspend the provisions of this subchapter and any sanctions imposed under this subchapter for not more than 180 days to allow time for a certification described in subsection (b) to be submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9110ebbc-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158/tVII/s706"},"text":"Pub. L. 112–158, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1268"},"text":"126 Stat. 1268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9110ebbd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9110ebbe-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id9110ebbf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (a) and (c), was in the original a reference to title VII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/158"},"text":"Pub. L. 112–158","children":[],"tail":", which enacted this subchapter and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
