{"tag":"section","attrib":{"id":"id9062d12b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4058"},"text":null,"children":[{"tag":"num","attrib":{"value":"4058"},"text":"§ 4058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimate of appropriations needed","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall prepare the estimates of the annual appropriations required to be made to the Fund, and shall make actuarial valuations of the System at intervals of not more than five years. The Secretary of State may expend from money to the credit of the Fund an amount not exceeding $5,000 per year for the incidental expenses necessary in administering the provisions of this part, including actuarial advice.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9062d12c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s818"},"text":"Pub. L. 96–465, title I, § 818","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2120"},"text":"94 Stat. 2120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tIV/s402/a/2"},"text":"Pub. L. 99–335, title IV, § 402(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/609"},"text":"100 Stat. 609","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9062d12d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9062d12e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","childre