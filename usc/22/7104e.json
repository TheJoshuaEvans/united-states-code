{"tag":"section","attrib":{"id":"id90d2d161-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104e"},"text":null,"children":[{"tag":"num","attrib":{"value":"7104e"},"text":"§ 7104e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventing future trafficking in the United States through receipt of complaints abroad","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90d2d162-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall ensure that each diplomatic or consular post or other mission designates an employee to be responsible for receiving information from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90d2d163-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who was a victim of a severe form of trafficking in persons (as such term is defined in section 7102(14) ","children":[{"tag":"ref","attrib":{"idref":"fn002368"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002368"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) while present in the United States; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90d2d164-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who has information regarding a victim described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d2d165-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any information received pursuant to subsection (a) shall be transmitted to the Department of Justice, the Department of Labor, the Department of Homeland Security, and to any other relevant Federal agency for appropriate response. The Attorney General, the Secretary of Labor, the Secretary of Homeland Security, and the head of any other such relevant Federal agency shall establish a process to address any actions to be taken in response to such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90d2d166-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7104e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from foreign governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The employee designated for receiving information pursuant to subsection (a) should coordinate with foreign governments or civil society organizations in the countries of origin of victims of severe forms of trafficking in persons, with the permission of and without compromising the safety of such victims, to ensure that such victims receive any additional support available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90d2d167-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/425/tI/s102"},"text":"Pub. L. 115–425, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-08"},"text":"Jan. 8, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5474"},"text":"132 Stat. 5474","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90d2d168-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90d2d169-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90d2d16a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/14"},"text":"Section 7102(14) of this title","children":[],"tail":", referred to in subsec. (a)(1), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/16"},"text":"section 7102(16) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/427/s2/1"},"text":"Pub. L. 115–427, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5503"},"text":"132 Stat. 5503","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90d2d16b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Frederick Douglass Trafficking Victims Prevention and Protection Reauthorization Act of 2018, and not as part of the Trafficking Victims Protection Act of 2000 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
