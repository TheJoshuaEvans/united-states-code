{"tag":"section","attrib":{"id":"id8eac2037-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276p"},"text":null,"children":[{"tag":"num","attrib":{"value":"276p"},"text":"§ 276p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Senate-Japan Interparliamentary Group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8eac2038-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not to exceed 12 Senators shall be appointed to meet once per Congress with representatives of the Diet of Japan for discussion of common problems in the interest of relations between the United States and Japan. The Senators so appointed shall be referred to as the “United States group” of the United States Senate-Japan Interparliamentary Group. The meetings shall take place in Japan and Washington, D.C. alternatively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac2039-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President of the Senate shall appoint Senators under this section, including a Chair and Vice Chair, upon recommendations of the majority and minority leaders of the Senate. Such appointments shall be for the duration of each Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac203a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $100,000 for each Congress to assist in meeting the expenses of the United States group. Appropriations shall be disbursed on vouchers to be approved by the Chair of the United States group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac203b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276p/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A report of expenditures by the United States group shall be prepared and certified each Congress by the Chair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8eac203c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s276p/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall apply to fiscal year 2008, and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8eac203d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s5"},"text":"Pub. L. 110–161, div. H, title I, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2221"},"text":"121 Stat. 2221","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
