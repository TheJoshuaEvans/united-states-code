{"tag":"section","attrib":{"id":"id91218e2e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9229"},"text":null,"children":[{"tag":"num","attrib":{"value":"9229"},"text":"§ 9229.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on and imposition of sanctions to address persons responsible for knowingly engaging in significant activities undermining cybersecurity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91218e2f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9229/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91218e30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9229/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall submit to the appropriate congressional committees a report that describes significant activities undermining cybersecurity aimed against the United States Government or any United States person and conducted by the Government of North Korea, or a person owned or controlled, directly or indirectly, by the Government of North Korea or any person acting for or on behalf of that Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218e31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9229/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report required under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91218e32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9229/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity and nationality of persons that have knowingly engaged in, directed, or provided material support to conduct significant activities undermining cybersecurity described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218e33-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9229/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the conduct engaged in by each person identified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218e34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9229/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the extent to which a foreign government has provided material support to the Government of North Korea or any person acting for or on behalf of that Government to conduct significant activities undermining cybersecurity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218e35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9229/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States strategy to counter North Korea’s efforts to conduct significant activities undermining cybersecurity against the United States, that includes efforts to engage foreign governments to halt the capability of the Government of North Korea and persons acting for or on behalf of that Government to conduct significant activities undermining cybersecurity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91218e36-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9229/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission and form","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91218e37-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9229/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required under paragraph (1) shall be submitted not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2018-10-25"},"text":"October 25, 2018","children":[],"tail":", and every 180 days thereafter for 5 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91218e38-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9229/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required under paragraph (1) shall be submitted in an unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91218e39-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9229/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall designate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9214/a"},"text":"section 9214(a) of this title","children":[],"tail":" any person identified in the report required under subsection (a)(1) that knowingly engages in significant activities undermining cybersecurity through the use of computer networks or systems against foreign persons, governments, or other entities on behalf of the Government of North Korea."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91218e3a-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/122/tII/s209"},"text":"Pub. L. 114–122, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"Feb. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/110"},"text":"130 Stat. 110","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/272/tIII/s303/c/1"},"text":"Pub. L. 115–272, title III, § 303(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-25"},"text":"Oct. 25, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4157"},"text":"132 Stat. 4157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91218e3b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91218e3c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id91218e3d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/272"},"text":"Pub. L. 115–272","children":[],"tail":" substituted “not later than 90 days after "},{"tag":"date","attrib":{"date":"2018-10-25"},"text":"October 25, 2018","children":[],"tail":", and every 180 days thereafter for 5 years” for “not later than 90 days after "},{"tag":"date","attrib":{"date":"2016-02-18"},"text":"February 18, 2016","children":[],"tail":", and every 180 days thereafter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id91218e3e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id91218e3f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions of President under this section, see Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2016-05-18"},"text":"May 18, 2016","children":[],"tail":", 81 F.R. 37479, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s9212"},"text":"section 9212 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
