{"tag":"section","attrib":{"id":"id90ed1076-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7712"},"text":null,"children":[{"tag":"num","attrib":{"value":"7712"},"text":"§ 7712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ed1077-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the third Friday of December of each year, the Chief Executive Officer shall submit a report to Congress describing the assistance provided pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7704"},"text":"section 7704 of this title","children":[],"tail":" during the most recently concluded fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed1078-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed1079-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7712/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of obligations and expenditures for assistance provided to each eligible country during the prior fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed107a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7712/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each eligible country, an assessment of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ed107b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7712/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made during each year by the country toward achieving the objectives set out in any Compact entered into by the country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed107c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7712/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7704"},"text":"section 7704 of this title","children":[],"tail":" has been effective in helping the country to achieve such objectives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed107d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7712/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the coordination of assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7704"},"text":"section 7704 of this title","children":[],"tail":" with other United States foreign assistance and related trade policies."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed107e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7712/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the coordination of assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7704"},"text":"section 7704 of this title","children":[],"tail":" with assistance provided by other donor countries."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed107f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7712/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information the President considers relevant with respect to assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7704"},"text":"section 7704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ed1080-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tVI/s613"},"text":"Pub. L. 108–199, div. D, title VI, § 613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/221"},"text":"118 Stat. 221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/167/tII/s204/b"},"text":"Pub. L. 115–167, title II, § 204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-04-23"},"text":"Apr. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1280"},"text":"132 Stat. 1280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLI/s5122/e"},"text":"Pub. L. 118–159, div. E, title LI, § 5122(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2431"},"text":"138 Stat. 2431","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ed1081-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ed1082-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90ed1083-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “Not later than "},{"tag":"date","attrib":{"date":"2005-03-31"},"text":"March 31, 2005","children":[],"tail":", and each March 31 thereafter, the President shall submit to Congress a report on the assistance provided under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7704"},"text":"section 7704 of this title","children":[],"tail":" during the prior fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167"},"text":"Pub. L. 115–167","children":[],"tail":" substituted “any Compact” for “the Compact”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90ed1084-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90ed1085-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/167"},"text":"Pub. L. 115–167","children":[],"tail":" applicable to Compacts entered into between the United States and an eligible country under this chapter before, on, or after "},{"tag":"date","attrib":{"date":"2018-04-23"},"text":"Apr. 23, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/167/s204/c"},"text":"section 204(c) of Pub. L. 115–167","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7708"},"text":"section 7708 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id90ed1086-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90ed1087-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Assignment of Function To Submit a Report Relating to Millennium Challenge Corporation Activities","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2005-03-31"},"text":"Mar. 31, 2005","children":[],"tail":", 70 F.R. 17195, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, the function of the President under section 613 of the Foreign Operations, Export Financing, and Related Programs Appropriations Act, 2004 (Division D of "},{"tag":"ref","attrib":{"href":"/us/pl/108/199"},"text":"Public Law 108–199","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7712"},"text":"22 U.S.C. 7712","children":[],"tail":"] is assigned to the Secretary of State."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Secretary of State shall perform such function in a manner consistent with the President’s constitutional authority to withhold information the disclosure of which could impair foreign relations, national security, the deliberative processes of the Executive, or the performance of the Executive’s constitutional duties. Heads of departments and agencies shall, to the extent permitted by law, furnish to the Secretary information the Secretary requests to perform such function, in the format and on the schedule specified by the Secretary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any reference in this memorandum to the provision of any Act shall be deemed to include references to any hereafter-enacted provision of law that is the same or substantially the same as such provision.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"George W. Bush.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
