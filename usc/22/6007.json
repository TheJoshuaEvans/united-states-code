{"tag":"section","attrib":{"id":"id90a5a6a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6007"},"text":null,"children":[{"tag":"num","attrib":{"value":"6007"},"text":"§ 6007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy toward a democratic Cuban Government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90a5a6a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may waive the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6005"},"text":"section 6005 of this title","children":[],"tail":" if the President determines and reports to the Congress that the Government of Cuba—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a5a6a3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has held free and fair elections conducted under internationally recognized observers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a6a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has permitted opposition parties ample time to organize and campaign for such elections, and has permitted full access to the media to all candidates in the elections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a6a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6007/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is showing respect for the basic civil liberties and human rights of the citizens of Cuba;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a6a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6007/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is moving toward establishing a free market economic system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a6a7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6007/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has committed itself to constitutional change that would ensure regular free and fair elections that meet the requirements of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90a5a6a8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the President makes a determination under subsection (a), the President shall take the following actions with respect to a Cuban Government elected pursuant to elections described in subsection (a):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90a5a6a9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To encourage the admission or reentry of such government to international organizations and international financial institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a6aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide emergency relief during Cuba’s transition to a viable economic system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90a5a6ab-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6007/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To take steps to end the United States trade embargo of Cuba.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90a5a6ac-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tXVII/s1708"},"text":"Pub. L. 102–484, div. A, title XVII, § 1708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2580"},"text":"106 Stat. 2580","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
