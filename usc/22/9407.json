{"tag":"section","attrib":{"id":"id9128b94a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9407"},"text":null,"children":[{"tag":"num","attrib":{"value":"9407"},"text":"§ 9407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of applicability of sanctions relating to Iran’s support for terrorism and its ballistic missile program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9128b94b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9407/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after ","children":[{"tag":"date","attrib":{"date":"2017-08-02"},"text":"August 2, 2017","children":[],"tail":", the President shall conduct a review of all persons on the list of specially designated nationals and blocked persons maintained by the Office of Foreign Assets Control of the Department of the Treasury for activities relating to Iran—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id9128b94c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9407/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to assess the conduct of such persons as that conduct relates to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9128b94d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9407/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity that materially contributes to the activities of the Government of Iran with respect to its ballistic missile program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9128b94e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9407/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support by the Government of Iran for acts of international terrorism; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b94f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9407/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to determine the applicability of sanctions with respect to such persons under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9128b950-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9407/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Executive Order No. 13382 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note; relating to blocking property of weapons of mass destruction delivery system proliferators and their supporters); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9128b951-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9407/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Executive Order No. 13224 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1701"},"text":"50 U.S.C. 1701","children":[],"tail":" note; relating to blocking property and prohibiting transactions with persons who commit, threaten to commit, or support terrorism)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9128b952-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9407/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of sanctions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the President determines under subsection (a) that sanctions under an Executive order specified in paragraph (2) of that subsection are applicable with respect to a person, the President shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9128b953-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9407/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose sanctions with respect to that person pursuant to that Executive order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9128b954-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9407/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise the waiver authority provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s9411"},"text":"section 9411 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9128b955-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tI/s108"},"text":"Pub. L. 115–44, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/894"},"text":"131 Stat. 894","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9128b956-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9128b957-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}