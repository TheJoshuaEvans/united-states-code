{"tag":"section","attrib":{"id":"id8fedef77-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656g"},"text":null,"children":[{"tag":"num","attrib":{"value":"2656g"},"text":"§ 2656g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on terrorist assets in United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fedef78-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning 90 days after ","children":[{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", and every 365 days thereafter, the Secretary of the Treasury, in consultation with the Attorney General and appropriate investigative agencies, shall submit to the Committee on Foreign Relations and the Committee on Finance of the Senate and the Committee on Foreign Affairs and the Committee on Ways and Means of the House of Representatives a report describing the nature and extent of assets held in the United States by terrorist countries and any organization engaged in international terrorism. Each such report shall provide a detailed list and description of specific assets."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fedef79-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fedef7a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “terrorist countries”, refers to countries designated by the Secretary of State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2780/d"},"text":"section 2780(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fedef7b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2656g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “international terrorism” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2656f/d"},"text":"section 2656f(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fedef7c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/tIII/s304"},"text":"Pub. L. 102–138, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/710"},"text":"105 Stat. 710","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s133/b/2"},"text":"Pub. L. 103–236, title I, § 133(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/396"},"text":"108 Stat. 396","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fedef7d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fedef7e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fedef7f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" substituted “Secretary of the Treasury, in consultation with the Attorney General and appropriate investigative agencies,” for “Secretary of the Treasury” and inserted at end “Each such report shall provide a detailed list and description of specific assets.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
