{"tag":"section","attrib":{"id":"id90cbcc0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6961"},"text":null,"children":[{"tag":"num","attrib":{"value":"6961"},"text":"§ 6961.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Task Force","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby established a task force on prohibition of importation of products of forced or prison labor from the People’s Republic of China (hereafter in this part referred to as the “Task Force”).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90cbcc10-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/286/dB/tV/s501"},"text":"Pub. L. 106–286, div. B, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-10"},"text":"Oct. 10, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/903"},"text":"114 Stat. 903","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
