{"tag":"section","attrib":{"id":"id903a3a8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3421"},"text":null,"children":[{"tag":"num","attrib":{"value":"3421"},"text":"§ 3421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional declaration of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Congress considers the establishment of the Multinational Force and Observers to be an essential stage in the development of a comprehensive settlement in the Middle East. The Congress enacts this subchapter with the hope and expectation that establishment of the Multinational Force and Observers will assist Egypt and Israel in fulfilling the Camp David accords and bringing about the establishment of a self-governing authority in order to provide full autonomy in the West Bank and Gaza.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id903a3a8d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/132/s2"},"text":"Pub. L. 97–132, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1693"},"text":"95 Stat. 1693","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903a3a8e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id903a3a8f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id903a3a90-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/132"},"text":"Pub. L. 97–132","children":[],"tail":", which enacted this subchapter, as the Multinational Force and Observers Participation Resolution, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/132/s1"},"text":"section 1 of Pub. L. 97–132","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3401"},"text":"section 3401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
