{"tag":"section","attrib":{"id":"id90f43c52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8007"},"text":null,"children":[{"tag":"num","attrib":{"value":"8007"},"text":"§ 8007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States-India scientific cooperative nuclear nonproliferation program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f43c53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy, acting through the Administrator of the National Nuclear Security Administration, is authorized to establish a cooperative nuclear nonproliferation program to pursue jointly with scientists from the United States and India a program to further common nuclear nonproliferation goals, including scientific research and development efforts, with an emphasis on nuclear safeguards (in this section referred to as “the program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f43c54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program shall be carried out in consultation with the Secretary of State and the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f43c55-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Academies recommendations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f43c56-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8007/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy shall enter into an agreement with the National Academies to develop recommendations for the implementation of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f43c57-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8007/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agreement entered into under paragraph (1) shall provide for the preparation by qualified individuals with relevant expertise and knowledge and the communication to the Secretary of Energy each fiscal year of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90f43c58-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8007/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for research and related programs designed to overcome existing technological barriers to nuclear nonproliferation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90f43c59-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8007/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of whether activities and programs funded under this section are achieving the goals of the activities and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f43c5a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8007/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recommendations and assessments prepared under this subsection shall be made publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f43c5b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8007/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with Nuclear Non-Proliferation Treaty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All United States activities related to the program shall be consistent with United States obligations under the Nuclear Non-Proliferation Treaty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f43c5c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8007/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this section for each of fiscal years 2007 through 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f43c5d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/401/tI/s109"},"text":"Pub. L. 109–401, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-18"},"text":"Dec. 18, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2739"},"text":"120 Stat. 2739","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
