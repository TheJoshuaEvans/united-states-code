{"tag":"section","attrib":{"id":"id90ed1088-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713"},"text":null,"children":[{"tag":"num","attrib":{"value":"7713"},"text":"§ 7713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of the Corporation; related provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ed1089-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed108a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have perpetual succession unless dissolved by a law enacted after ","children":[{"tag":"date","attrib":{"date":"2004-01-23"},"text":"January 23, 2004","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed108b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may adopt, alter, and use a seal, which shall be judicially noticed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed108c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make and perform such contracts, grants, and other agreements with any person or government however designated and wherever situated, as may be necessary for carrying out the functions of the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed108d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may determine and prescribe the manner in which its obligations shall be incurred and its expenses allowed and paid, including expenses for representation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed108e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may lease, purchase, or otherwise acquire, improve, and use such real property wherever situated, as may be necessary for carrying out the functions of the Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed108f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept cash gifts or donations of services or of property (real, personal, or mixed), tangible or intangible, for the purpose of carrying out the provisions of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1090-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may use the United States mails in the same manner and on the same conditions as the executive departments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1091-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may contract with individuals for personal services, who shall not be considered Federal employees for any provision of law administered by the Office of Personnel Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1092-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may hire or obtain passenger motor vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1093-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have such other powers as may be necessary and incident to carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed1094-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall maintain its principal office in the metropolitan area of Washington, District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed1095-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Positions with foreign governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When approved by the Chief Executive Officer, for purposes of implementing a Compact, employees of the Corporation (including individuals detailed to the Corporation) may accept and hold offices or positions to which no compensation is attached with governments or governmental agencies of foreign countries or with international organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed1096-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except to the extent inconsistent with the provisions of this chapter, the administrative authorities contained in the State Department Basic Authorities Act of 1956 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a"},"text":"22 U.S.C. 2651a","children":[],"tail":" et seq.) and the Foreign Assistance Act of 1961 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.) shall apply to the implementation of this chapter to the same extent and in the same manner as such authorities apply to the implementation of those Acts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed1097-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of Government Corporation Control Act","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed1098-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall be subject to chapter 91 of subtitle VI of title 31, except that the Corporation shall not be authorized to issue obligations or offer obligations to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed1099-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed109a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed109b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the United States Agency for International Development shall serve as Inspector General of the Corporation, and, in acting in such capacity, may conduct reviews, investigations, and inspections of all aspects of the operations and activities of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed109c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of the Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the responsibilities under this subsection, the Inspector General shall report to and be under the general supervision of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed109d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement and authorization of services","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90ed109e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall reimburse the United States Agency for International Development for all expenses incurred by the Inspector General in connection with the Inspector General’s responsibilities under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90ed109f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount authorized to be appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7718/a"},"text":"section 7718(a) of this title","children":[],"tail":" for a fiscal year, up to $5,000,000 is authorized to be made available to the Inspector General of the United States Agency for International Development to conduct reviews, investigations, and inspections of operations and activities of the Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ed10a0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ed10a1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Executive Officer is authorized to contract with any nongovernmental organization (including a university, independent foundation, or other organization) in the United States or in a candidate country, and, where appropriate, directly with a governmental agency of any such country, that is undertaking research aimed at improving data related to eligibility criteria under this chapter with respect to the country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ed10a2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7713/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amount authorized to be appropriated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7718/a"},"text":"section 7718(a) of this title","children":[],"tail":" for a fiscal year, up to $5,000,000 is authorized to be made available to carry out paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ed10a3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tVI/s614"},"text":"Pub. L. 108–199, div. D, title VI, § 614","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/222"},"text":"118 Stat. 222","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ed10a4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ed10a5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90ed10a6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(6), (10), (d), and (g)(1), was in the original “this title”, meaning title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD"},"text":"Pub. L. 108–199, div. D","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/211"},"text":"118 Stat. 211","children":[],"tail":", which is classified generally to this chapter. For complete classification of this title to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7701"},"text":"section 7701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The State Department Basic Authorities Act of 1956, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"act Aug. 1, 1956, ch. 841","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/890"},"text":"70 Stat. 890","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90ed10a7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/s614"},"text":"section 614 of div. D of Pub. L. 108–199","children":[],"tail":". Subsec. (e)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/s614"},"text":"section 614 of div. D of Pub. L. 108–199","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9101"},"text":"section 9101 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
