{"tag":"section","attrib":{"id":"id90e8554c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633"},"text":null,"children":[{"tag":"num","attrib":{"value":"7633"},"text":"§ 7633.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to combat malaria","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90e8554d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e8554e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e8554f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to funds available under section 104(c) of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b/c"},"text":"22 U.S.C. 2151b(c)","children":[],"tail":") for such purpose or under any other provision of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.], there are authorized to be appropriated to the President, from amounts authorized to be appropriated under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7671"},"text":"section 7671 of this title","children":[],"tail":", $5,000,000,000 during the 5-year period beginning on "},{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":" to carry out section 104C of the Foreign Assistance Act of 1961, as added by subsection (a) ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b–4"},"text":"22 U.S.C. 2151b–4","children":[],"tail":"], including for the development of anti-malarial pharmaceuticals by the Medicines for Malaria Venture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e85550-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to paragraph (1) are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e85551-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of prior year funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unobligated balances of funds made available for fiscal year 2001, 2002, or 2003 under section 104(c) of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b/c"},"text":"22 U.S.C. 2151b(c)","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002388"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002388"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a second closing parenthesis."}],"tail":" (as in effect immediately before "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":") and made available for the control of malaria shall be transferred to, merged with, and made available for the same purposes as funds made available for fiscal years 2009 through 2013 under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e85552-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statement of policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Providing assistance for the prevention, control, treatment, and the ultimate eradication of malaria is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e85553-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a major objective of the foreign assistance program of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e85554-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 component of a comprehensive United States global health strategy to reduce disease burdens and strengthen communities around the world.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90e85555-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of a comprehensive 5-Year strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall establish a comprehensive, 5-year strategy to combat global malaria that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90e85556-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthens the capacity of the United States to be an effective leader of international efforts to reduce ","children":[{"tag":"ref","attrib":{"idref":"fn002389"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002389"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by “the”."}],"tail":" malaria burden;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e85557-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains sufficient flexibility and remains responsive to the ever-changing nature of the global malaria challenge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e85558-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes specific objectives and multisectoral approaches and strategies to reduce the prevalence, mortality, incidence, and spread of malaria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e85559-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how this strategy would contribute to the United States’ overall global health and development goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e8555a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clearly explains how outlined activities will interact with other United States Government global health activities, including the 5-year global AIDS strategy required under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e8555b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expands public-private partnerships and leverage of resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e8555c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinates among relevant Federal agencies to maximize human and financial resources and to reduce duplication among these agencies, foreign governments, and international organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e8555d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinates with other international entities, including the Global Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e8555e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizes United States capabilities in the areas of technical assistance and training and research, including vaccine research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90e8555f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishes priorities and selection criteria for the distribution of resources based on factors such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90e85560-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size and demographics of the population with malaria;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85561-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of that population;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85562-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the country’s existing infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90e85563-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7633/d/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to closely coordinate United States Government efforts with national malaria control plans of partner countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90e85564-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25/tIII/s303"},"text":"Pub. L. 108–25, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/736"},"text":"117 Stat. 736","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/293/tIII/s303/b"},"text":"Pub. L. 110–293, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2960"},"text":"122 Stat. 2960","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90e85565-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90e85566-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90e85567-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (d)(5), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25"},"text":"Pub. L. 108–25","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-05-27"},"text":"May 27, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/711"},"text":"117 Stat. 711","children":[],"tail":", which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7601"},"text":"section 7601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90e85568-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/25/s303"},"text":"section 303 of Pub. L. 108–25","children":[],"tail":". Subsec. (a) and another subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/108/25/s303"},"text":"section 303 of Pub. L. 108–25","children":[],"tail":", respectively, enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b–4"},"text":"section 2151b–4 of this title","children":[],"tail":" and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b"},"text":"section 2151b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90e85569-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293/s303/b/1/A"},"text":"Pub. L. 110–293, § 303(b)(1)(A)","children":[],"tail":", substituted “$5,000,000,000 during the 5-year period beginning on "},{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":"” for “such sums as may be necessary for fiscal years 2004 through 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293/s303/b/1/B"},"text":"Pub. L. 110–293, § 303(b)(1)(B)","children":[],"tail":", substituted “fiscal years 2009 through 2013” for “fiscal years 2004 through 2008”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/293/s303/b/2"},"text":"Pub. L. 110–293, § 303(b)(2)","children":[],"tail":", added subsecs. (c) relating to statement of policy and (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
