{"tag":"section","attrib":{"id":"id9003734f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2736d"},"text":"§ 2736d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payne fellowship authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90037350-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Undergraduate and graduate components of the Donald M. Payne International Development Fellowship Program may conduct outreach to attract outstanding students with an interest in pursuing a Foreign Service career who represent diverse ethnic and socioeconomic backgrounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90037351-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2736d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of past programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review past programs designed to increase minority representation in international affairs positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90037352-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dE/tLIV/s5407"},"text":"Pub. L. 117–81, div. E, title LIV, § 5407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2374"},"text":"135 Stat. 2374","childr