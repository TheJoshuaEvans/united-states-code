{"tag":"section","attrib":{"id":"id902998fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2805"},"text":null,"children":[{"tag":"num","attrib":{"value":"2805"},"text":"§ 2805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withdrawal of Federal recognition or participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may withdraw Federal recognition or participation whenever he finds that continuing recognition or participation would be inconsistent with the national interest and with the purposes of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id902998ff-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/269/s5"},"text":"Pub. L. 91–269, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-05-27"},"text":"May 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/272"},"text":"84 Stat. 272","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
