{"tag":"section","attrib":{"id":"id9018f670-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2777"},"text":null,"children":[{"tag":"num","attrib":{"value":"2777"},"text":"§ 2777.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal provisions relating to foreign military sales credits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9018f671-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2777/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible uses of cash payments under sections 2761, 2762, 2763, and 2769","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Cash payments received under sections 2761, 2762, and 2769 of this title and advances received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2763"},"text":"section 2763 of this title","children":[],"tail":" shall be available solely for payments to suppliers (including the military departments) and refunds to purchasers and shall not be available for financing credits and guaranties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9018f672-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2777/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds to miscellaneous receipts of Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts received from foreign governments and international organizations as repayments for credits extended pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2763"},"text":"section 2763 of this title","children":[],"tail":", amounts received from the disposition of instruments evidencing indebtedness under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2764/b"},"text":"section 2764(b) of this title","children":[],"tail":" (excluding such portion of the sales proceeds as may be required at the time of disposition to be obligated as a reserve for payment of claims under guaranties issued pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2764/b"},"text":"section 2764(b) of this title","children":[],"tail":", which sums are made available for such obligations), and other collections (including fees and interest) shall be transferred to the miscellaneous receipts of the Treasury."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9018f673-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2777/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credit of funds to reserve under section 2764(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of subsection (b), to the extent that any of the funds constituting the reserve under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2764/c"},"text":"section 2764(c) of this title","children":[],"tail":" are paid out for a claim arising out of a loan guaranteed under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2764"},"text":"section 2764 of this title","children":[],"tail":", amounts received from a foreign government or international organization after the date of such payment, with respect to such claim, shall be credited to such reserve, shall be merged with the funds in such reserve, and shall be available for any purpose for which funds in such reserve are available."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9018f674-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 3, § 37, "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1326"},"text":"82 Stat. 1326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/189/s25/11"},"text":"Pub. L. 93–189, § 25(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-17"},"text":"Dec. 17, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/731"},"text":"87 Stat. 731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/533/tI"},"text":"Pub. L. 96–533, title I","children":[],"tail":", §§ 104(b), 105(e)(1), "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3133"},"text":"94 Stat. 3133","children":[],"tail":", 3135.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9018f675-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9018f676-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9018f677-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/533/s105/e/1"},"text":"Pub. L. 96–533, § 105(e)(1)","children":[],"tail":", inserted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2769"},"text":"section 2769 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/533/s104/b"},"text":"Pub. L. 96–533, § 104(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/189"},"text":"Pub. L. 93–189","children":[],"tail":" inserted provisions relating to indebtedness under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2764/b"},"text":"section 2764(b) of this title","children":[],"tail":" and exclusions of portions of the sales proceeds required at the time of disposition as a reserve for payment of claims under guaranties issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2764/b"},"text":"section 2764(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9018f678-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id9018f679-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1968-07-01"},"text":"July 1, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/629/s41"},"text":"section 41 of Pub. L. 90–629","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
