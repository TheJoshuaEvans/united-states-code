{"tag":"section","attrib":{"id":"id8f613f08-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2174"},"text":null,"children":[{"tag":"num","attrib":{"value":"2174"},"text":"§ 2174.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American schools, libraries, and hospital centers abroad","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f613f09-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2174/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for schools and libraries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to furnish assistance, on such terms and conditions as he may specify, to schools and libraries outside the United States founded or sponsored by United States citizens and serving as study and demonstration centers for ideas and practices of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f613f0a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2174/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for hospital centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized, notwithstanding the provisions of the Mutual Defense Assistance Control Act of 1951 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1611"},"text":"22 U.S.C. 1611","children":[],"tail":" et seq.], to furnish assistance, on such terms and conditions as he may specify, to institutions referred to in subsection (a) of this section, and to hospital centers for medical education and research outside the United States, founded or sponsored by United States citizens."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f613f0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2174/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f613f0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2174/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out the purposes of this section, there are authorized to be appropriated to the President $35,000,000 for fiscal year 1986 and $35,000,000 for fiscal year 1987.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f613f0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2174/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts appropriated under paragraph (1) are authorized to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f613f0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2174/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pediatric plastic and reconstructive surgery centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of subsection (b), funds appropriated under this section may be used for assistance to centers for pediatric plastic and reconstructive surgery established by Children’s Medical Relief International, except that assistance may not be furnished for the domestic operations of any such center located in the United States, its territories or possessions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f613f0f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 214, "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/428"},"text":"75 Stat. 428","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/205"},"text":"Pub. L. 88–205","children":[],"tail":", pt. I, § 103(b), "},{"tag":"date","attrib":{"date":"1963-12-16"},"text":"Dec. 16, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/381"},"text":"77 Stat. 381","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/633"},"text":"Pub. L. 88–633","children":[],"tail":", pt. I, § 102(c), "},{"tag":"date","attrib":{"date":"1964-10-07"},"text":"Oct. 7, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1009"},"text":"78 Stat. 1009","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/171"},"text":"Pub. L. 89–171","children":[],"tail":", pt. I, § 103(b), "},{"tag":"date","attrib":{"date":"1965-09-06"},"text":"Sept. 6, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/654"},"text":"79 Stat. 654","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/583"},"text":"Pub. L. 89–583","children":[],"tail":", pt. I, § 103(c), "},{"tag":"date","attrib":{"date":"1966-09-19"},"text":"Sept. 19, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/798"},"text":"80 Stat. 798","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/137"},"text":"Pub. L. 90–137","children":[],"tail":", pt. I, § 103(c), "},{"tag":"date","attrib":{"date":"1967-11-14"},"text":"Nov. 14, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/450"},"text":"81 Stat. 450","children":[],"tail":"; "}