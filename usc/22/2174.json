attrib":{"date":"1978-10-06"},"text":"Oct. 6, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/950"},"text":"92 Stat. 950","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/tI/s111"},"text":"Pub. L. 96–53, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/363"},"text":"93 Stat. 363","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/533/tIV/s401"},"text":"Pub. L. 96–533, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3149"},"text":"94 Stat. 3149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tV/s501"},"text":"Pub. L. 97–113, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1538"},"text":"95 Stat. 1538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tIV/s401"},"text":"Pub. L. 99–83, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/217"},"text":"99 Stat. 217","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f613f10-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f613f11-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f613f12-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Mutual Defense Assistance Control Act of 1951, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-10-26/ch575"},"text":"act Oct. 26, 1951, ch. 575","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/644"},"text":"65 Stat. 644","children":[],"tail":", which was classified generally to chapter 20A (§ 1611 et seq.) of this title prior to its supersedure by former "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4619/e"},"text":"section 4619(e) of Title 50","children":[],"tail":", War and National Defense. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f613f13-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83"},"text":"Pub. L. 99–83","children":[],"tail":" amended subsec. (c) generally, designating existing provisions as pars. (1) and (2) and substituting provisions authorizing appropriations of $35,000,000 for fiscal years 1986 and 1987 for provisions authorizing appropriations of $20,000,000 for fiscal years 1982 and 1983."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/113"},"text":"Pub. L. 97–113","children":[],"tail":" substituted appropriations of $20,000,000 for fiscal years 1982 and 1983, for appropriation of $30,000,000 for fiscal year 1981."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/533"},"text":"Pub. L. 96–533","children":[],"tail":" substituted appropriations authorization of $30,000,000 for the fiscal year 1981 for such authorization of $25,000,000 for the fiscal year 1980."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":" extended authorization of appropriations from fiscal year 1979 to fiscal year 1980."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" substituted “$25,000,000 for the fiscal year 1979, which amount is” for “for the fiscal year 1977, $25,000,000, and for the fiscal year 1978, $25,000,000, which amounts are”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/424"},"text":"Pub. L. 95–424","children":[],"tail":" struck out subsec. (d) relating to authorization of appropriations, and subsec. (e) relating to submission of recommendations to Congress by the Secretary of State concerning assistance, and redesignated former subsec. (f) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88/s116/a/1"},"text":"Pub. L. 95–88, § 116(a)(1)","children":[],"tail":", struck out provisions authorizing appropriations of $19,000,000 for each of the fiscal years 1974 and 1975 and $25,000,000 for fiscal year 1976 and inserted provisions authorizing an appropriation of $25,000,000 for fiscal year 1978."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88/s116/a/2"},"text":"Pub. L. 95–88, § 116(a)(2)","children":[],"tail":", struck out provisions authorizing appropriations of $6,500,000 for each of the fiscal years 1974 and 1975 and an appropriation of $7,000,000 for fiscal year 1976 and inserted provisions authorizing an appropriation of $7,000,000 for fiscal year 1978."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88/s116/a/3"},"text":"Pub. L. 95–88, § 116(a)(3)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/161/s311/2/A"},"text":"Pub. L. 94–161, § 311(2)(A)","children":[],"tail":", authorized appropriation of $25,000,000 for fiscal years 1976 and 1977."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/161/s311/2/B"},"text":"Pub. L. 94–161, § 311(2)(B)","children":[],"tail":", authorized additional appropriation of $7,000,000 for fiscal years 1976 and 1977."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/189"},"text":"Pub. L. 93–189","children":[],"tail":" substituted provisions authorizing appropriations for the fiscal years 1974 and 1975, for provisions authorizing appropriations for the fiscal years 1972 and 1973 and directing that any amounts appropriated for the fiscal year 1970 be available for expenditure solely in accordance with the allocations set forth on pages 25 and 26 of House Report No. 91–611 and on page 23 of Senate Report No. 91–603."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/189"},"text":"Pub. L. 93–189","children":[],"tail":" substituted provisions authorizing the appropriation in fiscal years 1974 and 1975 of $6,500,000 in foreign currencies which the Secretary of the Treasury determines to be in excess to the normal requirements of the United States, for provisions authorizing the appropriation for the purposes of subsec. (b) of this section, in addition to funds otherwise available for such purposes, for the fiscal year 1970, of $3,000,000 in foreign currencies which the Secretary of the Treasury determines to be in excess of the normal requirement of the United States and directing that foreign currencies thus appropriated be available for expenditure solely in accordance with the allocation set forth on page 23 of Senate Report No. 91–603."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/189"},"text":"Pub. L. 93–189","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/226"},"text":"Pub. L. 92–226","children":[],"tail":" authorized appropriations of $30,000,000 for fiscal years 1972 and 1973, and struck out provision for authorization of $25,900,000 for fiscal year 1970, and $12,900,000 for fiscal year 1971."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/175/s103/1"},"text":"Pub. L. 91–175, § 103(1)","children":[],"tail":", substituted authorization of $25,900,000 for the fiscal year 1970 and $12,900,000 for the fiscal year 1971, for sum of $14,600,000 for the fiscal year 1969, and inserted provision making amounts appropriated under this subsection for the fiscal year 1970 available for expenditure solely in accordance with the allocations set forth on pages 25 and 26 of House Report No. 91–611 and on page 23 of Senate Report No. 91–603."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/175/s103/2"},"text":"Pub. L. 91–175, § 103(2)","children":[],"tail":", (3), substituted authorization of $3,000,000 for fiscal year 1970, for sum of $5,100,000 for fiscal year 1969, and inserted provision making foreign currencies appropriated under this subsection available for expenditure solely in accordance with the allocation set forth on page 23 of Senate Report No. 91–603."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/554/s102/c/1"},"text":"Pub. L. 90–554, § 102(c)(1)","children":[],"tail":", substituted authorization of $14,600,000 for fiscal year 1969, for sum of $14,000,000 for fiscal year 1968."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/554/s102/c/2"},"text":"Pub. L. 90–554, § 102(c)(2)","children":[],"tail":", substituted authorization of $5,100,000 for fiscal year 1969, for sum of $2,986,000 for fiscal year 1968."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/137/s103/c/1"},"text":"Pub. L. 90–137, § 103(c)(1)","children":[],"tail":", substituted authorization of $14,000,000 for fiscal year 1968 for sum of $10,989,000 for fiscal year 1967."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/137/s103/c/2"},"text":"Pub. L. 90–137, § 103(c)(2)","children":[],"tail":", substituted authorization of $2,986,000 for fiscal year 1968 for sum of $1,000,000 for fiscal year 1967."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/583/s103/c/1"},"text":"Pub. L. 89–583, § 103(c)(1)","children":[],"tail":", substituted “to institutions referred to in subsection (a) of this section, and to hospital centers for medical education and research outside the United States, founded or sponsored by United States citizens” for “to hospitals outside the United States founded or sponsored by United States citizens and serving as centers for medical education and research”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/583/s103/c/2"},"text":"Pub. L. 89–583, § 103(c)(2)","children":[],"tail":", substituted authorization of $10,989,000 for fiscal year 1967 for sum of $7,000,000 for fiscal year 1966."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/583/s103/c/3"},"text":"Pub. L. 89–583, § 103(c)(3)","childr