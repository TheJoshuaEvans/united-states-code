{"tag":"section","attrib":{"id":"id90aa613f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065"},"text":null,"children":[{"tag":"num","attrib":{"value":"6065"},"text":"§ 6065.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements and factors for determining transition government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90aa6140-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter, a transition government in Cuba is a government that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90aa6141-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has legalized all political activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6142-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has released all political prisoners and allowed for investigations of Cuban prisons by appropriate international human rights organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6143-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has dissolved the present Department of State Security in the Cuban Ministry of the Interior, including the Committees for the Defense of the Revolution and the Rapid Response Brigades; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6144-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has made public commitments to organizing free and fair elections for a new government—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90aa6145-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be held in a timely manner within a period not to exceed 18 months after the transition government assumes power;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90aa6146-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the participation of multiple independent political parties that have full access to the media on an equal basis, including (in the case of radio, television, or other telecommunications media) in terms of allotments of time for such access and the times of day such allotments are given; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90aa6147-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be conducted under the supervision of internationally recognized observers, such as the Organization of American States, the United Nations, and other election monitors;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6148-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has ceased any interference with Radio Marti or Television Marti broadcasts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6149-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" makes public commitments to and is making demonstrable progress in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90aa614a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing an independent judiciary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90aa614b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respecting internationally recognized human rights and basic freedoms as set forth in the Universal Declaration of Human Rights, to which Cuba is a signatory nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90aa614c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing the establishment of independent trade unions as set forth in conventions 87 and 98 of the International Labor Organization, and allowing the establishment of independent social, economic, and political associations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa614d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include Fidel Castro or Raul Castro; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa614e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has given adequate assurances that it will allow the speedy and efficient distribution of assistance to the Cuban people.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90aa614f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the requirements in subsection (a), in determining whether a transition government in Cuba is in power, the President shall take into account the extent to which that government—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90aa6150-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is demonstrably in transition from a communist totalitarian dictatorship to representative democracy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6151-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has made public commitments to, and is making demonstrable progress in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90aa6152-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effectively guaranteeing the rights of free speech and freedom of the press, including granting permits to privately owned media and telecommunications companies to operate in Cuba;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90aa6153-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permitting the reinstatement of citizenship to Cuban-born persons returning to Cuba;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90aa6154-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assuring the right to private property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90aa6155-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking appropriate steps to return to United States citizens (and entities which are 50 percent or more beneficially owned by United States citizens) property taken by the Cuban Government from such citizens and entities on or after ","children":[{"tag":"date","attrib":{"date":"1959-01-01"},"text":"January 1, 1959","children":[],"tail":", or to provide equitable compensation to such citizens and entities for such property;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6156-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has extradited or otherwise rendered to the United States all persons sought by the United States Department of Justice for crimes committed in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90aa6157-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6065/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has permitted the deployment throughout Cuba of independent and unfettered international human rights monitors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90aa6158-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114/tII/s205"},"text":"Pub. L. 104–114, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/811"},"text":"110 Stat. 811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90aa6159-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90aa615a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90aa615b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/114"},"text":"Pub. L. 104–114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-12"},"text":"Mar. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/785"},"text":"110 Stat. 785","children":[],"tail":", known as the Cuban Liberty and Democratic Solidarity (LIBERTAD) Act of 1996, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6021"},"text":"section 6021 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
