{"tag":"section","attrib":{"id":"id90f1f214-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7903"},"text":null,"children":[{"tag":"num","attrib":{"value":"7903"},"text":"§ 7903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology inventory for developing countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90f1f215-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Energy, in coordination with the Secretary of State and the Secretary of Commerce, shall conduct an inventory of greenhouse gas intensity reducing technologies that are developed, or under development in the United States, to identify technologies that are suitable for transfer to, deployment in, and commercialization in the developing countries identified in the report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7902/a/2/A"},"text":"section 7902(a)(2)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90f1f216-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the completion of the inventory under subsection (a), the Secretary of State and the Secretary of Energy shall jointly submit to Congress a report that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90f1f217-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the results of the completed inventory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f218-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies obstacles to the transfer, deployment, and commercialization of the inventoried technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f219-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7903/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes results from previous Federal reports related to the inventoried technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90f1f21a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7903/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an analysis of market forces related to the inventoried technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90f1f21b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/240/tVII/s733"},"text":"Pub. L. 101–240, title VII, § 733","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tXVI/s1611"},"text":"Pub. L. 109–58, title XVI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1114"},"text":"119 Stat. 1114","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90f1f21c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90f1f21d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90f1f21e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"Oct. 1, 2005","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/s739"},"text":"section 739 of Pub. L. 101–240","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7901"},"text":"section 7901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
