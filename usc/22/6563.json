{"tag":"section","attrib":{"id":"id90bfbe52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6563"},"text":null,"children":[{"tag":"num","attrib":{"value":"6563"},"text":"§ 6563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of AID","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90bfbe53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6563/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless abolished pursuant to the reorganization plan submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6601"},"text":"section 6601 of this title","children":[],"tail":", and except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6562"},"text":"section 6562 of this title","children":[],"tail":", there is within the Executive branch of Government the United States Agency for International Development as an entity described in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s104"},"text":"section 104 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90bfbe54-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6563/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall require the reappointment of any officer of the United States serving in the Agency for International Development of the United States International Development Cooperation Agency as of the day before the effective date of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90bfbe55-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIV, § 1413, "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-791"},"text":"112 Stat. 2681–791","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90bfbe56-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90bfbe57-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90bfbe58-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of this subchapter, referred to in subsec. (b), meaning the effective date of title XIV of subdiv. A of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1401"},"text":"section 1401 of Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6561"},"text":"section 6561 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
