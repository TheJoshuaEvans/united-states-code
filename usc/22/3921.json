{"tag":"section","attrib":{"id":"id904b033f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3921"},"text":null,"children":[{"tag":"num","attrib":{"value":"3921"},"text":"§ 3921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration by Secretary of State","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id904b0340-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3921/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under the direction of the President, the Secretary of State shall administer and direct the Service and shall coordinate its activities with the needs of the Department of State and other agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id904b0341-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3921/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State alone among the heads of agencies utilizing the Foreign Service personnel system shall perform the functions expressly vested in the Secretary of State by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id904b0342-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s201"},"text":"Pub. L. 96–465, title I, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2078"},"text":"94 Stat. 2078","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id904b0343-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id904b0344-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id904b0345-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2071"},"text":"94 Stat. 2071","children":[],"tail":", known as the Foreign Service Act of 1980, which is classified principally to this chapter (§ 3901 et seq.). For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id904b0346-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id904b0347-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Curtailments, Removals From Post, and Waivers of Privileges and Immunities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCII/s9209"},"text":"Pub. L. 117–263, div. I, title XCII, § 9209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3873"},"text":"136 Stat. 3873","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dI/tXCII/s9209"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Curtailments Report.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], and every 180 days thereafter, the Secretary [of State] shall submit a report to the appropriate congressional committees [Committee on Foreign Relations of the Senate and Committee on Foreign Affairs of the House of Representatives] regarding curtailments of Department [of State] personnel from overseas posts."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in the report required under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" relevant information about any post that, during the 6-month period preceding the report—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had more than 5 curtailments; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had curtailments representing more than 5 percent of Department personnel at such post; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each post referred to in subparagraph (A), the number of curtailments, disaggregated by month of occurrence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional contents for initial report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The initial report submitted pursuant to paragraph (1) shall identify—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of curtailments at the Deputy Chief of Mission or Principal Officer level for each of the previous 5 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent practicable—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"     “(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such curtailments that were voluntary and the number of such curtailments that were involuntary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"     “(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of those curtailed who left the service within 1 year after such curtailment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Removal of Diplomats","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 20 days after the date on which any United States personnel under Chief of Mission authority is declared persona non grata by a host government, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Committee on Foreign Relations of the Senate, the Select Committee on Intelligence of the Senate, the Committee on Foreign Affairs of the House of Representatives, and the Permanent Select Committee on Intelligence of the House of Representatives of such declaration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include with such notification—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the official reason for such declaration (if provided by the host government);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the declaration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the Department responded by declaring a host government’s diplomat in the United States persona non grata.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Privileges and Immunities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 15 days after any waiver of privileges and immunities pursuant to the Vienna Convention on Diplomatic Relations, done at Vienna ","children":[{"tag":"date","attrib":{"date":"1961-04-18"},"text":"April 18, 1961","children":[],"tail":", that is applicable to an entire diplomatic post or to the majority of United States personnel under Chief of Mission authority, the Secretary shall notify the appropriate congressional committees of such waiver and the reason for such waiver."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall terminate on the date that is 5 years after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id904d4d38-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Management Assessments at Diplomatic and Consular Posts","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCII/s9212"},"text":"Pub. L. 117–263, div. I, title XCII, § 9212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3874"},"text":"136 Stat. 3874","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dI/tXCII/s9212"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], the Secretary [of State] shall annually conduct, at each diplomatic and consular post, a voluntary survey, which shall be offered to all staff assigned to that post who are citizens of the United States (excluding the Chief of Mission) to assess the management and leadership of that post by the Chief of Mission, the Deputy Chief of Mission, and the Charge d’Affaires."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Anonymity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"All responses to the survey shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fully anonymized; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made available to the Director General of the Foreign Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Survey","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The survey shall seek to assess—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the general morale at post;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the presence of any hostile work environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the presence of any harassment, discrimination, retaliation, or other mistreatment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective leadership and collegial work environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director General Recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon compilation and review of the surveys, the Director General of the Foreign Service shall issue recommendations to posts, as appropriate, based on the findings of the surveys.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Referral","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the surveys reveal any action that is grounds for referral to the Inspector General of the Department of State and the Foreign Service, the Director General of the Foreign Service may refer the matter to the Inspector General of the Department of State and the Foreign Service, who shall, as the Inspector General considers appropriate, conduct an inspection of the post in accordance with section 209(b) of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3929/b"},"text":"22 U.S.C. 3929(b)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director General of the Foreign Service shall submit an annual report to the appropriate congressional committees [Committee on Foreign Relations of the Senate and Committee on Foreign Affairs of the House of Representatives] that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any trends or summaries from the surveys;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the posts where corrective action was recommended or taken in response to any issues identified by the surveys; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of referrals to the Inspector General of the Department of State and the Foreign Service, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial Basis","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The surveys and reports required under this section shall be carried out on an initial basis for the 5-year period beginning on the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id904d4d39-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Third Party Verification of Permanent Change of Station (PCS) Orders","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dI/tXCII/s9214"},"text":"Pub. L. 117–263, div. I, title XCII, § 9214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3875"},"text":"136 Stat. 3875","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dI/tXCII/s9214"},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], the Secretary [of State] shall establish a mechanism for third parties to verify the employment of, and the validity of permanent change of station (PCS) orders received by, members of the Foreign Service, in a manner that protects the safety, security, and privacy of sensitive employee information.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
