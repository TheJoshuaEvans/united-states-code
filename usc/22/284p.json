{"tag":"section","attrib":{"id":"id8ebcc1f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284p"},"text":null,"children":[{"tag":"num","attrib":{"value":"284p"},"text":"§ 284p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seventh replenishment; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc1f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor is hereby authorized to agree on behalf of the United States to pay to the Association $2,250,000,000 as the United States contribution to the seventh replenishment of the resources of the Association, except that any commitment to make such contributions shall be made subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc1f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $2,250,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc1f8-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s18"},"text":"Pub. L. 86–565, § 18","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s101/1/tI"},"text":"Pub. L. 98–473, title I, § 101(1) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1884"},"text":"98 Stat. 1884","children":[],"tail":", 1885.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ebcc1f9-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ebcc1fa-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ebcc1fb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s18"},"text":"Section 18 of Pub. L. 86–565","children":[],"tail":" is based on section 901 of S. 2582, Ninety-eighth Congress, as reported "},{"tag":"date","attrib":{"date":"1984-04-18"},"text":"Apr. 18, 1984","children":[],"tail":", and enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ebcc1fc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ebcc1fd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Credits Available to Sub-Saharan Africa","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s101/1/tI"},"text":"Pub. L. 98–473, title I, § 101(1) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1884"},"text":"98 Stat. 1884","children":[],"tail":", 1885, provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/473/tI/s101/1/tI"},"text":"“That the Secretary of the Treasury shall instruct the United States Executive Director to undertake negotiations to ensure, to the maximum extent possible consistent with the effective use of resources, that the amount of development credits made available to sub-Saharan Africa through the seventh replenishment shall equal or exceed the amount of development credits made available to sub-Saharan Africa through the sixth replenishment.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
