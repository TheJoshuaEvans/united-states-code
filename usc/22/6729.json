{"tag":"section","attrib":{"id":"id90c4a04c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6729"},"text":null,"children":[{"tag":"num","attrib":{"value":"6729"},"text":"§ 6729.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States assistance in inspections at private facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c4a04d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6729/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance in preparation for inspections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of an owner of a facility not owned or operated by the United States Government, or contracted for use by or for the United States Government, the Secretary of Defense may assist the facility to prepare the facility for possible inspections pursuant to the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a04e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6729/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a04f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6729/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the owner of a facility provided assistance under subsection (a) shall reimburse the Secretary for the costs incurred by the Secretary in providing the assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a050-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6729/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of assistance provided under subsection (a) to a facility owned by a person described in subsection (c), the United States National Authority shall reimburse the Secretary for the costs incurred by the Secretary in providing the assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c4a051-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6729/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Owners covered by United States National Authority reimbursements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (b)(2) applies in the case of assistance provided to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90c4a052-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6729/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business concerns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A small business concern as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c4a053-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6729/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic producers of Schedule 3 or unscheduled discrete organic chemicals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person located in the United States that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90c4a054-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6729/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not possess, produce, process, consume, import, or export any Schedule 1 or Schedule 2 chemical; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c4a055-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6729/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the calendar year preceding the year in which the assistance is to be provided, produced—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id90c4a056-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6729/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 30 metric tons of Schedule 3 or unscheduled discrete organic chemicals that contain phosphorous, sulfur, or fluorine; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id90c4a057-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6729/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 200 metric tons of unscheduled discrete organic chemicals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c4a058-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/tIII/s310"},"text":"Pub. L. 105–277, div. I, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-880"},"text":"112 Stat. 2681–880","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
