{"tag":"section","attrib":{"id":"id90ef801c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7813"},"text":null,"children":[{"tag":"num","attrib":{"value":"7813"},"text":"§ 7813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radio broadcasting to North Korea","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90ef801d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7813/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that the United States should—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ef801e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7813/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the unhindered dissemination of information in North Korea by increasing its support for broadcasting, including news rebroadcasting, to North Korea, and that the Broadcasting Board of Governors should increase such broadcasts, including news rebroadcasts, to North Korea from current levels, with a goal of providing 12-hour-per-day broadcasting to North Korea, including broadcasts by Radio Free Asia and Voice of America; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef801f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7813/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand funding for nongovernmental organization broadcasting efforts, prioritizing organizations that engage North Korean defectors in programming and broadcast services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90ef8020-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7813/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2004-10-18"},"text":"October 18, 2004","children":[],"tail":", the Broadcasting Board of Governors shall submit to the appropriate congressional committees a report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id90ef8021-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7813/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the status of current United States broadcasting to North Korea; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90ef8022-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s7813/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outlines a plan for increasing such broadcasts to 12 hours per day, including a detailed description of the technical and fiscal requirements necessary to implement the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90ef8023-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/333/tI/s103"},"text":"Pub. L. 108–333, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1291"},"text":"118 Stat. 1291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/198/s4"},"text":"Pub. L. 115–198, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-07-20"},"text":"July 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1521"},"text":"132 Stat. 1521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90ef8024-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90ef8025-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90ef8026-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/198/s4/1"},"text":"Pub. L. 115–198, § 4(1)","children":[],"tail":", (3), substituted “United States should—” for “United States should”, inserted par. (1) designation before “facilitate”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/198/s4/2"},"text":"Pub. L. 115–198, § 4(2)","children":[],"tail":", substituted “broadcasting, including news rebroadcasting,” for “radio broadcasting”, “increase such broadcasts, including news rebroadcasts,” for “increase broadcasts”, and “Voice of America; and” for “Voice of America.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90ef8027-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id90ef8028-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Broadcasting Board of Governors renamed United States Agency for Global Media pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6204/a/21"},"text":"section 6204(a)(21) of this title","children":[],"tail":". The renaming was effectuated by notice to congressional appropriations committees dated "},{"tag":"date","attrib":{"date":"2018-05-24"},"text":"May 24, 2018","children":[],"tail":", and became effective "},{"tag":"date","attrib":{"date":"2018-08-22"},"text":"Aug. 22, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
