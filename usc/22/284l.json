{"tag":"section","attrib":{"id":"id8ebcc1de-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284l"},"text":null,"children":[{"tag":"num","attrib":{"value":"284l"},"text":"§ 284l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fourth replenishment; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc1df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor is hereby authorized to agree on behalf of the United States to pay to the Association four annual installments of $375,000,000 each as the United States contribution to the Fourth Replenishment of the Resources of the Association.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc1e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution, there is hereby authorized to be appropriated without fiscal year limitation four annual installments of $375,000,000 each for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc1e1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s14"},"text":"Pub. L. 86–565, § 14","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/373/s1"},"text":"Pub. L. 93–373, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-08-14"},"text":"Aug. 14, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/445"},"text":"88 Stat. 445","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
