{"tag":"section","attrib":{"id":"id8f28076d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1972"},"text":null,"children":[{"tag":"num","attrib":{"value":"1972"},"text":"§ 1972.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by Secretary of State upon seizure of vessel by foreign country; preconditions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f28076e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1972/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel of the United States is seized by a foreign country on the basis of claims to jurisdiction that are not recognized by the United States, or on the basis of claims to jurisdiction recognized by the United States but exercised in a manner inconsistent with international law as recognized by the United States; ","children":[{"tag":"ref","attrib":{"idref":"fn002080"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002080"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “or”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f28076f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1972/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any general claim of any foreign country to exclusive fishery management authority is recognized by the United States, and any vessel of the United States is seized by such foreign country on the basis of conditions and restrictions under such claim, if such conditions and restrictions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f280770-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1972/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are unrelated to fishery conservation and management,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f280771-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1972/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to consider and take into account traditional fishing practices of vessels of the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f280772-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1972/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are greater or more onerous than the conditions and restrictions which the United States applies to foreign fishing vessels subject to the exclusive fishery management authority of the United States (as established in title I of the Magnuson-Stevens Fishery Conservation and Management Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1811"},"text":"16 U.S.C. 1811","children":[],"tail":" et seq.]), or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f280773-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1972/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to allow fishing vessels of the United States equitable access to fish subject to such country’s exclusive fishery management authority;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary of State, unless there is clear and convincing credible evidence that the seizure did not meet the requirements under paragraph (1) or (2), as the case may be, shall immediately take such steps as are necessary—","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f280774-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1972/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the protection of such vessel and for the health and welfare of its crew;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f280775-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1972/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to secure the release of such vessel and its crew; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f280776-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1972/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the amount of any fine, license, fee, registration fee, or other direct charge reimbursable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1973/a"},"text":"section 1973(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f280777-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-27/ch1018/s2"},"text":"Aug. 27, 1954, ch. 1018, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/883"},"text":"68 Stat. 883","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/569/s1"},"text":"Pub. L. 92–569, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-26"},"text":"Oct. 26, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1182"},"text":"86 Stat. 1182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/265/tIV/s403/a/1"},"text":"Pub. L. 94–265, title IV, § 403(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/360"},"text":"90 Stat. 360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/561/tII/s238/b"},"text":"Pub. L. 96–561, title II, § 238(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3300"},"text":"94 Stat. 3300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/364/tIII/s303/a"},"text":"Pub. L. 98–364, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/444"},"text":"98 Stat. 444","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f280778-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f280779-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f28077a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Magnuson-Stevens Fishery Conservation and Management Act, referred to in par. (2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/331"},"text":"90 Stat. 331","children":[],"tail":". Title I of the Act is classified generally to subchapter II (§ 1811 et seq.) of chapter 38 of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"section 1801 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f28077b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Par. (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “Magnuson-Stevens Fishery” for “Magnuson Fishery”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364"},"text":"Pub. L. 98–364","children":[],"tail":", in par. (1), substituted “any vessel of the United States is seized by a foreign country on the basis of claims to jurisdiction that are not recognized by the United States, or on the basis of claims to jurisdiction recognized by the United States but exercised in a manner inconsistent with international law as recognized by the United States;” for “any vessel of the United States is seized by a foreign country on the basis of claims in territorial waters or the high seas which are not recognized by the United States; or”, and in provisions following par. (2)(D), substituted “the Secretary of State, unless there is clear and convincing credible evidence that the seizure did not meet the requirements under paragraph (1) or (2), as the case may be, shall immediately take such steps as are necessary” for “and there is no dispute as to the material facts with respect to the location or activity of such vessel at the time of such seizure, the Secretary of State shall immediately take such steps as are necessary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Par. (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/561"},"text":"Pub. L. 96–561","children":[],"tail":" substituted “Magnuson Fishery Conservation and Management Act” for “Fishery Conservation and Management Act of 1976”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":" redesignated existing subsecs. (a) and (b) as pars. (1) and (2), respectively, and, in par. (1) struck out reference to rights in territorial waters, and in par. (2) substituted provisions relating to any general claim of any foreign country, conditions, and restrictions of seizure, lack of dispute as to material facts, and steps authorized for Secretary of State upon seizure, for provisions relating to lack of dispute as to material facts and actions authorized for Secretary of State upon seizure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/569"},"text":"Pub. L. 92–569","children":[],"tail":" required the Secretary of State to take appropriate action to immediately ascertain the fees, fines, and other direct charges paid by a United States vessel owner to the seizing foreign country for the release of the vessel and its crew."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f28077c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f28077d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41, provided that the amendment made by that section is effective 15 days after "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f28077e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364/tIII/s303/c"},"text":"Pub. L. 98–364, title III, § 303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/445"},"text":"98 Stat. 445","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/364/tIII/s303/c"},"text":"“The amendments made by subsections (a) and (b) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1974"},"text":"section 1974 of this title","children":[],"tail":"] apply with respect to seizures made after "},{"tag":"date","attrib":{"date":"1983-04-01"},"text":"April 1, 1983","children":[],"tail":", by foreign countries of vessels of the United States.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f28077f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/561/tII/s238/b"},"text":"Pub. L. 96–561, title II, § 238(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3300"},"text":"94 Stat. 3300","children":[],"tail":", provided that the amendment made by that section is effective 15 days after "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f280780-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/tIV/s403/b"},"text":"Pub. L. 94–265, title IV, § 403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-13"},"text":"Apr. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/360"},"text":"90 Stat. 360","children":[],"tail":", provided in part that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/94/265/s403/a/1"},"text":"section 403(a)(1) of Pub. L. 94–265","children":[],"tail":" to this section was to take effect "},{"tag":"date","attrib":{"date":"1977-03-01"},"text":"Mar. 1, 1977","children":[],"tail":", prior to the general amendment of title IV of "},{"tag":"ref","attrib":{"href":"/us/pl/94/265"},"text":"Pub. L. 94–265","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/104/297"},"text":"Pub. L. 104–297","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8f280781-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/569/s6"},"text":"Pub. L. 92–569, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-26"},"text":"Oct. 26, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1183"},"text":"86 Stat. 1183","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/569/s6"},"text":"“The amendments made by this Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1979"},"text":"section 1979 of this title","children":[],"tail":" and amending this section and sections 1973, 1975, and 1977 of this title] shall apply with respect to seizures of vessels of the United States occurring on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1972-10-26"},"text":"Oct. 26, 1972","children":[],"tail":"]; except that reimbursements under section 3 of the Fishermen’s Protective Act of 1967 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1973"},"text":"section 1973 of this title","children":[],"tail":"] (as in effect before such date of enactment ["},{"tag":"date","attrib":{"date":"1972-10-26"},"text":"Oct. 26, 1972","children":[],"tail":"]) may be made from the fund established by the amendment made by section 5 of this Act [enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1979"},"text":"section 1979 of this title","children":[],"tail":"] with respect to any seizure of a vessel occurring before such date of enactment ["},{"tag":"date","attrib":{"date":"1972-10-26"},"text":"Oct. 26, 1972","children":[],"tail":"] and after "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"December 31, 1970","children":[],"tail":", if no reimbursement was made before such date of enactment ["},{"tag":"date","attrib":{"date":"1972-10-26"},"text":"Oct. 26, 1972","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
