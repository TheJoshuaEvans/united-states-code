{"tag":"section","attrib":{"id":"id8ef13ff1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s616"},"text":null,"children":[{"tag":"num","attrib":{"value":"616"},"text":"§ 616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public examination of official records; transmittal of records and information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ef13ff2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s616/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent copy of statement; inspection; withdrawal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall retain in permanent form one copy of all registration statements furnished under this subchapter, and the same shall be public records and open to public examination and inspection at such reasonable hours, under such regulations, as the Attorney General may prescribe, and copies of the same shall be furnished to every applicant at such reasonable fee as the Attorney General may prescribe. The Attorney General may withdraw from public examination the registration statement and other statements of any agent of a foreign principal whose activities have ceased to be of a character which requires registration under the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ef13ff3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s616/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall, promptly upon receipt, transmit one copy of every registration statement filed hereunder and one copy of every amendment or supplement thereto filed hereunder, to the Secretary of State for such comment and use as the Secretary of State may determine to be appropriate from the point of view of the foreign relations of the United States. Failure of the Attorney General so to transmit such copy shall not be a bar to prosecution under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ef13ff4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s616/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive departments and agencies; Congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General is authorized to furnish to departments and agencies in the executive branch and committees of the Congress such information obtained by him in the administration of this subchapter, including the names of registrants under this subchapter, copies of registration statements, or parts thereof, or other documents or information filed under this subchapter, as may be appropriate in the light of the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ef13ff5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s616/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public database of registration statements and updates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ef13ff6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s616/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General shall maintain, and make available to the public over the Internet, without a fee or other access charge, in a searchable, sortable, and downloadable manner, to the extent technically practicable, an electronic database that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ef13ff7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s616/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the information contained in registration statements and updates filed under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ef13ff8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s616/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is searchable and sortable, at a minimum, by each of the categories of information described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s612/a"},"text":"section 612(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ef13ff9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s616/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General shall make each registration statement and update filed in electronic form pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s612/g"},"text":"section 612(g) of this title","children":[],"tail":" available for public inspection over the Internet as soon as technically practicable after the registration statement or update is filed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ef13ffa-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-08/ch327/s6"},"text":"June 8, 1938, ch. 327, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/633"},"text":"52 Stat. 633","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1942-04-29/ch263/s1"},"text":"Apr. 29, 1942, ch. 263, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/256"},"text":"56 Stat. 256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/486/s6"},"text":"Pub. L. 89–486, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-07-04"},"text":"July 4, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/247"},"text":"80 Stat. 247","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s9/7"},"text":"Pub. L. 104–65, § 9(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/700"},"text":"109 Stat. 700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/81/tII/s212/b"},"text":"Pub. L. 110–81, title II, § 212(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/749"},"text":"121 Stat. 749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ef13ffb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ef13ffc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8ef13ffd-2930-11f1-8918