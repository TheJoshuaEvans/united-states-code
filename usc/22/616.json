political propaganda” after “supplement thereto”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s9/7/C"},"text":"Pub. L. 104–65, § 9(7)(C)","children":[],"tail":", struck out “copies of political propaganda,” after “parts thereof,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/486"},"text":"Pub. L. 89–486","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1942—Act ","children":[{"tag":"date","attrib":{"date":"1942-04-29"},"text":"Apr. 29, 1942","children":[],"tail":", amended section generally."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ef13fff-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ef14000-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/81"},"text":"Pub. L. 110–81","children":[],"tail":" effective on the 90th day after "},{"tag":"date","attrib":{"date":"2007-09-14"},"text":"Sept. 14, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/81/s212/c"},"text":"section 212(c) of Pub. L. 110–81","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s612"},"text":"section 612 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ef14001-2930-11f1-8918-be39dde81dc6"},"text":