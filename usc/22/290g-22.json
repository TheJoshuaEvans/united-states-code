{"tag":"section","attrib":{"id":"id8ee09de0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–22"},"text":null,"children":[{"tag":"num","attrib":{"value":"290g–22"},"text":"§ 290g–22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Thirteenth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ee09de1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–22/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Fund is authorized to contribute on behalf of the United States $585,000,000 to the thirteenth replenishment of the resources of the Fund, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ee09de2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s290g–22/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $585,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ee09de3-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/302/tII/s223"},"text":"Pub. L. 94–302, title II, § 223","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dJ/tVII/s7083/c"},"text":"Pub. L. 113–235, div. J, title VII, § 7083(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2684"},"text":"128 Stat. 2684","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
