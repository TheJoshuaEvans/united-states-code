{"tag":"section","attrib":{"id":"id903a3ac7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3426"},"text":null,"children":[{"tag":"num","attrib":{"value":"3426"},"text":"§ 3426.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statements of Congressional intent","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id903a3ac8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3426/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclaimer of Congressional approval of other agreements, understandings, or commitments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter is intended to signify approval by the Congress of any agreement, understanding, or commitment made by the executive branch other than the agreement to participate in the Multinational Force and Observers as set forth in the exchanges of letters between the United States and Egypt and between the United States and Israel which were signed on ","children":[{"tag":"date","attrib":{"date":"1981-08-03"},"text":"August 3, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a3ac9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3426/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on United States participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The limitations contained in this subchapter with respect to United States participation in the Multinational Force and Observers apply to the exercise of the authorities provided by this subchapter or provided by any other provision of law. No funds appropriated by the Congress may be obligated or expended for any activity which is contrary to the limitations contained in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903a3aca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3426/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" War Powers Resolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall affect the responsibilities of the President or the Congress under the War Powers Resolution (","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/148"},"text":"Public Law 93–148","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1541"},"text":"50 U.S.C. 1541","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903a3acb-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/132/s7"},"text":"Pub. L. 97–132, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1696"},"text":"95 Stat. 1696","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903a3acc-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id903a3acd-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id903a3ace-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The War Powers Resolution, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/148"},"text":"Pub. L. 93–148","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-07"},"text":"Nov. 7, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/555"},"text":"87 Stat. 555","children":[],"tail":", which is classified generally to chapter 33 (§ 1541 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1541"},"text":"section 1541 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
