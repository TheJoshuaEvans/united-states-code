{"tag":"section","attrib":{"id":"id8ea4f46b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262s"},"text":null,"children":[{"tag":"num","attrib":{"value":"262s"},"text":"§ 262s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multilateral development bank procurement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ea4f46c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Directors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director of each multilateral development bank to attach a high priority to promoting opportunities for exports for goods and services from the United States and, in carrying out this function, to investigate thoroughly any complaints from United States bidders about the awarding of procurement contracts by the multilateral development banks to ensure that all contract procedures and rules of the banks are observed and that United States firms are treated fairly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ea4f46d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002021"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002021"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Two subsecs. (b) have been enacted."}],"tail":" Officer of procurement"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ea4f46e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262s/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall designate, within the Office of International Affairs in the Department of the Treasury, an officer of multilateral development bank procurement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ea4f46f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262s/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Function","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The officer shall act as the liaison between the Department of the Treasury, the Department of Commerce, and the United States Executive Directors’ offices in the multilateral development banks, in carrying out this section. The officer shall cooperate with the Department of Commerce in efforts to improve opportunities for multilateral development bank procurement by United States companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ea4f470-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" “Multilateral development bank” defined"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “multilateral development bank” includes the International Bank for Reconstruction and Development, the International Development Association, the International Finance Corporation, the Inter-American Development Bank, the InterAmerican Investment Corporation, the Asian Development Bank, the African Development Bank, and the African Development Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ea4f471-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/118/tXVIII/s1801"},"text":"Pub. L. 95–118, title XVIII, § 1801","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIII/s3202"},"text":"Pub. L. 100–418, title III, § 3202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1382"},"text":"102 Stat. 1382","children":[],"tail":"; renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/95/118/s1801"},"text":"§ 1801 of Pub. L. 95–118","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/101/240/tV/s541/b/1"},"text":"Pub. L. 101–240, title V, § 541(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2517"},"text":"103 Stat. 2517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ea4f472-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ea4f473-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ea4f474-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262q"},"text":"section 262q of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/101/240"},"text":"Pub. L. 101–240","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ea4f475-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id8ea4f476-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIII/s3201"},"text":"Pub. L. 100–418, title III, § 3201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1382"},"text":"102 Stat. 1382","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/418/tIII/s3201"},"text":"“This subtitle [subtitle C (§§ 3201, 3202) of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418"},"text":"Pub. L. 100–418","children":[],"tail":", enacting former "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s262q"},"text":"section 262q of this title","children":[],"tail":"] may be cited as the ‘Multilateral Development Banks Procurement Act of 1988’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id8ea4f477-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s262r"},"text":"section 262r of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
