{"tag":"section","attrib":{"id":"id8ee7a2aa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s294a"},"text":null,"children":[{"tag":"num","attrib":{"value":"294a"},"text":"§ 294a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts requiring payment in foreign currency","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever a contract is made for the construction, alteration, or repair of a Foreign Service building which requires payments in a foreign currency, the Secretary of State is authorized to purchase such currency at such times and in such amounts (within the total amount of the payments to be made under such contract) as he may deem necessary, the currency so purchased to be disbursed and accounted for at its cost price.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ee7a2ab-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-05-14/ch189"},"text":"May 14, 1940, ch. 189","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/54/186"},"text":"54 Stat. 186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ee7a2ac-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ee7a2ad-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ee7a2ae-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as a part of the Foreign Service Buildings Act, 1926, which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8ee7a2af-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior similar provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-29/ch248/tI"},"text":"act June 29, 1939, ch. 248, title I","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/53/890"},"text":"53 Stat. 890","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
