{"tag":"section","attrib":{"id":"id90bfbf0b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701"},"text":null,"children":[{"tag":"num","attrib":{"value":"6701"},"text":"§ 6701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90bfbf0c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chemical weapon","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “chemical weapon” means the following, together or separately:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bfbf0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A toxic chemical and its precursors, except where intended for a purpose not prohibited under this chapter as long as the type and quantity is consistent with such a purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A munition or device, specifically designed to cause death or other harm through toxic properties of those toxic chemicals specified in subparagraph (A), which would be released as a result of the employment of such munition or device.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any equipment specifically designed for use directly in connection with the employment of munitions or devices specified in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbf10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chemical Weapons Convention; Convention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “Chemical Weapons Convention” and “Convention” mean the Convention on the Prohibition of the Development, Production, Stockpiling and Use of Chemical Weapons and on Their Destruction, opened for signature on ","children":[{"tag":"date","attrib":{"date":"1993-01-13"},"text":"January 13, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbf11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Key component of a binary or multicomponent chemical system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “key component of a binary or multicomponent chemical system” means the precursor which plays the most important role in determining the toxic properties of the final product and reacts rapidly with other chemicals in the binary or multicomponent system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbf12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national of the United States” has the same meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"section 1101(a)(22) of title 8","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbf13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Organization” means the Organization for the Prohibition of Chemical Weapons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbf14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person”, except as otherwise provided, means any individual, corporation, partnership, firm, association, trust, estate, public or private institution, any State or any political subdivision thereof, or any political entity within a State, any foreign government or nation or any agency, instrumentality or political subdivision of any such government or nation, or other entity located in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbf15-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Precursor","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bfbf16-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “precursor” means any chemical reactant which takes part at any stage in the production by whatever method of a toxic chemical. The term includes any key component of a binary or multicomponent chemical system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf17-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of precursors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Precursors which have been identified for the application of verification measures under Article VI of the Convention are listed in schedules contained in the Annex on Chemicals of the Chemical Weapons Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbf18-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes not prohibited by this chapter","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “purposes not prohibited by this chapter” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bfbf19-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peaceful purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any peaceful purpose related to an industrial, agricultural, research, medical, or pharmaceutical activity or other activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf1a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protective purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any purpose directly related to protection against toxic chemicals and to protection against chemical weapons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf1b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unrelated military purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any military purpose of the United States that is not connected with the use of a chemical weapon and that is not dependent on the use of the toxic or poisonous properties of the chemical weapon to cause death or other harm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf1c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any law enforcement purpose, including any domestic riot control purpose and including imposition of capital punishment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbf1d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical Secretariat","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Technical Secretariat” means the Technical Secretariat of the Organization for the Prohibition of Chemical Weapons established by the Chemical Weapons Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbf1e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule 1 chemical agent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Schedule 1 chemical agent” means any of the following, together or separately:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bfbf1f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" O-Alkyl (≤C","children":[{"tag":"sub","attrib":{},"text":"10","children":[],"tail":", incl. cycloalkyl) alkyl"},{"tag":"p","attrib":{},"text":"(Me, Et, n-Pr or i-Pr)-phosphonofluoridates","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(e.g. Sarin: O-Isopropyl methylphosphonofluoridate Soman: O-Pinacolyl methylphosphonofluoridate).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf20-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" O-Alkyl (≤C","children":[{"tag":"sub","attrib":{},"text":"10","children":[],"tail":", incl. cycloalkyl) N,N-dialkyl"},{"tag":"p","attrib":{},"text":"(Me, Et, n-Pr or i-Pr)-phosphoramidocyanidates","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(e.g. Tabun: O-Ethyl N,N-dimethyl phosphoramidocyanidate).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf21-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" O-Alkyl (H or ≤C","children":[{"tag":"sub","attrib":{},"text":"10","children":[],"tail":", incl. cycloalkyl) S-2-dialkyl"},{"tag":"p","attrib":{},"text":"(Me, Et, n-Pr or i-Pr)-aminoethyl alkyl","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(Me, Et, n-Pr or i-Pr) phosphonothiolates and corresponding alkylated or protonated salts","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(e.g. VX: O-Ethyl S-2-diisopropylaminoethyl methyl phosphonothiolate).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf22-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sulfur mustards:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"2-Chloroethylchloromethylsulfide","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Mustard gas: (Bis(2-chloroethyl)sulfide ","children":[{"tag":"ref","attrib":{"idref":"fn002349"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002349"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be preceded by an open parenthesis."}],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Bis(2-chloroethylthio)methane","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sesquimustard: 1,2-Bis(2-chloroethylthio)ethane","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1,3-Bis(2-chloroethylthio)-n-propane","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1,4-Bis(2-chloroethylthio)-n-butane","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1,5-Bis(2-chloroethylthio)-n-pentane","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Bis(2-chloroethylthiomethyl)ether","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"O-Mustard: Bis(2-chloroethylthioethyl)ether.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf23-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lewisites:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"Lewisite 1: 2-Chlorovinyldichloroarsine","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Lewisite 2: Bis(2-chlorovinyl)chloroarsine","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Lewisite 3: Tris(2-clorovinyl)arsine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf24-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/10/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nitrogen mustards:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"HN1: Bis(2-chloroethyl)ethylamine","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"HN2: Bis(2-chloroethyl)methylamine","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"HN3: Tris(2-chloroethyl)amine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf25-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/10/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Saxitoxin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf26-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/10/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ricin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf27-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/10/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alkyl (Me, Et, n-Pr or i-Pr) phosphonyldifluorides","children":[{"tag":"p","attrib":{},"text":"e.g. DF: Methylphosphonyldifluoride.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf28-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/10/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" O-Alkyl (H or ≤C","children":[{"tag":"sub","attrib":{},"text":"10","children":[],"tail":", incl. cycloalkyl)O-2-dialkyl"},{"tag":"p","attrib":{},"text":"(Me, Et, n-Pr or i-Pr)-aminoethyl alkyl","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(Me, Et, n-Pr or i-Pr) phosphonites and corresponding alkylated or protonated salts","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"e.g. QL: O-Ethyl O-2-diisopropylaminoethyl methylphosphonite.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf29-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/10/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chlorosarin: O-Isopropyl methylphosphonochloridate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/10/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chlorosoman: O-Pinacolyl methylphosphonochloridate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90bfbf2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule 2 chemical agent","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Schedule 2 chemical agent” means the following, together or separately:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90bfbf2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amiton: O,O-Diethyl S-[2-(diethylamino)ethyl]","children":[{"tag":"p","attrib":{},"text":"phosphorothiolate and corresponding alkylated or protonated salts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf2d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" PFIB: 1,1,3,3,3-Pentafluoro-2-(trifluoromethyl)-1-propene.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf2e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" BZ: 3-Quinuclidinyl benzilate","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf2f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/11/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chemicals, except for those listed in Schedule 1, containing a phosphorus atom to which is bonded one methyl, ethyl or propyl (normal or iso) group but not further carbon atoms,","children":[{"tag":"p","attrib":{},"text":"e.g. Methylphosphonyl dichloride Dimethyl methylphosphonate","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Exemption: Fonofos: O-Ethyl S-phenyl ethylphosphonothiolothionate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90bfbf30-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/11/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" N,N-Dialkyl (Me, Et, n-Pr or i-Pr) phosphoramidic dihalides.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22f31-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/11/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dialkyl (Me, Et, n-Pr or i-Pr) N,N-dialkyl (Me, Et, n-Pr or i-Pr)-phosphoramidates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22f32-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/11/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text"