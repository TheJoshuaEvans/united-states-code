n":[],"tail":null},{"tag":"content","attrib":{},"text":" Triethyl phosphite.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22f44-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/12/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Dimethyl phosphite.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22f45-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/12/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Diethyl phosphite.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22f46-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/12/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sulfur monochloride.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22f47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/12/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sulfur dichloride.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22f48-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/12/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Thionyl chloride.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22f49-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/12/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ethyldiethanolamine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22f4a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/12/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Methyldiethanolamine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22f4b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/12/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Triethanolamine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c22f4c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Toxic chemical","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90c22f4d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “toxic chemical” means any chemical which through its chemical action on life processes can cause death, temporary incapacitation or permanent harm to humans or animals. The term includes all such chemicals, regardless of their origin or of their method of production, and regardless of whether they are produced in facilities, in munitions or elsewhere.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22f4e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" List of toxic chemicals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Toxic chemicals which have been identified for the application of verification measures under Article VI of the Convention are listed in schedules contained in the Annex on Chemicals of the Chemical Weapons Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c22f4f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States” means the several States of the United States, the District of Columbia, and the commonwealths, territories, and possessions of the United States and includes all places under the jurisdiction or control of the United States, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90c22f50-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any of the places within the provisions of paragraph (41) ","children":[{"tag":"ref","attrib":{"idref":"fn002350"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002350"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102"},"text":"section 40102 of title 49","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22f51-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any civil aircraft of the United States or public aircraft, as such terms are defined in paragraphs (17) and (37),","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" respectively, of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102"},"text":"section 40102 of title 49","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90c22f52-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel of the United States, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502/b"},"text":"section 70502(b) of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90c22f53-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6701/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unscheduled discrete organic chemical","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “unscheduled discrete organic chemical” means any chemical not listed on any schedule contained in the Annex on Chemicals of the Convention that belongs to the class of chemical compounds consisting of all compounds of carbon, except for its oxides, sulfides, and metal carbonates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c22f54-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/s3"},"text":"Pub. L. 105–277, div. I, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-856"},"text":"112 Stat. 2681–856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90c22f55-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90c22f56-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90c22f57-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this Act” and was translated as reading “this division”, meaning div. I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-856"},"text":"112 Stat. 2681–856","children":[],"tail":", known as the Chemical Weapons Convention Implementation Act of 1998, to reflect the probable intent of Congress. For complete classification of division I to the Code, see Short Title note set out below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraphs (17), (37), and (41) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102"},"text":"section 40102 of title 49","children":[],"tail":", referred to in par. (14)(A), (B), probably were originally meant to refer to paragraphs (17), (37), and (41) of subsection (a) of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102"},"text":"section 40102 of title 49","children":[],"tail":". Paragraphs (37) and (41) were subsequently redesignated as (41) and (46), respectively, by "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tII/s225/a/1"},"text":"Pub. L. 108–176, title II, § 225(a)(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2528"},"text":"117 Stat. 2528","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90c22f58-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In par. 14(C), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502/b"},"text":"section 70502(b) of title 46","children":[],"tail":"” substituted for “section 3(b) of the Maritime Drug Enforcement Act, as amended (46 U.S.C., App. sec. 1903(b))”, meaning section 3(b) of the Maritime Drug Law Enforcement Act, on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/c"},"text":"Pub. L. 109–304, § 18(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1709"},"text":"120 Stat. 1709","children":[],"tail":", which Act enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s70502"},"text":"section 70502 of Title 46","children":[],"tail":", Shipping."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90c22f59-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id90c22f5a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/s1"},"text":"Pub. L. 105–277, di