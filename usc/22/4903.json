{"tag":"section","attrib":{"id":"id90868574-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4903"},"text":null,"children":[{"tag":"num","attrib":{"value":"4903"},"text":"§ 4903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowships","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90868575-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Up to 100 fellowships may be provided under this chapter each year. Not less than 15 shall be provided during fiscal year 1993.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90868576-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remuneration and period","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall determine, taking into consideration the position in which each Fellow will serve and his or her experience and expertise—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90868577-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of remuneration the Fellow will receive for his or her service under this chapter, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90868578-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of the fellowship, which shall be between one and two years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90868579-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Fellow may be given appropriate training at the George P. Shultz National Foreign Affairs Training Center or other appropriate institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9086857a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Housing and transportation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall, pursuant to regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9086857b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide housing for each Fellow while the Fellow is serving abroad, including (where appropriate) housing for family members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9086857c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay the costs and expenses incurred by each Fellow in traveling between the United States and the country in which the Fellow serves, including (where appropriate) travel for family members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9086857d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4903/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (d) of this section shall not take effect until ","children":[{"tag":"date","attrib":{"date":"1986-10-01"},"text":"October 1, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9086857e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tX/s1004"},"text":"Pub. L. 99–399, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/894"},"text":"100 Stat. 894","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/511/tVIII/s804/a"},"text":"Pub. L. 102–511, title VIII, § 804(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3353"},"text":"106 Stat. 3353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/132/s1/b"},"text":"Pub. L. 107–132, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-16"},"text":"Jan. 16, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2412"},"text":"115 Stat. 2412","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9086857f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90868580-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90868581-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/132"},"text":"Pub. L. 107–132","children":[],"tail":" substituted “George P. Shultz National Foreign Affairs Training Center” for “Foreign Service Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511"},"text":"Pub. L. 102–511","children":[],"tail":" inserted at end “Not less than 15 shall be provided during fiscal year 1993.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90868582-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90868583-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Funding","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/tVIII/s804/b"},"text":"Pub. L. 102–511, title VIII, § 804(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3353"},"text":"106 Stat. 3353","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/511/tVIII/s804/b"},"text":"“In addition to the funds made available pursuant to section 1005(c) of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4904/c"},"text":"22 U.S.C. 4904(c)","children":[],"tail":"], funds authorized to be appropriated by chapter 11 of part I of the Foreign Assistance Act of 1961 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2295"},"text":"22 U.S.C. 2295","children":[],"tail":" et seq.] may be used in carrying out the amendment made by subsection (a) [amending this section] with respect to missions in the independent states of the former Soviet Union.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
