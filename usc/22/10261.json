{"tag":"section","attrib":{"id":"id9153998c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10261"},"text":null,"children":[{"tag":"num","attrib":{"value":"10261"},"text":"§ 10261.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions exception relating to importation of goods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9153998d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10261/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorities and requirements to impose sanctions under this chapter shall not include the authority or requirement to impose sanctions on the importation of goods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9153998e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10261/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “good” means any article, natural or man-made substance, material, supply, or manufactured product, including inspection and test equipment, and excluding technical data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9153998f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5579"},"text":"Pub. L. 117–263, div. E, title LV, § 5579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3370"},"text":"136 Stat. 3370","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
