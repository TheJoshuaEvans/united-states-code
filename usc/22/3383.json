{"tag":"section","attrib":{"id":"id9037f0be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3383"},"text":null,"children":[{"tag":"num","attrib":{"value":"3383"},"text":"§ 3383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9037f0bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3383/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency head","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agency head” means, in the case of the executive branch of United States Government or a legislative branch agency described in paragraph (2), the head of the respective agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9037f0c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3383/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency of the United States Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agency of the United States Government” includes the Government Accountability Office, the Congressional Budget Office, and the Congressional Research Service of the legislative branch, as well as any agency of the executive branch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9037f0c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3383/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9037f0c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3383/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9037f0c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3383/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9037f0c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3383/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9037f0c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3383/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9037f0c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3383/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detailee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “detailee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9037f0c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3383/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of an agency of the United States Government on loan to the American Institute in Taiwan, without a change of position from the agency at which the employee is employed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9037f0c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3383/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a legislative branch employee from the Government Accountability Office, Congressional Budget Office, or the Congressional Research Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9037f0c9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3383/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementing partner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “implementing partner” means any United States organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9037f0ca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3383/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs logistical, administrative, and other functions, as determined by the Department of State and the American Institute of Taiwan in support of the Taiwan Fellowship Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9037f0cb-2930-11f1-8918-be39dde81dc6","identif