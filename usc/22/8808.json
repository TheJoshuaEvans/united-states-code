{"tag":"section","attrib":{"id":"id91133584-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8808"},"text":null,"children":[{"tag":"num","attrib":{"value":"8808"},"text":"§ 8808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on use of certain Iranian seaports by foreign vessels and use of foreign airports by sanctioned Iranian air carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91133585-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8808/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2013-01-02"},"text":"January 2, 2013","children":[],"tail":", and annually thereafter through 2016, the President shall submit to the appropriate congressional committees a report that contains—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id91133586-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8808/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of large or otherwise significant vessels that have entered seaports in Iran controlled by the Tidewater Middle East Company during the period specified in subsection (b) and the owners and operators of those vessels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91133587-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8808/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all airports at which aircraft owned or controlled by an Iranian air carrier on which sanctions have been imposed by the United States have landed during the period specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91133588-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8808/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period specified","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The period specified in this subsection is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91133589-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8808/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the first report submitted under subsection (a), the 180-day period preceding the submission of the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9113358a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8808/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any subsequent report submitted under that subsection, the year preceding the submission of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9113358b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s8808/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report required by subsection (a) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9113358c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXII/s1252"},"text":"Pub. L. 112–239, div. A, title XII, § 1252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2017"},"text":"126 Stat. 2017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9113358d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id9113358e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id9113358f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of certain functions and authorities vested in the President by this section, see Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2013-06-03"},"text":"June 3, 2013","children":[],"tail":", 78 F.R. 35545, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s8801"},"text":"section 8801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
