{"tag":"section","attrib":{"id":"id90737337-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4222"},"text":null,"children":[{"tag":"num","attrib":{"value":"4222"},"text":"§ 4222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authentication of documents of State of Vatican City by consular officer in Rome","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Until the United States shall have consular officer resident in the State of the Vatican City, a copy of any document of record or on file in a public office of said State of the Vatican City, certified by the lawful custodian of such document, may be authenticated, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1741"},"text":"section 1741 of title 28","children":[],"tail":", by a consular officer of the United States resident in the city of Rome, Kingdom of Italy, and such document or record shall, when so certified and authenticated, be admissible in evidence in any court of the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90737338-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-20/ch640/s6A"},"text":"June 20, 1936, ch. 640, § 6A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch682"},"text":"June 25, 1938, ch. 682","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1163"},"text":"52 Stat. 1163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90737339-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9073733a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9073733b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1741"},"text":"Section 1741 of title 28","children":[],"tail":"” substituted in text for “section 6 of this Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t28/s695e"},"text":"28 U.S.C. 695e","children":[],"tail":"]” on authority of "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"act June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/869"},"text":"62 Stat. 869","children":[],"tail":", section 1 of which enacted Title 28, Judiciary and Judicial Procedure."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1204"},"text":"section 1204 of this title","children":[],"tail":", and prior thereto to "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s695e–1"},"text":"section 695e–1 of Title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
