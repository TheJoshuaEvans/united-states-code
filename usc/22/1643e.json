{"tag":"section","attrib":{"id":"id8f14f484-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1643e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1643e"},"text":"§ 1643e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offsets","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In determining the amount of any claim, the Commission shall deduct all amounts the claimant has received from any source on account of the same loss or losses.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f14f485-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-10/ch54"},"text":"Mar. 10, 1950, ch. 54","children":[],"tail":", title V, § 506, as added "},{"tag":"ref","attrib":{"href":"/us/pl/88/666"},"text":"Pub. L. 88–666","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-16"},"text":"Oct. 16, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1112"},"text":"78 Stat. 1112","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/262/s4"},"text":"Pub. L. 89–262, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-19"},"text":"Oct. 19, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/988"},"text":"79 Stat. 988","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f14f486-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f14f487-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f14f488-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/262"},"text":"Pub. L. 89–262","children":[],"tail":" struck out proviso that the deduction of such amounts shall not be construed as divesting the United States of any rights against the Government of Cuba for the amounts so deducted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
