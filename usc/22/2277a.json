{"tag":"section","attrib":{"id":"id8f7208df-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2277a"},"text":"§ 2277a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Targeted sanctions to fight corruption in El Salvador, Guatemala,,","children":[{"tag":"ref","attrib":{"idref":"fn002117"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002117"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" Honduras, and Nicaragua"}],"tail":null},{"tag":"subsection","attrib":{"id":"id8f7208e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7208e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" corruption in El Salvador, Guatemala,,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Honduras, and Nicaragua by private citizens and select officials in local, regional, and Federal governments significantly damages the economies of such countries and deprives citizens of opportunities;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7208e2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" corruption in El Salvador, Guatemala,,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Honduras, and Nicaragua is facilitated and carried out not only by private citizens and select officials from those countries but also in many instances by individuals from third countries; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7208e3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposing targeted sanctions on individuals from throughout the world and particularly in the Western Hemisphere who are engaged in acts of significant corruption that impact El Salvador, Guatemala,,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Honduras, and Nicaragua or obstruction of investigations into such acts of corruption will benefit the citizens and governments of such countries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7208e4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", and not less frequently than annually thereafter, the President shall submit to the appropriate congressional committees an unclassified report with classified annex if necessary that identifies each foreign person who the President determines to have knowingly engaged in actions that undermine democratic processes or institutions, or in significant corruption or obstruction of investigations into such acts of corruption in El Salvador, Guatemala,,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Honduras, and Nicaragua, including the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7208e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Corruption related to government contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7208e6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Bribery and extortion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7208e7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The facilitation or transfer of the proceeds of corruption, including through money laundering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7208e8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acts of violence, harassment, or intimidation directed at governmental and nongovernmental corruption investigators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7208e9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall impose the sanctions described in subsection (d) with respect to each foreign person identified in the report required under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7208ea-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sanctions described","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7208eb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sanctions described in this subsection are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f7208ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility for visas and admission to the United States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a foreign person who is an individual, such foreign person is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8f7208ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inadmissible to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f7208ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ineligible to receive a visa or other documentation to enter the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f7208ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise ineligible to be admitted or paroled into the United States or to receive any other benefit under the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f7208f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Current visas revoked","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8f7208f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The issuing consular officer or the Secretary of State, (or a designee of the Secretary of State) shall, in accordance with section 221(i) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1201/i"},"text":"8 U.S.C. 1201(i)","children":[],"tail":"), revoke any visa or other entry documentation issued to a foreign person regardless of when the visa or other entry documentation is issued."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f7208f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of revocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A revocation under clause (i) shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id8f7208f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/d/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take effect immediately; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id8f7208f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/d/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automatically cancel any other valid visa or entry documentation that is in the foreign person’s possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7208f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to comply with international obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sanctions under subparagraph (B) and (C) ","children":[{"tag":"ref","attrib":{"idref":"fn002118"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002118"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “subparagraphs (A) and (B)”."}],"tail":" of paragraph (1) shall not apply with respect to a foreign person if admitting or paroling such person into the United States is necessary to permit the United States to comply with the Agreement regarding the Headquarters of the United Nations, signed at Lake Success "},{"tag":"date","attrib":{"date":"1947-06-26"},"text":"June 26, 1947","children":[],"tail":", and entered into force "},{"tag":"date","attrib":{"date":"1947-11-21"},"text":"November 21, 1947","children":[],"tail":", between the United Nations and the United States, or other applicable international obligations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7208f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may waive the application of the sanctions under subsection (c) ","children":[{"tag":"ref","attrib":{"idref":"fn002119"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002119"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “subsection (d)”."}],"tail":" if the President—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7208f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that such a waiver is in the national security interest of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7208f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits to the appropriate congressional committees within 15 days after such determination a notice of and justification for the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7208f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to impose sanctions under subsection (b),","children":[{"tag":"ref","attrib":{"idref":"fn002120"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002120"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. Probably should be “subsection (c),”."}],"tail":" and any sanctions imposed pursuant to such authority, shall expire on the date that is 3 years after "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7208fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The unclassified portion of the report required by subsection (b) shall be made available to the public, including through publication in the Federal Register. In any case in which the President concludes that such publication would be harmful to the national security of the United States, only a statement that a determination or finding has been made by the President, including the name and section of the Act under which it was made, shall be published.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7208fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7208fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations and the Committee on the Judiciary of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7208fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2277a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs and the Committee on the Judiciary of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f7208fe-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dFF/tIII/s353"},"text":"Pub. L. 116–260, div. FF, title III, § 353","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3129"},"text":"134 Stat. 3129","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/54/s7"},"text":"Pub. L. 117–54, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-10"},"text":"Nov. 10, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/418"},"text":"135 Stat. 418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f7208ff-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f720900-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f720901-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (d)(1)(A)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of Title 8, Aliens and Nationality. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f720902-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the United States – Northern Triangle Enhanced Engagement Act, and not as part of the Foreign Assistance Act of 1961 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f720903-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/54"},"text":"Pub. L. 117–54","children":[],"tail":" substituted “, Honduras, and Nicaragua” for “and Honduras” in section catchline and wherever appearing in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f720904-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f720905-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Certain Authorities and Functions Under Section 353 of the United States-Northern Triangle Enhanced Engagement Act","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2021-06-21"},"text":"June 21, 2021","children":[],"tail":", 86 F.R. 34591, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of State","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, I hereby delegate to the Secretary of State all authorities and functions vested in the President by section 353 of the United States-Northern Triangle Enhanced Engagement Act (Subtitle F of Title III of Division FF of "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Public Law 116–260","children":[],"tail":") (the “Act”) ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2277a"},"text":"22 U.S.C. 2277a","children":[],"tail":"]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any reference herein to the Act related to the subject of this memorandum shall be deemed to include references to any hereafter-enacted [","children":[{"tag":"date","attrib":{"date":"2021-06-21"},"text":"June 21, 2021","children":[],"tail":"] provisions of law that are the same or substantially the same as such provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are authorized and directed to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"J.R. Biden, Jr.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
