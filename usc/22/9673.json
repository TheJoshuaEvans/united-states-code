{"tag":"section","attrib":{"id":"id9147b305-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9673"},"text":null,"children":[{"tag":"num","attrib":{"value":"9673"},"text":"§ 9673.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on support in countries that support terrorism or violate human rights and with sanctioned persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9147b306-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9673/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation is prohibited from providing support under subchapter II of this chapter for a government, or an entity owned or controlled by a government, if the Secretary of State has determined that the government—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b307-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9673/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has repeatedly provided support for acts of international terrorism for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id9147b308-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9673/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4813/c/1/A/i"},"text":"section 4813(c)(1)(A)(i) of title 50","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b309-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9673/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2371/a"},"text":"section 2371(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b30a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9673/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2780/d"},"text":"section 2780(d) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id9147b30b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9673/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant provision of law; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b30c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9673/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has engaged in a consistent pattern of gross violations of internationally recognized human rights for purposes of section 2151n(a) or 2304(a)(2) of this title or any other relevant provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b30d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9673/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on support of sanctioned persons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation is prohibited from all dealings related to any project under subchapter II of this chapter prohibited under United States sanctions laws or regulations, including dealings with persons on the list of specially designated persons and blocked persons maintained by the Office of Foreign Assets Control of the Department of the Treasury, except to the extent otherwise authorized by the Secretary of the Treasury or the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b30e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9673/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on support of activities subject to sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall require any person receiving support under subchapter II of this chapter to certify that the person, and any entity owned or controlled by the person, is in compliance with all United States sanctions laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9147b30f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tV/s1453"},"text":"Pub. L. 115–254, div. F, title V, § 1453","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3510"},"text":"132 Stat. 3510","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
