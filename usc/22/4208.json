{"tag":"section","attrib":{"id":"id907372f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4208"},"text":null,"children":[{"tag":"num","attrib":{"value":"4208"},"text":"§ 4208.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valuation of foreign coins in payment of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Consuls, vice consuls, and consular agents in the Dominion of Canada, in the collection of official fees, shall receive foreign moneys at the rate given in the Treasury schedule of the value of foreign coins.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907372f5-2930-11f1-8918-be39dde81dc6"},"text":"(R.S. § 1722.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907372f6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907372f7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id907372f8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1722 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1869-03-03/ch125/s3"},"text":"act Mar. 3, 1869, ch. 125, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/15/321"},"text":"15 Stat. 321","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of R.S. § 1722 that no consul, vice consul, or consular agent in the Dominion of Canada shall be allowed tonnage fees for any services, actual or constructive, rendered any vessel owned and registered in the United States that may touch at a Canadian port, were omitted as superseded by section 12 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1884-06-26/ch121"},"text":"act June 26, 1884, ch. 121","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/23/56"},"text":"23 Stat. 56","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4206"},"text":"section 4206 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1188"},"text":"section 1188 of this title","children":[],"tail":", and prior thereto to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s91"},"text":"section 91 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
