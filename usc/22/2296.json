{"tag":"section","attrib":{"id":"id8f851b82-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296"},"text":null,"children":[{"tag":"num","attrib":{"value":"2296"},"text":"§ 2296.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States assistance to promote reconciliation and recovery from regional conflicts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f851b83-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of assistance under this section include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f851b84-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation of the basis for reconciliation between belligerents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f851b85-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promotion of economic development in areas of the countries of the South Caucasus and Central Asia impacted by civil conflict and war; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f851b86-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the encouragement of broad regional cooperation among countries of the South Caucasus and Central Asia that have been destabilized by internal conflicts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f851b87-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f851b88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out the purposes of subsection (a), the President is authorized to provide humanitarian assistance and economic reconstruction assistance for the countries of the South Caucasus and Central Asia to support the activities described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f851b89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of humanitarian assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “humanitarian assistance” means assistance to meet humanitarian needs, including needs for food, medicine, medical supplies and equipment, education, and clothing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f851b8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities supported","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities that may be supported by assistance under subsection (b) include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f851b8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the humanitarian needs of victims of the conflicts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f851b8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the return of refugees and internally displaced persons to their homes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f851b8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2296/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in the reconstruction of residential and economic infrastructure destroyed by war.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f851b8e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 499, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/2/tV/s596/b"},"text":"Pub. L. 106–113, div. B, § 1000(a)(2) [title V, § 596(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–123.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f851b8f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f851b90-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8f851b91-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2296, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 499, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/391/tV/s594/a"},"text":"Pub. L. 102–391, title V, § 594(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1692"},"text":"106 Stat. 1692","children":[],"tail":", authorized reduction of certain debts owed to the United States, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/549/tVI/s602/b"},"text":"Pub. L. 102–549, title VI, § 602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3669"},"text":"106 Stat. 3669","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f851b92-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f851b93-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
