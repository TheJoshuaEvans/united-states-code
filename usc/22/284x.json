{"tag":"section","attrib":{"id":"id8ebcc228-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284x"},"text":null,"children":[{"tag":"num","attrib":{"value":"284x"},"text":"§ 284x.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sixteenth replenishment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc229-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284x/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the International Development Association is authorized to contribute on behalf of the United States $4,075,500,000 to the sixteenth replenishment of the resources of the Association, subject to obtaining the necessary appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc22a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284x/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, $4,075,500,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc22b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s26"},"text":"Pub. L. 86–565, § 26","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dI/tVII/s7083/a"},"text":"Pub. L. 112–74, div. I, title VII, § 7083(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1262"},"text":"125 Stat. 1262","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
