{"tag":"section","attrib":{"id":"id909022c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5503"},"text":null,"children":[{"tag":"num","attrib":{"value":"5503"},"text":"§ 5503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of State notification of families of victims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id909022c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of State policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the policy of the Department of State pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2715"},"text":"section 2715 of this title","children":[],"tail":" to directly and promptly notify the families of victims of aviation disasters abroad concerning citizens of the United States directly affected by such a disaster, including timely written notice. The Secretary of State shall ensure that such notification by the Department of State is carried out notwithstanding notification by any other person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id909022c5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of State guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":", the Secretary of State shall issue such regulations, guidelines, and circulars as are necessary to ensure that the policy under subsection (a) is fully implemented."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id909022c6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/604/tII/s204"},"text":"Pub. L. 101–604, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3083"},"text":"104 Stat. 3083","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
