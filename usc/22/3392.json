{"tag":"section","attrib":{"id":"id903a3a47-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3392"},"text":null,"children":[{"tag":"num","attrib":{"value":"3392"},"text":"§ 3392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction regarding the use of military force","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter may be construed as authorizing the use of military force or the introduction of United States forces into hostilities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id903a3a48-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV/s5540"},"text":"Pub. L. 117–263, div. E, title LV, § 5540","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3334"},"text":"136 Stat. 3334","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903a3a49-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id903a3a4a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id903a3a4b-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, and was translated as reading “this subtitle”, meaning subtitle A (§§ 5501–5540) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLV"},"text":"Pub. L. 117–263, div. E, title LV","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3292"},"text":"136 Stat. 3292","children":[],"tail":", known as the Taiwan Enhanced Resilience Act, which is classified principally to this chapter, to reflect the probable intent of Congress. For complete classification of subtitle A to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3351"},"text":"section 3351 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
