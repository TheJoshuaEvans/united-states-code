{"tag":"section","attrib":{"id":"id8eb0daaa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s277d–16"},"text":null,"children":[{"tag":"num","attrib":{"value":"277d–16"},"text":"§ 277d–16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby authorized to be appropriated to the Department of State for the use of the United States Section, International Boundary and Water Commission, United States and Mexico, such sums as may be necessary to carry out the provisions of sections 277d–13 to 277d–16 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8eb0daab-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/605/s4"},"text":"Pub. L. 86–605, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-07"},"text":"July 7, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/361"},"text":"74 Stat. 361","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
