{"tag":"section","attrib":{"id":"id90c4a038-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6727"},"text":null,"children":[{"tag":"num","attrib":{"value":"6727"},"text":"§ 6727.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Consistent with the objective of eliminating chemical weapons, the President may deny a request to inspect any facility in the United States in cases where the President determines that the inspection may pose a threat to the national security interests of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id90c4a039-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dI/tIII/s307"},"text":"Pub. L. 105–277, div. I, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-878"},"text":"112 Stat. 2681–878","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
