{"tag":"section","attrib":{"id":"id8f7934ec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2291c"},"text":"§ 2291c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements relating to aircraft and other equipment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8f7934ed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of title to aircraft","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7934ee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f7934ef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), any aircraft made available to a foreign country under this part, or made available to a foreign country primarily for narcotics-related purposes under any other provision of law, shall be provided only on a lease or loan basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f7934f0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraph (A) applies to aircraft made available at any time after ","children":[{"tag":"date","attrib":{"date":"1986-10-27"},"text":"October 27, 1986","children":[],"tail":" (which was the date of enactment of the International Narcotics Control Act of 1986)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7934f1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f7934f2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) shall not apply to the extent that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8f7934f3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of that paragraph with respect to particular aircraft would be contrary to the national interest of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8f7934f4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President notifies the appropriate congressional committees in accordance with the procedures applicable to reprogramming notifications under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2394–1"},"text":"section 2394–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f7934f5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) does not apply with respect to aircraft made available to a foreign country under any provision of law that authorizes property that has been civilly or criminally forfeited to the United States to be made available to foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7934f6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for leasing of aircraft","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8f7934f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of satisfying the requirement of paragraph (1), funds made available for the “Foreign Military Financing Program” under section 23 of the Arms Export Control Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2763"},"text":"22 U.S.C. 2763","children":[],"tail":"] may be used to finance the leasing of aircraft under chapter 6 of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2796"},"text":"22 U.S.C. 2796","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f7934f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 61(a)(3) ","children":[{"tag":"ref","attrib":{"idref":"fn002124"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002124"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2796/a/3"},"text":"22 U.S.C. 2796(a)(3)","children":[],"tail":"] shall not apply with respect to leases so financed; rather the entire cost of any such lease (including any renewals) shall be an initial, one time payment of the amount which would be the sales price for the aircraft if they were sold under section 21(a)(1)(B) or section 22 of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2761/a/1/B"},"text":"22 U.S.C. 2761(a)(1)(B)","children":[],"tail":", 2762] (as appropriate)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8f7934f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent that aircraft so leased were acquired under chapter 5 of that Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2795"},"text":"22 U.S.C. 2795","children":[],"tail":" et seq.], funds used pursuant to this paragraph to finance such leases shall be credited to the Special Defense Acquisition Fund under chapter 5 of that Act (excluding the amount of funds that reflects the charges described in section 21(e)(1) of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2761/e/1"},"text":"22 U.S.C. 2761(e)(1)","children":[],"tail":"]). The funds described in the parenthetical clause of the preceding sentence shall be available for payments consistent with sections 37(a) and 43(b) of that Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2777/a"},"text":"22 U.S.C. 2777(a)","children":[],"tail":", 2792(b)]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7934fa-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissible uses of aircraft and other equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall take all reasonable steps to ensure that aircraft and other equipment made available to foreign countries under this part are used only in ways that are consistent with the purposes for which such equipment was made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8f7934fb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the reports submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291h/a"},"text":"section 2291h(a) of this title","children":[],"tail":", the President shall discuss—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f7934fc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any evidence indicating misuse by a foreign country of aircraft or other equipment made available under this part, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f7934fd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2291c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actions taken by the United States Government to prevent future misuse of such equipment by that foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f7934fe-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, § 484, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tII/s2003"},"text":"Pub. L. 99–570, title II, § 2003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-61"},"text":"100 Stat. 3207–61","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/623/s7"},"text":"Pub. L. 101–623, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-21"},"text":"Nov. 21, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3355"},"text":"104 Stat. 3355","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/583/s4/f/1"},"text":"Pub. L. 102–583, § 4(f)(1)","children":[],"tail":", (2)(D), "},{"tag":"date","attrib":{"date":"1992-11-02"},"text":"Nov. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4916"},"text":"106 Stat. 4916","children":[],"tail":", 4917.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f7934ff-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f793500-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8f793501-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Arms Export Control Act, referred to in subsec. (a)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1320"},"text":"82 Stat. 1320","children":[],"tail":". Chapters 5 and 6 of the Act are classified generally to subchapters V (§ 2795 et seq.) and VI (§ 2796 et seq.), respectively, of chapter 39 of this title. Section 61(a)(3) of the Act was redesignated section 61(a)(4), and a new section 61(a)(3) was added, by "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tVII/s731/e/2"},"text":"Pub. L. 103–236, title VII, § 731(e)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/503"},"text":"108 Stat. 503","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8f793502-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of subsecs. (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291h"},"text":"section 2291h of this title","children":[],"tail":", which were redesignated as subsecs. (b) and (c) of this section by "},{"tag":"ref","attrib":{"href":"/us/pl/102/583/s4/f/2/D"},"text":"Pub. L. 102–583, § 4(f)(2)(D)","children":[],"tail":", was based on section 489(a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. I, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIV/s4507"},"text":"Pub. L. 100–690, title IV, § 4507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4286"},"text":"102 Stat. 4286","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/583/s4/f/2/B"},"text":"Pub. L. 102–583, § 4(f)(2)(B)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"1992-11-02"},"text":"Nov. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4917"},"text":"106 Stat. 4917","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f793503-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/583/s4/f/1"},"text":"Pub. L. 102–583, § 4(f)(1)","children":[],"tail":", amended section generally, substituting subsec. (a) for former text which read as follows: “Any aircraft which, at any time after "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"October 27, 1986","children":[],"tail":", are made available to a foreign country under this part, or are made available to a foreign country primarily for narcotics-related purposes under any other provision of law, shall be provided only on a lease or loan basis. The requirement of this section does not apply with respect to aircraft made available to a foreign country under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s635/b/6/B"},"text":"section 635(b)(6)(B) of title 12","children":[],"tail":" or under any provision of law that authorizes property that has been civilly or criminally forfeited to the United States to be made available to foreign countries.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/583/s4/f/2/D"},"text":"Pub. L. 102–583, § 4(f)(2)(D)","children":[],"tail":", redesignated subsecs. (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291h"},"text":"section 2291h of this title","children":[],"tail":" as subsecs. (b) and (c), respectively, of this section. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/623"},"text":"Pub. L. 101–623","children":[],"tail":" inserted at end “The requirement of this section does not apply with respect to aircraft made available to a foreign country under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s635/b/6/B"},"text":"section 635(b)(6)(B) of title 12","children":[],"tail":" or under any provision of law that authorizes property that has been civilly or criminally forfeited to the United States to be made available to foreign countries.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f793504-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f793505-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Training of Host Country Pilots","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/623/s13"},"text":"Pub. L. 101–623, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-21"},"text":"Nov. 21, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3356"},"text":"104 Stat. 3356","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/623/s13"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Instruction Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-21"},"text":"Nov. 21, 1990","children":[],"tail":"], the President shall implement, under chapter 8 of part I of the Foreign Assistance Act of 1961 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291"},"text":"22 U.S.C. 2291","children":[],"tail":" and following; relating to international narcotics control assistance), a detailed program of instruction to train host country pilots, and other flight crew members, to fly host country aircraft involved in counternarcotics efforts in Andean countries. Such program shall be designed to eliminate direct participation of the United States Government (including participation through the use of either direct hire or contract personnel) in the operation of such aircraft."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Replacement of United States Government Pilots by Host Country Pilots","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall ensure that, within 18 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-21"},"text":"Nov. 21, 1990","children":[],"tail":"], flight crews composed of host country personnel replace all United States Government pilots and other flight crew members (including both direct hire or contract personnel) for host country aircraft involved in airborne counternarcotics operations in the Andean countries."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aircraft Subject to Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As used in this section, the term ‘host country aircraft’ means any aircraft made available to an Andean country by the United States Government under chapter 8 of part I of the Foreign Assistance Act of 1961 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291"},"text":"22 U.S.C. 2291","children":[],"tail":" et seq.], or any other provision of law, for use by that country for narcotics-related purposes.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Functions of President under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/623/s13"},"text":"section 13 of Pub. L. 101–623","children":[],"tail":", set out above, delegated to Secretary of State in consultation with Secretary of Defense by Determination of President of the United States, No. 91–20, "},{"tag":"date","attrib":{"date":"1991-01-25"},"text":"Jan. 25, 1991","children":[],"tail":", 56 F.R. 8681, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2291"},"text":"section 2291 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id8f793506-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"id8f793507-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see Ex. Ord. No. 12163, ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", 44 F.R. 56673, as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2381"},"text":"section 2381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
