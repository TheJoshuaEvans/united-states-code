{"tag":"section","attrib":{"id":"id8ebcc223-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284w"},"text":null,"children":[{"tag":"num","attrib":{"value":"284w"},"text":"§ 284w.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multilateral debt relief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebcc224-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284w/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of contribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury is authorized to contribute, on behalf of the United States, not more than $356,000,000 to the International Development Association for the purpose of funding debt relief under the Multilateral Debt Relief Initiative in the period governed by the fifteenth replenishment of resources of the International Development Association, subject to obtaining the necessary appropriations and without prejudice to any funding arrangements in existence on ","children":[{"tag":"date","attrib":{"date":"2009-06-24"},"text":"June 24, 2009","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc225-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284w/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to pay for the United States contribution provided for in subsection (a), there are authorized to be appropriated, without fiscal year limitation, not more than $356,000,000 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebcc226-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s284w/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multilateral Debt Relief Initiative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Multilateral Debt Relief Initiative” means the proposal set out in the G8 Finance Ministers’ Communique entitled “Conclusions on Development,” done at London, ","children":[{"tag":"date","attrib":{"date":"2005-06-11"},"text":"June 11, 2005","children":[],"tail":", and reaffirmed by G8 Heads of State at the Gleneagles Summit on "},{"tag":"date","attrib":{"date":"2005-07-08"},"text":"July 8, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebcc227-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/565/s25"},"text":"Pub. L. 86–565, § 25","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/32/tXI/s1109/a"},"text":"Pub. L. 111–32, title XI, § 1109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-06-24"},"text":"June 24, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1901"},"text":"123 Stat. 1901","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
