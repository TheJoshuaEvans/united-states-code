{"tag":"section","attrib":{"id":"id8ef1400c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s618"},"text":null,"children":[{"tag":"num","attrib":{"value":"618"},"text":"§ 618.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement and penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ef1400d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s618/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations; false statements and willful omissions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ef1400e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s618/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully violates any provision of this subchapter or any regulation thereunder, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ef1400f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s618/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any registration statement or supplement thereto or in any other document filed with or furnished to the Attorney General under the provisions of this subchapter willfully makes a false statement of a material fact or willfully omits any material fact required to be stated therein or willfully omits a material fact or a copy of a material document necessary to make the statements therein and the copies of documents furnished therewith not misleading, shall, upon conviction thereof, be punished by a fine of not more than $10,000 or by imprisonment for not more than five years, or both, except that in the case of a violation of subsection (b), (e), or (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s614"},"text":"section 614 of this title","children":[],"tail":" or of subsection (g) or (h) of this section the punishment shall be a fine of not more than $5,000 or imprisonment for not more than six months, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ef14010-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s618/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof of identity of foreign principal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any proceeding under this subchapter in which it is charged that a person is an agent of a foreign principal with respect to a foreign principal outside of the United States, proof of the specific identity of the foreign principal shall be permissible but not necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ef14011-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s618/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any alien who shall be convicted of a violation of, or a conspiracy to violate, any provision of this subchapter or any regulation thereunder shall be subject to removal pursuant to chapter 4 of title II of the Immigration and Nationality Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1221"},"text":"8 U.S.C. 1221","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ef14012-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s618/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s9/8/B"},"text":"Pub. L. 104–65, § 9(8)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/700"},"text":"109 Stat. 700","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ef14013-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s618/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing offense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Failure to file any such registration statement or supplements thereto as is required by either section 612(a) or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s612/b"},"text":"section 612(b) of this title","children":[],"tail":" shall be considered a continuing offense for as long as such failure exists, notwithstanding any statute of limitation or other statute to the contrary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ef14014-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s618/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctive remedy; jurisdiction of district court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever in the judgment of the Attorney General any person is engaged in or about to engage in any acts which constitute or will constitute a violation of any provision of this subchapter, or regulations issued thereunder, or whenever any agent of a foreign principal fails to comply with any of the provisions of this subchapter or the regulations issued thereunder, or otherwise is in violation of the subchapter, the Attorney General may make application to the appropriate United States district court for an order enjoining such acts or enjoining such person from continuing to act as an agent of such foreign principal, or for an order requiring compliance with any appropriate provision of the subchapter or regulation thereunder. The district court shall have jurisdiction and authority to issue a temporary or permanent injunction, restraining order or such other order which it may deem proper.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ef14015-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s618/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deficient registration statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Attorney General determines that a registration statement does not comply with the requirements of this subchapter or the regulations issued thereunder, he shall so notify the registrant in writing, specifying in what respects the statement is deficient. It shall be unlawful for any person to act as an agent of a foreign principal at any time ten days or more after receipt of such notification without filing an amended registration statement in full compliance with the requirements of this subchapter and the regulations issued thereunder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ef14016-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s618/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contingent fee arrangement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any agent of a foreign principal required to register under this subchapter to be a party to any contract, agreement, or understanding, either express or implied, with such foreign principal pursuant to which the amount or payment of the compensation, fee, or other remuneration of such agent is contingent in whole or in part upon the success of any political activities carried on by such agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ef14017-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-08/ch327/s8"},"text":"June 8, 1938, ch. 327, § 8","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1942-04-29/ch263/s1"},"text":"Apr. 29, 1942, ch. 263, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/56/257"},"text":"56 Stat. 257","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-23/ch1024"},"text":"Sept. 23, 1950, ch. 1024","children":[],"tail":", title I, § 20(b), "},{"tag":"ref","attrib":{"href":"/us/stat/64/1005"},"text":"64 Stat. 1005","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"June 27, 1952, ch. 477","children":[],"tail":", title IV, § 402(d), "},{"tag":"ref","attrib":{"href":"/us/stat/66/276"},"text":"66 Stat. 276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch849/s1"},"text":"Aug. 1, 1956, ch. 849, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/899"},"text":"70 Stat. 899","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/486/s7"},"text":"Pub. L. 89–486, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-07-04"},"text":"July 4, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/248"},"text":"80 Stat. 248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/tIV/s402/26"},"text":"Pub. L. 98–620, title IV, § 402(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3359"},"text":"98 Stat. 3359","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s9/8"},"text":"Pub. L. 104–65, § 9(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-19"},"text":"Dec. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/700"},"text":"109 Stat. 700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dC/tIII/s308/e/19"},"text":"Pub. L. 104–208, div. C, title III, § 308(e)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-621"},"text":"110 Stat. 3009–621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ef14018-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ef14019-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ef1401a-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":". Chapter 4 of title II of the Act is classified generally to part IV (§ 1221 et seq.) of subchapter II of chapter 12 of Title 8, Aliens and Nationality. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8ef1401b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions on this subject were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s615"},"text":"section 615 of this title","children":[],"tail":" prior to general amendment of act "},{"tag":"date","attrib":{"date":"1938-06-08"},"text":"June 8, 1938","children":[],"tail":", by act "},{"tag":"date","attrib":{"date":"1942-04-29"},"text":"Apr. 29, 1942","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ef1401c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “removal pursuant to chapter 4 of title II of the Immigration and Nationality Act” for “deportation in the manner provided by sections 1251 to 1253 of title 8”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s9/8/A"},"text":"Pub. L. 104–65, § 9(8)(A)","children":[],"tail":", struck out “or in any statement under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s614/a"},"text":"section 614(a) of this title","children":[],"tail":" concerning the distribution of political propaganda” after “or supplement thereto”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65/s9/8/B"},"text":"Pub. L. 104–65, § 9(8)(B)","children":[],"tail":", struck out subsec. (d) which read as follows: “The United States Postal Service may declare to be nonmailable any communication or expression falling within clause (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s611/j"},"text":"section 611(j) of this title","children":[],"tail":" in the form of prints or in any other form reasonably adapted to, or reasonably appearing to be intended for, dissemination or circulation among two or more persons, which is offered or caused to be offered for transmittal in the United States mails to any person or persons in any other American republic by any agent of a foreign principal, if the United States Postal Service is informed in writing by the Secretary of State that the duly accredited diplomatic representative of such American republic has made written representation to the Department of State that the admission or circulation of such communication or expression in such American republic is prohibited by the laws thereof and has requested in writing that its transmittal thereto be stopped.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" struck out provision that the proceedings shall be made a preferred cause and expedited in every way."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/486/s7/1"},"text":"Pub. L. 89–486, § 7(1)","children":[],"tail":", inserted exception provision."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/486/s7/2"},"text":"Pub. L. 89–486, § 7(2)","children":[],"tail":", added subsecs. (f) to (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-08-01"},"text":"Aug. 1, 1956","children":[],"tail":", amended credit to section by redesignating section 20(b) of act "},{"tag":"date","attrib":{"date":"1950-09-23"},"text":"Sept. 23, 1950","children":[],"tail":", as section 20."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1952—Subsec. (c). Act ","children":[{"tag":"date","attrib":{"date":"1952-06-27"},"text":"June 27, 1952","children":[],"tail":", substituted “sections 1251 to 1253 of title 8” for “sections 155 and 156 of title 8”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1950—Subsec. (e). Act ","children":[{"tag":"date","attrib":{"date":"1950-09-23"},"text":"Sept. 23, 1950","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ef1401d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ef1401e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective, with certain transitional provisions, on the first day of the first month beginning more than 180 days after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/s309"},"text":"section 309 of Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ef1401f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/65"},"text":"Pub. L. 104–65","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/65/s24"},"text":"section 24 of Pub. L. 104–65","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1601"},"text":"section 1601 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ef14020-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/620"},"text":"Pub. L. 98–620","children":[],"tail":" not applicable to cases pending on "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/620/s403"},"text":"section 403 of Pub. L. 98–620","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1657"},"text":"section 1657 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ef14021-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/486"},"text":"Pub. L. 89–486","children":[],"tail":" effective ninety days after "},{"tag":"date","attrib":{"date":"1966-07-04"},"text":"July 4, 1966","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/486/s9"},"text":"section 9 of Pub. L. 89–486","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s611"},"text":"section 611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8ef14022-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the sixtieth day after ","children":[{"tag":"date","attrib":{"date":"1942-04-29"},"text":"Apr. 29, 1942","children":[],"tail":", except that prior to such sixtieth day the Attorney General may make, prescribe, amend, and rescind such rules, regulations, and forms as may be necessary to carry out act "},{"tag":"date","attrib":{"date":"1942-04-29"},"text":"Apr. 29, 1942","children":[],"tail":", see section 3 of act "},{"tag":"date","attrib":{"date":"1942-04-29"},"text":"Apr. 29, 1942","children":[],"tail":", set out as an Effective Date of 1942 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s611"},"text":"section 611 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
