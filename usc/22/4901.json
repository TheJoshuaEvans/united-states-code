{"tag":"section","attrib":{"id":"id90868558-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4901"},"text":null,"children":[{"tag":"num","attrib":{"value":"4901"},"text":"§ 4901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship program for temporary service at United States missions abroad","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90868559-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is hereby established a fellowship program pursuant to which the Secretary of State will provide fellowships to United States citizens while they serve, for a period of between one and two years, in positions which would otherwise be held by foreign national employees at United States diplomatic or consular missions abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9086855a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of fellowships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fellowships under this chapter shall be known as “Fascell Fellowships”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9086855b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of fellowships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fellowships under this chapter shall be provided in order to allow the recipient (hereafter in this chapter referred to as a “Fellow”) to serve on a short-term basis at a United States diplomatic or consular mission abroad in order to obtain first hand exposure to that country, including (as appropriate) independent study in that country’s area studies or languages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9086855c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4901/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals who may receive a fellowship","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To receive a fellowship under this chapter, an individual must be a United States citizen who is an undergraduate or graduate student, a teacher, scholar, or other academic, or an other individual, who has expertise in international affairs, foreign languages, or career and professional experience or interest in international affairs, and who has a working knowledge of the principal language of the country in which he or she would serve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9086855d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4901/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Women and members of minority groups","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary of State shall actively recruit women and members of minority groups.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9086855e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tX/s1002"},"text":"Pub. L. 99–399, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/893"},"text":"100 Stat. 893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/454/s9/b"},"text":"Pub. L. 101–454, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-24"},"text":"Oct. 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1065"},"text":"104 Stat. 1065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/199/tIII/s303"},"text":"Pub. L. 103–199, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2323"},"text":"107 Stat. 2323","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9086855f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90868560-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90868561-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/199"},"text":"Pub. L. 103–199","children":[],"tail":" substituted “abroad” for “in the Soviet Union and Eastern Europe” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/454/s9/b/1"},"text":"Pub. L. 101–454, § 9(b)(1)","children":[],"tail":", substituted “which would otherwise be” for “formerly” and “abroad” for “in the Soviet Union or Eastern European countries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/454/s9/b/2"},"text":"Pub. L. 101–454, § 9(b)(2)","children":[],"tail":", substituted “abroad” for “in the Soviet Union or an Eastern European country” and “that country’s” for “Soviet or Eastern European”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/454/s9/b/3"},"text":"Pub. L. 101–454, § 9(b)(3)","children":[],"tail":", substituted “international affairs, foreign languages, or career and professional experience or interest in international affairs,” for “Soviet or Eastern European area studies or languages”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90868562-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"id90868563-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/454/s9/a"},"text":"Pub. L. 101–454, § 9(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-24"},"text":"Oct. 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1065"},"text":"104 Stat. 1065","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/454/s9/a"},"text":"“This section [amending this section and sections 4902 and 4904 of this title, and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4902"},"text":"section 4902 of this title","children":[],"tail":"] may be cited as the ‘Fascell Fellowship Amendments Act of 1990’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id90868564-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399/tX/s1001"},"text":"Pub. L. 99–399, title X, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/893"},"text":"100 Stat. 893","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/399/tX/s1001"},"text":"“This title [enacting this chapter] may be cited as the ‘Fascell Fellowship Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
