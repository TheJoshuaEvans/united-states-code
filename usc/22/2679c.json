{"tag":"section","attrib":{"id":"id8ff2d15c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2679c"},"text":"§ 2679c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on discriminatory contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff2d15d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff2d15e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except for real estate leases and as provided in subsection (b), the Department of State may not enter into any contract that expends funds appropriated to the Department of State for an amount in excess of the small purchase threshold (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":"— "},{"tag":"ref","attrib":{"idref":"fn002194"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002194"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “41)—”."}],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff2d15f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a foreign person that complies with the Arab League boycott of Israel, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff2d160-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with any foreign or United States person that discriminates in the award of subcontracts on the basis of religion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff2d161-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ff2d162-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign person complies with the boycott of Israel by Arab League countries when that foreign person takes or knowingly agrees to take any action, with respect to the boycott of Israel by Arab League countries, which section 4607(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002195"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002195"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 50 prohibits a United States person from taking, except that for purposes of this paragraph, the term “United States person” as used in subparagraphs (B) and (C) of section 4607(a)(1) "},{"tag":"ref","attrib":{"idref":"fn002195"},"text":"2","children":[],"tail":" of title 50 shall be deemed to mean “person”; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ff2d163-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “foreign person” means any person other than a United States person as defined in section 4618(2) ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" of title 50."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff2d164-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of paragraph (1), a foreign person shall be deemed not to comply with the boycott of Israel by Arab League countries if that person, or the Secretary of State or his designee on the basis of available information, certifies that the person violates or otherwise does not comply with the boycott of Israel by Arab League countries by taking any actions prohibited by section 4607(a) ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" of title 50. Certification by the Secretary of State or his designee may occur only 30 days after notice has been given to the Congress that this certification procedure will be utilized at a specific overseas mission."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff2d165-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver by Secretary of State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State may waive the requirements of this section on a country-by-country basis for a period not to exceed one year upon certification to the Congress by the Secretary that such waiver is in the national interest and is necessary to carry on diplomatic functions of the United States. Each such certification shall include a detailed justification for the waiver with respect to each such country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff2d166-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responses to contract solicitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff2d167-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, the Secretary of State shall ensure that any response to a solicitation for a bid or a request for a proposal, with respect to a contract covered by subsection (a), includes the following clause, in substantially the following form:","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"level","attrib":{"id":"id8ff2d168-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"“arab league boycott of israel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ff2d169-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this clause—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff2d16a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘foreign person’ means any person other than a United States person as defined in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff2d16b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘United States person’ means any United States resident or national (other than an individual resident outside the United States and employed by other than a United States person), any domestic concern (including any permanent domestic establishment of any foreign concern), and any foreign subsidiary or affiliate (including any permanent foreign establishment) of any domestic concern which is controlled in fact by such domestic concern, as determined under regulations of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff2d16c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"By submitting this offer, the Offeror certifies that it is not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff2d16d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking or knowingly agreeing to take any action, with respect to the boycott of Israel by Arab League countries, which section 8(a) of the Export Administration Act of 1979 (50 U.S.C. App. 2407(a)) prohibits a United States person from taking; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff2d16e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discriminating in the award of subcontracts on the basis of religion.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff2d16f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Offeror would not be required to include the certification required by paragraph (1), if the Offeror is deemed not to comply with the Arab League boycott of Israel by the Secretary of State or a designee on the basis of available information. Certification by the Secretary of State or a designee may occur only 30 days after notice has been given to the Congress that this certification procedure will be utilized at a specific overseas mission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff2d170-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State shall ensure that all State Department contract solicitations include a detailed explanation of the requirements of section 4607(a) ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" of title 50."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ff2d171-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and termination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ff2d172-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of State shall conduct reviews of the certifications submitted pursuant to this section for the purpose of assessing the accuracy of the certifications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ff2d173-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2679c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon complaint of any foreign or United States person of a violation of the certification as required by this section, filed with the Secretary of State, the Department of State shall investigate such complaint, and if such complaint is found to be correct and a violation of the certification has been found, all contracts with such violator shall be terminated for default as soon as practicable, and, for a period of two years thereafter, the State Department shall not enter into any contracts with such a violator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ff2d174-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tV/s565"},"text":"Pub. L. 103–236, title V, § 565","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/484"},"text":"108 Stat. 484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, § 1336(3), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-790"},"text":"112 Stat. 2681–790","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ff2d175-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ff2d176-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ff2d177-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4607/a"},"text":"Section 4607(a) of title 50","children":[],"tail":", referred to in subsecs. (a)(2)(A), (3) and (c)(3), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s4618/2"},"text":"Section 4618(2) of title 50","children":[],"tail":", referred to in subsec. (a)(2)(B), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8(a) of the Export Administration Act of 1979 (50 U.S.C. App. 2407(a)), referred to in subsec. (c)(1) in the quoted clause, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/72/s8/a"},"text":"section 8(a) of Pub. L. 96–72","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-29"},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/521"},"text":"93 Stat. 521","children":[],"tail":", which was editorially transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s4607/a"},"text":"section 4607(a) of Title 50","children":[],"tail":", War and National Defense, and was subsequently repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVII/s1766/a"},"text":"Pub. L. 115–232, div. A, title XVII, § 1766(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2232"},"text":"132 Stat. 2232","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8ff2d178-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a)(1), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":"” substituted for “section 4(11) of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s403/11"},"text":"41 U.S.C. 403(11)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ff2d179-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" struck out heading and text of subsec. (e). Text read as follows: “The provisions of this section shall apply to the United States Information Agency in the same manner and extent to which such provisions apply to the Department of State. In the application of this section to the United States Information Agency, the Director of the United States Information Agency or a designee shall have the authorities and responsibilities of the Secretary of State.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ff2d17a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ff2d17b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id8ff2d17c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tV/s561"},"text":"Pub. L. 103–236, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/483"},"text":"108 Stat. 483","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/236/tV/s561"},"text":"“This part [part C (§§ 561–565) of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", enacting this section and provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of this title","children":[],"tail":"] may be cited as the ‘Anti-Economic Discrimination Act of 1994’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
