],"tail":"” substituted for “the Classification Act of 1949” and “section 15 of Public Law 600, Seventy-ninth Congress ["},{"tag":"ref","attrib":{"href":"/us/usc/t5/s55a"},"text":"5 U.S.C. 55a","children":[],"tail":"]”, respectively, on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":" "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", which Act enacted Title 5, Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(1), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s501"},"text":"section 501 of title 44","children":[],"tail":"” substituted for “"},{"tag":"ref","attrib":{"href":"/us/act/1919-03-01/s11"},"text":"section 11 of the Act of March 1, 1919","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t44/s111"},"text":"44 U.S.C. 111","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/90/620/s2/b"},"text":"Pub. L. 90–620, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1305"},"text":"82 Stat. 1305","children":[],"tail":", which Act enacted Title 44, Public Printing and Documents."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(1), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"” substituted for “section 3709 of the Revised Statutes, as amended” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","chil