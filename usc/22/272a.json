e39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annual Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Annual appropriations to meet the obligations of membership in various international organizations were contained in acts listed in a note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s269a"},"text":"section 269a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ea73e44-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation of Contributions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Contributions by United States, except for special projects, limited to amount provided by Joint Res. ","children":[{"tag":"date","attrib":{"date":"1950-09-21"},"text":"Sept. 21, 1950","children":[],"tail":"; consent by State Department and reports to Congress, see "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s262a"},"text":"section 262a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
