{"tag":"section","attrib":{"id":"id8ea73e37-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s272a"},"text":null,"children":[{"tag":"num","attrib":{"value":"272a"},"text":"§ 272a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There is hereby authorized to be appropriated annually to the Department of State—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ea73e38-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s272a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as may be necessary for the payments by the United States of its share of the expenses of the Organization, but not to exceed 25 per centum of such expenses, as apportioned by the International Labour Conference in accordance with article 13(2)(c) and 13(3) of the constitution of the Organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ea73e39-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s272a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such additional sums as may be necessary to pay the expenses incident to participation by the United States in the activities of the Organization, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ea73e3a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s272a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" salaries of the representative or representatives and alternates and appropriate staff, including personal services in the District of Columbia and elsewhere, without regard to the civil-service laws and chapter 51 and subchapter III of chapter 53 of title 5; services as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"; under such rules and regulations as the Secretary of State may prescribe, allowances for living quarters, including heat, fuel, and light and cost-of-living allowances to persons temporarily stationed abroad; printing and binding without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s501"},"text":"section 501 of title 44","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"section 6101 of title 41","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ea73e3b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s272a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other expenses as the Secretary of State deems necessary to participation by the United States in the activities of the Organization: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s287r"},"text":"section 287r of this title","children":[],"tail":", and regulations thereunder, applicable to expenses incurred pursuant to subchapter XVII of this chapter shall be applicable to any expenses incurred pursuant to this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ea73e3c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch756/s2"},"text":"June 30, 1948, ch. 756, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/1151"},"text":"62 Stat. 1151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch782"},"text":"Oct. 28, 1949, ch. 782","children":[],"tail":", title II, § 202(2), title XI, § 1106(a), "},{"tag":"ref","attrib":