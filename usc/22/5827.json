{"tag":"section","attrib":{"id":"id909e7a8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5827"},"text":null,"children":[{"tag":"num","attrib":{"value":"5827"},"text":"§ 5827.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance for Russian Far East","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id909e7a8e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5827/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to provide technical assistance, through an American university in a region which received nonstop air service to and from the Russian Far East as of ","children":[{"tag":"date","attrib":{"date":"1992-07-01"},"text":"July 1, 1992","children":[],"tail":", to facilitate the development of United States business opportunities, free markets, and democratic institutions in the Russian Far East."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id909e7a8f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5827/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $2,000,000 to carry out subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id909e7a90-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/tIII/s307"},"text":"Pub. L. 102–511, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children