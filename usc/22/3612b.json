{"tag":"section","attrib":{"id":"id903f1cc0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3612b"},"text":"§ 3612b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific powers of Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id903f1cc1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Panama Canal management, operation, and maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may manage, operate, and maintain the Panama Canal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1cc2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment, maintenance, and operation of activities, facilities, and appurtenances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may construct or acquire, establish, maintain, and operate such activities, facilities, and appurtenances as necessary and appropriate for the accomplishment of the purposes of this chapter, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903f1cc3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Docks, wharves, piers, and other shoreline facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1cc4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Shops and yards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1cc5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Marine railways, salvage and towing facilities, fuel-handling facilities, and motor transportation facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1cc6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Power systems, water systems, and a telephone system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1cc7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Construction facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1cc8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Living quarters and other buildings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1cc9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Warehouses, storehouses, a printing plant, and manufacturing, processing, or service facilities in connection therewith.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1cca-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recreational facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1ccb-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of United States mails","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may use the United States mails in the same manner and under the same conditions as the executive departments of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1ccc-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Necessary or appropriate actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may take such actions as are necessary or appropriate to carry out the powers specifically conferred upon it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1ccd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may conduct and promote commercial activities related to the management, operation, or maintenance of the Panama Canal. Any such commercial activity shall be carried out consistent with the Panama Canal Treaty of 1977 and related agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id903f1cce-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id903f1ccf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission may seek and accept donations of funds, property, and services from individuals, foundations, corporations, and other private and public entities for the purpose of carrying out its promotional activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id903f1cd0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3612b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall establish written guidelines setting forth the criteria to be used in determining whether the acceptance of funds, property, or services authorized by paragraph (1) would reflect unfavorably upon the ability of the Commission (or any employee of the Commission) to carry out its responsibilities or official duties in a fair and objective manner or would compromise the integrity or the appearance of the integrity of its programs or of any official in those programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id903f1cd1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1102b"},"text":"Pub. L. 96–70, title I, § 1102b","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dC/tXXXV/s3524/a"},"text":"Pub. L. 104–106, div. C, title XXXV, § 3524(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/639"},"text":"110 Stat. 639","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dC/tXXXV/s3547"},"text":"Pub. L. 105–85, div. C, title XXXV, § 3547","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2073"},"text":"111 Stat. 2073","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dC/tXXXV/s3505"},"text":"Pub. L. 105–261, div. C, title XXXV, § 3505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2268"},"text":"112 Stat. 2268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id903f1cd2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id903f1cd3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id903f1cd4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/452"},"text":"93 Stat. 452","children":[],"tail":", known as the Panama Canal Act of 1979 which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"section 3601 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id903f1cd5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261"},"text":"Pub. L. 105–261","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Pub. L. 105–85","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
