{"tag":"section","attrib":{"id":"id8f06c36c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1473"},"text":null,"children":[{"tag":"num","attrib":{"value":"1473"},"text":"§ 1473.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of existing Government property and facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In carrying on activities under this chapter which require the utilization of Government property and facilities, maximum use shall be made of existing Government property and facilities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f06c36d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-01-27/ch36"},"text":"Jan. 27, 1948, ch. 36","children":[],"tail":", title VIII, § 803, "},{"tag":"ref","attrib":{"href":"/us/stat/62/12"},"text":"62 Stat. 12","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
