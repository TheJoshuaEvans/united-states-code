{"tag":"section","attrib":{"id":"id8fc57f97-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2458a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2458a"},"text":"§ 2458a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal employee participation in cultural exchange programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fc57f98-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2458a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and other foreign government assistance; family or household expense assistance prohibited; “Federal employee” defined","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fc57f99-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2458a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Congress consents to the acceptance by a Federal employee of grants and other forms of assistance provided by a foreign government to facilitate the participation of such Federal employee in a cultural exchange—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fc57f9a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2458a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is of the type described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2452/a/2/i"},"text":"section 2452(a)(2)(i) of this title","children":[],"tail":","}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fc57f9b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2458a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is conducted for a purpose comparable to the purpose stated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2451"},"text":"section 2451 of this title","children":[],"tail":", and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fc57f9c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2458a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is specifically approved by the Secretary of State for purposes of this section;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but the Congress does not consent to the acceptance by any Federal employee of any portion of any such grant or other form of assistance which provides assistance with respect to any expenses incurred by or for any member of the family or household of such Federal employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fc57f9d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2458a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the term “Federal employee” means any employee as defined in subparagraphs (A) through (F) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7342/a/1"},"text":"section 7342(a)(1) of title 5","children":[],"tail":", but does not include a person described in subparagraph (G) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc57f9e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2458a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign grants and other assistance not gifts for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7342"},"text":"section 7342 of title 5","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grants and other forms of assistance with respect to which the consent of Congress is given in subsection (a) of this section shall not constitute gifts for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7342"},"text":"section 7342 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fc57f9f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2458a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State is authorized to promulgate regulations for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fc57fa0-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/256/s108A"},"text":"Pub. L. 87–256, § 108A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/350/tI/s111"},"text":"Pub. L. 94–350, title I, § 111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-07-12"},"text":"July 12, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/825"},"text":"90 Stat. 825","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/60/tII/s204/d"},"text":"Pub. L. 96–60, title II, § 204(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-15"},"text":"Aug. 15, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/400"},"text":"93 Stat. 400","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fc57fa1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fc57fa2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fc57fa3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/60"},"text":"Pub. L. 96–60","children":[],"tail":" substituted “(F)” for “(E)” and “(G)” for “(F)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fc57fa4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8fc57fa5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/60"},"text":"Pub. L. 96–60","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/60/s209"},"text":"section 209 of Pub. L. 96–60","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1471"},"text":"section 1471 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
