{"tag":"section","attrib":{"id":"id9147b2fe-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9672"},"text":null,"children":[{"tag":"num","attrib":{"value":"9672"},"text":"§ 9672.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additionality and avoidance of market distortion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9147b2ff-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9672/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the Corporation provides support for a project under subchapter II of this chapter, the Corporation shall ensure that private sector entities are afforded an opportunity to support the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9147b300-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9672/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safeguards, policies, and guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation shall develop appropriate safeguards, policies, and guidelines to ensure that support provided by the Corporation under subchapter II of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9147b301-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9672/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplements and encourages, but does not compete with, private sector support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b302-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9672/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates according to internationally recognized best practices and standards with respect to ensuring the avoidance of market distorting government subsidies and the crowding out of private sector lending; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9147b303-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9672/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have a significant adverse impact on United States employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9147b304-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dF/tV/s1452"},"text":"Pub. L. 115–254, div. F, title V, § 1452","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3509"},"text":"132 Stat. 3509","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
