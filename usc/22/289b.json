{"tag":"section","attrib":{"id":"id8edbbbec-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s289b"},"text":null,"children":[{"tag":"num","attrib":{"value":"289b"},"text":"§ 289b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations; payment of salaries and expenses","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"There is hereby authorized to be appropriated annually to the Department of State—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8edbbbed-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s289b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums, not to exceed $73,325,000 for the fiscal year beginning ","children":[{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":", as may be necessary for the payment of United States contributions to the Organization (consisting of supplies, services, or funds and all necessary expenses related thereto) as determined in accordance with article 10 of the constitution of the Organization; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8edbbbee-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s289b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such sums, not to exceed $175,000 for the fiscal year beginning ","children":[{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":", as may be necessary for the payment of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8edbbbef-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s289b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" salaries of the representative or representatives and alternates provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s289a"},"text":"section 289a of this title","children":[],"tail":", and appropriate staff, including personal services in the District of Columbia and elsewhere, without regard to the civil-service laws and chapter 51 and subchapter III of chapter 53 of title 5; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8edbbbf0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s289b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other expenses as the Secretary of State deems necessary to participation by the United States in the activities of the Organization; ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s287e"},"text":"section 287e of this title","children":[],"tail":" and regulations thereunder, applicable to expenses incurred pursuant to subchapter XVI of this chapter shall be applicable to any expenses incurred pursuant to this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8edbbbf1-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-01/ch185/s3"},"text":"July 1, 1947, ch. 185, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/215"},"text":"61 Stat. 215","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch782"},"text":"Oct. 28, 1949, ch. 782","children":[],"tail":", title II, § 202(2), title XI, § 1106(a), "},{"tag":"ref","attrib":{"href":"/us/stat/63/954"},"text":"63 Stat. 954","children":[],"tail":", 972.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8edbbbf2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8edbbbf3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8edbbbf4-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter XVI [§ 287 et seq.] of this chapter, referred to in subsec. (b)(2), was in the original a reference to the United Nations Participation Act of 1945.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id8edbbbf5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(1), “chapter 51 and subchapter III of chapter 53 of title 5” substituted for “the Classification Act of 1949” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554/s7/b"},"text":"Pub. L. 89–554, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/631"},"text":"80 Stat. 631","children":[],"tail":", the first section of which enacted Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8edbbbf6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1949—Subsec. (b)(1). Act ","children":[{"tag":"date","attrib":{"date":"1949-10-28"},"text":"Oct. 28, 1949","children":[],"tail":", substituted “Classification Act of 1949” for “Classification Act of 1923”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8edbbbf7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"id8edbbbf8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch782"},"text":"Act Oct. 28, 1949, ch. 782","children":[],"tail":", cited as a credit to this section, was repealed (subject to a savings clause) by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", § 8, "},{"tag":"ref","attrib":{"href":"/us/stat/80/632"},"text":"80 Stat. 632","children":[],"tail":", 655."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
