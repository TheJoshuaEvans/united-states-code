{"tag":"section","attrib":{"id":"id8ffeb878-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2723"},"text":null,"children":[{"tag":"num","attrib":{"value":"2723"},"text":"§ 2723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of visas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ffeb879-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb87a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2723/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of visas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall report, on a timely basis, to the appropriate committees of the Congress each time a consular post denies a visa on the grounds of terrorist activities or foreign policy. Such report shall set forth the name and nationality of each such person and a factual statement of the basis for such denial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb87b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2723/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visa issuance to inadmissible aliens","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, on a semiannual basis, submit to the appropriate committees of the Congress a report describing every instance during the period covered by the report in which a consular post or the Visa Office of the Department of State issued an immigrant or nonimmigrant visa to an alien who is inadmissible to the United States based upon terrorist activity or failed to object to the issuance of an immigrant or nonimmigrant visa to an alien notwithstanding any such ground of inadmissibility. The report shall set forth the name and nationality of the alien, the issuing post, and a brief factual statement of the basis for issuance of the visa or the failure to object. The report may be submitted in classified or unclassified form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb87c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information contained in such report may be classified to the extent necessary and shall protect intelligence sources and methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9001016d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section the term “appropriate committees of the Congress” means the Committee on the Judiciary and the Committee on Foreign Affairs of the House of Representatives and the Committee on the Judiciary and the Committee on Foreign Relations of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9001016e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 51, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s127/a"},"text":"Pub. L. 102–138, title I, § 127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/660"},"text":"105 Stat. 660","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tII/s231"},"text":"Pub. L. 107–228, div. A, title II, § 231","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1372"},"text":"116 Stat. 1372","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9001016f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90010170-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90010171-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" designated existing provisions as par. (1), inserted par. (1) heading, and added par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
