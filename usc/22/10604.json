{"tag":"section","attrib":{"id":"id915ac576-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604"},"text":null,"children":[{"tag":"num","attrib":{"value":"10604"},"text":"§ 10604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corporate powers and obligations of the Foundation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id915ac577-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id915ac578-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id915ac579-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may conduct business in foreign countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac57a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have its principal offices in the Washington, DC, metropolitan area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id915ac57b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall continuously maintain a designated agent in Washington, DC, who is authorized to accept notice or service of process on behalf of the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac57c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The serving of notice to, or service of process upon, the agent referred to in paragraph (1)(C), or mailed to the business address of such agent, shall be deemed as service upon, or notice to, the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac57d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation shall be subject to the general audit authority of the Comptroller General of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3523"},"text":"section 3523 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915ac57e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to powers explicitly authorized under this chapter, the Foundation, in order to carry out the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10602/b"},"text":"section 10602(b) of this title","children":[],"tail":", shall have the usual powers of a corporation headquartered in Washington, DC, including the authority—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id915ac57f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept, receive, solicit, hold, administer, and use any gift, devise, or bequest, either absolutely or in trust, or real or personal property or any income derived from such gift or property, or other interest in such gift or property located in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac580-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire by donation, gift, devise, purchase, or exchange any real or personal property or interest in such property located in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac581-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise required by the instrument of transfer, to sell, donate, lease, invest, reinvest, retain, or otherwise dispose of any property or income derived from such property located in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac582-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complain and defend itself in any court of competent jurisdiction (except that the members of the Board shall not be personally liable, except for gross negligence);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac583-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into contracts or other arrangements with public agencies, private organizations, and persons and to make such payments as may be necessary to carry out the purposes of such contracts or arrangements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id915ac584-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award grants for eligible projects, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10606"},"text":"section 10606 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id915ac585-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10604/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of public liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States shall not be liable for any debts, defaults, acts, or omissions of the Foundation. The Federal Government shall be held harmless from any damages or awards ordered by a court against the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id915ac586-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLI/s5104"},"text":"Pub. L. 118–159, div. E, title LI, § 5104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2416"},"text":"138 Stat. 2416","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
