{"tag":"section","attrib":{"id":"id907372e0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4204"},"text":null,"children":[{"tag":"num","attrib":{"value":"4204"},"text":"§ 4204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction as to certificate for goods from countries adjacent to United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No consular officer of the United States shall grant a certificate for goods, wares, or merchandise shipped from countries adjacent to the United States which have passed a consulate after purchase for shipment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id907372e1-2930-11f1-8918-be39dde81dc6"},"text":"(R.S. § 1717.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id907372e2-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id907372e3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id907372e4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1717 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1873-02-22/ch184/s3"},"text":"act Feb. 22, 1873, ch. 184, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/17/474"},"text":"17 Stat. 474","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1184"},"text":"section 1184 of this title","children":[],"tail":", and prior thereto to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s87"},"text":"section 87 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
