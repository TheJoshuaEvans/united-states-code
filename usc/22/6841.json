{"tag":"section","attrib":{"id":"id90c6ea40-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6841"},"text":null,"children":[{"tag":"num","attrib":{"value":"6841"},"text":"§ 6841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90c6ea41-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6841/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other funds authorized to be appropriated for multilateral or bilateral programs related to HIV/AIDS or economic development, there is authorized to be appropriated to the Secretary of the Treasury $150,000,000 for each of the fiscal years 2001 and 2002 for payment to the Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90c6ea42-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6841/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts authorized to be appropriated by subsection (a) for the fiscal years 2001 and 2002, $50,000,000 are authorized to be available each such fiscal year only for programs that benefit orphans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90c6ea43-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/264/tI/s141"},"text":"Pub. L. 106–264, title I, § 141","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-08-19"},"text":"Aug. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/758"},"text":"114 Stat. 758","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
