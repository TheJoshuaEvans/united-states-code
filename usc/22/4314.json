{"tag":"section","attrib":{"id":"id90785481-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4314"},"text":null,"children":[{"tag":"num","attrib":{"value":"4314"},"text":"§ 4314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extraordinary protective services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90785482-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide extraordinary protective services for foreign missions directly, by contract, or through State or local authority to the extent deemed necessary by the Secretary in carrying out this chapter, except that the Secretary may not provide under this section any protective services for which authority exists to provide such services under subsections (a)(7) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3056A"},"text":"section 3056A of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90785483-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of extraordinary circumstances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide funds to a State or local authority for protective services under this section only if the Secretary has determined that a threat of violence, or other circumstances, exists which requires extraordinary security measures which exceed those which local law enforcment ","children":[{"tag":"ref","attrib":{"idref":"fn002301"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002301"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “enforcement”."}],"tail":" agencies can reasonably be expected to take."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90785484-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s139/2"},"text":"Pub. L. 103–236, title I, § 139(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/397"},"text":"108 Stat. 397","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90785485-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds made available for obligation under this section in any fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90785486-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4314/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 20 percent may be obligated for protective services within any single State during that year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90785487-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4314/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 15 percent shall be retained as a reserve for protective services provided directly by the Secretary or for expenditures in local jurisdictions not otherwise covered by an agreement for protective services under this section.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The limitations on funds available for obligation in this subsection shall not apply to unobligated funds during the final quarter of any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90785488-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4314/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of agreement with State or local authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any agreement with a State or local authority for the provision of protective services under this section shall be for a period of not to exceed 90 days in any calendar year, but such agreements may be renewed after review by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90785489-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4314/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement for appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contracts may be entered into in carrying out this section only to such extent or in such amounts as are provided in advance in appropriation Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9078548a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4314/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Working capital fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts used to carry out this section shall not be subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4308/h"},"text":"section 4308(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9078548b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title II, § 214, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/93/tI/s126/a"},"text":"Pub. L. 99–93, title I, § 126(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/417"},"text":"99 Stat. 417","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s139/2"},"text":"Pub. L. 103–236, title I, § 139(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/397"},"text":"108 Stat. 397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tVI/s605/d/3"},"text":"Pub. L. 109–177, title VI, § 605(d)(3)","children":[],"tail":", (e)(2)(C), "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/255"},"text":"120 Stat. 255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9078548c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9078548d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id9078548e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s605/e/2/C"},"text":"Pub. L. 109–177, § 605(e)(2)(C)","children":[],"tail":", substituted “subsections (a)(7) and (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3056A"},"text":"section 3056A of title 18","children":[],"tail":"” for “sections 202(7) and 208 of title 3”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/s605/d/3"},"text":"Pub. L. 109–177, § 605(d)(3)","children":[],"tail":", which directed amendment of section 214(a) of the State Department Basic Authorities Act by substituting “section 3056A(a)(7) and (d) of title 18” for “sections 202(8) and 208 of title 3”, was not executed because this section, which is section 214 of the State Department Basic Authorities Act of 1956, did not contain the words “sections 202(8) and 208 of title 3” and because of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/s605/e/2/C"},"text":"Pub. L. 109–177, § 605(e)(2)(C)","children":[],"tail":". See note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":" struck out subsec. (c) which read as follows: “Funds may be obligated under this section only after regulations to implement this section have been issued by the Secretary after consultation with appropriate committees of the Congress.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9078548f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id90785490-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/tI/s126/e"},"text":"Pub. L. 99–93, title I, § 126(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/418"},"text":"99 Stat. 418","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/93/tI/s126/e"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4304"},"text":"section 4304 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s208"},"text":"section 208 of Title 3","children":[],"tail":", The President] shall take effect on "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"October 1, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
