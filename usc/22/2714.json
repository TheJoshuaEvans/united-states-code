{"tag":"section","attrib":{"id":"id8ffc472a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714"},"text":null,"children":[{"tag":"num","attrib":{"value":"2714"},"text":"§ 2714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of passports to certain convicted drug traffickers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ffc472b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligibility for passport","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffc472c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A passport may not be issued to an individual who is convicted of an offense described in subsection (b) during the period described in subsection (c) if the individual used a passport or otherwise crossed an international border in committing the offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc472d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Passport revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall revoke a passport previously issued to an individual who is ineligible to receive a passport under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc472e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug law offenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffc472f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Felonies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) applies with respect to any individual convicted of a Federal drug offense, or a State drug offense, if the offense is a felony.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc4730-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain misdemeanors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) also applies with respect to an individual convicted of a Federal drug offense, or a State drug offense, if the offense is ","children":[{"tag":"ref","attrib":{"idref":"fn002204"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002204"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “a”."}],"tail":" misdemeanor, but only if the Secretary of State determines that subsection (a) should apply with respect to that individual on account of that offense. This paragraph does not apply to an individual’s first conviction for a misdemeanor which involves only possession of a controlled substance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc4731-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of ineligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) applies during the period that the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffc4732-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is imprisoned, or is legally required to be imprisoned, as the result of the conviction for the offense described in subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc4733-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is on parole or other supervised release after having been imprisoned as the result of that conviction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc4734-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency and humanitarian exceptions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), the Secretary of State may issue a passport, in emergency circumstances or for humanitarian reasons, to an individual with respect to whom that subsection applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffc4735-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffc4736-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “controlled substance” has the same meaning as is provided in section 102 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc4737-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “Federal drug offense” means a violation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8ffc4738-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"21 U.S.C. 801","children":[],"tail":" et seq.) or the Controlled Substances Import and Export Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s951"},"text":"21 U.S.C. 951","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc4739-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal law involving controlled substances; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8ffc473a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter II of chapter 53 of title 31 (commonly referred to as the “Bank Secrecy Act”), or section 1956 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1957"},"text":"section 1957 of title 18","children":[],"tail":" (commonly referred to as the “Money Laundering Act”), if the Secretary of State determines that the violation is related to illicit production of or trafficking in a controlled substance;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc473b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “felony” means a criminal offense punishable by death or imprisonment for more than one year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc473c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “imprisoned” means an individual is confined in or otherwise restricted to a jail-type institution, a half-way house, a treatment facility, or another institution, on a full or part-time basis, pursuant to the sentence imposed as the result of a conviction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc473d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “misdemeanor” means a criminal offense other than a felony;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc473e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State drug offense” means a violation of State law involving the manufacture, distribution, or possession of a controlled substance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffc473f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2714/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State law” means the law of a State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, or a territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ffc4740-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 42, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIV/s4603/2"},"text":"Pub. L. 100–690, title IV, § 4603(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4287"},"text":"102 Stat. 4287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ffc4741-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ffc4742-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8ffc4743-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Controlled Substances Act, referred to in subsec. (e)(2)(A), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1242"},"text":"84 Stat. 1242","children":[],"tail":", which is classified principally to subchapter I (§ 801 et seq.) of chapter 13 of Title 21, Food and Drugs. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Controlled Substances Import and Export Act, referred to in subsec. (e)(2)(A), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1285"},"text":"84 Stat. 1285","children":[],"tail":", which is classified principally to subchapter II (§ 951 et seq.) of chapter 13 of Title 21. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s951"},"text":"section 951 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id8ffc4744-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 42 of act ","children":[{"tag":"date","attrib":{"date":"1956-08-01"},"text":"Aug. 1, 1956","children":[],"tail":", was renumbered section 43 by "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/s4603/1"},"text":"section 4603(1) of Pub. L. 100–690","children":[],"tail":", and subsequently renumbered, and set out as a Short Title of 1956 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s111/1"},"text":"Pub. L. 102–138, title I, § 111(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/654"},"text":"105 Stat. 654","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
