{"tag":"section","attrib":{"id":"id90272768-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2799d"},"text":"§ 2799d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90272769-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “CFE Treaty” means the Treaty on Conventional Armed Forces in Europe (signed at Paris, ","children":[{"tag":"date","attrib":{"date":"1990-11-19"},"text":"November 19, 1990","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9027276a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “conventional armaments and equipment limited by the CFE Treaty” has the same meaning as the term “conventional armaments and equipment limited by the Treaty” does under paragraph 1(J) of article II of the CFE Treaty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9027276b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “NATO” means the North Atlantic Treaty Organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9027276c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “NATO/CFE country” means a member country of NATO that is a party to the CFE Treaty and is listed in paragraph 1(A) of article II of the CFE Treaty within the group of States Parties that signed or acceded to the Treaty of Brussels of 1948 or the Treaty of Washington of 1949 (the North Atlantic Treaty); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9027276d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2799d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “country of the Eastern Group of States Parties” means a country that is listed in paragraph 1(A) of article II of the CFE Treaty within the group of States Parties that signed the Treaty of Warsaw of 1955 or a successor state to such a country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9027276e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", ch. 9, § 95, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/228/s2"},"text":"Pub. L. 102–228, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-12"},"text":"Dec. 12, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1693"},"text":"105 Stat. 1693","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/199/tIV/s402/2"},"text":"Pub. L. 103–199, title IV, § 402(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-17"},"text":"Dec. 17, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2324"},"text":"107 Stat. 2324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9027276f-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90272770-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90272771-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/199"},"text":"Pub. L. 103–199","children":[],"tail":" substituted “country of the Eastern Group of States Parties” for “Warsaw Pact country” and inserted before period at end “or a successor state to such a country”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
