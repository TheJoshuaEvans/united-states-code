{"tag":"section","attrib":{"id":"id8ffeb779-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2715b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2715b"},"text":"§ 2715b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of next of kin; reports of death","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ffeb77a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2715b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever a United States citizen or national dies abroad, a consular officer shall endeavor to notify, or assist the Secretary of State in notifying, the next of kin or legal guardian as soon as possible, except that, in the case of death of any Peace Corps volunteer (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2504/a"},"text":"section 2504(a) of this title","children":[],"tail":"), any member of the Armed Forces, any dependent of such a volunteer or member, or any Department of Defense employee, the consular officer shall assist the Peace Corps or the appropriate military authorities, as the case may be, in making such notifications."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb77b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2715b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports of death or presumptive death","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The consular officer may, for any United States citizen who dies abroad—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ffeb77c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2715b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a finding of death by the appropriate local authorities, issue a report of death or of presumptive death; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ffeb77d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2715b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the absence of a finding of death by the appropriate local authorities, issue a report of presumptive death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ffeb77e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2715b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementing regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State shall prescribe such regulations as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ffeb77f-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-01/ch841"},"text":"Aug. 1, 1956, ch. 841","children":[],"tail":", title I, § 43A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tII/s234/b"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title II, § 234(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–426.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ffeb780-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ffeb781-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8ffeb782-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tII/s234/c"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title II, § 234(c)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–429, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/113/dB/s1000/a/7/dA/tII/s234/c"},"text":"“The repeal and amendment made by this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2715c"},"text":"section 2715c of this title","children":[],"tail":" and repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4195"},"text":"section 4195 of this title","children":[],"tail":"] shall take effect six months after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8ffeb783-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Administrative Assistance in Arrangements Following Death of United States Citizen Abroad","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/426/tI/s121"},"text":"Pub. L. 95–426, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-07"},"text":"Oct. 7, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/970"},"text":"92 Stat. 970","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tV/s505/a/2"},"text":"Pub. L. 97–241, title V, § 505(a)(2)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/299"},"text":"96 Stat. 299","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/241/tV/s505/a/2"},"text":"“The Congress finds that the Department of State should, in the performance of its consular duties, render all reasonable administrative assistance to a United States citizen who is making necessary arrangements following the death of another United States citizen abroad.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
