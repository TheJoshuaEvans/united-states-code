{"tag":"section","attrib":{"id":"id91587c0d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602"},"text":null,"children":[{"tag":"num","attrib":{"value":"10602"},"text":"§ 10602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Foundation for International Conservation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id91587c0e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91587c0f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"December 23, 2024","children":[],"tail":", the Secretary shall establish the United States Foundation for International Conservation, which shall be operated as a charitable, nonprofit corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c10-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Foundation is not an agency or instrumentality of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c11-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-exempt status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall take all necessary and appropriate steps to ensure that the Foundation is an organization described in subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"section 501 of title 26","children":[],"tail":", which exempt the organization from taxation under subsection (a) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c12-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of operations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Foundation shall terminate operations on the date that is 10 years after the date on which the Foundation becomes operational, in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c13-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for winding down the activities of the Foundation that the Board shall submit to the appropriate congressional committees not later than 180 days before such termination date; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c14-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bylaws established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s10603/b/13"},"text":"section 10603(b)(13) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91587c15-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Foundation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91587c16-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide grants for the responsible management of designated priority primarily protected and conserved areas in eligible countries that have a high degree of biodiversity or species and ecosystems of significant ecological value;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c17-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote responsible, long-term management of primarily protected and conserved areas and their contiguous buffer zones;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c18-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to incentivize, leverage, accept, and effectively administer governmental and nongovernmental funds, including donations from the private sector, to increase the availability and predictability of financing for responsible, long-term management of primarily protected and conserved areas in eligible countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c19-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to help close critical gaps in public international conservation efforts in eligible countries by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c1a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing private sector investment, including investments from philanthropic entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c1b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborating with partners providing bilateral and multilateral financing to support enhanced coordination, including public and private funders, partner governments, local protected areas authorities, and private and nongovernmental organization partners;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c1c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to identify and financially support viable projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c1d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote responsible, long-term management of primarily protected and conserved areas and their contiguous buffer zones in eligible countries, including support for the management of terrestrial, coastal, freshwater, and marine protected areas, parks, community conservancies, Indigenous reserves, conservation easements, and biological reserves; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c1e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide effective area-based conservation measures, consistent with best practices and standards for environmental and social safeguards; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c1f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to coordinate with, consult, and otherwise support and assist, governments, private sector entities, local communities, Indigenous Peoples, and other stakeholders in eligible countries in undertaking biodiversity conservation activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c20-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve measurable and enduring biodiversity conservation outcomes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c21-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve local security, governance, food security, and economic opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id91587c22-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan of Action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id91587c23-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after the establishment of the Foundation, the Executive Director shall submit for approval from the Board an initial 3-year Plan of Action to implement the purposes of this chapter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id91587c24-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the priority actions to be undertaken by the Foundation over the proceeding 3-year period, including a timeline for implementation of such priority actions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c25-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" descriptions of the processes and criteria by which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id91587c26-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible countries, in which eligible projects may be selected to receive assistance under this chapter, will be identified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c27-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant proposals for Foundation activities in eligible countries will be developed, evaluated, and selected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id91587c28-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant implementation will be monitored and evaluated;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c29-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projected staffing and budgetary requirements of the Foundation during the proceeding 3-year period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id91587c2a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to maximize commitments from private sector entities to fund the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c2b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director shall submit the initial Plan of Action to the appropriate congressional committees not later than 5 days after the Plan of Action is approved by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id91587c2c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s10602/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Executive Director shall annually update the Plan of Action and submit each such updated plan to the appropriate congressional committees not later that 5 days after the update plan is approved by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id91587c2d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLI/s5102"},"text":"Pub. L. 118–159, div. E, title LI, § 5102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2410"},"text":"138 Stat. 2410","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id91587c2e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id91587c2f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id91587c30-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(1), was in the original “this title” and was translated as reading “this subtitle”, meaning subtitle A (§§ 5101–5109) of title LI of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2410"},"text":"138 Stat. 2410","children":[],"tail":", known as the United States Foundation for International Conservation Act of 2024, which is classified generally to this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
