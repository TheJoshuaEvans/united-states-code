{"tag":"section","attrib":{"id":"id8ebf32a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285s"},"text":null,"children":[{"tag":"num","attrib":{"value":"285s"},"text":"§ 285s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional subscription to shares; authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8ebf32a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Governor of the Bank is authorized to subscribe on behalf of the United States to sixty-seven thousand and five hundred additional shares of the capital stock of the Bank: ","children":[{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That any subscription to additional shares shall be effective only to such extent or in such amounts as are provided in advance in appropriation Acts."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8ebf32a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s285s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to pay for the increase in the United States subscription to the Bank provided for in this section, there are authorized to be appropriated without fiscal year limitation $814,286,250 for payment by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ebf32a7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/369/s22"},"text":"Pub. L. 89–369, § 22","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/118/tV/s501"},"text":"Pub. L. 95–118, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-10-03"},"text":"Oct. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1068"},"text":"91 Stat. 1068","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXIII/s1353"},"text":"Pub. L. 97–35, title XIII, § 1353","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/745"},"text":"95 Stat. 745","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ebf32a8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ebf32a9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ebf32aa-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted “effective only to such extent or in such amounts as are provided in advance in appropriation Acts” for “made only after the amount required for such subscription has been appropriated”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8ebf32ab-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id8ebf32ac-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":nul