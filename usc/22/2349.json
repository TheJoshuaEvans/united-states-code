{"tag":"section","attrib":{"id":"id8f95bc88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349"},"text":null,"children":[{"tag":"num","attrib":{"value":"2349"},"text":"§ 2349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8f95bc89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to construct such air bases in Israel for the Government of Israel as may be agreed upon between the Government of Israel and the Government of the United States to replace the Israeli air bases located at Etzion and Etam on the Sinai peninsula that are to be evacuated by the Government of Israel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8f95bc8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2349/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of such construction, to furnish as a grant to the Government of Israel, on such terms and conditions as the President may determine, defense articles and defense services, which he may acquire from any source, of a value not to exceed the amount appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349a/a"},"text":"section 2349a(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8f95bc8b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", pt. II, § 561, as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/35/s3"},"text":"Pub. L. 96–35, § 3","children":[],"ta