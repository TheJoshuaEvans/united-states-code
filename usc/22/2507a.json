{"tag":"section","attrib":{"id":"id8fcef52e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2507a"},"text":"§ 2507a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault risk-reduction and response training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8fcef52f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the training provided to all volunteers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2507/a"},"text":"section 2507(a) of this title","children":[],"tail":", the President shall develop and implement comprehensive sexual assault risk-reduction and response training that, to the extent practicable, conforms to best practices in the sexual assault field."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef530-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and consultation with experts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the sexual assault risk-reduction and response training under subsection (a), the President shall consult with and incorporate, as appropriate, the recommendations and views of experts in the sexual assault field.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef531-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Once a volunteer has arrived in his or her country of service, the President shall provide the volunteer with training tailored to the country of service that includes cultural training relating to gender relations, risk-reduction strategies, treatment available in such country (including sexual assault forensic exams, post-exposure prophylaxis (PEP) for HIV exposure, screening for sexually transmitted diseases, and pregnancy testing), MedEvac procedures, and information regarding a victim’s right to pursue legal action against a perpetrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef532-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information regarding crimes and risks","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fcef533-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each applicant for enrollment as a volunteer shall be provided, with respect to each country in which the applicant may be invited to serve, with specific, aggregated, and easily accessible information regarding crimes against and risks to volunteers, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fcef534-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an overview of past crimes against volunteers in such country, including statistics regarding unreported crime collected through anonymous surveys;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef535-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current early termination rate of volunteers serving in such country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef536-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health risks prevalent in such country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef537-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and frequency of sexual harassment reported by volunteers serving in such country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef538-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent and types of services provided by the Peace Corps to volunteers serving in such country, including access to medical care, counseling services, and assistance from the Office of Victim Advocacy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef539-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of satisfaction reported by volunteers serving in such country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef53a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Option to timely decline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receiving information ","children":[{"tag":"ref","attrib":{"idref":"fn002169"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002169"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" described in paragraph (1), the applicant shall have the option to change the country of consideration and identify a substitute country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef53b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contact information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall provide each applicant, before the applicant enrolls as a volunteer, with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fcef53c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contact information of the Inspector General of the Peace Corps for purposes of reporting sexual assault mismanagement or any other mismanagement, misconduct, wrongdoing, or violations of law or policy whenever it involves a Peace Corps employee, volunteer, contractor, or outside party that receives funds from the Peace Corps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef53d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clear, written guidelines regarding whom to contact, including the direct telephone number for the designated Sexual Assault Response Liaison (SARL) and the Office of Victim Advocacy and what steps to take in the event of a sexual assault or other crime; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef53e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contact information for a 24-hour sexual assault hotline to be established for the purpose of providing volunteers a mechanism to anonymously—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fcef53f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report sexual assault;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef540-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive crisis counseling in the event of a sexual assault; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef541-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek information about Peace Corps sexual assault reporting and response procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8fcef542-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section and sections 2507b through 2507g of this title:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8fcef543-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personally identifying information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “personally identifying information” means individually identifying information for or about a volunteer who is a victim of sexual assault, including information likely to disclose the location of such victim, including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fcef544-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A first and last name.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef545-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A home or other physical address.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef546-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contact information (including a postal, email, or Internet protocol address, or telephone or facsimile number).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef547-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A social security number.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef548-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information, including date of birth, racial or ethnic background, or religious affiliation, that, in combination with information described in subparagraphs (A) through (D), would serve to identify the victim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef549-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restricted reporting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fcef54a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “restricted reporting” means a system of reporting that allows a volunteer who is sexually assaulted to confidentially disclose the details of his or her assault to specified individuals and receive the services outlined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2507b/c"},"text":"section 2507b(c) of this title","children":[],"tail":" without the dissemination of his or her personally identifying information except as necessary for the provision of such services, and without automatically triggering an official investigative process."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef54b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In cases in which volunteers elect restricted reporting, disclosure of their personally identifying information is authorized to the following persons or organizations when disclosure would be for the following reasons:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8fcef54c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Peace Corps staff or law enforcement when authorized by the victim in writing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fcef54d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Peace Corps staff or law enforcement to prevent or lessen a serious or imminent threat to the health or safety of the victim or another person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fcef54e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" SARLs, Victim’s Advocates, or healthcare providers when required for the provision of victim services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fcef54f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and Federal courts when ordered, or if disclosure is required by Federal or State statute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef550-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of disclosure and privacy protection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In cases in which information is disclosed pursuant to subparagraph (B), the President shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id8fcef551-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make reasonable attempts to provide notice to the volunteer with respect to whom such information is being released; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id8fcef552-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such action as is necessary to protect the privacy and safety of the volunteer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef553-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “sexual assault” means any conduct prescribed by chapter 109A of title 18, whether or not the conduct occurs in the special maritime and territorial jurisdiction of the United States, and includes both assaults committed by offenders who are strangers to the victim and assaults committed by offenders who are known or related by blood or marriage to the victim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8fcef554-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stalking","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “stalking” means engaging in a course of conduct directed at a specific person that would cause a reasonable person to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id8fcef555-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fear for his or her safety or the safety of others; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id8fcef556-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2507a/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suffer substantial emotional distress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8fcef557-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/293/tI/s8A"},"text":"Pub. L. 87–293, title I, § 8A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/57/s2"},"text":"Pub. L. 112–57, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-21"},"text":"Nov. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/736"},"text":"125 Stat. 736","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/256/tIII/s302"},"text":"Pub. L. 115–256, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-09"},"text":"Oct. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3656"},"text":"132 Stat. 3656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8fcef558-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8fcef559-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8fcef55a-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/256/s302/1"},"text":"Pub. L. 115–256, § 302(1)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, text read as follows: “Each applicant for enrollment as a volunteer shall be provided with information regarding crimes against and risks to volunteers in the country in which the applicant has been invited to serve, including an overview of past crimes against volunteers in the country.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/256/s302/2"},"text":"Pub. L. 115–256, § 302(2)","children":[],"tail":", substituted “Victim’s Advocates,” for “victim advocates”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8fcef55b-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8fcef55c-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Offset of Costs and Personnel","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/57/s9"},"text":"Pub. L. 112–57, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-21"},"text":"Nov. 21, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/745"},"text":"125 Stat. 745","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/57/s9"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Notwithstanding any other provision of law, the Direct [probably should be “Director”] of the Peace Corps shall—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate such initiatives, positions, and programs within the Peace Corps (other than within the Office of Inspector General) as the Director deems necessary to ensure any and all costs incurred to carry out the provisions of this Act [see Short Title of 2011 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2501"},"text":"section 2501 of this title","children":[],"tail":"], and the amendments made by this Act, are entirely offset;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure no net increase in personnel are added to carry out the provisions of this Act, with any new full or part time employees or equivalents offset by eliminating an equivalent number of existing staff (other than within the Office of Inspector General);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to Congress not later than 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2011-11-21"},"text":"Nov. 21, 2011","children":[],"tail":"] the actions taken to ensure compliance with paragraphs (1) and (2), including the specific initiatives, positions, and programs within the Peace Corps that have been eliminated to ensure that the costs of carrying out this Act will be offset; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not implement any other provision of this Act (other than paragraphs (1), (2), and (3)) or any amendment made by this Act until the Director has certified that the actions specified in paragraphs (1), (2), and (3) have been completed.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
