{"tag":"section","attrib":{"id":"id9073732b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4220"},"text":null,"children":[{"tag":"num","attrib":{"value":"4220"},"text":"§ 4220.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medium for payment of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All fees collected by diplomatic and consular officers for and in behalf of the United States shall be collected in the coin of the United States, or at its representative value in exchange.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id9073732c-2930-11f1-8918-be39dde81dc6"},"text":"(R.S. § 1746.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9073732d-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id9073732e-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id9073732f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 1746 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1856-08-18/ch127/s30"},"text":"act Aug. 18, 1856, ch. 127, § 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/11/63"},"text":"11 Stat. 63","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1202"},"text":"section 1202 of this title","child