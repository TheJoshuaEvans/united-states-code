{"tag":"section","attrib":{"id":"id90595b34-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4028a"},"text":null,"children":[{"tag":"num","attrib":{"value":"4028a"},"text":"§ 4028a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per diem allowance for newly hired members of the Foreign Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90595b35-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4028a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per diem allowance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90595b36-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4028a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), any newly hired Foreign Service employee who is in initial orientation training, or any other training expected to last less than 6 months in the Washington, D.C. area before transferring to the employee’s first assignment overseas or domestically outside the Washington, D.C. area shall, for the duration of such training, receive a per diem allowance at the levels prescribed under subchapter I of chapter 57 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90595b37-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4028a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on lodging expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A newly hired Foreign Service employee may not receive any lodging expenses under the applicable per diem allowance pursuant to paragraph (1) if that employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id90595b38-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4028a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a permanent residence in the Washington, D.C., area (not including government-supplied housing during such orientation training or other training); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id90595b39-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4028a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not vacate such residence during such orientation training or other training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90595b3a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4028a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90595b3b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4028a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “per diem allowance” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5701"},"text":"section 5701 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90595b3c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s4028a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Washington, D.C., area” means the geographic area within a 50-mile radius of the Washington Monument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90595b3d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXI/s7109"},"text":"Pub. L. 118–159, div. G, title LXXI, § 7109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2525"},"text":"138 Stat. 2525","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90595b3e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90595b3f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90595b40-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of State Authorization Act for Fiscal Year 2025, and also as part of the Servicemember Quality of Life Improvement and National Defense Authorization Act for Fiscal Year 2025, and not as part of the Foreign Service Act of 1980 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
