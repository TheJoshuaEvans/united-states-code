{"tag":"section","attrib":{"id":"id90acab88-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6203"},"text":null,"children":[{"tag":"num","attrib":{"value":"6203"},"text":"§ 6203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the Chief Executive Officer of the United States Agency for Global Media","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90acab89-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued existence within Executive branch","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States Agency for Global Media shall continue to exist within the Executive branch of Government as an entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s104"},"text":"section 104 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90acab8a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Executive Officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90acab8b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of the United States Agency for Global Media shall be a Chief Executive Officer, who shall be appointed by the President, by and with the advice and consent of the Senate. Notwithstanding any other provision of law, until such time as a Chief Executive Officer is appointed and has qualified, the current or acting Chief Executive Officer appointed by the Board may continue to serve and exercise the authorities and powers under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab8c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first Chief Executive Officer appointed pursuant to paragraph (1) shall serve for an initial term of three years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90acab8d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6203/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Chief Executive Officer appointed pursuant to paragraph (1) shall be compensated at the annual rate of basic pay for level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90acab8e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of Director of International Broadcasting Bureau","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective on ","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"December 23, 2016","children":[],"tail":", the position of the Director of the International Broadcasting Bureau shall be terminated, and all of the responsibilities, offices, authorities, and immunities of the Director or the Agency under this chapter or any other Act or authority before such date shall be transferred or available to, assumed by, or overseen by the Chief Executive Officer, as head of the Agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90acab8f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6203/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity from civil liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, all limitations on liability that apply to the Chief Executive Officer shall also apply to members of the boards of directors of RFE/RL, Inc., Radio Free Asia, the Open Technology Fund, the Middle East Broadcasting Networks, or any organization that consolidates such entities when such members are acting in their official capacities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90acab90-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tIII/s304"},"text":"Pub. L. 103–236, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/434"},"text":"108 Stat. 434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIII, §§ 1322, 1323(b), (c), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-777"},"text":"112 Stat. 2681–777","children":[],"tail":", 2681–778; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tV/s502"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title V, §§ 502, 504]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–451; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXII/s1288/1"},"text":"Pub. L. 114–328, div. A, title XII, § 1288(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2548"},"text":"130 Stat. 2548","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII"},"text":"Pub. L. 116–283, div. A, title XII","children":[],"tail":", §§ 1299P(c)(1), 1299Q(e)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4020"},"text":"134 Stat. 4020","children":[],"tail":", 4024.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id90acab91-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id90acab92-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id90acab93-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (b)(1) and (c), was in the original a reference to this Act, and was translated as referring to this title, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236"},"text":"Pub. L. 103–236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/432"},"text":"108 Stat. 432","children":[],"tail":", known as the United States International Broadcasting Act of 1994, which is classified principally to this chapter, to reflect the probable intent of Congress. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6201"},"text":"section 6201 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"December 23, 2016","children":[],"tail":", and such date, referred to in subsec. (c), were in the original “the date of the enactment of this section” and “such date of enactment”, respectively, and were translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", which amended this section generally, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id90acab94-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1299Q/e/1"},"text":"Pub. L. 116–283, div. A, title XII, § 1299Q(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4024"},"text":"134 Stat. 4024","children":[],"tail":", which amended this section, was itself amended by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tXIII/s1301"},"text":"Pub. L. 116–260, div. O, title XIII, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2158"},"text":"134 Stat. 2158","children":[],"tail":", to make it effective 90 days after "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":". However, the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" could not be executed because it was enacted before the provision from "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" that it amended."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id90acab95-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/e/1/A"},"text":"Pub. L. 116–283, § 1299Q(e)(1)(A)","children":[],"tail":", substituted “United States Agency for Global Media” for “Broadcasting Board of Governors” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/e/1/B"},"text":"Pub. L. 116–283, § 1299Q(e)(1)(B)","children":[],"tail":", substituted “United States Agency for Global Media” for “Broadcasting Board of Governors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/e/1/C"},"text":"Pub. L. 116–283, § 1299Q(e)(1)(C)","children":[],"tail":", substituted “United States Agency for Global Media” for “Broadcasting Board of Governors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299Q/e/1/D"},"text":"Pub. L. 116–283, § 1299Q(e)(1)(D)","children":[],"tail":", substituted “Agency” for “Board” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1299P/c/1"},"text":"Pub. L. 116–283, § 1299P(c)(1)","children":[],"tail":", inserted “the Open Technology Fund,” before “the Middle East Broadcasting Networks”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" amended section generally. Prior to amendment, section related to the continued existence within the Executive branch, retention of existing Board members, Inspector General authorities, composition, term, selection, compensation, decisions, and immunity from civil liability of the Broadcasting Board of Governors."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/dA/tV/s502/2"},"text":"Pub. L. 106–113, § 1000(a)(7) [div. A, title V, § 502(2)]","children":[],"tail":", which directed amendment of par. (2) by inserting “, subject to the advice and consent of the Senate” at end, was executed by making the insertion before period at end, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/dA/tV/s502/1"},"text":"Pub. L. 106–113, § 1000(a)(7) [div. A, title V, § 502(1)]","children":[],"tail":", substituted “appoint” for “designate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/7/dA/tV/s504"},"text":"Pub. L. 106–113, § 1000(a)(7) [div. A, title V, § 504]","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1322"},"text":"Pub. L. 105–277, § 1322","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “There is hereby established within the United States Information Agency a Broadcasting Board of Governors (hereafter in this chapter referred to as the ‘Board’).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1323/b"},"text":"Pub. L. 105–277, § 1323(b)","children":[],"tail":", substituted “Secretary of State” for “Director of the United States Information Agency” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1323/b"},"text":"Pub. L. 105–277, § 1323(b)","children":[],"tail":", (c), in first sentence, substituted “Secretary of State” for “Director of the United States Information Agency”, and in last sentence, substituted “no Secretary of State” for “no Director of the United States Information Agency” and “Acting Secretary of State” for “acting Director of the agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1323/b"},"text":"Pub. L. 105–277, § 1323(b)","children":[],"tail":", substituted “Secretary of State” for “Director of the United States Information Agency”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id90acab96-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90acab97-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXII/s1299P/e"},"text":"Pub. L. 116–283, div. A, title XII, § 1299P(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4020"},"text":"134 Stat. 4020","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tXII/s1299P/e"},"text":"“Section 309A of the United States International Broadcasting Act of 1994 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s6208a"},"text":"22 U.S.C. 6208a","children":[],"tail":"] (as added by subsection (b) of this section) and subsections (c) [amending this section and sections 6204 and 6209 of this title] and (d) [not classified to the Code] of this section shall take effect and apply beginning on "},{"tag":"date","attrib":{"date":"2021-07-01"},"text":"July 1, 2021","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id90acab98-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1999-10-01"},"text":"Oct. 1, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s1301"},"text":"section 1301 of Pub. L. 105–277","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s6531"},"text":"section 6531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90acab99-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References to Broadcasting Board of Governors","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dG/tI"},"text":"Pub. L. 116–94, div. G, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2822"},"text":"133 Stat. 2822","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/94/dG/tI"},"text":"“That any reference to the ‘Broadcasting Board of Governors’ or ‘BBG’, including in any account providing amounts to the Broadcasting Board of Governors, in any Act making appropriations for the Department of State, foreign operations, and related programs enacted before, on, or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"] shall for this fiscal year, and any fiscal year thereafter, be construed to mean the ‘United States Agency for Global Media’ or ‘USAGM’, respectively.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
