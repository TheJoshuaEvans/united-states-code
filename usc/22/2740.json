{"tag":"section","attrib":{"id":"id9005e3f7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2740"},"text":null,"children":[{"tag":"num","attrib":{"value":"2740"},"text":"§ 2740.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Career intermission program adjustment to enhance retention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id9005e3f8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2740/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to extend Federal Employee Health Benefit coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and Administrator are authorized to offer employees the option of extending Federal Employee Health Benefit coverage during pre-approved leave without pay for up to 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9005e3f9-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2740/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for premium payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an employee elects to continue coverage pursuant to subsection (a) for longer than 365 days, the employee shall be responsible for 100 percent of the premium (employee share and government share) during such longer period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9005e3fa-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dG/tLXXI/s7106"},"text":"Pub. L. 118–159, div. G, title LXXI, § 7106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2524"},"text":"138 Stat. 2524","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id9005e3fb-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9005e3fc-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"id9005e3fd-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definitions of “Secretary” and “Administrator” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s7002"},"text":"section 7002 of Pub. L. 118–159","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651"},"text":"section 2651 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
