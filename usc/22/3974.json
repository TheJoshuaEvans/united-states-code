{"tag":"section","attrib":{"id":"id90547947-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3974"},"text":null,"children":[{"tag":"num","attrib":{"value":"3974"},"text":"§ 3974.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Border equalization pay adjustment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90547948-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3974/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employee who regularly commutes from the employee’s place of residence in the continental United States to an official duty station in Canada or Mexico shall receive a border equalization pay adjustment equal to the amount of comparability payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5304"},"text":"section 5304 of title 5","children":[],"tail":" that the employee would receive if the employee were assigned to an official duty station within the United States locality pay area closest to the employee’s official duty station."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90547949-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3974/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “employee” means a person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id9054794a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3974/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an “employee” as defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id9054794b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3974/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed by the Department of State, the United States Agency for International Development, or the International Joint Commission of the United States and Canada (established under Article VII of the treaty signed ","children":[{"tag":"date","attrib":{"date":"1909-01-11"},"text":"January 11, 1909","children":[],"tail":") ("},{"tag":"ref","attrib":{"href":"/us/stat/36/2448"},"text":"36 Stat. 2448","children":[],"tail":"), except that the term shall not include members of the Service (as specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3903"},"text":"section 3903 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9054794c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3974/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as basic pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An equalization pay adjustment paid under this section shall be considered to be part of basic pay for the same purposes for which comparability payments are considered to be part of basic pay under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5304"},"text":"section 5304 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id9054794d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s3974/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The heads of the agencies referred to in subsection (b)(2) may prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id9054794e-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tI/s414"},"text":"Pub. L. 96–465, title I, § 414","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tIII/s333/a"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title III, § 333(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–439.)"}],"tail":"\n"}],"tail":null}
