{"tag":"section","attrib":{"id":"id8f2a77e1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s1979"},"text":null,"children":[{"tag":"num","attrib":{"value":"1979"},"text":"§ 1979.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishermen’s Protective Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is created a Fishermen’s Protective Fund which shall be used by the Secretary of State to reimburse owners of vessels for amounts determined and certified by him under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1973"},"text":"section 1973 of this title","children":[],"tail":". The amount of any claim or portion thereof collected by the Secretary of State from any foreign country pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1975/a"},"text":"section 1975(a) of this title","children":[],"tail":" shall be deposited in the fund and shall be available for the purpose of reimbursing vessel owners under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1973"},"text":"section 1973 of this title","children":[],"tail":"; except that if a transfer to the fund was made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1975/b/1"},"text":"section 1975(b)(1) of this title","children":[],"tail":" with respect to any such claim, an amount from the fund equal to the amount so collected shall be covered into the Treasury as miscellaneous receipts. There is authorized to be appropriated to the fund (1) the sum of $3,000,000 to provide initial capital, and (2) such additional sums as may be necessary from time to time to supplement the fund in order to meet the requirements of the fund."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f2a77e2-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-27/ch1018/s9"},"text":"Aug. 27, 1954, ch. 1018, § 9","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/569/s5"},"text":"Pub. L. 92–569, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-26"},"text":"Oct. 26, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1183"},"text":"86 Stat. 1183","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/364/tIII/s302/c"},"text":"Pub. L. 98–364, title III, § 302(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/444"},"text":"98 Stat. 444","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f2a77e3-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8f2a77e4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8f2a77e5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364"},"text":"Pub. L. 98–364","children":[],"tail":" substituted “Secretary of State” for “Secretary of the Treasury” and “determined and certified by him” for “certified to him by the Secretary of State”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f2a77e6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id8f2a77e7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to seizure of vessels of the United States occurring on or after ","children":[{"tag":"date","attrib":{"date":"1972-10-26"},"text":"Oct. 26, 1972","children":[],"tail":", except that reimbursements under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1973"},"text":"section 1973 of this title","children":[],"tail":" may be made from the fund established by this section with respect to seizure of vessels occurring after "},{"tag":"date","attrib":{"date":"1970-12-31"},"text":"Dec. 31, 1970","children":[],"tail":" and before "},{"tag":"date","attrib":{"date":"1972-10-26"},"text":"Oct. 26, 1972","children":[],"tail":", if no reimbursement was made before "},{"tag":"date","attrib":{"date":"1972-10-26"},"text":"Oct. 26, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/569/s6"},"text":"section 6 of Pub. L. 92–569","children":[],"tail":", set out as an Effective Date of 1972 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1972"},"text":"section 1972 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
