{"tag":"section","attrib":{"id":"id8ec17d5b-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286e–1e"},"text":null,"children":[{"tag":"num","attrib":{"value":"286e–1e"},"text":"§ 286e–1e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equivalent increase in quota of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Governor of the Fund is authorized to consent to an increase in the quota of the United States in the Fund equivalent to 1,705 million Special Drawing Rights.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ec17d5c-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s25"},"text":"July 31, 1945, ch. 339, § 25","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/564/s1"},"text":"Pub. L. 94–564, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2660"},"text":"90 Stat. 2660","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
