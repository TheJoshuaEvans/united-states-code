{"tag":"section","attrib":{"id":"id908db1be-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5425"},"text":null,"children":[{"tag":"num","attrib":{"value":"5425"},"text":"§ 5425.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Polish currency generated by agricultural assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id908db1bf-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5425/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional assistance for Poland","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A portion of the agricultural commodities described in subsection (c) may be made available and sold or bartered in Poland to generate local currencies to be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id908db1c0-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5425/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to complement the assistance for Poland authorized by sections 5413(b), 5421, and 5423 of this title, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id908db1c1-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5425/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the activities of the joint commission established pursuant to section 2226 of the American Aid to Poland Act of 1988 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431"},"text":"7 U.S.C. 1431","children":[],"tail":" note),"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431/b/7"},"text":"section 1431(b)(7) of title 7","children":[],"tail":" or any other provision of law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db1c2-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5425/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emphasis on agricultural development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The uses of local currencies generated under this section should emphasize the development of agricultural infrastructure, agriculture-related training, and other aspects of agricultural development in Poland.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db1c3-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5425/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodities subject to requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) applies with respect to agricultural commodities made available for Poland for fiscal years 1990, 1991, and 1992 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431/b"},"text":"section 1431(b) of title 7","children":[],"tail":", the Food for Peace Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"7 U.S.C. 1691","children":[],"tail":" and following), and section 1736"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of title 7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id908db1c4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s5425/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other uses not precluded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The uses of agricultural commodities and local currencies specified in subsection (a) are in addition to other uses authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id908db1c5-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/179/tII/s205"},"text":"Pub. L. 101–179, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-28"},"text":"Nov. 28, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1310"},"text":"103 Stat. 1310","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/b/1/A"},"text":"Pub. L. 110–246, title III, § 3001(b)(1)(A)","children":[],"tail":", (2)(U), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1820"},"text":"122 Stat. 1820","children":[],"tail":", 1821.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id908db1c6-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id908db1c7-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id908db1c8-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2226 of the American Aid to Poland Act of 1988, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/s2226"},"text":"section 2226 of Pub. L. 100–418","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431"},"text":"section 1431 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Food for Peace Act, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"act July 10, 1954, ch. 469","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/454"},"text":"68 Stat. 454","children":[],"tail":", which is classified generally to chapter 41 (§ 1691 et seq.) of Title 7. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id908db1c9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" substituted “Food for Peace Act” for “Agricultural Trade Development and Assistance Act of 1954”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id908db1ca-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id908db1cb-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"r