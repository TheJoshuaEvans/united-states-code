{"tag":"section","attrib":{"id":"id8ea9af6c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s275a"},"text":null,"children":[{"tag":"num","attrib":{"value":"275a"},"text":"§ 275a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent International Commission of the Congresses of Navigation; authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not to exceed $45,000 annually of the funds appropriated for rivers and harbors shall be available for the support and maintenance of the Permanent International Commission of the Congresses of Navigation and for the payment in amounts approved by the Chief of Engineers of the expenses of the properly accredited delegates of the United States to the meetings of the congresses and of the Commission.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8ea9af6d-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-30/ch771"},"text":"June 30, 1948, ch. 771","children":[],"tail":", title I, § 107, "},{"tag":"ref","attrib":{"href":"/us/stat/62/1174"},"text":"62 Stat. 1174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/298/tIII/s306"},"text":"Pub. L. 89–298, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-27"},"text":"Oct. 27, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1094"},"text":"79 Stat. 1094","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/251/tI/s93"},"text":"Pub. L. 93–251, title I, § 93","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-03-07"},"text":"Mar. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/39"},"text":"88 Stat. 39","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8ea9af6e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8ea9af6f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8ea9af70-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/251"},"text":"Pub. L. 93–251","children":[],"tail":" substituted “$45,000” for “$22,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/298"},"text":"Pub. L. 89–298","children":[],"tail":" substituted “$22,000” for “$5,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
