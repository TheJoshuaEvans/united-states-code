{"tag":"section","attrib":{"id":"id8e91e146-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262k–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"262k–1"},"text":"§ 262k–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency of budgets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id8e91e147-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262k–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning three years after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", the Secretary of the Treasury shall instruct the United States Executive Director of each international financial institution to use the voice and vote of the United States to oppose any loan or other utilization of the funds of their respective institution, other than to address basic human needs, for the government of any country which the Secretary of the Treasury determines—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id8e91e148-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262k–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not have in place a functioning system for reporting to civilian authorities audits of receipts and expenditures that fund activities of the armed forces and security forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8e91e149-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262k–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not provided to the institution information about the audit process requested by the institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id8e91e14a-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s262k–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “International financial institution” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “international financial institution” shall include the institutions identified in section 532(b) of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8e91e14b-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/c/tV/s576"},"text":"Pub. L. 104–208, div. A, title I, § 101(c) [title V, § 576]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-121"},"text":"110 Stat. 3009–121","children":[],"tail":", 3009–168; "},{"tag":"ref","attrib":{"href":"/us/pl/105/118/tV/s572"},"text":"Pub. L. 105–118, title V, § 572","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-26"},"text":"Nov. 26, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2430"},"text":"111 Stat. 2430","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8e91e14c-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8e91e14d-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8e91e14e-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 532(b) of this Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s532/b"},"text":"section 532(b) of Pub. L. 104–208","children":[],"tail":", div. A, title I, § 101(c) [title V], "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-121"},"text":"110 Stat. 3009–121","children":[],"tail":", 3009–152, which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id8e91e14f-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/118/s572/a"},"text":"Pub. L. 105–118, § 572(a)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “does not have in place a functioning system for a civilian audit of all receipts and expenditures that fund activities of the armed forces and security forces;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/118/s572/b"},"text":"Pub. L. 105–118, § 572(b)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “has not provided a summary of a current audit to the institution.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
