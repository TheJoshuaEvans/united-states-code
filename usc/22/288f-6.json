{"tag":"section","attrib":{"id":"id8ed971bd-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s288f–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"288f–6"},"text":"§ 288f–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global Fund to Fight AIDS, Tuberculosis and Malaria; extension of privileges, exemptions, and immunities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The provisions of this subchapter may be extended to the Global Fund to Fight AIDS, Tuberculosis and Malaria in the same manner, to the same extent, and subject to the same conditions, as they may be extended to a public international organization in which the United States participates pursuant to any treaty or under the authority of any Act of Congress authorizing such participation or making an appropriation for such participation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8edbbbae-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-12-29/ch652"},"text":"Dec. 29, 1945, ch. 652","children":[],"tail":", title I, § 16, as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dD/tV/s593"},"text":"Pub. L. 108–199, div. D, title V, § 593","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/208"},"text":"118 Stat. 208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8edbbbaf-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id8edbbbb0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id8edbbbb1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-12-29/ch652"},"text":"act Dec. 29, 1945, ch. 652","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/669"},"text":"59 Stat. 669","children":[],"tail":", which is classified principally to this subchapter. For complete classification of title I to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s288"},"text":"section 288 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
