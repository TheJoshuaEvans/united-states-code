{"tag":"section","attrib":{"id":"id90b6488c-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6416"},"text":null,"children":[{"tag":"num","attrib":{"value":"6416"},"text":"§ 6416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equal access to United States missions abroad for conducting religious activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id90b6488d-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6416/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to this section, the Secretary of State shall permit, on terms no less favorable than that accorded other nongovernmental activities unrelated to the conduct of the diplomatic mission, access to the premises of any United States diplomatic mission or consular post by any United States citizen seeking to conduct an activity for religious purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b6488e-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6416/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing and location","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall make reasonable accommodations with respect to the timing and location of such access in light of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id90b6488f-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6416/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of United States citizens requesting the access (including any particular religious concerns regarding the time of day, date, or physical setting for services);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b64890-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6416/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conflicts with official activities and other nonofficial United States citizen requests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b64891-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6416/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of openly conducted, organized religious services outside the premises of the mission or post;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b64892-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6416/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" availability of space and resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id90b64893-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6416/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary security precautions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id90b64894-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s6416/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary access for foreign nationals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of State may permit access to the premises of a United States diplomatic mission or consular post to foreign nationals for the purpose of attending or participating in religious activities conducted pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id90b8b895-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/292/tI/s107"},"text":"Pub. L. 105–292, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-27"},"text":"Oct. 27, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2796"},"text":"112 Stat. 2796","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
