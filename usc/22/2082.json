{"tag":"section","attrib":{"id":"id8f2f32e5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s2082"},"text":null,"children":[{"tag":"num","attrib":{"value":"2082"},"text":"§ 2082.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation in Interama by States and foreign countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is authorized, by proclamation or in such other manner as he may deem proper, to invite the several States of the United States and foreign countries to take part in Interama, except that no Communist de facto government holding any people in subjugation shall be invited to participate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id8f2f32e6-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/355/s2/a"},"text":"Pub. L. 89–355, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-02-19"},"text":"Feb. 19, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/6"},"text":"80 Stat. 6","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id8f2f32e7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id8f2f32e8-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id8f2f32e9-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congress by ","children":[{"tag":"date","attrib":{"date":"1966-05-15"},"text":"May 15, 1966","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/89/355/s2/b"},"text":"Pub. L. 89–355, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-02-19"},"text":"Feb. 19, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/6"},"text":"80 Stat. 6","children":[],"tail":", provided that the department or agency, designated by the President pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2081"},"text":"section 2081 of this title","children":[],"tail":", submit a report to the Senate Committees on Foreign Relations and Appropriations and the Speaker of the House, on the proposed nature, extent and cost of United States participation in Interama and of the extent of participation of foreign countries and private industries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
