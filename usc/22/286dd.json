{"tag":"section","attrib":{"id":"id8ec8a8c6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"286dd"},"text":"§ 286dd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund bailouts of banks; rescheduling of debt","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury shall instruct the United States Executive Director of the Fund—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id8ec8a8c7-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286dd/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to oppose and vote against any Fund drawing by a member country where, in his judgment, the Fund resources would be drawn principally for the purpose of repaying loans which have been imprudently made by banking institutions to the member country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id8ec8a8c8-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s286dd/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to work to insure that the Fund encourages borrowing countries and banking institutions to negotiate, where appropriate, a rescheduling of debt which is consistent with safe and sound banking practices and the country’s ability to pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id8ec8a8c9-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-07-31/ch339/s46"},"text":"July 31, 1945, ch. 339, § 46","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/98/181/tI"},"text":"Pub. L. 98–181, title I","children":[],"tail":" [title VIII, § 807], "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1273"},"text":"97 Stat. 1273","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
