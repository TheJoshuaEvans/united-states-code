{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/132"},"text":"Pub. L. 107–132","children":[],"tail":" inserted at end “The institution shall be designated the ‘George P. Shultz National Foreign Affairs Training Center’ ”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d)(4) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s2205/a/3"},"text":"Pub. L. 105–277, § 2205(a)(3)","children":[],"tail":". See 1998 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s2205/a/3/B"},"text":"Pub. L. 105–277, § 2205(a)(3)(B)","children":[],"tail":", which directed the redesignation of subsec. (g) as (d)(4), effective "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s2205/a/1/A"},"text":"Pub. L. 105–277, § 2205(a)(1)(A)","children":[],"tail":", redesignated subsec. (d)(4) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s2205/a/3/A"},"text":"Pub. L. 105–277, § 2205(a)(3)(A)","children":[],"tail":", which directed the striking out of subsecs. (e) and (f), effective "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s2205/a/1/B"},"text":"Pub. L. 105–277, § 2205(a)(1)(B)","children":[],"tail":", added subsecs. (e) and (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s2205/a/3/B"},"text":"Pub. L. 105–277, § 2205(a)(3)(B)","children":[],"tail":", which directed the redesignation of subsec. (g) as (d)(4), effective "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/228"},"text":"Pub. L. 107–228","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s2205/a/1/A"},"text":"Pub. L. 105–277, § 2205(a)(1)(A)","children":[],"tail":", redesignated subsec. (d)(4) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/415"},"text":"Pub. L. 103–415","children":[],"tail":" made technical amendment relating to style of section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/s126/2/A"},"text":"Pub. L. 103–236, § 126(2)(A)","children":[],"tail":", substituted “Institution for training” for “Foreign Service Institute” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/s126/2/B"},"text":"Pub. L. 103–236, § 126(2)(B)","children":[],"tail":", inserted heading, substituted “an institution or center for training (hereinafter in this subchapter referred to as the ‘institution’)” for “the Foreign Service Institute (hereinafter in this subchapter referred to as the ‘Institute’),”, and substituted “institution shall” for “Institute shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/s126/3"},"text":"Pub. L. 103–236, § 126(3)","children":[],"tail":", substituted “institution” for “Institute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/s126/2/C"},"text":"Pub. L. 103–236, § 126(2)(C)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/164"},"text":"Pub. L. 98–164","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id9056eaa0-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id9056eaa1-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/132/s1/b"},"text":"Pub. L. 107–132, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-16"},"text":"Jan. 16, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2412"},"text":"115 Stat. 2412","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/132/s1/b"},"text":"“Any reference in any provision of law to the National Foreign Affairs Training Center or the Foreign Service Institute shall be considered to be a reference to the ‘George P. Shultz National Foreign Affairs Training Center’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id9056eaa2-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXII, § 2205(a)(2), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-809"},"text":"112 Stat. 2681–809","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dG"},"text":"“The amendments made by paragraph (1) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXII, § 2205(a)(3), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-809"},"text":"112 Stat. 2681–809","children":[],"tail":", which provided that the amendment made by section 2205(a)(3) was effective "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tIII/s318/2"},"text":"Pub. L. 107–228, div. A, title III, § 318(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1379"},"text":"116 Stat. 1379","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9056eaa3-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Designation of Foreign Language Resources Coordinator","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/236/tI/s192"},"text":"Pub. L. 103–236, title I, § 192","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-04-30"},"text":"Apr. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/419"},"text":"108 Stat. 419","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/236/tI/s192"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of the Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State, by virtue of the Secretary’s overall responsibility under section 701(a) of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4011/a"},"text":"22 U.S.C. 4011(a)","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s4021/a"},"text":"22 U.S.C. 4021(a)","children":[],"tail":"]) for training and instruction in the field of foreign relations to meet the needs of all Federal agencies, should take the lead in this interagency effort; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to promote efficiency and quality in the training provided by the Secretary of State and other Federal agencies, the Secretary should call upon other agencies to share in the joint management and coordination of Federal foreign language resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Language Resources Coordinator.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of State should appoint a Foreign Language Resources Coordinator (in this subsection referred to as the ‘Coordinator’) who shall be responsible—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for coordinating the efforts of the appropriate agencies of Government—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen mechanisms for sharing of foreign language resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify Federal foreign language resource requirements in the areas of diplomacy, military preparedness, international security, and other foreign policy objectives; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for making recommendations to the Secretary of State as to which Federal foreign language assets, if any, should be made available to the private sector in support of national global economic competitiveness goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All appropriate United States Government agencies maintaining and utilizing Federal foreign language training and related resources shall cooperate fully with any Coordinator.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id9056eaa4-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Foreign Service Institute Facilities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/tI/s123"},"text":"Pub. L. 99–93, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-16"},"text":"Aug. 16, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/413"},"text":"99 Stat. 413","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/204/tI/s135"},"text":"Pub. L. 100–204, title I, § 135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1345"},"text":"101 Stat. 1345","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s124"},"text":"Pub. L. 102–138, title I, § 124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/659"},"text":"105 Stat. 659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXII, § 2219(a)(3), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-817"},"text":"112 Stat. 2681–817","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dG"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this section is to promote comprehensive training to meet the foreign relations and national security objectives of the United States and to provide facilities designed for that purpose to assure cost efficient training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction of Training Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services may construct a consolidated training facility for the Foreign Service Institute on a site made available by the Secretary of State or acquired by the Administrator of General Services. Such site shall be located outside the District of Columbia but within reasonable proximity to the Department of State. The Administrator of General Services may carry out this subsection only to the extent that funds are provided in advance in appropriation Acts to the Department of State and are transferred to the Administrator of General Services for carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of amounts authorized to be appropriated to the Department of State for fiscal years 1986 and 1987 for ‘Administration of Foreign Affairs’ by section 101(1) [","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/93/s101/1"},"text":"Pub. L. 99–93, § 101(1)","children":[],"tail":", which is not classified to the Code], a total of not to exceed $11,000,000 may be transferred by the Secretary of State to the Administrator of General Services for carrying out feasibility studies, site acquisition, and design, architectural, and engineering planning under subsection (b) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of the amounts authorized to be appropriated to the Department of State for fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":", the Secretary of State may transfer a total not to exceed $11,000,000 for ‘Administration of Foreign Affairs’ to the Administrator of General Services for carrying out feasibility studies, site preparation, and design, architectural, and engineering planning under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Of amounts authorized to be appropriated to the Department of State for fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":", for ‘Administration of Foreign Affairs’, a total not to exceed $70,000,000 may be transferred by the Secretary of State to the Administrator of General Services for carrying out construction under subsection (b) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Funds may not be obligated for construction of a facility under this section before the end of the period of 30 days of continuous session of Congress beginning on the date on which plans and estimates developed to carry out this section are submitted to the Committees on Foreign Affairs and Public Works and Transportation of the House of Representatives and the Committees on Foreign Relations and Environment and Public Works of the Senate. In determining days of continuous session of Congress for purposes of this paragraph—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuity of session is broken only by an adjournment of Congress sine die; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the days on which either House is not in session because of an adjournment of more than 3 days to a day certain are excluded in the determination.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If both Houses of Congress are not in session on the day any plans and estimates are submitted to such committees, such submittal shall be deemed to have been submitted on the first succeeding day on which both Houses are in session. If all such committees do not receive a submittal on the same day, such period shall not begin until the date on which all such committees have received it.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction and Custody","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The facility constructed under this section and the site of such facility shall be under jurisdiction and in the custody of the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation, Maintenance, Security, Alteration, and Repair","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of General Services shall delegate, in accordance with section 205 of the Federal Property and Administrative Services Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s486"},"text":"40 U.S.C. 486","children":[],"tail":") [see "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s121"},"text":"40 U.S.C. 121","children":[],"tail":" and Historical and Revision notes thereunder] and section 15 of the Public Buildings Act of 1959 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s614"},"text":"40 U.S.C. 614","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3315"},"text":"40 U.S.C. 3315","children":[],"tail":"], to the Secretary of State responsibility for the operation, maintenance, and security of and alterations and repairs to the facility constructed pursuant to this section, provided the facility is used by the Secretary for the purposes authorized by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"status":"repealed"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“[(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXII, § 2219(a)(3), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-817"},"text":"112 Stat. 2681–817","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption From Payment of Charges","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the Department of State shall be exempt from the charges required by section 210(j) of the Federal Property and Administrative Services Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s490/j"},"text":"40 U.S.C. 490(j)","children":[],"tail":") [now "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s586/a"},"text":"40 U.S.C. 586(a)","children":[],"tail":", (b)] for the use of the facility constructed under this section for the Foreign Service Institute."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of General Services shall charge the Department of State under such section 210(j) for the costs of any operation, maintenance, repairs, or alterations of such facility carried out by the Administrator of General Services.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90595aa5-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Language Training for Family Members of Foreign Service Personnel","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/105/tIV/s414"},"text":"Pub. L. 95–105, title IV, § 414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-17"},"text":"Aug. 17, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/857"},"text":"91 Stat. 857","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/241/tV/s505/a/3"},"text":"Pub. L. 97–241, title V, § 505(a)(3)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1982-08-24"},"text":"Aug. 24, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/299"},"text":"96 Stat. 299","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/241/tV/s505/a/3"},"text":"“It is the sense of Congress that, in order to increase the effectiveness of United States diplomatic representation abroad, the Secretary of State should make greater use of his authority under section 701 of the Foreign Service Act of 1946 [former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s1041"},"text":"section 1041 of this title","children":[],"tail":"] in order to increase the language training opportunities available to the family members of Foreign Service personnel.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id90595aa6-2930-11f1-8918-be39dde81dc6"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id90595aa7-2930-11f1-8918-be39dde81dc6"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
