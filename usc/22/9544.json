{"tag":"section","attrib":{"id":"id913256a4-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9544"},"text":null,"children":[{"tag":"num","attrib":{"value":"9544"},"text":"§ 9544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on media organizations controlled and funded by the Government of the Russian Federation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id913256a5-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9544/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2017-08-02"},"text":"August 2, 2017","children":[],"tail":", and annually thereafter, the President shall submit to the appropriate congressional committees a report that includes a description of media organizations that are controlled and funded by the Government of the Russian Federation, and any affiliated entities, whether operating within or outside the Russian Federation, including broadcast and satellite-based television, radio, Internet, and print media organizations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id913256a6-2930-11f1-8918-be39dde81dc6","identifier":"/us/usc/t22/s9544/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required by subsection (a) shall be submitted in unclassified form but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id913256a7-2930-11f1-8918-be39dde81dc6"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/44/tII/s255"},"text":"Pub. L. 115–44, title II, § 255","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/930"},"text":"131 Stat. 930","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
