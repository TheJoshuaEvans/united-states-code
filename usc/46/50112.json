 3504]","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–493; "},{"tag":"html:a","attrib":{"href":"/us/pl/108/426"},"text":"Pub. L. 108–426","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 2004","children":[],"tail":", § 2(c)(4), "},{"tag":"html:a","attrib":{"href":"/us/stat/118/2424"},"text":"118 Stat. 2424","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6b87a4b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idf6b87a4c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Office of the Assistant Secretary for Research and Technology of the Department of Transportation” substituted for “Research and Innovative Technology Administration” in subsec. (f) on authority of title I of div. L of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76"},"text":"Pub. L. 113–76","children":[],"tail":", set out in part as a note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s112"},"text":"section 112 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
