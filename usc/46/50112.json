{"tag":"section","attrib":{"id":"idf6b60a32-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112"},"text":null,"children":[{"tag":"num","attrib":{"value":"50112"},"text":"§ 50112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Maritime Enhancement Institutes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b60a33-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may designate National Maritime Enhancement Institutes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a34-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities undertaken by an institute may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b60a35-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting research about methods to improve the performance of maritime industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a36-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing the competitiveness of domestic maritime industries in international trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a37-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forecasting trends in maritime trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a38-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing technological advancements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a39-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing management initiatives and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a3a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzing economic and operational impacts of regulatory policies and international negotiations or agreements pending before international bodies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a3b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the compatibility of domestic maritime infrastructure systems with overseas transport systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a3c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fostering innovations in maritime transportation pricing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a3d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving maritime economics and finance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a3e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application for Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An institution seeking designation as a National Maritime Enhancement Institute shall submit an application under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a3f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall designate an institute under this section on the basis of the following criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b60a40-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The demonstrated research and extension resources available to the applicant for carrying out the activities specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a41-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ability of the applicant to provide leadership in making national and regional contributions to the solution of both long-range and immediate problems of the domestic maritime industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a42-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The existence of an established program of the applicant encompassing research and training directed to enhancing maritime industries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a43-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The demonstrated ability of the applicant to assemble and evaluate pertinent information from national and international sources and to disseminate results of maritime industry research and educational programs through a continuing education program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a44-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The qualification of the applicant as a nonprofit institution of higher learning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a45-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial Awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make awards on an equal matching basis to an institute designated under subsection (a) from amounts appropriated. The aggregate annual amount of the Federal share of the awards by the Secretary may not exceed $500,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a46-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50112/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"University Transportation Research Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5505"},"text":"section 5505 of title 49","children":[],"tail":" to an institute designated under subsection (a) for maritime and maritime intermodal research under that section as if the institute were a university transportation center. In making a grant, the Secretary, through the Office of the Assistant Secretary for Research and Technology of the Department of Transportation, shall advise the Maritime Administration on the availability of funds for the grants and consult with the Administration on making the grants."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b60a47-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"t