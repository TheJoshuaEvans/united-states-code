{"tag":"section","attrib":{"id":"idf6ea86df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55301"},"text":null,"children":[{"tag":"num","attrib":{"value":"55301"},"text":"§ 55301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on administration of programs by other Federal departments and agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ea86e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Maritime Administration shall annually submit to Congress a report on the administration by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea86e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2631"},"text":"section 2631 of title 10","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea86e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal departments and agencies of programs the Administrator determines are subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55305"},"text":"section 55305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ea86e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each annual report required under subsection (a) shall include, for each Federal department or agency that administers a program covered by the report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea86e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross tonnage of cargo (equipment, materials, or agricultural products), expressed by type of cargo, transported on United States flag vessels as compared to on foreign vessels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea86e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of United States flag vessels and total number of foreign vessels contracted by each department or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ea86e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Reporting Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than January 31 of each year, the head of each Federal department or agency that administers a program covered by a report required under subsection (a) shall submit to the Administrator of the Maritime Administration the information described in subsection (b) for that department or agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ea86e7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dC/tXXXV/s3521/a/1"},"text":"Pub. L. 118–31, div. C, title XXXV, § 3521(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/819"},"text":"137 Stat. 819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ea86e8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6ea86e9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf6ea86ea-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 55301 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55123"},"text":"section 55123 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
