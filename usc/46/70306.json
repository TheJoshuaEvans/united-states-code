{"tag":"section","attrib":{"id":"idf7098020-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70306"},"text":null,"children":[{"tag":"num","attrib":{"value":"70306"},"text":"§ 70306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on terrorist threats","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7098021-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall submit an annual report to Congress on the threat from acts of terrorism to United States ports and vessels operating from those ports. The Secretary shall include a description of activities undertaken under title I of the Maritime Transportation Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Public Law 107–295","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2066"},"text":"116 Stat. 2066","children":[],"tail":") and an analysis of the effect of those activities on port security against acts of terrorism."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098022-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The report shall be submitted to the Committee on International Relations and the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Foreign Relations and the Committee on Commerce, Science, and Transportation of the Senate. Any classified information in the report shall be submitted separately as an addendum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf7098023-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s10/2"},"text":"Pub. L. 109–304, § 10(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1685"},"text":"120 Stat. 1685","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIX/s901/q"},"text":"Pub. L. 109–241, title IX, § 901(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/566"},"text":"120 Stat. 566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3525/a/5"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3525(a)(5)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/601"},"text":"122 Stat. 601","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf7098024-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf7098025-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf7098026-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{