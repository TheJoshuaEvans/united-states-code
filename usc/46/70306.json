}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf7098027-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf7098028-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Maritime Transportation Security Act of 2002, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2064"},"text":"116 Stat. 2064","children":[],"tail":". Title I of the Act enacted subtitle VI (now subtitle VII) of this title, amended section 1802 of the former Appendix to this title, sections 661 (now 4903) and 724 (now 3735) of Title 14, Coast Guard, "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1431a"},"text":"section 1431a of Title 19","children":[],"tail":", Customs Duties, sections 1226, 1501 to 1504, 1507, and 1520 of Title 33, Navigation and Navigable Waters, and former section 192 and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s195"},"text":"section 195 of Title 50","children":[],"tail":", War and National Defense, enacted provisions set out as notes under sections 70101, 70103, 70104, 70111, 70114, and former "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s70116"},"text":"section 70116 of this title","children":[],"tail":" and former section 1226 and "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1504"},"text":"section 1504 of Title 33","children":[],"tail":", amended provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2071"},"text":"section 2071 of Title 19","children":[],"tail":", and repealed provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s2071"},"text":"section 2071 of Title 19","children":[],"tail":". For complete classification of title I to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf7098029-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3525/b"},"text":"Pub. L. 110–181, § 3525(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/s901/q"},"text":"Pub. L. 109–241, § 901(q)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3525/a/5"},"text":"Pub. L. 110–181, § 3525(a)(5)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/s901/q"},"text":"Pub. L. 109–241, § 901(q)","children":[],"tail":", into this section by substituting “The Secretary shall submit an annual report” for “Not later than February 28 of each year, the Secretary shall submit a report”. See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s901/q"},"text":"Pub. L. 109–241, § 901(q)","children":[],"tail":", which directed the amendment of section 1802 of the former Appendix to this title from which subsec. (a) of this section was derived, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3525/b"},"text":"Pub. L. 110–181, § 3525(b)","children":[],"tail":". See 2008 Amendment note for subsec. (a) and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
