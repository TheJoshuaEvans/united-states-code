{"tag":"section","attrib":{"id":"idf6bfa658-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51303"},"text":null,"children":[{"tag":"num","attrib":{"value":"51303"},"text":"§ 51303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-competitive appointments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6bfa659-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may appoint each year without competition as cadets at the United States Merchant Marine Academy not more than 50 qualified individuals with qualities the Secretary considers to be of special value to the Academy. In making these appointments, the Secretary shall try to achieve a national demographic balance at the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bfa65a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of Candidates Selected for Preparatory School Sponsorship","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may appoint each year as cadets at the United States Merchant Marine Academy not more than 40 qualified individuals sponsored by the Academy to attend preparatory school during the academic year prior to entrance in the Academy, and who have successfully met the terms and conditions of sponsorship set by the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6bfa65b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1572"},"text":"120 Stat. 1572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3516/a"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3516(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2789"},"text":"130 Stat. 2789","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3504"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1970"},"text":"133 Stat. 1970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6bfa65c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6bfa65d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6bfa65e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],