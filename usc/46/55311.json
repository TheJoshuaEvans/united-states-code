{"tag":"section","attrib":{"id":"idf6ea8732-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55311"},"text":null,"children":[{"tag":"num","attrib":{"value":"55311"},"text":"§ 55311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ea8733-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea8734-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55311/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a productive and healthy agricultural industry and a strong and active United States maritime industry are vitally important to the economic well-being and security of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea8735-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55311/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both industries must compete in international markets increasingly dominated by foreign trade barriers and the subsidization practices of foreign governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea8736-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55311/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased agricultural exports and the use of merchant vessels of the United States contribute positively to the United States balance of trade and generate employment opportunities in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ea8737-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subchapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea8738-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable the Secretary of Agriculture to plan export programs effectively, by clarifying the ocean transportation requirements applicable to those programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea8739-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take immediate and positive steps to promote the growth of the cargo-carrying capacity of the United States merchant marine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea873a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55311/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand international trade in United States agricultural commodities and products and develop, maintain, and expand markets for United States agricultural exports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea873b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55311/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the efficiency of administration of both the commodity purchasing and selling activities and the ocean transportation activities associated with export programs sponsored by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea873c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55311/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stimulate and promote the agricultural and maritime industries of the United States and encourage cooperative efforts by both industries to address their common problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea873d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55311/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the appropriate disposition of these findings and purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ea873e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1643"},"text":"120 Stat. 1643","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ea873f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ea8740-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ea8741-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55311","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1241d.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/198/tXI/s1141"},"text":"Pub. L. 99–198, title XI, § 1141","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/99/1490"},"text":"99 Stat. 1490","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the word “security” is substituted for “national security objectives” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Secretary of Agriculture” in paragraph (1) and “Secretary” in paragraph (4) are substituted for “Department of Agriculture” because all functions of the Department are vested in the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2202"},"text":"7 U.S.C. 2202","children":[],"tail":" and 6911 and Reorganization Plan No. 2 of 1953 (5 App. U.S.C.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
