{"tag":"section","attrib":{"id":"idf6c1f0d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312"},"text":null,"children":[{"tag":"num","attrib":{"value":"51312"},"text":"§ 51312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of Visitors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c1f0d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There shall be a Board of Visitors to the United States Merchant Marine Academy (referred to in this section as the “Board” and the “Academy”, respectively) to provide independent advice and recommendations on matters relating to the United States Merchant Marine Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f0d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c1f0d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c1f0da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 Senators appointed by the Chairman of the Committee on Commerce, Science, and Transportation of the Senate in consultation with the ranking member of such Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 Members of the House of Representatives appointed by the Chairman of the Committee on Armed Services of the House of Representatives in consultation with the ranking member of such Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 Senator appointed by the Vice President, who shall be a member of the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 Members of the House of Representatives appointed by the Speaker of the House of Representatives, in consultation with the Minority Leader, at least 1 of whom shall be a member of the Committee on Appropriations of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 individuals appointed by the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as ex officio members—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c1f0e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commander of the Military Sealift Command;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c1f0e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Deputy Commandant for Operations of the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c1f0e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/1/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairman of the Committee on Commerce, Science, and Transportation of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c1f0e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/1/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairman of the Committee on Armed Services of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c1f0e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/1/F/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairman of the Advisory Board to the Academy established under section 51313; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c1f0e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/1/F/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Member of the House of Representatives for the congressional district in which the Academy is located, as a nonvoting member, unless such Member of the House of Representatives is appointed as a voting member of the Board under subparagraph (B) or (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f0e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presidential appointees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the individuals appointed by the President under paragraph (1)(E)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c1f0e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 2 shall be graduates of the Academy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 shall be a senior corporate officer from a United States maritime shipping company that participates in the Maritime Security Program, or in any Maritime Administration program providing incentives for companies to register their vessels in the United States, and this appointment shall rotate biennially among such companies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 shall be a representative of a maritime labor organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more may be a Senate-confirmed Presidential appointee, a member of the Senior Executive Service, or an officer of flag-rank from the Coast Guard, the National Oceanic and Atmospheric Administration, or any of the military services that commission graduates of the Academy, other than the individuals who are members of the Board under clauses (i) and (ii) of paragraph (1)(F).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f0eb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of service.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c1f0ec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), each member of the Board, other than an ex officio member under paragraph (1)(F), shall serve for a term of 2 years commencing at the beginning of each Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0ed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation of service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any member described in subparagraph (A) whose term on the Board has expired, other than a member appointed under any of subparagraphs (A) through (D) of paragraph (1) who is no longer a Member of Congress, shall continue to serve until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0ee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Replacement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a member of the Board is replaced, not later than 60 days after the date of the replacement, the Designated Federal Officer selected under subsection (g)(2) shall notify that member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f0ef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a member of the Board is no longer able to serve on the Board or resigns, the Designated Federal Officer selected under subsection (g)(2) shall immediately notify the person who appointed such member. Not later than 60 days after that notification, such person shall designate a replacement to serve the remainder of such member’s term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f0f0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation and responsibility of substitute board members.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c1f0f1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to designate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Board under clause (i) or (ii) of paragraph (1)(F) or appointed under subparagraph (B) or (C) of paragraph (2) may, if unable to attend or participate in an activity described in subsection (d), (e), or (f), designate another individual to serve as a substitute member of the Board, on a temporary basis, to attend or participate in such activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0f2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A substitute member of the Board designated under subparagraph (A) shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c1f0f3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual serving in a position for which the individual was appointed by the President and confirmed by the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c1f0f4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Senior Executive Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c1f0f5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an officer of flag-rank who is employed by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6c1f0f6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/5/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Coast Guard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6c1f0f7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/5/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Military Sealift Command.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0f8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A substitute member of the Board designated under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c1f0f9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be permitted by the Board to fully participate in the proceedings and activities of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c1f0fa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall report to the member that designated the substitute member on the Board’s activities not later than 15 days following the substitute member’s participation in such activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c1f0fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/b/5/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be permitted by the Board to participate in the preparation of reports described in paragraph ","children":[{"tag":"ref","attrib":{"idref":"fn002026"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002026"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (j) related to any proceedings or activities of the Board in which such substitute member participates."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f0fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c1f0fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On a biennial basis and subject to paragraph (2), the Board shall select from among its members a Member of the House of Representatives or a Senator to serve as the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f0fe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rotation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Member of the House of Representatives and a Member of the Senate shall alternately be selected as the Chairperson of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f0ff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual may not serve as Chairperson for consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f100-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c1f101-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall meet as provided for in the Charter adopted under paragraph (2)(B), including at least 1 meeting held at the Academy and 2 additional meetings, which may be held in person or virtually.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f102-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson and charter","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Designated Federal Officer selected under subsection (g)(2) shall organize a meeting of the Board for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c1f103-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selecting a Chairperson under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f104-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopting an official Charter for the Board, which shall establish the schedule of meetings of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f105-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scheduling; notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When scheduling a meeting of the Board, the Designated Federal Officer shall coordinate, to the greatest extent practicable, with the members of the Board to determine the date and time of the meeting. Members of the Board shall be notified of the date of each meeting not less than 30 days prior to the meeting date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f106-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Visiting the Academy.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c1f107-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual visit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall visit the Academy annually on a date selected by the Board, in consultation with the Secretary of Transportation and the Superintendent of the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f108-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other visits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In cooperation with the Superintendent, the Board or its members may make other visits to the Academy in connection with the duties of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f109-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"While visiting the Academy under this subsection, members of the Board shall have reasonable access to the grounds, facilities, midshipmen, faculty, staff, and other personnel of the Academy for the purpose of carrying out the duties of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f10a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staff","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"One or more staff of each member of the Board may accompany them on Academy visits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f10b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scheduling; notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When scheduling a visit to the Academy, the Designated Federal Officer shall coordinate, to the greatest extent practicable, with the members of the Board to determine the date and time of the visit. Members of the Board shall be notified of the date of each visit not less than 30 days prior to the visit date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f10c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall inquire into the state of morale and discipline, the curriculum, instruction, physical equipment, fiscal affairs, and academic methods of the Academy, and other matters relating to the Academy that the Board decides to consider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f10d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department of Transportation Support","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c1f10e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide support as deemed necessary by the Board for the performance of the Board’s functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f10f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select a Designated Federal Officer to support the performance of the Board’s functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f110-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with the Maritime Administrator and the Superintendent of the Academy, advise the Board of any institutional issues, consistent with applicable laws concerning the disclosure of information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f111-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staff","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each of the chairman and ranking member of the Committee on Commerce, Science, and Transportation of the Senate and the chairman and ranking member of the Committee on Armed Services of the House of Representatives may designate staff members of such Committee to serve, without additional reimbursement (except as provided in subsection (i)), as staff for the Board. Such staff may attend meetings and may visit the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f112-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Travel Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"While serving away from his or her home or regular place of business, a member of the Board or a staff member designated under subsection (h) shall be allowed travel expenses, including per diem in lieu of subsistence, as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f113-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c1f114-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after each annual visit required under subsection (e)(1), the Board shall submit to the President a written report of its actions, views, and recommendations pertaining to the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f115-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the members of the Board visit the Academy under subsection (e)(2), the Board may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c1f116-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare a report on such visit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f117-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if approved by a majority of the members of the Board, submit such report to the President not later than 60 days after the date of the approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f118-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may call in advisers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c1f119-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/j/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for consultation regarding the execution of the Board’s responsibility under subsection (f); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f11a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/j/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the preparation of a report described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f11b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report submitted to the President under paragraph (1) or (2) shall be concurrently submitted to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c1f11c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/j/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f11d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/j/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f11e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51312/j/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Armed Services of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c1f11f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1575"},"text":"120 Stat. 1575","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dC/tXXXV/s3504/a"},"text":"Pub. L. 113–291, div. C, title XXXV, § 3504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3905"},"text":"128 Stat. 3905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3512"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3065"},"text":"136 Stat. 3065","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c1f120-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6c1f121-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6c1f122-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","a