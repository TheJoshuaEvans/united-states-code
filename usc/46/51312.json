ren":[],"tail":", (ii), redesignated subpar. (C) as (D) and substituted “flag-rank” for “flag-rank who”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3512/1/B"},"text":"Pub. L. 117–263, § 3512(1)(B)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3512/2/A"},"text":"Pub. L. 117–263, § 3512(2)(A)","children":[],"tail":", inserted “and 2 additional meetings, which may be held in person or virtually” after “Academy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3512/2/B"},"text":"Pub. L. 117–263, § 3512(2)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3512/3"},"text":"Pub. L. 117–263, § 3512(3)","children":[],"tail":", added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3512/4"},"text":"Pub. L. 117–263, § 3512(4)","children":[],"tail":", inserted “and ranking member” after “chairman” in two places and inserted at end “Such staff may attend meetings and may visit the Academy.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" amended section generally. Prior to amendment, section related to the Board of Visitors and consisted of subsecs. (a) to (d) relating to establishment of the Board, appointment of board members, designation of staff members to the board, and travel expenses, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6c1f125-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6c1f126-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadlines; Continuation of Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dC/tXXXV/s3504/b"},"text":"Pub. L. 113–291, div. C, title XXXV, § 3504(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3909"},"text":"128 Stat. 3909","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/291/dC/tXXXV/s3504/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadlines.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of designated federal officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall select a Designated Federal Officer under subsection (g)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51312"},"text":"section 51312 of title 46","children":[],"tail":", United States Code, as amended by this Act, by not later than 30 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Appointments under subsection (b)(1) of such section shall be completed by not later than 60 days after the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Organization of first meeting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Such Designated Federal Officer shall organize a meeting of the Board under section (d)(2) of such section by not later than 60 days after the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation of Service of Current Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Board of Visitors serving as a member of the Board on the date of the enactment of this Act shall continue to serve on the Board for the remainder of such member’s term.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
