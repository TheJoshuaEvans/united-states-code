{"tag":"section","attrib":{"id":"idf6e0e9d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722"},"text":null,"children":[{"tag":"num","attrib":{"value":"53722"},"text":"§ 53722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions by Secretary or Administrator","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e0e9d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On default under an obligation or related agreement between the Secretary or Administrator and the obligor, the Secretary or Administrator, on terms that may be provided in the obligation or agreement, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e0e9d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assume the obligor’s rights and duties under the obligation or agreement, make any payment in default, and notify the obligee or the obligee’s agent of the default and the Secretary’s or Administrator’s assumption; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0e9d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the obligee or the obligee’s agent of the default.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0e9d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Demands by Obligees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e0e9d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Demand","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary or Administrator proceeds under subsection (a)(2), the obligee or the obligee’s agent may demand that the Secretary or Administrator pay the unpaid principal amount of the obligation and the unpaid interest on the obligation. The demand must be made within the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e0e9d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period that may be specified in the guarantee or a related agreement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e0e9d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 days from the date of the Secretary’s or Administrator’s notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0e9da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a demand is made under paragraph (1), the Secretary or Administrator shall pay to the obligee or the obligee’s agent the unpaid principal amount of the obligation and the unpaid interest on the obligation to the date of payment. Payment shall be made within the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e0e9db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period that may be specified in the guarantee or a related agreement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e0e9dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 days from the date of the demand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0e9dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continued Effect of Guarantee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A guarantee of an obligation remains in effect after an assumption of the obligation by the Secretary or Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0e9de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Responses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If there is a default on an obligation, the Secretary or Administrator shall conduct operations under this chapter in a manner that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e0e9df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizes the net present value return from the sale or disposition of assets associated with the obligation, including prompt referral to the Attorney General for collection as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0e9e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimizes the amount of any loss realized in the resolution of the guarantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0e9e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures adequate competition and fair and consistent treatment of offerors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0e9e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53722/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires appraisal of assets by an independent appraiser.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e0e9e3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1618"},"text":"120 Stat. 1618","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/C"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(C)","children":[],"tail":", (F), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/10/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(10)(B)","children":[],"tail":", (11), (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e0e9e4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e0e9e5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e0e9e6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"