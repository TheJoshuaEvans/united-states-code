{"tag":"section","attrib":{"id":"idf6c6d291-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327"},"text":null,"children":[{"tag":"num","attrib":{"value":"51327"},"text":"§ 51327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual Assault Advisory Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c6d292-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall establish a Sexual Assault Advisory Council (in this section referred to as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d293-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c6d294-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall be composed of not fewer than 8 and not more than 14 individuals selected by the Secretary of Transportation who are alumni that have graduated within the last 4 years or current midshipmen of the United States Merchant Marine Academy (including midshipmen or alumni who were victims of sexual assault, to the maximum extent practicable, and midshipmen or alumni who were not victims of sexual assault) and governmental and nongovernmental experts and professionals in the sexual assault field.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d295-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Experts included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c6d296-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 1 member who is licensed in the field of mental health and has prior experience working as a counselor or therapist providing mental health care to survivors of sexual assault in a victim services agency or organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c6d297-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 1 member who has prior experience developing or implementing sexual assault or sexual harassment prevention and response policies in an academic setting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d298-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules regarding membership","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No employee of the Department of Transportation shall be a member of the Council. The number of governmental experts appointed to the Council shall not exceed the number of nongovernmental experts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d299-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties; Authorized Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c6d29a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall meet not less often than semiannually to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c6d29b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" review—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c6d29c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policies on sexual harassment, dating violence, domestic violence, sexual assault, and stalking under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51318"},"text":"section 51318 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c6d29d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trends and patterns of data contained in the system described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51325"},"text":"section 51325 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c6d29e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" related matters the Council views as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c6d29f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop recommendations designed to ensure that such policies and such matters conform, to the extent practicable, to best practices in the field of sexual assault and sexual harassment response and prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2a0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out this subsection, the Council may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c6d2a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interview current and former midshipmen of the United States Merchant Marine Academy (to the extent that such midshipmen provide the Department of Transportation express consent to be interviewed by the Council); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c6d2a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review surveys under section 51322(d).","children":[{"tag":"ref","attrib":{"idref":"fn002030"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002030"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personally identifiable information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this subsection, the Council shall comply with the obligations of the Department of Transportation to protect personally identifiable information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d2a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On an annual basis for each of the 5 years after the date of enactment of this section, and at the discretion of the Council thereafter, the Council shall submit, to the President and the Committee on Commerce, Science, and Transportation and the Committee on Appropriations of the Senate and the Committee on Transportation and Infrastructure and the Committee on Appropriations of the House of Representatives, a report on the Council’s findings based on the reviews conducted pursuant to subsection (c) and related recommendations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d2a5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee Status","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the Council shall not be considered employees of the United States Government for any purpose and shall not receive compensation other than reimbursement of travel expenses and per diem allowance in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d2a6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51327/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability of FACA","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" shall not apply to the Council."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c6d2a7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3531/a"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3531(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3086"},"text":"136 Stat. 3086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c6d2a8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6c6d2a9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6c6d2aa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 51322(d), referred to in subsec. (c)(2)(B), probably should be a reference to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51322/g"},"text":"section 51322(g) of this title","children":[],"tail":". Subsec. (d) of section 51322, which relates to the completion of a survey by a cadet upon the completion of the cadet’s Sea Year, was redesignated as subsec. (g) of section 51322 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3513/a/2"},"text":"Pub. L. 117–263, § 3513(a)(2)","children":[],"tail":". Subsec. (d) of section 51322, as added by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3513/a/1"},"text":"Pub. L. 117–263, § 3513(a)(1)","children":[],"tail":", provides that the Maritime Administrator is to ensure that a cadet participating in Sea Year has certain information, training, and resources."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
