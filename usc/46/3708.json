{"tag":"section","attrib":{"id":"idf66c2f0e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3708"},"text":null,"children":[{"tag":"num","attrib":{"value":"3708"},"text":"§ 3708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Self-propelled tank vessel minimum standards","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A self-propelled tank vessel of at least 10,000 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" shall be equipped with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf66c2f0f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3708/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dual radar system with short-range and long-range capabilities, each with true-north features;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f10-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3708/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electronic relative motion analyzer that is at least functionally equivalent to equipment complying with specifications established by the Secretary of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f11-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3708/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electronic position-fixing device;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f12-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3708/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate communications equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f13-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3708/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sonic depth finder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f14-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3708/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a gyrocompass; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f15-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3708/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" up-to-date charts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf66c2f16-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/524"},"text":"97 Stat. 524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s717"},"text":"Pub. L. 104–324, title VII, § 717","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3937"},"text":"110 Stat. 3937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf66c2f17-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf66c2f18-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf66c2f19-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3708","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(7)(J)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3708 requires compliance with certain minimum standards by a self-propelled tank vessel. These requirements apply to any tank vessel of 10,000 gross tons or above with no distinction being made as to whether or not the vessel is “primarily” constructed or adapted to carry oil or hazardous material in bulk in the cargo spaces. These vessels are required to be equipped with a dual radar system, a computerized relative motion analyzer, an electronic position fixing device, adequate communications equipment, a sonic depth finder, a gyrocompass, and up-to-date charts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf66c2f1a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf66c2f1b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “10,000 gross tons”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
