{"tag":"section","attrib":{"id":"idf6f1b2cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57111"},"text":null,"children":[{"tag":"num","attrib":{"value":"57111"},"text":"§ 57111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of obsolete vessel","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter, the term “obsolete vessel” means a vessel that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f1b2cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57111/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is or will be in the custody and control of the Maritime Administration for purposes of disposing of the vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b2cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57111/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has been determined by the Secretary of Transportation to be of insufficient value, with respect to the programs of the Maritime Administration, to warrant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6f1b2ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57111/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserving for future use or spare parts harvesting; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f1b2cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57111/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retaining in the National Defense Reserve Fleet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b2d0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dC/tXXXV/s3514/j/1/B"},"text":"Pub. L. 118–31, div. C, title XXXV, § 3514(j)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/811"},"text":"137 Stat. 811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b2d1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6f1b2d2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf6f1b2d3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 57111 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s57110"},"text":"section 57110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
