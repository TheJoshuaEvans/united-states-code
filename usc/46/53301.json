{"tag":"section","attrib":{"id":"idf6d2b9e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53301"},"text":null,"children":[{"tag":"num","attrib":{"value":"53301"},"text":"§ 53301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d2b9e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b9e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “construction contract” includes, for a taxpayer constructing a new vessel in a shipyard owned by that taxpayer, an agreement between the taxpayer and the Secretary of Transportation for that construction containing provisions the Secretary considers advisable to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “new vessel” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d2b9e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53301/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a vessel—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6d2b9e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53301/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructed in the United States after ","children":[{"tag":"date","attrib":{"date":"1939-12-31"},"text":"December 31, 1939","children":[],"tail":", constructed with a construction-differential subsidy under title V of the Merchant Marine Act, 1936, or constructed with financing or a financing guarantee under chapter 537 or 575 of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6d2b9e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53301/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documented or agreed with the Secretary to be documented under the laws of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6d2b9e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53301/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6d2b9e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53301/a/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of a type, size, and speed that the Secretary determines is suitable for use on the high seas or Great Lakes in carrying out this subtitle, but not less than 2,000 gross tons or less than 12 knots speed unless the Secretary certifies in each case that a vessel of lesser tonnage or speed is desirable for use by the United States Government in case of war or national emergency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6d2b9ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53301/a/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructed to replace a vessel bought or requisitioned by the Government; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d2b9eb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53301/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel reconstructed or reconditioned for use only on the Great Lakes, including the Saint Lawrence River and Gulf, if the Secretary finds that the reconstruction or reconditioning will promote the objectives of this subtitle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9ec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Tax-Related Terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Other terms used in this chapter have the same meaning as in chapter 1 of the Internal Revenue Code of 1986 (26 U.S.C. ch. 1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d2b9ed-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1587"},"text":"120 Stat. 1587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d2b9ee-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6d2b9ef-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6d2b9f0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody