ag":"html:a","attrib":{"href":"/us/stat/54/1106"},"text":"54 Stat. 1106","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/92/A"},"text":"Pub. L. 97–31, § 12(92)(A)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/161"},"text":"95 Stat. 161","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"53301(a) (2)(B)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1161(","children":[{"tag":"html:i","attrib":{},"text":"o","children":[],"tail":")."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title V, § 511("},{"tag":"html:i","attrib":{},"text":"o","children":[],"tail":"), as added "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-17/ch939/s14"},"text":"July 17, 1952, ch. 939, § 14","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/764"},"text":"66 Stat. 764","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/92/A"},"text":"Pub. L. 97–31, § 12(92)(A)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/161"},"text":"95 Stat. 161","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53301(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1161(m).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title V, § 511(m), as added "},{"tag":"html:a","attrib":{"href":"/us/act/1940-10-10/ch849"},"text":"Oct. 10, 1940, ch. 849","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/54/1108"},"text":"54 Stat. 1108","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(A)(i), the words “constructed with a construction-differential subsidy under title V of the Merchant Marine Act, 1936, or constructed with financing or a financing guarantee under chapter 537 or 575 of this title” are substituted for “the construction of which has been financed under subchapters V or VII of this chapter, or the construction of which has been aided by a mortgage insured under subchapter XI of this chapter” because of the reorganization of the material and the omission from the revised title of the provisions relating to the construction-differential subsidy program.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(2)(B) is substituted for the source provision to state more directly that a vessel described in the source provision is a new vessel for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6d2b9f1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6d2b9f2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Merchant Marine Act, 1936, referred to in subsec. (a)(2)(A)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"act June 29, 1936, ch. 858","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1985"},"text":"49 Stat. 1985","children":[],"tail":". Title V of the Act enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53101"},"text":"section 53101 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1936 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
