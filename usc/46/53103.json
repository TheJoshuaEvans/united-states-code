{"tag":"section","attrib":{"id":"idf6cdd7a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53103"},"text":null,"children":[{"tag":"num","attrib":{"value":"53103"},"text":"§ 53103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of operating agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6cdd7a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require, as a condition of including any vessel in the Fleet, that the person that is the owner or operator of the vessel for purposes of section 53102(c) enter into an operating agreement with the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6cdd7a5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension of Existing Operating Agreements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6cdd7a6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offer to extend","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date of enactment of this paragraph, the Secretary shall offer, to an existing contractor, to extend, through ","children":[{"tag":"date","attrib":{"date":"2040-09-30"},"text":"September 30, 2040","children":[],"tail":", an operating agreement that is in existence on the date of enactment of this paragraph. The terms and conditions of the extended operating agreement shall include terms and conditions authorized under this chapter, as amended from time to time."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6cdd7a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time limit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An existing contractor shall have not later than 120 days after the date the Secretary offers to extend an operating agreement to agree to the extended operating agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6cdd7a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent award","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may award an operating agreement to an applicant that is eligible to enter into an operating agreement for fiscal years 2016 through 2040 if the existing contractor does not agree to the extended operating agreement under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6cdd7a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure for Awarding New Operating Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may enter into a new operating agreement with an applicant that meets the requirements of section 53102(c) (for vessels that meet the qualifications of section 53102(b)) on the basis of priority for vessel type established by military requirements of the Secretary of Defense. The Secretary shall allow an applicant at least 30 days to submit an application for a new operating agreement. After consideration of military requirements, priority shall be given to an applicant that is a United States citizen under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":". The Secretary may not approve an application without the consent of the Secretary of Defense. The Secretary shall enter into an operating agreement with the applicant or provide a written reason for denying the application."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047aa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not award operating agreements under this chapter that require payments under section 53106 for a fiscal year for more than 60 vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d047ab-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dC/tXXXV/s3531/a"},"text":"Pub. L. 108–136, div. C, title XXXV, § 3531(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1808"},"text":"117 Stat. 1808","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/2"},"text":"Pub. L. 109–304, § 13(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1700"},"text":"120 Stat. 1700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dC/tXXXV/s3502/b/1"},"text":"Pub. L. 109–364, div. C, title XXXV, § 3502(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2515"},"text":"120 Stat. 2515","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dC/tXXXV/s3508/c"},"text":"Pub. L. 112–239, div. C, title XXXV, § 3508(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2224"},"text":"126 Stat. 2224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3502/a"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1969"},"text":"133 Stat. 1969","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXV/s3502/a"},"text":"Pub. L. 118–159, div. C, title XXXV, § 3502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2304"},"text":"138 Stat. 2304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d047ac-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6d047ad-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6d047ae-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this paragraph, referred to in subsec. (b)(1), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":", which amended subsec. (b) generally and was approved "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6d047af-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(1), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “2040” for “2035”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(1), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “2035” for “2025”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s3508/c/1"},"text":"Pub. L. 112–239, § 3508(c)(1)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) related to procedure for applications."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s3508/c/2"},"text":"Pub. L. 112–239, § 3508(c)(2)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) related to priority for awarding agreements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/2/A"},"text":"Pub. L. 109–304, § 13(a)(2)(A)","children":[],"tail":"–(C), substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":"” for “section 2 of the Shipping Act, 1916 (46 U.S.C. App. 802)” in subpars. (A)(iii) and (C)(i) and (ii), “applying subparagraph” for “applying subparagraphs” in subpar. (B), and “section 50501” for “section 2” in subpar. (C) heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/2/D"},"text":"Pub. L. 109–304, § 13(a)(2)(D)","children":[],"tail":", substituted “agreements” for “agreement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3502/b/1/A"},"text":"Pub. L. 109–364, § 3502(b)(1)(A)","children":[],"tail":"–(D), redesignated cls. (i) and (ii) as cl. (i), subcls. (I) and (II), respectively, in subcl. (II) substituted “; or” for period at end, and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3502/b/1/E"},"text":"Pub. L. 109–364, § 3502(b)(1)(E)","children":[],"tail":", inserted “with respect to which a binding contract is entered into under subparagraph (A)(i)” after “existing tank vessel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3502/b/1/F"},"text":"Pub. L. 109–364, § 3502(b)(1)(F)","children":[],"tail":", added subpars. (C) and (D)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
