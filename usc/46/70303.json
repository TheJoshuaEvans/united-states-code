{"tag":"section","attrib":{"id":"idf7071102-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70303"},"text":null,"children":[{"tag":"num","attrib":{"value":"70303"},"text":"§ 70303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security standards at foreign ports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7071103-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop and implement a plan to assess the effectiveness of the security measures maintained at foreign ports that the Secretary, in consultation with the Secretary of State, determines pose a high risk of acts of terrorism against passenger vessels. In carrying out this subsection, the Secretary shall consult with the Secretary of State about the terrorist threat that exists in each country and poses a high risk of acts of terrorism against passenger vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7071104-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice and Recommendations to Other Countries","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary, after implementing the plan under subsection (a), determines that a port does not maintain and administer effective security measures, the Secretary of State (after being informed by the Secretary) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7071105-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the appropriate government authorities of the country in which the port is located of the determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7071106-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend steps necessary to bring the security measures at that port up to the standard used by the Secretary in making the assessment under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7071107-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Antiterrorism Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President is encouraged to provide antiterrorism assistance related to maritime security under chapter 8 of part II of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2349aa"},"text":"22 U.S.C. 2349aa","children":[],"tail":" et seq.) to foreign countries, especially for a port that the Secretary determines under subsection (b) does not maintain and administer effective security measures."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf7098008-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s10/2"},"text":"Pub. L. 109–304, § 10(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1684"},"text":"120 Stat. 1684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf7098009-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf709800a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf709800b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1803.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/399/tIX/s907/a"},"text":"Pub. L. 99–399, title IX, § 907(a)","children":[],"tail":", (b), (d), (e), "},{"tag":"html:span","attrib":{},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/891"},"text":"100 Stat. 891","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf709800c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf709800d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Chapter 8 of part II of the Act is classified generally to part VIII (§ 2349aa et seq.) of subchapter II of chapter 32 of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
