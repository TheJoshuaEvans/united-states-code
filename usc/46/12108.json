{"tag":"section","attrib":{"id":"idf69255da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12108"},"text":null,"children":[{"tag":"num","attrib":{"value":"12108"},"text":"§ 12108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to extend duration of vessel certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf69255db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certificates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Provided a vessel is in compliance with inspection requirements in section 3313, the Secretary of the department in which in the Coast Guard is operating may, if the Secretary makes the determination described in subsection (b), extend, for a period of not more than 1 year, an expiring certificate of documentation issued for a vessel under chapter 121.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69255dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The determination referred to in subsection (a) is a determination that such extension is required to enable the Coast Guard to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf69255dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate a backlog in processing applications for such certificates; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69255de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act in response to a national emergency or natural disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69255df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Manner of Extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any extension granted under this section may be granted to individual vessels or to a specifically identified group of vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf69255e0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8320(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4701"},"text":"134 Stat. 4701","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
