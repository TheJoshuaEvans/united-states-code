{"tag":"section","attrib":{"id":"idf7098016-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70305"},"text":null,"children":[{"tag":"num","attrib":{"value":"70305"},"text":"§ 70305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of passenger services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7098017-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever the President determines that a foreign nation permits the use of territory under its jurisdiction as a base of operations or training for, or as a sanctuary for, or in any way arms, aids, or abets, a terrorist or terrorist group that knowingly uses the illegal seizure of passenger vessels or the threat thereof as an instrument of policy, the President may suspend the right of any passenger vessel common carrier to operate to or from, and the right of any passenger vessel of the United States to use, a port in that foreign nation for passenger service. The suspension may be without notice or hearing and for as long as the President determines is necessary to ensure the security of passenger vessels against unlawful seizure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098018-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A passenger vessel common carrier, or a passenger vessel of the United States, may not operate in violation of a suspension under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098019-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf709801a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70305/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Denial of entry","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a person operates a vessel in violation of this section, the Secretary may deny the vessels of that person entry to ports of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf709801b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70305/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person violating this section is liable to the United States Government for a civil penalty of not more than $50,000. Each day a vessel uses a prohibited port is a separate violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf709801c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s10/2"},"text":"Pub. L. 109–304, § 10(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1684"},"text":"120 Stat. 1684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf709801d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf709801e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf709801f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70305","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1805.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/399/tIX/s909"},"text":"Pub. L. 99–399, title IX, § 909","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/892"},"text":"100 Stat. 892","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
