{"tag":"section","attrib":{"id":"idf6971092-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12304"},"text":null,"children":[{"tag":"num","attrib":{"value":"12304"},"text":"§ 12304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificates of numbers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6971093-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certificate of number is granted for a number issued under this chapter. The certificate shall be at all times available for inspection on the vessel for which issued when the vessel is in operation, and may be in hard copy or digital form. Any certificate issued in hard copy under this section shall be pocketsized. The certificate shall be valid for not more than 3 years. The certificate of number for a vessel less than 26 feet in length and leased or rented to another for the latter’s noncommercial operation of less than 7 days may be retained on shore by the vessel’s owner or representative at the place from which the vessel departs or returns to the possession of the owner or the owner’s representative. A vessel that does not have the certificate of number on board shall be identified when in operation, and comply with requirements, as the issuing authority prescribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6971094-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The owner of a vessel numbered under this chapter shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6971095-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuing authority notice of the transfer of any part of the owner’s interest in the vessel or of the destruction or abandonment of the vessel, within a reasonable time after the transfer, destruction, or abandonment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6971096-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice of a change of address within a reasonable time of the change, as prescribed by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6971097-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/591"},"text":"97 Stat. 591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11506"},"text":"Pub. L. 117–263, div. K, title CXV, § 11506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4136"},"text":"136 Stat. 4136","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6971098-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6971099-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf697109a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12304","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:1469","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 12304 describes a certificate of number and stipulates when it must be carried on board a vessel. It also requires that the number issuing authority be notified when a boat is sold, transferred, destroyed, or abandoned, or when the owner’s address changes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf697109b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf697109c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" struck out “shall be pocketsized,” after “this chapter. The certificate” and inserted “in hard copy or digital form. Any certificate issued in hard copy under this section shall be pocketsized. The certificate shall be” after “operation, and may be”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
