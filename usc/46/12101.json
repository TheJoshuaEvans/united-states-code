{"tag":"section","attrib":{"id":"idf6925563-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12101"},"text":null,"children":[{"tag":"num","attrib":{"value":"12101"},"text":"§ 12101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6925564-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rebuilt in the United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this chapter, a vessel is deemed to have been rebuilt in the United States only if the entire rebuilding, including the construction of any major component of the hull or superstructure, was done in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6925565-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Related Terms in Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When the following terms are used in a law, regulation, document, ruling, or other official act referring to the documentation of a vessel, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6925566-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registry endorsement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms “certificate of registry”, “register”, and “registry” mean a certificate of documentation with a registry endorsement issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6925567-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coastwise endorsement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms “license”, “enrollment and license”, “license for the coastwise (or coasting) trade”, and “enrollment and license for the coastwise (or coasting) trade” mean a certificate of documentation with a coastwise endorsement issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6925568-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12101/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Yacht","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “yacht” means a recreational vessel even if not documented.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6925569-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1491"},"text":"120 Stat. 1491","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf692556a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf692556b-2930-11