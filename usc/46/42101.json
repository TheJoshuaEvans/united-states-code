{"tag":"section","attrib":{"id":"idf6b14f3d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42101"},"text":null,"children":[{"tag":"num","attrib":{"value":"42101"},"text":"§ 42101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations of the Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b14f3e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unfavorable Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To further the objectives and policy set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50101"},"text":"section 50101 of this title","children":[],"tail":", the Federal Maritime Commission shall prescribe regulations affecting shipping in foreign trade, not in conflict with law, to adjust or meet general or special conditions unfavorable to shipping in foreign trade, whether in a particular trade or on a particular route or in commerce generally, including intermodal movements, terminal operations, cargo solicitation, agency services, ocean transportation intermediary services and operations, and other activities and services integral to transportation systems, and which arise out of or result from laws or regulations of a foreign country or competitive methods, pricing practices, or other practices employed by owners, operators, agents, or masters of vessels of a foreign country."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14f3f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initiation of Regulation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A regulation under subsection (a) may be initiated by the Commission on its own motion or on the petition of any person, including another component of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b14f40-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1548"},"text":"120 Stat. 1548","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b14f41-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b14f42-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b14f43-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"child