{"tag":"section","attrib":{"id":"idf6866e56-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701"},"text":null,"children":[{"tag":"num","attrib":{"value":"8701"},"text":"§ 8701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merchant mariners’ documents required","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6866e57-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section applies to a merchant vessel of at least 100 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" except—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6866e58-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel operating only on rivers and lakes (except the Great Lakes);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e59-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a barge (except a seagoing barge or a barge to which chapter 37 of this title applies);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e5a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fishing, fish tender, or whaling vessel or a yacht;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e5b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sailing school vessel with respect to sailing school instructors and sailing school students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e5c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an oceanographic research vessel with respect to scientific personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e5d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fish processing vessel entered into service before ","children":[{"tag":"date","attrib":{"date":"1988-01-01"},"text":"January 1, 1988","children":[],"tail":", and not more than 1,600 gross tons as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" or entered into service after "},{"tag":"date","attrib":{"date":"1987-12-31"},"text":"December 31, 1987","children":[],"tail":", and having not more than 16 individuals on board primarily employed in the preparation of fish or fish products;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e5e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fish processing vessel (except a vessel to which clause (6) of this subsection applies) with respect to individuals on board primarily employed in the preparation of fish or fish products or in a support position not related to navigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e5f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mobile offshore drilling unit with respect to individuals, other than crew members required by the certificate of inspection, engaged on board the unit for the sole purpose of carrying out the industrial business or function of the unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e60-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a passenger vessel not engaged in a foreign voyage with respect to individuals on board employed for a period of not more than 30 service days within a 12 month period as entertainment personnel, with no duties, including emergency duties, related to the navigation of the vessel or the safety of the vessel, its crew, cargo or passengers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e61-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may prescribe the individuals required to hold a merchant mariner’s document serving onboard an oil spill response vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e62-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person may not engage or employ an individual, and an individual may not serve, on board a vessel to which this section applies if the individual does not have a merchant mariner’s document issued to the individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7302"},"text":"section 7302 of this title","children":[],"tail":". Except for an individual required to be licensed or registered under this part, the document must authorize service in the capacity for which the holder of the document is engaged or employed."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e63-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On a vessel to which section 10306 or 10503 of this title does not apply, an individual required by this section to hold a merchant mariner’s document must exhibit it to the master of the vessel before the individual may be employed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e64-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8701/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person (including an individual) violating this section is liable to the United States Government for a civil penalty of $500.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6866e65-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/554"},"text":"97 Stat. 554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/364/tIV/s402/12/A"},"text":"Pub. L. 98–364, title IV, § 402(12)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/449"},"text":"98 Stat. 449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/640/s11/c"},"text":"Pub. L. 99–640, § 11(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3550"},"text":"100 Stat. 3550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s731"},"text":"Pub. L. 104–324, title VII, § 731","children":[],"tail":", title XI, § 1104(e), "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3940"},"text":"110 Stat. 3940","children":[],"tail":", 3967; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIII/s324/b"},"text":"Pub. L. 107–295, title III, § 324(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2104"},"text":"116 Stat. 2104","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6866e66-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6866e67-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6866e68-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8701","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:444","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:643","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:643a","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:672","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8701 requires an individual to have a merchant mariner’s document before that individual can be engaged or employed on certain vessels.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) makes this documentation requirement applicable to United States merchant vessels of at least 100 gross tons except for certain inland vessels and barges, fishing or whaling vessels, yachts, and, in certain circumstances, to sailing school vessels or oceanographic research vessels.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) prohibits the engagement or employment of an individual required to have a document prescribed under section 7302 if the individual does not have one. Except for licensed or registered individuals, the document must specify the capacity in which the individual is engaged or employed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) requires an individual to exhibit the required document to the master, if not otherwise required to do so in some other manner before that individual may be employed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) prescribes the penalty for violation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6866e69-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6866e6a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":" added par. (9) and redesignated former par. (9) as (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s731/1"},"text":"Pub. L. 104–324, § 731(1)","children":[],"tail":", inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “100 gross tons” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s731/2"},"text":"Pub. L. 104–324, § 731(2)","children":[],"tail":", inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “1,600 gross tons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s1104/e"},"text":"Pub. L. 104–324, § 1104(e)","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/640"},"text":"Pub. L. 99–640","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364/s402/12/A/i"},"text":"Pub. L. 98–364, § 402(12)(A)(i)","children":[],"tail":", substituted “fishing, fish tender, or whaling” for “fishing or whaling”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364/s402/12/A/ii"},"text":"Pub. L. 98–364, § 402(12)(A)(ii)","children":[],"tail":"– (iv), added pars. (6) and (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6866e6b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6866e6c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Non-Operating Individual","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8313(a), (b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4697"},"text":"134 Stat. 4697","children":[],"tail":", 4698, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11516"},"text":"Pub. L. 117–263, div. K, title CXV, § 11516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4141"},"text":"136 Stat. 4141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7302"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1759"},"text":"139 Stat. 1759","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dG/tLXXIII/s7302"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the department in which the Coast Guard is operating shall not enforce ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s8701"},"text":"section 8701 of title 46","children":[],"tail":", United States Code, with respect to the following:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vessel with respect to individuals, other than crew members required by the Certificate of Inspection or to ensure the safe navigation of the vessel and not a member of the steward’s department, engaged on board for the sole purpose of carrying out spill response activities, salvage, marine firefighting, or commercial diving business or functions from or on any vessel, including marine firefighters, spill response personnel, salvage personnel, and commercial divers and diving support personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An offshore supply vessel, an industrial vessel (as such term is defined in section 90.10–16 of title 46, Code of Federal Regulations), or other similarly engaged vessel with respect to persons engaged in the business of the ship on board the vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting or executing the industrial business or function of the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" brief periods to conduct surveys or investigations, assess crew competence, conduct vessel trials, provide extraordinary security resources, or similar tasks not traditionally performed by the vessel crew; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing maintenance tasks on equipment under warranty, or on equipment not owned by the vessel owner, or maintenance beyond the capability of the vessel crew to perform; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not the master or crew members required by the certificate of inspection and not a member of the steward’s department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition in subsection (a) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2027-01-01"},"text":"January 1, 2027","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
