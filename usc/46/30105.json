{"tag":"section","attrib":{"id":"idf6a0adfd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30105"},"text":null,"children":[{"tag":"num","attrib":{"value":"30105"},"text":"§ 30105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on recovery by non-citizens and non-resident aliens for incidents in waters of other countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a0adfe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “continental shelf” has the meaning given that term in article I of the 1958 Convention on the Continental Shelf.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0adff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c), a civil action for maintenance and cure or for damages for personal injury or death may not be brought under a maritime law of the United States if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ae00-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual suffering the injury or death was not a citizen or permanent resident alien of the United States at the time of the incident giving rise to the action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ae01-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the incident occurred in the territorial waters or waters overlaying the continental shelf of a country other than the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ae02-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual suffering the injury or death was employed at the time of the incident by a person engaged in the exploration, development, or production of offshore mineral or energy resources, including drilling, mapping, surveying, diving, pipelaying, maintaining, repairing, constructing, or transporting supplies, equipment, or personnel, but not including transporting those resources by a vessel constructed or adapted primarily to carry oil in bulk in the cargo spaces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ae03-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (b) does not apply if the individual bringing the action establishes that a remedy is not available under the laws of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ae04-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the country asserting jurisdiction over the area in which the incident occurred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ae05-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the country in which the individual suffering the injury or death maintained citizenship or residency at the time of the incident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a0ae06-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1510"},"text":"120 Stat. 1510","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a0ae07-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a0ae08-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a0ae09-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30105(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:688(b)(1) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1915-03-04/ch153/s20/b"},"text":"Mar. 4, 1915, ch. 153, § 20(b)","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/pl/97/389/tV/s503/a/2"},"text":"Pub. L. 97–389, title V, § 503(a)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 29, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1955"},"text":"96 Stat. 1955","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30105(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:688(b)(1) (less last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30105(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:688(b)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before paragraph (1), the words “civil action” are substituted for “action” for consistency with rule 2 of the Federal Rules of Civil Procedure (28 App. U.S.C.). The words “under subsection (a) of this section or under any other” are omitted as unnecessary. In paragraph (2), the words “its territories, or possessions” are omitted as unnecessary because of the definition of “United States” in chapter 1 of the revised title. In paragraph (3), the word “person” is substituted for “enterprise” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6a0ae0a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6a0ae0b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The 1958 Convention on the Continental Shelf, referred to in subsec. (a), was done at Geneva, ","children":[{"tag":"date","attrib":{"date":"1958-04-29"},"text":"April 29, 1958","children":[],"tail":", and entered into force for the United States, "},{"tag":"date","attrib":{"date":"1964-06-10"},"text":"June 10, 1964","children":[],"tail":". See 15 UST 471; TIAS 5578."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
