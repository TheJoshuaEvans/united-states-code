{"tag":"section","attrib":{"id":"idf68d9a45-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10601"},"text":null,"children":[{"tag":"num","attrib":{"value":"10601"},"text":"§ 10601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68d9a46-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before proceeding on a voyage, the owner, charterer, or managing operator, or a representative thereof, including the master or individual in charge, of a fishing vessel, fish processing vessel, or fish tender vessel shall make a fishing agreement in writing with each seaman employed on board if the vessel is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68d9a47-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 20 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68d9a48-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a voyage from a port in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9a49-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The agreement shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68d9a4a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10601/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the period of effectiveness of the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68d9a4b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10601/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the terms of any wage, share, or other compensation arrangement peculiar to the fishery in which the vessel will be engaged during the period of the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68d9a4c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10601/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a seaman employed on a vessel that is a catcher processor or fish processing vessel that employs more than 25 crewmembers, include a requirement that each crewmember shall be served not less than three meals a day that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68d9a4d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10601/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" total not less than 3,100 calories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68d9a4e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10601/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include adequate water and minerals in accordance with the United States Recommended Daily Allowances; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68d9a4f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10601/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include other agreed terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68d9a50-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/424/s6/a"},"text":"Pub. L. 100–424, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1591"},"text":"102 Stat. 1591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s739"},"text":"Pub. L. 104–324, title VII, § 739","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3942"},"text":"110 Stat. 3942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s441/a"},"text":"Pub. L. 107–295, title IV, § 441(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2131"},"text":"116 Stat. 2131","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11526"},"text":"Pub. L. 117–263, div. K, title CXV, § 11526","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4145"},"text":"136 Stat. 4145","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68d9a51-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68d9a52-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68d9a53-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10601","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:531","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68d9a54-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68d9a55-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/s441/a"},"text":"Pub. L. 107–295, § 441(a)","children":[],"tail":", (b)(1), in introductory provisions, inserted “owner, charterer, or managing operator, or a representative thereof, including the” after “on a voyage, the” and comma after “individual in charge” and substituted “employed” for “enployed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/s441/b/2"},"text":"Pub. L. 107–295, § 441(b)(2)","children":[],"tail":", (3), redesignated subsec. (c) as (b) and struck out former subsec. (b) which read as follows: “The agreement shall be signed also by the owner of the vessel.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “20 gross tons”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf68d9a56-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf68d9a57-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Agreements Deemed Compliant","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s441/c"},"text":"Pub. L. 107–295, title IV, § 441(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2131"},"text":"116 Stat. 2131","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dH/s137/a"},"text":"Pub. L. 108–199, div. H, § 137(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/442"},"text":"118 Stat. 442","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/199/dH/s137/a"},"text":"“An agreement that complies with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s10601/a"},"text":"section 10601(a) of title 46","children":[],"tail":", United States Code, as herein amended, is hereby deemed to have been in compliance with subsections (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s10601"},"text":"section 10601 of title 46","children":[],"tail":", United States Code, as in effect prior to "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dH/s137/b"},"text":"Pub. L. 108–199, div. H, § 137(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/442"},"text":"118 Stat. 442","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/199/dH/s137/b"},"text":"“The amendments made by subsection (a) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/s441/c"},"text":"section 441(c) of Pub. L. 107–295","children":[],"tail":", set out above] apply to all proceedings pending on or commenced after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":"].”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
