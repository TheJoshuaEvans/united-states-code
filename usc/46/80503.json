{"tag":"section","attrib":{"id":"idf70bf146-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80503"},"text":null,"children":[{"tag":"num","attrib":{"value":"80503"},"text":"§ 80503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority of the Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf70bf147-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the department in which the Coast Guard is operating shall carry out the Convention and this chapter in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70bf148-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe regulations to carry out this chapter. The regulations shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf70bf149-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures for testing, inspecting, and initially approving containers and designs for containers, including procedures for attaching, invalidating, and removing safety approval plates for containers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70bf14a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures to be followed by the owners of containers for the periodic examination of containers as provided in the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70bf14b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a method for developing, collecting, and disseminating information about container safety and the international transport of containers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70bf14c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety Approval Plates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the owner of a container without a safety approval plate establishes that the container satisfies the standards of the Convention, the Secretary may authorize a safety approval plate to be attached to the container.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70bf14d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Schedule of Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may prescribe a schedule of fees for services performed by the Secretary, or by a person delegated authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s80506"},"text":"section 80506 of this title","children":[],"tail":", for the testing, inspection, and initial approval of containers and container designs."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70bf14e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Encouraging Intermodal Transport","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the maximum extent possible, the Secretary shall encourage the development and use of intermodal transport, using containers built to facilitate economical, safe, and expeditious handling of containerized cargo without intermediate reloading when it is being transported over land, air, and sea areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf70bf14f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s11"},"text":"Pub. L. 109–304, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1694"},"text":"120 Stat. 1694","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf70bf150-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf70bf151-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf70bf152-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80503(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1503(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/208/s4/a"},"text":"Pub. L. 95–208, § 4(a)","children":[],"tail":", (b), (c)(1), (3), (e), "},{"tag":"html:span","attrib":{},"text":"Dec. 13, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1476"},"text":"91 Stat. 1476","children":[],"tail":", 1477."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80503(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1503(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80503(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1503(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80503(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1503(c)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80503(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1503(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “On and after the date the instrument of ratification is deposited by the United States in accordance with the provisions of article VII of the Convention,” and “and, unless an earlier date is specifically provided,” are omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before paragraph (1), the words “as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1977-12-13"},"text":"December 13, 1977","children":[],"tail":"” are omitted as obsolete. The word “prescribe” is substituted for “promulgate, and from time to time, amend” for consistency in the revised title and with other titles of the United States Code and to eliminate unnecessary words. The words “he deems necessary for such enforcement” and “among other things” are omitted as unnecessary. In paragraph (1), the words “existing” and “new” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (c) and (d), the words “At any time after ","children":[{"tag":"date","attrib":{"date":"1977-12-13"},"text":"December 13, 1977","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
