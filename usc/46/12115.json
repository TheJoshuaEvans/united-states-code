{"tag":"section","attrib":{"id":"idf6949f44-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12115"},"text":null,"children":[{"tag":"num","attrib":{"value":"12115"},"text":"§ 12115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary endorsement for vessels procured outside the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6949f45-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary and the Secretary of State, acting jointly, may provide for the issuance of a certificate of documentation with an appropriate endorsement for a vessel procured outside the United States and meeting the ownership requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12103"},"text":"section 12103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949f46-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Activity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to limitations the Secretary may prescribe, a vessel documented under this section may proceed to the United States and engage en route in foreign trade or trade with Guam, American Samoa, Wake, Midway, or Kingman Reef.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949f47-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of United States Jurisdiction and Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel documented under this section is subject to the jurisdiction and laws of the United States. However, if the Secretary considers it to be in the public interest, the Secretary may suspend for a period of not more than 6 months the application of a vessel inspection law carried out by the Secretary or regulations prescribed under that law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949f48-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12115/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Surrender of Certificate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On the vessel’s arrival in the United States, the certificate of documentation shall be surrendered as provided by regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6949f49-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1498"},"text":"120 Stat. 1498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6949f4a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6949f4b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6949f4c-2930-11f1-96a8-b9bd2a0a99b5"},"tex