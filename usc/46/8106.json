{"tag":"section","attrib":{"id":"idf683fc81-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106"},"text":null,"children":[{"tag":"num","attrib":{"value":"8106"},"text":"§ 8106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Riding gangs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf683fc82-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The owner or managing operator of a freight vessel of the United States on voyages covered by the International Convention for Safety of Life at Sea, 1974 (32 UST 47m) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf683fc83-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf683fc84-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to subsection (d), each riding gang member on the vessel—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf683fc85-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a United States citizen or an alien lawfully admitted to the United States for permanent residence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf683fc86-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possesses a United States nonimmigrant visa for individuals desiring to enter the United States temporarily for business, employment-related and personal identifying information, and any other documentation required by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf683fc87-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all required documentation for such member is kept on the vessel and available for inspection by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf683fc88-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each riding gang member is identified on the vessel’s crew list;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fc89-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf683fc8a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner or managing operator attests in a certificate that the background of each riding gang member has been examined and found to be free of any credible information indicating a material risk to the security of the vessel, the vessel’s cargo, the ports the vessel visits, or other individuals onboard the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf683fc8b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the background check consisted of a search of all information reasonably available to the owner or managing operator in the riding gang member’s country of citizenship and any other country in which the riding gang member works, receives employment referrals, or resides;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf683fc8c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the certificate required under subparagraph (A) is kept on the vessel and available for inspection by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf683fc8d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information derived from any such background check is made available to the Secretary upon request;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fc8e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each riding gang member, while on board the vessel, is subject to the same random chemical testing and reporting regimes as crew members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fc8f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each such riding gang member receives basic safety familiarization and basic safety training approved by the Coast Guard as satisfying the requirements for such training under the International Convention of Training, Certification, and Watchkeeping for Seafarers, 1978;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fc90-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prevent from boarding the vessel, or cause the removal from the vessel at the first available port, and disqualify from future service on board any other vessel owned or operated by that owner or operator, any riding gang member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf683fc91-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has been convicted in any jurisdiction of an offense described in paragraph (2) or (3) of section 7703;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf683fc92-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose license, certificate of registry, or merchant mariner’s document has been suspended or revoked under section 7704; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf683fc93-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who otherwise constitutes a threat to the safety of the vessel;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fc94-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure and certify to the Secretary that the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf683fc95-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of riding gang members on board a freight vessel, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf683fc96-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals in addition to crew permitted under section 3304,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"does not exceed 12;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fc97-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that every riding gang member is employed on board the vessel under conditions that meet or exceed the minimum international standards of all applicable international labor conventions to which the United States is a party, including all of the merchant seamen protection and relief provided under United States law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fc98-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that each riding gang member—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf683fc99-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is supervised by an individual who holds a license issued under chapter 71; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf683fc9a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only performs work in conjunction with individuals who hold merchant mariners documents issued under chapter 73 and who are part of the vessel’s crew.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf683fc9b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permitted Work","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (f), a riding gang member on board a vessel to which subsection (a) applies who is neither a United States citizen nor an alien lawfully admitted to the United States for permanent residence may not perform any work on board the vessel other than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf683fc9c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work in preparation of a vessel entering a shipyard located outside of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fc9d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completion of the residual repairs after departing a shipyard located outside of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fc9e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical in-voyage repairs, in excess of any repairs that can be performed by the vessel’s crew, in order to advance the vessel’s useful life without having to actually enter a shipyard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf683fc9f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Workday Limit.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf683fca0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum number of days in any calendar year that the owner or operator of a vessel to which subsection (a) applies may employ on board riding gang members who are neither United States citizens nor aliens lawfully admitted to the United States for permanent residence for work on board that vessel is 60 days. If the vessel is at sea on the 60th day, each riding gang member shall be discharged from the vessel at the next port of call reached by the vessel after the date on which the 60-workday limit is reached.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fca1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Calculation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of calculating the 60-workday limit under this subsection, each day worked by a riding gang member who is neither a United States citizen nor an alien lawfully admitted to the United States for permanent residence shall be counted against the limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf683fca2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions for Warranty Work.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf683fca3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (b), (c), (e), and (f) do not apply to a riding gang member employed exclusively to perform, and who performs only, work that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf683fca4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" customarily performed by original equipment manufacturers’ technical representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf683fca5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required by a manufacturer’s warranty on specific machinery and equipment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf683fca6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required by a contractual guarantee or warranty on actual repairs performed in a shipyard located outside of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fca7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Citizenship requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a)(1)(A) applies only to a riding gang member described in paragraph (1) who is on the vessel when it calls at a United States port.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf683fca8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recordkeeping","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to the requirements of subsection (a), the owner or managing operator of a vessel to which subsection (a) applies shall ensure that all information necessary to ensure compliance with this section, as determined by the Secretary, is entered into the vessel’s official logbook required by chapter 113.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf683fca9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to Employ Qualified Available U.S. Citizens or Residents.—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf683fcaa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The owner or operator of a vessel to which subsection (a) applies may not employ a riding gang member who is neither a United States citizen nor an alien lawfully admitted to the United States for permanent residence to perform work described in subsection (b) unless the owner or operator determines, in accordance with procedures established by the Secretary to carry out section 8103(b)(3)(C), that there is not a sufficient number of United States citizens or individuals lawfully admitted to the United States for permanent residence who are qualified and available for the work for which the riding gang member is to be employed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fcab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A violation of paragraph (1) is punishable by a civil penalty of not more than $10,000 for each day during which the violation continues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fcac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum amount of a civil penalty for a violation under this subsection shall be $100,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fcad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In determining the amount of the penalty, the Secretary shall take into account the nature, circumstances, extent, and gravity of the violation committed and, with respect to the violator, the degree of culpability, the history of prior offenses, the ability to pay, and such other matters as justice may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fcae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8106/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compromise, modification, and remittal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may compromise, modify, or remit, with or without conditions, any civil penalty imposed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf683fcaf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIII/s312/a"},"text":"Pub. L. 109–241, title III, § 312(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/530"},"text":"120 Stat. 530","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3546/g"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3546(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2326"},"text":"132 Stat. 2326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf683fcb0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf683fcb1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf683fcb2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" added par. (3) and struck out former par. (3) which related to continuing violations in fiscal years 2006 and 2007 and after fiscal year 2007."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf683fcb3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf683fcb4-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"International Convention for Safety of Life at Sea","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For International Conventions for the Safety of Life at Sea to which the United States has been a party, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1602"},"text":"section 1602 of Title 33","children":[],"tail":", Navigation and Navigable Waters, and notes thereunder."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
