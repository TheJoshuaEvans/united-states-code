{"tag":"section","attrib":{"id":"idf6a2f66b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30524"},"text":null,"children":[{"tag":"num","attrib":{"value":"30524"},"text":"§ 30524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit of liability for personal injury or death","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a2f66c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30524/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies only to seagoing vessels, but does not apply to pleasure yachts, tugs, towboats, towing vessels, tank vessels, fishing vessels, fish tender vessels, canal boats, scows, car floats, barges, lighters, or nondescript vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a2f66d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30524/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Liability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the amount of the vessel owner’s liability determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s30523"},"text":"section 30523 of this title","children":[],"tail":" is insufficient to pay all losses in full, and the portion available to pay claims for personal injury or death is less than $420 times the tonnage of the vessel, that portion shall be increased to $420 times the tonnage of the vessel. That portion may be used only to pay claims for personal injury or death."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a2f66e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30524/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Calculation of Tonnage","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under subsection (b), the tonnage of a self-propelled vessel is the gross tonnage without deduction for engine room, and the tonnage of a sailing vessel is the tonnage for documentation. However, space for the use of seamen is excluded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a2f66f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30524/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claims Arising on Distinct Occasions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Separate limits of liability apply to claims for personal injury or death arising on distinct occasions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a2f670-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30524/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Privity or Knowledge","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a claim for personal injury or death, the privity or knowledge of the master or the owner’s superintendent or managing agent, at or before the beginning of each voyage, is imputed to the owner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a2f671-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1513"},"text":"120 Stat. 1513","children":[],"tail":", § 30506; renumbered § 30524 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11503/a/3"},"text":"Pub. L. 117–263, div. K, title CXV, § 11503(a)(3)","children":[],"tail":", (f)(3), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4130"},"text":"136 Stat. 4130","children":[],"tail":", 4131.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a2f672-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a2f673-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a2f674-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30506(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:183(f) (related to 46 App.:183(b)–(e)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30506(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:183(b) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 4283(b) (1st sentence); ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-08-29/ch804/s1"},"text":"Aug. 29, 1935, ch. 804, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/960"},"text":"49 Stat. 960","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1936-06-05/ch521/s1"},"text":"June 5, 1936, ch. 521, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1479"},"text":"49 Stat. 1479","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/498/tII/s213/a"},"text":"Pub. L. 98–498, title II, § 213(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2306"},"text":"98 Stat. 2306","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30506(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:183(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 4283(c)–(f) (related to R.S. § 4283(b)–(e)); ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-08-29/ch804/s1"},"text":"Aug. 29, 1935, ch. 804, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/960"},"text":"49 Stat. 960","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1936-06-05/ch521/s1"},"text":"June 5, 1936, ch. 521, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1480"},"text":"49 Stat. 1480","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30506(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:183(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30506(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:183(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is written as an application provision rather than as a definition to be more direct and to avoid having to repeat the word “seagoing” throughout the section. The words “fishing vessel, fish tender vessel” are substituted for “fishing vessels or their tenders” for clarity. The words “nondescript vessel” are substituted for “nondescript self-propelled vessels” and “nondescript non-self-propelled vessels” to eliminate unnecessary words. The words “self-propelled lighters” are omitted as covered by “lighter”. The words “even though the same may be seagoing vessels within the meaning of such term as used in section 188 of this Appendix, as amended” are omitted as unnecessary. This provision is restated also at section 30508(a) of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “is such that the portion available to pay claims for personal injury or death” are substituted for “is insufficient to pay all losses in full, and the portion of such amount applicable to the payment of losses in respect of loss of life or bodily injury” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “self-propelled vessel” are substituted for “steam or motor vessel”, and the words “tonnage for documentation” are substituted for “registered tonnage”, for consistency in the revised title. The words “space for the use of seamen” are substituted for “space occupied by seamen or apprentices and appropriated to their use” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “Separate limits of liability apply” are substituted for “The owner . . . shall be liable . . . to the same extent as if no other loss of life or bodily injury had arisen” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “the privity or knowledge . . . is imputed to the owner” are substituted for “shall be deemed conclusively the privity or knowledge of the owner” for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6a2f675-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6a2f676-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11503/a/3"},"text":"Pub. L. 117–263, § 11503(a)(3)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s30506"},"text":"section 30506 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11503/f/3"},"text":"Pub. L. 117–263, § 11503(f)(3)","children":[],"tail":", substituted “section 30523” for “section 30505”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
