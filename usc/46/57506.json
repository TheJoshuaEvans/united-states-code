{"tag":"section","attrib":{"id":"idf6f1b34e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57506"},"text":null,"children":[{"tag":"num","attrib":{"value":"57506"},"text":"§ 57506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum selling price of vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f1b34f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel constructed under this subtitle or the Merchant Marine Act, 1936, may not be sold by the Secretary of Transportation for less than the price specified in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b350-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation in Foreign Trade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the vessel is to be operated in foreign trade, the minimum price is the estimated foreign construction cost (exclusive of national defense features) determined as of the date the construction contract is executed, less depreciation under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b351-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation in Domestic Trade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the vessel is to be operated in domestic trade, the minimum price is the cost of construction in the United States (exclusive of national defense features), less depreciation under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b352-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Depreciation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Depreciation under subsections (b) and (c) shall be based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f1b353-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57506/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 25-year life for dry-cargo and passenger vessels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b354-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57506/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 20-year life for tankers and other bulk liquid carrier vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b355-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1665"},"text":"120 Stat. 1665","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b356-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f1b357-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f1b358-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"57506","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1195 (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title VII, § 705 (last sentence), as added "},{"tag":"html:a","attrib":{"href":"/us/act/1939-08-04/ch417/s11/a"},"text":"Aug. 4, 1939, ch. 417, § 11(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/1185"},"text":"53 Stat. 1185","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/86/518/s1"},"text":"Pub. L. 86–518, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"June 12, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/216"},"text":"74 Stat. 216","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/107"},"text":"Pub. L. 97–31, § 12(107)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/163"},"text":"95 Stat. 163","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1125 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/86/518/s9"},"text":"Pub. L. 86–518, § 9","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"June 12, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/217"},"text":"74 Stat. 217","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) is substituted for “less depreciation based on a twenty-five year life” because of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/518/s9"},"text":"section 9 of Public Law 86–518","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"1960-06-12"},"text":"June 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/217"},"text":"74 Stat. 217","children":[],"tail":"), which provided that “Nothing in any amendment made by this Act [including section 1 substituting ‘twenty-five’ for ‘twenty’ in 46 App. U.S.C. 1195] shall operate or be interpreted to change from twenty to twenty-five years the provisions of the Merchant Marine Act, 1936, as amended, relating to the commercial expectancy or period of depreciation of any tanker or other liquid bulk carrier.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6f1b359-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6f1b35a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Merchant Marine Act, 1936, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"act June 29, 1936, ch. 858","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1985"},"text":"49 Stat. 1985","children":[],"tail":", which was classified principally to chapter 27 (§ 1101 et seq.) of the former Appendix to this title. The Act, with the exception of title V, most of title VI, and sections 301, 801, 802, 809(a), and 909 thereof, was repealed and restated, mainly in this subtitle, by "},{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":", §§ 8, 19, "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1555"},"text":"120 Stat. 1555","children":[],"tail":", 1710. Title V and sections 301 and 909 of the Act are set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53101"},"text":"section 53101 of this title","children":[],"tail":". Those portions of title VI not repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" and sections 802 and 809(a) of the Act were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s313/a"},"text":"Pub. L. 114–120, title III, § 313(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/58"},"text":"130 Stat. 58","children":[],"tail":". Section 801 of the Act was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s57522"},"text":"section 57522 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s313/c/1/A"},"text":"Pub. L. 114–120, title III, § 313(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/58"},"text":"130 Stat. 58","children":[],"tail":". For complete classification of the Act to the Code, see Tables. For disposition of sections of the former Appendix to Title 46, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
