{"tag":"section","attrib":{"id":"idf6d047c2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105"},"text":null,"children":[{"tag":"num","attrib":{"value":"53105"},"text":"§ 53105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligations and rights under operating agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d047c3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation of Vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An operating agreement under this chapter shall require that, during the period a vessel is operating under the agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d047c4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d047c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be operated exclusively in the foreign commerce or, except as provided in paragraph (2), in mixed foreign commerce and domestic trade allowed under a registry endorsement issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12111"},"text":"section 12111 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not otherwise be operated in the coastwise trade;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a vessel, other than a replacement vessel under subsection (f), first covered by an operating agreement after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2018, the vessel shall not be operated in the transportation of cargo between points in the United States and its territories either directly or via a foreign port; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel shall be documented under chapter 121 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Payments by Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d047ca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An operating agreement under this chapter shall require, subject to the availability of appropriations, that the Secretary make a payment each fiscal year to the contractor in accordance with section 53106.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operating agreement is obligation of united states government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An operating agreement under this chapter constitutes a contractual obligation of the United States Government to pay the amounts provided for in the agreement to the extent of actual appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documentation Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each vessel covered by an operating agreement (including an agreement terminated under section 53104(c)(2)) shall remain documented under chapter 121 of this title, until the date the operating agreement would terminate according to its terms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Security Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d047ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contractor with respect to an operating agreement (including an agreement terminated under section 53104(c)(2)) shall continue to be bound by the provisions of section 53107 until the date the operating agreement would terminate according to its terms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emergency preparedness agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All terms and conditions of an Emergency Preparedness Agreement entered into under section 53107 shall remain in effect until the date the operating agreement would terminate according to its terms, except that the terms of such Emergency Preparedness Agreement may be modified by the mutual consent of the contractor, the Secretary of Transportation, and the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047d0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Operating Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contractor under an operating agreement may transfer the agreement (including all rights and obligations under the operating agreement) to any person that is eligible to enter into the operating agreement under this chapter if the Secretary and the Secretary of Defense determine that the transfer is in the best interests of the United States. A transaction shall not be considered a transfer of an operating agreement if the same legal entity with the same vessels remains the contracting party under the operating agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53105/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Replacement Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contractor may replace a vessel under an operating agreement with another vessel that is eligible to be included in the Fleet under section 53102(b), if the Secretary, in conjunction with the Secretary of Defense, approves the replacement of the vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d047d2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dC/tXXXV/s3531/a"},"text":"Pub. L. 108–136, div. C, title XXXV, § 3531(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1812"},"text":"117 Stat. 1812","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/4"},"text":"Pub. L. 109–304, § 13(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1701"},"text":"120 Stat. 1701","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dC/tXXXV/s3502/a"},"text":"Pub. L. 109–364, div. C, title XXXV, § 3502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2514"},"text":"120 Stat. 2514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3526/f"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3526(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/602"},"text":"122 Stat. 602","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dC/tXXXV/s3508/e"},"text":"Pub. L. 112–239, div. C, title XXXV, § 3508(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2225"},"text":"126 Stat. 2225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dC/tXXXV/s3503/a"},"text":"Pub. L. 115–91, div. C, title XXXV, § 3503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1911"},"text":"131 Stat. 1911","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d047d3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6d047d4-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6d047d5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2018, referred to in subsec. (a)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6d047d6-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3503/a/1"},"text":"Pub. L. 115–91, § 3503(a)(1)","children":[],"tail":", inserted “, except as provided in paragraph (2),” after “in the foreign commerce or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3503/a/2"},"text":"Pub. L. 115–91, § 3503(a)(2)","children":[],"tail":"–(4), added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s3508/e/1"},"text":"Pub. L. 112–239, § 3508(e)(1)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, subsec. (e) related to transfer of operating agreements, with limitation based on citizenship of recipient."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s3508/e/2"},"text":"Pub. L. 112–239, § 3508(e)(2)","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, text read as follows: “A contractor may replace a vessel under an operating agreement with another vessel that is eligible to be included in the Fleet under section 53102(b), if the Secretary, in conjunction with the Secretary of Defense, approves replacement of the vessel.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":"” for “section 2 of the Shipping Act, 1916 (46 U.S.C. App. 802),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/4/A"},"text":"Pub. L. 109–304, § 13(a)(4)(A)","children":[],"tail":", substituted “section 12111” for “section 12105”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364"},"text":"Pub. L. 109–364","children":[],"tail":" designated existing provisions as par. (1), inserted heading and aligned margins in par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/4/B"},"text":"Pub. L. 109–304, § 13(a)(4)(B)","children":[],"tail":", substituted “approves” for “approve”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
