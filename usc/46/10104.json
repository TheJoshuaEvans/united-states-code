{"tag":"section","attrib":{"id":"idf688b897-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104"},"text":null,"children":[{"tag":"num","attrib":{"value":"10104"},"text":"§ 10104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to report sexual offenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf688b898-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mandatory Reporting by Responsible Entity of a Vessel.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b899-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The responsible entity of a vessel shall report to the Commandant any complaint or incident of sexual harassment or sexual assault in violation of employer policy or law or harassment, of which such entity is made aware.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b89a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A responsible entity of a vessel who knowingly fails to report in compliance with paragraph (1) is liable to the United States Government for a civil penalty of not more than $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b89b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Procedures.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b89c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsible entity of a vessel reporting","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report required under subsection (a) shall be made immediately after the responsible entity of a vessel gains knowledge of a sexual assault or sexual harassment incident by the fastest telecommunication channel available to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf688b89d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single entity in the Coast Guard designated by the Commandant to receive such reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b89e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate officer or agency of the government of the country in whose waters the incident occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b89f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such shall include, to the best of the knowledge of the individual making the report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf688b8a0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, official position or role in relation to the vessel, and contact information of such individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b8a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and official number of the documented vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b8a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time and date of the incident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b8a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic position or location of the vessel when the incident occurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b8a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief description of the alleged sexual harassment or sexual assault being reported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b8a5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Receiving reports; collection of information.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf688b8a6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Receiving reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to reports submitted under subsection (a), the Commandant—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf688b8a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may establish additional reporting procedures, including procedures for receiving reports through—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf688b8a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single telephone number that is continuously manned at all times; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf688b8a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a single email address that is continuously monitored; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf688b8aa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use procedures that include preserving evidence in such reports and providing emergency service referrals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b8ab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection of information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After receipt of the report made under subsection (a), the Coast Guard shall collect information related to the identity of each alleged victim, alleged perpetrator, and any witnesses identified in the report through means designed to protect, to the extent practicable, the personal identifiable information of such individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b8ac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subpoena Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b8ad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may compel the testimony of witnesses and the production of any evidence by subpoena to determine compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b8ae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdictional limits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The jurisdictional limits of a subpoena issued under this section are the same as, and are enforceable in the same manner as, subpoenas issued under chapter 63 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b8af-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Company After-action Summary.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b8b0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A responsible entity of a vessel that makes a report under subsection (a) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf688b8b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Commandant a document with detailed information to describe the actions taken by such entity after becoming aware of the sexual assault or sexual harassment incident, including the results of any investigation into the complaint or incident and any action taken against the offending individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b8b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such submission not later than 10 days after such entity made the report under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b8b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A responsible entity of a vessel that fails to comply with paragraph (1) is liable to the United States Government for a civil penalty of $25,000 and $500 shall be added for each day of noncompliance, except that the total amount of a penalty with respect to a complaint or incident shall not exceed $50,000 per violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b8b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investigatory Audit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall periodically perform an audit or other systematic review of the submissions made under this section to determine if there were any failures to comply with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b8b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability; Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b8b6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may issue regulations to implement the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b8b7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interim reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any report required to be made to the Commandant under this section shall be made to the Coast Guard National Command Center, until regulations implementing the procedures required by this section are issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b8b8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Responsible Entity of a Vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “responsible entity of a vessel” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b8b9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner, master, or managing operator of a documented vessel engaged in commercial service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b8ba-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employer of a seafarer on such a vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b8bb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Harassment Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “harassment” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b8bc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf688b8bd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" unwelcome remarks about an individual’s race, color, religion, sex, national origin, age, disability, genetic information, or other physical or physiological attribute, or other unwelcome verbal or physical conduct towards an individual based on 1 or more of those categories, as prohibited by any Federal law, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf688b8be-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/h/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title VII of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"42 U.S.C. 2000e","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf688b8bf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/h/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Age Discrimination in Employment Act of 1967 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s621"},"text":"29 U.S.C. 621","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf688b8c0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/h/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf688b8c1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/h/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title II of the Genetic Information Nondisclosure Act ","children":[{"tag":"ref","attrib":{"idref":"fn002014"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002014"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000ff"},"text":"42 U.S.C. 2000ff","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b8c2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf688b8c3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/h/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submission to such remarks or conduct is made either explicitly or implicitly a term or condition of employment, pay, career, benefits, or entitlements of an individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf688b8c4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/h/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submission to or rejection of such remarks or conduct by an individual is used as the basis for decisions affecting that individual’s job, pay, career, benefits, or entitlements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf688b8c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/h/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such remarks or conduct have the purpose or effect of unreasonably interfering with an individual’s work performance; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b8c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such remarks or conduct are so severe or pervasive that a reasonable person would perceive, and the alleged harassed individual does perceive, the environment as hostile or offensive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b8c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Response to Incidents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to impede the ability of the responsible entity of the vessel to take immediate personnel action in response to an incident described in subsection (a)(1) to preserve the safety and security of individuals on the vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b8c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Education and Outreach","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of the enactment of this Act, the Coast Guard, after consultation with the Equal Employment Opportunity Commission (referred to in this subsection as the “Commission”), shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68b28c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop and disseminate informational guidance to seafarers, vessel owners and operators, employers of seafarers, and other relevant stakeholders, which shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68b28ca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe, in general terms—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf68b28cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/j/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose, functions, and powers of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf68b28cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/j/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role of the Commission in addressing employment discrimination complaints; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68b28cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the publicly available websites and contact information for the Commission; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68b28ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10104/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available trainings or other presentations to inform seafarers of employment and anti-discrimination rights under the laws administered by the Coast Guard and the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68b28cf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/225/tII/s214/a/2"},"text":"Pub. L. 101–225, title II, § 214(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1914"},"text":"103 Stat. 1914","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVI/s11609"},"text":"Pub. L. 117–263, div. K, title CXVI, § 11609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4152"},"text":"136 Stat. 4152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7315"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7315","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1762"},"text":"139 Stat. 1762","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68b28d0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68b28d1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf68b28d2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title II of the Genetic Information Nondisclosure Act, referred to in subsec. (h)(1)(A)(iv), probably means title II of the Genetic Information Nondiscrimination Act of 2008, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/233"},"text":"Pub. L. 110–233","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-21"},"text":"May 21, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/905"},"text":"122 Stat. 905","children":[],"tail":", which is classified to chapter 21F (§ 2000ff et seq.) of Title 42, The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this Act, referred to in subsec. (j), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which enacted subsec. (j) of this section and was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf68b28d3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10104, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/561"},"text":"97 Stat. 561","children":[],"tail":", related to regulations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/225/s214/a/1"},"text":"Pub. L. 101–225, § 214(a)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68b28d4-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7315/1"},"text":"Pub. L. 119–60, § 7315(1)","children":[],"tail":", substituted “sexual harassment or sexual assault in violation of employer policy or law or harassment” for “harassment, sexual harassment, or sexual assault in violation of employer policy or law”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7315/2"},"text":"Pub. L. 119–60, § 7315(2)","children":[],"tail":", added subsecs. (h) to (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added subsecs. (a) to (g) and struck out former subsecs. (a) and (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) A master or other individual in charge of a documented vessel shall report to the Secretary a complaint of a sexual offense prohibited under chapter 109A of title 18, United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) A master or other individual in charge of a documented vessel who knowingly fails to report in compliance with this section is liable to the United States Government for a civil penalty of not more than $5,000.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
