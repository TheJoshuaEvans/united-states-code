{"tag":"section","attrib":{"id":"idf7071062-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70120"},"text":null,"children":[{"tag":"num","attrib":{"value":"70120"},"text":"§ 70120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In rem liability for civil penalties and certain costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7071063-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70120/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any vessel operated in violation of this chapter or any regulations prescribed under this chapter shall be liable in rem for any civil penalty assessed pursuant to section 70119 for such violation, and may be proceeded against for such liability in the United States district court for any district in which the vessel may be found.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7071064-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70120/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursable Costs of Service Providers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel shall be liable in rem for the reimbursable costs incurred by any service provider related to implementation and enforcement of this chapter and arising from a violation by the operator of the vessel of this chapter or any regulations prescribed under this chapter, and may be proceeded against for such liability in the United States district court for any district in which such vessel may be found.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7071065-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70120/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7071066-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70120/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “reimbursable costs” means costs incurred by any service provider acting in conformity with a lawful order of the Federal government or in conformity with the instructions of the vessel operator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7071067-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70120/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “service provider” means any port authority, facility or terminal operator, shipping agent, Federal, State, or local government agency, or other person to whom the management of the vessel at the port of supply is entrusted, for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf7071068-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70120/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services rendered to or in relation to vessel crew on board the vessel, or in transit to or from the vessel, including accommodation, detention, transportation, and medical expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7071069-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70120/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required handling of cargo or other items on board the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf707106a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/tVIII/s802/a/2"},"text":"Pub. L. 108–293, title VIII, § 802(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1078"},"text":"118 Stat. 1078","children":[],"tail":", § 70117; renumbered § 70120 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIX/s901"},"text":"Pub. L. 109–241, title IX, § 901","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), (3), "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/565"},"text":"120 Stat. 565","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/33/B"},"text":"Pub. L. 109–304, § 15(33)(B)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1705"},"text":"120 Stat. 1705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3529/c/1"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3529(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/603"},"text":"122 Stat. 603","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf707106b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf707106c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf707106d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/33/B"},"text":"Pub. L. 109–304, § 15(33)(B)","children":[],"tail":", (C). See 2006 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/33/B"},"text":"Pub. L. 109–304, § 15(33)(B)","children":[],"tail":", which directed renumbering identical to that made by "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/s901"},"text":"Pub. L. 109–241, § 901","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":". See Amendment note and Construction of 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s901"},"text":"Pub. L. 109–241, § 901","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s70117"},"text":"section 70117 of this title","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/s802/a/2"},"text":"Pub. L. 108–293, § 802(a)(2)","children":[],"tail":", as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/33/C"},"text":"Pub. L. 109–304, § 15(33)(C)","children":[],"tail":", which directed amendment identical to that made by "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/s901"},"text":"Pub. L. 109–241, § 901","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":". See Amendment note and Construction of 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s901"},"text":"Pub. L. 109–241, § 901","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3), substituted “section 70119” for “section 70120”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf707106e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf707106f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3529/c/1"},"text":"section 3529(c)(1) of Pub. L. 110–181","children":[],"tail":" to be treated as if never enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3529/c/2"},"text":"section 3529(c)(2) of Pub. L. 110–181","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s9504"},"text":"section 9504 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"