{"tag":"section","attrib":{"id":"idf6f3fcfc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58106"},"text":null,"children":[{"tag":"num","attrib":{"value":"58106"},"text":"§ 58106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Concerted discriminatory activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f3fcfd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contractor receiving an operating-differential subsidy, or a charterer under chapter 575 of this title, may not continue as a party to or conform to an agreement with another carrier by water, or engage in a practice in concert with another carrier by water, that is unjustly discriminatory or unfair to any other citizen of the United States operating a common carrier by water employing only vessels documented under the laws of the United States on an established trade route from and to a United States port.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f3fcfe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Government Payment Prohibited","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No payment or subsidy of any kind may be paid, directly or indirectly, out of funds of the United States Government to a contractor or charterer that has violated subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f3fcff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Action","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person whose business or property is injured by a violation of subsection (a) may bring a civil action in the district court of the United States for the district in which the defendant resides, is found, or has an agent. If the person prevails, the person shall be awarded—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f3fd00-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 times the damages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f3fd01-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs, including reasonable attorney fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f3fd02-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1672"},"text":"120 Stat. 1672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f3fd03-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f3fd04-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f3fd05-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"58106","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1227.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title VIII, § 810, "},{"tag":"html:a","attrib":{"href":"/us/stat/49/2015"},"text":"49 Stat. 2015","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “United States Government” are substituted for “United States or any agency of the United States” for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “bring a civil action” are substituted for “sue” for consistency in the revised title. The words “without respect to the amount in controversy” are omitted because ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1331"},"text":"section 1331 of title 28","children":[],"tail":" no longer contains a requirement of any particular amount in controversy for jurisdiction of civil actions arising under the laws of the United States. The words “If the person prevails” are added for clarity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
