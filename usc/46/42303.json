{"tag":"section","attrib":{"id":"idf6b3bf9b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42303"},"text":null,"children":[{"tag":"num","attrib":{"value":"42303"},"text":"§ 42303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information requests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b3bf9c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To further the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s42302/a"},"text":"section 42302(a) of this title","children":[],"tail":", the Federal Maritime Commission may order any person (including a common carrier, shipper, shippers’ association, ocean transportation intermediary, or marine terminal operator, or an officer, receiver, trustee, lessee, agent or employee thereof) to file with the Commission any periodic or special report, answers to questions, documentary material, or other information the Commission considers necessary or appropriate. The Commission may require the response to any such order to be made under oath. The response shall be provided in the form and within the time specified by the Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bf9d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subpoenas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In an investigation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s42302"},"text":"section 42302 of this title","children":[],"tail":", the Commission may subpoena witnesses and evidence."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bf9e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nondisclosure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the Commission may determine that any information submitted to it in response to a request under this section, or otherwise, shall not be disclosed to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b3bf9f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1552"},"text":"120 Stat. 1552","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b3bfa0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b3bfa1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b3bfa2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1710a(d)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/418/tX/s10002/d"},"text":"Pub. L. 100–418, title X, § 10002(d)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/1571"},"text":"102 Stat. 1571","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tI/s111/4"},"text":"Pub. L. 105–258, title I, § 111(4)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1911"},"text":"112 Stat. 1911","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “subpoena witnesses and evidence” are substituted for “issue subpoenas to compel the attendance and testimony of witnesses and the production of records or other evidence” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “in its discretion” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
