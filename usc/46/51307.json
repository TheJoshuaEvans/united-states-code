{"tag":"section","attrib":{"id":"idf6bfa69d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307"},"text":null,"children":[{"tag":"num","attrib":{"value":"51307"},"text":"§ 51307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Places of training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6bfa69e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may provide for the training of cadets at the United States Merchant Marine Academy—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bfa69f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on vessels owned, subsidized by, or contracted with the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa6a0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on other documented vessels, with the permission of the owner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa6a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in shipyards or plants and with industrial or educational organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa6a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on any other vessel considered by the Secretary to be necessary or appropriate or in the national interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bfa6a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sea Year Cadets on Certain Vessels.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bfa6a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require an operator of a vessel participating in the Maritime Security Program under chapter 531 of this title, the Cable Security Fleet under chapter 532 of this title, or the Tanker Security Fleet under chapter 534 of this title to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bfa6a5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry on each Maritime Security Program vessel, Cable Security Fleet vessel, or Tanker Security Fleet vessel 2 United States Merchant Marine Academy cadets, if available, on each voyage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bfa6a6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement and adhere to policies, programs, criteria, and requirements established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51322"},"text":"section 51322 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa6a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure to implement or adhere to requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Failure to implement or adhere to the policies, programs, criteria, and requirements referred to in paragraph (1) may, as determined by the Maritime Administrator, constitute a violation of an operating agreement entered into under chapter 531, 532, or 534 of this title and the Maritime Administrator may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bfa6a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the operator to take corrective actions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bfa6a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withhold payment due to the operator until the violation, as determined by the Maritime Administrator, has been remedied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa6aa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withheld payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any payment withheld pursuant to paragraph (2)(B) may be paid, upon a determination by the Maritime Administrator that the operator is in compliance with the policies, programs, criteria, and requirements referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bfa6ab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Sealift Command Vessels.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bfa6ac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), the Commander of the Military Sealift Command shall require an operator of a vessel in the United States Navy’s Military Sealift Command to carry on each such vessel 2 United States Merchant Marine Academy cadets, if available, on each voyage, if the vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bfa6ad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is flagged in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bfa6ae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is rated at 10,000 gross tons or higher.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa6af-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commander of the Military Sealift Command may waive the requirement under paragraph (1) at any time if the Commander determines that carrying a cadet from the United States Merchant Marine Academy would place an undue burden on the vessel or the operator of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bfa6b0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Operator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “operator” includes a government operator and a non-government operator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bfa6b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Clause","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section may be construed as affecting—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bfa6b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the discretion of the Secretary to determine whether to place a United States Merchant Marine Academy cadet on a vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa6b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the Coast Guard regarding a vessel security plan approved under section 70103; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa6b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51307/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the discretion of the master of the vessel to ensure the safety of all crew members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6bfa6b5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1574"},"text":"120 Stat. 1574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIII/s307"},"text":"Pub. L. 109–241, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/528"},"text":"120 Stat. 528","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3525/a/3"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3525(a)(3)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/600"},"text":"122 Stat. 600","children":[],"tail":", 601; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3512"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2311"},"text":"132 Stat. 2311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dC/tXXXV/s3506"},"text":"Pub. L. 116–283, div. C, title XXXV, § 3506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4405"},"text":"134 Stat. 4405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3517/a/1"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3517(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3073"},"text":"136 Stat. 3073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c1f0a6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6c1f0a7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6c1f0a8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"51307","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1295b(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XIII, § 1303(f), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/96/453/s2"},"text":"Pub. L. 96–453, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2002"},"text":"94 Stat. 2002","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (2), the words “with the permission of the owner” are substituted for “if the owner . . . cooperates in such use” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6c1f0a9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6c1f0aa-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, text read as follows: “The Secretary shall require an operator of a vessel participating in the Maritime Security Program under chapter 531 of this title, the Cable Security Fleet under chapter 532 of this title, or the Tanker Security Fleet under chapter 534 of this title to carry on each Maritime Security Program vessel, Cable Security Fleet vessel, or Tanker Security Fleet vessel 2 United States Merchant Marine Academy cadets, if available, on each voyage.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “The Secretary shall require an operator of a vessel participating in the Maritime Security Program under chapter 531 of this title to carry on each Maritime Security Program vessel 2 United States Merchant Marine Academy cadets, if available, on each voyage.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3512/1"},"text":"Pub. L. 115–232, § 3512(1)","children":[],"tail":", (3), designated existing provisions as subsec. (a), inserted heading, and added subsecs. (b) to (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3512/2"},"text":"Pub. L. 115–232, § 3512(2)","children":[],"tail":", substituted “owned, subsidized by, or contracted with” for “owned or subsidized by”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3525/b"},"text":"Pub. L. 110–181, § 3525(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/s307"},"text":"Pub. L. 109–241, § 307","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3525/a/3"},"text":"Pub. L. 110–181, § 3525(a)(3)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/s307"},"text":"Pub. L. 109–241, § 307","children":[],"tail":", into this section by adding par. (4). See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s307"},"text":"Pub. L. 109–241, § 307","children":[],"tail":", which directed the amendment of section 1295b(f) of the former Appendix to this title from which this section was derived, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3525/b"},"text":"Pub. L. 110–181, § 3525(b)","children":[],"tail":". See 2008 Amendment note for par. (4) and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6c1f0ab-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6c1f0ac-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3517/a/2"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3517(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3074"},"text":"136 Stat. 3074","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dC/tXXXV/s3517/a/2"},"text":"“Paragraph (2) of subsection (b) of section 51307, as amended by paragraph (1), shall apply with respect to any failure to implement or adhere to the policies, programs, criteria, and requirements referred to in paragraph (1)(B) of such subsection that occurs on or after the date that is one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
