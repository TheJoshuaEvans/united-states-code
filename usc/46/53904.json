{"tag":"section","attrib":{"id":"idf6e35a9c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53904"},"text":null,"children":[{"tag":"num","attrib":{"value":"53904"},"text":"§ 53904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability insurance for persons involved in war or defense efforts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e35a9d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may provide insurance under this chapter against legal liability that a person may incur in providing services or facilities for a vessel if, in the opinion of the Secretary, the insurance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e35a9e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required in prosecuting a war or for national defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35a9f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cannot be obtained at reasonable rates or on reasonable terms and conditions from approved companies authorized to do insurance business in a State of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35aa0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"t