{"tag":"section","attrib":{"id":"idf665037e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503"},"text":null,"children":[{"tag":"num","attrib":{"value":"3503"},"text":"§ 3503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fire-retardant materials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf665037f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6650380-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A passenger vessel of the United States having berth or stateroom accommodations for at least 50 passengers shall be granted a certificate of inspection only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6650381-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is constructed of fire-retardant materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6650382-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the vessel—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6650383-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is operating engines, boilers, main electrical distribution panels, fuel tanks, oil tanks, and generators that meet current Coast Guard regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6650384-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is operating boilers and main electrical generators that are contained within noncombustible enclosures equipped with fire suppression systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6650385-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before ","children":[{"tag":"date","attrib":{"date":"2028-12-01"},"text":"December 1, 2028","children":[],"tail":", this subsection does not apply to any vessel in operation before "},{"tag":"date","attrib":{"date":"1968-01-01"},"text":"January 1, 1968","children":[],"tail":", and operating only within the Boundary Line."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6650386-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6650387-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The owner or managing operator of an exempted vessel described in subsection (a)(2) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6650388-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify in writing prospective passengers, prior to purchase, and each crew member that the vessel does not comply with applicable fire safety standards due primarily to the wooden construction of passenger berthing areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6650389-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" display in clearly legible font prominently throughout the vessel, including in each state room the following: “THIS VESSEL FAILS TO COMPLY WITH SAFETY RULES AND REGULATIONS OF THE U.S. COAST GUARD.”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf665038a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire prior to the vessel entering service, and maintain, liability insurance in an amount to be prescribed by the Federal Maritime Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf665038b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make annual structural alteration to not less than 10 percent of the areas of the vessel that are not constructed of fire retardant materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf665038c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize alterations in galleys, engineering areas of the vessel, including all spaces and compartments containing, or adjacent to spaces and compartments containing, engines, boilers, main electrical distribution panels, fuel tanks, oil tanks, and generators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf665038d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure, to the satisfaction of the Secretary, that the combustible fire-load has been reduced pursuant to subparagraph (D) during each annual inspection for certification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf665038e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure the vessel has multiple forms of egress off the vessel’s bow and stern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf665038f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advance notice to the Coast Guard regarding the structural alterations made pursuant to subparagraph (D) and comply with any noncombustible material requirements prescribed by the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6650390-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually notify all ports of call and State emergency management offices of jurisdiction that the vessel does not comply with the requirement under subsection (a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6650391-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide crewmembers manning such vessel shipboard training that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6650392-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is specialized for exempted vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6650393-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exceeds requirements related to standards for firefighting training under chapter I of title 46, Code of Federal Regulations, as in effect on ","children":[{"tag":"date","attrib":{"date":"2017-10-01"},"text":"October 1, 2017","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6650394-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/J/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is approved by the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6650395-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, take all steps to retain previously trained crew knowledgeable of such vessel or to hire crew trained in operations aboard exempted vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6650396-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner or managing operator of an exempted vessel described in subsection (a)(2) may not disclaim liability to a passenger or crew member of such vessel for death, injury, or any other loss caused by fire due to the negligence of the owner or managing operator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6650397-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6650398-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an annual audit and inspection of each exempted vessel described in subsection (a)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6650399-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in implementing subparagraph (b)(1)(F), consider, to the extent practicable, the goal of preservation of the historic integrity of such vessel in areas carrying or accessible to passengers or generally visible to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf665039a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe regulations to carry out this section, including to prescribe the manner in which prospective passengers are to be notified under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf665039b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The penalties provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s3504/c"},"text":"section 3504(c) of this title","children":[],"tail":" shall apply to a violation of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf665039c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to otherwise applicable penalties, the Secretary may immediately withdraw a certificate of inspection for an exempted vessel described in subsection (a)(2) that does not comply with any requirement under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf665039d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/519"},"text":"97 Stat. 519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/307/s1/7/A"},"text":"Pub. L. 99–307, § 1(7)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-19"},"text":"May 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/445"},"text":"100 Stat. 445","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/241/s20"},"text":"Pub. L. 102–241, § 20","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-19"},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2216"},"text":"105 Stat. 2216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tXI/s1133"},"text":"Pub. L. 104–324, title XI, § 1133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3985"},"text":"110 Stat. 3985","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVIII/s834"},"text":"Pub. L. 115–282, title VIII, § 834","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4318"},"text":"132 Stat. 4318","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf665039e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf665039f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf66503a0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3503","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:369(b)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3503 requires the use of fire retardant materials on a vessel having berthing facilities for at least 50 passengers. This requirement in the case of vessels engaged in foreign trade is consistent with our international treaty obligations, which impose extensive and additional fire safety standards. A waiver that grandfathers existing inland river passenger vessels is also included.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf66503a1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf66503a2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" amended section generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) A passenger vessel of the United States having berth or stateroom accommodations for at least 50 passengers shall be granted a certificate of inspection only if the vessel is constructed of fire-retardant materials. Before ","children":[{"tag":"date","attrib":{"date":"2008-11-01"},"text":"November 1, 2008","children":[],"tail":", this section does not apply to any vessel in operation before "},{"tag":"date","attrib":{"date":"1968-01-01"},"text":"January 1, 1968","children":[],"tail":", and operating only within the Boundary Line."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b)(1) When a vessel is exempted from the fire-retardant standards of this section—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the owner or managing operator of the vessel shall notify prospective passengers that the vessel does not comply with applicable fire safety standards due primarily to the wooden construction of passenger berthing areas;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the owner or managing operator of the vessel may not disclaim liability to a passenger for death, injury, or any other loss caused by fire due to the negligence of the owner or managing operator;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) the penalties provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s3504/c"},"text":"section 3504(c) of this title","children":[],"tail":" apply to a violation of this subsection; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) the owner or managing operator of the vessel shall notify the Coast Guard of structural alterations to the vessel, and with regard to those alterations comply with any noncombustible material requirements that the Coast Guard prescribes for nonpublic spaces. Coast Guard requirements shall be consistent with preservation of the historic integrity of the vessel in areas carrying or accessible to passengers or generally visible to the public.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Secretary shall prescribe regulations under this subsection on the manner in which prospective passengers are to be notified.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" substituted “Before "},{"tag":"date","attrib":{"date":"2008-11-01"},"text":"November 1, 2008","children":[],"tail":", this section does not apply to any vessel in operation before "},{"tag":"date","attrib":{"date":"1968-01-01"},"text":"January 1, 1968","children":[],"tail":", and operating only within the Boundary Line.” for “Before "},{"tag":"date","attrib":{"date":"1998-11-01"},"text":"November 1, 1998","children":[],"tail":", this section does not apply to a vessel in operation before "},{"tag":"date","attrib":{"date":"1968-01-01"},"text":"January 1, 1968","children":[],"tail":", and operating only on the inland rivers.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/241/s20/1"},"text":"Pub. L. 102–241, § 20(1)","children":[],"tail":", substituted “1998” for “1993”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/241/s20/2"},"text":"Pub. L. 102–241, § 20(2)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/307"},"text":"Pub. L. 99–307","children":[],"tail":" designated existing provision as subsec. (a), substituted “"},{"tag":"date","attrib":{"date":"1993-11-01"},"text":"November 1, 1993","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1988-11-01"},"text":"November 1, 1988","children":[],"tail":"” and inserted “in operation before "},{"tag":"date","attrib":{"date":"1968-01-01"},"text":"January 1, 1968","children":[],"tail":", and” after “to a vessel”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf66503a3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf66503a4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf66503a5-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Notification to Prospective Passengers of Noncompliance With Fire-Retardant Standards","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/307/s1/7/B"},"text":"Pub. L. 99–307, § 1(7)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-19"},"text":"May 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/445"},"text":"100 Stat. 445","children":[],"tail":", required notification to prospective passengers of a vessel’s noncompliance with certain standards until regulations became effective."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
