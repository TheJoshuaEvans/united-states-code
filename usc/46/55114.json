{"tag":"section","attrib":{"id":"idf6e8167b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55114"},"text":null,"children":[{"tag":"num","attrib":{"value":"55114"},"text":"§ 55114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unloading fish from foreign vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e8167c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided by this section or a treaty or convention to which the United States is a party, a foreign vessel may not unload, in a port of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e8167d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its catch of fish taken on board on the high seas or fish products processed from that catch of fish; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e8167e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fish or fish products taken on board that vessel on the high seas from a vessel engaged in fishing operations or the processing of fish or fish products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e8167f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations on Obtaining Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Commerce may prescribe regulations the Secretary considers necessary to obtain information on the transportation of fish products by vessels of the United States for foreign fish processing vessels to points in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e81680-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Virgin Islands","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e81681-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55114/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A foreign vessel of not more than 50 feet overall in length may unload its catch of fresh fish (whole or with the heads, viscera, or fins removed, but not frozen, otherwise processed, or further advanced) in a port of the Virgin Islands for immediate consumption in those islands. Fish unloaded under this paragraph may be sold or transferred only for immediate consumption. In the absence of satisfactory evidence that a sale or transfer to an agent, representative, or employee of a freezer or cannery is for immediate consumption, the sale or transfer is deemed not to be for immediate consumption. This paragraph does not prohibit the freezing, smoking, or other processing of fresh fish by the ultimate consumer of the fish.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81682-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55114/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Seizure, forfeiture, and penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Fish unloaded in the Virgin Islands that are retained, sold, or transferred, except as allowed by paragraph (1), are liable to seizure by and forfeiture to the United States Government. A person retaining, selling, transferring, buying, or receiving the fish is liable to the Government for a civil penalty of not more than $1,000 for each violation. A penalty or forfeiture under this paragraph may be compromised, modified, or remitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2107/b"},"text":"section 2107(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e81683-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55114/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Northern Mariana Islands","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply to the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e81684-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1639"},"text":"120 Stat. 1639","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e81685-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e81686-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e81687-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55114(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:251(a) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 4311; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-02/ch842"},"text":"Sept. 2, 1950, ch. 842","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/577"},"text":"64 Stat. 577","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/87/220/s1"},"text":"Pub. L. 87–220, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 13, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/493"},"text":"75 Stat. 493","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/61/s2"},"text":"Pub. L. 96–61, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 15, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/407"},"text":"93 Stat. 407","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/96/594/tI/s126/b"},"text":"Pub. L. 96–594, title I, § 126(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/3459"},"text":"94 Stat. 3459","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/100/239/s8/a"},"text":"Pub. L. 100–239, § 8(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Jan. 11, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1783"},"text":"101 Stat. 1783","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55114(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:251(a) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55114(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:251(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55114(c)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:251(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:251a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/87/220/s2"},"text":"Pub. L. 87–220, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 13, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/493"},"text":"75 Stat. 493","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55114(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"48:1801 note (Covenant § 503(b)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before paragraph (1), the words “whether documented as a cargo vessel or otherwise” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “severally” and “in addition to any other penalty provided in law” are omitted as unnecessary. The last sentence is substituted for 46 App. U.S.C. 251a.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) is based on section 503(b) of the Covenant to Establish a Commonwealth of the Northern Mariana Islands in Political Union With the United States of America (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1801"},"text":"48 U.S.C. 1801","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
