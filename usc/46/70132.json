{"tag":"section","attrib":{"id":"idf70710cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132"},"text":null,"children":[{"tag":"num","attrib":{"value":"70132"},"text":"§ 70132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credentialing standards, training, and certification for State and local support for the enforcement of security zones for the transportation of especially hazardous cargo","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf70710ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standard","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant of the Coast Guard shall establish, by regulation, national standards for training and credentialing of public safety personnel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf70710cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enforce a security zone; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710d0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the enforcement of a security zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70710d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf70710d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commandant of the Coast Guard—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf70710d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall develop and publish a training curriculum for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf70710d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public safety personnel to enforce a security zone;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf70710d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public safety personnel to enforce or assist in the enforcement of a security zone; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf70710d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel who are employed or retained by a facility or vessel owner to assist in the enforcement of a security zone; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70710d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf70710d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" test and deliver such training, the curriculum for which is developed pursuant to subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf70710d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into an agreement under which a public entity (including a Federal agency) or private entity may test and deliver such training, the curriculum for which has been developed pursuant to subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf70710da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept a program, conducted by a public entity (including a Federal agency) or private entity, through which such training is delivered the curriculum for which is developed pursuant to subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any Federal agency that provides such training, and any public or private entity that receives moneys, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70107/b/8"},"text":"section 70107(b)(8) of this title","children":[],"tail":", to provide such training, shall provide such training—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf70710dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to public safety personnel who enforce or assist in the enforcement of a security zone; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70710dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on an availability basis to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf70710de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public safety personnel who assist in the enforcement of a security zone; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf70710df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel who are employed or retained by a facility or vessel owner or operator to assist in the enforcement of a security zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a Federal agency provides the training, the head of such agency may, notwithstanding any other provision of law, accept payment from any source for such training, and any amount received as payment shall be credited to the appropriation, current at the time of collection, charged with the cost thereof and shall be merged with, and available for, the same purposes of such appropriation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, any moneys, awarded by the Department of Homeland Security in the form of awards or grants, may be used by the recipient to pay for training of personnel to assist in the enforcement of security zones and limited access areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70710e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification; Training Partners","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing and delivering training under the training program, the Secretary, in coordination with the Maritime Administrator of the Department of Transportation, and consistent with section 109 of the Maritime Transportation Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70101"},"text":"46 U.S.C. 70101","children":[],"tail":" note), shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf70710e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with government training facilities, academic institutions, private organizations, employee organizations, and other entities that provide specialized, state-of-the-art training for governmental and nongovernmental emergency responder providers or commercial seaport personnel and management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize, as appropriate, government training facilities, courses provided by community colleges, public safety academies, State and private universities, and other facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify organizations that offer the curriculum for training and certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70710e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70132/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Safety Personnel Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of this section, the term “public safety personnel” includes any Federal, State (or political subdivision thereof), territorial, or Tribal law enforcement officer, firefighter, or emergency response provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf70710e7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVIII/s828/a"},"text":"Pub. L. 111–281, title VIII, § 828(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3005"},"text":"124 Stat. 3005","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1/16"},"text":"Pub. L. 111–330, § 1(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3570"},"text":"124 Stat. 3570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8314(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4699"},"text":"134 Stat. 4699","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf70710e8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf70710e9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf70710ea-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 109 of the Maritime Transportation Security Act of 2002, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s109"},"text":"section 109 of title I of Pub. L. 107–295","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s70101"},"text":"section 70101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf70710eb-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8314/2/A"},"text":"Pub. L. 116–283, § 8314(2)(A)","children":[],"tail":", substituted “public safety personnel—” for “law enforcement personnel—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8314/2/B"},"text":"Pub. L. 116–283, § 8314(2)(B)","children":[],"tail":", substituted “public safety personnel” for “law enforcement personnel” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8314/2/C"},"text":"Pub. L. 116–283, § 8314(2)(C)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/330"},"text":"Pub. L. 111–330","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/s828/a"},"text":"Pub. L. 111–281, § 828(a)","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf70710ec-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf70710ed-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1"},"text":"Pub. L. 111–330, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3569"},"text":"124 Stat. 3569","children":[],"tail":", provided that the amendment made by section 1(16) is effective with the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
