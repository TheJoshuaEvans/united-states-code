{"tag":"section","attrib":{"id":"idf6bd35be-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50504"},"text":null,"children":[{"tag":"num","attrib":{"value":"50504"},"text":"§ 50504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sailing school vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6bd35bf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “sailing school instructor”, “sailing school student”, and “sailing school vessel” have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"section 2101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bd35c0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Not Seamen","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A sailing school student or sailing school instructor is deemed not to be a seaman under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bd35c1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parts B, F, and G of subtitle II of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd35c2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maritime law doctrines of maintenance and cure or warranty of seaworthiness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bd35c3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Not Merchant Vessel or Engaged in Trade or Commerce","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A sailing school vessel is deemed not to be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bd35c4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a merchant vessel under section 11101(a)–(c) of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd35c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel engaged in trade or commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bd35c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidence of Financial Responsibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The owner or charterer of a sailing school vessel shall maintain evidence of financial responsibility to meet liability for death or injury to sailing school students and sailing school instructors on a voyage on the vessel. The amount of financial responsibility shall be at least $50,000 for each student and instructor. Financial responsibility under this subsection may be evidenced by insurance or other adequate financial resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6bd35c7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1568"},"text":"120 Stat. 1568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6bd35c8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6bd35c9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6bd35ca-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"50504(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:446c.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/97/322/tII"},"text":"Pub. L. 97–322, title II","children":[],"tail":", §§ 204, 205, 207, "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1589"},"text":"96 Stat. 1589","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"50504(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:446.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"50504(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:446b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/97/322/tII/s206"},"text":"Pub. L. 97–322, title II, § 206","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1590"},"text":"96 Stat. 1590","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/557/s34/b"},"text":"Pub. L. 98–557, § 34(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2876"},"text":"98 Stat. 2876","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"50504(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:446a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “parts B, F, and G of subtitle II of this title” are substituted for “the provisions of titles 52 and 53 of the Revised Statutes of the United States and any Act amendatory thereof or supplementary thereto” because the relevant provisions of titles 52 and 53 of the Revised Statutes were previously codified in parts B, F, and G of subtitle II of title 46.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), references to 46 App. U.S.C. 291 and 883 are omitted for consistency with section 50503 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
