{"tag":"section","attrib":{"id":"idf6d2ba2e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53309"},"text":null,"children":[{"tag":"num","attrib":{"value":"53309"},"text":"§ 53309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accumulation of deposits","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For any taxable year, amounts on deposit in a construction reserve fund on the last day of the taxable year, for which the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53310"},"text":"section 53310 of this title","children":[],"tail":" have been satisfied (to the extent they apply on the last day of the taxable year), are deemed to have been retained for the reasonable needs of the business within the meaning of section 537(a) of the Internal Revenue Code of 1986 ("},{"tag":"ref","attrib":{"href":"/us/usc/t26/s537/a"},"text":"26 U.S.C. 537(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6d2ba2f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1589"},"text":"120 Stat. 1589","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d2ba30-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6d2ba31-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6d2ba32-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n