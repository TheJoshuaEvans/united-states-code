{"tag":"section","attrib":{"id":"idf6a0ade7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30104"},"text":null,"children":[{"tag":"num","attrib":{"value":"30104"},"text":"§ 30104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal injury to or death of seamen","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a0ade8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A seaman injured in the course of employment or, if the seaman dies from the injury, the personal representative of the seaman may elect to bring a civil action at law, with the right of trial by jury, against the employer. Laws of the United States regulating recovery for personal injury to, or death of, a railway employee apply to an action under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ade9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Recovery by Aquaculture Workers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0adea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the term “seaman” does not include an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0adeb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30104/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an aquaculture worker if State workers’ compensation is available to such individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0adec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30104/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was, at the time of injury, engaged in aquaculture in a place where such individual had lawful access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0aded-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aquaculture worker defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “aquaculture worker” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0adee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is employed by a commercial enterprise that is involved in the controlled cultivation and harvest of aquatic plants and animals, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6a0adef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30104/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cleaning, processing, or canning of fish and fish products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6a0adf0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30104/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cultivation and harvesting of shellfish; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6a0adf1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30104/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the controlled growing and harvesting of other aquatic species;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0adf2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not hold a license issued under section 7101(c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0adf3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30104/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not required to hold a merchant mariner credential under part F of subtitle II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a0adf4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1510"},"text":"120 Stat. 1510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3521/a"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/596"},"text":"122 Stat. 596","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11520/a"},"text":"Pub. L. 117–263, div. K, title CXV, § 11520(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4142"},"text":"136 Stat. 4142","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a0adf5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a0adf6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a0adf7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30104(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:688(a) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1915-03-04/ch153/s20/a"},"text":"Mar. 4, 1915, ch. 153, § 20(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/38/1185"},"text":"38 Stat. 1185","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1920-06-05/ch250/s33"},"text":"June 5, 1920, ch. 250, § 33","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/41/1007"},"text":"41 Stat. 1007","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/389/tV/s503/a/1"},"text":"Pub. L. 97–389, title V, § 503(a)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 29, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1955"},"text":"96 Stat. 1955","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30104(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:688(a) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “A seaman injured in the course of employment or, if the seaman dies from the injury, the personal representative of the seaman” are substituted for “Any seaman who shall suffer personal injury in the course of his employment” and “in case of the death of any seaman as a result of any such personal injury the personal representative” to eliminate unnecessary words. The words “bring a civil action” are substituted for “maintain an action” for consistency with rule 2 of the Federal Rules of Civil Procedure (28 App. U.S.C.). The words “for damages” are omitted as unnecessary. The words “against the employer” are added for clarity. The words “Laws of the United States regulating recovery for personal injury to, or death of, a railway employee” are substituted for “all statutes of the United States modifying or extending the common-law right or remedy in cases of personal injury to railway employees” and “all statutes of the United States conferring or regulating the right of action for death in the case of railway employees” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “An action under this section shall be brought” are substituted for “Jurisdiction in such actions shall be under” because 46 App. U.S.C. 688(a) (last sentence) provides for venue, not jurisdiction. ","children":[{"tag":"i","attrib":{},"text":"Panama R.R. Co. v. Johnson","children":[],"tail":", 264 U.S. 375 (1924). As to the relationship between 46 App. U.S.C. 688(a) (last sentence) and "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s1391/c"},"text":"28 U.S.C. 1391(c)","children":[],"tail":", see "},{"tag":"i","attrib":{},"text":"Pure Oil Co. v. Suarez","children":[],"tail":", 384 U.S. 202 (1966)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6a0adf8-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6a0adf9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" struck out subsec. (a) designation and heading before “A seaman injured” and struck out heading and text of subsec. (b). Text read as follows: “An action under this section shall be brought in the judicial district in which the employer resides or the employer’s principal office is located.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6a0adfa-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6a0adfb-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11520/b"},"text":"Pub. L. 117–263, div. K, title CXV, § 11520(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4143"},"text":"136 Stat. 4143","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dK/tCXV/s11520/b"},"text":"“The amendments made by this section [amending this section] shall apply to an injury incurred on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6a0adfc-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3521/b"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3521(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/596"},"text":"122 Stat. 596","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/181/dC/tXXXV/s3521/b"},"text":"“The amendment made by subsection (a) [amending this section] shall be effective as if included in the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Public Law 109–304","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
