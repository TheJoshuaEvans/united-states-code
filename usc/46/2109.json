{"tag":"section","attrib":{"id":"idf6543aa9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2109"},"text":null,"children":[{"tag":"num","attrib":{"value":"2109"},"text":"§ 2109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided, this subtitle does not apply to a public vessel of the United States. However, this subtitle does apply to a vessel (except a Great Lakes St. Lawrence Seaway Development Corporation vessel) owned or operated by the Department of Transportation or by any corporation organized or controlled by the Department.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf656abaa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/507"},"text":"97 Stat. 507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5102/b/3"},"text":"Pub. L. 99–509, title V, § 5102(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1927"},"text":"100 Stat. 1927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIX/s902/e/1"},"text":"Pub. L. 109–241, title IX, § 902(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/567"},"text":"120 Stat. 567","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIX/s903/a/5/A"},"text":"Pub. L. 111–281, title IX, § 903(a)(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"