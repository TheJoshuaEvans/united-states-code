{"tag":"section","attrib":{"id":"idf6c1f132-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51314"},"text":null,"children":[{"tag":"num","attrib":{"value":"51314"},"text":"§ 51314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on charges and fees for attendance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c1f133-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), no charge or fee for tuition, room, or board for attendance at the United States Merchant Marine Academy may be imposed unless the charge or fee is specifically authorized by a law enacted after ","children":[{"tag":"date","attrib":{"date":"1994-10-05"},"text":"October 5, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f134-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition specified in subsection (a) does not apply with respect to any item or service provided to cadets for which a charge or fee is imposed as of ","children":[{"tag":"date","attrib":{"date":"1994-10-05"},"text":"October 5, 1994","children":[],"tail":", or for calculators, computers, personal and academic supplies, midshipman services such as barber, tailor, or laundry services, and Coast Guard license fees. The Secretary of Transportation shall present at the next meeting of the Board of Visitors, and post on a publicly available website, any change made by the Academy in the amount of a charge or fee authorized under this subsection. Such fees shall be credited to the Maritime Administration’s Operations and Training appropriation, to remain available until expended, for those expenses directly related to the purposes of the fees. Fees collected in excess of actual expenses may be refunded to the Midshipmen through a mechanism approved by the Secretary. The Academy shall maintain a separate and detailed accounting of fee revenue and all associated expenses."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c1f135-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1576"},"text":"120 Stat. 1576","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dC/tXXXV/s3510"},"text":"Pub. L. 111–84, div. C, title XXXV, § 3510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2722"},"text":"123 Stat. 2722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/117/dA/tI/s176"},"text":"Pub. L. 111–117, div. A, title I, § 176","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-12-16"},"text":"Dec. 16, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3068"},"text":"123 Stat. 3068","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/420/s2"},"text":"Pub. L. 115–420, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5444"},"text":"132 Stat. 5444","children":[],"tail":".)"}],"tail":"\n"},{"