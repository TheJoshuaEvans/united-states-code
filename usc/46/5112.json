{"tag":"section","attrib":{"id":"idf675a589-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5112"},"text":null,"children":[{"tag":"num","attrib":{"value":"5112"},"text":"§ 5112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loading restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf675a58a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vessel may not be loaded in a way that submerges the assigned load line or the place at which the load line is required to be marked on the vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf675a58b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the loading or stability conditions of a vessel change, the master or individual in charge of the vessel, before moving the vessel, shall record in the official logbook or other permanent record of the vessel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf675a58c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the position of the assigned load line relative to the water surface; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf675a58d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the draft of the vessel fore and aft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf675a58e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vessel may be operated only if the loading distribution, stability, and margin of strength are adequate for the voyage or movement intended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf675a58f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5112/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (a) and (b) of this section do not apply to a submersible vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf675a590-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5101/2"},"text":"Pub. L. 99–509, title V, § 5101(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1917"},"text":"100 Stat. 1917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf675a591-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf675a592-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 5112","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Source: Section (U.S. Code) 46 App. U.S.C. 86g, 88c, 88e.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5112(a) prohibits a vessel from being loaded in a manner that submerges its load line.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5112(b) requires that whenever the loading or stability conditions of a vessel change, the master or individual in charge of the vessel must record in the official logbook the position of the load line and the draft of the vessel.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5112(c) is a new provision that provides that a vessel may be operated only if the loading distribution, stability, and margin of strength are adequate for the intended voyage or movement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5112(d) provides that subsections (a) and (b) do not apply to a submersible vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
