{"tag":"section","attrib":{"id":"idf6f3fd06-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58107"},"text":null,"children":[{"tag":"num","attrib":{"value":"58107"},"text":"§ 58107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discrimination at ports by water common carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f3fd07-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A common carrier by water may not, directly or indirectly, through an agreement, conference, association, understanding, or otherwise, prevent or attempt to prevent any other common carrier by water from serving any port described in subsection (b) at the same rates the first carrier charges at the nearest port already regularly served by it.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f3fd08-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A port referred to in subsection (a) is one that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f3fd09-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed for the accommodation of ocean-going vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f3fd0a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located on an improvement project authorized by law or by a Federal agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f3fd0b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58107/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located within the continental limits of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f3fd0c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Authority Not Limited","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not limit the authority otherwise vested in the Secretary of Transportation and the Federal Maritime Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f3fd0d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1672"},"text":"120 Stat. 1672","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f3fd0e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f3fd0f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f3fd10-2930-11f1-96a8-b9bd2a0a9