{"tag":"section","attrib":{"id":"idf67cd102-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7506"},"text":null,"children":[{"tag":"num","attrib":{"value":"7506"},"text":"§ 7506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convention tonnage for licenses, certificates, and documents","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any provision of section 14302(c) or 14305 of this title, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67cd103-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7506/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the service of an individual who is applying for a license, a certificate of registry, or a merchant mariner’s document by using the tonnage as measured under chapter 143 of this title for the vessels on which that service was acquired, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd104-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7506/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue the license, certificate, or document based on that service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67cd105-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s745/a"},"text":"Pub. L. 104–324, title VII, § 745(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3942"},"text":"110 Stat. 3942","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
