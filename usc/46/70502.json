{"tag":"section","attrib":{"id":"idf7098036-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502"},"text":null,"children":[{"tag":"num","attrib":{"value":"70502"},"text":"§ 70502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7098037-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Other Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The definitions in section 102 of the Comprehensive Drug Abuse Prevention and Control Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":") apply to this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098038-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel of the United States","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter, the term “vessel of the United States” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7098039-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel documented under chapter 121 of this title or numbered as provided in chapter 123 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf709803a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a vessel owned in any part by an individual who is a citizen of the United States, the United States Government, the government of a State or political subdivision of a State, or a corporation incorporated under the laws of the United States or of a State, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf709803b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel has been granted the nationality of a foreign nation under article 5 of the 1958 Convention on the High Seas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf709803c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a claim of nationality or registry for the vessel is made by the master or individual in charge at the time of the enforcement action by an officer or employee of the United States who is authorized to enforce applicable provisions of United States law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf709803d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel that was once documented under the laws of the United States and, in violation of the laws of the United States, was sold to a person not a citizen of the United States, placed under foreign registry, or operated under the authority of a foreign nation, whether or not the vessel has been granted the nationality of a foreign nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf709803e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel Subject to the Jurisdiction of the United States","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf709803f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter, the term “vessel subject to the jurisdiction of the United States” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf7098040-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel without nationality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7098041-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel assimilated to a vessel without nationality under paragraph (2) of article 6 of the 1958 Convention on the High Seas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7098042-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel registered in a foreign nation if that nation has consented or waived objection to the enforcement of United States law by the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7098043-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel in the customs waters of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7098044-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel in the territorial waters of a foreign nation if the nation consents to the enforcement of United States law by the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7098045-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a vessel in the contiguous zone of the United States, as defined in Presidential Proclamation 7219 of ","children":[{"tag":"date","attrib":{"date":"1999-09-02"},"text":"September 2, 1999","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"43 U.S.C. 1331","children":[],"tail":" note), that—"}],"tail":null},{"tag":"clause","attrib":{"id":"idf7098046-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entering the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf7098047-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has departed the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf7098048-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c/1/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a hovering vessel as defined in section 401 of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1401"},"text":"19 U.S.C. 1401","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7098049-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consent or waiver of objection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consent or waiver of objection by a foreign nation to the enforcement of United States law by the United States under paragraph (1)(C) or (E)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf709804a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be obtained by radio, telephone, or similar oral or electronic means; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf709804b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is proved conclusively by certification of the Secretary of State or the Secretary’s designee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf709804c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel Without Nationality","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf709804d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter, the term “vessel without nationality” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf709804e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel aboard which the master or individual in charge makes a claim of registry that is denied by the nation whose registry is claimed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf709804f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel aboard which the master or individual in charge fails, on request of an officer of the United States authorized to enforce applicable provisions of United States law, to make a claim of nationality or registry for that vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7098050-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel aboard which the master or individual in charge makes a claim of registry and for which the claimed nation of registry does not affirmatively and unequivocally assert that the vessel is of its nationality; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7098051-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel aboard which no individual, on request of an officer of the United States authorized to enforce applicable provisions of United States law, claims to be the master or is identified as the individual in charge, and that has no other claim of nationality or registry under paragraph (1) or (2) of subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7098052-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Response to claim of registry","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The response of a foreign nation to a claim of registry under paragraph (1)(A) or (C) may be made by radio, telephone, or similar oral or electronic means, and is proved conclusively by certification of the Secretary of State or the Secretary’s designee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098053-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claim of Nationality or Registry","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A claim of nationality or registry under this section includes only—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7098054-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possession on board the vessel and production of documents evidencing the vessel’s nationality as provided in article 5 of the 1958 Convention on the High Seas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7098055-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flying its nation’s ensign or flag; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7098056-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a verbal claim of nationality or registry by the master or individual in charge of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098057-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Semi-submersible Vessel; Submersible Vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7098058-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Semi-submersible vessel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “semi-submersible vessel” means any watercraft constructed or adapted to be capable of operating with most of its hull and bulk under the surface of the water, including both manned and unmanned watercraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7098059-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70502/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submersible vessel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “submersible vessel” means a vessel that is capable of operating completely below the surface of the water, including both manned and unmanned watercraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf709805a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s10/2"},"text":"Pub. L. 109–304, § 10(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1685"},"text":"120 Stat. 1685","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIII/s303"},"text":"Pub. L. 109–241, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/527"},"text":"120 Stat. 527","children":[],"tai