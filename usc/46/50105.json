{"tag":"section","attrib":{"id":"idf6b609ef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50105"},"text":null,"children":[{"tag":"num","attrib":{"value":"50105"},"text":"§ 50105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies and cooperation relating to the construction of vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b609f0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relative Costs and New Designs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall investigate, determine, and keep current records of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b609f1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative cost of construction of comparable vessels in the United States and in foreign countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b609f2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new designs, new methods of construction, and new types of equipment for vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b609f3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules, Classifications, and Ratings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall examine the rules under which vessels are constructed abroad and in the United States and the methods of classifying and rating the vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b609f4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collaboration With Owners and Builders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall collaborate with vessel owners and shipbuilders in developing plans for the economical construction of vessels and their propelling machinery, of most modern economical types, giving thorough consideration to all well-recognized means of propulsion and taking into account the benefits from standardized production where practicable and desirable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b609f5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Express-Liner and Super-Liner Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall study and cooperate with vessel owners in devising means by which there may be constructed, by or with the aid of the United States Government, express-liner or super-liner vessels comparable to those of other nations, especially with a view to their use in a national emergency, and the use of transoceanic aircraft service in connection with or in lieu of those vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b609f6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1558"},"text":"120 Stat. 1558","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b609f7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b609f8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b609f9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail"