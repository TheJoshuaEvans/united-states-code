{"tag":"section","attrib":{"id":"idf64ac44c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s109"},"text":null,"children":[{"tag":"num","attrib":{"value":"109"},"text":"§ 109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign commerce or trade","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf64ac44d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this title, the terms “foreign commerce” and “foreign trade” mean commerce or trade between a place in the United States and a place in a foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf64ac44e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital Construction Funds and Construction-Differential Subsidies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the context of capital construction funds under chapter 535 of this title, and in the context of construction-differential subsidies under title V of the Merchant Marine Act, 1936, the terms “foreign commerce” and “foreign trade” also include, in the case of liquid and dry bulk cargo carrying services, trading between foreign ports in accordance with normal commercial bulk shipping practices in a manner that will permit bulk vessels of the United States to compete freely with foreign bulk vessels in their operation or competition for charters, subject to regulations prescribed by the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf64ac44f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s4"},"text":"Pub. L. 109–304, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1487"},"text":"120 Stat. 1487","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf64ac450-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf64ac451-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf64ac452-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail"