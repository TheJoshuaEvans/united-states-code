{"tag":"section","attrib":{"id":"idf6e35a87-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903"},"text":null,"children":[{"tag":"num","attrib":{"value":"53903"},"text":"§ 53903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurable interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e35a88-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may provide insurance and reinsurance under this chapter for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e35a89-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an American vessel, including a vessel under construction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35a8a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a foreign vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e35a8b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by a citizen of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35a8c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in transportation in the waterborne commerce of the United States or in such other transportation by water or such other services as the Secretary considers to be in the interest of the national defense or national economy of the United States, when so engaged;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35a8d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" cargo—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e35a8e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shipped or to be shipped on a vessel insurable under this section, including by express or registered mail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35a8f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by a citizen or resident of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35a90-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imported to or exported from the United States, or sold or purchased by a citizen or resident of the United States, under a contract of sale or purchase the terms of which provide that the risk of loss by war risks or the obligation to provide insurance against war risks is on a citizen or resident of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35a91-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shipped between ports in the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35a92-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disbursements, including advances to masters and general average disbursements, and freight and passage money of a vessel insurable under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35a93-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal effects of an individual on a vessel insurable under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35a94-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loss of life, injury, or detention by an enemy of the United States after capture, with respect to an individual on a vessel insurable under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35a95-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statutory or contractual obligations or other liabilities of a vessel insurable under this section or of the owner or charterer of such a vessel, of a nature customarily covered by insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35a96-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations for Foreign Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In determining whether to provide insurance or reinsurance for a foreign vessel, the Secretary shall consider the characteristics, employment, and general management of the vessel by the owner or charterer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35a97-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-War Risks","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Insurance of a risk under subsection (a)(5)–(7), insofar as it involves a liability related to an individual on the vessel, may include risks other than war risks to the extent the Secretary considers advisable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e35a98-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1627"},"text":"120 Stat. 1627","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e35a99-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e35a9a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e35a9b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53903(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1283(a) (1st sentence), (b) (1st sentence), (c)–(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XII, § 1203(a) (1st, 2d sentences), (b) (1st sentence), (c)–(f), as added "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-07/ch906"},"text":"Sept. 7, 1950, ch. 906","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/773"},"text":"64 Stat. 773","children":[],"tail":", 774; "},{"tag":"html:a","attrib":{"href":"/us/pl/94/523"},"text":"Pub. L. 94–523","children":[],"tail":", §§ 1–3, "},{"tag":"html:span","attrib":{},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/2474"},"text":"90 Stat. 2474","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53903(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1283(a) (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53903(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1284.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XII, § 1204, as added "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-07/ch906"},"text":"Sept. 7, 1950, ch. 906","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/774"},"text":"64 Stat. 774","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a)(2) and (b), the words “foreign vessel” are substituted for “foreign-flag vessels” because of the definition of “foreign vessel” in chapter 1 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (3), references to the territories and possessions of the United States are omitted as unnecessary because of the definition of “United States” in chapter 1 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (5), the words “individual on a vessel insurable under this section” are substituted for “masters, officers, and crews of such vessels, and of other persons transported on such vessels” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (6), the words “individual on a vessel insurable under this section” are substituted for “Masters, officers, members of the crews of such vessels and other persons employed or transported thereon” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
