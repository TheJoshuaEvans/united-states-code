{"tag":"section","attrib":{"id":"idf6fb2939-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022"},"text":null,"children":[{"tag":"num","attrib":{"value":"70022"},"text":"§ 70022.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on entry and operation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6fb293a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb293b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this section, no vessel described in subsection (b) may enter or operate in the navigable waters of the United States or transfer cargo in any port or place under the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb293c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on application.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6fb293d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition under paragraph (1) shall not apply with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6fb293e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a vessel described in subsection (b)(1), if the Secretary of State determines that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6fb293f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/a/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is owned or operated by or on behalf of a country the government of which the Secretary of State determines is closely cooperating with the United States with respect to implementing the applicable United Nations Security Council resolutions (as such term is defined in section 3 of the North Korea Sanctions and Policy Enhancement Act of 2016); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6fb2940-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/a/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the national security interest not to apply the prohibition to such vessel; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6fb2941-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel described in subsection (b)(2), if the Secretary of State determines that the vessel is no longer registered as described in that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6fb2942-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 15 days after making a determination under subparagraph (A), the Secretary of State shall submit to the Committee on Foreign Affairs and the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Foreign Relations and the Committee on Commerce, Science, and Transportation of the Senate written notice of the determination and the basis upon which the determination was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6fb2943-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of State shall publish a notice in the Federal Register of each determination made under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb2944-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessels Described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel referred to in subsection (a) is a foreign vessel for which a notice of arrival is required to be filed under section 70001(a)(5), and that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb2945-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is on the most recent list of vessels published in the Federal Register under subsection (c)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb2946-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 180 days after the publication of such list, is knowingly registered, pursuant to the 1958 Convention on the High Seas entered into force on ","children":[{"tag":"date","attrib":{"date":"1962-09-30"},"text":"September 30, 1962","children":[],"tail":", by a government the agents or instrumentalities of which are maintaining a registration of a vessel that is included on such list."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb2947-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information and Publication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the department in which the Coast Guard is operating, with the concurrence of the Secretary of State, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb2948-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain timely information on the registrations of all foreign vessels over 300 gross tons that are known to be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6fb2949-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or operated by or on behalf of the Government of North Korea or a North Korean person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6fb294a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or operated by or on behalf of any country in which a sea port is located, the operator of which the President has identified in the most recent report submitted under section 205(a)(1)(A) of the North Korea Sanctions and Policy Enhancement Act of 2016; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6fb294b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or operated by or on behalf of any country identified by the President as a country that has not complied with the applicable United Nations Security Council resolutions (as such term is defined in section 3 of such Act); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb294c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically publish in the Federal Register a list of the vessels described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb294d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Governments.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb294e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of State shall notify each government, the agents or instrumentalities of which are maintaining a registration of a foreign vessel that is included on a list published under subsection (c)(2), not later than 30 days after such publication, that all vessels registered under such government’s authority are subject to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb294f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a government that continues to maintain a registration for a vessel that is included on such list after receiving an initial notification under paragraph (1), the Secretary shall issue an additional notification to such government not later than 120 days after the publication of a list under subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb2950-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receiving a notice of arrival under section 70001(a)(5) from a vessel described in subsection (b), the Secretary of the department in which the Coast Guard is operating shall notify the master of such vessel that the vessel may not enter or operate in the navigable waters of the United States or transfer cargo in any port or place under the jurisdiction of the United States, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb2951-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State has made a determination under subsection (a)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb2952-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the department in which the Coast Guard is operating allows provisional entry of the vessel, or transfer of cargo from the vessel, under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb2953-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisional Entry or Cargo Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this section, the Secretary of the department in which the Coast Guard is operating may allow provisional entry of, or transfer of cargo from, a vessel, if such entry or transfer is necessary for the safety of the vessel or persons aboard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb2954-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70022/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Right of Innocent Passage and Right of Transit Passage","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall not be construed as authority to restrict the right of innocent passage or the right of transit passage as recognized under international law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6fb2955-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8508(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4755"},"text":"134 Stat. 4755","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXVII/s7701/a"},"text":"Pub. L. 119–60, div. G, title LXXVII, § 7701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1835"},"text":"139 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6fb2956-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6fb2957-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6fb2958-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 3 and 205(a)(1)(A) of the North Korea Sanctions and Policy Enhancement Act of 2016, referred to in subsecs. (a)(2)(A)(i)(I) and (c)(1)(B), (C), are classified to sections 9202 and 9225(a)(1)(A), respectively, of Title 22, Foreign Relations and Intercourse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf6fb2959-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section, as added and amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", is based on "},{"tag":"ref","attrib":{"href":"/us/pl/92/340/s16"},"text":"section 16 of Pub. L. 92–340","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/44/tIII/s315/a"},"text":"Pub. L. 115–44, title III, § 315(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-08-02"},"text":"Aug. 2, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/948"},"text":"131 Stat. 948","children":[],"tail":", which was formerly classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1232c"},"text":"section 1232c of Title 33","children":[],"tail":", Navigation and Navigable Waters, repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIV"},"text":"Pub. L. 115–282, title IV","children":[],"tail":", §402(e), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4264"},"text":"132 Stat. 4264","children":[],"tail":", then transferred to this title and renumbered as this section effective upon the enactment of such "},{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" and notwithstanding such repeal."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6fb295a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “the Federal Register” for “Federal Register”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8508/1/A"},"text":"Pub. L. 116–283, § 8508(1)(A)","children":[],"tail":", transferred "},{"tag":"ref","attrib":{"href":"/us/pl/92/340/s16"},"text":"section 16 of Pub. L. 92–340","children":[],"tail":" to this title and renumbered it as this section. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8508/1/B/i"},"text":"Pub. L. 116–283, § 8508(1)(B)(i)","children":[],"tail":", substituted “section 70001(a)(5)” for “section 4(a)(5)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8508/1/B/ii"},"text":"Pub. L. 116–283, § 8508(1)(B)(ii)","children":[],"tail":", substituted “periodically” for “not later than 180 days after the date of the enactment of this section, and periodically thereafter,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8508/1/B/i"},"text":"Pub. L. 116–283, § 8508(1)(B)(i)","children":[],"tail":", substituted “section 70001(a)(5)” for “section 4(a)(5)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8508/1/B/iii"},"text":"Pub. L. 116–283, § 8508(1)(B)(iii)","children":[],"tail":", struck out subsec. (h). Text read as follows: “In this section, the term ‘foreign vessel’ has the meaning given that term in "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s110"},"text":"section 110 of title 46","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6fb295b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6fb295c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition on Entry and Operation of Russian Vessels","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11524"},"text":"Pub. L. 117–263, div. K, title CXV, § 11524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4143"},"text":"136 Stat. 4143","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dK/tCXV/s11524"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this section, during the period in which Executive Order 14065 (87 Fed. Reg. 10293, relating to blocking certain Russian property or transactions), or any successor Executive Order is in effect, no vessel described in subsection (b) may enter or operate in the navigable waters of the United States or transfer cargo in any port or place under the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on application.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prohibition under paragraph (1) shall not apply with respect to a vessel described in subsection (b) if the Secretary of State determines that—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is owned or operated by a Russian national or operated by the government of the Russian Federation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the national security interest not to apply the prohibition to such vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 15 days after making a determination under subparagraph (A), the Secretary of State shall submit to the Committee on Foreign Affairs and the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Foreign Relations and the Committee on Commerce, Science, and Transportation of the Senate written notice of the determination and the basis upon which the determination was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of State shall publish a notice in the Federal Register of each determination made under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition under paragraph (1) shall not apply with respect to vessels engaged in passage permitted under international law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessels Described","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel referred to in subsection (a) is a vessel owned or operated by a Russian national or operated by the government of the Russian Federation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information and Publication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, with the concurrence of the Secretary of State, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain timely information on the registrations of all foreign vessels owned or operated by or on behalf of the Government of the Russian Federation, a Russian national, or a entity organized under the laws of the Russian Federation or any jurisdiction within the Russian Federation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically publish in the Federal Register a list of the vessels described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Governments.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of State shall notify each government, the agents or instrumentalities of which are maintaining a registration of a foreign vessel that is included on a list published under subsection (c)(2), not later than 30 days after such publication, that all vessels registered under such government’s authority are subject to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a government that continues to maintain a registration for a vessel that is included on such list after receiving an initial notification under paragraph (1), the Secretary shall issue an additional notification to such government not later than 120 days after the publication of a list under subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon receiving a notice of arrival under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70001/a/5"},"text":"section 70001(a)(5) of title 46","children":[],"tail":", United States Code, from a vessel described in subsection (b), the Secretary shall notify the master of such vessel that the vessel may not enter or operate in the navigable waters of the United States or transfer cargo in any port or place under the jurisdiction of the United States, unless—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State has made a determination under subsection (a)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary allows provisional entry of the vessel, or transfer of cargo from the vessel, under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisional Entry or Cargo Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this section, the Secretary may allow provisional entry of, or transfer of cargo from, a vessel, if such entry or transfer is necessary for the safety of the vessel or persons aboard.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “Secretary” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11524"},"text":"section 11524 of Pub. L. 117–263","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11002"},"text":"section 11002 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s106"},"text":"section 106 of Title 14","children":[],"tail":", Coast Guard.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
