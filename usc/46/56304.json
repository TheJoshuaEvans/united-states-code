{"tag":"section","attrib":{"id":"idf6ecf8c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56304"},"text":null,"children":[{"tag":"num","attrib":{"value":"56304"},"text":"§ 56304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disputed compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the person entitled to compensation disputes the amount of just compensation determined by the Secretary of Transportation under this chapter, the Secretary shall pay the person, as a tentative advance, 75 percent of the amount determined. The person may bring a civil action against the United States to recover just compensation. If the tentative advance paid under this section is greater than the amount of the court’s judgment, the person shall refund the difference.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6ecf8c8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1655"},"text":"120 Stat. 1655","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ecf8c9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ecf8ca-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ecf8cb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"