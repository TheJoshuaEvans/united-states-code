{"tag":"section","attrib":{"id":"idf6d2b98e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53203"},"text":null,"children":[{"tag":"num","attrib":{"value":"53203"},"text":"§ 53203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of operating agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d2b98f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require, as a condition of including any vessel in the Cable Fleet, that the person that is the owner or operator of the vessel for purposes of section 53202(c) enter into an Operating Agreement with the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b990-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure for Applications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b991-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of applications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning no later than 60 days after the effective date of this chapter, the Secretary shall accept applications for enrollment of vessels in the Cable Fleet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b992-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action on applications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 120 days after receipt of an application for enrollment of a vessel in the Cable Fleet, the Secretary shall approve the application in conjunction with the Operating Agency, and shall enter into an Operating Agreement with the applicant, or provide in writing the reason for denial of that application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b993-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority for Awarding Agreements.—","children":[],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall enter into Operating Agreements with those vessels determined by the Operating Agency, in its sole discretion, to best meet the national security requirements of the United States. After consideration of national security requirements, priority shall be given to an applicant that is a United States citizen under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d2b994-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3521/a"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1992"},"text":"133 Stat. 1992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d2b995-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6d2b996-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6d2b997-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this chapter, referred to in subsec. (b)(1), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", which enacted this chapter and was approved "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
