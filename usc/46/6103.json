{"tag":"section","attrib":{"id":"idf67815f5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s6103"},"text":null,"children":[{"tag":"num","attrib":{"value":"6103"},"text":"§ 6103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf67815f6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s6103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An owner, charterer, managing operator, agent, master, or individual in charge of a vessel failing to report a casualty as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s6101"},"text":"section 6101 of this title","children":[],"tail":" or a regulation prescribed under section 6101 or 6102 is liable to the United States Government for a civil penalty of not more than $25,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67815f7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s6103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person failing to comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s6104"},"text":"section 6104 of this title","children":[],"tail":" or a regulation prescribed under that section is liable to the Government for a civil penalty of not more than $5,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67815f8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/536"},"text":"97 Stat. 536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/498/tII/s212/b/2"},"text":"Pub. L. 98–498, title II, § 212(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2306"},"text":"98 Stat. 2306","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/424/s4/b"},"text":"Pub. L. 100–424, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1590"},"text":"102 Stat. 1590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tIII"},"text":"Pub. L. 104–324, title III","children":[],"tail":", §§ 306(a), 314(b), "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3918"},"text":"110 Stat. 3918","children":[],"tail":", 3922.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67815f9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf67815fa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf67815fb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"33:361","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"33:362","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6103 provides for a civil penalty of $1,000 for any owner, charterer, managing operator, agent, master, or individual in charge of a vessel that fails to report a casualty required to be reported under subsection (b) of section 6101 or an incident required to be reported under subsection (c) of section 6101.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf67815fc-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf67815fd-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" inserted “or 6102” before “is liable” and substituted “not more than $25,000” for “$1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/424"},"text":"Pub. L. 100–424","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498"},"text":"Pub. L. 98–498","children":[],"tail":" struck out “or incident” after “a casualty”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf67815fe-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf67815ff-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498"},"text":"Pub. L. 98–498","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/498/s214"},"text":"section 214 of Pub. L. 98–498","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s2306"},"text":"section 2306 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
