{"tag":"section","attrib":{"id":"idf68b2913-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10305"},"text":null,"children":[{"tag":"num","attrib":{"value":"10305"},"text":"§ 10305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of signing agreement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The agreement required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s10302"},"text":"section 10302 of this title","children":[],"tail":" shall be signed—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68b2914-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10305/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first by the master and dated at that time, after which each seaman shall sign; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68b2915-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10305/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the presence of the master or individual in charge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68b2916-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/563"},"text":"97 Stat. 563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/206/tIV/s403"},"text":"Pub. L. 103–206, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2436"},"text":"107 Stat. 2436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68b2917-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68b2918-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68b2919-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10305","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:565","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10305 describes the procedures for signing the shipping agreement, and for keeping official records of the agreement. It also requires that the agreement include a statement that the seaman understand its provisions, and did so while sober.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68b291a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68b291b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206"},"text":"Pub. L. 103–206","children":[],"tail":" struck out “(a)” before “The agreement”, substituted “the master or individual in charge” for “a shipping commissioner” in par. (2), and struck out subsecs. (b) and (c) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) When the crew is first engaged, the agreement shall be signed in duplicate. One of the copies shall be retained by the shipping commissioner. The other copy shall contain space for the description and signatures of seamen engaged subsequent to the first making of the agreement, and shall be delivered to the master.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) An agreement signed before a shipping commissioner shall be acknowledged and signed by the commissioner on the agreement in the manner and form prescribed by regulation. The acknowledgment and certification shall include a statement by the commissioner that the seaman—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) has read the agreement;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) is acquainted with and understands its conditions; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) has signed it freely and voluntarily when sober.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
