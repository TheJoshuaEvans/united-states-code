{"tag":"section","attrib":{"id":"idf6a2f638-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30501"},"text":null,"children":[{"tag":"num","attrib":{"value":"30501"},"text":"§ 30501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a2f639-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered small passenger vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered small passenger vessel”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a2f63a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30501/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a small passenger vessel, as defined in section 2101, that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6a2f63b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30501/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not a wing-in-ground craft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6a2f63c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30501/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" carrying—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6a2f63d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30501/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 49 passengers on an overnight domestic voyage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6a2f63e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30501/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 150 passengers on any voyage that is not an overnight domestic voyage; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a2f63f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30501/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any wooden vessel constructed prior to ","children":[{"tag":"date","attrib":{"date":"1996-03-11"},"text":"March 11, 1996","children":[],"tail":", carrying at least 1 passenger for hire."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a2f640-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Owner","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “owner” includes a charterer that mans, supplies, and navigates a vessel at the charterer’s own expense or by the charterer’s own procurement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a2f641-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1512"},"text":"120 Stat. 1512","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11503/b"},"text":"Pub. L. 117–263, div. K, title CXV, § 11503(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4130"},"text":"136 Stat. 4130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a2f642-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a2f643-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a2f644-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30501","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:186.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 4286.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “In this chapter” are substituted for “within the meaning of the provisions of title 48 of the Revised Statutes relating to the limitation of the liability of the owners of vessels” because of the codification of title 46, United States Code. The word “supplies” is substituted for “victual” for clarity. The words “and such vessel, when so chartered, shall be liable in the same manner as if navigated by the owner thereof” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6a2f645-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6a2f646-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “In this chapter, the term ‘owner’ includes a charterer that mans, supplies, and navigates a vessel at the charterer’s own expense or by the charterer’s own procurement.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
