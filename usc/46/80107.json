{"tag":"section","attrib":{"id":"idf70980f3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80107"},"text":null,"children":[{"tag":"num","attrib":{"value":"80107"},"text":"§ 80107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salvors of life to share in remuneration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf70980f4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entitlement of Salvors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A salvor of human life, who gave aid following an accident giving rise to salvage, is entitled to a fair share of the payment awarded to the salvor for salvaging the vessel or other property or preventing or minimizing damage to the environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70980f5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Common Ownership of Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The right to remuneration for aid or salvage services is not affected by common ownership of the vessels giving and receiving the aid or salvage services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70980f6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time Limit on Bringing Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A civil action to recover remuneration for giving aid or salvage services must be brought within 2 years after the date the aid or salvage services were given, unless the court in which the action is brought is satisfied that during that 2-year period there had not been a reasonable opportunity to seize the aided or salvaged vessel within the jurisdiction of the court or within the territorial waters of the country of the plaintiff’s residence or principal place of business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70980f7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to a vessel of war or a vessel owned by the United States Government appropriated only to a public service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf70980f8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s11"},"text":"Pub. L. 109–304, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1691"},"text":"120 Stat. 1691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf70980f9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf70980fa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf70980fb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80107(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:729.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1912-08-01/ch268"},"text":"Aug. 1, 1912, ch. 268","children":[],"tail":", §§ 1, 3–5, "},{"tag":"html:a","attrib":{"href":"/us/stat/37/242"},"text":"37 Stat. 242","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/102/241/s40"},"text":"Pub. L. 102–241, § 40","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 19, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/2225"},"text":"105 Stat. 2225","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80107(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:727.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80107(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:730.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80107(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:731.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “civil action” are substituted for “suit”, the words “must be brought within 2 years after” are substituted for “shall not be maintainable if brought later than two years from”, and the word “seize” is substituted for “arresting”, for consistency in the revised title. The words “of the plaintiff’s residence or principal place of business” are substituted for “in which the libelant resides or has his principal place of business” for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsectoin [sic] (d), the reference to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2304"},"text":"section 2304 of title 46","children":[],"tail":" is omitted because of the amendment to section 2304 in section 14(8) of the bill."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
