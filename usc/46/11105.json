{"tag":"section","attrib":{"id":"idf68fe434-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11105"},"text":null,"children":[{"tag":"num","attrib":{"value":"11105"},"text":"§ 11105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wages on discharge when vessel sold","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68fe435-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When a vessel of the United States is sold in a foreign country, the master shall deliver to the consular officer a certified crew list and the agreement required by this part. The master shall pay each seaman the wages due the seaman and provide the seaman with employment on board another vessel of the United States bound for the port of original engagement of the seaman or to another port agreed on. If employment cannot be provided, the master shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68fe436-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the seaman with the means to return to the port of original engagement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe437-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the seaman passage to the port of original engagement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe438-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11105/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposit with the consular officer an amount of money considered sufficient by the officer to provide the seaman with maintenance and passage home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe439-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The consular officer shall endorse on the agreement the particulars of the payment, provision, or deposit made under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe43a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An owner of a vessel is liable to the United States Government for a civil penalty of $500 if the master does not comply with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68fe43b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/579"},"text":"97 Stat. 579","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68fe43c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68fe43d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68fe43e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"11105","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:684","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 11105 provides that when a United States vessel is sold in a foreign port, the seamen must be provided employment on another vessel, or passage to the port of original shipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
