{"tag":"section","attrib":{"id":"idf6e81621-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108"},"text":null,"children":[{"tag":"num","attrib":{"value":"55108"},"text":"§ 55108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Platform jackets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e81622-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e81623-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coastwise qualified vessel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “coastwise qualified vessel” means a vessel that has been issued a certificate of documentation with a coastwise endorsement under chapter 121 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81624-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Platform jacket","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “platform jacket” refers to a single physical component and includes any type of offshore exploration, development, or production structure or component thereof, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e81625-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" platform jackets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e81626-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tension leg or SPAR platform superstructures (including the deck, drilling rig and support utilities, and supporting structure);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e81627-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hull (including vertical legs and connecting pontoons or vertical cylinder);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e81628-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tower and base sections of a platform jacket;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e81629-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jacket structures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e8162a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deck modules (known as “topsides”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e8162b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55102"},"text":"Section 55102 of this title","children":[],"tail":" does not apply to the transportation of a platform jacket in or on a non-coastwise qualified launch barge between two points in the United States, at one of which there is an installation or other device within the meaning of section 4(a) of the Outer Continental Shelf Lands Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1333/a"},"text":"43 U.S.C. 1333(a)","children":[],"tail":"), if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e8162c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the launch barge was built before ","children":[{"tag":"date","attrib":{"date":"2000-12-31"},"text":"December 31, 2000","children":[],"tail":", and has a launch capacity of at least 12,000 long tons; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e8162d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation makes a determination, in accordance with procedures established under subsection (c), that a suitable coastwise qualified vessel is not available for use in the transportation and, if needed, launch or installation of a platform jacket.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e8162e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures To Maximize Use of Coastwise Qualified Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall adopt procedures implementing this section that are reasonably designed to provide timely information so as to maximize the use of coastwise qualified vessels. The procedures shall, among other things, establish that for purposes of this section, a coastwise qualified vessel shall be deemed to be not available only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e8162f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on application by an owner or operator for the use of a non-coastwise qualified launch barge for transportation of a platform jacket under this section (which application shall include all relevant information, including engineering details and timing requirements), the Secretary promptly publishes a notice in the Federal Register—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e81630-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the project and the platform jacket involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e81631-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising that all relevant information reasonably needed to assess the transportation requirements for the platform jacket will be made available to interested parties on request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e81632-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requesting that information on the availability of coastwise qualified vessels be submitted within 30 days after publication of that notice; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81633-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e81634-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no information is submitted to the Secretary within that 30 day period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e81635-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55108/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner or operator of a coastwise qualified vessel submits information to the Secretary asserting that the owner or operator has a suitable coastwise qualified vessel available for the transportation, but the Secretary determines, within 90 days after the notice is first published, that the coastwise qualified vessel is not suitable or reasonably available for the transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e81636-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1636"},"text":"120 Stat. 1636","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e81637-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e81638-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e81639-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55108","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:883 (last proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-06-05/ch250/s27"},"text":"June 5, 1920, ch. 250, § 27","children":[],"tail":" (last proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/999"},"text":"41 Stat. 999","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1935-07-02/ch355"},"text":"July 2, 1935, ch. 355","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/442"},"text":"49 Stat. 442","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/329"},"text":"Pub. L. 101–329","children":[],"tail":" [100–329], § 1(a)(2), "},{"tag":"html:span","attrib":{},"text":"June 7, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/588"},"text":"102 Stat. 588","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/107/295/tII/s213/c"},"text":"Pub. L. 107–295, title II, § 213(c)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/116/2100"},"text":"116 Stat. 2100","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/108/293/tIV/s417"},"text":"Pub. L. 108–293, title IV, § 417","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/118/1048"},"text":"118 Stat. 1048","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “coastwise endorsement under chapter 121” are substituted for “coastwise endorsement under section 12106” because section 12106 is being restated in various sections in revised chapter 121.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55102"},"text":"Section 55102 of this title","children":[],"tail":" does not apply” are substituted for “shall not be deemed transportation subject to this section” for consistency in the chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
