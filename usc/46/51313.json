{"tag":"section","attrib":{"id":"idf6c1f127-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51313"},"text":null,"children":[{"tag":"num","attrib":{"value":"51313"},"text":"§ 51313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c1f128-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An Advisory Board to the United States Merchant Marine Academy shall be established to visit the Academy at least once during each academic year, for the purpose of examining the course of instruction and management of the Academy and advising the Maritime Administrator and the Superintendent of the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f129-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment and Terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall be composed of not more than 7 individuals appointed by the Secretary of Transportation. The individuals must be distinguished in education and other fields related to the Academy. Members of the Board shall be appointed for terms of not more than 3 years and may be reappointed. The Secretary shall designate one of the members as chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f12a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Travel Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When serving away from home or regular place of business, a member of the Board shall be allowed travel expenses, including per diem in lieu of subsistence, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f12b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51313/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Chapter 10 of title 5 does not apply to the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c1f12c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1576"},"text":"120 Stat. 1576","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/292"},"text":"Pub. L. 117–286, § 4(a)(292)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4338"},"text":"136 Stat. 4338","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c1f12d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6c1f12e-2930-11