{"tag":"section","attrib":{"id":"idf683fc7c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8105"},"text":null,"children":[{"tag":"num","attrib":{"value":"8105"},"text":"§ 8105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing vessel exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, neither the International Convention on Standards of Training, Certification and Watchkeeping for Seafarers, 1978, nor any amendment to such convention, shall apply to a fishing vessel, including a fishing vessel used as a fish tender vessel.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf683fc7d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tXI/s1146/a"},"text":"Pub. L. 104–324, title XI, § 1146(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3992"},"text":"110 Stat. 3992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf683fc7e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf683fc7f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf683fc80-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8105, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/550"},"text":"97 Stat. 550","children":[],"tail":", authorized Secretary to prescribe regulations to carry out this part prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/595/tVI/s603/7/A"},"text":"Pub. L. 101–595, title VI, § 603(7)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2993"},"text":"104 Stat. 2993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
