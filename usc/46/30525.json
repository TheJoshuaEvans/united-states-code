{"tag":"section","attrib":{"id":"idf6a2f677-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30525"},"text":null,"children":[{"tag":"num","attrib":{"value":"30525"},"text":"§ 30525.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apportionment of losses","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If the amounts determined under sections 30523 and 30524 of this title are insufficient to pay all claims—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a2f678-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30525/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all claimants shall be paid in proportion to their respective losses out of the amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s30523"},"text":"section 30523 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a2f679-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30525/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal injury and death claimants, if any, shall be paid an additional amount in proportion to their respective losses out of the additional amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s30524/b"},"text":"section 30524(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a2f67a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1513"},"text":"120 Stat. 1513","children":[],"tail":", § 30507; renumbered