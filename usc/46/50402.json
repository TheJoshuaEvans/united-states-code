{"tag":"section","attrib":{"id":"idf6bd3580-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402"},"text":null,"children":[{"tag":"num","attrib":{"value":"50402"},"text":"§ 50402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maritime Transportation System National Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6bd3581-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a Maritime Transportation System National Advisory Committee (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bd3582-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall advise the Secretary of Transportation on matters relating to the United States maritime transportation system and its seamless integration with other segments of the transportation system, including the viability of the United States Merchant Marine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bd3583-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bd3584-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall consist of 27 members appointed by the Secretary of Transportation in accordance with this section and section 15109.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd3585-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expertise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd3586-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Committee shall be appointed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bd3587-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least one member shall represent the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3588-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least one member shall represent the Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3589-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least one member shall represent the Corps of Engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd358a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least one member shall represent the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd358b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least one member shall represent Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd358c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least one member shall represent State and local governmental entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd358d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Additional members shall represent private sector entities that reflect a cross-section of maritime industries, including port and water stakeholders, academia, and labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd358e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may appoint additional representatives from other Federal agencies as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd358f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restrictions on members representing federal agencies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Committee that represent Federal agencies shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bd3590-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprise more than one-third of the total membership of the Committee or of any subcommittee therein; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3591-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the chair or co-chair of the Committee or of any subcommittee therein.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd3592-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 15109—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bd3593-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee shall be treated as a committee established under chapter 151; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3594-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50402/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation shall fulfill all duties and responsibilities and have all authorities of the Secretary of Homeland Security with regard to the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6bd3595-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8332(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4703"},"text":"134 Stat. 4703","children":[],"tail":", § 55502; renumbered § 50402, "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dC/tXXXV/s3512/a/3"},"text":"Pub. L. 117–81, div. C, title XXXV, § 3512(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2239"},"text":"135 Stat. 2239","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6bd3596-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6bd3597-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6bd3598-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s55502"},"text":"section 55502 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6bd3599-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6bd359a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Treatment of Existing Committee","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8332(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4704"},"text":"134 Stat. 4704","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dC/tXXXV/s3512/b"},"text":"Pub. L. 117–81, div. C, title XXXV, § 3512(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2239"},"text":"135 Stat. 2239","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/81/dC/tXXXV/s3512/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Notwithstanding any other provision of law—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an advisory committee substantially similar to the Committee established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50402"},"text":"section 50402 of title 46","children":[],"tail":", United States Code, and that was in force or in effect on the day before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"], including the charter, membership, and other aspects of such advisory committee, may remain in force or in effect for the 2-year period beginning on the date of the enactment of this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during such 2-year period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements relating the Maritime Transportation System National Advisory Committee established by such section shall be treated as satisfied by such substantially similar advisory committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the enactment of this section shall not be the basis—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deem, find, or declare such committee, including the charter, membership, and other aspects thereof, void, not in force, or not in effect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to suspend the activities of such committee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to bar the members of such committee from a meeting.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
