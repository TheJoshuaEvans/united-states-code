{"tag":"section","attrib":{"id":"idf6e0e9fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53725"},"text":null,"children":[{"tag":"num","attrib":{"value":"53725"},"text":"§ 53725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions against obligor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e0e9fe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a default under a guaranteed obligation or related agreement, the Secretary or Administrator may take any action against the obligor or another liable party that the Secretary or Administrator considers necessary to protect the interests of the United States Government. A civil action may be brought in the name of the United States or the obligee. The obligee shall make available to the Government all records and evidence necessary to prosecute the action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0e9ff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Title, Possession, and Purchase","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e0ea00-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53725/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or Administrator may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e0ea01-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53725/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept a conveyance of title to and possession of property from the obligor or another party liable to the Secretary or Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e0ea02-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53725/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase the property for an amount not greater than the unpaid principal amount of the obligation and interest thereon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea03-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53725/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of excess","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, through the sale of property, the Secretary or Administrator receives an amount of cash greater than the unpaid principal amount of the obligation, the unpaid interest on the obligation, and the expenses of collecting those amounts, the Secretary or Administrator shall pay the excess to the obligor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e0ea04-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1619"},"text":"120 Stat. 1619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/F"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/10/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(10)(B)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e0ea05-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e0ea06-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e0ea07-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text"