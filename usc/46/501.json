{"tag":"section","attrib":{"id":"idf64d358e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501"},"text":null,"children":[{"tag":"num","attrib":{"value":"501"},"text":"§ 501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of navigation and vessel-inspection laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf64d358f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"On Request of Secretary of Defense.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf64d3590-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On request of the Secretary of Defense, the head of an agency responsible for the administration of the navigation or vessel-inspection laws shall waive compliance with those laws to the extent the Secretary considers necessary in the interest of national defense to address an immediate adverse effect on military operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf64d3591-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submittal of explanation to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 24 hours after making a request under paragraph (1), the Secretary of Defense shall submit to the Committee on Transportation and Infrastructure and the Committee on Armed Services of the House of Representatives and the Committee on Commerce, Science, and Transportation and the Committee on Armed Services of the Senate a written explanation of the circumstances requiring such a waiver in the interest of national defense, including a confirmation that there are insufficient qualified vessels to meet the needs of national defense without such a waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf64d3592-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"By Head of Agency.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf64d3593-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon a determination by the President that a waiver of the navigation or vessel-inspection laws is necessary in the interest of national defense, the head of an agency responsible for the administration of such laws,","children":[{"tag":"ref","attrib":{"idref":"fn002000"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002000"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" may waive compliance with such laws—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf64d3594-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" following a determination in accordance with the requirements of paragraph (3) by the Maritime Administrator, acting in the Administrator’s capacity as Director, National Shipping Authority, of the non-availability of qualified United States flag capacity to meet national defense requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d3595-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not earlier than 48 hours after a waiver request is published under paragraph (6)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d3596-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a vessel specific basis to the extent, in the manner, and on the terms the head of such agency, in consultation with the Administrator, acting in such capacity, prescribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf64d3597-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of waiver.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf64d3598-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subparagraphs (B) and (C), a waiver issued under this subsection shall be for a period of not more than 10 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d3599-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the termination of the period of a waiver issued under this subsection, the head of an agency may extend the waiver for an additional period of not more than 10 days, if the Maritime Administrator makes the determination referred to in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d359a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aggregate duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The aggregate duration of the period of all waivers and extensions of waivers under this subsection with respect to any one set of events shall not exceed 45 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf64d359b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determinations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Maritime Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf64d359c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each determination referred to in paragraph (1)(A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf64d359d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any actions that could be taken to enable qualified United States flag capacity to meet national defense requirements prior to the issuance of a waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf64d359e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not assess the non-availability of qualified United States flag capacity to meet national defense requirements retrospectively after the date on which a waiver is requested;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d359f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide notice of each such determination to the Secretary of Transportation and the head of the agency referred to in paragraph (1) for which the determination is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d35a0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish each such determination on the Internet Web site of the Department of Transportation not later than 48 hours after notice of the determination is provided to the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf64d35a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to congress.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf64d35a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an agency referred to in paragraph (1) shall notify the Committee on Transportation and Infrastructure and the Committee on Armed Services of the House of Representatives and the Committee on Commerce, Science, and Transportation and the Committee on Armed Services of the Senate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf64d35a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of any request for a waiver of the navigation or vessel-inspection laws under this section not later than 48 hours after receiving such a request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf64d35a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the issuance of any such waiver not later than 48 hours after such issuance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d35a5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such head of an agency shall include in each notification under subparagraph (A)(ii) an explanation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf64d35a6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons the waiver is necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf64d35a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons actions referred to in paragraph (3)(A) are not feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d35a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification required for extensions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this paragraph, an extension requested or issued under paragraph (2)(B) shall be treated in the same manner as a waiver requested or issued under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf64d35a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prospective application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No waiver shall be issued for a vessel if, at the time of the waiver request under this section, such vessel is laden with merchandise that, pursuant to the requested waiver, could be unladen at points or places to which the coastwise laws apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf64d35aa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication requirements.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf64d35ab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of waiver requests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon receiving a request for a waiver under this subsection, the head of an agency referred to in paragraph (1) shall publish such request on the website of such agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d35ac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of waiver denial","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 48 hours after denying a waiver requested under this subsection, the head of an agency referred to in paragraph (1) shall publish on the website of such agency an explanation for denying such waiver, including applicable findings to support the denial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf64d35ad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf64d35ae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 10 days after the date of the conclusion of the voyage of a vessel that, during such voyage, operated under a waiver issued under this section, the owner or operator of the vessel and the individual requesting such waiver (if not the owner or operator of the vessel) shall submit to the Maritime Administrator a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf64d35af-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and flag of the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d35b0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the owner and operator of the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d35b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dates of the voyage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d35b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any relevant ports of call;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d35b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the cargo carried;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d35b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation as to why the waiver was in the interest of national defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf64d35b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Maritime Administrator determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf64d35b6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 48 hours after receiving a report under paragraph (1), the Maritime Administrator shall publish such report on an appropriate website of the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf64d35b7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority granted by this section shall terminate at such time as the Congress by concurrent resolution or the President may designate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf64d35b8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s4"},"text":"Pub. L. 109–304, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1490"},"text":"120 Stat. 1490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/dC/tXXXV/s3510"},"text":"Pub. L. 110–417, div. C, title XXXV, § 3510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4769"},"text":"122 Stat. 4769","children":[],"tai