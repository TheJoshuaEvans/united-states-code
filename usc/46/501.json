:"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"501","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:3 note prec.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-12-27/ch1155"},"text":"Dec. 27, 1950, ch. 1155","children":[],"tail":", §§ 1, 2, "},{"tag":"html:a","attrib":{"href":"/us/stat/64/1120"},"text":"64 Stat. 1120","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “When the head of an agency . . . considers it necessary” are substituted for “either upon his own initiative or upon the written recommendation of the head of any other Government agency, when he deems that such action is necessary” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf64d35bc-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf64d35bd-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3541/1/A"},"text":"Pub. L. 117–263, § 3541(1)(A)","children":[],"tail":", added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “When the head of an agency responsible for the administration of the navigation or vessel-inspection laws considers it necessary in the interest of national defense, the individual, following a determination by the Maritime Administrator, acting in the Administrator’s capacity as Director, National Shipping Authority, of the non-availability of qualified United States flag capacity to meet national defense requirements, may waive compliance with those laws to the extent, in the manner, and on the terms the individual, in consultation with the Administrator, acting in that capacity, prescribes.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3541/1/B"},"text":"Pub. L. 117–263, § 3541(1)(B)","children":[],"tail":", substituted “determination referred to in paragraph (1)(A)” for “determinations referred to in paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3541/1/C"},"text":"Pub. L. 117–263, § 3541(1)(C)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A). Prior to amendment, subpar. (A) read as follows: “for each determination referred to in paragraph (1), identify any actions that could be taken to enable qualified United States flag capacity to meet national defense requirements;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3541/1/D"},"text":"Pub. L. 117–263, § 3541(1)(D)","children":[],"tail":", added pars. (5) and (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3541/2"},"text":"Pub. L. 117–263, § 3541(2)","children":[],"tail":", inserted “and the individual requesting such waiver (if not the owner or operator of the vessel)” before “shall submit” in introductory provisions, added subpars. (B), (E), and (F), and redesignated former subpars. (B), (C), and (D) as (C), (D), and (G), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3502/a/1/A"},"text":"Pub. L. 116–283, § 3502(a)(1)(A)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “On request of the Secretary of Defense, the head of an agency responsible for the administration of the navigation or vessel-inspection laws shall waive compliance with those laws to the extent the Secretary considers necessary in the interest of national defense.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3502/a/1/B/i"},"text":"Pub. L. 116–283, § 3502(a)(1)(B)(i)","children":[],"tail":", (ii), added par. (2) and redesignated former par. (2) as (3). Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3502/a/1/B/i"},"text":"Pub. L. 116–283, § 3502(a)(1)(B)(i)","children":[],"tail":", redesignated par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3502/a/1/B/ii/I"},"text":"Pub. L. 116–283, § 3502(a)(1)(B)(ii)(I)","children":[],"tail":", substituted “paragraph (3)(A)” for “paragraph (2)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3502/a/1/B/ii/II"},"text":"Pub. L. 116–283, § 3502(a)(1)(B)(ii)(II)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3502/a/1/C"},"text":"Pub. L. 116–283, § 3502(a)(1)(C)","children":[],"tail":", (D), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" substituted “the Committee on Transportation and Infrastructure and the Committee on Armed Services of the House of Representatives and the Committee on Commerce, Science, and Transportation and the Committee on Armed Services of the Senate” for “the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" designated existing provisions as par. (1), inserted par. (1) heading, and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “When the head of an agency responsible for the administration of the navigation or vessel-inspection laws considers it necessary in the interest of national defense, the individual may waive compliance with those laws to the extent, in the manner, and on the terms the individual prescribes.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf64d35be-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf64d35bf-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dC/tXXXV/s3502/a/2"},"text":"Pub. L. 116–283, div. C, title XXXV, § 3502(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4398"},"text":"134 Stat. 4398","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dC/tXXXV/s3502/a/2"},"text":"“The amendments made by paragraph (1) [amending this section] shall apply with respect to waivers issued after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
