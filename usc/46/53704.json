hildren":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53704(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1273(f) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XI, § 1103(f), as added "},{"tag":"html:a","attrib":{"href":"/us/act/1938-06-23/ch600/s46"},"text":"June 23, 1938, ch. 600, § 46","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/52/969"},"text":"52 Stat. 969","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-08-15/ch513/s1"},"text":"Aug. 15, 1953, ch. 513, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/626"},"text":"67 Stat. 626","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1954-09-03/ch1265/s3"},"text":"Sept. 3, 1954, ch. 1265, § 3","children":[],"tail":", "},{"tag":"html:a"