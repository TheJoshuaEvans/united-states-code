{"tag":"section","attrib":{"id":"idf6c46206-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320"},"text":null,"children":[{"tag":"num","attrib":{"value":"51320"},"text":"§ 51320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of guarantees with gifts for major projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c46207-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c46208-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Major project","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “major project” means a project estimated to cost at least $1,000,000 for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c46209-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase or other procurement of real or personal property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c4620a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction, renovation, or repair of real or personal property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c4620b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Major united states commercial bank","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “major United States commercial bank” means a commercial bank that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c4620c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an insured bank (as defined in section 3(h) of the Federal Deposit Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/h"},"text":"12 U.S.C. 1813(h)","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c4620d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is headquartered in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c4620e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has total net assets of an amount considered by the Maritime Administrator to qualify the bank as a major bank.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c4620f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Major united states investment management firm","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “major United States investment management firm” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c46210-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any broker or dealer (as such terms are defined in section 3 of the Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"15 U.S.C. 78c","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c46211-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any investment adviser or provider of investment supervisory services (as such terms are defined in section 202 of the Investment Advisers Act of 1940 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s80b–2"},"text":"15 U.S.C. 80b–2","children":[],"tail":")); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c46212-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a major United States commercial bank that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c46213-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is headquartered in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c46214-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds for the account of others investment assets in a total amount considered by the Maritime Administrator to qualify the bank as a major investment management firm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46215-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified guarantee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified guarantee”, with respect to a major project, means a guarantee that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c46216-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made by 1 or more persons in connection with a donation for the project of a total amount in cash or securities that the Maritime Administrator determines is sufficient to defray a substantial portion of the total cost of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c46217-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made to facilitate or expedite the completion of the project in reasonable anticipation that other donors will contribute sufficient funds or other resources in amounts sufficient to pay for completion of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c46218-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is set forth as a written agreement providing that the donor will furnish in cash or securities, in addition to the donor’s other gift or gifts for the project, any additional amount that may become necessary for paying the cost of completing the project by reason of a failure to obtain from other donors or sources funds or other resources in amounts sufficient to pay the cost of completing the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c46219-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is accompanied by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c4621a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an irrevocable and unconditional standby letter of credit for the benefit of the United States Merchant Marine Academy that is in the amount of the guarantee and is issued by a major United States commercial bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c4621b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified account control agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c4621c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified account control agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified account control agreement”, with respect to a guarantee of a donor, means an agreement among the donor, the Maritime Administrator, and a major United States investment management firm that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c4621d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures the availability of sufficient funds or other financial resources to pay the amount guaranteed during the period of the guarantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c4621e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the perfection of a security interest in the assets of the account for the United States for the benefit of the United States Merchant Marine Academy with the highest priority available for liens and security interests under applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c4621f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires the donor to maintain in an account with the investment management firm assets having a total value that is not less than 130 percent of the amount guaranteed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c46220-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires the investment management firm, whenever the value of the account is less than the value required to be maintained under subparagraph (C), to liquidate any noncash assets in the account and reinvest the proceeds in Treasury bills issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3104"},"text":"section 3104 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c46221-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (d), the Maritime Administrator may accept a qualified guarantee from a donor or donors for the completion of a major project for the benefit of the United States Merchant Marine Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c46222-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligation Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a qualified guarantee accepted under this section shall be considered as contract authority to provide obligation authority for purposes of Federal fiscal and contractual requirements. Funds available for a project for which such a guarantee has been accepted may be obligated and expended for the project without regard to whether the total amount of funds and other resources available for the project (not taking into account the amount of the guarantee) is sufficient to pay for completion of the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c46223-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator may not accept a qualified guarantee under this section for the completion of a major project until 30 days after the date on which a report of the facts concerning the proposed guarantee is submitted to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c46224-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51320/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Commingling Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator may not enter into any contract or other transaction involving the use of a qualified guarantee and appropriated funds in the same contract or transaction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c46225-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dC/tXXXV/s3510/a"},"text":"Pub. L. 115–91, div. C, title XXXV, § 3510(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1916"},"text":"131 Stat. 1916","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
