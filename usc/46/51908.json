{"tag":"section","attrib":{"id":"idf6c91d16-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51908"},"text":null,"children":[{"tag":"num","attrib":{"value":"51908"},"text":"§ 51908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against unauthorized manufacture, sale, possession, or display of awards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c91d17-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as authorized by this chapter or the Secretary of Transportation, a person may not manufacture, sell, possess, or display a decoration or medal provided for in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c91d18-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person violating this section is liable to the United States Government for a civil penalty of not more than $2,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c91d19-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1585"},"text":"120 Stat. 1585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dC/tX