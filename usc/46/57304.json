{"tag":"section","attrib":{"id":"idf6f1b2fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57304"},"text":null,"children":[{"tag":"num","attrib":{"value":"57304"},"text":"§ 57304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible acquisition dates","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"At the option of the owner, the acquisition of an obsolete vessel under this chapter shall occur—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f1b2fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57304/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the owner contracts for the construction or purchase of a new vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b2fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57304/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 5 days of the actual date of delivery of the new vessel to the owner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b2fe-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1662"},"text":"120 Stat. 1662","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b2ff-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f1b300-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f1b301-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"