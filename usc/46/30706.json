{"tag":"section","attrib":{"id":"idf6a567eb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30706"},"text":null,"children":[{"tag":"num","attrib":{"value":"30706"},"text":"§ 30706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Defenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a567ec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Due Diligence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a carrier has exercised due diligence to make the vessel in all respects seaworthy and to properly man, equip, and supply the vessel, the carrier and the vessel are not liable for loss or damage arising from an error in the navigation or management of the vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a567ed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Defenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A carrier and the vessel are not liable for loss or damage arising from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a567ee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dangers of the sea or other navigable waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a567ef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acts of God;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a567f0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30706/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public enemies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a567f1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30706/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seizure under legal process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a567f2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30706/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inherent defect, quality, or vice of the goods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a567f3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30706/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insufficiency of package;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a567f4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30706/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act or omission of the shipper or owner of the goods or their agent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a567f5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30706/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" saving or attempting to save life or property at sea, including a deviation in rendering such a service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a567f6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1517"},"text":"120 Stat. 1517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a567f7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a567f8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a567f9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30706","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:192.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1893-02-13/ch105/s3"},"text":"Feb. 13, 1893, ch. 105, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/27/445"},"text":"27 Stat. 445","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section is restated as two subsections to clarify that the exercise of due diligence in making the vessel seaworthy is a condition only to the defense of error in navigation or management restated in subsection (a). See ","children":[{"tag":"i","attrib":{},"text":"May v. Hamburg-Amerikanische Packetfahrt Aktiengesellschaft (The Isis)","children":[],"tail":", 290 U.S. 333, 353 (1933). The words “transporting merchandise or property to or from any port in the United States of America” are omitted because of section 30702(a) of the revised title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
