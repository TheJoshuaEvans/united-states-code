{"tag":"section","attrib":{"id":"idf7071095-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125"},"text":null,"children":[{"tag":"num","attrib":{"value":"70125"},"text":"§ 70125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Port security training for facility security officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7071096-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Facility Security Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish comprehensive facility security officer training requirements designed to provide full security training that would lead to certification of such officers. In establishing the requirements, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7071097-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with affected industry stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7071098-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" evaluate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf7071099-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf707109a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing security training programs employed at marine terminal facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf707109b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing port security training programs developed by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf707109c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training program shall provide validated training that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf707109d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides training at the awareness, performance, management, and planning levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf707109e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilizes multiple training mediums and methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf707109f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes a validated provisional on-line certification methodology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710a0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for continuing education and training for facility security officers beyond certification requirements, including a program to educate on the dangers and issues associated with the shipment of hazardous and especially hazardous cargo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" addresses port security topics, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf70710a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facility security plans and procedures, including how to develop security plans and security procedure requirements when threat levels are elevated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70710a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facility security force operations and management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70710a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical security and access control at facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70710a5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods of security for preventing and countering cargo theft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70710a6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" container security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70710a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognition and detection of weapons, dangerous substances, and devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70710a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation and maintenance of security equipment and systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70710a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security threats and patterns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70710aa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/5/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security incident procedures, including procedures for communicating with governmental and nongovernmental emergency response providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70710ab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/5/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evacuation procedures;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710ac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with, and supports implementation of, the National Incident Management System, the National Response Plan, the National Infrastructure Protection Plan, the National Preparedness Guidance, the National Preparedness Goal, the National Maritime Transportation Security Plan, and other such national initiatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710ad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is evaluated against clear and consistent performance measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710ae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses security requirements under facility security plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710af-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses requirements under the International Code for the Security of Ships and Port Facilities to address shore leave for mariners and access to visitors, representatives of seafarers’ welfare organizations, and labor organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710b0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other subject matters as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70710b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing Security Training","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with the Secretary of Transportation, shall work with State and local law enforcement agencies and industry stakeholders to develop and certify the following additional security training requirements for Federal, State, and local officials with security responsibilities at United States seaports:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf70710b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A program to familiarize them with port and shipping operations, requirements of the Maritime Transportation Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Public Law 107–295","children":[],"tail":"), and other port and cargo security programs that educates and trains them with respect to their roles and responsibilities."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A program to familiarize them with dangers and potential issues with respect to shipments of hazardous and especially hazardous cargoes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70710b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A program of continuing education as deemed necessary by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70710b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training Partners","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing curriculum and delivering training established pursuant to subsections (a) and (c), the Secretary, in coordination with the Maritime Administrator of the Department of Transportation and consistent with section 109 of the Maritime Transportation Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70101"},"text":"46 U.S.C. 70101","children":[],"tail":" note), shall work with institutions with maritime expertise and with industry stakeholders with security expertise to develop appropriate training capacity to ensure that training can be provided in a geographically balanced manner to personnel seeking certification under subsection (a) or education and training under subsection (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70710b6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70125/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Established Grant Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall issue regulations or grant solicitations for grants for homeland security or port security to ensure that activities surrounding the development of curriculum and the provision of training and these activities are eligible grant activities under both grant programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf70710b7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVIII/s821/a"},"text":"Pub. L. 111–281, title VIII, § 821(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3001"},"text":"124 Stat. 3001","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1/14"},"text":"Pub. L. 111–330, § 1(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3570"},"text":"124 Stat. 3570","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf70710b8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf70710b9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf70710ba-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Maritime Transportation Security Act of 2002, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2064"},"text":"116 Stat. 2064","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf70710bb-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/330"},"text":"Pub. L. 111–330","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/s821/a"},"text":"Pub. L. 111–281, § 821(a)","children":[],"tail":", which enacted this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf70710bc-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf70710bd-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1"},"text":"Pub. L. 111–330, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3569"},"text":"124 Stat. 3569","children":[],"tail":", provided that the amendment made by section 1(12) is effective with the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
