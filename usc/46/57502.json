{"tag":"section","attrib":{"id":"idf6f1b32f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57502"},"text":null,"children":[{"tag":"num","attrib":{"value":"57502"},"text":"§ 57502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction, reconditioning, and remodeling of vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f1b330-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may have new vessels constructed, and have old vessels reconditioned or remodeled, as the Secretary determines necessary to carry out the objectives of this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b331-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Place of Work","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Construction, reconditioning, and remodeling of vessels under subsection (a) shall take place in shipyards in the continental United States (including Alaska and Hawaii). However, if satisfactory contracts cannot be obtained from private shipbuilders, the Secretary may have the work done in navy yards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b332-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Construction-Differential Subsidy Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Contracts for the construction, reconstruction, or reconditioning of a vessel by a private shipbuilder under this chapter are subject to the provisions of title V of the Merchant Marine Act, 1936, applicable to a contract with a private shipbuilder for the construction of a vessel under title V of that Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b333-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1664"},"text":"120 Stat. 1664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b334-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f1b335-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f1b336-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"57502(a), (b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1192.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title VII, § 702, "},{"tag":"html:a","attrib":{"href":"/us/stat/49/2008"},"text":"49 Stat. 2008","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/85/191"},"text":"Pub. L. 85–191","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/71/471"},"text":"71 Stat. 471","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/86/624/s35/c"},"text":"Pub. L. 86–624, § 35(c)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/421"},"text":"74 Stat. 421","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/104"},"text":"Pub. L. 97–31, § 12(104)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/162"},"text":"95 Stat. 162","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"57502(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1193(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title VII, § 703(b), "},{"tag":"html:a","attrib":{"href":"/us/stat/49/2008"},"text":"49 Stat. 2008","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “for such new construction or reconstruction, in accordance with the provisions of this chapter” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6f1b337-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6f1b338-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Merchant Marine Act, 1936, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"act June 29, 1936, ch. 858","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1985"},"text":"49 Stat. 1985","children":[],"tail":". Title V of the Act enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53101"},"text":"section 53101 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1936 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
