{"tag":"section","attrib":{"id":"idf656abed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2113"},"text":null,"children":[{"tag":"num","attrib":{"value":"2113"},"text":"§ 2113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to exempt certain vessels","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If the Secretary decides that the application of a provision of part B, C, F, or G of this subtitle is not necessary in performing the mission of the vessel engaged in excursions or an oceanographic research vessel, or not necessary for the safe operation of certain vessels carrying passengers, the Secretary by regulation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf656abee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2113/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a vessel, issue a special permit specifying the conditions of operation and equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf656abef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2113/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt an oceanographic research vessel from that provision under conditions the Secretary may specify;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf656abf0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2113/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish different operating and equipment requirements for vessels defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101/55/A"},"text":"section 2101(55)(A) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf656abf1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2113/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain different structural fire protection, manning, operating, and equipment requirements for vessels that satisfied requirements set forth in the Passenger Vessel Safety Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206"},"text":"Public Law 103–206","children":[],"tail":") before "},{"tag":"date","attrib":{"date":"1994-06-21"},"text":"June 21, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf656abf2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/508"},"text":"97 Stat. 508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/206/tV/s511/a"},"text":"Pub. L. 103–206, title V, § 511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2441"},"text":"107 Stat. 2441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s710"},"text":"Pub. L. 104–324, title VII, § 710","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3935"},"text":"110 Stat. 3935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV"},"text":"Pub. L. 115–232, div. C, title XXXV","children":[],"tail":", §§ 3541(b)(6), 3542(a), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2323"},"text":"132 Stat. 2323","children":[],"tail":", 2324; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVI/s11601/c/1"},"text":"Pub. L. 117–263, div. K, title CXVI, § 11601(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4146"},"text":"136 Stat. 4146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/k/1/B"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(k)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1759"},"text":"139 Stat. 1759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf656abf3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf656abf4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf656abf5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2113","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:445","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:453","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2113 provides the Secretary with the authority to exempt certain vessels from the inspection and manning requirements of law when vessels are engaged in excursions or oceanographic research. This is the authority of the issuance of excursion permits when special circumstances justify the waiver of certain maritime safety and seamen’s welfare laws for a short period of time. It also contains flexible exemption authority for regulation of oceanographic research vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf656abf6-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf656abf7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Passenger Vessel Safety Act of 1993, referred to in par. (4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/tV"},"text":"Pub. L. 103–206, title V","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2439"},"text":"107 Stat. 2439","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1993 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf656abf8-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “section 2101(55)(A)” for “section 2101(53)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “section 2101(53)(A)” for “section 2101(51)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3541/b/6"},"text":"Pub. L. 115–232, § 3541(b)(6)","children":[],"tail":", substituted “section 2101(51)(A)” for “section 2101(42)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3542/a"},"text":"Pub. L. 115–232, § 3542(a)","children":[],"tail":", added par. (4) and struck out former par. (4) which related to establishing different structural fire protection, manning, operating, and equipment requirements for vessels between 100 gross tons and 300 gross tons."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3542/a/2"},"text":"Pub. L. 115–232, § 3542(a)(2)","children":[],"tail":", struck out par. (5) which related to establishing different structural fire protection, manning, operating, and equipment requirements for former public vessels of the United States between 100 gross tons and 500 gross tons."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s710/1"},"text":"Pub. L. 104–324, § 710(1)","children":[],"tail":", inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “less than 300 gross tons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s710/2"},"text":"Pub. L. 104–324, § 710(2)","children":[],"tail":", inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “less than 500 gross tons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206"},"text":"Pub. L. 103–206","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “If the Secretary decides that the application of a provision of part B or F of this subtitle is not necessary in performing the mission of a vessel engaged in excursions or an oceanographic research vessel, the Secretary by regulation may—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) for an excursion vessel, issue a special permit specifying the conditions of operation and equipment; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) exempt the oceanographic research vessel from that provision under conditions the Secretary may specify.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf656abf9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf656abfa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
