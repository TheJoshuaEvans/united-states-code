{"tag":"section","attrib":{"id":"idf6ecf8b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56302"},"text":null,"children":[{"tag":"num","attrib":{"value":"56302"},"text":"§ 56302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter terms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ecf8b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a vessel is requisitioned for use but not ownership under this chapter, the Secretary of Transportation, at the time of requisition or as soon thereafter as the situation allows, shall offer the person entitled to possession of the vessel a charter containing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ecf8b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms the Secretary believes should govern the relationship between the United States Government and the person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf8b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of hire the Secretary considers just compensation for the use of the vessel and the services required under the charter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf8b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Refusal To Accept","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the person does not accept the charter and rate of hire, the parties shall proceed as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s56304"},"text":"section 56304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ecf8b6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1654"},"text":"120 Stat. 1654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ecf8b7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ecf8b8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ecf8b9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"56302","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1242(c) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title IX, § 902(c) (1st sentence); as added "},{"tag":"html:a","attrib":{"href":"/us/act/1939-08-07/ch555/s3"},"text":"Aug. 7, 1939, ch. 555, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/1255"},"text":"53 Stat. 1255","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/131"},"text":"Pub. L. 97–31, § 12(131)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/165"},"text":"95 Stat. 165","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “requisitioned for use but not ownership under this chapter” are substituted for “taken and used under authority of this section, but the ownership thereof is not required by the United States” to eliminate unnecessary words. The word “requisition” is substituted for “taking”, and the word “vessel” is substituted for “such property”, for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is added because the provisions about disputed compensation, for both charter use and other takings, are consolidated in section 56304 of the revised title to avoid repetition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
