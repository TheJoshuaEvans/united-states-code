{"tag":"section","attrib":{"id":"idf6c461c3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319"},"text":null,"children":[{"tag":"num","attrib":{"value":"51319"},"text":"§ 51319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sexual assault response coordinators and sexual assault victim advocates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c461c4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sexual Assault Response Coordinators.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c461c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for coordinators","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States Merchant Marine Academy shall employ or contract with at least 1 full-time sexual assault response coordinator who shall reside at or near the Academy. The Secretary of Transportation may assign additional full-time or part-time sexual assault response coordinators at the Academy as necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c461c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each sexual assault response coordinator shall be selected based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c461c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experience and a demonstrated ability to effectively provide victim services related to sexual harassment, dating violence, domestic violence, sexual assault, and stalking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection of the individual under applicable law to provide privileged communication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c461c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Confidentiality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A sexual assault response coordinator shall, to the extent authorized under applicable law, provide confidential services to a cadet at the Academy who reports being a victim of, or witness to, sexual harassment, dating violence, domestic violence, sexual assault, or stalking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c461ca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c461cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Verification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the enactment of the National Defense Authorization Act for Fiscal Year 2018, the Maritime Administrator, in consultation with the Director of the Maritime Administration Office of Civil Rights, shall develop a process to verify that each sexual assault response coordinator has completed proper training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training referred to in subparagraph (A) shall include training in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c461cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with victims of sexual harassment, dating violence, domestic violence, sexual assault, and stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c461ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policies, procedures, and resources of the Academy related to responding to sexual harassment, dating violence, domestic violence, sexual assault, and stalking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c461cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national, State, and local victim services and resources available to victims of sexual harassment, dating violence, domestic violence, sexual assault, and stalking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461d0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Completion of training","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A sexual assault response coordinator shall complete the training referred to in subparagraphs (A) and (B) not later than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c461d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 270 days after enactment of the National Defense Authorization Act for Fiscal Year 2018; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c461d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 180 days after starting in the role of sexual assault response coordinator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c461d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A sexual assault response coordinator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c461d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confidentially receive a report from a victim of sexual harassment, dating violence, domestic violence, sexual assault, or stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" inform the victim of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c461d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the victim’s rights under applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c461d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" options for reporting an incident of sexual harassment, dating violence, domestic violence, sexual assault, or stalking to the Academy and law enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c461d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how to access available services, including emergency medical care, medical forensic or evidentiary examinations, legal services, services provided by rape crisis centers and other victim service providers, services provided by the volunteer sexual assault victim advocates at the Academy, and crisis intervention counseling and ongoing counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c461d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such coordinator’s ability to assist in arranging access to such services, with the consent of the victim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c461da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available accommodations, such as allowing the victim to change living arrangements and obtain accessibility services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c461db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such coordinator’s ability to assist in arranging such accommodations, with the consent of the victim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c461dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the victim’s rights and the Academy’s responsibilities regarding orders of protection, no contact orders, restraining orders, or similar lawful orders issued by the Academy or a criminal, civil, or tribal court; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c461dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" privacy limitations under applicable law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the interests of any cadet at the Academy who reports being a victim of sexual harassment, dating violence, domestic violence, sexual assault, or stalking, even if such interests are in conflict with the interests of the Academy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the victim of, and provide written materials regarding, the information described in subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liaise with appropriate staff at the Academy, with the victim’s consent, to arrange reasonable accommodations through the Academy to allow the victim to change living arrangements, obtain accessibility services, or access other accommodations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain the privacy and confidentiality of the victim, and shall not notify the Academy or any other authority of the identity of the victim or the alleged circumstances surrounding the reported incident unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c461e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise required by applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c461e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requested to do so by the victim who has been fully and accurately informed about what procedures shall occur if the information is shared; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c461e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding clause (i) or clause (ii), there is risk of imminent harm to other individuals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the victim in contacting and reporting an incident of sexual harassment, dating violence, domestic violence, sexual assault, or stalking to the Academy or law enforcement, if requested to do so by the victim who has been fully and accurately informed about what procedures shall occur if information is shared; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/a/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Director of the Maritime Administration Office of Civil Rights an annual report summarizing how the resources supplied to the coordinator were used during the prior year, including the number of victims assisted by the coordinator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c461e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c461e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c461e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each sexual assault response coordinator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c461ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report directly to the Superintendent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c461eb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have concurrent reporting responsibility to the Executive Director of the Maritime Administration on matters related to the Maritime Administration and the Department of Transportation and upon belief that the Academy leadership is acting inappropriately regarding sexual assault prevention and response matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461ec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administration Office of Civil Rights shall provide support to the sexual assault response coordinator at the Academy on all sexual harassment, dating violence, domestic violence, sexual assault, or stalking prevention matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c461ed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on investigation by the academy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any request by a victim for an accommodation, as described in subsection (a)(5)(E), made by a sexual assault response coordinator shall not trigger an investigation by the Academy, even if such coordinator deals only with matters relating to sexual harassment, dating violence, domestic violence, sexual assault, or stalking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c461ee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on retaliation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A sexual assault response coordinator, victim advocate, or companion may not be disciplined, penalized, or otherwise retaliated against by the Academy for representing the interests of the victim, even if such interests are in conflict with the interests of the Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c461ef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Victims Advisor.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c461f0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall designate an attorney (to be known as the “Special Victims Advisor”) for the purpose of providing legal assistance to any cadet of the Academy who is the victim of an alleged sex-related offense regarding administrative and criminal proceedings related to such offense, regardless of whether the report of that offense is restricted or unrestricted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c461f1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special victims advisory","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that the attorney designated as the Special Victims Advisor has knowledge of the Uniform Code of Military Justice, as well as criminal and civil law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c461f2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Privileged communications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any communications between a victim of an alleged sex-related offense and the Special Victim Advisor, when acting in their capacity as such, shall have the same protection that applicable law provides for confidential attorney-client communications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c461f3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Volunteer Sexual Assault Victim Advocates.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c461f4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, acting through the Superintendent of the Academy, shall designate from among volunteers 1 or more permanent employees of the Academy to serve as advocates for victims of sexual assaults involving cadets of the Academy or other Academy personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c461f5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training; other duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each victim advocate designated under this subsection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c461f6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have or receive training in matters relating to sexual assault and the comprehensive policy developed under section 51318; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461f7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a victim advocate voluntarily, in addition to the individual’s other duties as an employee of the Academy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c461f8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Primary duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"While performing the duties of a victim advocate under this subsection, a designated employee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c461f9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support victims of sexual assault by informing them of the rights and resources available to them as victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461fa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify additional resources to ensure the safety of victims of sexual assault; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" connect victims of sexual assault to companions, as described in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c461fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Companions.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c461fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At least 1 victim advocate designated under this subsection, or a sexual assault response coordinator designated under subsection (a), while performing the duties of a victim advocate, shall act as a companion to a victim described in paragraph (1) in navigating investigative, medical, mental, and emotional health, and recovery processes relating to sexual assault.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c461fe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternate victim advocates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If requested by the victim, an alternate victim advocate shall be designated under this subsection to act as a companion to the victim, as described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c461ff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Formal relationships with other entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may enter into formal relationships with other entities to make available additional victim advocates or to implement paragraphs (3) and (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c46200-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51319/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unfilled Vacancies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Maritime Administration may appoint qualified candidates to positions under subsections (a) and (d) of this section without regard to sections 3309 through 3319 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c46201-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3511/a"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2785"},"text":"130 Stat. 2785","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dC/tXXXV/s3515/a"},"text":"Pub. L. 115–91, div. C, title XXXV, § 3515(a)","children":[],"tail":", (b) (formerly § 3515(c)), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1924"},"text":"131 Stat. 1924","children":[],"tail":", 1927, § 3515(b) renumbered § 3515(c), "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3513/c/2"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3513(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-22"},"text":"Dec. 22, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3068"},"text":"136 Stat. 3068","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3531/e"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3531(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3088"},"text":"136 Stat. 3088","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c46202-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6c46203-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6c46204-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2018 and enactment of the National Defense Authorization Act for Fiscal Year 2018, referred to in subsec. (a)(4)(A), (C)(i), are the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6c46205-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3531/e/1"},"text":"Pub. L. 117–263, § 3531(e)(1)","children":[],"tail":", (2), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3531/e/3"},"text":"Pub. L. 117–263, § 3531(e)(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3515/a"},"text":"Pub. L. 115–91, § 3515(a)","children":[],"tail":", added subsecs. (a) and (b), redesignated former subsec. (b) as (c), and struck out former subsec. (a) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Sexual Assault Response Coordinators","children":[],"tail":".—The United States Merchant Marine Academy shall employ or contract with at least 1 full-time sexual assault response coordinator who shall reside at or near the Academy. The Secretary of Transportation may assign additional full-time or part-time sexual assault response coordinators at the Academy as necessary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3515/b"},"text":"Pub. L. 115–91, § 3515(b)","children":[],"tail":", formerly § 3515(c), as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3513/c/2"},"text":"Pub. L. 117–263, § 3513(c)(2)","children":[],"tail":", redesignated par. (6) as (5), substituted “paragraphs (3) and (4)” for “paragraphs (3), (4), and (5)”, and struck out former par. (5) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Hotline","children":[],"tail":".—The Secretary shall establish a 24-hour hotline through which the victim of a sexual assault described in paragraph (1) can receive victim support services.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
