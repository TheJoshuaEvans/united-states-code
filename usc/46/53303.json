{"tag":"section","attrib":{"id":"idf6d2b9fa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53303"},"text":null,"children":[{"tag":"num","attrib":{"value":"53303"},"text":"§ 53303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons eligible to establish funds","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A construction reserve fund may be established by a citizen of the United States that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b9fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53303/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is operating a vessel in the foreign or domestic commerce of the United States or in the fisheries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53303/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns, in whole or in part, a vessel being operated in the foreign or domestic commerce of the United States or in the fisheries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53303/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was operating a vessel in the foreign or domestic commerce of the United States or in the fisheries when it was bought or requisitioned by the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9fe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53303/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned, in whole or in part, a vessel being operated in the foreign or domestic commerce of the United States or in the fisheries when it was bought or requisitioned by the Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9ff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53303/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had acquired or was having constructed a vessel to operate in the foreign or domestic commerce of the United States or in the fisheries when it was bought or requisitioned by the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d2ba00-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1587"},"text":"120 Stat. 1587","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d2ba01-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6d2ba02-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6d2ba03-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag"