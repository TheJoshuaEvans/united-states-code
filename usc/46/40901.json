{"tag":"section","attrib":{"id":"idf6aeddc7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40901"},"text":null,"children":[{"tag":"num","attrib":{"value":"40901"},"text":"§ 40901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" License requirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6aeddc8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person in the United States may not advertise, hold oneself out, or act as an ocean transportation intermediary unless the person holds an ocean transportation intermediary’s license issued by the Federal Maritime Commission. The Commission shall issue a license to a person that the Commission determines to be qualified by experience and character to act as an ocean transportation intermediary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aeddc9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person whose primary business is the sale of merchandise may forward shipments of the merchandise for its own account without an ocean transportation intermediary’s license.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aeddca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) and section 40902 do not apply to a person that performs ocean transportation intermediary services on behalf of an ocean transportation intermediary for which it is a disclosed agent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6aeddcb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1538"},"text":"120 Stat. 1538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVII/s707/a"},"text":"Pub. L. 115–282, title VII, § 707(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4295"},"text":"132 Stat. 4295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6aeddcc-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6aeddcd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6aeddce-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"ta