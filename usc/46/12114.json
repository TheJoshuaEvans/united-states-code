{"tag":"section","attrib":{"id":"idf6949f38-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12114"},"text":null,"children":[{"tag":"num","attrib":{"value":"12114"},"text":"§ 12114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreational endorsement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6949f39-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A recreational endorsement may be issued for a vessel that satisfies the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12103"},"text":"section 12103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949f3a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Activity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel operating under a recreational endorsement may be operated only for pleasure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949f3b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Customs Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel for which a recreational endorsement is issued may proceed between a port of the United States and a port of a foreign country without entering or clearing with the Secretary of Homeland Security. However, a recreational vessel is subject to the requirements for reporting arrivals under section 433 of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1433"},"text":"19 U.S.C. 1433","children":[],"tail":"), and individuals on the vessel are subject to applicable customs regulations."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6949f3c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1498"},"text":"120 Stat. 1498","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6949f3d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6949f3e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6949f3f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"tex