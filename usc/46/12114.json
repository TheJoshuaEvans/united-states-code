ag":"html:p","attrib":{},"text":"46:12110(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12114(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:12109(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Secretary of Homeland Security” are substituted for “Customs Service” because the functions of the Customs Service and of the Secretary of the Treasury relating thereto were transferred to the Secretary of Homeland Security by section 403(1) of the Homeland Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2178"},"text":"116 Stat. 2178","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6949f40-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf6949f41-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12114, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/589"},"text":"97 Stat. 589","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/36/s1/a/8"},"text":"Pub. L. 99–36, § 1(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-05-15"},"text":"May 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/67"},"text":"99 Stat. 67","children":[],"tail":", originally derived from section 65c of former Title 46, Shipping, related to home ports, prior to being repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI"},"text":"Pub. L. 100–710, title I","children":[],"tail":", §§ 106(b)(5), 107(a), "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4752"},"text":"102 Stat. 4752","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6949f42-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6949f43-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Documentation of Recreational Vessels","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVIII/s826"},"text":"Pub. L. 115–282, title VIII, § 826","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4314"},"text":"132 Stat. 4314","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/282/tVIII/s826"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Coast Guard personnel performing nonrecreational vessel documentation functions under subchapter II of chapter 121 of title 46, United States Code, may perform recreational vessel documentation under section 12114 of such title in any fiscal year in which—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds available for Coast Guard operating expenses may not be used for expenses incurred for recreational vessel documentation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fees collected from owners of yachts and credited to such use are insufficient to pay expenses of recreational vessel documentation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a backlog of applications for recreational vessel documentation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
