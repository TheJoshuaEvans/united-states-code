{"tag":"section","attrib":{"id":"idf6c6d2cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504"},"text":null,"children":[{"tag":"num","attrib":{"value":"51504"},"text":"§ 51504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of training vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c6d2cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications To Use Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Governor of a State sponsoring a State maritime academy (or the Governor of the State designated to conduct the affairs of a regional maritime academy) may apply in writing to the Secretary of Transportation to obtain the use of a training vessel for the academy. A vessel provided under this section remains the property of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d2cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (c), the Secretary may provide to a State maritime academy, for use as a training vessel, a suitable vessel under the control of the Secretary or made available to the Secretary under subsection (e). If a suitable vessel is not available, the Secretary may build and provide a suitable vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d2ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide a vessel under this section only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c6d2cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an application has been made under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2d0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State maritime academy satisfies ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51506/a"},"text":"section 51506(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a suitable port will be available for the safe mooring of the vessel while the academy is using the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d2d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preparation and Maintenance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel provided under this section shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c6d2d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repaired, reconditioned, and equipped (with all apparel, charts, books, and instruments of navigation) as necessary for use as a training vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintained in good repair by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d2d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agency may provide to the Secretary, for use by a State maritime academy, a vessel (including equipment) that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c6d2d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is suitable for training purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can be provided without detriment to the service to which the vessel is assigned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d2d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fuel Costs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c6d2d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall pay to each State maritime academy the costs of fuel used by a vessel provided under this section while used for training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the payment to a State maritime academy under paragraph (1) may not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c6d2db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000 for fiscal year 2006;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c6d2dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $200,000 for fiscal year 2007; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c6d2dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $300,000 for fiscal year 2008 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d2de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel Sharing.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c6d2df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of the National Defense Authorization Act for Fiscal Year 2019, the Secretary, acting through the Maritime Administrator, shall upon consultation with the maritime academies, and to the extent feasible with the consent of the maritime academies, implement a program of training vessel sharing, requiring maritime academies to share training vessel ","children":[{"tag":"ref","attrib":{"idref":"fn002031"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002031"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “vessels”."}],"tail":" provided by the Secretary among maritime academies, as necessary to ensure that training needs of each academy are met."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program of vessel sharing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, a program of vessel sharing shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c6d2e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways to maximize the available underway training available in the fleet of training vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c6d2e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating the dates and duration of training cruises with the academic calendars of maritime academies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c6d2e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating academic programs designed to be implemented aboard training vessels among maritime academies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c6d2e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying ways to minimize costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations, the Maritime Administrator may provide additional funding to State maritime academies during periods of limited training vessel capacity, for costs associated with training vessel sharing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51504/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the beginning of each fiscal year, the Secretary, acting through the Maritime Administrator, shall evaluate the vessel sharing program under this subsection to determine the optimal utilization of State maritime training vessels, and modify the program as necessary to improve utilization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c6d2e7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1577"},"text":"120 Stat. 1577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3502/b"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3548"},"text":"119 Stat. 3548","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3523/a/2"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3523(a)(2)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/599"},"text":"122 Stat. 599","children":[],"tail":", 600; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3505"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2308"},"text":"132 Stat. 2308","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c6d2e8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6c6d2e9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6c6d2ea-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"ht