{"tag":"section","attrib":{"id":"idf6dc2eb0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706"},"text":null,"children":[{"tag":"num","attrib":{"value":"53706"},"text":"§ 53706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible purposes of obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6dc2eb1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a guarantee under this chapter, an obligation must aid in any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dc2eb2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dc2eb3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Financing (including reimbursement of an obligor for expenditures previously made for) the construction, reconstruction, or reconditioning of a vessel designed principally for research, or for commercial use—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6dc2eb4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the coastwise or intercoastal trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6dc2eb5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the Great Lakes, or on bays, sounds, rivers, harbors, or inland lakes of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6dc2eb6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in foreign trade as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s109/b"},"text":"section 109(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6dc2eb7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as an ocean thermal energy conversion facility or plantship; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6dc2eb8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a floating drydock in the construction, reconstruction, reconditioning, or repair of vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2eb9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A guarantee under subparagraph (A) may not be made more than one year after delivery of the vessel (or redelivery if the vessel was reconstructed or reconditioned) unless the proceeds of the obligation are used to finance the construction, reconstruction, or reconditioning of a vessel or of facilities or equipment related to marine operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2eba-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financing (including reimbursement of an obligor for expenditures previously made for) the construction, reconstruction, reconditioning, or purchase of a vessel owned by citizens of the United States and designed principally for research, or for commercial use in the fishing industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ebb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Financing the purchase, reconstruction, or reconditioning of a vessel or fishery facility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dc2ebc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which an obligation was guaranteed under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2ebd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that, under subchapter II of this chapter—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6dc2ebe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a vessel or fishery facility for which an obligation was accelerated and paid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6dc2ebf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was acquired by the Federal Ship Financing Fund or successor account under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53717"},"text":"section 53717 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6dc2ec0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was sold at foreclosure begun or intervened in by the Secretary or Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ec1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financing any part of the repayment to the United States Government of any amount of a construction-differential subsidy paid for a vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ec2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Refinancing an existing obligation (regardless of whether guaranteed under this chapter) issued for a purpose described in paragraphs (1)–(4), including a short-term obligation incurred to obtain temporary funds with the intention of refinancing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ec3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financing or refinancing (including reimbursement of an obligor for expenditures previously made for) the construction, reconstruction, reconditioning, or purchase of a fishery facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ec4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Financing or refinancing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dc2ec5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of individual fishing quotas in accordance with section 303(d)(4) of the Magnuson-Stevens Fishery Conservation and Management Act (including the reimbursement of obligors for expenditures previously made for such a purchase);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2ec6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that assist in the transition to reduced fishing capacity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2ec7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technologies or upgrades designed to improve collection and reporting of fishery-dependent data, to reduce bycatch, to improve selectivity or reduce adverse impacts of fishing gear, or to improve safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ec8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financing (including reimbursement of an obligor for expenditures previously made for) the reconstruction, reconditioning, retrofitting, repair, reconfiguration, or similar work in a shipyard located in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2ec9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-Vessels Treated as Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An obligation guaranteed under subsection (a)(6) or (7) shall be treated, for purposes of this chapter, in the same manner and to the same extent as an obligation that aids in financing the construction, reconstruction, reconditioning, or purchase of a vessel, except with respect to provisions that by their nature can only be applied to vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2eca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priorities for Certain Vessels.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dc2ecb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In guaranteeing or making a commitment to guarantee an obligation under this chapter, the Administrator shall give priority to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dc2ecc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel that is otherwise eligible for a guarantee and is constructed with assistance under subtitle D of the Maritime Security Act of 2003 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53101"},"text":"46 U.S.C. 53101","children":[],"tail":" note);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2ecd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after applying subparagraph (A), a vessel that is otherwise eligible for a guarantee and that the Secretary of Defense determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6dc2ece-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is suitable for service as a naval auxiliary in time of war or national emergency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6dc2ecf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets a shortfall in sealift capacity or capability; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2ed0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after applying subparagraphs (A) and (B), Vessels of National Interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ed1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall determine whether a vessel satisfies paragraph (1)(B) not later than 30 days after receipt of a request from the Administrator for such a determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6dc2ed2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1606"},"text":"120 Stat. 1606","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/D"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(D)","children":[],"tail":", (2)(A), (B), (b)(2), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":", 3556; "},{"tag":"ref","attrib":{"href":"/us/pl/109/479/tII/s209"},"text":"Pub. L. 109–479, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-01-12"},"text":"Jan. 12, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3617"},"text":"120 Stat. 3617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/2"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(2)","children":[],"tail":", (10)(B), (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/596"},"text":"122 Stat. 596","children":[],"tail":", 598; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3506/e"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3506(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1972"},"text":"133 Stat. 1972","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dC/tXXXV/s3536/a"},"text":"Pub. L. 118–31, div. C, title XXXV, § 3536(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/835"},"text":"137 Stat. 835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6dc2ed3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6dc2ed4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6dc2ed5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col