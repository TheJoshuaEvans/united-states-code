d","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53706(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274(a) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53706(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1273(i), (j).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XI, § 1103(i), (j), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/108/136/tX/s1014/a"},"text":"Pub. L. 108–136, title X, § 1014(a)","children":[],"tail":", title XXXV, § 3544, "},{"tag":"html:span","attrib":{},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/117/1591"},"text":"117 Stat. 1591","children":[],"tail":", 1822."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before paragraph (1), the words “To be eligible for a guarantee under this chapter, an obligation must aid in any of the following” are substituted for “Pursuant to the authority granted under section 1273(a) of this Appendix, the Secretary, upon such terms as he shall prescribe, may guarantee or make a commitment to guarantee, payment of the principal of and interest on an obligation which aids in” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “citizens of the United States” are substituted for “citizens or nationals of the United States or citizens of the Northern Mariana Islands” because of the definition of “citizen of the United States” in chapter 1 of the revised title. Citizens of the Northern Mariana Islands became citizens or non-citizen nationals of the United States (either of which is a “citizen of the United States” as defined in chapter 1 of the revised title) when the Covenant establishing the Commonwealth of the Northern Mariana Islands became effective ","children":[{"tag":"date","attrib":{"date":"1986-11-04"},"text":"November 4, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6dc2ed6-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6dc2ed7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 303(d)(4) of the Magnuson-Stevens Fishery Conservation and Management Act, referred to in subsec. (a)(7)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/265/s303/d/4"},"text":"section 303(d)(4) of Pub. L. 94–265","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1853/d/4"},"text":"section 1853(d)(4) of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Maritime Security Act of 2003, referred to in subsec. (c)(1)(A), is title XXXV of div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1788"},"text":"117 Stat. 1788","children":[],"tail":". Subtitle D of the Act amended section 1273 of the former Appendix to this title and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53101"},"text":"section 53101 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2003 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6dc2ed8-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3506/e/1/A"},"text":"Pub. L. 116–92, § 3506(e)(1)(A)","children":[],"tail":", struck out “(including an eligible export vessel)” after “reconditioning of a vessel” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A)(vi). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3506/e/1/B"},"text":"Pub. L. 116–92, § 3506(e)(1)(B)","children":[],"tail":"–(D), struck out cl. (vi) which read as follows: “as an eligible export vessel in worldwide trade.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3506/e/2"},"text":"Pub. L. 116–92, § 3506(e)(2)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/D"},"text":"Pub. L. 109–163, § 3507(a)(1)(D)","children":[],"tail":", (2)(A), (B), (b)(2). See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/a/10/B"},"text":"Pub. L. 110–181, § 3522(a)(10)(B)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/D"},"text":"Pub. L. 109–163, § 3507(a)(1)(D)","children":[],"tail":", into this section by inserting “or Administrator” after “Secretary”. See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/a/2"},"text":"Pub. L. 110–181, § 3522(a)(2)","children":[],"tail":", incorporated the substance of the amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/2/A"},"text":"Pub. L. 109–163, § 3507(a)(2)(A)","children":[],"tail":", (B), (b)(2), by amending subsec. (c) generally. Prior to amendment, subsec. (c) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“","children":[{"tag":"inline","attrib":{},"text":"Priorities for Certain Vessels","children":[],"tail":".—In guaranteeing or making a commitment to guarantee an obligation under this chapter, the Secretary shall give priority to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) a vessel that is otherwise eligible for a guarantee and is constructed with assistance under subtitle D of the Maritime Security Act of 2003 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53101"},"text":"46 U.S.C. 53101","children":[],"tail":" note); and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) after applying paragraph (1), a vessel that is otherwise eligible for a guarantee and that the Secretary of Defense determines—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) is suitable for service as a naval auxiliary in time of war or national emergency; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) meets a shortfall in sealift capacity or capability.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"See 2006 Amendment note below and ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/479"},"text":"Pub. L. 109–479","children":[],"tail":" amended par. (7) generally. Prior to amendment, par. (7) read as follows: “Financing or refinancing (including reimbursement of an obligor for expenditures previously made for) the purchase of an individual fishing quota in accordance with section 303(d)(4) of the Magnuson-Stevens Fishery Conservation and Management Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1853/d/4"},"text":"16 U.S.C. 1853(d)(4)","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/D"},"text":"Pub. L. 109–163, § 3507(a)(1)(D)","children":[],"tail":", (2)(A), (B), (b)(2), which directed the amendment of sections 1273(i), (j) and 1274(a) of the former Appendix to this title from which this section was derived, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":". See 2008 Amendment notes for subsecs. (a)(3)(B)(iii) and (c) and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6dc2ed9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6dc2eda-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition of New Loans for Construction of Fishing Vessels Under Certain Conditions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/297/tIII/s302/b/2"},"text":"Pub. L. 104–297, title III, § 302(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3615"},"text":"110 Stat. 3615","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tII/s212"},"text":"Pub. L. 105–277, div. C, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-635"},"text":"112 Stat. 2681–635","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/206/tI/s1103"},"text":"Pub. L. 107–206, title I, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/884"},"text":"116 Stat. 884","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s302/b"},"text":"Pub. L. 114–120, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/52"},"text":"130 Stat. 52","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/120/tIII/s302/b"},"text":"“No loans may be provided or guaranteed by the Federal Government for the construction or rebuilding of a vessel intended for use as a fishing vessel (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"section 2101 of title 46","children":[],"tail":", United States Code), if such vessel will be greater than 165 feet in registered length, of more than 750 gross registered tons (as measured under chapter 145 of title 46) or 1,900 gross registered tons [(]as measured under chapter 143 of that title), or have an engine or engines capable of producing a total of more than 3,000 shaft horsepower, after such construction or rebuilding is completed. This prohibition shall not apply to vessels to be used in the menhaden fishery, in tuna purse seine fisheries outside the exclusive economic zone of the United States or the area of the South Pacific Regional Fisheries Treaty, in fisheries that are under the jurisdiction of the North Pacific Fishery Management Council and managed under a fishery management plan issued under the Magnuson-Stevens Fishery Conservation and Management Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"16 U.S.C. 1801","children":[],"tail":" et seq.), or in the Pacific whiting fishery that is under the jurisdiction of the Pacific Fishery Management Council and managed under a fishery management plan issued under that Act. Any fishing vessel operated in fisheries under the jurisdiction of the North Pacific Fishery Management Council and managed under a fishery management plan issued under the Magnuson-Stevens Fishery Conservation and Management Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1801"},"text":"16 U.S.C. 1801","children":[],"tail":" et seq.), or in the Pacific whiting fishery under the jurisdiction of the Pacific Fishery Management Council and managed under a fishery management plan issued under that Act, and that is replaced by a vessel that is constructed or rebuilt with a loan or loan guarantee provided by the Federal Government may not be used to harvest fish in any fishery under the jurisdiction of any regional fishery management council, other than a fishery under the jurisdiction of the North Pacific Fishery Management Council or the Pacific Fishery Management Council.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206/tI/s1103"},"text":"Pub. L. 107–206, title I, § 1103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/884"},"text":"116 Stat. 884","children":[],"tail":", which directed the amendment of title II of division C of "},{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Public Law 105–277","children":[],"tail":" by substituting “of more than 750 gross registered tons (as measured under chapter 145 of title 46) or 1,900 gross registered tons as measured under chapter 143 of that title)” for “of more than 750 gross registered tons”, was executed to "},{"tag":"ref","attrib":{"href":"/us/pl/104/297/s302/b/2"},"text":"section 302(b)(2) of Pub. L. 104–297","children":[],"tail":", set out above, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s212"},"text":"section 212 of Pub. L. 105–277","children":[],"tail":", to reflect the probable intent of Congress.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
