:"/us/stat/94/2003"},"text":"94 Stat. 2003","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The reference to territories is omitted as unnecessary because of the definition of “State” in chapter 1 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
