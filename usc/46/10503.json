{"tag":"section","attrib":{"id":"idf68d99f0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10503"},"text":null,"children":[{"tag":"num","attrib":{"value":"10503"},"text":"§ 10503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exhibiting merchant mariners’ documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Before signing the agreement required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s10502"},"text":"section 10502 of this title","children":[],"tail":", a seaman required by "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s8701"},"text":"section 8701 of this title","children":[],"tail":" to have a merchant mariner’s document shall exhibit to the master a document issued to the seaman and appropriately endorsed for the capacity in which the seaman is to serve."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf68d99f1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/570"},"text":"97 Stat. 570","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68d99f2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68d99f3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68d99f4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag"