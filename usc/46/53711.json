{"tag":"section","attrib":{"id":"idf6dea03f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53711"},"text":null,"children":[{"tag":"num","attrib":{"value":"53711"},"text":"§ 53711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6dea040-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator may guarantee an obligation under this chapter only if the obligor conveys or agrees to convey to the Secretary or Administrator a security interest the Secretary or Administrator considers necessary to protect the interest of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea041-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple Vessels and Types of Security","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The security interest may relate to more than one vessel and may consist of more than one type of security. If the security interest relates to more than one vessel, the obligation may have the latest maturity date allowable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53710/a/3"},"text":"section 53710(a)(3) of this title","children":[],"tail":" for any of the vessels used as security for the guarantee. However, the Secretary or Administrator may require such payments of principal prior to maturity, with respect to all related obligations, as the Secretary or Administrator considers necessary to maintain adequate security for the guarantee."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6dea042-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1612"},"text":"120 Stat. 1612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/C"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(C)","children":[],"tail":", (D), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/10/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(10)(B)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6dea043-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6dea044-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6dea045-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":