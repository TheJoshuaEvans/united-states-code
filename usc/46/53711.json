–31, § 12(136)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/166"},"text":"95 Stat. 166","children":[],"tail":"; § 1104 renumbered as § 1104A, "},{"tag":"html:a","attrib":{"href":"/us/pl/101/380/tIV/s4115/f/1"},"text":"Pub. L. 101–380, title IV, § 4115(f)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/521"},"text":"104 Stat. 521","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “a security interest the Secretary considers necessary” are substituted for “such security interest, which may include a mortgage or mortgages on a vessel or vessels, as the Secretary may reasonably require” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6dea046-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6dea047-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/C"},"text":"Pub. L. 109–163, § 3507(a)(1)(C)","children":[],"tail":", (D). See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/a/10/B"},"text":"Pub. L. 110–181, § 3522(a)(10)(B)","children":[]