section 70503 or 70508 of this title shall be tried in the district court of the United States for—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the district at which the person enters the United States; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the District of Columbia.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/407"},"text":"Pub. L. 110–407","children":[],"tail":" inserted “or 70508” after “70503” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
