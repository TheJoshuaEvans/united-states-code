{"tag":"section","attrib":{"id":"idf7098075-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70504"},"text":null,"children":[{"tag":"num","attrib":{"value":"70504"},"text":"§ 70504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction and venue","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7098076-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Jurisdiction of the United States with respect to a vessel subject to this chapter is not an element of an offense. Jurisdictional issues arising under this chapter are preliminary questions of law to be determined solely by the trial judge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098077-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person violating section 70503 or 70508—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7098078-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be tried in the district in which such offense was committed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7098079-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the offense was begun or committed upon the high seas, or elsewhere outside the jurisdiction of any particular State or district, may be tried in any district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf709807a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s10/2"},"text":"Pub. L. 109–304, § 10(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1688"},"text":"120 Stat. 1688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/407/tII/s202/b/2"},"text":"Pub. L. 110–407, title II, § 202(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4300"},"text":"122 Stat. 4300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1012/a"},"text":"Pub. L. 115–91, div. A, title X, § 1012(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1546"},"text":"131 Stat. 1546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf709807b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf709807c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf709807d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail