{"tag":"section","attrib":{"id":"idf6fb2975-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70033"},"text":null,"children":[{"tag":"num","attrib":{"value":"70033"},"text":"§ 70033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on application to foreign vessels","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except pursuant to international treaty, convention, or agreement, to which the United States is a party, subchapters I through III and this subchapter shall not apply to any foreign vessel that is not destined for, or departing from, a port or place subject to the jurisdiction of the United States and that is in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb2976-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70033/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innocent passage through the territorial sea of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb2977-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70033/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transit through the navigable waters of the United States that form a part of an international strait.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6fb2978-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIV/s401/a"},"text":"Pub. L. 115–282, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4261"},"text":"132 Stat. 4261","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8507(a)(6), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4753"},"text":"134 Stat. 4753","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6fb2979-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6fb297a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6fb297b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “I through III” for “A through C” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
