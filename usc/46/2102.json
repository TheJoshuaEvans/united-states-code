{"tag":"section","attrib":{"id":"idf6543a77-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2102"},"text":null,"children":[{"tag":"num","attrib":{"value":"2102"},"text":"§ 2102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In chapters 33, 45, 51, 81, and 87 of this title, “Aleutian trade” means the transportation of cargo (including fishery related products) for hire on board a fish tender vessel to or from a place in Alaska west of 153 degrees west longitude and east of 172 degrees east longitude, if that place receives weekly common carrier service by water, to or from a place in the United States (except a place in Alaska).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6543a78-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/505"},"text":"97 Stat. 505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1011/a"},"text":"Pub. L. 98–369, div. A, title X, § 1011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1013"},"text":"98 Stat. 1013","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5102/b/2"},"text":"Pub. L. 99–509, title V, § 5102(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1926"},"text":"100 Stat. 1926","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/595/tVI/s602/a"},"text":"Pub. L. 101–595, title VI, § 602(a)","