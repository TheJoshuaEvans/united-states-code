"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" inserted reference to chapters 37 and 51."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1011/a/1"},"text":"Pub. L. 98–369, § 1011(a)(1)","children":[],"tail":", struck out “and facilities improvement” after “recreational boating safety”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1011/a/2"},"text":"Pub. L. 98–369, § 1011(a)(2)","children":[],"tail":", (3), redesignated par. (5) as (3) and struck out former par. (3) which defined a State recreational boating facilities improvement program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1011/a/2"},"text":"Pub. L. 98–369, § 1011(a)(2)","children":[],"tail":", struck out par. (4) which defined State recreational boating safety and facilities improvement program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1011/a/3"},"text":"Pub. L. 98–369, § 1011(a)(3)","children":[],"tail":", redesignated par. (5) as (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6543a7e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6543a7f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective "},{"tag":"d