{"tag":"section","attrib":{"id":"idf65b664d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3204"},"text":null,"children":[{"tag":"num","attrib":{"value":"3204"},"text":"§ 3204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of safety management system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf65dd74e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety Management Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each responsible person shall establish and submit to the Secretary for approval a safety management plan describing how that person and vessels of the person to which this chapter applies will comply with the regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s3203/a"},"text":"section 3203(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65dd74f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon receipt of a safety management plan submitted under subsection (a), the Secretary shall review the plan and approve it if the Secretary determines that it is consistent with and will assist in implementing the safety management system established under section 3203.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65dd750-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Vessel Operation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel to which this chapter applies under section 3202(a) may not be operated without having on board a Safety Management Certificate and a copy of a Document of Compliance issued for the vessel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s3205"},"text":"section 3205 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf65dd751-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVI/s602/a"},"text":"Pub. L. 104–324, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3929"},"text":"110 Stat. 3929","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
