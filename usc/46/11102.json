{"tag":"section","attrib":{"id":"idf68fe413-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11102"},"text":null,"children":[{"tag":"num","attrib":{"value":"11102"},"text":"§ 11102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medicine chests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68fe414-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vessel of the United States on a voyage from a port in the United States to a foreign port (except to a Canadian port), and a vessel of the United States of at least 75 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" on a voyage between a port of the United States on the Atlantic Ocean and Pacific Ocean, shall be provided with a medicine chest."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe415-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner and master of a vessel not equipped as required by subsection (a) of this section or a regulation prescribed under subsection (a) are liable to the United States Government for a civil penalty of $500. If the offense was due to the fault of the owner, a master penalized under this section has the right to recover the penalty and costs from the owner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68fe416-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/578"},"text":"97 Stat. 578","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s741"},"text":"Pub. L. 104–324, title VII, § 741","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3942"},"text":"110 Stat. 3942","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68fe417-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68fe418-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68fe419-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"11102(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:666","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"11102(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:667","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 11102 requires that a United States vessel on a foreign or intercoastal domestic voyage be equipped with a medicine chest, and provides a penalty for noncompliance. The Committee intends that regulation will provide for a well stocked medicine chest adequate for the crew of a vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68fe41a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68fe41b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “75 gross tons”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
