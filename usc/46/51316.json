{"tag":"section","attrib":{"id":"idf6c1f14b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51316"},"text":null,"children":[{"tag":"num","attrib":{"value":"51316"},"text":"§ 51316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary appointments to the Academy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Maritime Administrator may appoint any present employee of the United States Merchant Marine Academy non-appropriated fund instrumentality to a position on the General Schedule of comparable pay. Eligible personnel shall be engaged in work permissibly funded by annual appropriations, and such appointments to the Civil Service shall be without regard to competition, for a term not to exceed 2 years.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6c1f14c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/dC/tXXXV/s3506/h/1"},"text":"Pub. L. 110–417, div. C, title XXXV, § 3506(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4765"},"text":"122 Stat. 4765","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c1f14d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6c1f14e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6c1f14f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in text, is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
