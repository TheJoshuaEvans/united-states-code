{"tag":"section","attrib":{"id":"idf6dc2f1e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710"},"text":null,"children":[{"tag":"num","attrib":{"value":"53710"},"text":"§ 53710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6dc2f1f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An obligation guaranteed under this chapter must—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dc2f20-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for payments by the obligor satisfactory to the Secretary or Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2f21-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for interest (exclusive of guarantee fees and other fees) at a rate not more than the annual rate on the unpaid principal that the Secretary or Administrator determines is reasonable, considering the range of interest rates prevailing in the private market for similar loans and the risks assumed by the Secretary or Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2f22-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have a maturity date satisfactory to the Secretary or Administrator, but—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dc2f23-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 25 years after the date of delivery of the vessel used as security for the guarantee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2f24-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the vessel has been reconstructed or reconditioned, not more than the later of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6dc2f25-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 years after the date of delivery of the vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6dc2f26-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the remaining years of useful life of the vessel as determined by the Secretary or Administrator; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2f27-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide, or a related agreement must provide, that if the vessel used as security for the guarantee is a delivered vessel, the vessel shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dc2f28-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in class A–1, American Bureau of Shipping, or meet other standards acceptable to the Secretary or Administrator, with all required certificates, including marine inspection certificates of the Coast Guard, and with all outstanding requirements and recommendations necessary for class retention accomplished, unless the Secretary or Administrator permits a deferment of repairs necessary to meet these requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2f29-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" well equipped, in good repair, and in every respect seaworthy and fit for service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2f2a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documented under the laws of the United States for the term of the guarantee of the obligation or until the obligation is paid in full, whichever is sooner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2f2b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions for Certain Passenger Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dc2f2c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With the Administrator’s approval, if the vessel used as security for the guarantee is a passenger vessel having the tonnage, speed, passenger accommodations, and other characteristics described in section 503 of the Merchant Marine Act, 1936, an obligation guaranteed under this chapter or a related agreement may provide that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dc2f2d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the only recourse by the United States Government against the obligor for payments under the guarantee will be repossession of the vessel and assignment of insurance claims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2f2e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligor’s liability for payments under the guarantee will be satisfied and discharged by the surrender of the vessel and all interest in the vessel to the Government in the condition described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2f2f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Surrender of vessel","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dc2f30-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On surrender, the vessel must be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6dc2f31-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" free and clear of all liens and encumbrances except the security interest conveyed to the Administrator under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6dc2f32-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in class; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6dc2f33-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in as good order and condition (ordinary wear and tear excepted) as when acquired by the obligor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2f34-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covering deficiencies by insurance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent covered by insurance, a deficiency related to a requirement in subparagraph (A) may be satisfied by assignment of the obligor’s insurance claims to the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2f35-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Provisions To Protect Security Interests and Provide for the Financial Stability of the Obligor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An obligation guaranteed under this chapter and any related agreement must contain other provisions, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dc2f36-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions for the protection of the security interests of the Government (including acceleration, assumption, and subrogation provisions and the issuance of notes by the obligor to the Secretary or Administrator), liens and releases of liens, payment of taxes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea037-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53710/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provisions that the Secretary or Administrator may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6dea038-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1610"},"text":"120 Stat. 1610","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/D"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(D)","children":[],"tail":", (2)(C), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/5"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(5)","children":[],"tail":", (9)(A), (10)(B), (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3506/g"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3506(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1972"},"text":"133 Stat. 1972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6dea039-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6dea03a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6dea03b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53710(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274(b)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a"