4 renumbered as § 1104A, "},{"tag":"html:a","attrib":{"href":"/us/pl/101/380/tIV/s4115/f/1"},"text":"Pub. L. 101–380, title IV, § 4115(f)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/521"},"text":"104 Stat. 521","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/160/tXIII/s1356/3/C"},"text":"Pub. L. 103–160, title XIII, § 1356(3)(C)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/1813"},"text":"107 Stat. 1813","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53710(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274(b)(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53710(a)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274(b)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53710(a)(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274(b)(6).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53710(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274(b)(7).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53710(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274(h).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"During review of this bill, the American Bureau of Shipping, through counsel, explained that it disagrees with an existing interpretation by the Maritime Administration of language restated in subsection (a)(4)(A) of this section, and requested the Committee to clarify that this codification should not be construed as a ratification of that regulatory interpretation. The Committee therefore states that this codification should not be construed as an expression of any opinion whatsoever concerning any such administrative interpretation.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “subject to the provisions of paragraph (2) of subsection (c) of this section” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(4)(B), the words “well equipped, in good repair, and in every respect seaworthy and fit for service” are substituted for “tight, stanch, strong, and well and sufficiently tackled, appareled, furnished, and equipped, and in every respect seaworthy and in good running condition and repair, and in all respects fit for service” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the reference to section 503 of the Merchant Marine Act, 1936, is substituted for the reference to “subchapter V of this chapter” because the relevant characteristics referred to in the text are contained in that section and because that section is part of the construction-differential subsidy program, which is not being restated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6dea03c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6dea03d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 503 of the Merchant Marine Act, 1936, referred to in subsec. (b)(1), is section 503 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"act June 29, 1936, ch. 858","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1985"},"text":"49 Stat. 1985","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53101"},"text":"section 53101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6dea03e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3506/g/1/A/i"},"text":"Pub. L. 116–92, § 3506(g)(1)(A)(i)","children":[],"tail":", struck out “or, in the case of an eligible export vessel, of the appropriate foreign authorities under a treaty, convention, or other international agreement to which the United States is a party” after “certificates of the Coast Guard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3506/a/1/A/ii"},"text":"Pub. L. 116–92, § 3506(a)(1)(A)(ii)","children":[],"tail":"–(C), added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3506/g/2"},"text":"Pub. L. 116–92, § 3506(g)(2)","children":[],"tail":", in heading, inserted “and Provide for the Financial Stability of the Obligor” after “Interests” and, in text, inserted “provisions, which shall include—” after “must contain other” and par. (1) designation before “provisions for the protection of”, substituted “; and” for “, and other matters that the Secretary or Administrator may prescribe.”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/D"},"text":"Pub. L. 109–163, § 3507(a)(1)(D)","children":[],"tail":", (2)(C). See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/a/10/B"},"text":"Pub. L. 110–181, § 3522(a)(10)(B)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":