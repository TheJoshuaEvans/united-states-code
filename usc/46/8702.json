{"tag":"section","attrib":{"id":"idf6866e6d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702"},"text":null,"children":[{"tag":"num","attrib":{"value":"8702"},"text":"§ 8702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain crew requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6866e6e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section applies to a vessel of at least 100 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" except—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6866e6f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel operating only on rivers and lakes (except the Great Lakes);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e70-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a barge (except a seagoing barge or a barge to which chapter 37 of this title applies);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e71-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fishing, fish tender, or whaling vessel (except a fish tender vessel engaged in the Aleutian trade) or a yacht;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e72-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sailing school vessel with respect to sailing school instructors and sailing school students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e73-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an oceanographic research vessel with respect to scientific personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e74-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fish processing vessel entered into service before ","children":[{"tag":"date","attrib":{"date":"1988-01-01"},"text":"January 1, 1988","children":[],"tail":", and not more than 1,600 gross tons as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" or entered into service after "},{"tag":"date","attrib":{"date":"1987-12-31"},"text":"December 31, 1987","children":[],"tail":", and having not more than 16 individuals on board primarily employed in the preparation of fish or fish products; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e75-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fish processing vessel (except a vessel to which clause (6) of this subsection applies) with respect to individuals on board primarily employed in the preparation of fish or fish products or in a support position not related to navigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e76-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A vessel may operate only if at least—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6866e77-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent of the crew in each department on board is able to understand any order spoken by the officers, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e78-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 65 percent of the deck crew (excluding licensed individuals) have merchant mariners’ documents endorsed for a rating of at least able seaman, except that this percentage may be reduced to 50 percent—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6866e79-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/b/2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a vessel permitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s8104"},"text":"section 8104 of this title","children":[],"tail":" to maintain a 2-watch system; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6866e7a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/b/2/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a fish tender vessel engaged in the Aleutian trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e7b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An able seaman is not required on a towing vessel operating on bays and sounds connected directly with the seas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e7c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual having a rating of less than able seaman may not be permitted at the wheel in ports, harbors, and other waters subject to congested vessel traffic, or under conditions of reduced visibility, adverse weather, or other hazardous circumstances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e7d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8702/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner, charterer, managing operator, agent, master, or individual in charge of a vessel operated in violation of this section or a regulation prescribed under this section is liable to the United States Government for a civil penalty of $10,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6866e7e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/554"},"text":"97 Stat. 554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/364/tIV/s402/12/B"},"text":"Pub. L. 98–364, title IV, § 402(12)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/449"},"text":"98 Stat. 449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/239/s5/e"},"text":"Pub. L. 100–239, § 5(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-11"},"text":"Jan. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1781"},"text":"101 Stat. 1781","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV/s4302/i"},"text":"Pub. L. 101–380, title IV, § 4302(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/539"},"text":"104 Stat. 539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/595/tVI/s602/e/2"},"text":"Pub. L. 101–595, title VI, § 602(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2992"},"text":"104 Stat. 2992","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s732"},"text":"Pub. L. 104–324, title VII, § 732","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3941"},"text":"110 Stat. 3941","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6866e7f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6866e80-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6866e81-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8702","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:643","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:672","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8702 specifies certain crew requirements.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) applies this section to the same vessels to which section 8701 applies.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) requires that 75 percent of the crew in each department on board a vessel understand any order spoken by the officers and that 65 percent of the deck crew be at least able seamen, except for the licensed officers. For 2-watch system vessels under section 8104, the 65-percent deck crew requirement may be reduced to 50 percent.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) exempts certain inland towing vessels from the able seaman requirement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) prohibits anyone having a rating of less than able seamen from serving as a helmsman in congested vessel traffic or under hazardous conditions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (e) prescribes the penalty for violation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6866e82-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6866e83-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s732/1"},"text":"Pub. L. 104–324, § 732(1)","children":[],"tail":", inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “100 gross tons” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s732/2"},"text":"Pub. L. 104–324, § 732(2)","children":[],"tail":", inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “1,600 gross tons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/595/s602/e/2/A"},"text":"Pub. L. 101–595, § 602(e)(2)(A)","children":[],"tail":", substituted “vessel (except a fish tender vessel engaged in the Aleutian trade)” for “vessel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/595/s602/e/2/B"},"text":"Pub. L. 101–595, § 602(e)(2)(B)","children":[],"tail":", inserted provisions authorizing reduction to 50 percent of the deck crew in the case of a fish tender vessel engaged in the Aleutian trade."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" substituted “$10,000” for “$500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/239"},"text":"Pub. L. 100–239","children":[],"tail":" substituted “operate” for “depart from a port of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364/s402/12/B/i"},"text":"Pub. L. 98–364, § 402(12)(B)(i)","children":[],"tail":", substituted “fishing, fish tender, or whaling” for “fishing or whaling”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364/s402/12/B/ii"},"text":"Pub. L. 98–364, § 402(12)(B)(ii)","children":[],"tail":"– (iv), added pars. (6) and (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6866e84-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6866e85-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/595/s602/e/2/A"},"text":"section 602(e)(2)(A) of Pub. L. 101–595","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", and requirements imposed by subsec. (b)(2), as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/101/595/s602/e/2/B"},"text":"section 602(e)(2)(B) of Pub. L. 101–595","children":[],"tail":", effective 1 year after "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/595/s602/f"},"text":"section 602(f) of Pub. L. 101–595","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s4502"},"text":"section 4502 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" applicable to incidents occurring after "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/s1020"},"text":"section 1020 of Pub. L. 101–380","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6866e86-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exemption of Certain Fish Processing Vessels","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Certain fish processing vessels exempt from crew requirements of subsec. (b) of this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364/s403/b"},"text":"section 403(b) of Pub. L. 98–364","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s3302"},"text":"section 3302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
