{"tag":"section","attrib":{"id":"idf68b2976-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10314"},"text":null,"children":[{"tag":"num","attrib":{"value":"10314"},"text":"§ 10314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68b2977-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68b2978-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68b2979-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10314/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay a seaman wages in advance of the time when the seaman has earned the wages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68b297a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10314/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay advance wages of the seaman to another person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68b297b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10314/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make to another person an order, note, or other evidence of indebtedness of the wages, or pay another person, for the engagement of seamen when payment is deducted or to be deducted from the seaman’s wage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68b297c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person violating this subsection is liable to the United States Government for a civil penalty of not more than $500. A payment made in violation of this subsection does not relieve the vessel or the master from the duty to pay all wages after they have been earned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68b297d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person demanding or receiving from a seaman or an individual seeking employment as a seaman, remuneration for providing the seaman or individual with employment, is liable to the Government for a civil penalty of not more than $500.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68b297e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section applies to a foreign vessel when in waters of the United States. An owner, charterer, managing operator, agent, or master of a foreign vessel violating this section is liable to the Government for the same penalty as an owner, charterer, managing operator, agent, or master of a vessel of the United States for the same violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68b297f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner, charterer, managing operator, agent, or master of a vessel seeking clearance from a port of the United States shall present the agreement required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s10302"},"text":"section 10302 of this title","children":[],"tail":" at the office of clearance. Clearance may be granted to a vessel only if this section has been complied with."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68b2980-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10314/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to a fishing or whaling vessel or a yacht.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68b2981-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/567"},"text":"97 Stat. 567","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/640/s10/b/4"},"text":"Pub. L. 99–640, § 10(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3550"},"text":"100 Stat. 3550","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68b2982-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68b2983-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68b2984-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10314","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:599","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10314 forbids advance payment of wages to seamen prior to the commencement of the seaman’s employment. It provides a civil penalty of $500 for any person making such a payment, and for any person demanding or receiving remuneration for providing a seaman with employment. This means that the use of employment agencies for hiring seamen is prohibited. It also requires compliance with section 10302 regarding the signing of articles of agreement before a vessel can be cleared from a United States port. This section applies to foreign vessels in United States waters but not to fishing vessels, whaling vessels or yachts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68b2985-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68b2986-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/640"},"text":"Pub. L. 99–640","children":[],"tail":" struck out last sentence which read as follows: “However, this section applies to a vessel taking oysters.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
