{"tag":"section","attrib":{"id":"idf6dc2f08-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709"},"text":null,"children":[{"tag":"num","attrib":{"value":"53709"},"text":"§ 53709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6dc2f09-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The principal of an obligation may not be guaranteed in an amount greater than the amount determined by multiplying the percentage applicable under subsection (b) by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dc2f0a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount paid by or for the account of the obligor (as determined by the Secretary or Administrator, which determination shall be conclusive) for the construction, reconstruction, or reconditioning of the vessel used as security for the guarantee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2f0b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the obligor creates an escrow fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53715"},"text":"section 53715 of this title","children":[],"tail":", the actual cost of the vessel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2f0c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Amount Borrowed","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dc2f0d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided, the principal amount of an obligation guaranteed under this chapter may not exceed 75 percent of the actual cost or depreciated actual cost, as determined by the Secretary or Administrator, of the vessel used as security for the guarantee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2f0e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain approved vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The principal amount may not exceed 87.5 percent of the actual cost or depreciated actual cost if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dc2f0f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size and speed of the vessel are approved by the Secretary or Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2f10-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is or would have been eligible for mortgage aid for construction under section 509 of the Merchant Marine Act, 1936, or would have been eligible except that the vessel was built with a construction-differential subsidy and the subsidy has been repaid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2f11-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is of a type described in that section for which the minimum down payment required by that section is 12.5 percent of the cost of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2f12-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fishing vessels and fishery facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a fishing vessel or fishery facility, the principal amount may not exceed 80 percent of the actual cost or depreciated actual cost. However, debt for the vessel or facility may not be placed through the Federal Financing Bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2f13-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"OTEC","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For an ocean thermal energy conversion facility or plantship constructed without a construction-differential subsidy, the principal amount may not exceed 87.5 percent of the actual cost or depreciated actual cost of the facility or plantship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2f14-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security Involving Multiple Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The principal amount of an obligation having more than one vessel as security for the guarantee may not exceed the sum of the principal amounts allowable for all the vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2f15-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Uniform Percentage Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator may not establish a percentage under any provision of subsection (b) that is to be applied uniformly to all guarantees or commitments to guarantee made under that provision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2f16-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53709/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Minimum Principal Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not establish, as a condition of eligibility for a guarantee under this chapter, a minimum principal amount for an obligation covering the reconstruction or reconditioning of a fishing vessel or fishery facility. For purposes of this chapter, the reconstruction or reconditioning of a fishing vessel or fishery facility does not include the routine minor repair or maintenance of the vessel or facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6dc2f17-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1609"},"text":"120 Stat. 1609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/C"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(C)","children":[],"tail":", (D), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/10/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(10)(B)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3506/f"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3506(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1972"},"text":"133 Stat. 1972","children":[],"tail":".)"}]