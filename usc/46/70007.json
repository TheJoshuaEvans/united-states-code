{"tag":"section","attrib":{"id":"idf6fb28f6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70007"},"text":null,"children":[{"tag":"num","attrib":{"value":"70007"},"text":"§ 70007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anchorage grounds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6fb28f7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Anchorage Grounds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb28f8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70007/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the department in which the Coast Guard is operating shall define and establish anchorage grounds in the navigable waters of the United States for vessels operating in such waters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb28f9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70007/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relevant factors for establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall take into account all relevant factors concerning navigational safety, protection of the marine environment, proximity to undersea pipelines and cables, safe and efficient use of Marine Transportation System, and national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb28fa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Vessels, of certain sizes or type determined by the Secretary, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb28fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set and maintain an anchor alarm for the duration of an anchorage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb28fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with any directions or orders issued by the Captain of the Port; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb28fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70007/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with any applicable anchorage regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb28fe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb28ff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70007/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anchor in any Federal navigation channel unless authorized or directed to by the Captain of the Port;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb2900-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70007/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anchor in near proximity, within distances determined by the Coast Guard, to an undersea pipeline or cable, unless authorized or directed to by the Captain of the Port; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb2901-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70007/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anchor or remain anchored in an anchorage ground during any period in which the Captain of the Port orders closure of the anchorage ground due to inclement weather, navigational hazard, a threat to the environment, or other safety or security concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb2902-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70007/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to prevent a vessel from taking actions necessary to maintain the safety of the vessel or to prevent the loss of life or property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6fb2903-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11318/a"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11318(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4090"},"text":"136 Stat. 4090","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6fb2904-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6fb2905-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idf6fb2906-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Clause","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11318/c"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11318(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4091"},"text":"136 Stat. 4091","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dK/tCXIII/s11318/c"},"text":"“Nothing in this section [enacting this section and provisions set out as a note under this section] shall limit any authority available, as of the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], to the captain of a port with respect to safety measures or any other authority as necessary for the safety of vessels located in anchorage grounds in the navigable waters of the United States.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6fb2907-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction; Applicability of Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXIII/s11318/e"},"text":"Pub. L. 117–263, div. K, title CXIII, § 11318(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4091"},"text":"136 Stat. 4091","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dK/tCXIII/s11318/e"},"text":"“The amendments made by subsection (a) [enacting this section] may not be construed to alter any existing rules, regulations, or final agency actions issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70006"},"text":"section 70006 of title 46","children":[],"tail":", United States Code, as in effect on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], until all regulations required under subsection (b) ["},{"tag":"ref","attrib":{"href":"/us/stat/136/4091"},"text":"136 Stat. 4091","children":[],"tail":"] take effect.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
