{"tag":"section","attrib":{"id":"idf6b3c015-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103"},"text":null,"children":[{"tag":"num","attrib":{"value":"44103"},"text":"§ 44103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial responsibility to pay liability for death or injury","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b3c016-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The owner or charterer of a vessel to which this chapter applies shall establish, under regulations prescribed by the Federal Maritime Commission, financial responsibility to meet liability for death or injury to passengers or other individuals on a voyage to or from a port in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3c017-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3c018-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of financial responsibility required under subsection (a) shall be based on the number of passenger accommodations as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b3c019-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000 for each of the first 500 passenger accommodations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b3c01a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000 for each additional passenger accommodation between 501 and 1,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b3c01b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000 for each additional passenger accommodation between 1,001 and 1,500.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b3c01c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000 for each additional passenger accommodation over 1,500.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3c01d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the owner or charterer is operating more than one vessel subject to this chapter, the amount of financial responsibility shall be based on the number of passenger accommodations on the vessel with the largest number of passenger accommodations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3c01e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability To Pay Judgment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount determined under subsection (b) shall be available to pay a judgment for damages (whether less than or more than $20,000) for death or injury to a passenger or other individual on a voyage to or from a port in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3c01f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Means of Establishing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Financial responsibility under this section may be established by one or more of the following if acceptable to the Commission:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3c020-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3c021-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Surety bond issued by a bonding company authorized to do business in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3c022-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Qualification as a self-insurer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3c023-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44103/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other evidence of financial responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b3c024-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1554"},"text":"120 Stat. 1554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b3c025-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b3c026-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b3c027-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:817d(a) (1st–5th, 29th–last words), (b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/777/s2/a"},"text":"Pub. L. 89–777, § 2(a)","children":[],"tail":" (1st–5th, 29th–last words), (b), "},{"tag":"html:span","attrib":{},"text":"Nov. 6, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/1356"},"text":"80 Stat. 1356","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), the words “issued by a bonding company authorized to do business in the United States” are substituted for 46 App. U.S.C. 817d(b) to eliminate unnecessary words. The words “or any State thereof or the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, or any territory or possession of the United States” are omitted as unnecessary because of the definition of “United States” in chapter 1 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
