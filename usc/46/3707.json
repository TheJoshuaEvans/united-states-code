{"tag":"section","attrib":{"id":"idf66c2efc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3707"},"text":null,"children":[{"tag":"num","attrib":{"value":"3707"},"text":"§ 3707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tanker minimum standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf66c2efd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A new tanker of at least 10,000 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" shall be equipped with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf66c2efe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 remote steering gear control systems operable separately from the navigating bridge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2eff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the main steering gear control in the steering gear compartment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f00-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3707/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means of communications and rudder angle indicators on the navigating bridge, a remote steering gear control station, and the steering gear compartment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f01-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3707/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 2 identical and adequate power units for the main steering gear;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f02-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3707/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alternative and adequate power supply, either from an emergency source of electrical power or from another independent source of power located in the steering gear compartment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f03-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3707/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means of automatic starting and stopping of power units with attendant alarms at all steering stations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66c2f04-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An existing tanker of at least 10,000 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" shall be equipped with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf66c2f05-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 remote steering gear control systems operable separately from the navigating bridge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f06-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the main steering gear control in the steering gear compartment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f07-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3707/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means of communications and rudder angle indicators on the navigating bridge, a remote steering gear control station, and the steering gear compartment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf66c2f08-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/524"},"text":"97 Stat. 524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s716"},"text":"Pub. L. 104–324, title VII, § 716","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3937"},"text":"110 Stat. 3937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf66c2f09-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf66c2f0a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf66c2f0b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3707(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(7)(K)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3707(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(7)(L)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3707 requires compliance with certain minimum standards by a tanker, which is a self-propelled tank vessel.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3707(a) requires new tankers of 10,000 gross tons or above, to have two remote steering gear control systems, a main steering gear control in the steering gear compartment, a means of communications and rudder angle indicators at specified locations, two or more specified power units for the main steering gear, an alternative and adequate power supply of specified characteristics, and a means of automatic operation of power units, with attendant alarms at all steering stations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3707(b) requires existing tankers of 10,000 gross tons or above, to have two remote steering gear control systems, a main steering gear control in the steering gear compartment, and a means of communication and rudder angle indicators at specified locations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf66c2f0c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note"