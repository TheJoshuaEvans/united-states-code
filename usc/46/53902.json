{"tag":"section","attrib":{"id":"idf6e0ea7f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53902"},"text":null,"children":[{"tag":"num","attrib":{"value":"53902"},"text":"§ 53902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to provide insurance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e0ea80-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With the approval of the President, and after such consultation with interested agencies of United States Government as the President may require, the Secretary of Transportation may provide insurance and reinsurance against loss or damage from war risks as provided by this chapter whenever it appears to the Secretary that insurance adequate for the needs of the waterborne commerce of the United States cannot be obtained on reasonable terms and conditions from companies authorized to do insurance business in a State of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0ea81-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration of Risk","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Insurance or reinsurance under this chapter shall be based, insofar as practicable, on consideration of the risk involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35a82-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Vessel During War or National Emergency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Insurance or reinsurance for a vessel may be provided under this chapter only on the condition that the vessel will be available to the Government in time of war or national emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e35a83-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1627"},"text":"120 Stat. 1627","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e35a84-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e35a85-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e35a86-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53902","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1282.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XII, § 1202, as added "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-07/ch906"},"text":"Sept. 7, 1950, ch. 906","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/773"},"text":"64 Stat. 773","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/115/s7/a"},"text":"Pub. L. 101–115, § 7(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1989","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/103/694"},"text