{"tag":"section","attrib":{"id":"idf69710ae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12308"},"text":null,"children":[{"tag":"num","attrib":{"value":"12308"},"text":"§ 12308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Providing vessel numbering and registration information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person may request from an authority issuing a number under this chapter the numbering and registration information of a vessel that is retrievable from vessel numbering system records of the issuing authority. When the issuing authority is satisfied that the request is reasonable and related to a boating safety purpose, the information shall be provided on paying the cost of retrieving and providing the information requested.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf69710af-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/592"},"text":"97 Stat. 592","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69710b0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69710b1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf69710b2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12308","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:1473","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 12308 requires the number issuing authority to supply for a fee, numbering and registration information to any person, upon request, if the request is reasonable and related to boating safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
