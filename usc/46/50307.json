{"tag":"section","attrib":{"id":"idf6bac4c1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307"},"text":null,"children":[{"tag":"num","attrib":{"value":"50307"},"text":"§ 50307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maritime environmental and technical assistance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6bac4c2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emerging Marine Technologies and Practices","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bac4c3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation, acting through the Maritime Administrator, shall engage in or support the study, research, development, assessment, and deployment of emerging marine technologies and practices related to the maritime transportation system through eligible entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac4c4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Components","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under this subsection, the Secretary of Transportation shall identify, study, evaluate, test, demonstrate, improve, or support efforts related to, emerging marine technologies and practices to improve—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bac4c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" environmental performance to meet United States Federal and international standards and guidelines, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6bac4c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing air emissions, water emissions, or other ship discharges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6bac4c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing fuel economy or the use of alternative fuels and alternative energy (including the use of shore power); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6bac4c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" controlling aquatic invasive species; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6bac4c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing incidental vessel-generated underwater noise, such as noise from propeller cavitation or hydrodynamic flow; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bac4ca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efficiency and safety of domestic maritime industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac4cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Coordination with other Federal agencies or with State, local, or Tribal governments, as appropriate, under paragraph (2)(B) may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bac4cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities that are associated with the development or approval of validation and testing regimes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bac4cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certification or validation of emerging technologies or practices that demonstrate significant environmental or other benefits to domestic maritime industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac4ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may accept gifts, or enter into cooperative agreements, contracts, or other agreements with eligible entities to carry out the activities authorized under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac4cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the availability of appropriations, the Maritime Administrator, may establish and carry out a competitive grant program to award grants to eligible entities for projects in the United States consistent with the goals of this subsection to study, evaluate, test, demonstrate, or apply technologies and practices to improve environmental performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bac4d0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The results of activities conducted under this section shall be used to inform—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bac4d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policy decisions of the United States related to domestic regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac4d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the position of the United States on matters before the International Maritime Organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bac4d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Activities carried out under a grant or cooperative agreement made under this section may be conducted on public vessels under the control of the Maritime Administration, upon approval of the Maritime Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bac4d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Entity Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bac4d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private entity, including a nonprofit organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac4d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public entity, including a Federal, State, regional, or local government entity, including a special district;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac4d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe (as defined in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")) or a consortium of Indian Tribes;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac4d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education as defined under section 102 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"20 U.S.C. 1002","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac4d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership or collaboration of entities described in paragraphs (1) through (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bac4da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Center for Maritime Innovation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bac4db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall, through a cooperative agreement, establish a United States Center for Maritime Innovation (referred to in this subsection as the “Center”) to support the study, research, development, assessment, and deployment of emerging marine technologies and practices related to the maritime transportation system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac4dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bac4dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selected through a competitive process of eligible entities, and if a private entity, a domestic entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bac4de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based in the United States with technical expertise in emerging marine technologies and practices related to the maritime transportation system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bac4df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in close proximity to eligible entities with expertise in United States emerging marine technologies and practices, including the use of alternative fuels and the development of both vessel and shoreside infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac4e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall coordinate with other agencies critical for science, research, and regulation of emerging marine technologies for the maritime sector, including the Department of Energy, the Environmental Protection Agency, the National Science Foundation, and the Coast Guard, when establishing the Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac4e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bac4e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support eligible entities regarding the development and use of clean energy and necessary infrastructure to support the deployment of clean energy on vessels of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bac4e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor and assess, on an ongoing basis, the current state of knowledge regarding emerging marine technologies in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bac4e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any significant gaps in emerging marine technologies research specific to the United States maritime industry, and seek to fill those gaps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bac4e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research, development, testing, and evaluation for equipment, technologies, and techniques to address the components under subsection (a)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bac4e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6bac4e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/4/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance on best available technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6bac4e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/4/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6bac4e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/4/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance with understanding complex regulatory requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6bac4ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/4/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation of best practices in the maritime industry, including training and informational webinars on solutions for the maritime industry; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bac4eb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50307/e/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with academic and private sector response training centers and Domestic Maritime Workforce Training and Education Centers of Excellence to develop maritime strategies applicable to various segments of the United States maritime industry, including the inland, deep water, and coastal fleets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6bac4ec-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/tIV/s403/a"},"text":"Pub. L. 112–213, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1569"},"text":"126 Stat. 1569","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3503"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1969"},"text":"133 Stat. 1969","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8504(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4747"},"text":"134 Stat. 4747","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dC/tXXXV/s3514"},"text":"Pub. L. 117–81, div. C, title XXXV, § 3514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2243"},"text":"135 Stat. 2243","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3543/a"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3543(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3098"},"t