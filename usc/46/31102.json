{"tag":"section","attrib":{"id":"idf6a7b177-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31102"},"text":null,"children":[{"tag":"num","attrib":{"value":"31102"},"text":"§ 31102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of immunity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a7b178-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A civil action in personam in admiralty may be brought, or an impleader filed, against the United States for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a7b179-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damages caused by a public vessel of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a7b17a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for towage and salvage services, including contract salvage, rendered to a public vessel of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a7b17b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Counterclaim or Setoff","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the United States brings a civil action in admiralty for damages caused by a privately owned vessel, the owner of the vessel, or the successor in interest, may file a counterclaim in personam, or claim a setoff, against the United States for damages arising out of the same subject matter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a7b17c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1521"},"text":"120 Stat. 1521","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a7b17d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a7b17e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a7b17f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31102(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:781.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1925-03-03/ch428/s1"},"text":"Mar. 3, 1925, ch. 428, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/43/1112"},"text":"43 Stat. 1112","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31102(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:783 (words before proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1925-03-03/ch428/s3"},"text":"Mar. 3, 1925, ch. 428, § 3","children":[],"tail":" (words before proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/43/1112"},"text":"43 Stat. 1112","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “civil action” are substituted for “libel” because of rule 2 of the Federal Rules of Civil Procedure (28 App. U.S.C.).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the cause of action arose after the 6th day of April, 1920” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “in rem or in personam” are omitted as unnecessary. The words “file a counterclaim in personam, or claim a setoff” are substituted for “file a cross libel in personam or claim a set-off or counterclaim” to conform to the terminolgy in the Federal Rules of Civil Procedure and to eliminate unnecessary words. The words “for damages arising out of the same subject matter” are substituted for “in such suit for and on account of any damages arising out of the same subject matter or cause of action” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
