{"tag":"section","attrib":{"id":"idf6c46266-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51324"},"text":null,"children":[{"tag":"num","attrib":{"value":"51324"},"text":"§ 51324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfilled vacancies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c46267-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the event of an unfilled vacancy for any critical position at the United States Merchant Marine Academy, the Secretary of Transportation may appoint, without regard to the provisions of subchapter I of chapter 33 of title 5, other than sections 3303 and 3328 of that title, a qualified candidate for the purposes of filling up to 20 of such positions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c46268-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Critical Position Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “critical position” means a position that contributes to the improvement of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c46269-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51324/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the culture or infrastructure of the Academy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c4626a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51324/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" student health and well being;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c4626b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51324/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Academy governance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c4626c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51324/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other priority areas identified by the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c4626d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dC/tXXXV/s3501/c/1"},"text":"Pub. L. 117–81, div. C, title XXXV, § 3501(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2238"},"text":"135 Stat. 2238","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
