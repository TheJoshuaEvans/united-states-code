{"tag":"section","attrib":{"id":"idf6b60a27-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50111"},"text":null,"children":[{"tag":"num","attrib":{"value":"50111"},"text":"§ 50111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of annual MARAD authorization request","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b60a28-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Legislative Proposal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date on which the President submits to Congress a budget for a fiscal year pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Secretary of Transportation shall submit to the Committee on Armed Services and the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate the Maritime Administration authorization request for that fiscal year."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a29-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maritime Administration Request Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “Maritime Administration authorization request” means a proposal for legislation that, for a fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b60a2a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommends authorizations of appropriations for the Maritime Administration for that fiscal year, including with respect to matters described in subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002025"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002025"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 109(j) of title 49 or authorized in subtitle V of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a2b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addresses any other matter with respect to the Maritime Administration that the Secretary determines is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b60a2c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1560"},"text":"120 Stat. 1560","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1074/c/1"},"text":"Pub. L. 114–92, div. A, title X, § 1074(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/996"},"text":"129 Stat. 996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b60a2d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n