{"tag":"section","attrib":{"id":"idf6591c39-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2118"},"text":null,"children":[{"tag":"num","attrib":{"value":"2118"},"text":"§ 2118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of equipment standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6591c3a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In establishing standards for approved equipment required on vessels subject to part B of this subtitle, the Secretary shall establish standards that are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6591c3b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2118/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on performance using the best available technology that is economically achievable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6591c3c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2118/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operationally practical.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6591c3d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Using the standards established under subsection (a), the Secretary may also certify lifesaving equipment that is not required to be carried on vessels subject to part B of this subtitle to ensure that such equipment is suitable for its intended purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6591c3e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2118/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least once every 10 years the Secretary shall review and revise the standards established under subsection (a) to ensure that the standards meet the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6591c3f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVI/s608/a"},"text":"Pub. L. 111–281, title VI, § 608(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2968"},"text":"124 Stat. 2968","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s306/a/2"},"text":"Pub. L. 114–120, title III, § 306(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/54"},"text":"130 Stat. 54","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6591c40-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6591c41-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6591c42-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s306/a/2/A"},"text":"Pub. L. 114–120, § 306(a)(2)(A)","children":[],"tail":", substituted “subtitle,” for “title,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s306/a/2/B"},"text":"Pub. L. 114–120, § 306(a)(2)(B)","children":[],"tail":", substituted “subtitle” for “title”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
