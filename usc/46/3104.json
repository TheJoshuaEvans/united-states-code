{"tag":"section","attrib":{"id":"idf65b65c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3104"},"text":null,"children":[{"tag":"num","attrib":{"value":"3104"},"text":"§ 3104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survival craft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf65b65c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement To Equip","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require that a passenger vessel be equipped with survival craft that ensures that no part of an individual is immersed in water, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf65b65c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such vessel is built or undergoes a major conversion after ","children":[{"tag":"date","attrib":{"date":"2016-01-01"},"text":"January 1, 2016","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b65c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates in cold waters as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65b65c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Higher Standard of Safety","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may revise part 117 or part 180 of title 46, Code of Federal Regulations, as in effect before ","children":[{"tag":"date","attrib":{"date":"2016-01-01"},"text":"January 1, 2016","children":[],"tail":", if such revision provides a higher standard of safety than is provided by the regulations in effect on or before the date of the enactment of the Coast Guard Authorization Act of 2016."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65b65ca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Innovative and Novel Designs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, in lieu of the requirements set out in part 117 or part 180 of title 46, Code of Federal Regulations, as in effect on the date of the enactment of the Coast Guard Authorization Act of 2016, allow a passenger vessel to be equipped with a life-saving appliance or arrangement of an innovative or novel design that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf65b65cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures no part of an individual is immersed in water; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b65cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an equal or higher standard of safety than is provided by such requirements as in effect before such date of the enactment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65b65cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Built Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “built” has the meaning that term has under section 4503(d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf65b65ce-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVI/s609/a"},"text":"Pub. L. 111–281, title VI, § 609(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2968"},"text":"124 Stat. 2968","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tIII/s303"},"text":"Pub. L. 112–213, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1563"},"text":"126 Stat. 1563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s301/a"},"text":"Pub. L. 114–120, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/50"},"text":"130 Stat. 50","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3503/a"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2775"},"text":"130 Stat. 2775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tV/s508/e"},"text":"Pub. L. 115–282, title V, § 508(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4273"},"text":"132 Stat. 4273","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf65b65cf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf65b65d0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf65b65d1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Coast Guard Authorization Act of 2016, referred to in subsecs. (b) and (c), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf65b65d2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" substituted “section 4503(d)” for “section 4503(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" amended section generally. Prior to amendment, section related to survival craft."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “Coast Guard Authorization Act of 2016” for “Coast Guard Authorization Act of 2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/s303/1"},"text":"Pub. L. 112–213, § 303(1)","children":[],"tail":", substituted “the date that is 30 months after the date on which the report described in subsection (c) is submitted” for “"},{"tag":"date","attrib":{"date":"2015-01-01"},"text":"January 1, 2015","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/s303/2"},"text":"Pub. L. 112–213, § 303(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf65b65d3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf65b65d4-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3503/e"},"text":"section 3503(e) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2182"},"text":"section 2182 of Title 14","children":[],"tail":", Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf65b65d5-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Review; Revision of Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s301/b"},"text":"Pub. L. 114–120, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/50"},"text":"130 Stat. 50","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/120/tIII/s301/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2016-12-31"},"text":"December 31, 2016","children":[],"tail":", the Secretary of the department in which the Coast Guard is operating shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a review of—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of casualties for individuals with disabilities, children, and the elderly as a result of immersion in water, reported to the Coast Guard over the preceding 30-year period, by vessel type and area of operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the risks to individuals with disabilities, children, and the elderly as a result of immersion in water, by passenger vessel type and area of operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the effect that carriage of survival craft that ensure that no part of an individual is immersed in water has on—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passenger vessel safety, including stability and safe navigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the survivability of individuals, including individuals with disabilities, children, and the elderly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs, the incremental cost difference to vessel operators, and the cost effectiveness of requiring the carriage of such survival craft to address the risks to individuals with disabilities, children, and the elderly;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efficacy of alternative safety systems, devices, or measures in improving survivability of individuals with disabilities, children, and the elderly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of small businesses and nonprofit vessel operators that would be affected by requiring the carriage of such survival craft on passenger vessels to address the risks to individuals with disabilities, children, and the elderly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In conducting the review under paragraph (1), the Secretary shall include an examination of passenger vessel casualties that have occurred in the waters of other nations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall update the review required under paragraph (1) every 5 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Based on the review conducted under paragraph (1), including updates thereto, the Secretary shall revise regulations concerning the carriage of survival craft under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s3104/c"},"text":"section 3104(c) of title 46","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
