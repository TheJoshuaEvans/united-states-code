{"tag":"section","attrib":{"id":"idf6a0ad72-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109"},"text":null,"children":[{"tag":"num","attrib":{"value":"15109"},"text":"§ 15109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a0ad73-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ad74-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), each committee established under this chapter or to which this chapter applies shall, at least once each year, meet at the call of the Secretary or a majority of the members of the committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad75-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The committee established under section 15102 shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad76-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet in-person, not less frequently than twice each year, at the call of the Secretary of a majority of the members of the committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad77-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold additional meetings as necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad78-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" post the minutes of each meeting of the committee on a publicly available website not later than 2 weeks after the date on which a meeting concludes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad79-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide reasonable public notice of any meeting of the committee, and publish such notice in the Federal Register and on a publicly available website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad7a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee Status","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of a committee established under this chapter or to which this chapter applies shall not be considered an employee of the Federal Government by reason of service on such committee, except for the purposes of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ad7b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 81 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad7c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 171 of title 28 and any other Federal law relating to tort liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad7d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (b), a member of a committee established under this chapter or to which this chapter applies, when actually engaged in the performance of the duties of such committee, may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ad7e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive compensation at a rate established by the Secretary, not to exceed the maximum daily rate payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad7f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if not compensated in accordance with paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad80-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be reimbursed for actual and reasonable expenses incurred in the performance of such duties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad81-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be allowed travel expenses, including per diem in lieu of subsistence, as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad82-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Volunteer Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of a committee established under this chapter or to which this chapter applies may serve on such committee on a voluntary basis without pay without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":" or any other law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad83-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status of Members.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ad84-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), with respect to a member of a committee established under this chapter or to which this chapter applies whom the Secretary appoints to represent an entity or group—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad85-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member is authorized to represent the interests of the applicable entity or group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad86-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements under Federal law that would interfere with such representation and that apply to a special Government employee (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s202/a"},"text":"section 202(a) of title 18","children":[],"tail":"), including requirements relating to employee conduct, political activities, ethics, conflicts of interest, and corruption, do not apply to the member."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad87-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (b), a member of a committee established under this chapter or to which this chapter applies shall be treated as a special Government employee for purposes of the committee service of the member if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad88-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary appointed the member to represent the general public; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad89-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member, without regard to service on the committee, is a special Government employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad8a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service on Committee.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ad8b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Solicitation of nominations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before appointing an individual as a member of a committee established under this chapter or to which this chapter applies, the Secretary shall publish, in the Federal Register, a timely notice soliciting nominations for membership on such committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad8c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointments.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad8d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After considering nominations received pursuant to a notice published under paragraph (1), the Secretary may, as necessary, appoint a member to the applicable committee established under this chapter or to which this chapter applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad8e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not seek, consider, or otherwise use information concerning the political affiliation of a nominee in making an appointment to any committee established under this chapter or to which this chapter applies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad8f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service at pleasure of the secretary.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad90-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of a committee established under this chapter or to which this chapter applies shall serve at the pleasure of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad91-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subparagraph (A), a member of the committee established under section 15102 may only be removed prior to the end of the term of that member for just cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad92-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security background examinations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require an individual to have passed an appropriate security background examination before appointment to a committee established under this chapter or to which this chapter applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad93-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad94-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), a Federal employee may not be appointed as a member of a committee established under this chapter or to which this chapter applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad95-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for national merchant marine personnel advisory committee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may appoint a Federal employee to serve as a member of the National Merchant Marine Personnel Advisory Committee to represent the interests of the United States Merchant Marine Academy and, notwithstanding paragraphs (1) and (2), may do so without soliciting, receiving, or considering nominations for such appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad96-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad97-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of each member of a committee established under this chapter or to which this chapter applies shall expire on December 31 of the third full year after the effective date of the appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad98-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continued service after term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the term of a member of a committee established under this chapter or to which this chapter applies ends, the member, for a period not to exceed 1 year, may continue to serve as a member until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad99-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vacancy on a committee established under this chapter or to which this chapter applies shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad9a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for reappointments.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad9b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reappointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraphs (1) and (2), the Secretary may reappoint a member of a committee established under this chapter or to which this chapter applies for any term, other than the first term of the member, without soliciting, receiving, or considering nominations for such appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad9c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/f/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to the committee established under section 15102, members may serve not more than 3 terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad9d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staff Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall furnish to each committee established under this chapter or to which this chapter applies any staff and services considered by the Secretary to be necessary for the conduct of the committee’s functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad9e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman; Vice Chairman.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ad9f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each committee established under this chapter or to which this chapter applies shall elect a Chairman and Vice Chairman from among the committee’s members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ada0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vice chairman acting as chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Vice Chairman shall act as Chairman in the absence or incapacity of, or in the event of a vacancy in the office of, the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ada1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcommittees and Working Groups.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ada2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chairman of a committee established under this chapter or to which this chapter applies may establish and disestablish subcommittees and working groups for any purpose consistent with the function of the committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ada3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to conditions imposed by the Chairman, members of a committee established under this chapter or to which this chapter applies and additional individuals drawn from entities or groups designated by this chapter to be represented on the committee or the general public may be assigned to subcommittees and working groups established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ada4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chair","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Only committee members may chair subcommittees and working groups established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ada5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation, Advice, Reports, and Recommendations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ada6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ada7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before taking any significant action, the Secretary shall consult with, and consider the information, advice, and recommendations of, a committee established under this chapter or to which this chapter applies if the function of the committee is to advise the Secretary on matters related to the significant action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ada8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this paragraph, regulations proposed under chapter 45 of this title are significant actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ada9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advice, reports, and recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each committee established under this chapter or to which this chapter applies shall submit, in writing, to the Secretary its advice, reports, and recommendations, in a form and at a frequency determined appropriate by the committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0adaa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Explanation of actions taken","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date on which the Secretary receives recommendations from a committee under paragraph (2), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0adab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/j/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the recommendations on a website accessible at no charge to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0adac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/j/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the recommendations are from the committee established under section 15102, establish a mechanism for the submission of public comments on the recommendations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0adad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/j/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond, in writing, to the committee regarding the recommendations, including by providing an explanation of actions taken regarding the recommendations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0adae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/j/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make all responses required by subparagraph (C) which are related to recommendations made by the committee established under section 15102 available to the public not later than 30 days after the date of response.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0adaf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission to congress.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0adb0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/j/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate the advice, reports, and recommendations received from committees under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0adb1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/j/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional submission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to a committee established under section 70112 and to which this section applies, the Secretary shall submit the advice, reports, and recommendations received from the committee under paragraph (2) to the Committee on Homeland Security of the House of Representatives in addition to the committees specified in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0adb2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Observers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0adb3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any Federal agency with matters under such agency’s administrative jurisdiction related to the function of a committee established under this chapter or to which this chapter applies may designate a representative to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0adb4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/k/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attend any meeting of such committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0adb5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/k/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate as an observer at meetings of such committee that relate to such a matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0adb6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National commercial fishing safety advisory committee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to the committee established under section 15102, the Commandant of the Coast Guard shall designate a representative under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0adb7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Assistance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0adb8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide technical assistance to the Committee if requested by the Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0adb9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Committee consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to the committee established under section 15102, the Chairman of the committee shall seek expertise from the fishing industry, marine safety experts, the shipbuilding industry, and others as the committee determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0adba-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each committee established under this chapter or to which this chapter applies shall terminate on ","children":[{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0adbb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15109/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall preclude the Secretary from taking emergency action to ensure safety and preservation of life at sea.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a0adbc-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVI/s601/a"},"text":"Pub. L. 115–282, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4286"},"text":"132 Stat. 4286","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], §§ 8331(b), 8335(a)(2), title LVXXXV [LXXXV], § 8505(b)(14), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4703"},"text":"134 Stat. 4703","children":[],"tail":", 4707, 4752; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXV/s3535/e"},"text":"Pub. L. 118–159, div. C, title XXXV, § 3535(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2315"},"text":"138 Stat. 2315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a0adbd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6a0adbe-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6a0adbf-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3535/e/1"},"text":"Pub. L. 118–159, § 3535(e)(1)","children":[],"tail":", substituted “15102” for “15102,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3535/e/2"},"text":"Pub. L. 118–159, § 3535(e)(2)","children":[],"tail":", inserted “or to which this chapter applies” after “under this chapter” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8331/b"},"text":"Pub. L. 116–283, § 8331(b)","children":[],"tail":", inserted “or to which this chapter applies” after “committee established under this chapter” wherever appearing. The phrase “committee established under this chapter” in subsec. (k) was added subsequent to this amendment, and therefore the inserted phrase does not appear there. See subsec. (k) Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8335/a/2/A"},"text":"Pub. L. 116–283, § 8335(a)(2)(A)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, substituted “Except as provided in paragraph (2), each” for “Each”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8335/a/2/B"},"text":"Pub. L. 116–283, § 8335(a)(2)(B)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/b/14"},"text":"Pub. L. 116–283, § 8505(b)(14)","children":[],"tail":", substituted “additional individuals” for “additional persons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8335/a/2/C"},"text":"Pub. L. 116–283, § 8335(a)(2)(C)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8335/a/2/D"},"text":"Pub. L. 116–283, § 8335(a)(2)(D)","children":[],"tail":", amended subsec. (k) generally. Prior to amendment, text read as follows: “Any Federal agency with matters under such agency’s administrative jurisdiction related to the function of a committee established under this chapter or to which this chapter applies may designate a representative to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) attend any meeting of such committee; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) participate as an observer at meetings of such committee that relate to such a matter.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":