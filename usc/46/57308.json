{"tag":"section","attrib":{"id":"idf6f1b31a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57308"},"text":null,"children":[{"tag":"num","attrib":{"value":"57308"},"text":"§ 57308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of vessels at least 25 years old","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An obsolete vessel acquired under this chapter that is or becomes at least 25 years old may not be used for commercial operation. However, the vessel may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f1b31b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57308/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during a period in which vessels may be requisitioned under chapter 563 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b31c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57308/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise provided in this subtitle, on trade routes serving only the foreign trade of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b31d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1664"},"text":"120 Stat. 1664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b31e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f1b31f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children