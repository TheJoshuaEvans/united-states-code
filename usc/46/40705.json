{"tag":"section","attrib":{"id":"idf6aeddb7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40705"},"text":null,"children":[{"tag":"num","attrib":{"value":"40705"},"text":"§ 40705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential review of Commission orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6aeddb8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transmission to President","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Maritime Commission shall transmit to the President, concurrently with publication thereof, each order of suspension or final order of prohibition issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s40704"},"text":"section 40704 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aeddb9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presidential Request and Commission Action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 10 days after receipt or the effective date of a Commission order referred to in subsection (a), the President, in writing, may request the Commission to stay the effect of the order if the President finds that the stay is required for reasons of national defense or foreign policy. The reasons shall be specified in the request. The Commission shall immediately grant the request by issuing an order in which the President’s request shall be described. During a stay, the President shall, whenever practicable, attempt to resolve the matter by negotiating with representatives of the applicable foreign governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6aeddba-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1537"},"text":"120 Stat. 1537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6aeddbb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6aeddbc-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6aeddbd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text"