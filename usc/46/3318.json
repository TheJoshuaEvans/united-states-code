0/s4302/b/5"},"text":"Pub. L. 101–380, § 4302(b)(5)","children":[],"tail":", substituted “commits a class D felony.” for “shall be fined not less than $1,000 but not more than $10,000, and imprisoned for not less than 2 years but not more than 5 years,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/307"},"text":"Pub. L. 99–307","children":[],"tail":" in provision preceding par. (1) substituted “than” for “then” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498/s211/c/1"},"text":"Pub. L. 98–498, § 211(c)(1)","children":[],"tail":", substituted “Except as otherwise provided in this part, the” for “The” and “not more than $5,000” for “$1,000, except that when the violation involves operation of a barge, the penalty is $500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498/s211/c/2"},"text":"Pub. L. 98–498, § 211(c)(2)","children":[],"tail":", substituted “$5,000” for “$2,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498/s211/c/3"},"text":"Pub. L. 98–498, § 211(c)(3)","children":[],"tail":", substituted “$5,000” for “$2,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498/s211/c/4"},"text":"Pub. L. 98–498, § 211(c)(4)","children":[],"tail":", substituted “$10,000” for “$2,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498/s211/c/5"},"text":"Pub. L. 98–498, § 211(c)(5)","children":[],"tail":", substituted “$10,000” for “$5,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498/s211/c/6"},"text":"Pub. L. 98–498, § 211(c)(6)","children":[],"tail":", substit