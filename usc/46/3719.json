{"tag":"section","attrib":{"id":"idf66c2faf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3719"},"text":null,"children":[{"tag":"num","attrib":{"value":"3719"},"text":"§ 3719.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction of oil spills from single hull non-self-propelled tank vessels","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, in consultation with the National Towing Safety Advisory Committee and taking into consideration the characteristics, methods of operation, and the size and nature of service of single hull non-self-propelled tank vessels and towing vessels, prescribe regulations requiring a single hull non-self-propelled tank vessel that operates in the open ocean or coastal waters, or the vessel towing it, to have at least one of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf66c2fb0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3719/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A crew member and an operable anchor on board the tank vessel that together are capable of arresting the tank vessel without additional assistance under reasonably foreseeable sea conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2fb1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3719/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An emergency system on the tank vessel or towing vessel that without additional assistance under reasonably foreseeable sea conditions will allow the tank vessel to be retrieved by the towing vessel if the tow line ruptures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2fb2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3719/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other measure or combination of measures that the Secretary determines will provide protection against grounding of the tank vessel comparable to that provided by the measures described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf66c2fb3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tIX/s901/a"},"text":"Pub. L. 104–324, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3946"},"text":"110 Stat. 3946","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVI/s601/c/6/B/i"},"text":"Pub. L. 115–282, title VI, § 601(c)(6)(B)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4290"},"text":"132 Stat. 4290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf66c2fb4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf66c2fb5-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf66c2fb6-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" inserted “National” before “Towing Safety” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf66c2fb7-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf66c2fb8-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tIX/s901/b"},"text":"Pub. L. 104–324, title IX, § 901(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3946"},"text":"110 Stat. 3946","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/324/tIX/s901/b"},"text":"“The Secretary of the department in which the Coast Guard is operating shall issue regulations required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s3719"},"text":"section 3719 of title 46","children":[],"tail":", United States Code, as added by subsection (a), by not later than "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
