{"tag":"section","attrib":{"id":"idf6bfa634-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302"},"text":null,"children":[{"tag":"num","attrib":{"value":"51302"},"text":"§ 51302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nomination and competitive appointment of cadets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6bfa635-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual may be nominated for a competitive appointment as a cadet at the United States Merchant Marine Academy only if the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bfa636-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a citizen or national of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa637-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the minimum requirements that the Secretary of Transportation shall establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bfa638-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nominators","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nominations for competitive appointments for the positions allocated under subsection (c) may be made as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bfa639-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Senator may nominate residents of the State represented by that Senator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa63a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Member of the House of Representatives may nominate residents of the State in which the congressional district represented by that Member is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa63b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Delegate to the House of Representatives from the District of Columbia, the Virgin Islands, Guam, the Northern Mariana Islands, or American Samoa may nominate residents of the jurisdiction represented by that Delegate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa63c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Resident Commissioner to the United States from Puerto Rico may nominate residents of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa63d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Panama Canal Commission may nominate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bfa63e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" residents, or sons or daughters of residents, of an area or installation in Panama and made available to the United States under the Panama Canal Treaty of 1977, the agreements relating to and implementing that Treaty, signed ","children":[{"tag":"date","attrib":{"date":"1977-09-07"},"text":"September 7, 1977","children":[],"tail":", and the Agreement Between the United States of America and the Republic of Panama Concerning Air Traffic Control and Related Services, concluded "},{"tag":"date","attrib":{"date":"1979-01-08"},"text":"January 8, 1979","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bfa63f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sons or daughters of personnel of the United States Government and the Panama Canal Commission residing in Panama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bfa640-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of Positions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Positions for competitive appointments shall be allocated each year as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bfa641-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Positions shall be allocated for residents of each State nominated by the Members of Congress from that State in proportion to the representation in Congress from that State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa642-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four positions shall be allocated for residents of the District of Columbia nominated by the Delegate to the House of Representatives from the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa643-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One position each shall be allocated for residents of the Virgin Islands, Guam, and American Samoa nominated by the Delegates to the House of Representatives from the Virgin Islands, Guam, and American Samoa, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa644-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One position shall be allocated for a resident of Puerto Rico nominated by the Resident Commissioner to the United States from Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa645-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One position shall be allocated for a resident of the Northern Mariana Islands nominated by the Governor of the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa646-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two positions shall be allocated for individuals nominated by the Panama Canal Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bfa647-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competitive System for Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bfa648-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a competitive system for selecting individuals nominated under subsection (b) to fill the positions allocated under subsection (c). The system must determine the relative merit of each individual based on competitive examinations, an assessment of the individual’s academic background, and other effective indicators of motivation and probability of successful completion of training at the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa649-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointments by jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall appoint individuals to fill the positions allocated under subsection (c) for each jurisdiction in the order of merit of the individuals nominated from that jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa64a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remaining unfilled positions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If positions remain unfilled after the appointments are made under paragraph (2), the Secretary shall appoint individuals to fill the positions in the order of merit of the remaining individuals nominated from all jurisdictions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bfa64b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Notification in Advance of Appointments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When a nominee of a Senator, Representative, or Delegate is selected for appointment as a cadet, the Senator, Representative, or Delegate shall be notified at least 48 hours before the official notification or announcement of the appointment is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6bfa64c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1570"},"text":"120 Stat. 1570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dC/tXXXV/s3503"},"text":"Pub. L. 111–383, div. C, title XXXV, § 3503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4518"},"text":"124 Stat. 4518","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s566/d"},"text":"Pub. L. 114–328, div. A, title V, § 566(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2139"},"text":"130 Stat. 2139","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6bfa64d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6bfa64e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6bfa64f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"51302(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1295b(b) (1)(A).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XIII, § 1303(b)(1)–(3)(A), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/96/453/s2"},"text":"Pub. L. 96–453, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1998"},"text":"94 Stat. 1998","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/595/tVII/s708/1"},"text":"Pub. L. 101–595, title VII, § 708(1)","children":[],"tail":", (2), "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/2995"},"text":"104 Stat. 2995","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1295b(b)(2) (A) (related to nominations).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"51302(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1295b(b)(1) (less cl. (A)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1295b(b)(3) (A)(ii) (related to who may be nominated).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"51302(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1295b(b)(3) (A) (less (ii) (related to who may be nominated)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"51302(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1295b(b)(2) (A) (related to selection), (B), (3)(B), (C).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(6)(A), the words “residents, or sons or daughters of residents, of an area or installation” are substituted for “a resident of the area or installation” in 46 App. U.S.C. 1295b(b)(1)(B) and “sons or daughters of residents of any area or installation” in 46 App. U.S.C. 1295b(b)(3)(A)(ii) to resolve an inconsistency in the source law and to conform to the probable intent of Congress. Although 46 App. U.S.C. 1295b(b)(1)(B) provides that a nominee must be a resident, 46 App. U.S.C. 1295b(b)(3)(A)(ii) allocates positions only for sons or daughters of residents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6bfa650-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6bfa651-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s3503/1"},"text":"Pub. L. 111–383, § 3503(1)","children":[],"tail":", inserted “the Northern Mariana Islands,” after “Guam,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383/s3503/2"},"text":"Pub. L. 111–383, § 3503(2)","children":[],"tail":", redesignated par. (6) as (5) and struck out former par. (5) which read as follows: “The Governor of the Northern Mariana Islands may nominate residents of the Northern Mariana Islands.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6bfa652-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6bfa653-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" applicable with respect to the appointment of cadets and midshipmen to the United States Military Academy, the United States Naval Academy, the United States Air Force Academy, and the United States Merchant Marine Academy for classes entering these service academies after "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"Jan. 1, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s566/e"},"text":"section 566(e) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s7442"},"text":"section 7442 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
