{"tag":"section","attrib":{"id":"idf6781697-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7103"},"text":null,"children":[{"tag":"num","attrib":{"value":"7103"},"text":"§ 7103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licenses for radio officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6781698-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A license as radio officer may be issued only to an applicant who has a first-class or second-class radiotelegraph operator license issued by the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6781699-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7318"},"text":"section 7318 of this title","children":[],"tail":", this part does not affect the status of radiotelegraph operators serving on board vessels operating only on the Great Lakes."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf678169a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/540"},"text":"97 Stat. 540","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf678169b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf678169c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf678169d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:229a","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:229b","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:229g","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7103 requires an applicant for a license as a radio officer to have, as a prerequisite, a first-class or second-class radiotelegraph operator license issued by the Federal Communications Commission (FCC). It also excepts radiotelegraph operators that are engaged on Great Lakes vessels from the requirement of having to obtain a radio officer’s license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
