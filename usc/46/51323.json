{"tag":"section","attrib":{"id":"idf6c4625d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51323"},"text":null,"children":[{"tag":"num","attrib":{"value":"51323"},"text":"§ 51323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Merchant Marine Academy Advisory Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c4625e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall establish an advisory council, to be known as the “United States Merchant Marine Academy Advisory Council” (in this section referred to as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c4625f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c46260-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51323/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall select not fewer than 8 and not more than 14 individuals to serve as members of the Council. Such individuals shall have such expertise as the Secretary determines necessary and appropriate for providing advice and guidance on improving the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46261-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51323/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Governmental experts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The number of members of the Council who are employees of the Federal Government may not exceed the number of members of the Council who are not employees of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46262-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51323/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee status","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the Council shall not be considered employees of the United States Government by reason of their membership on the Council for any purpose and shall not receive compensation other than reimbursement of travel expenses and per diem allowance in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c46263-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51323/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall provide advice to the Secretary at the time and in the manner requested by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c46264-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51323/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personally Identifiable Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out its responsibilities under this subsection, the Council shall comply with the obligations of the Department of Transportation to protect personally identifiable information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c46265-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dC/tXXXV/s3501/c/1"},"text":"Pub. L. 117–81, div. C, title XXXV, § 3501(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2238"},"text":"135 Stat. 2238","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
