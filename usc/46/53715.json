{"tag":"section","attrib":{"id":"idf6dea07f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715"},"text":null,"children":[{"tag":"num","attrib":{"value":"53715"},"text":"§ 53715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Escrow fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6dea080-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the proceeds of an obligation guaranteed under this chapter are to be used to finance the construction, reconstruction, or reconditioning of a vessel that will serve as security for a guarantee under this chapter, the Secretary or Administrator may accept and hold in escrow, under an escrow agreement with the obligor, a portion of the proceeds of all obligations guaranteed under this chapter whose proceeds are to be so used which is equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dea081-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the excess of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dea082-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal amount of all obligations whose proceeds are to be so used; over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dea083-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent or 87.5 percent, whichever is applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53709/b"},"text":"section 53709(b) of this title","children":[],"tail":", of the amount paid by or for the account of the obligor for the construction, reconstruction, or reconditioning of the vessel; plus"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea084-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any interest the Secretary or Administrator may require on the amount described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea085-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security Involving Both Uncompleted and Delivered Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the security for the guarantee of an obligation relates both to a vessel to be constructed, reconstructed, or reconditioned and to a delivered vessel, the principal amount of the obligation shall be prorated for purposes of subsection (a) under regulations prescribed by the Secretary or Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea086-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disbursement Before Termination of Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dea087-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or Administrator shall disburse amounts in the escrow fund, as specified in the escrow agreement, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dea088-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" pay amounts the obligor is obligated to pay for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6dea089-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction, reconstruction, or reconditioning of a vessel used as security for the guarantee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6dea08a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest on the obligations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dea08b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" redeem the obligations under a refinancing guaranteed under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dea08c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay any excess interest deposits to the obligor at times provided for in the escrow agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea08d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Manner of payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a payment becomes due under the guarantee before the termination of the escrow agreement, the amount in the escrow fund at the time the payment becomes due, including realized income not yet paid to the obligor, shall be paid into the appropriate account under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53717"},"text":"section 53717 of this title","children":[],"tail":". The amount shall be credited against amounts due or to become due from the obligor to the Secretary or Administrator on the guaranteed obligations or, to the extent not so required, be paid to the obligor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea08e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payments Required Before Disbursement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dea08f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No disbursement shall be made under subsection (c) to any person until the total amount paid by or for the account of the obligor from sources other than the proceeds of the obligation equals at least 25 percent or 12.5 percent, whichever is applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53709/b"},"text":"section 53709(b) of this title","children":[],"tail":", of the aggregate actual cost of the vessel, as previously approved by the Secretary or Administrator. If the aggregate actual cost of the vessel has increased since the Secretary’s or Administrator’s initial approval or if it increases after the first disbursement is permitted under this subsection, then no further disbursements shall be made under subsection (c) until the total amount paid by or for the account of the obligor from sources other than the proceeds of the obligation equals at least 25 percent or 12.5 percent, as applicable, of the increase, as determined by the Secretary or Administrator, in the aggregate actual cost of the vessel. This paragraph does not require the Secretary or Administrator to consent to finance any increase in actual cost unless the Secretary or Administrator determines that such an increase in the obligation meets all the terms and conditions of this chapter or other applicable law."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea090-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documented proof of progress requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator shall, by regulation, establish a transparent, independent, and risk-based process for verifying and documenting the progress of projects under construction before disbursing guaranteed loan funds. At a minimum, the process shall require documented proof of progress in connection with the construction, reconstruction, or reconditioning of a vessel or vessels before disbursements are made from the escrow fund. The Secretary or Administrator may require that the obligor provide a certificate from an independent party certifying that the requisite progress in construction, reconstruction, or reconditioning has taken place.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea091-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disbursement on Termination of Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dea092-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a payment has not become due under the guarantee before the termination of the escrow agreement, the balance of the escrow fund at the time of termination shall be disbursed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dea093-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepay the excess of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6dea094-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal amount of all obligations whose proceeds are to be used to finance the construction, reconstruction, or reconditioning of the vessel used or to be used as security for the guarantee; over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6dea095-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent or 87.5 percent, whichever is applicable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53709/b"},"text":"section 53709(b) of this title","children":[],"tail":", of the actual cost of the vessel to the extent paid; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dea096-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay interest on that prepaid amount of principal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea097-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remaining balance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any remaining balance of the escrow fund shall be paid to the obligor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea098-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator may invest and reinvest any part of an escrow fund in obligations of the United States Government with maturities such that the escrow fund will be available as required for purposes of the escrow agreement. Investment income shall be paid to the obligor when received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea099-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53715/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms To Protect Government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The escrow agreement shall contain other terms the Secretary or Administrator considers necessary to protect fully the interests of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6dea09a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1614"},"text":"120 Stat. 1614","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/H"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(H)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/10/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(10)(B)","children":[],"tail":", (11), (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6dea09b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6dea09c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6dea09d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)