{"tag":"section","attrib":{"id":"idf66c2f72-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715"},"text":null,"children":[{"tag":"num","attrib":{"value":"3715"},"text":"§ 3715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lightering","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf66c2f73-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A vessel may transfer oil or hazardous material in a port or place subject to the jurisdiction of the United States, when the cargo has been transferred from another vessel on the navigable waters of the United States or in the marine environment, only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf66c2f74-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer was conducted consistent with regulations prescribed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f75-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both the delivering and receiving vessels had on board, at the time of transfer, a certificate of inspection or a certificate of compliance, as would have been required under section 3710 or 3711 of this title, had the transfer taken place in a port or place subject to the jurisdiction of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f76-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivering and the receiving vessel had on board at the time of transfer, a certificate of financial responsibility as would have been required under section 1016 of the Oil Pollution Act of 1990, had the transfer taken place in a place subject to the jurisdiction of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f77-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivering and the receiving vessel had on board at the time of transfer, evidence that each vessel is operating in compliance with section 311(j) of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321/j"},"text":"33 U.S.C. 1321(j)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f78-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the delivering and the receiving vessel are operating in compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s3703a"},"text":"section 3703a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66c2f79-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall prescribe regulations to carry out subsection (a) of this section. The regulations shall include provisions on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf66c2f7a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimum safe operating conditions, including sea state, wave height, weather, proximity to channels or shipping lanes, and other similar factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f7b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevention of spills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f7c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment for responding to a spill;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f7d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevention of any unreasonable interference with navigation or other reasonable uses of the high seas, as those uses are defined by treaty, convention, or customary international law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f7e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of lightering zones; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f7f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3715/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements for communication and prearrival messages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf66c2f80-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/526"},"text":"97 Stat. 526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV/s4115/d"},"text":"Pub. L. 101–380, title IV, § 4115(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/520"},"text":"104 Stat. 520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s306/a/4"},"text":"Pub. L. 114–120, title III, § 306(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/54"},"text":"130 Stat. 54","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf66c2f81-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf66c2f82-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf66c2f83-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3715","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(17)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3715 requires the Secretary to control lightering operations; that is, the transferring of cargoes at sea from large deep-draft vessels to shallow-draft vessels for subsequent transfer to shoreside terminals due to the inability of the larger tank vessels to enter shallow ports. It prohibits a tank vessel from unloading any cargo of oil or hazardous material at any port or terminal under the jurisdiction of the United States, unless the cargo has been transferred in accordance with lightering regulations. It also prohibits the shoreside transfer unless both the delivering and receiving vessels involved in the prior lightering had on board at the time of the offshore transfer, the certificates that would have been required had the transfer taken place in a port or place subject to the jurisdiction of the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The regulations to be prescribed by the Secretary shall include a number of specific considerations but may include any related matters deemed necessary to promote navigation and vessel safety and protection of the marine environment. The Secretary must consider standards for minimum safe operating conditions, including sea state, wave height, weather, vessel traffic, the prevention of oil spills, and oil spill response equipment. In regulating this operation, there must not be any unreasonable interference with international navigation or reasonable uses of the high seas, and there must be established lightering zones with attendant communications and prearrival message requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf66c2f84-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf66c2f85-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1016 of the Oil Pollution Act of 1990, referred to in subsec. (a)(3), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2716"},"text":"section 2716 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf66c2f86-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" added pars. (3) to (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf66c2f87-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf66c2f88-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" applicable to incidents occurring after "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/s1020"},"text":"section 1020 of Pub. L. 101–380","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf66c2f89-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89/s2/g/2"},"text":"Pub. L. 98–89, § 2(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/599"},"text":"97 Stat. 599","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/89/s2/g/2"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s3715/a"},"text":"Section 3715(a) of title 46","children":[],"tail":" (as enacted by section 1 of this Act) is effective on the day after the effective date of the regulations prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s3715/b"},"text":"section 3715(b) of title 46","children":[],"tail":".”"}],"tail":"\n [Regulations effective "},{"tag":"date","attrib":{"date":"1984-04-26"},"text":"Apr. 26, 1984","children":[],"tail":", see 49 F.R. 11170, "},{"tag":"date","attrib":{"date":"1984-03-26"},"text":"Mar. 26, 1984","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
