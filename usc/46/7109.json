{"tag":"section","attrib":{"id":"idf67a5fb7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7109"},"text":null,"children":[{"tag":"num","attrib":{"value":"7109"},"text":"§ 7109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of criminal records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may review the criminal record of each holder of a license or certificate of registry issued under this part who applies for renewal of that license or certificate of registry.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf67a5fb8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/540"},"text":"97 Stat. 540","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV/s4102/e/1"},"text":"Pub. L. 101–380, title IV, § 4102(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/510"},"text":"104 Stat. 510","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67a5fb9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf67a5fba-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf67a5fbb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr"