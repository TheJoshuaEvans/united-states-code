{"tag":"section","attrib":{"id":"idf6866ed9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9101"},"text":null,"children":[{"tag":"num","attrib":{"value":"9101"},"text":"§ 9101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for foreign tank vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6866eda-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6866edb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall evaluate the manning, training, qualification, and watchkeeping standards of a foreign country that issues documentation for any vessel to which chapter 37 of this title applies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6866edc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9101/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a periodic basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6866edd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9101/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the vessel is involved in a marine casualty required to be reported under section 6101(a)(4) or (5) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866ede-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After each evaluation made under paragraph (1) of this subsection, the Secretary shall determine whether—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6866edf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9101/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreign country has standards for licensing and certification of seamen that are at least equivalent to United States law or international standards accepted by the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6866ee0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9101/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those standards are being enforced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866ee1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary determines under this subsection that a country has failed to maintain or enforce standards at least equivalent to United States law or international standards accepted by the United States, the Secretary shall prohibit vessels issued documentation by that country from entering the United States until the Secretary determines those standards have been established and are being enforced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866ee2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9101/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may allow provisional entry of a vessel prohibited from entering the United States under paragraph (3) of this subsection if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6866ee3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9101/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner or operator of the vessel establishes, to the satisfaction of the Secretary, that the vessel is not unsafe or a threat to the marine environment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6866ee4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9101/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entry is necessary for the safety of the vessel or individuals on the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866ee5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A foreign vessel to which chapter 37 of this title applies that has on board oil or hazardous material in bulk as cargo or cargo residue shall have a specified number of personnel certified as tankerman or equivalent, as required by the Secretary, when the vessel transfers oil or hazardous material in a port or place subject to the jurisdiction of the United States. The requirement of this subsection shall be noted in applicable terminal operating procedures. A transfer operation may take place only if the crewmember in charge is capable of clearly understanding instructions in English.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6866ee6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/556"},"text":"97 Stat. 556","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV/s4106/a"},"text":"Pub. L. 101–380, title IV, § 4106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/513"},"text":"104 Stat. 513","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6866ee7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6866ee8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6866ee9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9101(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(11)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9101(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(10)(B)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 9101 requires monitoring of manning standards for foreign tank vessels operating on the navigable waters of the United States and transferring oil or hazardous material in the United States.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) requires the Secretary of Transportation to evaluate the manning, training, qualification, and watchkeeping standards of foreign countries whose tank vessels operate on United States waters, or use transfer facilities, and to decide if the standards are equivalent or more stringent than United States standards.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) authorizes the Secretary to specify the number of tankermen required on a foreign tank vessel and to have certified tankermen who can understand English when transferring oil or hazardous material in the United States. This requirement is to be made part of the terminal operating procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6866eea-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6866eeb-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “The Secretary shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) periodically evaluate the manning, training, qualification, and watchkeeping standards prescribed by the certificating country of a foreign vessel to which chapter 37 of this title applies, that operates on the navigable waters of the United States and transfers oil or hazardous material in a port or place under the jurisdiction of the United States; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) after each evaluation made under clause (1) of this subsection, decide whether the foreign country, whose system for licensing and certification of seamen was evaluated, has standards that are equivalent to or more stringent than United States standards or international standards accepted by the United States.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6866eec-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6866eed-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" applicable to incidents occurring after "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/s1020"},"text":"section 1020 of Pub. L. 101–380","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
