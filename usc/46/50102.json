{"tag":"section","attrib":{"id":"idf6b609ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50102"},"text":null,"children":[{"tag":"num","attrib":{"value":"50102"},"text":"§ 50102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey of merchant marine","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b609cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall survey the merchant marine of the United States to determine whether replacements and additions are required to carry out the objectives and policy of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50101"},"text":"section 50101 of this title","children":[],"tail":". The Secretary shall study, perfect, and adopt a long-range program for replacements and additions that will result, as soon as practicable, in—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b609d0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an adequate and well-balanced merchant fleet, including vessels of all types, that will provide shipping service essential for maintaining the flow of foreign commerce by vessels designed to be readily and quickly convertible into transport and supply vessels in a time of national emergency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b609d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ownership and operation of the fleet by citizens of the United States insofar as practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b609d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vessels designed to afford the best and most complete protection for passengers and crew against fire and all marine perils; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b609d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50102/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an efficient capacity for building and repairing vessels in the United States with an adequate number of skilled personnel to provide an adequate mobilization base.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b609d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation With Secretary of Navy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out subsection (a)(1), the Secretary of Transportation shall cooperate closely with the Secretary of the Navy as to national defense requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b609d5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1557"},"text":"120 Stat. 1557","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b609d6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b609d7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b609d8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","ch