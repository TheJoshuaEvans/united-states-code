{"tag":"section","attrib":{"id":"idf67cd086-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7313"},"text":null,"children":[{"tag":"num","attrib":{"value":"7313"},"text":"§ 7313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirements for members of engine departments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf67cd087-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Classes of endorsement as qualified members of the engine department on vessels of at least 100 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" (except vessels operating on rivers or lakes (except the Great Lakes)) may be prescribed by regulation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd088-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ratings of wiper are entry ratings and are not ratings as qualified members of the engine department.","children":[{"tag":"ref","attrib":{"idref":"fn002011"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002011"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd089-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Classification of Credentials","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may classify the merchant mariner credential issued under subsection (a) based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67cd08a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7313/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tonnage and means of propulsion of vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd08b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7313/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waters on which vessels are to be operated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd08c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7313/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd08d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7313/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To qualify for a credential under this section, an applicant shall provide satisfactory proof that the applicant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67cd08e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7313/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least 18 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd08f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7313/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a minimum of 6-months service in the related entry rating;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd090-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7313/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is qualified professionally as demonstrated by an applicable examination or educational requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd091-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7313/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is qualified as to sight, hearing, and physical condition to perform the member’s duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67cd092-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/544"},"text":"97 Stat. 544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s724"},"text":"Pub. L. 104–324, title VII, § 724","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3939"},"text":"110 Stat. 3939","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/d/5"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(d)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1754"},"text":"139 Stat. 1754","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67cd093-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf67cd094-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf67cd095-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7313","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:672(g)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7313(a) authorizes the Secretary to establish classes of endorsement for qualified members of the engine department on vessels of 100 gross tons or more (except on vessels operating on rivers and lakes (except the Great Lakes)).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) establishes the entry ratings of wiper and coal passer, but specifically excludes them as qualified members of the engine department.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) establishes the minimum qualifications individuals must meet in order to have their documents endorsed as a qualified member of engine department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf67cd096-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf67cd097-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/d/5/A"},"text":"Pub. L. 119–60, § 7301(d)(5)(A)","children":[],"tail":", struck out “and coal passer” after “wiper”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/d/5/B"},"text":"Pub. L. 119–60, § 7301(d)(5)(B)","children":[],"tail":", added subsecs. (c) and (d) and struck out former subsec. (c) which read as follows: “An applicant for an endorsement as qualified member of the engine department must provide satisfactory proof that the applicant—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) has the service required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7314"},"text":"section 7314 of this title","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) is qualified professionally as demonstrated by an applicable examination; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) is qualified as to sight, hearing, and physical condition to perform the member’s duties.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “100 gross tons”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
