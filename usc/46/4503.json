{"tag":"section","attrib":{"id":"idf6735b24-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503"},"text":null,"children":[{"tag":"num","attrib":{"value":"4503"},"text":"§ 4503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fishing, fish tender, and fish processing vessel certification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6735b25-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A vessel to which this subsection applies may not be operated unless the vessel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735b26-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets all survey and classification requirements prescribed by the American Bureau of Shipping or another similarly qualified organization approved by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b27-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has on board a certificate issued by the American Bureau of Shipping or that other organization evidencing compliance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735b28-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) applies to a fish processing vessel to which this chapter applies that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735b29-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is built after ","children":[{"tag":"date","attrib":{"date":"1990-07-27"},"text":"July 27, 1990","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b2a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undergoes a major conversion completed after that date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735b2b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735b2c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), subsection (a) applies to a vessel to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s4502/b"},"text":"section 4502(b) of this title","children":[],"tail":" applies that is at least 50 feet overall in length and is built after "},{"tag":"date","attrib":{"date":"2013-07-01"},"text":"July 1, 2013","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b2d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) does not apply to a fishing vessel or fish tender vessel to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s4502/b"},"text":"section 4502(b) of this title","children":[],"tail":" applies, if the vessel—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6735b2e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least 50 feet overall in length, and not more than 180 feet overall in length as listed on the vessel’s certificate of documentation or certificate of number; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735b2f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6735b30-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is built after the date of the enactment of the Coast Guard Authorization Act of 2016; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6735b31-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" complies with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6735b32-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements described in subsection (d); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6735b33-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alternative requirements established by the Secretary under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735b34-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The requirements referred to in subsection (c)(2)(B)(ii)(I) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735b35-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The vessel is designed by an individual licensed by a State as a naval architect or marine engineer, and the design incorporates standards equivalent to those prescribed by a classification society to which the Secretary has delegated authority under section 3316 or another qualified organization approved by the Secretary for purposes of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b36-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Construction of the vessel is overseen and certified as being in accordance with its design by a marine surveyor of an organization accepted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b37-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6735b38-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completes a stability test performed by a qualified individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735b39-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has written stability and loading instructions from a qualified individual that are provided to the owner or operator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735b3a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an assigned loading mark.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b3b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The vessel is not substantially altered without the review and approval of an individual licensed by a State as a naval architect or marine engineer before the beginning of such substantial alteration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b3c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The vessel undergoes a condition survey at least twice in 5 years, not to exceed 3 years between surveys, to the satisfaction of a marine surveyor of an organization accepted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b3d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The vessel undergoes an out-of-water survey at least once every 5 years to the satisfaction of a certified marine surveyor of an organization accepted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b3e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Once every 5 years and at the time of a substantial alteration to such vessel, compliance of the vessel with the requirements of paragraph (3) is reviewed and updated as necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b3f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the life of the vessel, the owner of the vessel maintains records to demonstrate compliance with this subsection and makes such records readily available for inspection by an official authorized to enforce this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735b40-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735b41-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 10 years after the date of the enactment of the Coast Guard Authorization Act of 2016, the Secretary shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a report that provides an analysis of the adequacy of the requirements under subsection (d) in maintaining the safety of the fishing vessels and fish tender vessels which are described in subsection (c)(2) and which comply with the requirements of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b42-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the report required under this subsection includes a determination that the safety requirements under subsection (d) are not adequate or that additional safety measures are necessary, then the Secretary may establish an alternative safety compliance program for fishing vessels or fish tender vessels (or both) which are described in subsection (c)(2) and which comply with the requirements of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b43-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The alternative safety compliance program established under this subsection shall include requirements for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6735b44-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vessel construction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735b45-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel stability test;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735b46-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vessel stability and loading instructions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735b47-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assigned vessel loading mark;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735b48-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel condition survey at least twice in 5 years, not to exceed 3 years between surveys;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735b49-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/e/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an out-of-water vessel survey at least once every 5 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735b4a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/e/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance of records to demonstrate compliance with the program, and the availability of such records for inspection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735b4b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/e/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other aspects of vessel safety as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735b4c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735b4d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section and section 4503a,","children":[{"tag":"ref","attrib":{"idref":"fn002005"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the term “built” means, with respect to a vessel, that the vessel’s construction has reached any of the following stages:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6735b4e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The vessel’s keel is laid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735b4f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Construction identifiable with the vessel has begun and assembly of that vessel has commenced comprising of at least 50 metric tons or one percent of the estimated mass of all structural material, whichever is less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b50-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4503/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a vessel greater than 79 feet overall in length, for purposes of paragraph (1)(A) a keel is deemed to be laid when a marine surveyor affirms that a structure adequate for serving as a keel for such vessel is in place and identified for use in the construction of such vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6735b51-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364/tIV/s402/7/C"},"text":"Pub. L. 98–364, title IV, § 402(7)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/447"},"text":"98 Stat. 447","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s33/b"},"text":"Pub. L. 98–557, § 33(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2876"},"text":"98 Stat. 2876","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/424/s2/a"},"text":"Pub. L. 100–424, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1587"},"text":"102 Stat. 1587","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVI/s604/e/1"},"text":"Pub. L. 111–281, title VI, § 604(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2966"},"text":"124 Stat. 2966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tIII/s305/c"},"text":"Pub. L. 112–213, title III, § 305(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1564"},"text":"126 Stat. 1564","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s318/a"},"text":"Pub. L. 114–120, title III, § 318(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/63"},"text":"130 Stat. 63","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3503/a"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3503(a)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2775"},"text":"130 Stat. 2775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tV"},"text":"Pub. L. 115–282, title V","children":[],"tail":", §§ 507, 508(a), (b), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4272"},"text":"132 Stat. 4272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11509/a/2"},"text":"Pub. L. 117–263, div. K, title CXV, § 11509(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4137"},"text":"136 Stat. 4137","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6735b52-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6735b53-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6735b54-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Coast Guard Authorization Act of 2016, referred to in subsecs. (c)(2)(B)(i) and (e)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4503a, referred to in subsec. (f)(1), was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11509/a/3"},"text":"Pub. L. 117–263, div. K, title CXV, § 11509(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4137"},"text":"136 Stat. 4137","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6735b55-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “Subsection (a)” for “Except as provided in section 4503a, subsection (a)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s508/b/2"},"text":"Pub. L. 115–282, § 508(b)(2)","children":[],"tail":", substituted “section 4503a” for “subsection (d)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s507/a"},"text":"Pub. L. 115–282, § 507(a)","children":[],"tail":", substituted “180” for “79”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B)(ii)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s508/b/3"},"text":"Pub. L. 115–282, § 508(b)(3)","children":[],"tail":", substituted “subsection (d)” for “subsection (e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B)(ii)(II). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s508/b/4"},"text":"Pub. L. 115–282, § 508(b)(4)","children":[],"tail":", substituted “subsection (e)” for “subsection (f)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s508/b/1"},"text":"Pub. L. 115–282, § 508(b)(1)","children":[],"tail":", redesignated subsec. (e) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s508/a"},"text":"Pub. L. 115–282, § 508(a)","children":[],"tail":", redesignated subsec. (d) as "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s4503a"},"text":"section 4503a of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s508/b/1"},"text":"Pub. L. 115–282, § 508(b)(1)","children":[],"tail":", redesignated subsec. (f) as (e). Former subsec. (e) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s508/b/5"},"text":"Pub. L. 115–282, § 508(b)(5)","children":[],"tail":", (6), substituted “subsection (d)” for “subsection (e)” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s508/b/1"},"text":"Pub. L. 115–282, § 508(b)(1)","children":[],"tail":", redesignated subsec. (g) as (f). Former subsec. (f) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s507/b"},"text":"Pub. L. 115–282, § 507(b)","children":[],"tail":", generally amended subsec. (f), as redesignated by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/s508/b/1"},"text":"Pub. L. 115–282, § 508(b)(1)","children":[],"tail":". Prior to amendment, subsec. (f) read as follows: “For the purposes of this section, the term ‘built’ means, with respect to a vessel, that the vessel’s construction has reached any of the following stages:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The vessel’s keel is laid.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Construction identifiable with the vessel has begun and assembly of that vessel has commenced comprising of at least 50 metric tons or one percent of the estimated mass of all structural material, whichever is less.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s508/b/1"},"text":"Pub. L. 115–282, § 508(b)(1)","children":[],"tail":", redesignated subsec. (g) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s318/a/1"},"text":"Pub. L. 114–120, § 318(a)(1)","children":[],"tail":", substituted “this subsection” for “this section” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s318/a/2"},"text":"Pub. L. 114–120, § 318(a)(2)","children":[],"tail":", substituted “Except as provided in subsection (d), subsection (a)” for “This section” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s318/a/3"},"text":"Pub. L. 114–120, § 318(a)(3)","children":[],"tail":", designated existing provisions as par. (1), substituted “Except as provided in paragraph (2), subsection (a)” for “This section”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3503/a"},"text":"Pub. L. 114–328, § 3503(a)","children":[],"tail":", substituted “Coast Guard Authorization Act of 2016” for “Coast Guard Authorization Act of 2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s318/a/4"},"text":"Pub. L. 114–120, § 318(a)(4)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s318/a/4"},"text":"Pub. L. 114–120, § 318(a)(4)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3503/a"},"text":"Pub. L. 114–328, § 3503(a)","children":[],"tail":", substituted “Coast Guard Authorization Act of 2016” for “Coast Guard Authorization Act of 2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3503/b/2"},"text":"Pub. L. 114–328, § 3503(b)(2)","children":[],"tail":", substituted “, then” for “, that”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s318/a/4"},"text":"Pub. L. 114–120, § 318(a)(4)","children":[],"tail":", redesignated subsec. (e) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/s305/c/1"},"text":"Pub. L. 112–213, § 305(c)(1)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2013-07-01"},"text":"July 1, 2013","children":[],"tail":".” for “"},{"tag":"date","attrib":{"date":"2012-07-01"},"text":"July 1, 2012","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/s305/c/2/A"},"text":"Pub. L. 112–213, § 305(c)(2)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2013-07-01"},"text":"July 1, 2013","children":[],"tail":";” for “"},{"tag":"date","attrib":{"date":"2012-07-01"},"text":"July 1, 2012","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/s305/c/2/B"},"text":"Pub. L. 112–213, § 305(c)(2)(B)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2013-07-01"},"text":"July 1, 2013","children":[],"tail":",” for “"},{"tag":"date","attrib":{"date":"2012-07-01"},"text":"July 1, 2012","children":[],"tail":",” in two places and substituted “major conversion” for “substantial change to the dimension of or type of vessel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/s305/c/3"},"text":"Pub. L. 112–213, § 305(c)(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s604/e/1/A"},"text":"Pub. L. 111–281, § 604(e)(1)(A)","children":[],"tail":", substituted “Fishing, fish tender, and fish processing vessel certification” for “Fish processing vessel certification” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s604/e/1/B"},"text":"Pub. L. 111–281, § 604(e)(1)(B)","children":[],"tail":", struck out “fish processing” before “vessel to which this section applies” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s604/e/1/C"},"text":"Pub. L. 111–281, § 604(e)(1)(C)","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/424"},"text":"Pub. L. 100–424","children":[],"tail":" amended section generally, substituting “Fish processing vessel certification” for “Equivalency” in section catchline, and provisions which require certification issued by American Bureau of Shipping or similar organization for fish processing vessel built after "},{"tag":"date","attrib":{"date":"1990-07-27"},"text":"July 27, 1990","children":[],"tail":", or undergoes major conversion completed after that date, for provisions which deemed compliance with this chapter if vessel has unexpired certificate of inspection issued by foreign country that is party to International Convention for Safety of Life at Sea to which United States is party."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" substituted “is deemed” for “shall be deemed”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6735b56-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6735b57-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effectiv