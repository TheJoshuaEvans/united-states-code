{"tag":"section","attrib":{"id":"idf6c1f13b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51315"},"text":null,"children":[{"tag":"num","attrib":{"value":"51315"},"text":"§ 51315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts to the Merchant Marine Academy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c1f13c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator may accept and use conditional or unconditional gifts of money or property for the benefit of the United States Merchant Marine Academy, including acceptance and use for non-appropriated fund instrumentalities of the Merchant Marine Academy. The Maritime Administrator may accept a gift of services in carrying out the Administrator’s duties and powers. Property accepted under this section and proceeds from that property must be used, as nearly as possible, in accordance with the terms of the gift.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f13d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Academy Gift Fund","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the Treasury a fund, to be known as the “Academy Gift Fund”. Disbursements from the Fund shall be made on order of the Maritime Administrator. Unless otherwise specified by the terms of the gift, the Maritime Administrator may use monies in the Fund for appropriated or non-appropriated purposes at the Academy. The Fund consists of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c1f13e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51315/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gifts of money;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f13f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51315/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income from donated property accepted under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f140-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51315/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceeds from the sale of donated property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f141-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51315/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income from securities under subsection (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f142-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51315/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investment of Fund Balances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On request of the Maritime Administrator, the Secretary of the Treasury may invest and reinvest amounts in the Fund in securities of, or in securities the principal and interest of which is guaranteed by, the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f143-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51315/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disbursement Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are hereby authorized to be disbursed from the Fund such sums as may be on deposit, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f144-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51315/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deductibility of Gifts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Gifts accepted under this section are a gift to or for the use of the Government under the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f145-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51315/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator may pay all necessary expenses in connection with the conveyance or transfer of a gift, devise, or bequest accepted under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c1f146-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/dC/tXXXV/s3506/g/1"},"text":"Pub. L. 110–417, div. C, title XXXV, § 3506(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4764"},"text":"122 Stat. 4764","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dC/tXXXV/s3511"},"text":"Pub. L. 115–91, div. C, title XXXV, § 3511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1918"},"text":"131 Stat. 1918","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c1f147-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6c1f148-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6c1f149-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (e), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6c1f14a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
