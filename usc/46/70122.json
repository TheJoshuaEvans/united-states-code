{"tag":"section","attrib":{"id":"idf7071079-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122"},"text":null,"children":[{"tag":"num","attrib":{"value":"70122"},"text":"§ 70122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waterway Watch Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf707107a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Established","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is hereby established, within the Coast Guard, the America’s Waterway Watch Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf707107b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall administer the Program in a manner that promotes voluntary reporting of activities that may indicate that a person or persons may be preparing to engage or engaging in a violation of law relating to a threat or an act of terrorism (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3077"},"text":"section 3077 of title 18","children":[],"tail":") against a vessel, facility, port, or waterway."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf707107c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information; Training.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf707107d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may establish, as an element of the Program, a network of individuals and community-based organizations that encourage the public and industry to recognize activities referred to in subsection (b), promote voluntary reporting of such activity, and enhance the situational awareness within the Nation’s ports and waterways. Such network shall, to the extent practicable, be conducted in cooperation with Federal, State, and local law enforcement agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf707107e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide training in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf707107f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" observing and reporting on covered activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7071080-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sharing such reports and coordinating the response by Federal, State, and local law enforcement agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7071081-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntary Participation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Participation in the Program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7071082-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be wholly voluntary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7071083-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be a prerequisite to eligibility for, or receipt of, any other service or assistance from, or to participation in, any other program of any kind; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7071084-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not require disclosure of information regarding the individual reporting covered activities or, for proprietary purposes, the location of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7071085-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall coordinate the Program with other like watch programs. The Secretary shall submit, concurrent with the President’s budget submission for each fiscal year, a report on coordination of the Program and like watch programs within the Department of Homeland Security to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Homeland Security of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7071086-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70122/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated for the purposes of this section $3,000,000 for each of fiscal years 2011 through 2016. Such funds shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf7071087-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVIII/s801/a"},"text":"Pub. L. 111–281, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2988"},"text":"124 Stat. 2988","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s306/a/11"},"text":"Pub. L. 114–120, title III, § 306(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/55"},"text":"130 Stat. 55","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf7071088-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf7071089-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf707108a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" substituted “Watch Program” for “watch program” in section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
