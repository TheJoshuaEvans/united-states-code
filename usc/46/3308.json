{"tag":"section","attrib":{"id":"idf662927f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3308"},"text":null,"children":[{"tag":"num","attrib":{"value":"3308"},"text":"§ 3308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In addition to inspections required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s3307"},"text":"section 3307 of this title","children":[],"tail":", the Secretary shall examine or have examined—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6629280-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3308/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each vessel subject to inspection at proper times to ensure compliance with law and regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6629281-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3308/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" crewmember accommodations on each vessel subject to inspection at least once a month or when the vessel enters United States ports to ensure that the accommodations are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6629282-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3308/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the size required by law and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6629283-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3308/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" properly ventilated and in a clean and sanitary condition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6629284-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3308/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipped with proper plumbing and mechanical appliances required by law and regulations, and the appliances are in good working condition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6629285-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/514"},"text":"97 Stat. 514","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVI/s603/c"},"text":"Pub. L. 104–324, title VI, § 603(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3930"},"text":"110 Stat. 3930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6629286-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6629287-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6629288-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text"