{"tag":"section","attrib":{"id":"idf6c1f150-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51317"},"text":null,"children":[{"tag":"num","attrib":{"value":"51317"},"text":"§ 51317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjunct professors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c1f151-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator may establish a program for the purpose of contracting with individuals as personal services contractors to provide services as adjunct professors at the Academy, if the Maritime Administrator determines that there is a need for adjunct professors and the need is not of permanent duration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f152-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each contract under the program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c1f153-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51317/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must be approved by the Maritime Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f154-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51317/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be for a duration, including options, of not to exceed one year unless the Maritime Administrator finds that exceptional circumstances justify an extension of up to one additional year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f155-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51317/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c1f156-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84/dC/tXXXV/s3503/a"},"text":"Pub. L. 111–84, div. C, title XXXV, § 3503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2719"},"text":"123 Stat. 2719","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dC/tXXXV/s3509"},"text":"Pub. L. 115–91, div. C, title XXXV, § 3509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1916"},"text":"131 Stat. 1916","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c1f157-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6c1f158-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6c1f159-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3509/1/A"},"text":"Pub. L. 115–91, § 3509(1)(A)","children":[],"tail":", struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3509/1/B"},"text":"Pub. L. 115–91, § 3509(1)(B)","children":[],"tail":", substituted “; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3509/2"},"text":"Pub. L. 115–91, § 3509(2)","children":[],"tail":", struck out subsecs. (c) and (d) which related to limitation on number of contractors and reporting requirements, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
