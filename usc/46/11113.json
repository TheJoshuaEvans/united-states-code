{"tag":"section","attrib":{"id":"idf68fe470-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113"},"text":null,"children":[{"tag":"num","attrib":{"value":"11113"},"text":"§ 11113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of abandoned seafarers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68fe471-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Abandoned Seafarers Fund.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68fe472-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Treasury a separate account to be known as the Abandoned Seafarers Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe473-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized uses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts in the Fund may be appropriated to the Secretary for use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68fe474-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to pay necessary support of a seafarer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf68fe475-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf68fe476-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was paroled into the United States under section 212(d)(5) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182/d/5"},"text":"8 U.S.C. 1182(d)(5)","children":[],"tail":"), or for whom the Secretary has requested parole under such section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf68fe477-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is involved in an investigation, reporting, documentation, or adjudication of any matter that is related to the administration or enforcement of law by the Coast Guard; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf68fe478-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf68fe479-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is physically present in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf68fe47a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines was abandoned in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf68fe47b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not applied for asylum under the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"8 U.S.C. 1101","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe47c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to reimburse a vessel owner or operator for the costs of necessary support of a seafarer who has been paroled into the United States to facilitate an investigation, reporting, documentation, or adjudication of any matter that is related to the administration or enforcement of law by the Coast Guard, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf68fe47d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel owner or operator is not convicted of a criminal offense related to such matter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf68fe47e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that reimbursement is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe47f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crediting of amounts to fund.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68fe480-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B), there shall be credited to the Fund the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf68fe481-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Penalties deposited in the Fund under section 9 of the Act to Prevent Pollution from Ships (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1908"},"text":"33 U.S.C. 1908","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf68fe482-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts reimbursed or recovered under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe483-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts may be credited to the Fund under subparagraph (A) only if the unobligated balance of the Fund is less than $5,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe484-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (5), on the date on which the President submits each budget for a fiscal year pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Secretary shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a report that describes—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68fe485-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts credited to the Fund under paragraph (3) for the preceding fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe486-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts in the Fund that were expended for the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe487-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No report required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A report under paragraph (4) shall not be required if there were no expenditures from the Fund in the preceding fiscal year. The Commandant shall notify Congress in the event a report is not required under paragraph (4) by reason of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe488-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68fe489-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create a private right of action or any other right, benefit, or entitlement to necessary support for any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe48a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to compel the Secretary to pay or reimburse the cost of necessary support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe48b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement; Recovery.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68fe48c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel owner or operator shall reimburse the Fund an amount equal to the total amount paid from the Fund for necessary support of a seafarer, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68fe48d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the vessel owner or operator—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf68fe48e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the course of an investigation, reporting, documentation, or adjudication of any matter that the Coast Guard referred to a United States attorney or the Attorney General, fails to provide necessary support of a seafarer who was paroled into the United States to facilitate the investigation, reporting, documentation, or adjudication; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf68fe48f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subsequently is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf68fe490-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convicted of a criminal offense related to such matter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf68fe491-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required to reimburse the Fund pursuant to a court order or negotiated settlement related to such matter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe492-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel owner or operator abandons a seafarer in the United States, as determined by the Secretary based on substantial evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe493-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a vessel owner or operator fails to reimburse the Fund under paragraph (1) within 60 days after receiving a written, itemized description of reimbursable expenses and a demand for payment, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68fe494-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceed in rem against the vessel on which the seafarer served in the Federal district court for the district in which the vessel is found; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe495-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withhold or revoke the clearance required under section 60105 for the vessel and any other vessel operated by the same operator (as that term is defined in section 2(a)(9)(A) ","children":[{"tag":"ref","attrib":{"idref":"fn002015"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002015"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “2(a)(9)(a)”."}],"tail":" of the Act to Prevent Pollution from Ships ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1901/a/9/A"},"text":"33 U.S.C. 1901(a)(9)(A)","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn002016"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002016"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “"},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1901/a/9/a"},"text":"33 U.S.C. 1901(a)(9)(a)","children":[],"tail":"))”."}],"tail":" as the vessel on which the seafarer served."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe496-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obtaining clearance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel may obtain clearance from the Secretary after it is withheld or revoked under paragraph (2)(B) if the vessel owner or operator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68fe497-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimburses the Fund the amount required under paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe498-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a bond, or other evidence of financial responsibility, sufficient to meet the amount required to be reimbursed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe499-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall notify the vessel at least 72 hours before taking any action under paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe49a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68fe49b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Abandons; abandoned","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each of the terms “abandons” and “abandoned” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68fe49c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel owner’s or operator’s unilateral severance of ties with a seafarer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe49d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel owner’s or operator’s failure to provide necessary support of a seafarer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe49e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Fund” means the Abandoned Seafarers Fund established under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe49f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Necessary support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “necessary support” means normal wages and expenses the Secretary considers reasonable for lodging, subsistence, clothing, medical care (including hospitalization), repatriation, and any other support the Secretary considers to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4a0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Seafarer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “seafarer” means an alien crew member who is employed or engaged in any capacity on board a vessel subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel subject to the jurisdiction of the united states","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “vessel subject to the jurisdiction of the United States” has the meaning given that term in section 70502(c), except that it does not include a vessel that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68fe4a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned, or operated under a bareboat charter, by the United States, a State or political subdivision thereof, or a foreign nation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe4a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11113/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not engaged in commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68fe4a4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIII/s320/a"},"text":"Pub. L. 113–281, title III, § 320(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3051"},"text":"128 Stat. 3051","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s306/a/7"},"text":"Pub. L. 114–120, title III, § 306(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/54"},"text":"130 Stat. 54","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3546/i"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3546(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2326"},"text":"132 Stat. 2326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8240(d), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4667"},"text":"134 Stat. 4667","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68fe4a5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68fe4a6-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf68fe4a7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Immigration and Nationality Act, referred to in subsec. (a)(2)(A)(ii)(III), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1952-06-27/ch477"},"text":"act June 27, 1952, ch. 477","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/163"},"text":"66 Stat. 163","children":[],"tail":", which is classified principally to chapter 12 (§ 1101 et seq.) of Title 8, Aliens and Nationality. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101"},"text":"section 1101 of Title 8","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68fe4a8-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/d/1"},"text":"Pub. L. 116–283, § 8240(d)(1)","children":[],"tail":", substituted “Except as provided in paragraph (5), on the date” for “On the date” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/d/2"},"text":"Pub. L. 116–283, § 8240(d)(2)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3546/i/1"},"text":"Pub. L. 115–232, § 3546(i)(1)","children":[],"tail":", substituted “paragraph (3)” for “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3546/i/2"},"text":"Pub. L. 115–232, § 3546(i)(2)","children":[],"tail":", substituted “section 2(a)(9)(A)” for “section 2(9)(a)” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1901/a/9/A"},"text":"33 U.S.C. 1901(a)(9)(A)","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t33/s1901/9/a"},"text":"33 U.S.C. 1901(9)(a)","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" struck out “under this Act” after “any matter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
