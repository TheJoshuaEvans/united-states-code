,"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6bac52b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inclusion of COVID–19 Pandemic Public Health Emergency","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dC/tXXXV/s3505/c"},"text":"Pub. L. 116–283, div. C, title XXXV, § 3505(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4405"},"text":"134 Stat. 4405","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dC/tXXXV/s3505/c"},"text":"“For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50308"},"text":"section 50308 of title 46","children":[],"tail":", United States Code, as added by subsection (a), the public health emergency declared pursuant to section 319 of the Public Health Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d"},"text":"42 U.S.C. 247d","children":[],"tail":") resulting from the COVID–19 pandemic shall be treated as an emergency.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
