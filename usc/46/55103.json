{"tag":"section","attrib":{"id":"idf6e5cbf4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55103"},"text":null,"children":[{"tag":"num","attrib":{"value":"55103"},"text":"§ 55103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of passengers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e5cbf5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this chapter or chapter 121 of this title, a vessel may not transport passengers between ports or places in the United States to which the coastwise laws apply, either directly or via a foreign port, unless the vessel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e5cbf6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is wholly owned by citizens of the United States for purposes of engaging in the coastwise trade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e5cbf7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been issued a certificate of documentation with a coastwise endorsement under chapter 121 or is exempt from documentation but would otherwise be eligible for such a certificate and endorsement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e5cbf8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The penalty for violating subsection (a) is $300 for each passenger transported and landed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e5cbf9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1633"},"text":"120 Stat. 1633","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e5cbfa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e5cbfb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e5cbfc-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:289.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1886-06-19/ch421/s8"},"text":"June 19, 1886, ch. 421, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/24/81"},"text":"24 Stat. 81","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1898-02-17/ch26/s2"},"text":"Feb. 17, 1898, ch. 26, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/30/248"},"text":"30 Stat. 248","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section is substituted for the source provision for consistency with section 55102. See 19 C.F.R. §§ 4.80, 4.80a (2004).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the penalty amount reflects the adjustment for inflation pursuant to the Federal Civil Penalties Inflation Adjustment Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2461"},"text":"28 U.S.C. 2461","children":[],"tail":" note). See 19 C.F.R. § 4.80(b)(2) (2004)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
