{"tag":"section","attrib":{"id":"idf67f4257-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7511"},"text":null,"children":[{"tag":"num","attrib":{"value":"7511"},"text":"§ 7511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Convicted sex offender as grounds for denial","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf67f4258-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sexual Abuse","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A license, certificate of registry, or merchant mariner’s document authorized to be issued under this part shall be denied to an individual who has been convicted of a sexual offense prohibited under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67f4259-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7511/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 109A of title 18, except for subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2244"},"text":"section 2244 of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67f425a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7511/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 920 or 920b of title 10 (article 120 and 120b of the Uniform Code of Military Justice); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67f425b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7511/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a substantially similar offense under Federal, State, local, or Tribal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67f425c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Abusive Sexual Contact","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A license, certificate of registry, or merchant mariner’s document authorized to be issued under this part may be denied to an individual who within 5 years before applying for the license, certificate, or document, has been convicted of a sexual offense prohibited under subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2244"},"text":"section 2244 of title 18","children":[],"tail":", or a substantially similar offense under State, local, or Tribal law."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67f425d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVI/s11602/a"},"text":"Pub. L. 117–263, div. K, title CXVI, § 11602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4147"},"text":"136 Stat. 4147","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/g/3"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1756"},"text":"139 Stat. 1756","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67f425e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf67f425f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf67f4260-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/3/A"},"text":"Pub. L. 119–60, § 7301(g)(3)(A)","children":[],"tail":", struck out “or” after “title 18;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/3/D"},"text":"Pub. L. 119–60, § 7301(g)(3)(D)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/3/B"},"text":"Pub. L. 119–60, § 7301(g)(3)(B)","children":[],"tail":", substituted “Federal, State, local, or Tribal law” for “State, local, or Tribal law”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/3/C"},"text":"Pub. L. 119–60, § 7301(g)(3)(C)","children":[],"tail":", redesignated par. (2) as (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
