{"tag":"section","attrib":{"id":"idf688b83f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307"},"text":null,"children":[{"tag":"num","attrib":{"value":"9307"},"text":"§ 9307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes Pilotage Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf688b840-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall establish a Great Lakes Pilotage Advisory Committee. The Committee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b841-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may review proposed Great Lakes pilotage regulations and policies and make recommendations to the Secretary that the Committee considers appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b842-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may advise, consult with, report to, and make recommendations to the Secretary on matters relating to Great Lakes pilotage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b843-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make available to the Congress recommendations that the Committee makes to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b844-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall meet at the call of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf688b845-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, who shall call such a meeting at least once during each calendar year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b846-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b847-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b848-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee shall consist of 8 members appointed by the Secretary in accordance with this subsection, each of whom has at least 5 years practical experience in maritime operations. The term of each member is for a period of not more than 5 years, specified by the Secretary. Before filling a position on the Committee, the Secretary shall publish a notice in the Federal Register soliciting nominations for membership on the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b849-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The membership of the Committee shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf688b84a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President of each of the 3 Great Lakes pilotage districts, or the President’s representative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b84b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member chosen from among nominations made by vessel operators that contract for Great Lakes pilotage services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b84c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member chosen from among nominations made by Great Lakes port authorities and marine terminals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b84d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member chosen from among nominations made by shippers whose cargoes are transported through Great Lakes ports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b84e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member chosen from among nominations made by Great Lakes maritime labor organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b84f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a member who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf688b850-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/b/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must have been recommended to the Secretary by a unanimous vote of the other members of the Committee, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf688b851-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/b/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be appointed without regard to requirement in paragraph (1) that each member have 5 years of practical experience in maritime operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b852-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b853-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Committee shall elect one of its members as the Chairman and one of its members as the Vice Chairman. The Vice Chairman shall act as Chairman in the absence or incapacity of the Chairman, or in the event of a vacancy in the office of the Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b854-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, and any other interested agency may, designate a representative to participate as an observer with the Committee. The Secretary’s designated representative shall act as the executive secretary of the Committee and shall perform the duties set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1009/c"},"text":"section 1009(c) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b855-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b856-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, whenever practicable, consult with the Committee before taking any significant action relating to Great Lakes pilotage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b857-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall consider the information, advice, and recommendations of the Committee in formulating policy regarding matters affecting Great Lakes pilotage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b858-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any recommendations to the Secretary under subsection (a)(2) must have been approved by at least all but one of the members then serving on the committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b859-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b85a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the Committee, when attending meetings of the Committee or when otherwise engaged in the business of the Committee, is entitled to receive—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf688b85b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation at a rate fixed by the Secretary, not exceeding the daily equivalent of the current rate of basic pay in effect for GS–18 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" including travel time; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b85c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel or transportation expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b85d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Committee shall not be considered to be an officer or employee of the United States for any purpose based on their receipt of any payment under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b85e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b85f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 10 of title 5 applies to the Committee, except that the Committee terminates on ","children":[{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b860-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9307/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 years before the termination date set forth in paragraph (1) of this subsection, the Committee shall submit to the Congress its recommendation regarding whether the Committee should be renewed and continued beyond the termination date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf688b861-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/559"},"text":"97 Stat. 559","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIII/s303"},"text":"Pub. L. 105–383, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3418"},"text":"112 Stat. 3418","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dA/s1118"},"text":"Pub. L. 106–554, § 1(a)(4) [div. A, § 1118]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–209; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tIV/s418/d"},"text":"Pub. L. 108–293, title IV, § 418(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1049"},"text":"118 Stat. 1049","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/23"},"text":"Pub. L. 109–304, § 15(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1704"},"text":"120 Stat. 1704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVI/s621/a"},"text":"Pub. L. 111–281, title VI, § 621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2976"},"text":"124 Stat. 2976","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8334(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4705"},"text":"134 Stat. 4705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/291"},"text":"Pub. L. 117–286, § 4(a)(291)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4337"},"text":"136 Stat. 4337","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf688b862-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf688b863-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf688b864-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9307","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:216h","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 9307 permits the Secretary to establish a Great Lakes Pilotage Advisory Committee. This Committee is to be established consistent with the Federal Advisory Committee Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"P.L. 92–463","children":[],"tail":"; 5 App. U.S.C.) and with the requirements imposed by section 19 [118(e)] of "},{"tag":"ref","attrib":{"href":"/us/pl/97/322"},"text":"P.L. 97–322","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t14/s631"},"text":"14 U.S.C. 631","children":[],"tail":" note)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) authorizes the Committee to review and make recommendations on Great Lakes pilotage regulation and policies and to make the recommendations available to Congress and requires the Committee to meet at the call of the Secretary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) establishes the membership of the Committee as 3 members with 5 years of practical maritime experience appointed by the Secretary for a term of not more than 5 years. A Federal Register notice of solicitation for membership nominations for filling a position is required.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) provides for pay and travel expenses, including per diem, for the members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf688b865-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf688b866-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/291/A"},"text":"Pub. L. 117–286, § 4(a)(291)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1009/c"},"text":"section 1009(c) of title 5","children":[],"tail":".” for “section 10(c) of the Federal Advisory Committee Act (5 U.S.C. App.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/291/B"},"text":"Pub. L. 117–286, § 4(a)(291)(B)","children":[],"tail":", substituted “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8334/a/1/A"},"text":"Pub. L. 116–283, § 8334(a)(1)(A)","children":[],"tail":", substituted “8 members” for “seven members”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8334/a/1/B/i"},"text":"Pub. L. 116–283, § 8334(a)(1)(B)(i)","children":[],"tail":", substituted “chosen from among nominations made by” for “representing the interests of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8334/a/1/B/ii"},"text":"Pub. L. 116–283, § 8334(a)(1)(B)(ii)","children":[],"tail":", substituted “chosen from among nominations made by Great Lakes port authorities and marine terminals” for “representing the interests of Great Lakes ports”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8334/a/1/B/iii/I"},"text":"Pub. L. 116–283, § 8334(a)(1)(B)(iii)(I)","children":[],"tail":", substituted “chosen from among nominations made by” for “representing the interests of” and “ports;” for “ports; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8334/a/1/B/v"},"text":"Pub. L. 116–283, § 8334(a)(1)(B)(v)","children":[],"tail":", added subpar. (E). Former subpar. (E) redesignated (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8334/a/1/B/iv"},"text":"Pub. L. 116–283, § 8334(a)(1)(B)(iv)","children":[],"tail":", (vi), redesignated subpar. (E) as (F) and struck out “with a background in finance or accounting,” after “a member” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8334/a/2"},"text":"Pub. L. 116–283, § 8334(a)(2)","children":[],"tail":", substituted “2030” for “2020”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"September 30, 2010","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" substituted “the President” for “The President”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"September 30, 2010","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2005-09-30"},"text":"September 30, 2005","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dA/s1118/1"},"text":"Pub. L. 106–554, § 1(a)(4) [div. A, § 1118(1)]","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “three members who are practicing Great Lakes pilots and who reflect a regional balance;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dA/s1118/2"},"text":"Pub. L. 106–554, § 1(a)(4) [div. A, § 1118(2)]","children":[],"tail":", amended subpar. (E) generally. Prior to amendment, subpar. (E) read as follows: “one member representing the interests of the general public, who is an independent expert on the Great Lakes maritime industry.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dA/s1118/3"},"text":"Pub. L. 106–554, § 1(a)(4) [div. A, § 1118(3)]","children":[],"tail":", which directed the striking out of second sentence in subsec. (C)(2), was executed by striking out the second sentence in subsec. (c)(2), “The representatives shall, as appropriate, report to and advise the Committee on matters relating to Great Lakes pilotage.”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dA/s1118/4"},"text":"Pub. L. 106–554, § 1(a)(4) [div. A, § 1118(4)]","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dA/s1118/5"},"text":"Pub. L. 106–554, § 1(a)(4) [div. A, § 1118(5)]","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2005-09-30"},"text":"September 30, 2005","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"September 30, 2003","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383"},"text":"Pub. L. 105–383","children":[],"tail":" amended section generally, substituting provisions consisting of subsecs. (a) to (f) for former provisions consisting of subsecs. (a) to (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf688b867-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf688b868-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8334(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4706"},"text":"134 Stat. 4706","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dG/tLVXXXIII"},"text":"“Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s9307/f/1"},"text":"section 9307(f)(1) of title 46","children":[],"tail":", United States Code, in any case in which the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"] occurs after "},{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":", the Great Lakes Pilotage Advisory Committee in existence as of "},{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":", shall be deemed not expired during the period beginning on "},{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":" through the date of enactment of this Act. Accordingly, the committee membership, charter, and the activities of such Committee shall continue as though such Committee had not expired.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf688b869-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
