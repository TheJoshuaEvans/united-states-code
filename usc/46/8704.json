{"tag":"section","attrib":{"id":"idf6866e90-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8704"},"text":null,"children":[{"tag":"num","attrib":{"value":"8704"},"text":"§ 8704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alien deemed to be employed in the United States","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An alien is deemed to be employed in the United States for purposes of section 274A of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324a"},"text":"8 U.S.C. 1324a","children":[],"tail":") if the alien is an unlicensed individual employed on a fishing, fish processing, or fish tender vessel that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6866e91-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8704/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a vessel of the United States engaged in the fisheries in the navigable waters of the United States or the exclusive economic zone; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e92-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8704/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not engaged in fishing exclusively for highly migratory species (as that term is defined in section 3 of the Magnuson-Stevens Fishery Conservation and Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1802"},"text":"16 U.S.C. 1802","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6866e93-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/239/s5/f/1"},"text":"Pub. L. 100–239, § 5(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-11"},"text":"