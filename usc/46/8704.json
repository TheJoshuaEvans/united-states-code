":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tII/s211/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title II, § 211(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–41, provided that the amendment made by that section is effective 15 days after "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6866e99-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/239/s5/f/3"},"text":"Pub. L. 100–239, § 5(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-11"},"text":"Jan. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1781"},"text":"101 Stat. 1781","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/239/s5/f/3"},"text":"“With respect to an alien who is deemed to be employed in the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s8704"},"text":"section 8704 of title 46","children":[],"tail":", United States Code (as amended by this subsection), the term ‘date of the enactment of this section’ [translated as “"},{"tag":"date","attrib":{"date":"1986-11-06"},"text":"November 6, 1986","children":[],"tail":"”] as used in section 274A(i) of the Immigration and Nationality Act [former "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1324a/i"},"text":"8 U.S.C. 1324a(i)","children":[],"tail":"] means the date 180 days after the enactment of this section ["},{"tag":"date","attrib":{"date":"1988-01-11"},"text":"Jan. 11, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
