{"tag":"section","attrib":{"id":"idf67f42a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7703"},"text":null,"children":[{"tag":"num","attrib":{"value":"7703"},"text":"§ 7703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bases for suspension or revocation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A license, certificate of registry, or merchant mariner’s document issued by the Secretary may be suspended or revoked if the holder—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67f42a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7703/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" when acting under the authority of that license, certificate, or document—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf67f42a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7703/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has violated or fails to comply with this subtitle, a regulation prescribed under this subtitle, or any other law or regulation intended to promote marine safety or to protect navigable waters; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67f42a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7703/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has committed an act of misconduct or negligence;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67f42a5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7703/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is convicted of an offense that would prevent the issuance or renewal of a license, certificate of registry, or merchant mariner’s document;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67f42a6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7703/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the 3-year period preceding the initiation of the suspension or revocation proceeding is convicted of an offense described in section 30304(a)(3)(A) or (B) of title 49;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67f42a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7703/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has committed an act of incompetence relating to the operation of a vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67f42a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7703/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a security risk that poses a threat to the safety or security of a vessel or a public or commercial structure located within or adjacent to the marine environment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67f42a9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/546"},"text":"97 Stat. 546","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/36/s1/a/9/E"},"text":"Pub. L. 99–36, § 1(a)(9)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-05-15"},"text":"May 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/68"},"text":"99 Stat. 68","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV/s4103/b"},"text":"Pub. L. 101–380, title IV, § 4103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/511"},"text":"104 Stat. 511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tIV/s408"},"text":"Pub. L. 108–293, title IV, § 408","children":[],"tail":", title VI, § 609(3), "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1044"},"text":"118 Stat. 1044","children":[],"tail":", 1058; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIX/s901/h/3"},"text":"Pub. L. 109–241, title IX, § 901(h)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/564"},"text":"120 Stat. 564","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67f42aa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf67f42ab-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf67f42ac-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7703","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:226","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:239","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:240","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:246(c)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section provides the bases for suspension and revocation of a license, certificate or document. The individual must have been operating under the authority of the required license, certificate, or document and has violated a law or regulation intended to promote marine safety or to protect the navigable waters or has committed an act of incompetence, misconduct, or negligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf67f42ad-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf67f42ae-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" struck out “("},{"tag":"ref","attrib":{"href":"/us/usc/t23/s401"},"text":"23 U.S.C. 401","children":[],"tail":" note)” after “of title 49”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s408/1"},"text":"Pub. L. 108–293, § 408(1)","children":[],"tail":", substituted “misconduct or” for “incompetence, misconduct, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s609/3"},"text":"Pub. L. 108–293, § 609(3)","children":[],"tail":", substituted “section 30304(a)(3)(A) or (B) of title 49” for “section 205(a)(3)(A) or (B) of the National Driver Register Act of 1982”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s408/2"},"text":"Pub. L. 108–293, § 408(2)","children":[],"tail":"–(4), added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “A license, certificate of registry, or merchant mariner’s document issued by the Secretary may be suspended or revoked if, when acting under the authority of that license, certificate, or document, the holder—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) has violated or failed to comply with this subtitle, a regulation prescribed under this subtitle, or any other law or regulation intended to promote marine safety or to protect navigable waters.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) has committed an act of incompetence, misconduct, or negligence.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/36"},"text":"Pub. L. 99–36","children":[],"tail":" substituted “certificate of registry,” for first reference to “certificate,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf67f42af-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf67f42b0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" applicable to incidents occurring after "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/s1020"},"text":"section 1020 of Pub. L. 101–380","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
