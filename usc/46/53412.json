{"tag":"section","attrib":{"id":"idf6d5040e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53412"},"text":null,"children":[{"tag":"num","attrib":{"value":"53412"},"text":"§ 53412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of Fleet vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d5040f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon replacement of a Fleet vessel under an operating agreement under this chapter, and subject to agreement by the program participant of the vessel, the Secretary of Transportation is authorized, subject to the concurrence of the Secretary of Defense, acquire the vessel being replaced for inclusion in the National Defense Reserve Fleet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d77410-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for acquisition by the Secretary of Transportation under this section a vessel shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d77411-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53412/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been covered by an operating agreement under this chapter for not less than 3 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d77412-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53412/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet recapitalization requirements for the Ready Reserve Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d77413-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fair Market Value","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fair market value shall be established by the Maritime Administration for acquisition of an eligible vessel under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d77414-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53412/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Vessel acquisitions under this section shall be subject to the availability of appropriations. Amounts made available to carry out this section shall be derived from amounts authorized to be appropriated for the National Defense Reserve Fleet. Amounts authorized to be appropriated to carry out the Maritime Security Program may not be use to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d77415-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dC/tXXXV/s3511/a"},"text":"Pub. L. 116–283, div. C, title XXXV, § 3511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4418"},"text":"134 Stat. 4418","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
