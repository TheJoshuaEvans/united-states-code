{"tag":"section","attrib":{"id":"idf65b660e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202"},"text":null,"children":[{"tag":"num","attrib":{"value":"3202"},"text":"§ 3202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf65b660f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Voyages and Foreign Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter applies to a vessel that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf65b6610-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf65b6611-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is transporting more than 12 passengers described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101/31/A"},"text":"section 2101(31)(A) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf65b6612-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of at least 500 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" and is a tanker, freight vessel, bulk freight vessel, high speed freight vessel, or self-propelled mobile offshore drilling unit; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b6613-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf65b6614-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged on a foreign voyage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf65b6615-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a foreign vessel departing from a place under the jurisdiction of the United States on a voyage, any part of which is on the high seas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65b6616-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Passenger Vessels.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf65b6617-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter applies to a vessel that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf65b6618-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a passenger vessel or small passenger vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf65b6619-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is transporting more passengers than a number prescribed by the Secretary based on the number of individuals on the vessel that could be killed or injured in a marine casualty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b661a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety management system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision in this chapter, including paragraph (1)(B), any regulations under section 3203, including the safety management system established by such regulations, issued on or after the date of enactment of the Elijah E. Cummings Coast Guard Authorization Act of 2020, shall apply to all covered small passenger vessels, as defined in section 3306(n)(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65b661b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntary Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter applies to a vessel not described in subsection (a) of this section if the owner of the vessel requests the Secretary to apply this chapter to the vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65b661c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c) of this section, this chapter does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf65b661d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a barge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b661e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recreational vessel not engaged in commercial service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b661f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fishing vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b6620-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel operating on the Great Lakes or its tributary and connecting waters that is not described in subsection (b) of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b6621-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3202/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf65b6622-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVI/s602/a"},"text":"Pub. L. 104–324, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3928"},"text":"110 Stat. 3928","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tIV/s405/a"},"text":"Pub. L. 108–293, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1043"},"text":"118 Stat. 1043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVI/s610/a"},"text":"Pub. L. 111–281, title VI, § 610(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2969"},"text":"124 Stat. 2969","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3541/b/8"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3541(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2323"},"text":"132 Stat. 2323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIV"},"text":"Pub. L. 116–283, div. G, title LVXXXIV","children":[],"tail":" [LXXXIV], § 8441(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4744"},"text":"134 Stat. 4744","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/k/1/C"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(k)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1759"},"text":"139 Stat. 1759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf65b6623-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf65b6624-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf65b6625-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Elijah E. Cummings Coast Guard Authorization Act of 2020, referred to in subsec. (b)(2), is the date of enactment of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf65b6626-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “section 2101(31)(A)” for “section 2101(29)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" designated existing provisions as par. (1) and inserted heading, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1) and realigned margins, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 2101(29)(A)” for “section 2101(21)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s610/a/1"},"text":"Pub. L. 111–281, § 610(a)(1)","children":[],"tail":", substituted “"},{"tag":"inline","attrib":{},"text":"Foreign Voyages and Foreign Vessels","children":[],"tail":".—” for “"},{"tag":"inline","attrib":{},"text":"Mandatory Application","children":[],"tail":".—” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s610/a/2"},"text":"Pub. L. 111–281, § 610(a)(2)","children":[],"tail":"–(4), added subsec. (b), redesignated former subsecs. (b) and (c) as (c) and (d), respectively, and, in introductory provisions of subsec. (d), substituted “subsection (c)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s610/a/5"},"text":"Pub. L. 111–281, § 610(a)(5)","children":[],"tail":", inserted “that is not described in subsection (b) of this section” after “connecting waters”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “This chapter applies to the following vessels engaged on a foreign voyage:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Beginning ","children":[{"tag":"date","attrib":{"date":"1998-07-01"},"text":"July 1, 1998","children":[],"tail":"—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) a vessel transporting more than 12 passengers described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101/21/A"},"text":"section 2101(21)(A) of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) a tanker, bulk freight vessel, or high-speed freight vessel, of at least 500 gross tons.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Beginning ","children":[{"tag":"date","attrib":{"date":"2002-07-01"},"text":"July 1, 2002","children":[],"tail":", a freight vessel and a self-propelled mobile offshore drilling unit of at least 500 gross tons.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
