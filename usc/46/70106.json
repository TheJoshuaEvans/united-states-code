{"tag":"section","attrib":{"id":"idf704c60c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106"},"text":null,"children":[{"tag":"num","attrib":{"value":"70106"},"text":"§ 70106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deployable, specialized forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf704c60d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf704c60e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To enhance the domestic maritime security capability of the United States, the Secretary shall establish deployable specialized forces of varying capabilities as are needed to safeguard the public and protect vessels, harbors, ports, facilities, and cargo in waters subject to the jurisdiction of the United States from destruction, loss or injury from crime, or sabotage due to terrorist activity, and to respond to such activity in accordance with the transportation security plans developed under section 70103.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c60f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enhanced teams","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Such specialized forces shall include no less than two enhanced teams to serve as deployable forces capable of combating terrorism, engaging in interdiction, law enforcement, and advanced tactical maritime security operations to address known or potentially armed security threats (including non-compliant actors at sea), and participating in homeland security, homeland defense, and counterterrorism exercises in the maritime environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c610-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mission","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The combined force of the specialized forces established under subsection (a) shall be trained, equipped, and capable of being deployed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf704c611-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deter, protect against, and rapidly respond to threats of maritime terrorism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c612-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct maritime operations to protect against and disrupt illegal use, access to, or proliferation of weapons of mass destruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c613-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforce moving or fixed safety or security zones established pursuant to law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c614-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct high speed intercepts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c615-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" board, search, and seize any article or thing on or at, respectively, a vessel or facility found to present a risk to the vessel or facility, or to a port;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c616-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rapidly deploy to supplement United States armed forces domestically or overseas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c617-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond to criminal or terrorist acts so as to minimize, insofar as possible, the disruption caused by such acts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c618-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist with facility vulnerability assessments required under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c619-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out any other missions of the Coast Guard as are assigned to it by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c61a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimization of Response Times","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The enhanced teams established under subsection (a)(2) shall, to the extent practicable, be stationed in such a way so as to minimize the response time to maritime terrorist threats and potential or actual transportation security incidents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c61b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Other Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the maximum extent feasible, the combined force of the specialized forces established under subsection (a) shall coordinate their activities with other Federal, State, and local law enforcement and emergency response agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf704c61c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s102/a"},"text":"Pub. L. 107–295, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2074"},"text":"116 Stat. 2074","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIII/s305"},"text":"Pub. L. 109–241, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/528"},"text":"120 Stat. 528","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVIII/s804/a"},"text":"Pub. L. 111–281, title VIII, § 804(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2990"},"text":"124 Stat. 2990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf704c61d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf704c61e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf704c61f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" amended section generally. Prior to amendment, section related to maritime safety and security teams."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" substituted “any other missions of the Coast Guard” for “other security missions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf704c620-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf704c621-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Coast Guard Detection Canine Team Program Expansion","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVIII/s805"},"text":"Pub. L. 111–281, title VIII, § 805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2991"},"text":"124 Stat. 2991","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/281/tVIII/s805"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Canine detection team","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘detection canine team’ means a canine and a canine handler that are trained to detect narcotics or explosives, or other threats as defined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detection Canine Teams.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Increased capacity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":"], and subject to the availability of appropriations, the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begin to increase the number of detection canine teams certified by the Coast Guard for the purposes of maritime-related security by no fewer than 10 canine teams annually through fiscal year 2012; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage owners and operators of port facilities, passenger cruise liners, oceangoing cargo vessels, and other vessels identified by the Secretary to strengthen security through the use of highly trained detection canine teams.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Canine procurement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, acting through the Commandant of the Coast Guard, shall procure detection canine teams as efficiently as possible, including, to the greatest extent possible, through increased domestic breeding, while meeting the performance needs and criteria established by the Commandant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deployment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prioritize deployment of the additional canine teams to ports based on risk, consistent with the Security and Accountability For Every Port Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347"},"text":"Public Law 109–347","children":[],"tail":") [see Tables for classification].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
