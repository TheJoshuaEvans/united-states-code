)(2)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3523/a/1"},"text":"Pub. L. 110–181, § 3523(a)(1)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/g/2"},"text":"Pub. L. 109–163, § 515(g)(2)","children":[],"tail":", into this section by substituting “Navy Reserve” for “Naval Reserve” wherever appearing in section catchline and text. See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s515/g/2"},"text":"Pub. L. 109–163, § 515(g)(2)","children":[],"tail":", which directed the amendment of section 1295b of the former Appendix to this title from which this section was derived, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3523/b"},"text":"Pub. L. 110–181, § 3523(b)","children":[],"tail":". See 2008 Amendment note for subsecs. (a), (b)(1), (2) and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
