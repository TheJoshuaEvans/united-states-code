{"tag":"section","attrib":{"id":"idf6c1f0c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51311"},"text":null,"children":[{"tag":"num","attrib":{"value":"51311"},"text":"§ 51311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Midshipman status in the Navy Reserve","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c1f0c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before being appointed as a cadet at the United States Merchant Marine Academy, a citizen of the United States must agree to apply for midshipman status in the Navy Reserve (including the Merchant Marine Reserve, Navy Reserve).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f0ca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c1f0cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A citizen of the United States appointed as a cadet at the Academy shall be appointed by the Secretary of the Navy as a midshipman in the Navy Reserve (including the Merchant Marine Reserve, Navy Reserve).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f0cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rights and privileges","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy shall provide for cadets of the Academy who are midshipmen in the United States Navy Reserve to be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c1f0cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51311/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued an identification card (referred to as a “military ID card”); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51311/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entitled to all rights and privileges in accordance with the same eligibility criteria as apply to other members of the Ready Reserve of the reserve components of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f0cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51311/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Navy shall carry out paragraphs (1) and (2) in coordination with the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c1f0d0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1575"},"text":"120 Stat. 1575","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tV/s515/g/2"},"text":"Pub. L. 109–163, div. A, title V, § 515(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3236"},"text":"119 Stat. 3236","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3523/a/1"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3523(a)(1)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":", 600.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c1f0d1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6c1f0d2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6c1f0d3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"