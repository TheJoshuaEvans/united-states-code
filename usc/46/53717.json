ag":"html:span","attrib":{},"text":"June 25, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/231"},"text":"72 Stat. 231","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/137"},"text":"Pub. L. 97–31, § 12(137)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/166"},"text":"95 Stat. 166","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Ship Financing Fund which had been created by 46 App. U.S.C. 1272 is obsolete as a result of the Federal Credit Reform Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661"},"text":"2 U.S.C. 661","children":[],"tail":" et seq.). This section codifies the current requirements and practices for the management of funds under this chapter, based on the requirements of that Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6dea0be-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6dea0bf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Credit Reform Act of 1990, referred to in subsec. (a), is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text":"Pub. L. 93–344","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXIII/s13201/a"},"text":"Pub. L. 101–508, title XIII, § 13201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-609"},"text":"104 Stat. 1388–609","children":[],"tail":", which is classified generally to subchapter III (§ 661 et seq.) of chapter 17A of Title 2, The Congress. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6dea0c0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/B"},"text":"Pub. L. 109–163, § 3507(a)(1)(B)","children":[],"tail":", (D), (c)(2). See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/a/9/B"},"text":"Pub. L. 110–181, § 3522(a)(9)(B)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/B"},"text":"Pub. L. 109–163, § 3507(a)(1)(B)","children":[],"tail":", (D), (c)(2), into this section by substituting “Administrator” for “Secretary of Transportation” wherever appearing in heading and text. See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/a/7"},"text":"Pub. L. 110–181, § 3522(a)(7)","children":[],"tail":", struck out “of Commerce” after “Secretary” wherever appearing in headings and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/B"},"text":"Pub. L. 109–163, § 3507(a)(1)(B)","children":[],"tail":", (D), (c)(2), which directed the amendment of sections 1272, 1274(g), and 1280 of the former Appendix to this title from which this section was derived, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":". See 2008 Amendment note for subsec. (b) and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
