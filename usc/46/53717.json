{"tag":"section","attrib":{"id":"idf6dea0b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53717"},"text":null,"children":[{"tag":"num","attrib":{"value":"53717"},"text":"§ 53717.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of funds in the Treasury","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6dea0b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53717/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “FCRA” means the Federal Credit Reform Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661"},"text":"2 U.S.C. 661","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea0b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53717/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loan Guarantees by Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dea0b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53717/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When not subject to fcra","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall account for payments and disbursements involving obligations guaranteed under this chapter and not subject to FCRA in an account in the Treasury entitled the Federal Ship Financing Fund Liquidating Account (a liquidating account as defined in FCRA).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea0b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53717/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When subject to fcra","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall account for payments and disbursements involving obligations guaranteed under this chapter and subject to FCRA in a separate account in the Treasury entitled the Federal Ship Financing Guaranteed Loan Financing Account (a financing account as defined in FCRA).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea0b6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53717/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loan Guarantees by Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dea0b7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53717/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When not subject to fcra","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall account for payments and disbursements involving obligations guaranteed under this chapter and not subject to FCRA in a separate account in the Treasury established for this purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea0b8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53717/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When subject to fcra","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall account for payments and disbursements involving obligations guaranteed under this chapter and subject to FCRA in a separate account in the Treasury established for this purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea0b9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53717/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Direct Loans by Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall account for payments and disbursements involving direct loans made under this chapter in a separate account in the Treasury established for this purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6dea0ba-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1616"},"text":"120 Stat. 1616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/B"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(B)","children":[],"tail":", (D), (c)(2), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":", 3556; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/7"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(7)","children":