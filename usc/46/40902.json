{"tag":"section","attrib":{"id":"idf6aeddd1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40902"},"text":null,"children":[{"tag":"num","attrib":{"value":"40902"},"text":"§ 40902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial responsibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6aeddd2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not advertise, hold oneself out, or act as an ocean transportation intermediary unless the person furnishes a bond, proof of insurance, or other surety—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aeddd3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40902/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a form and amount determined by the Federal Maritime Commission to insure financial responsibility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aeddd4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40902/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued by a surety company found acceptable by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aeddd5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of Financial Responsibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A bond, insurance, or other surety obtained under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aeddd6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be available to pay any penalty assessed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s41109"},"text":"section 41109 of this title","children":[],"tail":" or any order for reparation issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s41305"},"text":"section 41305 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aeddd7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be available to pay any claim against an ocean transportation intermediary arising from its transportation-related activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6aeddd8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40902/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the consent of the insured ocean transportation intermediary and subject to review by the surety company; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aeddd9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40902/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the claim is deemed valid by the surety company after the ocean transportation intermediary has failed to respond to adequate notice to address the validity of the claim; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aeddda-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40902/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be available to pay any judgment for damages against an ocean transportation intermediary arising from its transportation-related activities, if the claimant has first attempted to resolve the claim under paragraph (2) and the claim has not been resolved within a reasonable period of time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedddb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations on Court Judgments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall prescribe regulations for the purpose of protecting the interests of claimants, ocean transportation intermediaries, and surety companies with respect to the process of pursuing claims against ocean transportation intermediary bonds, insurance, or sureties through court judgments. The regulations shall provide that a judgment for monetary damages may not be enforced except to the extent that the damages claimed arise from the transportation-related activities of the insured ocean transportation intermediary, as defined by the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedddc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40902/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resident Agent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An ocean transportation intermediary not domiciled in the United States shall designate a resident agent in the United States for receipt of service of judicial and administrative process, including subpoenas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6aedddd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1538"},"text":"120 Stat. 1538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVII/s707/c"},"text":"Pub. L. 115–282, title VII, § 707(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4295"},"text":"132 Stat. 4295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6aeddde-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6aedddf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6aedde0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40902","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1718(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/98/237/s19/b"},"text":"Pub. L. 98–237, § 19(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 20, 1984","children":[],"tail":"; added "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tI/s116/4"},"text":"Pub. L. 105–258, title I, § 116(4)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1913"},"text":"112 Stat. 1913","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), in paragraphs (2) and (3), the words “described in section 1702(17) of this Appendix” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6aedde1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6aedde2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" inserted “advertise, hold oneself out, or” after “may not” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
