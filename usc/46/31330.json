{"tag":"section","attrib":{"id":"idf6aa22f5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330"},"text":null,"children":[{"tag":"num","attrib":{"value":"31330"},"text":"§ 31330.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6aa22f6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aa22f7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A mortgagor shall be fined under title 18, imprisoned for not more than 2 years, or both, if the mortgagor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6aa22f8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to defraud, does not disclose an obligation on a vessel as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31323/a"},"text":"section 31323(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aa22f9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to defraud, incurs a contractual obligation in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31323/b"},"text":"section 31323(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aa22fa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to hinder or defraud an existing or future creditor of the mortgagor or a lienor of the vessel, files a mortgage with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aa22fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A mortgagor is liable to the United States Government for a civil penalty of not more than $10,000 if the mortgagor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6aa22fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not disclose an obligation on a vessel as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31323/a"},"text":"section 31323(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aa22fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incurs a contractual obligation in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31323/b"},"text":"section 31323(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aa22fe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files with the Secretary a mortgage made not in good faith.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aa22ff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aa2300-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person that knowingly violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31329"},"text":"section 31329 of this title","children":[],"tail":" shall be fined under title 18, imprisoned for not more than 3 years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aa2301-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person violating ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31329"},"text":"section 31329 of this title","children":[],"tail":" is liable to the Government for a civil penalty of not more than $25,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aa2302-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vessel involved in a violation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31329"},"text":"section 31329 of this title","children":[],"tail":" and its equipment may be seized by, and forfeited to, the Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aa2303-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31330/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person not an individual violates this section, the president or chief executive of the person also is subject to any penalty provided under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6aa2304-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s102/c"},"text":"Pub. L. 100–710, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4747"},"text":"102 Stat. 4747","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tXI/s1113/b/2"},"text":"Pub. L. 104–324, title XI, § 1113(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3970"},"text":"110 Stat. 3970","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIX/s913/a/1"},"text":"Pub. L. 111–281, title IX, § 913(a)(1)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3017"},"text":"124 Stat. 3017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6aa2305-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6aa2306-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6aa2307-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31330(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:941(b) (1st sentence)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31330(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"New","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31330(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:941(b) (1st sentence)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31330(a) provides for criminal penalties for not disclosing obligations, incurring contractual obligations in violation of section 31323(b), and filing a mortgage made not in good faith. This subsection makes a substantive change to law by adding civil penalties and by making it a crime to record with the Secretary of Transportation a mortgage made not in good faith with the intent to hinder an existing or future creditor of the mortgagor or a lienor of the vessel. This is done since the affidavit of good faith has been eliminated from the elements of a preferred mortgage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31330(b) adds criminal and civil penalties for violating the sale and trust requirements under sections 31328 and 31329. It also makes a vessel and its equipment involved in those violations subject to seizure by the Government.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31330(c) makes the president or chief executive officer of a corporation or association liable as a mortgagor for the penalties under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6aa2308-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"house floor statement","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (a) of this section adds criminal and civil penalties for a preferred mortgagor’s failure to carry out certain requirements under chapter 313 of title 46 (as enacted by this Act).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6aa2309-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6aa230a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s913/d/1/A"},"text":"Pub. L. 111–281, § 913(d)(1)(A)","children":[],"tail":", inserted “or” after semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s913/d/1/B"},"text":"Pub. L. 111–281, § 913(d)(1)(B)","children":[],"tail":", substituted “Secretary.” for “Secretary; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s913/a/1"},"text":"Pub. L. 111–281, § 913(a)(1)","children":[],"tail":", struck out “of Transportation” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s913/d/1/C"},"text":"Pub. L. 111–281, § 913(d)(1)(C)","children":[],"tail":", struck out subpar. (D) which read as follows: “with intent to defraud, does not comply with "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s31321/h"},"text":"section 31321(h) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s913/d/2"},"text":"Pub. L. 111–281, § 913(d)(2)","children":[],"tail":", inserted “or” at end of subpar. (B), substituted “faith.” for “faith; or” at end of subpar. (C), and struck out subpar. (D) which read as follows: “does not comply with "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s31321/h"},"text":"section 31321(h) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" struck out “31328 or” before “31329” in pars. (1) to (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6ac930b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf6ac930c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/710/s107"},"text":"section 107 of Pub. L. 100–710","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s31301"},"text":"section 31301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
