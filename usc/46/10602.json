{"tag":"section","attrib":{"id":"idf68d9a58-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10602"},"text":null,"children":[{"tag":"num","attrib":{"value":"10602"},"text":"§ 10602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of wages and shares of fish under agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68d9a59-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10602/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When fish caught under an agreement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s10601"},"text":"section 10601 of this title","children":[],"tail":" are delivered to the owner of the vessel for processing and are sold, the vessel is liable in rem for the wages and shares of the proceeds of the seamen. An action under this section must be brought within six months after the sale of the fish."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9a5a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10602/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68d9a5b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10602/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In an action under this section, the owner shall produce an accounting of the sale and division of proceeds under the agreement. If the owner fails to produce the accounting, the vessel is liable for the highest value alleged for the shares.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68d9a5c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10602/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner may offset the value of general supplies provided for the voyage and other supplies provided the seaman bringing the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9a5d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10602/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not affect a common law right of a seaman to bring an action to recover the seaman’s share of the fish or proceeds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68d9a5e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/424/s6/a"},"text":"Pub. L. 100–424, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1592"},"text":"102 Stat. 1592","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68d9a5f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68d9a60-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68d9a61-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10602","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:533, 534","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
