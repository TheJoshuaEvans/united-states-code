{"tag":"section","attrib":{"id":"idf6ecf8ac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56301"},"text":null,"children":[{"tag":"num","attrib":{"value":"56301"},"text":"§ 56301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"During a national emergency declared by Presidential proclamation, or a period for which the President has proclaimed that the security of the national defense makes it advisable, the Secretary of Transportation may requisition or purchase, or requisition or charter the use of, a vessel owned by citizens of the United States, a documented vessel, or a vessel under construction in the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6ecf8ad-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1654"},"text":"120 Stat. 1654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ecf8ae-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ecf8af-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ecf8b0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"