{"tag":"section","attrib":{"id":"idf6b14ec7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41301"},"text":null,"children":[{"tag":"num","attrib":{"value":"41301"},"text":"§ 41301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complaints","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b14ec8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may file with the Federal Maritime Commission a sworn complaint alleging a violation of this part, except section 41307(b)(1). If the complaint is filed within 3 years after the claim accrues, the complainant may seek reparations for an injury to the complainant caused by the violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14ec9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice and Response","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall provide a copy of the complaint to the person named in the complaint. Within a reasonable time specified by the Commission, the person shall satisfy the complaint or answer it in writing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14eca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"If Complaint Not Satisfied","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the complaint is not satisfied, the Commission shall investigate the complaint in an appropriate manner and make an appropriate order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b14ecb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1545"},"text":"120 Stat. 1545","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b14ecc-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b14ecd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b14ece-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41301(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1710(a), (g) (related to time limit).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/98/237/s11/a"},"text":"Pub. L. 98–237, § 11(a)","children":[],"tail":", (b), (g) (related to time limit), "},{"tag":"html:span","attrib":{},"text":"Mar. 20, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/80"},"text":"98 Stat. 80","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/595/s3/b/2"},"text":"Pub. L. 98–595, § 3(b)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/3132"},"text":"98 Stat. 3132","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tI/s110"},"text":"Pub. L. 105–258, title I, § 110","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1911"},"text":"112 Stat. 1911","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41301(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1710(b) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41301(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1710(b) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “If the complaint is filed within 3 years after the claim accrues” are substituted for “For any complaint filed within 3 years after the cause of action accrued” in 46 App. U.S.C. 1710(g) to alert the reader to that time limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
