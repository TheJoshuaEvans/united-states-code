{"tag":"section","attrib":{"id":"idf6b3c00b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44102"},"text":null,"children":[{"tag":"num","attrib":{"value":"44102"},"text":"§ 44102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial responsibility to indemnify passengers for nonperformance of transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b3c00c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person in the United States may not arrange, offer, advertise, or provide transportation on a vessel to which this chapter applies unless the person has filed with the Federal Maritime Commission evidence of financial responsibility to indemnify passengers for nonperformance of the transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3c00d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Satisfactory Evidence","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To satisfy subsection (a), a person must file—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3c00e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information the Commission considers necessary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3c00f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of a bond or other security, in such form as the Commission by regulation may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3c010-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s44102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Issuer of Bond","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a bond is filed, it must be issued by a bonding company authorized to do business in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b3c011-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1554"},"text":"120 Stat. 1554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b3c012-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b3c013-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b3c014-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44102","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:817e(a) (1st–14th, 37th–last words), (b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/777/s3/a"},"text":"Pub. L. 89–777, § 3(a)","children":[],"tail":" (1st–14th, 37th–last words), (b), "},{"tag":"html:span","attrib":{},"text":"Nov. 6, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/1357"},"text":"80 Stat. 1357","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/206/tIII/s320"},"text":"Pub. L. 103–206, title III, § 320","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/2427"},"text":"107 Stat. 2427","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “or any State thereof, or the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands or any territory or possession of the United States” are omitted as unnecessary because of the definition of “United States” in chapter 1 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
