{"tag":"section","attrib":{"id":"idf6c91c65-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51702"},"text":null,"children":[{"tag":"num","attrib":{"value":"51702"},"text":"§ 51702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civilian nautical schools","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c91c66-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “civilian nautical school” means a school operated in the United States (except the United States Merchant Marine Academy, a State maritime academy, or another school operated by the United States Government) that offers instruction to individuals quartered on a vessel primarily to train them for service in the merchant marine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c91c67-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each civilian nautical school is subject to inspection by the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c91c68-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rating and Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may, under regulations the Secretary may prescribe, provide for the rating and certification of civilian nautical schools as to the adequacy of their course of instruction, the competence of their instructors, and the suitability of the equipment used in their course of instruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c91c69-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1582"},"text":"120 Stat. 1582","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c91c6a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6c91c6b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6c91c6c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","chi