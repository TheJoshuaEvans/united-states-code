":"June 29, 1936, ch. 858","children":[],"tail":", title II, § 208 (related to Commission), "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1988"},"text":"49 Stat. 1988","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/94/273/s36"},"text":"Pub. L. 94–273, § 36","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/380"},"text":"90 Stat. 380","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/65"},"text":"Pub. L. 97–31, § 12(65)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/159"},"text":"95 Stat. 159","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"306(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1710a(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/418/tX/s10002/g"},"text":"Pub. L. 100–418, title X, § 10002(g)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/1572"},"text":"102 Stat. 1572","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “a statement of all receipts under this chapter” are omitted as inapplicable to the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6b609a4-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6b609a5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The reference to “this part”, referred to in subsec. (b)(6), was added when this section was numbered as ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s306"},"text":"section 306 of this title","children":[],"tail":" and was in subtitle I, which does not contain parts. After section 306 was renumbered as this section, it was transferred into part D of subtitle IV, but it is unclear whether the reference to “this part” was intended to take on the reference to such part D upon the transfer."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this paragraph, referred to in subsec. (b)(7)(B)(i), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146"},"text":"Pub. L. 117–146","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6b609a6-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" inserted “and public disclosure” after “report” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s14"},"text":"Pub. L. 117–146, § 14","children":[],"tail":", added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s6"},"text":"Pub. L. 117–146, § 6","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s306"},"text":"section 306 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s703/1"},"text":"Pub. L. 115–282, § 703(1)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s703/2"},"text":"Pub. L. 115–282, § 703(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
