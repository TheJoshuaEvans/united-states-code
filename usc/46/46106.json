{"tag":"section","attrib":{"id":"idf6b6098d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106"},"text":null,"children":[{"tag":"num","attrib":{"value":"46106"},"text":"§ 46106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report and public disclosure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b6098e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than April 1 of each year, the Federal Maritime Commission shall submit a report to Congress. The report shall include the results of its investigations, a summary of its transactions, the purposes for which all of its expenditures were made, and any recommendations for legislation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b6098f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report on Foreign Laws and Practices","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall include in its annual report to Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b60990-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the 20 foreign countries that generated the largest volume of oceanborne liner cargo for the most recent calendar year in bilateral trade with the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60991-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of conditions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s42302/a"},"text":"section 42302(a) of this title","children":[],"tail":" being investigated or found to exist in foreign countries;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60992-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any actions being taken by the Commission to offset those conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60993-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for additional legislation to offset those conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60994-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of petitions filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s42302/b"},"text":"section 42302(b) of this title","children":[],"tail":" that the Commission rejected and the reasons for each rejection;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60995-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the impacts on competition for the purchase of certain covered services by alliances of ocean common carriers acting pursuant to an agreement under this part ","children":[{"tag":"ref","attrib":{"idref":"fn002024"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002024"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" between or among ocean common carriers, including a summary of actions, including corrective actions, taken by the Commission to promote such competition; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60996-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an identification of any otherwise concerning practices by ocean common carriers, particularly such carriers that are controlled carriers, that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b60997-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State-owned or State-controlled enterprises; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b60998-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" owned or controlled by, a subsidiary of, or otherwise related legally or financially (other than a minority relationship or investment) to a corporation based in a country—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6b60999-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/b/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified as a nonmarket economy country (as defined in section 771(18) of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677/18"},"text":"19 U.S.C. 1677(18)","children":[],"tail":")) as of the date of enactment of this paragraph;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6b6099a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/b/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified by the United States Trade Representative in the most recent report required by section 182 of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2242"},"text":"19 U.S.C. 2242","children":[],"tail":") as a priority foreign country under subsection (a)(2) of that section; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6b6099b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/b/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to monitoring by the United States Trade Representative under section 306 of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2416"},"text":"19 U.S.C. 2416","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b6099c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Certain Covered Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “certain covered services” has the meaning given the term in section 40102.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b6099d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Disclosures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Maritime Commission shall publish, and annually update, on the website of the Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b6099e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all findings by the Commission of false detention and demurrage invoice information by common carriers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s41104/a/15"},"text":"section 41104(a)(15) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b6099f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46106/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all penalties imposed or assessed against common carriers, as applicable, under sections 41107, 41108, and 41109, listed by each common carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b609a0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s4"},"text":"Pub. L. 109–304, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1489"},"text":"120 Stat. 1489","children":[],"tail":", § 306; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVII/s703"},"text":"Pub. L. 115–282, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4294"},"text":"132 Stat. 4294","children":[],"tail":"; renumbered § 46106, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXVI"},"text":"Pub. L. 116–283, div. G, title LVXXXVI","children":[],"tail":" [LXXXVI], § 8605(a)(3), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4765"},"text":"134 Stat. 4765","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/146"},"text":"Pub. L. 117–146","children":[],"tail":", §§ 6, 14, "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1274"},"text":"136 Stat. 1274","children":[],"tail":", 1279; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXV/s3535/j/1"},"text":"Pub. L. 118–159, div. C, title XXXV, § 3535(j)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2315"},"text":"138 Stat. 2315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b609a1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b609a2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b609a3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":n