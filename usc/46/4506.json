{"tag":"section","attrib":{"id":"idf6735b6c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4506"},"text":null,"children":[{"tag":"num","attrib":{"value":"4506"},"text":"§ 4506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may exempt a vessel from any part of this chapter if, under regulations prescribed by the Secretary (including regulations on special operating conditions), the Secretary finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735b6d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4506/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" good cause exists for granting an exemption; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b6e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4506/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety of the vessel and those on board will not be adversely affected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6735b6f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/424/s2/a"},"text":"Pub. L. 100–424, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1587"},"text":"102 Stat. 1587","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tV/s5222"},"text":"Pub. L. 102–587, title V, § 5222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5081"},"text":"106 Stat. 5081","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIII/s301/b/6"},"text":"Pub. L. 105–383, title III, § 301(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3417"},"text":"112 Stat. 3417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVI/s604/b"},"text":"Pub. L. 111–281, title VI, § 604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2964"},"text":"124 Stat. 2964","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s306/a/5"},"text":"Pub. L. 114–120, title III, § 306(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/54"},"text":"130 Stat. 54","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6735b70-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6735b71-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6735b72-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" struck out subsec. (a) designation before “The Secretary may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" struck out subsec. (b) which read as follows: “A vessel to which this chapter applies is exempt from "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s4502/b/2/B"},"text":"section 4502(b)(2)(B) of this title","children":[],"tail":" if it—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) is less than 36 feet in length; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) is operating—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) in internal waters of the United States; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) within 3 nautical miles from the baselines from which the territorial sea of the United States is measured.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383"},"text":"Pub. L. 105–383","children":[],"tail":" added par. (2) and struck out former par. (2) which read as follows: “is not operating on the high seas.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" substituted “4502(b)(2)(B)” for “4502(b)(2)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idf6735b73-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6735b74-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Territorial Sea of United States","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For extension of territorial sea of United States, see Proc. No. 5928, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
