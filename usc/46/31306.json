{"tag":"section","attrib":{"id":"idf6a7b20b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31306"},"text":null,"children":[{"tag":"num","attrib":{"value":"31306"},"text":"§ 31306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of citizenship","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a7b20c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided by the Secretary, when an instrument transferring an interest in a vessel is presented to the Secretary for filing or recording, the transferee shall file with the instrument a declaration, in the form the Secretary may prescribe by regulation, stating information about citizenship and other information the Secretary may require to show the transaction involved does not violate section 56102 or 56103 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a7b20d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A declaration under this section filed by a corporation must be signed by its president, secretary, treasurer, or other official authorized by the corporation to execute the declaration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a7b20e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided by the Secretary, an instrument transferring an interest in a vessel is not valid against any person until the declaration required by this section has been filed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a7b20f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person knowingly making a false statement of a material fact in a declaration filed under this section shall be fined under title 18, imprisoned for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a7b210-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s102/c"},"text":"Pub. L. 100–710, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4741"},"text":"102 Stat. 4741","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/225/tIII/s303/1"},"text":"Pub. L. 101–225, title III, § 303(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1923"},"text":"103 Stat. 1923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/27"},"text":"Pub. L. 109–304, § 15(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1704"},"text":"120 Stat. 1704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIX/s913/a/1"},"text":"Pub. L. 111–281, title IX, § 913(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3017"},"text":"124 Stat. 3017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a7b211-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a7b212-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a7b213-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31306","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:838","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31306(a) requires that a person submitting an instrument transferring interest in a vessel to the Secretary for recording is also to file a declaration stating information about citizenship and other information to show that the transfer is not in violation of section 9 of the Shipping Act, or section 37 of that Act in a national emergency. This section makes no substantive change to law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31306(b) requires that a declaration filed by a corporation must be signed by the president, secretary, treasurer, or other official authorized by the corporation to execute the declaration. This section makes no substantive change to law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31306(c) invalidates any instrument transferring an interest until the declaration is filed. This section makes no substantive change to law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31306(d) provides for a criminal penalty for a violation of this section. The amount of the fine is prescribed under title 18, United States Code, and may include imprisonment for not more than 5 years, or both. This section makes no substantive change to law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6a7b214-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6a7b215-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" struck out “of Transportation” after “provided by the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" substituted “section 56102 or 56103 of this title” for “section 9 or 37 of the Shipping Act, 1916 (46 App. U.S.C. 808, 835)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/225/s303/1/A"},"text":"Pub. L. 101–225, § 303(1)(A)","children":[],"tail":", substituted “Except as provided by the Secretary of Transportation, when” for “When” and “Secretary for filing” for “Secretary of Transportation for filing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/225/s303/1/B"},"text":"Pub. L. 101–225, § 303(1)(B)","children":[],"tail":", substituted “Except as provided by the Secretary, an” for “An”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6a7b216-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf6a7b217-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/710/s107"},"text":"section 107 of Pub. L. 100–710","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s31301"},"text":"section 31301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
