{"tag":"section","attrib":{"id":"idf656abe5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2112"},"text":null,"children":[{"tag":"num","attrib":{"value":"2112"},"text":"§ 2112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to change working hours","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In a port at which the customary working hours begin before 8 a.m. or end after 5 p.m., the Secretary may regulate the working hours of the officers and employees referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2111"},"text":"section 2111 of this title","children":[],"tail":" so that those hours conform to the prevailing working hours of the port. However—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf656abe6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2112/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total period for which overtime pay may be required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2111"},"text":"section 2111 of this title","children":[],"tail":" may not be more than 15 hours between any 2 periods of ordinary working hours on other than Sundays and holidays;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf656abe7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2112/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of the working day for the officers and employees involved may not be changed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf656abe8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2112/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of overtime pay may not be changed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf656abe9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/508"},"text":"97 Stat. 508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf656abea-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf656abeb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf656abec-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2112","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:382b","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2112 provides the Secretary with the authority to regulate the working hours of civilian officers and employees of the Coast Guard to conform with the prevailing working hours of a port.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
