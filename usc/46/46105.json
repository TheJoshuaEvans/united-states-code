{"tag":"section","attrib":{"id":"idf6b60977-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105"},"text":null,"children":[{"tag":"num","attrib":{"value":"46105"},"text":"§ 46105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b60978-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Maritime Commission may prescribe regulations to carry out its duties and powers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60979-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transparency.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b6097a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In conjunction with the transmittal by the President to the Congress of the Budget of the United States for fiscal year 2021 and biennially thereafter, the Federal Maritime Commission shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives reports that describe the Commission’s progress toward addressing the issues raised in each unfinished regulatory proceeding, regardless of whether the proceeding is subject to a statutory or regulatory deadline.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b6097b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Format of reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under paragraph (1) shall, among other things, clearly identify for each unfinished regulatory proceeding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b6097c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the popular title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b6097d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current stage of the proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b6097e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an abstract of the proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b6097f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" what prompted the action in question;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b60980-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable statutory, regulatory, or judicial deadline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b60981-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the associated docket number;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b60982-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the rulemaking was initiated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b60983-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a date for the next action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b60984-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46105/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a date for the next action identified in the previous report is not met, the reason for the delay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b60985-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s4"},"text":"Pub