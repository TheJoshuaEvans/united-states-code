{"tag":"section","attrib":{"id":"idf67cd106-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7507"},"text":null,"children":[{"tag":"num","attrib":{"value":"7507"},"text":"§ 7507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to extend the duration of licenses, certificates of registry, and merchant mariner documents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf67cd107-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Licenses and Certificates of Registry","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding sections 7106 and 7107, the Secretary of the department in which the Coast Guard is operating may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67cd108-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend for not more than one year an expiring license or certificate of registry issued for an individual under chapter 71 if the Secretary determines that the extension is required to enable the Coast Guard to eliminate a backlog in processing applications for those licenses or certificates of registry or in response to a national emergency or natural disaster, as deemed necessary by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd109-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue for not more than five years an expiring license or certificate of registry issued for an individual under chapter 71 for the exclusive purpose of aligning the expiration date of such license or certificate of registry with the expiration date of a merchant mariner’s document.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd10a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Merchant Mariner Documents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 7302(g), the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67cd10b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend for not more than one year an expiring merchant mariner’s document issued for an individual under chapter 73 if the Secretary determines that the extension is required to enable the Coast Guard to eliminate a backlog in processing applications for those merchant mariner documents or in response to a national emergency or natural disaster, as deemed necessary by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd10c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue for not more than five years an expiring merchant mariner’s document issued for an individual under chapter 73 for the exclusive purpose of aligning the expiration date of such merchant mariner’s document with the expiration date of a license or certificate of registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd10d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Manner of Extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any extensions granted under this section may be granted to individual seamen or a specifically identified group of seamen.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd10e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7507/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Renewal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to any renewal of an active merchant mariner credential issued under this part that is not an extension under subsection (a) or (b), such credential shall begin the day after the expiration of the active credential of the credential holder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67cd10f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVI/s615/a"},"text":"Pub. L. 111–281, title VI, § 615(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2971"},"text":"124 Stat. 2971","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tIII/s311"},"text":"Pub. L. 112–213, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1569"},"text":"126 Stat. 1569","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tV/s510/3"},"text":"Pub. L. 115–282, title V, § 510(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4274"},"text":"132 Stat. 4274","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/g/1"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1755"},"text":"139 Stat. 1755","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67cd110-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf67cd111-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf67cd112-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s510/3"},"text":"Pub. L. 115–282, § 510(3)","children":[],"tail":", substituted “merchant mariner documents” for “licenses or certificates of registry”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s510/4"},"text":"Pub. L. 115–282, § 510(4)","children":[],"tail":", substituted “license or certificate of registry.” for “merchant mariner’s document.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" substituted “chapter 71” for “chapter 73” in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
