{"tag":"section","attrib":{"id":"idf6dea066-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714"},"text":null,"children":[{"tag":"num","attrib":{"value":"53714"},"text":"§ 53714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6dea067-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to this section, the Secretary or Administrator shall prescribe regulations to assess a fee for guaranteeing an obligation under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea068-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computation of Fee","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dea069-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of the fee for a guarantee under this chapter shall be equal to the sum of the amounts determined under paragraph (2) for the years in which the guarantee is in effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea06a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Present value for each year","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount referred to in paragraph (1) for a year in which the guarantee is in effect is the present value of the amount calculated under paragraph (3). To determine the present value, the Secretary or Administrator shall apply a discount rate determined by the Secretary of the Treasury, considering current market yields on outstanding obligations of the United States Government having periods to maturity comparable to the period to maturity for the guaranteed obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea06b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Calculation of amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount referred to in paragraph (2) shall be calculated by multiplying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dea06c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated average unpaid principal amount of the obligation that will be outstanding during the year (excluding the average amount, other than interest, on deposit during the year in an escrow fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53715"},"text":"section 53715 of this title","children":[],"tail":"); by"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dea06d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fee rate set under paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea06e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Setting fee rates","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To set the fee rate referred to in paragraph (3)(B), the Secretary or Administrator shall establish a formula that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dea06f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes into account the security provided for the guaranteed obligation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dea070-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is a sliding scale based on the creditworthiness of the obligor, using—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6dea071-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lowest allowable rate under paragraph (5) for the most creditworthy obligors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6dea072-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the highest allowable rate under paragraph (5) for the least creditworthy obligors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea073-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permissible range of rates","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The fee rate set under paragraph (4) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dea074-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a delivered vessel or equipment, at least 0.5 percent and not more than 1 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dea075-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a vessel to be constructed, reconstructed, or reconditioned or equipment to be delivered, at least 0.25 percent and not more than 0.5 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea076-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When Fee Collected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fee for the guarantee of an obligation under this chapter shall be collected not later than the date on which an amount is first paid on the obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea077-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financing the Fee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fee paid under this section is eligible to be financed under this chapter and shall be included in the actual cost of the obligation guaranteed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea078-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53714/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Not Refundable","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fee paid under this section is not refundable. However, an obligor shall receive credit for the amount paid for the remaining term of the obligation if the obligation is refinanced and guaranteed under this chapter after the refinancing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6dea079-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1613"},"text":"120 Stat. 1613","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/D"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/10/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(10)(B)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6dea07a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6dea07b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6dea07c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","at