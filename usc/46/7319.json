{"tag":"section","attrib":{"id":"idf67cd0c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7319"},"text":null,"children":[{"tag":"num","attrib":{"value":"7319"},"text":"§ 7319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records of merchant mariners’ documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain records on each merchant mariner’s document issued, including the name and address of the individual to whom issued and the next of kin of the individual.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf67cd0c7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/545"},"text":"97 Stat. 545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tIV/s403"},"text":"Pub. L. 108–293, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1043"},"text":"118 Stat. 1043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(b)(4), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4751"},"text":"134 Stat. 4751","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67cd0c8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf67cd0c9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf67cd0ca-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7319","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:643(f)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7319 requires the Secretary to maintain records on each merchant mariner’s document issued and the seaman’s next of kin. However, these records are not open for general or public inspection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf67cd0cb-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf67cd0cc-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “individual” for “seaman” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" struck out at end “The records are not open to general or public inspection.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
