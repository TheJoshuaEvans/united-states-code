{"tag":"section","attrib":{"id":"idf6a0ad3c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106"},"text":null,"children":[{"tag":"num","attrib":{"value":"15106"},"text":"§ 15106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Offshore Safety Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a0ad3d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a National Offshore Safety Advisory Committee (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad3e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall advise the Secretary on matters relating to activities directly involved with, or in support of, the exploration of offshore mineral and energy resources, to the extent that such matters are within the jurisdiction of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad3f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ad40-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall consist of 15 members appointed by the Secretary in accordance with this section and section 15109 of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad41-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expertise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad42-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Committee shall be appointed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad43-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members shall represent entities engaged in the production of petroleum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad44-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members shall represent entities engaged in offshore drilling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad45-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members shall represent entities engaged in the support, by offshore supply vessels or other vessels, of offshore operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad46-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent entities engaged in the construction of offshore facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad47-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent entities providing diving services to the offshore industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad48-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent entities providing safety and training services to the offshore industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad49-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent entities providing subsea engineering, construction, or remotely operated vehicle support to the offshore industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad4a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members shall represent individuals employed in offshore operations and, of the 2, 1 shall have recent practical experience on a vessel or offshore unit involved in the offshore industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad4b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent national environmental entities and entities providing environmental protection, compliance, or response services to the offshore industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad4c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent entities engaged in offshore oil exploration and production on the Outer Continental Shelf adjacent to Alaska.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad4d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15106/c/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent the general public (but not a specific environmental group).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a0ad4e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVI/s601/a"},"text":"Pub. L. 115–282, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4284"},"text":"132 Stat. 4284","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8331(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4702"},"text":"134 Stat. 4702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a0ad4f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6a0ad50-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6a0ad51-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8331/a/1"},"text":"Pub. L. 116–283, § 8331(a)(1)","children":[],"tail":", substituted “operations” for “mineral and oil operations, including geophysical services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8331/a/2"},"text":"Pub. L. 116–283, § 8331(a)(2)","children":[],"tail":", struck out “exploration and recovery” before “facilities.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8331/a/3"},"text":"Pub. L. 116–283, § 8331(a)(3)","children":[],"tail":", substituted “providing diving services to the offshore industry” for “engaged in diving services related to offshore construction, inspection, and maintenance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8331/a/4"},"text":"Pub. L. 116–283, § 8331(a)(4)","children":[],"tail":", substituted “providing safety and training services to the offshore industry” for “engaged in safety and training services related to offshore exploration and construction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8331/a/5"},"text":"Pub. L. 116–283, § 8331(a)(5)","children":[],"tail":", substituted “providing subsea engineering, construction, or remotely operated vehicle support to the offshore industry” for “engaged in pipelaying services related to offshore construction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8331/a/6"},"text":"Pub. L. 116–283, § 8331(a)(6)","children":[],"tail":", struck out “mineral and energy” before “industry.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8331/a/7"},"text":"Pub. L. 116–283, § 8331(a)(7)","children":[],"tail":", inserted “and entities providing environmental protection, compliance, or response services to the offshore industry” after “national environmental entities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8331/a/8"},"text":"Pub. L. 116–283, § 8331(a)(8)","children":[],"tail":", substituted “entities engaged in offshore oil exploration and production on the Outer Continental Shelf adjacent to Alaska” for “deepwater ports”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
