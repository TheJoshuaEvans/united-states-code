{"tag":"section","attrib":{"id":"idf6970ff3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12131"},"text":null,"children":[{"tag":"num","attrib":{"value":"12131"},"text":"§ 12131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Command of documented vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6970ff4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), a documented vessel may be placed under the command only of a citizen or noncitizen national (as such term is described in section 308 of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1408"},"text":"8 U.S.C. 1408","children":[],"tail":")) of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6970ff5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6970ff6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12131/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel with only a recreational endorsement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6970ff7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12131/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unmanned barge operating outside of the territorial waters of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6970ff8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1505"},"text":"120 Stat. 1505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3529/a/3"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3529(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/603"},"text":"122 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/b/2/C"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(b)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1752"},"text":"139 Stat. 1752","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6970ff9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6970ffa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6970ffb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":