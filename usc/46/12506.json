{"tag":"section","attrib":{"id":"idf699811a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12506"},"text":null,"children":[{"tag":"num","attrib":{"value":"12506"},"text":"§ 12506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of authority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may delegate to an agency, a State, or a qualified person the authority to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf699811b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12506/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain the vessel identification system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf699811c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12506/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charge fees under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12505"},"text":"section 12505 of this title","children":[],"tail":" to a person making information available to or requesting information from the vessel identification system."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf699811d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s101/a"},"text":"Pub. L. 100–710, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4737"},"text":"102 Stat. 4737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf699811e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf699811f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 12506","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section allows the Secretary to delegate the authority to establish and maintain the vessel identification system to an agency, a State, or a qualified person. The Secretary may also delegate the authority to charge fees under section 12505 for requesting information from or making information available to the vessel identification system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6998120-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf6998121-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/710/s107"},"text":"section 107 of Pub. L. 100–710","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s31301"},"text":"section 31301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
