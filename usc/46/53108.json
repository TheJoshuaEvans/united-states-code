{"tag":"section","attrib":{"id":"idf6d04819-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53108"},"text":null,"children":[{"tag":"num","attrib":{"value":"53108"},"text":"§ 53108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory relief","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d0481a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation in Foreign Commerce","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contractor for a vessel included in an operating agreement under this chapter may operate the vessel in the foreign commerce of the United States without restriction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d0481b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Restrictions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The restrictions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55305/a"},"text":"section 55305(a) of this title","children":[],"tail":" concerning the building, rebuilding, or documentation of a vessel in a foreign country shall not apply to a vessel for any day the operator of that vessel is receiving payments for operation of that vessel under an operating agreement under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d0481c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Telecommunications Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The telecommunications and other electronic equipment on an existing vessel that is redocumented under the laws of the United States for operation under an operating agreement under this chapter shall be deemed to satisfy all Federal Communications Commission equipment certification requirements, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d0481d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such equipment complies with all applicable international agreements and associated guidelines as determined by the country in which the vessel was documented immediately before becoming documented under the laws of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d0481e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that country has not been identified by the Secretary as inadequately enforcing international regulations as to that vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d0481f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53108/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the end of its useful life, such equipment will be replaced with equipment that meets Federal Communications Commission equipment certification standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d04820-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dC/tXXXV/s3531/a"},"text":"Pub. L. 108–136, div. C, title XXXV, § 3531(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1816"},"text":"117 Stat. 1816","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/7"},"text":"Pub. L. 109–304, § 13(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1701"},"text":"120 Stat. 1701","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d04821-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6d04822-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6d04823-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t46/s55305/a"},"text":"section 55305(a) of this title","children":[],"tail":"” for “section 901(b)(1) of the Merchant Marine Act, 1936 (46 U.S.C. App. 1241(b)(1))”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
