{"tag":"section","attrib":{"id":"idf6ac93d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301"},"text":null,"children":[{"tag":"num","attrib":{"value":"40301"},"text":"§ 40301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ac93d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ocean Common Carrier Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This part applies to an agreement between or among ocean common carriers to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ac93d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discuss, fix, or regulate transportation rates, including through rates, cargo space accommodations, and other conditions of service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pool or apportion traffic, revenues, earnings, or losses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allot ports or regulate the number and character of voyages between ports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulate the volume or character of cargo or passenger traffic to be carried;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in an exclusive, preferential, or cooperative working arrangement between themselves or with a marine terminal operator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control, regulate, or prevent competition in international ocean transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discuss and agree on any matter related to a service contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ac93db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Marine Terminal Operator Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This part applies to an agreement between or among marine terminal operators, or between or among one or more marine terminal operators and one or more ocean common carriers, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ac93dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discuss, fix, or regulate rates or other conditions of service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in exclusive, preferential, or cooperative working arrangements, to the extent the agreement involves ocean transportation in the foreign commerce of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ac93de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This part does not apply to an acquisition by any person, directly or indirectly, of any voting security or assets of any other person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ac93df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maritime Labor Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This part does not apply to a maritime labor agreement. However, this subsection does not exempt from this part any rate, charge, regulation, or practice of a common carrier that is required to be set forth in a tariff or is an essential term of a service contract, whether or not the rate, charge, regulation, or practice arises out of, or is otherwise related to, a maritime labor agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ac93e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40301/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This part (except sections 40305 and 40307(a)) does not apply to an assessment agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ac93e1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1528"},"text":"120 Stat. 1528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ac93e2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ac93e3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ac93e4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attri