{"tag":"section","attrib":{"id":"idf6e81610-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55107"},"text":null,"children":[{"tag":"num","attrib":{"value":"55107"},"text":"§ 55107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Empty cargo containers and barges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e81611-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (b) and (c), and on terms and conditions the Secretary of Homeland Security may prescribe by regulation, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55102"},"text":"section 55102 of this title","children":[],"tail":" does not apply to the transportation of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e81612-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" empty cargo vans, empty lift vans, or empty shipping tanks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81613-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment for use with cargo vans, lift vans, or shipping tanks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81614-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55107/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" empty barges specifically designed for carriage aboard a vessel and equipment (except propulsion equipment) for use with those barges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81615-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55107/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" empty instruments for international traffic exempted from the customs laws under section 322(a) of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1322/a"},"text":"19 U.S.C. 1322(a)","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81616-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55107/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stevedoring equipment and material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e81617-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e81618-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Paragraphs (1)–(4)","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraphs (1)–(4) of subsection (a) apply only if the items named are owned or leased by the owner or operator of the vessel and transported for its use in handling its cargo in foreign trade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81619-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Paragraph (5)","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (5) of subsection (a) applies only if the items named are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e8161a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55107/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or leased by the owner or operator of the vessel or by the stevedoring company having the contract for the loading or unloading of the vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e8161b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55107/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transported without charge for use in the handling of cargo in foreign trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e8161c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reciprocity Requirement for Foreign Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies to a vessel of foreign registry only if the Secretary of Homeland Security finds, based on information from the Secretary of State, that the government of the nation of registry extends reciprocal privileges to vessels of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e8161d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1635"},"text":"120 Stat. 1635","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e8161e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e8161f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e81620-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{