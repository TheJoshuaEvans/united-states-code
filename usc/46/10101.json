{"tag":"section","attrib":{"id":"idf688b87e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10101"},"text":null,"children":[{"tag":"num","attrib":{"value":"10101"},"text":"§ 10101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b87f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “master” means the individual having command of a vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b880-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “owner” means the person to whom the vessel belongs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b881-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “seaman” means an individual (except scientific personnel, a sailing school instructor, or a sailing school student) engaged or employed in any capacity on board a vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b882-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “fishing vessel” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf688b883-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10101/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fish tender vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf688b884-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10101/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fish processing vessel entered into service before ","children":[{"tag":"date","attrib":{"date":"1988-01-01"},"text":"January 1, 1988","children":[],"tail":", and not more than 1,600 gross tons as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" or entered into service after "},{"tag":"date","attrib":{"date":"1987-12-31"},"text":"December 31, 1987","children":[],"tail":", and having not more than 16 individuals on board primarily employed in the preparation of fish or fish products."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf688b885-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/560"},"text":"97 Stat. 560","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/364/tIV/s402/13"},"text":"Pub. L. 98–364, title IV, § 402(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/449