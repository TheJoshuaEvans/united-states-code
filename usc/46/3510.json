{"tag":"section","attrib":{"id":"idf6674d59-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3510"},"text":null,"children":[{"tag":"num","attrib":{"value":"3510"},"text":"§ 3510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional medical and safety standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6674d5a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Automated External Defibrillators","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, the Secretary, in consultation with the Secretary of Health and Human Services and other appropriate Federal agencies, shall promulgate regulations to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6674d5b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3510/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that the owner of a vessel to which section 3507 applies install, and maintain in working order, automated external defibrillators on such vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6674d5c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3510/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that such defibrillators be placed throughout such vessel in clearly designated locations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6674d5d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3510/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that such defibrillators are available for passenger and crew access in the event of an emergency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6674d5e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3510/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that automated external defibrillators, or adjacent equipment, allow passengers and crew to easily contact medical staff of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6674d5f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Owner","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “owner” has the meaning given such term in section 3507.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6674d60-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/14/s3/a"},"text":"Pub. L. 117–14, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-05-24"},"text":"May 24, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/275"},"text":"135 Stat. 275","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6674d61-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6674d62-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6674d63-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/14"},"text":"Pub. L. 117–14","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-05-24"},"text":"May 24, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
