{"tag":"section","attrib":{"id":"idf6ef4217-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56503"},"text":null,"children":[{"tag":"num","attrib":{"value":"56503"},"text":"§ 56503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of adjustments and arrangements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ef4218-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An adjustment or arrangement under this chapter shall include suspension of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ef4219-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement to operate the vessel in foreign trade under the applicable operating-differential or construction-differential subsidy contract or mortgage or other agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ef421a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to operating-differential subsidy for the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ef421b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretionary Adjustments and Arrangements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent the Secretary of Transportation considers appropriate to carry out the purposes of this subtitle, an adjustment or arrangement under this chapter may include any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ef421c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lay-up of the vessel by the owner or in the custody of the Secretary, with payment or reimbursement by the Secretary of necessary and proper expenses (including reasonable overhead and insurance) or a fixed periodic allowance instead of payment or reimbursement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ef421d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Postponement, for not more than the total period of the lay-up, of the maturity date of each installment of the principal of obligations to the United States Government for the vessel (regardless of whether the maturity date is during a lay-up period), or rearrangement of those maturities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ef421e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Postponement or cancellation of interest accruing on the obligations during a lay-up period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ef421f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56503/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Extension, for not more than the total period of the lay-up, of the 20-year life limitation for the vessel and other limitations and provisions of this subtitle based on a 20-year life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ef4220-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56503/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision for temporary or emergency employment of the vessel (instead of lay-up) as may be practicable, with such arrangements for management of the vessel, payment of expenses, and application of the proceeds of the employment, as the Secretary may approve, with any period of operation being included as part of the lay-up period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ef4221-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56503/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment to the Secretary, on termination of the arrangements with the applicant, of the applicant’s net profits (earned while the arrangements were in effect) in excess of 10 percent a year on the capital necessarily employed in the applicant’s business, as reimbursement for obligations postponed or canceled and expenses incurred or paid by the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ef4222-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Laid-Up Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under subsection (b)(6), capital of the applicant represented by a vessel of the applicant laid-up or operated under this section shall be included in capital necessarily employed in the applicant’s business. The Secretary may require a vessel laid-up or operated under this section to be security for reimbursement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ef4223-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1657"},"text":"120 Stat. 1657","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ef4224-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ef4225-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ef4226-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"56503","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1242a(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1940-06-29/ch442"},"text":"June 29, 1940, ch. 442","children":[],"tail":", subdiv. (c), "},{"tag":"html:a","attrib":{"href":"/us/stat/54/685"},"text":"54 Stat. 685","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/132"},"text":"Pub. L. 97–31, § 12(132)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/165"},"text":"95 Stat. 165","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
