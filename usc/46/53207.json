{"tag":"section","attrib":{"id":"idf6d2b9c2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207"},"text":null,"children":[{"tag":"num","attrib":{"value":"53207"},"text":"§ 53207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National security requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d2b9c3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contingency Agreement Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall include in each Operating Agreement under this chapter a requirement that the Contractor enter into a Contingency Agreement with the Operating Agency. The Operating Agency shall negotiate and enter into a Contingency Agreement with each Contractor as promptly as practicable after the Contractor has entered into an Operating Agreement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9c4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms of Contingency Agreement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b9c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Contingency Agreement under this section shall require that a Contractor for a vessel covered by an Operating Agreement under this chapter make the vessel, including all necessary resources to engage in Cable Services required by the Operating Agency, available upon request by the Operating Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d2b9c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The basic terms of a Contingency Agreement shall be established (subject to subparagraph (B)) by the Operating Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d2b9c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Operating Agency and a Contractor may agree to additional or modifying terms appropriate to the Contractor’s circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense Measures Against Unauthorized Seizures","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b9ca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Contingency Agreement shall require that any vessel operating under the direction of the Operating Agency operating in area that is designated by the Coast Guard as an area of high risk of piracy shall be equipped with, at a minimum, appropriate non-lethal defense measures to protect the vessel and crew from unauthorized seizure at sea.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense and the Secretary of the department in which the Coast Guard is operating shall jointly prescribe the non-lethal defense measures that are required under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation After Expiration of Operating Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided by section 53205(d), the Operating Agency may not require, through a Contingency Agreement or an Operating Agreement, that a Contractor continue to participate in a Contingency Agreement after the Operating Agreement with the Contractor has expired according to its terms or is otherwise no longer in effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resources Made Available","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The resources to be made available in addition to the vessel under a Contingency Agreement shall include all equipment, personnel, supplies, management services, and other related services as the Operating Agency may determine to be necessary to provide the Cable Services required by the Operating Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b9cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Operating Agency shall include in each Contingency Agreement provisions under which the Operating Agency shall pay fair and reasonable compensation for use of the vessel and all Cable Services provided pursuant to this section and the Contingency Agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9d0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Compensation under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d2b9d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be at the rate specified in the Contingency Agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d2b9d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be provided from the time that a vessel is required by the Operating Agency under the Contingency Agreement until the time it is made available by the Operating Agency available to reenter commercial service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d2b9d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in addition to and shall not in any way reflect amounts payable under section 53206.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability of the United States for Damages.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b9d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on the liability of the u.s","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided by law, the Government shall not be liable for disruption of a Contractor’s commercial business or other consequential damages to a Contractor arising from the activation of the Contingency Agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53207/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affirmative defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any action in any Federal or State court for breach of third-party contract, there shall be available as an affirmative defense that the alleged breach of contract was caused predominantly by action taken to carry out a Contingent Agreement. Such defense shall not release the party asserting it from any obligation under applicable law to mitigate damages to the greatest extent possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d2b9d7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3521/a"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1995"},"text":"133 Stat. 1995","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
