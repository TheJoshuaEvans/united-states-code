{"tag":"section","attrib":{"id":"idf6998138-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13101"},"text":null,"children":[{"tag":"num","attrib":{"value":"13101"},"text":"§ 13101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6998139-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “eligible State” means a State that has a State recreational boating safety program accepted by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf699813a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Recreational Boating Safety Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State recreational boating safety program” means education, assistance, and enforcement activities conducted for maritime casualty prevention, reduction, and reporting for recreational boating.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf699813b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s16/b/2"},"text":"Pub. L. 109–304, § 16(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1705"},"text":"120 Stat. 1705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf699813c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf699813d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 16 of the bill [H.R. 1442, which became ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":"] moves the definitions relating to the recreational boating safety program from section 2102(a)(1) and (3) to chapter 131 because the terms only appear in chapter 131."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 16 of the bill also eliminates the special definitions of “State” and “United States” in section 2102(a)(2) as including the Trust Territory of the Pacific Islands because the Trust Territory has been terminated. See the definitions of “State” and “United States” in section 2101, which are being moved to chapter 1 and being made applicable title-wide. Those definitions already include the Northern Mariana Islands, the only component of the former Trust Territory still under United States sovereignty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf699813e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf699813f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 13101 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s13102"},"text":"section 13102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
