{"tag":"section","attrib":{"id":"idf70bf19a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80508"},"text":null,"children":[{"tag":"num","attrib":{"value":"80508"},"text":"§ 80508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments to Convention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf70bf19b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proposals by United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of State, with the concurrence of the Secretary of the department in which the Coast Guard is operating, may propose amendments to the Convention or request a conference for amending the Convention as provided in article IX of the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70bf19c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proposals by Other Countries","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An amendment communicated to the United States under article IX(2) of the Convention may be accepted for the United States by the President, with the advice and consent of the Senate. The President may declare that the United States does not accept an amendment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70bf19d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amendments to Annexes","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf70bf19e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80508/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, with the concurrence of the Secretary of the department in which the Coast Guard is operating—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf70bf19f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80508/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may propose amendments to the annexes to the Convention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70bf1a0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80508/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may propose a conference for amending annexes to the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70bf1a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80508/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consider and act on amendments to the annexes to the Convention adopted by the Maritime Safety Committee of the International Maritime Organization and communicated to the United States under article X(2) of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70bf1a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80508/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action following approval or objection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a proposed amendment to an annex is approved by the United States, the amendment shall enter into force as provided in article X of the Convention. If a proposed amendment is objected to, the Secretary of State promptly shall communicate the objection as provided in article X(3) of the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70bf1a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80508/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of Arbitrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of State, with the concurrence of the Secretary of the department in which the Coast Guard is operating, shall appoint an arbitrator when one is required to resolve a dispute within the meaning of article XIII of the Convention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf70bf1a4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s11"},"text":"Pub. L. 109–304, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1697"},"text":"120 Stat. 1697","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf70bf1a5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf70bf1a6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf70bf1a7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80508","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1507.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/208/s8"},"text":"Pub. L. 95–208, § 8","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 13, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1479"},"text":"91 Stat. 1479","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
