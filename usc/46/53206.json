{"tag":"section","attrib":{"id":"idf6d2b9b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53206"},"text":null,"children":[{"tag":"num","attrib":{"value":"53206"},"text":"§ 53206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d2b9b6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Payment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b9b7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53206/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, subject to availability of appropriations and other provisions of this section, shall pay to the Contractor for an operating agreement, for each vessel that is covered by the operating agreement, an amount equal to $5,000,000 for each fiscal year 2021 through 2035.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9b8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53206/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This amount shall be paid in equal monthly installments at the end of each month. The amount shall not be reduced except as provided by this section or section 51307(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9b9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Required for Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As a condition of receiving payment under this section for a fiscal year for a vessel, the Contractor for the vessel shall certify that the vessel has been and will be operated in accordance with section 53205(a)(1) for 365 days in each fiscal year. Up to thirty (30) days during which the vessel is drydocked, surveyed, inspected, or repaired shall be considered days of operation for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9ba-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53206/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not make any payment under this chapter for a vessel with respect to any days for which the vessel is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b9bb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53206/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not operated or maintained in accordance with an Operating Agreement under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9bc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53206/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 40 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9bd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53206/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reductions in Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to payments under this chapter for a vessel covered by an Operating Agreement, the Secretary shall make a pro rata reduction for each day less than 365 in a fiscal year that the vessel is not operated in accordance with section 53205(a)(1), with days during which the vessel is drydocked or undergoing survey, inspection or repair to be considered days on which the vessel is operated as provided in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d2b9be-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3521/a"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1995"},"text":"133 Stat. 1995","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3517/b/2"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3517(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3074"},"text":"136 Stat. 3074","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d2b9bf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6d2b9c0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6d2b9c1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" inserted “or section 51307(b)” after “this section”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
