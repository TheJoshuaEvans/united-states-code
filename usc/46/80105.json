{"tag":"section","attrib":{"id":"idf70980e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80105"},"text":null,"children":[{"tag":"num","attrib":{"value":"80105"},"text":"§ 80105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Canadian vessels aiding vessels in United States waters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf70980e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Canadian vessels and wrecking equipment may give aid to Canadian or other vessels and property wrecked, disabled, or in distress in the waters of the United States contiguous to Canada, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf70980e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the canal and improvement of the waters between Lake Erie and Lake Huron; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70980e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Saint Marys River and canal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70980e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reciprocity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply after the President proclaims that privileges reciprocal to those under subsection (a) have been withdrawn or rendered inoperative by the Government of Canada.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf70980ea-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s11"},"text":"Pub. L. 109–304, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1691"},"text":"120 Stat. 1691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf70980eb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf70980ec-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf70980ed-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"ch