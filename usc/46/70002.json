{"tag":"section","attrib":{"id":"idf6f8dfbc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70002"},"text":null,"children":[{"tag":"num","attrib":{"value":"70002"},"text":"§ 70002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may order any vessel, in a port or place subject to the jurisdiction of the United States or in the navigable waters of the United States, to operate or anchor in a manner the Secretary directs if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f8dfbd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has reasonable cause to believe such vessel does not comply with any regulation issued under section 70034 or any other applicable law or treaty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f8dfbe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines such vessel does not satisfy the conditions for port entry set forth in section 70021 or 70022 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f8dfbf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by reason of weather, visibility, sea conditions, port congestion, other hazardous circumstances, or the condition of such vessel, the Secretary is satisfied such direction is justified in the interest of safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f8dfc0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIV/s401/a"},"text":"Pub. L. 115–282, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4255"},"text":"132 Stat. 4255","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8508(2)(A), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4755"},"text":"134 Stat. 4755","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f8dfc1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6f8dfc2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6f8dfc3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “or 70022” after “section 70021”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
