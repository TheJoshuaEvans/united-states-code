{"tag":"section","attrib":{"id":"idf6dea051-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713"},"text":null,"children":[{"tag":"num","attrib":{"value":"53713"},"text":"§ 53713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6dea052-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or Administrator shall charge and collect from the obligor fees the Secretary or Administrator considers reasonable for processing the application and monitoring the loan guarantee, including for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dea053-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigating an application for a guarantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea054-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appraising property offered as security for a guarantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea055-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issuing a commitment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea056-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing services related to an escrow fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53715"},"text":"section 53715 of this title","children":[],"tail":" or a deposit fund under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53716"},"text":"section 53716 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea057-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspecting property during construction, reconstruction, or reconditioning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea058-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring and providing services related to the obligor’s compliance with any terms related to the obligations, the guarantee, or maintenance of the Secretary or Administrator’s security interests under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea059-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Total Fee Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total fees under subsection (a) may not exceed 0.5 percent of the original principal amount of the obligations to be guaranteed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea05a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees for Independent Analysis.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dea05b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or Administrator may charge and collect fees to cover the costs of independent analysis under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53703/c"},"text":"section 53703(c) of this title","children":[],"tail":". Notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", any fee collected under this subsection shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dea05c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be credited as an offsetting collection to the account that finances the administration of the loan guarantee program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dea05d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be available for expenditure only to pay the costs of activities and services for which the fee is imposed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dea05e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea05f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53713/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fee limitation inapplicable","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Fees collected under this subsection are not subject to the limitation of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6dea060-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1612"},"text":"120 Stat. 1612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/D"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/10/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(10)(B)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/