"},{"tag":"html:a","attrib":{"href":"/us/pl/92/507/s3"},"text":"Pub. L. 92–507, § 3","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 19, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/913"},"text":"86 Stat. 913","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/136"},"text":"Pub. L. 97–31, § 12(136)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/166"},"text":"95 Stat. 166","children":[],"tail":"; § 1104 renumbered as § 1104A, "},{"tag":"html:a","attrib":{"href":"/us/pl/101/380/tIV/s4115/f/1"},"text":"Pub. L. 101–380, title IV, § 4115(f)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/521"},"text":"104 Stat. 521","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/107/314/tXXXV/s3503/2"},"text":"Pub. L. 107–314, title XXXV, § 3503(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/116/2754"},"text":"116 Stat. 2754","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/108/136/tXXXV/s3526/2"},"text":"Pub. L. 108–136, title XXXV, § 3526(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/117/1801"},"text":"117 Stat. 1801","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53713(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274(f)(1) (proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53713(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274(f)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6dea064-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6dea065-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3506/h/1/A"},"text":"Pub. L. 116–92, § 3506(h)(1)(A)","children":[],"tail":", substituted “reasonable for processing the application and monitoring the loan guarantee, including for—” for “reasonable for—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3506/h/1/B"},"text":"Pub. L. 116–92, § 3506(h)(1)(B)","children":[],"tail":", substituted “or a deposit fund under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53716"},"text":"section 53716 of this title","children":[],"tail":";” for “; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3506/h/1/C"},"text":"Pub. L. 116–92, § 3506(h)(1)(C)","children":[],"tail":", (D), added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3506/h/2/B"},"text":"Pub. L. 116–92, § 3506(h)(2)(B)","children":[],"tail":"–(D), designated existing provisions as par. (1) and inserted heading, redesignated former pars. (1) to (3) as subpars. (A) to (C), respectively, of par. (1) and realigned margins, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3506/h/2/A"},"text":"Pub. L. 116–92, § 3506(h)(2)(A)","children":[],"tail":", which directed amendment of par. (1) of subsec. (c) by substituting “under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53703/c"},"text":"section 53703(c) of this title","children":[],"tail":"” for “under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53708/d"},"text":"section 53708(d) of this title","children":[],"tail":"”, was executed by making the substitution in introductory provisions of subsec. (c) to reflect the probable intent of Congress and the subsequent designation of the provisions of subsec. (c) as subsec. (c)(1). See above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/D"},"text":"Pub. L. 109–163, § 3507(a)(1)(D)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/a/10/B"},"text":"Pub. L. 110–181, § 3522(a)(10)(B)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/D"},"text":"Pub. L. 109–163, § 3507(a)(1)(D)","children":[],"tail":", into this section, by inserting “or Administrator” after “Secretary” wherever appearing in introductory provisions. See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/D"},"text":"Pub. L. 109–163, § 3507(a)(1)(D)","children":[],"tail":", which directed the amendment of section 1274(f) of the former Appendix to this title from which this section was derived, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":". See 2008 Amendment note for subsecs. (a), (c) and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
