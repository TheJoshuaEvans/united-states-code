{"tag":"section","attrib":{"id":"idf6bfa661-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51304"},"text":null,"children":[{"tag":"num","attrib":{"value":"51304"},"text":"§ 51304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional appointments from particular areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6bfa662-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Countries in Western Hemisphere","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may appoint individuals from countries in the Western Hemisphere other than the United States to receive instruction at the United States Merchant Marine Academy. Not more than 12 individuals may receive instruction under this subsection at the same time, and not more than 2 individuals from the same country may receive instruction under this subsection at the same time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bfa663-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Countries Generally","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bfa664-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation, with the approval of the Secretary of State, may appoint individuals from countries other than the United States to receive instruction at the Academy. Not more than 30 individuals may receive instruction under this subsection at the same time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa665-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall ensure that the country from which an individual comes under this subsection will reimburse the Secretary for the cost (as determined by the Secretary) of the instruction and allowances received by the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bfa666-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Panama","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bfa667-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation, with the approval of the Secretary of State, may appoint individuals from Panama to receive instruction at the Academy. Individuals appointed under this subsection are in addition to those appointed under any other provision of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bfa668-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall be reimbursed for the cost (as determined by the Secretary) of the instruction and allowances received by an individual appointed under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bfa669-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowances and Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Individuals receiving instruction under this section are entitled to the same allowances and are subject to the same regulations on admission, attendance, discipline, resignation, discharge, dismissal, and graduation, as cadets at the Academy appointed from the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6bfa66a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1572"},"text":"120 Stat. 1572","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6bfa66b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6bfa66c