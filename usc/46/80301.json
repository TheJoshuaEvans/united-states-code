{"tag":"section","attrib":{"id":"idf7098101-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80301"},"text":null,"children":[{"tag":"num","attrib":{"value":"80301"},"text":"§ 80301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7098102-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may make agreements with interested maritime countries to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7098103-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain in the North Atlantic Ocean a service of ice patrol, of study and observation of ice and current conditions, and of assistance to vessels and their crews requiring assistance within the limits of the patrol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7098104-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a service of study and observation of ice and current conditions in the waters affecting the set and drift of ice in the North Atlantic Ocean; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7098105-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80301/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take all practicable steps to ensure the destruction or removal of derelicts in the northern part of the Atlantic Ocean, east of the line drawn from Cape Sable to a point in latitude 34 degrees north, longitude 70 degrees west, if the destruction or removal is necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098106-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Between Countries","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may include in an agreement under subsection (a) a provision for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7098107-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment to the United States Government by other countries for their proportionate share of the expense of maintaining the services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7098108-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contribution by the Government for its proportionate share if the agreement provides for another country to maintain the services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098109-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Payments received pursuant to subsection (b)(1) shall be credited to the appropriation for operations and support of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf709810a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s11"},"text":"Pub. L. 109–304, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1692"},"text":"120 Stat. 1692","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIII/s314/a/1"},"text":"Pub. L. 113–281, title III, § 314(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3049"},"text":"128 Stat. 3049","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8513(b), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4761"},"text":"134 Stat. 4761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf709810b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf709810c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf709810d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"chil