{"tag":"section","attrib":{"id":"idf6c46226-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51321"},"text":null,"children":[{"tag":"num","attrib":{"value":"51321"},"text":"§ 51321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for scientific and educational research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c46227-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defined Term","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “qualifying research grant” is a grant that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c46228-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is awarded on a competitive basis by the Federal Government (except for the Department of Transportation), a State, a corporation, a fund, a foundation, an educational institution, or a similar entity that is organized and operated primarily for scientific or educational purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46229-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is to be used to carry out a research project with a scientific or educational purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c4622a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Qualifying Research Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States Merchant Marine Academy may compete for and accept qualifying research grants if the work under the grant is to be carried out by a professor or instructor of the United States Merchant Marine Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c4622b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration of Grant Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c4622c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51321/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator shall establish a separate account for administering funds received from research grants under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c4622d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51321/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of grant funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Superintendent shall use grant funds deposited into the account established pursuant to paragraph (1) in accordance with applicable regulations and the terms and conditions of the respective grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c4622e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Related Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to such limitations as may be provided in appropriations Acts, appropriations available for the United States Merchant Marine Academy may be used to pay expenses incurred by the Academy in applying for, and otherwise pursuing, a qualifying research grant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c4622f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dC/tXXXV/s3512/a"},"text":"Pub. L. 115–91, div. C, title XXXV, § 3512(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1918"},"text":"131 Stat. 1918","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
