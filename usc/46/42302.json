{"tag":"section","attrib":{"id":"idf6b3bf91-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42302"},"text":null,"children":[{"tag":"num","attrib":{"value":"42302"},"text":"§ 42302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b3bf92-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Maritime Commission shall investigate whether any laws, rules, regulations, policies, or practices of a foreign government, or any practices of a foreign carrier or other person providing maritime or maritime-related services in a foreign country, result in the existence of conditions that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bf93-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adversely affect the operations of United States carriers in United States oceanborne trade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bf94-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not exist for foreign carriers of that country in the United States under the laws of the United States or as a result of acts of United States carriers or other persons providing maritime or maritime-related services in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bf95-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initiation of Investigation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An investigation under subsection (a) may be initiated by the Commission on its own motion or on the petition of any person, including another component of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bf96-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for Decision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall complete an investigation under this section and render a decision within 120 days after it is initiated. However, the Commission may extend this 120-day period for an additional 90 days if the Commission is unable to obtain sufficient information to determine whether a condition specified in subsection (a) exists. A notice providing an extension shall state clearly the reasons for the extension.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b3bf97-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1552"},"text":"120 Stat. 1552","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b3bf98-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b3bf99-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b3bf9a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42302(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1710a(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/418/tX/s10002/b"},"text":"Pub. L. 100–418, title X, § 10002(b)","children":[],"tail":", (c), "},{"tag":"html:span","attrib":{},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/1570"},"text":"102 Stat. 1570","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tI/s111/4"},"text":"Pub. L. 105–258, title I, § 111(4)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1911"},"text":"112 Stat. 1911","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42302(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1710a(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42302(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1710a(c)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “including another component of the United States Government” are substituted for “including any common carrier, shipper, shippers’ association, ocean transportation intermediary, or marine terminal operator, or any branch, department, agency, or other component of the Government of the United States” for consistency with section 42101(b) of the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
