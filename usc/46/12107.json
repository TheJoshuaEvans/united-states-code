{"tag":"section","attrib":{"id":"idf69255cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12107"},"text":null,"children":[{"tag":"num","attrib":{"value":"12107"},"text":"§ 12107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wrecked vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf69255d0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel is a wrecked vessel under this chapter if it—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf69255d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was wrecked on a coast of the United States or adjacent waters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69255d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has undergone repairs in a shipyard in the United States equal to at least 3 times the appraised salvage value of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69255d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appraisals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may appoint a board of three appraisers to determine whether a vessel satisfies subsection (a)(2). The costs of the appraisal shall be paid by the owner of the vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf69255d4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1494"},"text":"120 Stat. 1494","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69255d5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69255d6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf69255d7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":nul