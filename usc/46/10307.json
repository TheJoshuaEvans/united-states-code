{"tag":"section","attrib":{"id":"idf68b2923-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10307"},"text":null,"children":[{"tag":"num","attrib":{"value":"10307"},"text":"§ 10307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Posting agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"At the beginning of a voyage, the master shall have a legible copy of the agreement required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s10302"},"text":"section 10302 of this title","children":[],"tail":", omitting signatures, exhibited in a part of the vessel accessible to the crew."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf68b2924-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/564"},"text":"97 Stat. 564","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/206/tIV/s405"},"text":"Pub. L. 103–206, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2436"},"text":"107 Stat. 2436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68b2925-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68b2926-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68b2927-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10307","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:577","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10307 requires the master to post a copy of the shipping agreement in a part of the vessel accessible to the crew prior to the commencement of a voyage. The posting must be done in a manner that gives seamen adequate notice of the particulars of the pending voyage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68b2928-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68b2929-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206"},"text":"Pub. L. 103–206","children":[],"tail":" struck out at end “A master violating this section is liable to the United States Government for a civil penalty of $100.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
