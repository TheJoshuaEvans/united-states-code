{"tag":"section","attrib":{"id":"idf6c1f0b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51309"},"text":null,"children":[{"tag":"num","attrib":{"value":"51309"},"text":"§ 51309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Academic degree","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c1f0b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bachelor’s Degree","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c1f0b6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51309/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Superintendent of the United States Merchant Marine Academy may confer the degree of bachelor of science on an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c1f0b7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51309/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has met the conditions prescribed by the Secretary of Transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c1f0b8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51309/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a citizen of the United States, has passed the examination for a merchant marine officer’s license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c1f0b9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51309/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of physical or psychological disqualification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual not able or allowed to take the examination for a merchant marine officer’s license solely due to a documented medical or psychological condition shall not be denied a degree for not taking the examination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f0ba-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Master’s Degree","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Superintendent of the Academy may confer a master’s degree on an individual who has met the conditions prescribed by the Secretary. A master’s degree program may be funded through non-appropriated funds. To maintain the appropriate academic standards, the program shall be accredited by the appropriate accreditation body. Nonappropriated funds received for this purpose shall be credited to the Maritime Administration’s Operations and Training appropriation, to remain available until expended, for those expenses directly related to the purpose of such receipts. The Superintendent shall maintain a separate and detailed accounting of nonappropriated fund receipts and all associated expenses. The Secretary may prescribe regulations necessary to administer such a program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f0bb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51309/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Graduation Not Entitlement To Hold License","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Graduation from the Academy does not entitle an individual to hold a license authorizing service on a merchant vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c1f0bc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51309/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Documented Medical or Psychological Condition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section the term “documented medical or psychological condition” means, with respect to an individual, a physical disqualification or psychological condition, including a mental health condition arising from sexual assault or sexual harassment, for which the individual has been treated or is being treated by a medical or psychological provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c1f0bd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1574"},"text":"120 Stat. 1574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dC/tXXXV/s3514"},"text":"Pub. L. 111–84, div. C, title XXXV, § 3514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2724"},"text":"123 Stat. 2724","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3511"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3065"},"text":"136 Stat. 3065","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c1f0be-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6c1f0bf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6c1f0c0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (