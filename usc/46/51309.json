t":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3511/1"},"text":"Pub. L. 117–263, § 3511(1)","children":[],"tail":", in heading, inserted “or psychological” after “physical”, and, in text, inserted “able or” before “allowed” and substituted “solely due to a documented medical or psychological condition shall” for “only because of physical disqualification may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3511/2"},"text":"Pub. L. 117–263, § 3511(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" inserted before last sentence “Nonappropriated funds received for this purpose shall be credited to the Maritime Administration’s Operations and Training appropriation, to remain available until expended, for those expenses directly related to the purpose of such receipts. The Superintendent shall maintain a separate and detailed accounting of nonappropriated fund receipts and all associated expenses.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
