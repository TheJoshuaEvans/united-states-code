{"tag":"section","attrib":{"id":"idf66047fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3304"},"text":null,"children":[{"tag":"num","attrib":{"value":"3304"},"text":"§ 3304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transporting individuals in addition to crew","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf66047fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A documented vessel transporting cargo that transports not more than 12 individuals in addition to the crew on international voyages, or not more than 16 individuals in addition to the crew on other voyages, is not subject to inspection as a passenger vessel or a small passenger vessel if the vessel is otherwise subject to inspection under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66047fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except when subsection (e) of this section applies, before an individual in addition to the crew is transported on a vessel as permitted by this section, the owner, charterer, managing operator, agent, master, or individual in charge of the vessel first shall notify the individual of the presence on board of dangerous articles as defined by law, and of other conditions or circumstances that would constitute a risk of safety to the individual on board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66047fe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A privilege authorized by this section applies to a vessel of a foreign country that affords a similar privilege to vessels of the United States in trades not restricted to vessels under its own flag.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66047ff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A fishing, fish processing, or fish tender vessel that transports not more than 12 individuals employed in the fishing industry in addition to the crew is not subject to inspection as a passenger or small passenger vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6604800-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3304/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may by regulation allow individuals in addition to the crew to be transported in an emergency or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2304"},"text":"section 2304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6604801-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/513"},"text":"97 Stat. 513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/364/tIV/s402/4"},"text":"Pub. L. 98–364, title IV, § 402(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/446"},"text":"98 Stat. 446","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/307/s1/5/A"},"text":"Pub. L. 99–307, § 1(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-19"},"text":"May 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/444"},"text":"100 Stat. 444","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6604802-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6604803-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6604804-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3304","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:390–393","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:882","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3304 permits the carriage of not more than 12 individuals in addition to the crew on international voyages or not more than 16 individuals in addition to the crew on other voyages without subjecting a documented vessel carrying cargo to the inspection requirements of a passenger vessel. This section permits the bulk of vessels subject to the International Convention for Safety of Life at Sea to carry up to 12 passengers and to permit other cargo vessels, primarily those engaged in the coastwise trade, to carry up to 16 passengers without being categorized as passenger vessels. It also requires that these individuals be notified of the presence of dangerous articles or other conditions or circumstances that constitute a risk of safety. This is of prime importance on tank vessels that carry flammable or hazardous cargoes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6604805-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6604806-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/307/s1/5/A/i"},"text":"Pub. L. 99–307, § 1(5)(A)(i)","children":[],"tail":", substituted “Transporting” for “Carrying” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/307/s1/5/A/ii"},"text":"Pub. L. 99–307, § 1(5)(A)(ii)","children":[],"tail":", substituted “transporting cargo that transports” for “carrying cargo that carries” and inserted “if the vessel is otherwise subject to inspection under this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/307/s1/5/A/iii"},"text":"Pub. L. 99–307, § 1(5)(A)(iii)","children":[],"tail":", substituted “Except when subsection (e) of this section applies, before” for “Before” and “transported” for “carried”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/307/s1/5/A/iv"},"text":"Pub. L. 99–307, § 1(5)(A)(iv)","children":[],"tail":", substituted “A privilege” for “The privilege”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/307/s1/5/A/v"},"text":"Pub. L. 99–307, § 1(5)(A)(v)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364"},"text":"Pub. L. 98–364","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6604807-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf6604808-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1984-04-15"},"text":"Apr. 15, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/89/s2/g/1"},"text":"section 2(g)(1) of Pub. L. 98–89","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
