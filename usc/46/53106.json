/pl/118/159/s3502/c/3"},"text":"Pub. L. 118–159, § 3502(c)(3)","children":[],"tail":", added subpar. (D). Former subpar. (D) redesignated (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/c/4"},"text":"Pub. L. 118–159, § 3502(c)(4)","children":[],"tail":", substituted “$6,675,500” for “$5,800,000” and “2026, 2027,” for “2027”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/c/2"},"text":"Pub. L. 118–159, § 3502(c)(2)","children":[],"tail":", redesignated subpar. (D) as (E). Former subpar. (E) redesignated (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/c/5"},"text":"Pub. L. 118–159, § 3502(c)(5)","children":[],"tail":", substituted “$6,855,000” for “$6,300,000” and “and 2030;” for “, 2030, and 2031; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/c/2"},"text":"Pub. L. 118–159, § 3502(c)(2)","children":[],"tail":", redesignated subpar. (E) as (F). Former subpar. (F) redesignated (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/c/6"},"text":"Pub. L. 118–159, § 3502(c)(6)","children":[],"tail":", substituted “$7,040,000” for “$6,800,000” and “2032;” for “2032, 2033, 2034, and 2035.”, and inserted “2031 and” before “2032”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/c/2"},"text":"Pub. L. 118–159, § 3502(c)(2)","children":[],"tail":", redesignated subpar. (F) as (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(H) to (K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/c/7"},"text":"Pub. L. 118–159, § 3502(c)(7)","children":[],"tail":", added subpars. (H) to (K)."}],"tai