{"tag":"section","attrib":{"id":"idf6d047d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106"},"text":null,"children":[{"tag":"num","attrib":{"value":"53106"},"text":"§ 53106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d047d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Payment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d047d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, subject to the availability of appropriations and the other provisions of this section, shall pay to the contractor for an operating agreement, for each vessel that is covered by the operating agreement, an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d047da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for each of fiscal years 2018, 2019, and 2020;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,233,463 for fiscal year 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,300,000 for each of fiscal years 2022, 2023,,","children":[{"tag":"ref","attrib":{"idref":"fn002036"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002036"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Second comma probably should not appear."}],"tail":" and 2024;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,500,000 for each of fiscal years 2025 and 2026;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,675,500 for each of fiscal years 2027 and 2028;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,855,000 for each of fiscal years 2029and 2030;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,040,000 for each of fiscal years 2031 and 2032;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,230,000 for each of fiscal years 2033 and 2034;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,426,000 for each of fiscal years 2035 and 2036;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,626,000 for each of fiscal years 2037 and 2038; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,832,000 for each of fiscal years 2039 and 2040.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount shall be paid in equal monthly installments at the end of each month. The amount shall not be reduced except as provided by this section or section 51307(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Required for Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As a condition of receiving payment under this section for a fiscal year for a vessel, the contractor for the vessel shall certify, in accordance with regulations issued by the Secretary, that the vessel has been and will be operated in accordance with paragraph (1) and (2) of section 53105(a), as otherwise applicable with respect to such vessel, for at least 320 days in the fiscal year. Days during which the vessel is drydocked, surveyed, inspected, or repaired shall be considered days of operation for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall not make any payment under this chapter for a vessel with respect to any days for which the vessel is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d047e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a charter to the United States Government, other than a charter pursuant to an Emergency Preparedness Agreement under section 53107;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not operated or maintained in accordance with an operating agreement under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" more than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d047eb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 years of age, except as provided in subparagraph (B); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047ec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 years of age, in the case of a tank vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047ed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reductions in Payments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to payments under this chapter for a vessel covered by an operating agreement, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d047ee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraph (2), shall not reduce any payment for the operation of the vessel to carry military or other preference cargoes under section 55302(a), 55304, 55305, or 55314 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2631"},"text":"section 2631 of title 10","children":[],"tail":", or any other cargo preference law of the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047ef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not make any payment for any day that the vessel is engaged in transporting more than 7,500 tons of civilian bulk preference cargoes pursuant to section 55302(a), 55305, or 55314 of this title that is bulk cargo; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047f0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make a pro rata reduction in payment for each day less than 320 in a fiscal year that the vessel is not operated in accordance with paragraph (1) and (2) of section 53105(a), as otherwise applicable with respect to such vessel, with days during which the vessel is drydocked or undergoing survey, inspection, or repair considered to be days on which the vessel is operated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047f1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation Regarding Noncontiguous Domestic Trade","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d047f2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No contractor shall receive payments pursuant to this chapter during a period in which it participates in noncontiguous domestic trade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047f3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall not apply to any person that is a citizen of the United States within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":", applying the 75 percent ownership requirement of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047f4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53106/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participates in a noncontiguous domestic trade defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection the term “participates in a noncontiguous domestic trade” means directly or indirectly owns, charters, or operates a vessel engaged in transportation of cargo between a point in the contiguous 48 States and a point in Alaska, Hawaii, or Puerto Rico, other than a point in Alaska north of the Arctic Circle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d047f5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dC/tXXXV/s3531/a"},"text":"Pub. L. 108–136, div. C, title XXXV, § 3531(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1813"},"text":"117 Stat. 1813","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/5"},"text":"Pub. L. 109–304, § 13(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1701"},"text":"120 Stat. 1701","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dC/tXXXV/s3502/c"},"text":"Pub. L. 109–364, div. C, title XXXV, § 3502(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2516"},"text":"120 Stat. 2516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dC/tXXXV/s3502/2"},"text":"Pub. L. 111–383, div. C, title XXXV, § 3502(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4518"},"text":"124 Stat. 4518","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dC/tXXXV/s3508/f"},"text":"Pub. L. 112–239, div. C, title XXXV, § 3508(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2225"},"text":"126 Stat. 2225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dO/tI/s101/e/1"},"text":"Pub. L. 114–113, div. O, title I, § 101(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2988"},"text":"129 Stat. 2988","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3502/b"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2775"},"text":"130 Stat. 2775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dC/tXXXV/s3503/b"},"text":"Pub. L. 115–91, div. C, title XXXV, § 3503(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1911"},"text":"131 Stat. 1911","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3546"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3546","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2327"},"text":"132 Stat. 2327","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3502/c"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3502(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1969"},"text":"133 Stat. 1969","children":[],"tail":"; "},{"tag":