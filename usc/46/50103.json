{"tag":"section","attrib":{"id":"idf6b609d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50103"},"text":null,"children":[{"tag":"num","attrib":{"value":"50103"},"text":"§ 50103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations of essential services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b609da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Essential Services, Routes, and Lines","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b609db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall investigate, determine, and keep current records of the ocean services, routes, and lines from ports in the United States, or in the territories and possessions of the United States, to foreign markets, which the Secretary determines to be essential for the promotion, development, expansion, and maintenance of the foreign commerce of the United States. In making such a determination, the Secretary shall consider and give due weight to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b609dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50103/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of maintaining each line;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b609dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50103/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the probability that a line cannot be maintained except at a heavy loss disproportionate to the benefit to foreign trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b609de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50103/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of voyages and types of vessels that should be employed in a line;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b609df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50103/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intangible benefit of maintaining a line to the foreign commerce of the United States, the national defense, and other national requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b609e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50103/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other facts and conditions a prudent business person would consider when dealing with the person’s own business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b609e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Saint lawrence seaway","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of paragraph (1), the Secretary shall establish services, routes, and lines that reflect the seasonal closing of the Saint Lawrence Seaway and provide for alternate routing of vessels through a different range of ports during that closing to maintain continuity of service on a year-round basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b609e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bulk Cargo Carrying Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall investigate, determine, and keep current records of the bulk cargo carrying services that should be provided by vessels of the United States (whether or not operating on particular services, routes, or lines) for the promotion, development, expansion, and maintenance of the foreign commerce of the United States and the national defense or other national requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b609e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Types of Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall investigate, determine, and keep current records of the type, size, speed, method of propulsion, and other requirements of the vessels, including express-liner or super-liner vessels, that should be employed in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b609e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the services, routes, or lines described in subsection (a), and the frequency and regularity of the voyages of the vessels, with a view to furnishing adequate, regular, certain, and permanent service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b609e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bulk cargo carrying services described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b609e6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1557"},"text":"120 Stat. 1557","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b609e7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b609e8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b609e9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","att