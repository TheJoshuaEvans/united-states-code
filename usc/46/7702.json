{"tag":"section","attrib":{"id":"idf67f4287-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702"},"text":null,"children":[{"tag":"num","attrib":{"value":"7702"},"text":"§ 7702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative procedure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf67f4288-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 551–559 of title 5 apply to each hearing under this chapter about suspending or revoking a license, certificate of registry, or merchant mariner’s document.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67f4289-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The individual whose license, certificate of registry, or merchant mariner’s document has been suspended or revoked under this chapter may appeal, within 30 days, the suspension or revocation to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67f428a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67f428b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall request a holder of a license, certificate of registry, or merchant mariner’s document to make available to the Secretary, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30305/b/7"},"text":"section 30305(b)(7) of title 49","children":[],"tail":", all information contained in the National Driver Register related to an offense described in section 205(a)(3)(A) or (B) of that Act "},{"tag":"ref","attrib":{"idref":"fn002012"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" committed by the individual."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67f428c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall require the testing of the holder of a license, certificate of registry, or merchant mariner’s document for use of alcohol and dangerous drugs in violation of law or Federal regulation. The testing may include preemployment (with respect to dangerous drugs only), periodic, random, and reasonable cause testing, and shall include post-accident testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67f428d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67f428e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may temporarily, for not more than 45 days, suspend and take possession of the license, certificate of registry, or merchant mariner’s document held by ‘an ","children":[{"tag":"ref","attrib":{"idref":"fn002013"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002013"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Opening single quotation mark probably should not appear."}],"tail":" individual—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf67f428f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf67f4290-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that individual performs a safety sensitive function on a vessel, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf67f4291-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" there is probable cause to believe that the individual—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf67f4292-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/d/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has, while acting under the authority of that license, certificate, or document, performed the safety sensitive function in violation of law or Federal regulation regarding use of alcohol or a dangerous drug;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf67f4293-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/d/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been convicted of an offense that would prevent the issuance or renewal of the license, certificate, or document;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf67f4294-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/d/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the 3-year period preceding the initiation of a suspension proceeding, has been convicted of an offense described in section 30304(a)(3)(A) or (B) of title 49; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf67f4295-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/d/1/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a security risk that poses a threat to the safety or security of a vessel or a public or commercial structure located within or adjacent to the marine environment; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67f4296-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is probable cause to believe that the individual has violated company policy and is a security risk that poses a threat to other individuals on the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67f4297-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7702/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a license, certificate, or document is temporarily suspended under this section, an expedited hearing under subsection (a) of this section shall be held within 30 days after the temporary suspension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67f4298-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/546"},"text":"97 Stat. 546","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/36/s1/a/3"},"text":"Pub. L. 99–36, § 1(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-05-15"},"text":"May 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/67"},"text":"99 Stat. 67","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV/s4103/a/1"},"text":"Pub. L. 101–380, title IV, § 4103(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/510"},"text":"104 Stat. 510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIII/s304/a"},"text":"Pub. L. 105–383, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3419"},"text":"112 Stat. 3419","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tIV/s407"},"text":"Pub. L. 108–293, title IV, § 407","children":[],"tail":", title VI, § 609(2), "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1044"},"text":"118 Stat. 1044","children":[],"tail":", 1058; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3546/f"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3546(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2326"},"text":"132 Stat. 2326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/i"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1758"},"text":"139 Stat. 1758","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67f4299-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf67f429a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf67f429b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7702","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"..............................................","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7702(a) provides that Sections 551–559 of title 5 of the United States Code shall apply to each involving the suspension or revocation of a license, certificate, or document.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) allows an individual whose license, certificate, or document has been suspended or revoked to appeal it to the Secretary within 30 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf67f429c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf67f429d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 205(a)(3)(A) or (B) of that Act, referred to in subsec. (c)(1), means section 205(a)(3)(A), (B) of the National Driver Register Act of 1982, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/364"},"text":"Pub. L. 97–364","children":[],"tail":", which was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s401"},"text":"section 401 of Title 23","children":[],"tail":", Highways, and was repealed and restated in "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s30304"},"text":"section 30304 of Title 49","children":[],"tail":", Transportation, by "},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":", §§ 1(e), 7(b), "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/975"},"text":"108 Stat. 975","children":[],"tail":", 1379."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf67f429e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “an individual—” for “an individual” in introductory provisions, inserted subpar. (A) designation before “if—”, redesignated former subpars. (A) and (B) as cls. (i) and (ii), respectively, of subpar. (A), and added subpar. (B),"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s30305/b/7"},"text":"section 30305(b)(7) of title 49","children":[],"tail":"” for “section 206(b)(4) of the National Driver Register Act of 1982 ("},{"tag":"ref","attrib":{"href":"/us/usc/t23/s401"},"text":"23 U.S.C. 401","children":[],"tail":" note)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s407/1"},"text":"Pub. L. 108–293, § 407(1)","children":[],"tail":", substituted “if—” for “if, when acting under the authority of that license, certificate, or document—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec.(d)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s407/2"},"text":"Pub. L. 108–293, § 407(2)","children":[],"tail":", inserted “, while acting under the authority of that license, certificate, or document,” after “has”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s609/2"},"text":"Pub. L. 108–293, § 609(2)","children":[],"tail":", substituted “section 30304(a)(3)(A) or (B) of title 49” for “section 205(a)(3)(A) or (B) of the National Driver Register Act of 1982”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s407/3"},"text":"Pub. L. 108–293, § 407(3)","children":[],"tail":"–(5), added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383"},"text":"Pub. L. 105–383","children":[],"tail":" inserted second sentence and struck out former second sentence which read as follows: “The testing may include preemployment (with respect to dangerous drugs only), periodic, random, reasonable cause, and post accident testing.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/36"},"text":"Pub. L. 99–36","children":[],"tail":" substituted “mariner’s” for “mariners’ ”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf67f429f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf67f42a0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" applicable to incidents occurring after "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/s1020"},"text":"section 1020 of Pub. L. 101–380","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
