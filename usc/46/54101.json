2"},"text":"136 Stat. 3092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXV/s3535/b"},"text":"Pub. L. 118–159, div. C, title XXXV, § 3535(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2314"},"text":"138 Stat. 2314","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e35b31-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6e35b32-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6e35b33-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the National Defense Authorization Act for Fiscal Year 2020, referred to in subsec. (d)(2)(C)(i)(I)(aa), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf6e35b34-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 54101, added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3523/a/6/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3523(a)(6)(B)","children":[],"tail":"–(D), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/599"},"text":"122 Stat. 599","children":[],"tail":", which related to assistance for small shipyards and maritime communities, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/417/dC/tXXXV/s3508/b"},"text":"Pub. L. 110–417, div. C, title XXXV, § 3508(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4769"},"text":"122 Stat. 4769","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dA/tX/s1073/c/14"},"text":"Pub. L. 111–84, div. A, title X, § 1073(c)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2475"},"text":"123 Stat. 2475","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6e35b35-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" struck out subsec. (i). Text read as follows: “There are authorized to be appropriated to the Administrator of the Maritime Administration for fiscal year 2021 to carry out this section $20,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “The Administrator may not award more than 25 percent of the funds appropriated to carry out this section for any fiscal year to any small shipyard in one geographic location that has more than 600 employees.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “for fiscal year 2021 to carry out this section $20,000,000” for “for each of fiscal years 2020 and 2021 to carry out this section $40,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3507/a"},"text":"Pub. L. 116–92, § 3507(a)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s3507/b"},"text":"Pub. L. 116–92, § 3507(b)","children":[],"tail":", substituted “2020 and 2021” for “2018, 2019, and 2020” and “$40,000,000” for “$35,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3511"},"text":"Pub. L. 115–232, § 3511","children":[],"tail":", added par. (2), redesignated former pars. (2) and (3) as (3) and (4), respectively, and, in par. (4), substituted “paragraph (3)” for “paragraph (2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3546/r"},"text":"Pub. L. 115–232, § 3546(r)","children":[],"tail":", added par. (2) and struck out former par. (2) consisting of subpar. (A) and cls. (i) to (iii) which related to minimum standards for payment or reimbursement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3505/a/1"},"text":"Pub. L. 115–91, § 3505(a)(1)","children":[],"tail":", struck out “and maritime communities” after “shipyards” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3505/a/2"},"text":"Pub. L. 115–91, § 3505(a)(2)","children":[],"tail":", substituted “relating to shipbuilding, ship repair, and associated industries.” for “in communities whose economies are related to or dependent upon the maritime industry.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3505/a/3"},"text":"Pub. L. 115–91, § 3505(a)(3)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Awards","children":[],"tail":".—In providing assistance under the program, the Administrator shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) take into account—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the economic circumstances and conditions of maritime communities;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) projects that would be effective in fostering efficiency, competitive operations, and quality ship construction, repair, and reconfiguration; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) projects that would be effective in fostering employee skills and enhancing productivity; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) make grants within 120 days after the date of enactment of the appropriations Act for the fiscal year concerned.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3505/a/4"},"text":"Pub. L. 115–91, § 3505(a)(4)","children":[],"tail":", inserted “to” after “may be used” in introductory provisions, added subpars. (A) and (B), and struck out former subpars. (A) to (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) to make capital and related improvements in small shipyards located in or near maritime communities;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) to provide training for workers in communities whose economies are related to the maritime industry; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) for such other purposes as the Administrator determines to be consistent with and supplemental to such activities.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3505/a/5"},"text":"Pub. L. 115–91, § 3505(a)(5)","children":[],"tail":", struck out “unless such use is specifically approved by the Administrator in support of subsection (c)(1)(C)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3505/a/6/C"},"text":"Pub. L. 115–91, § 3505(a)(6)(C)","children":[],"tail":", struck out “Except as provided in paragraph (2),” before “Federal funds”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3505/a/6/A"},"text":"Pub. L. 115–91, § 3505(a)(6)(A)","children":[],"tail":", (B), redesignated par. (3) as (2) and struck out former par. (2) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—If the Administrator determines that a proposed project merits support and cannot be undertaken without a higher percentage of Federal financial assistance, the Administrator may award a grant for such project with a lesser matching requirement than is described in paragraph (1).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s3501/b"},"text":"Pub. L. 115–91, § 3501(b)","children":[],"tail":", substituted “2018, 2019, and 2020 to carry out this section $35,000,000” for “2015 through 2017 to carry out this section—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) $5,000,000 for training grants; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) $25,000,000 for capital and related improvements”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" substituted “2015 through 2017” for “2009 through 2013” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
