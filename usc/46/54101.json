{"tag":"section","attrib":{"id":"idf6e35af7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101"},"text":null,"children":[{"tag":"num","attrib":{"value":"54101"},"text":"§ 54101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for small shipyards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e35af8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Administrator of the Maritime Administration shall execute agreements with shipyards to provide assistance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e35af9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the form of grants, loans, and loan guarantees to small shipyards for capital improvements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35afa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for maritime training programs to foster technical skills and operational productivity relating to shipbuilding, ship repair, and associated industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35afb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Awards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e35afc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing assistance under the program, the Administrator shall consider projects that foster—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e35afd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efficiency, competitive operations, and quality ship construction, repair, and reconfiguration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35afe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee skills and enhanced productivity related to shipbuilding, ship repair, and associated industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35aff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing of grant notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall post a Notice of Funding Opportunity regarding grants awarded under this section not more than 15 days after the date of enactment of the appropriations Act for the fiscal year concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35b00-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing of grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall award grants under this section not later than 120 days after the date of the enactment of the appropriations Act for the fiscal year concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35b01-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reuse of unexpended grant funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (3), amounts awarded as a grant under this section that are not expended by the grantee shall remain available to the Administrator for use for grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35b02-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e35b03-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance provided under this section may be used to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e35b04-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make capital and related improvements in small shipyards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35b05-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training for workers in shipbuilding, ship repair, and associated industries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35b06-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than 2 percent of amounts made available to carry out the program may be used for the necessary costs of grant administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35b07-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Uses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e35b08-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Grants awarded under this section may not be used to construct buildings or other physical facilities or to acquire land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35b09-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Buy america.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e35b0a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), no funds may be obligated by the Administrator of the Maritime Administration under this section, unless each product and material purchased with those funds (including products and materials purchased by a grantee), and including any commercially available off-the-shelf item, is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6e35b0b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unmanufactured article, material, or supply that has been mined or produced in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6e35b0c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a manufactured article, material, or supply that has been manufactured in the United States substantially all from articles, materials, or supplies mined, produced, or manufactured in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35b0d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idf6e35b0e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subparagraph (A), the requirements of that subparagraph shall not apply with respect to a particular product or material if the Administrator determines—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6e35b0f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the application of those requirements would be inconsistent with the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6e35b10-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that such product or material is not available in the United States in sufficient and reasonably available quantities, of a satisfactory quality, or on a timely basis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6e35b11-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that inclusion of a domestic product or material will increase the cost of that product or material by more than 25 percent, with respect to a certain contract between a grantee and that grantee’s supplier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6e35b12-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal register","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A determination made by the Administrator under this subparagraph shall be published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35b13-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"ln this paragraph:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6e35b14-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “commercially available off-the-shelf item” means—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6e35b15-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any item of supply (including construction material) that is—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idf6e35b16-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/C/i/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commercial item, as defined by section 2.101 of title 48, Code of Federal Regulations (as in effect on the date of the enactment of the National Defense Authorization Act for Fiscal Year 2020); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idf6e35b17-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/C/i/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sold in substantial quantities in the commercial marketplace; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6e35b18-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include bulk cargo, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s40102/4"},"text":"section 40102(4) of this title","children":[],"tail":", such as agricultural products and petroleum products."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6e35b19-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “product or material” means an article, material, or supply brought to the site by the recipient for incorporation into the building, work, or project. The term also includes an item brought to the site preassembled from articles, materials, or supplies. However, emergency life safety systems, such as emergency lighting, fire alarm, and audio evacuation systems, that are discrete systems incorporated into a public building or work and that are produced as complete systems, are evaluated as a single and distinct construction material regardless of when or how the individual parts or components of those systems are delivered to the construction site.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6e35b1a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States” includes the District of Columbia, the Commonwealth of Puerto Rico, the Northern Mariana Islands, Guam, American Samoa, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35b1b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matching Requirements; Allocation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e35b1c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Federal funds for any eligible project under this section shall not exceed 75 percent of the total cost of such project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35b1d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of funds.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e35b1e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may not award more than 25 percent of the funds made available to carry out this section for any fiscal year to any small shipyard in one geographic location that has more than 600 employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35b1f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ineligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A maritime training center that has received funds awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51706"},"text":"section 51706 of title 46","children":[],"tail":", United States Code, shall not be eligible for grants under this subsection for training purposes in the same fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35b20-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e35b21-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible for assistance under this section, an applicant shall submit an application, in such form, and containing such information and assurances as the Administrator may require, within 60 days after the date of enactment of the appropriations Act for the fiscal year concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35b22-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum standards for payment or reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each application submitted under paragraph (1) shall include a comprehensive description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e35b23-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35b24-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methodology for implementing the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35b25-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any existing programs or arrangements that can be used to supplement or leverage assistance under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35b26-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedural safeguards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, in consultation with the Office of the Inspector General, shall issue guidelines to establish appropriate accounting, reporting, and review procedures to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e35b27-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant funds are used for the purposes for which they were made available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35b28-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grantees have properly accounted for all expenditures of grant funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35b29-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant funds not used for such purposes and amounts not obligated or expended are returned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35b2a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project approval required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may not award a grant under this section unless the Administrator determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e35b2b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient funding is available to meet the matching requirements of subsection (e);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35b2c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project will be completed without unreasonable delay; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e35b2d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient has authority to carry out the proposed project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35b2e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Audits and Examinations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All grantees under this section shall maintain such records as the Administrator may require and make such records available for review and audit by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35b2f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s54101/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Small Shipyard Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “small shipyard” means a shipyard facility in one geographic location that does not have more than 1,200 employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e35b30-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417/dC/tXXXV/s3508/a"},"text":"Pub. L. 110–417, div. C, title XXXV, § 3508(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4767"},"text":"122 Stat. 4767","children":[],"tail":"; amended "},{"tag":"ref","attri