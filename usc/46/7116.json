{"tag":"section","attrib":{"id":"idf67a5fde-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7116"},"text":null,"children":[{"tag":"num","attrib":{"value":"7116"},"text":"§ 7116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations for merchant mariner credentials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf67a5fdf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Sample Exams","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop a sample merchant mariner credential examination and outline of merchant mariner examination topics on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67a5fe0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each sample examination and outline of topics developed under subsection (a) shall be readily available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67a5fe1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s315/b/1"},"text":"Pub. L. 114–120, title III, § 315(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/62"},"text":"130 Stat. 62","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/c"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1753"},"text":"139 Stat. 1753","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67a5fe2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf67a5fe3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf67a5fe4-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" struck out subsec. (c). Text read as follows: “In this section, the term ‘merchant mariner credential’ has the meaning that term has in section 7510.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
