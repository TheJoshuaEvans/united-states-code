{"tag":"section","attrib":{"id":"idf6ecf82d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55604"},"text":null,"children":[{"tag":"num","attrib":{"value":"55604"},"text":"§ 55604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on marine highway transportation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation, in consultation with the Administrator of the Environmental Protection Agency, may conduct research on marine highway transportation, regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ecf82e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55604/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic effects of marine highway transportation on the United States economy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf82f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55604/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of marine highway transportation, including with respect to the provision of additional transportation options, on rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf830-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55604/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the environmental and transportation benefits to be derived from marine highway transportation alternatives for other forms of transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf831-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55604/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology, vessel design, and other improvements that would reduce emissions, increase fuel economy, and lower costs of marine highway transportation and increase the efficiency of intermodal transfers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf832-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55604/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solutions to impediments to marine highway transportation projects designated under section 55601.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ecf833-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXI/s1121/a"},"text":"Pub. L. 110–140, title XI, § 1121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1761"},"text":"121 Stat. 1761","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8332(d)(4), (5), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4705"},"text":"134 Stat. 4705","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3521/c"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3521(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3078"},"text":"136 Stat. 3078","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ecf834-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","att