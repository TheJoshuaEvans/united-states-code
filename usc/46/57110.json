{"tag":"section","attrib":{"id":"idf6f1b2c1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57110"},"text":null,"children":[{"tag":"num","attrib":{"value":"57110"},"text":"§ 57110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salvage recoveries for subrogated ownership of vessels and cargoes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f1b2c2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Salvage Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation is authorized to enter into marine salvage agreements for the recoveries, sale, and disposal of sunken or damaged vessels, cargoes, or properties owned or insured by or on behalf of the Maritime Administration, the United States Shipping Board, the U.S. Shipping Bureau, the United States Maritime Commission, or the War Shipping Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b2c3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Military Craft","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall consult with the Secretary of the military department concerned prior to engaging in or authorizing any activity under subsection (a) that will disturb sunken military craft, as such term is defined in section 1408(3) of the Ronald W. Reagan National Defense Authorization Act for Fiscal Year 2005 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Public Law 108–375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"10 U.S.C. 113","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b2c4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recoveries","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the net proceeds from salvage agreements entered into as authorized in subsection (a) shall remain available until expended and be distributed as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f1b2c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57110/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fifty percent shall be available to the Administrator of the Maritime Administration for the payment or reimbursement of expenses incurred by or on behalf of State maritime academies or the United States Merchant Marine Academy for facility and training ship maintenance, repair, and modernization, and for the purchase of simulators and fuel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b2c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57110/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The remainder shall be distributed for maritime heritage preservation to the Department of the Interior for grants as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s308703"},"text":"section 308703 of title 54","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b2c7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3509/a"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3509(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1977"},"text":"133 Stat. 1977","children":[],"tail":", § 57111; renumbered § 57110, "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dC/tXXXV/s3514/j/1/A"},"text":"Pub. L. 118–31, div. C, title XXXV, § 3514(j)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/811"},"text":"137 Stat. 811","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b2c8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6f1b2c9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6f1b2ca-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31"},"text":"Pub. L. 118–31","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s57111"},"text":"section 57111 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
