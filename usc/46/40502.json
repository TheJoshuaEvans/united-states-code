{"tag":"section","attrib":{"id":"idf6aedd56-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502"},"text":null,"children":[{"tag":"num","attrib":{"value":"40502"},"text":"§ 40502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6aedd57-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual ocean common carrier or an agreement between or among ocean common carriers may enter into a service contract with one or more shippers subject to the requirements of this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd58-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aedd59-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each service contract entered into under this section by an individual ocean common carrier or an agreement shall be filed confidentially with the Federal Maritime Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd5a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) does not apply to contracts regarding bulk cargo, forest products, recycled metal scrap, new assembled motor vehicles, waste paper, or paper waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd5b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Essential Terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each service contract shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aedd5c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the origin and destination port ranges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd5d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the origin and destination geographic areas in the case of through intermodal movements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd5e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commodities involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd5f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the minimum volume or portion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd60-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the line-haul rate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd61-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd62-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service commitments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd63-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the liquidated damages for nonperformance, if any; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd64-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other essential terms that the Federal Maritime Commission determines necessary or appropriate through a rulemaking process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd65-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of Certain Terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When a service contract is filed confidentially with the Commission, a concise statement of the essential terms specified in paragraphs (1), (3), (4), and (6) of subsection (c) shall be published and made available to the general public in tariff format.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd66-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure of Certain Terms","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aedd67-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the terms “dock area” and “within the port area” have the same meaning and scope as in the applicable collective bargaining agreement between the requesting labor organization and the carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd68-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An ocean common carrier that is a party to or is otherwise subject to a collective bargaining agreement with a labor organization shall, in response to a written request by the labor organization, state whether it is responsible for the following work at a dock area or within a port area in the United States with respect to cargo transportation under a service contract:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6aedd69-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The movement of the shipper’s cargo on a dock area or within the port area or to or from railroad cars on a dock area or within the port area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aedd6a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The assignment of intraport carriage of the shipper’s cargo between areas on a dock or within the port area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aedd6b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The assignment of the carriage of the shipper’s cargo between a container yard on a dock area or within the port area and a rail yard adjacent to the container yard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aedd6c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The assignment of container freight station work and container maintenance and repair work performed at a dock area or within the port area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd6d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Within reasonable time","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The common carrier shall provide the information described in paragraph (2) to the requesting labor organization within a reasonable period of time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd6e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existence of collective bargaining agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not require the disclosure of information by an ocean common carrier unless there exists an applicable and otherwise lawful collective bargaining agreement pertaining to that carrier. A disclosure by an ocean common carrier may not be deemed an admission or an agreement that any work is covered by a collective bargaining agreement. A dispute about whether any work is covered by a collective bargaining agreement and the responsibility of an ocean common carrier under a collective bargaining agreement shall be resolved solely in accordance with the dispute resolution procedures contained in the collective bargaining agreement and the National Labor Relations Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s151"},"text":"29 U.S.C. 151","children":[],"tail":" et seq.), and without reference to this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd6f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect under other laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not affect the lawfulness or unlawfulness under this part or any other Federal or State law of any collective bargaining agreement or element thereof, including any element that constitutes an essential term of a service contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd70-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy for Breach","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless the parties agree otherwise, the exclusive remedy for a breach of a service contract is an action in an appropriate court. The contract dispute resolution forum may not be controlled by or in any way affiliated with a controlled carrier or by the government that owns or controls the carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6aedd71-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1533"},"text":"120 Stat. 1533","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/146/s3"},"text":"Pub. L. 117–146, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1272"},"text":"136 Stat. 1272","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6aedd72-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6aedd73-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6aedd74-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40502(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1707(c)(1) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/98/237/s8/c"},"text":"Pub. L. 98–237, § 8(c)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 20, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/75"},"text":"98 Stat. 75","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tI/s106/b"},"text":"Pub. L. 105–258, title I, § 106(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1905"},"text":"112 Stat. 1905","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40502(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1707(c)(2) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40502(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1707(c)(2) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40502(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1707(c)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40502(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1707(c)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40502(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1707(c)(1) (2d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(5), the words “the National Labor Relations Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s151"},"text":"29 U.S.C. 151","children":[],"tail":" et seq.], the Taft-Hartley Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s141"},"text":"29 U.S.C. 141","children":[],"tail":" et seq.], the Federal Trade Commission Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.], the antitrust laws” are omitted as unnecessary because of the reference to “any other Federal or State law”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6aedd75-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6aedd76-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Labor Relations Act, referred to in subsec. (e)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-07-05/ch372"},"text":"act July 5, 1935, ch. 372","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/449"},"text":"49 Stat. 449","children":[],"tail":", which is classified generally to subchapter II (§ 151 et seq.) of chapter 7 of Title 29, Labor. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s167"},"text":"section 167 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6aedd77-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146"},"text":"Pub. L. 117–146","children":[],"tail":" added par. (9)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
