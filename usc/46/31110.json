{"tag":"section","attrib":{"id":"idf6a7b1a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31110"},"text":null,"children":[{"tag":"num","attrib":{"value":"31110"},"text":"§ 31110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoenas to officers or members of crew","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An officer or member of the crew of a public vessel may not be subpoenaed in a civil action under this chapter without the consent of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a7b1a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31110/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the department or the head of the independent establishment having control of the vessel at the time the cause of action arose; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a7b1a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31110/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the master or commanding officer of the vessel at the time the subpoena is issued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a7b1aa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1522"},"text":"120 Stat. 1522","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a7b1ab-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a7b1ac-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","childre