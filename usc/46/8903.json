{"tag":"section","attrib":{"id":"idf6866eac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8903"},"text":null,"children":[{"tag":"num","attrib":{"value":"8903"},"text":"§ 8903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Self-propelled, uninspected passenger vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A self-propelled, uninspected passenger vessel shall be operated by an individual licensed by the Secretary to operate that type of vessel, under prescribed regulations.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6866ead-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/555"},"text":"97 Stat. 555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/307/s1/14/B"},"text":"Pub. L. 99–307, § 1(14)(B)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"1986-05-19"},"text":"May 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/446"},"text":"100 Stat. 446","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6866eae-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6866eaf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6866eb0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text