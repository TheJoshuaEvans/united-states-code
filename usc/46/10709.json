{"tag":"section","attrib":{"id":"idf68d9aa7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10709"},"text":null,"children":[{"tag":"num","attrib":{"value":"10709"},"text":"§ 10709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68d9aa8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68d9aa9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the money, property, and wages of a seaman, including proceeds from the sale of property, are not more than $1,500 in value, the court, subject to deductions it allows for expenses and at least 60 days after receiving the money, property, and wages, may deliver the money, property, and wages to a claimant proving to be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68d9aaa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10709/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the seaman’s surviving spouse or child;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68d9aab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10709/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entitled to the money, property, and wages under the seaman’s will or under a law or at common law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68d9aac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10709/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entitled to secure probate, or take out letters of administration, although no probate or letters of administration have been issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68d9aad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The court is released from further liability for the money, property, and wages distributed under paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68d9aae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10709/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Instead of acting under paragraphs (1) and (2) of this subsection, the court may require probate or letters of administration to be taken out, and then deliver the money, property, and wages to the legal representative of the seaman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9aaf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the money, property, and wages are more than $1,500 in value, the court, subject to deductions for expenses, shall deliver the money, property, and wages to the legal representative of the seaman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68d9ab0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/574"},"text":"97 Stat. 574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/307/s1/15"},"text":"Pub. L. 99–307, § 1(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-19"},"text":"May 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/446"},"text":"100 Stat. 446","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68d9ab1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68d9ab2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68d9ab3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10709","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:627","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10709 instructs a district court to deliver a deceased seaman’s property and wages to the proper claimant or legal representative. It also discharges the court from liability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68d9ab4-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68d9ab5-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/307"},"text":"Pub. L. 99–307","children":[],"tail":", in text preceding cl. (A), substituted “than $1,500 in value, the court,” for “then $1,500 in value, and” and “wages, may” for “wages, the court may”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
