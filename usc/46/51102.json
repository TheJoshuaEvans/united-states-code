{"tag":"section","attrib":{"id":"idf6bd35da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51102"},"text":null,"children":[{"tag":"num","attrib":{"value":"51102"},"text":"§ 51102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bd35db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Academy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Academy” means the United States Merchant Marine Academy located at Kings Point, New York, and maintained under chapter 513 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd35dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost of education provided","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “cost of education provided” means the financial costs incurred by the United States Government for providing training or financial assistance to students at the Academy and the State maritime academies, including direct financial assistance, room, board, classroom academics, and other training activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd35dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Merchant marine officer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “merchant marine officer” means an individual issued a license by the Coast Guard authorizing service as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bd35de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51102/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a master, mate, or pilot on a documented vessel that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6bd35df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51102/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of at least 1,000 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":" or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6bd35e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51102/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates on the oceans or the Great Lakes; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd35e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51102/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an engineer officer on a documented vessel propelled by machinery of at least 4,000 horsepower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd35e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State maritime academy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State maritime academy” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bd35e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51102/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State maritime academy or college sponsored by a State and assisted under chapter 515 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd35e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51102/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a regional maritime academy or college sponsored by a group of States and assisted under chapter 515 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6bd35e5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1568"},"text":"120 Stat. 1568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6bd35e6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topi