il":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1295a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XIII, § 1302, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/96/453/s2"},"text":"Pub. L. 96–453, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1997"},"text":"94 Stat. 1997","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/143"},"text":"Pub. L. 97–31, § 12(143)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/166"},"text":"95 Stat. 166","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/324/tVII/s708"},"text":"Pub. L. 104–324, title VII, § 708","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3934"},"text":"110 Stat. 3934","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/108/136/tXXXV/s3515/a"},"text":"Pub. L. 108–136, title XXXV, § 3515(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/117/1792"},"text":"117 Stat. 1792","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definition of “Secretary” is omitted as unnecessary because the full title is used the first time the term appears in each section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the definition of “merchant marine office”, the words “documented vessel” are substituted for “vessel . . . which is documented under the laws of the United States” because of the definition of “documented vessel” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"46 U.S.C. 2101","children":[],"tail":", which is being moved to chapter 1 of the revised title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the definition of “State maritime academy”, the words “or territory of the United States” and “or territories of the United States” are omitted as unnecessary because of the definition of “State” in chapter 1 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
