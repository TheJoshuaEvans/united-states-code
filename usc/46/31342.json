{"tag":"section","attrib":{"id":"idf6ac9321-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31342"},"text":null,"children":[{"tag":"num","attrib":{"value":"31342"},"text":"§ 31342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishing maritime liens","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ac9322-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (b) of this section, a person providing necessaries to a vessel on the order of the owner or a person authorized by the owner—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ac9323-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31342/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a maritime lien on the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac9324-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31342/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may bring a civil action in rem to enforce the lien; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac9325-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31342/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not required to allege or prove in the action that credit was given to the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ac9326-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to a public vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ac9327-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s102/c"},"text":"Pub. L. 100–710, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4748"},"text":"102 Stat. 4748","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/225/tIII/s303/6"},"text":"Pub. L. 101–225, title III, § 303(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1924"},"text":"103 Stat. 1924","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ac9328-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ac9329-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ac932a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31342","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:971","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31342 provides that any authorized person providing necessaries for a vessel has a maritime lien on the vessel, may bring a civil action ","children":[{"tag":"i","attrib":{},"text":"in rem","children":[],"tail":" in admiralty to enforce the lien, and is not required to allege or prove that credit was given to the vessel. “Providing” has been substituted for “furnishing” for consistency with other laws. This section makes no substantive change to law. This section does not supersede the prohibition under the Public Vessels Act, the Foreign Sovereign Immunities Act, or the Suits in Admiralty Act, on bringing an "},{"tag":"i","attrib":{},"text":"in rem","children":[],"tail":" action against a public vessel."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6ac932b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6ac932c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/225"},"text":"Pub. L. 101–225","children":[],"tail":" designated existing provisions as subsec. (a), substituted “Except as provided in subsection (b) of this section, a person providing necessaries to a vessel on the order of the owner” for “A person providing necessaries to a vessel (except a public vessel) on the order of a person listed in "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s31341"},"text":"section 31341 of this title","children":[],"tail":"”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6ac932d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf6ac932e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/710/s107"},"text":"section 107 of Pub. L. 100–710","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s31301"},"text":"section 31301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
