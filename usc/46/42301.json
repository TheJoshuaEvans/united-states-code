{"tag":"section","attrib":{"id":"idf6b3bf85-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42301"},"text":null,"children":[{"tag":"num","attrib":{"value":"42301"},"text":"§ 42301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b3bf86-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defined in Part A","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this chapter, the terms “common carrier”, “marine terminal operator”, “ocean common carrier”, “ocean transportation intermediary”, “shipper”, and “shippers’ association” have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s40102"},"text":"section 40102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bf87-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bf88-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “foreign carrier” means an ocean common carrier a majority of whose vessels are documented under the laws of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bf89-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maritime services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “maritime services” means port-to-port transportation of cargo by vessels operated by an ocean common carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bf8a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42301/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maritime-related services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “maritime-related services” means intermodal operations, terminal operations, cargo solicitation, agency services, ocean transportation intermediary services and operations, and all other activities and services integral to total transportation systems of ocean common carriers and their foreign domiciled affiliates for themselves and others.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bf8b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42301/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “United States carrier” means an ocean common carrier operating vessels documented under the laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bf8c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42301/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states oceanborne trade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “United States oceanborne trade” means the carriage of cargo between the United States and a foreign country, whether directly or indirectly, by an ocean common carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b3bf8d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1551"},"text":"120 Stat. 1551","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b3bf8e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b3bf8f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b3bf90-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42301","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1710a(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/100/418/tX/s10002/a"},"text":"Pub. L. 100–418, title X, § 10002(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/1570"},"text":"102 Stat. 1570","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tI/s111/1"},"text":"Pub. L. 105–258, title I, § 111(1)","children":[],"tail":"–(3), "},{"tag":"html:span","attr