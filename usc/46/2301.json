{"tag":"section","attrib":{"id":"idf6591c49-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2301"},"text":null,"children":[{"tag":"num","attrib":{"value":"2301"},"text":"§ 2301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in sections 2304 and 2306 of this title, this chapter applies to a vessel operated on waters subject to the jurisdiction of the United States (including the territorial sea of the United States as described in Presidential Proclamation No. 5928 of ","children":[{"tag":"date","attrib":{"date":"1988-12-27"},"text":"December 27, 1988","children":[],"tail":") and, for a vessel owned in the United States, on the high seas."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6591c4a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/508"},"text":"97 Stat. 508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/498/tII/s212/a/2"},"text":"Pub. L. 98–498, title II, § 212(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2305"},"text":"98 Stat. 2305","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIII/s301/b/2"},"text":"Pub. L. 105–383, title III, § 301(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3417"},"text":"112 Stat. 3417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/7"},"text":"Pub. L. 109–304, § 15(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1702"},"text":"120 Stat. 1702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6591c4b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6591c4c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6591c4d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2301","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:480","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2301 provides that this chapter is applicable to all vessels, including foreign flag vessels, when operating on waters subject to the jurisdiction of the United States. Any vessel owned in the United States while operating on the high seas would be included. By ownership the Committee means those vessels that are documented or numbered under United States laws and those other vessels that are neither documented or numbered but are of national origin and are not documented under the laws of a foreign nation. This chapter is applicable to a foreign flag vessel that is in innocent passage through territorial waters of the United States, presently 3 miles seaward, whether or not it is bound to or from a port subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6591c4e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6591c4f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Presidential Proclamation No. 5928, referred to in text, is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6591c50-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attr