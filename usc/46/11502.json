{"tag":"section","attrib":{"id":"idf68fe524-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502"},"text":null,"children":[{"tag":"num","attrib":{"value":"11502"},"text":"§ 11502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entry of offenses in logbook","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68fe525-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When an offense listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s11501"},"text":"section 11501 of this title","children":[],"tail":" is committed, an entry shall be made in the vessel’s official logbook—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6925526-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the day of the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6925527-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating the details;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6925528-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" signed by the master; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6925529-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" signed by the chief mate or another seaman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf692552a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before arrival in port if the offense was committed at sea, or before departure if the offense was committed in port and the offender is still on the vessel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf692552b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entry shall be read to the offender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf692552c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offender shall be given a copy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf692552d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offender shall be given the opportunity to reply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf692552e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After subsection (b) of this section has been complied with, an entry shall be made in the official logbook—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf692552f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating that the entry about the offense was read and a copy provided to the offender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6925530-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating the offender’s reply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6925531-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" signed by the master; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6925532-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" signed by the chief mate or another seaman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6925533-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a subsequent legal proceeding, if the entries required by this section are not produced or proved, the court may refuse to receive evidence of the offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6925534-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/583"},"text":"97 Stat. 583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6925535-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6925536-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6925537-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"11502","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:702","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 11502 describes the manner in which offenses must be recorded in the official logbook, and the use of the records by the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
