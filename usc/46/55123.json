{"tag":"section","attrib":{"id":"idf6e816cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55123"},"text":null,"children":[{"tag":"num","attrib":{"value":"55123"},"text":"§ 55123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority loading for coal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A vessel engaged in the coastwise transportation of coal produced in the United States, from a port in the United States to another port in the United States, shall be given priority in loading at any of those ports ahead of a waiting vessel engaged in the export transportation of coal produced in the United States. However, if the Secretary of Transportation finds that it is in the national interest, the Secretary may eliminate this priority loading at any port. The Secretary shall report to Congress within 30 days an action eliminating priority loading under this section.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6e816d0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1642"},"text":"120 Stat. 1642","children":[],"tail":", § 55301; renumbered § 55123, "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1024/b/1/A"},"text":"Pub. L. 116–283, div. A, title X, § 1024(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3842"},"text":"134 Stat. 3842","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ea86d1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ea8