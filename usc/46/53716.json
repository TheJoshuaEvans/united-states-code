{"tag":"section","attrib":{"id":"idf6dea0a0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53716"},"text":null,"children":[{"tag":"num","attrib":{"value":"53716"},"text":"§ 53716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6dea0a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53716/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a deposit fund in the Treasury for purposes of this section. The Secretary or Administrator, in accordance with an agreement under subsection (b), may deposit into and hold in the fund cash belonging to an obligor to serve as collateral for a guarantee made under this chapter with respect to the obligor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea0a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53716/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or Administrator and an obligor shall make a reserve fund or other collateral account agreement to govern the deposit, withdrawal, retention, use, and reinvestment of cash of the obligor held in the fund. The agreement shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dea0a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53716/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terms and conditions required by this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea0a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53716/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terms that grant to the United States Government a security interest in all amounts deposited into the fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea0a5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53716/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional terms considered by the Secretary or Administrator to be necessary to protect fully the interests of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea0a6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53716/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator may invest and reinvest any part of the amounts in the fund in obligations of the Government with maturities such that amounts in the fund will be available as required for purposes of the agreement under subsection (b). Cash balances in the fund in excess of current requirements shall be maintained in a form of uninvested funds, and the Secretary of the Treasury shall pay interest on these funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dea0a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53716/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withdrawals","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dea0a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53716/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Cash deposited into the fund may not be withdrawn without the consent of the Secretary or Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea0a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53716/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of income","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (3), the Secretary or Administrator may pay any income earned on cash of an obligor deposited into the fund in accordance with the agreement with the obligor under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea0aa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53716/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention against default","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator may retain and offset any or all of the cash of an obligor in the fund, and any income realized thereon, as part of the Secretary’s or Administrator’s recovery against the obligor in case of a default by the obligor on an obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6dea0ab-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1616"},"text":"120 Stat. 1616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/H"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(H)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/10/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(10)(B)","children":[],"tail":", (11), (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6dea0ac-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6dea0ad-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6dea0ae-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","