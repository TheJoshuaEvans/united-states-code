{"tag":"section","attrib":{"id":"idf69e3bad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14521"},"text":null,"children":[{"tag":"num","attrib":{"value":"14521"},"text":"§ 14521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter applies to a vessel described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14501"},"text":"section 14501 of this title","children":[],"tail":" that is not measured under subchapter II of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf69e3bae-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5101/3"},"text":"Pub. L. 99–509, title V, § 5101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1925"},"text":"100 Stat. 1925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69e3baf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69e3bb0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 14521","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Source: Section (U.S. Code) 46 App. U.S.C. 71.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 14521 provides that vessels that are to be measured under the regulatory measurement system in this chapter, but are not measured under the standard regulatory measurement system in subchapter II, shall be measured under the simplified measurement system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
