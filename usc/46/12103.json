":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2125"},"text":"116 Stat. 2125","children":[],"tail":", originally derived from section 65e of former Title 46, Shipping, related to certificates of documentation, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":". See sections 12104, 12105, and 12133 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 12103a, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIV/s422/b/1"},"text":"Pub. L. 107–295, title IV, § 422(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2125"},"text":"116 Stat. 2125","children":[],"tail":", related to issuance of temporary certificate of documentation by third parties, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12105"},"text":"section 12105 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
