{"tag":"section","attrib":{"id":"idf6ea876a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55315"},"text":null,"children":[{"tag":"num","attrib":{"value":"55315"},"text":"§ 55315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum tonnage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ea876b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “base period” means the 5-year period running from the sixth through the second prior fiscal years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ea876c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each fiscal year, the minimum quantity of agricultural commodities to be exported under programs specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55314/b"},"text":"section 55314(b) of this title","children":[],"tail":" is the average of the tonnage exported under those programs during the base period, discarding the high and low years."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ea876d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55315/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waivers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may waive the minimum quantity for a fiscal year under this section if the President determines and reports to Congress, together with reasons, that the quantity cannot be used effectively for the purposes of those programs or, based on a certification by the Secretary of Agriculture, that the commodities are not available for reasons that include the unavailability of funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ea876e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1646"},"text":"120 Stat. 1646","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tI/s100124/c/1"},"text":"Pub. L. 112–141, div. F, title I, § 100124(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/915"},"text":"126 Stat. 915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ea876f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ea8770-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ea8771-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","a