 § 301(d)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3916"},"text":"110 Stat. 3916","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tII/s205/c"},"text":"Pub. L. 107–295, title II, § 205(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2096"},"text":"116 Stat. 2096","children":[],"tail":", originally derived from section 65"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of former Title 46, Shipping, related to surrender and invalidation of certificates of documentation, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":". See sections 12135 and 12136 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf69255f9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3525/b"},"text":"Pub. L. 110–181, § 3525(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/s310"},"text":"Pub. L. 109–241, § 310","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3525/a/1"},"text":"Pub. L. 110–181, § 3525(a)(1)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/s310"},"text":"Pub. L. 109–241, § 310","children":[],"tail":", into this section by adding subsec. (d). See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s310"},"text":"Pub. L. 109–241, § 310","children":[],"tail":", which directed the amendment of former "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12105"},"text":"section 12105 of this title","children":[],"tail":" from which this section was derived in part, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3525/b"},"text":"Pub. L. 110–181, § 3525(b)","children":[],"tail":". See 2008 Amendment note for subsec. (d) and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
