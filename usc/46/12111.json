{"tag":"section","attrib":{"id":"idf69255e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111"},"text":null,"children":[{"tag":"num","attrib":{"value":"12111"},"text":"§ 12111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registry endorsement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf69255e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A registry endorsement may be issued for a vessel that satisfies the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12103"},"text":"section 12103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69255e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Activity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel for which a registry endorsement is issued may engage in foreign trade or trade with Guam, American Samoa, Wake, Midway, or Kingman Reef.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69255e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Vessels Owned by Trusts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf69255e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication of beneficiary citizenship requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the issuance of a certificate of documentation with only a registry endorsement, the beneficiaries of a trust are not required to be citizens of the United States if the trust qualifies under paragraph (2) and the vessel is subject to a charter to a citizen of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69255e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for trust to qualify","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf69255e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), a trust qualifies under this paragraph with respect to a vessel only if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf69255e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each trustee is a citizen of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf69255ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application for documentation of the vessel includes the affidavit of each trustee stating that the trustee is not aware of any reason involving a beneficiary of the trust that is not a citizen of the United States, or involving any other person that is not a citizen of the United States, as a result of which the beneficiary or other person would hold more than 25 percent of the aggregate power to influence or limit the exercise of the authority of the trustee with respect to matters involving any ownership or operation of the vessel that may adversely affect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69255eb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of non-citizens","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any person that is not a citizen of the United States has authority to direct or participate in directing a trustee for a trust in matters involving any ownership or operation of the vessel that may adversely affect the interests of the United States or in removing a trustee for a trust without cause, either directly or indirectly through the control of another person, the trust is not qualified under this paragraph unless the trust instrument provides that persons who are not citizens of the United States may not hold more than 25 percent of the aggregate authority to so direct or remove a trustee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69255ec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ownership by non-citizens","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subparagraphs (A) and (B) do not prohibit a person that is not a citizen of the United States from holding more than 25 percent of the beneficial interest in a trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69255ed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Citizenship of person chartering vessel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a person chartering a vessel from a trust that qualifies under paragraph (2) is a citizen of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":", the vessel is deemed to be owned by a citizen of the United States for purposes of that section and related laws, except chapter 531 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69255ee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities Involving Mobile Offshore Drilling Units.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf69255ef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Only a vessel for which a certificate of documentation with a registry endorsement is issued may engage in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf69255f0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the setting, relocation, or recovery of the anchors or other mooring equipment of a mobile offshore drilling unit that is located over the outer Continental Shelf (as defined in section 2(a) of the Outer Continental Shelf Lands Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331/a"},"text":"43 U.S.C. 1331(a)","children":[],"tail":")); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69255f1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation of merchandise or personnel to or from a point in the United States from or to a mobile offshore drilling unit located over the outer Continental Shelf that is not attached to the seabed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69255f2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12111/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coastwise trade not authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in paragraph (1) authorizes the employment in the coastwise trade of a vessel that does not meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12112"},"text":"section 12112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf69255f3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1494"},"text":"120 Stat. 1494","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIII/s310"},"text":"Pub. L. 109–241, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/529"},"text":"120 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3525/a/1"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3525(a)(1)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/600"},"text":"122 Stat. 600","children":[],"tail":", 601.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69255f4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69255f5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf69255f6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","a