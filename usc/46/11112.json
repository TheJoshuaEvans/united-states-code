{"tag":"section","attrib":{"id":"idf68fe46e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11112"},"text":null,"children":[{"tag":"num","attrib":{"value":"11112"},"text":"§ 11112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Master’s lien for wages","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The master of a documented vessel has the same lien against the vessel for the master’s wages and the same priority as any other seaman serving on the vessel.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf68fe46f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/307/s1/19/B"},"text":"Pub. L. 99–307, § 1(19)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-19"},"text":"May 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/446"},"text":"100 Stat. 446","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
