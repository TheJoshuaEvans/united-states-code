{"tag":"section","attrib":{"id":"idf6f1b277-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103"},"text":null,"children":[{"tag":"num","attrib":{"value":"57103"},"text":"§ 57103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donation of vessels in the National Defense Reserve Fleet","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f1b278-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may convey the right, title, and interest of the United States Government in any vessel of the National Defense Reserve Fleet that has been identified by the Secretary as an obsolete vessel, if the recipient—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f1b279-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a non-profit organization, a State, or a municipal corporation or political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b27a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees not to use, or allow others to use, the vessel for commercial transportation purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b27b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to make the vessel available to the Government whenever the Secretary indicates that it is needed by the Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b27c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to hold the Government harmless for any claims arising from exposure to asbestos, polychlorinated biphenyls, lead paint, or other hazardous substances after conveyance of the vessel, except for claims arising from use of the vessel by the Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b27d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a conveyance plan and a business plan that describes the intended use of the vessel, each of which has been submitted to and approved by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b27e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has provided proof, as determined by the Secretary, of resources sufficient to accomplish the transfer, necessary repairs and modifications, and initiation of the intended use of the vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b27f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" agrees that when the recipient no longer requires the vessel for use as described in the business plan required under paragraph (5)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6f1b280-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient will, at the discretion of the Secretary, reconvey the vessel to the Government in good condition except for ordinary wear and tear; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f1b281-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Board of Trustees of the recipient has decided to dissolve the recipient according to the laws of the State in which the recipient is incorporated, then—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6f1b282-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/a/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient shall distribute the vessel, as an asset of the recipient, to a person that has been determined exempt from taxation under section 501(c)(3) of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"26 U.S.C. 501(c)(3)","children":[],"tail":"), or to the Federal Government or a State or local government for a public purpose; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6f1b283-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/a/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel shall be disposed of by a court of competent jurisdiction of the county in which the principal office of the recipient is located, for such purposes as the court shall determine, or to such organizations as the court shall determine are organized exclusively for public purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b284-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the Secretary’s discretion, additional equipment from other obsolete vessels of the Fleet may be conveyed to assist the recipient with maintenance, repairs, or modifications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b285-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require any additional terms the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b286-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delivery of Vessel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If conveyance is made under this section, the vessel shall be delivered to the recipient at a time and place to be determined by the Secretary. The vessel shall be conveyed in an “as is” condition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b287-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If at any time prior to delivery of the vessel to the recipient, the Secretary determines that a different disposition of the vessel would better serve the interests of the Government, the Secretary shall pursue the more favorable disposition of the obsolete vessel and shall not be liable for any damages that may result from an intended recipient’s reliance upon a proposed transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b288-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57103/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reversion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall include in any conveyance under this section terms under which all right, title, and interest conveyed by the Secretary shall revert to the Government if the Secretary determines the vessel has been used other than as described in the business plan required under subsection (a)(5).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b289-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1659"},"text":"120 Stat. 1659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tIV/s408/a"},"text":"Pub. L. 112–213, title IV, § 408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1571"},"text":"126 Stat. 1571","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dC/tXXXV/s3514/j/5"},"text":"Pub. L. 118–31, div. C, title XXXV, § 3514(j)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/812"},"text":"137 Stat. 812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b28a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f1b28b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f1b28c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"57103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1158(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title V, § 508(b), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/108/136/tXXXV/s3512/2"},"text":"Pub. L. 108–136, title XXXV, § 3512(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/117/1789"},"text":"117 Stat. 1789","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before paragraph (1), the words “Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s1160/j"},"text":"section 1160(j) of this title","children":[],"tail":"” are omitted as unnecessary because section 46 App. U.S.C. 1160(j) is restated in section 57101 of the revised title and that section contains an exception which includes this section. In paragraph (1), the words “Commonwealth, or possession of the United States” and “or the District of Columbia” are omitted as unnecessary because of the definition of “State” in chapter 1 of the revised title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6f1b28d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6f1b28e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/j/5/A"},"text":"Pub. L. 118–31, § 3514(j)(5)(A)","children":[],"tail":", struck out “nonretention” before “vessels” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s3514/j/5/B"},"text":"Pub. L. 118–31, § 3514(j)(5)(B)","children":[],"tail":", struck out “of insufficient value to warrant its further preservation” after “obsolete vessel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" substituted “Donation of nonretention vessels in the National Defense Reserve Fleet” for “Sale of obsolete vessels in National Defense Reserve Fleet” in section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
