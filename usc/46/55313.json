{"tag":"section","attrib":{"id":"idf6ea8749-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55313"},"text":null,"children":[{"tag":"num","attrib":{"value":"55313"},"text":"§ 55313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption of certain agricultural exports from cargo preference provisions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Sections 55304 and 55305 of this title do not apply to export activities of the Secretary of Agriculture or the Commodity Credit Corporation under which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea874a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55313/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural commodities or their products acquired by the Corporation are made available to United States exporters, users, processors, or foreign purchasers for the purpose of developing, maintaining, or expanding export markets for United States agricultural commodities or their products at prevailing world market prices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea874b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55313/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payments are made available to United States exporters, users, or processors or, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55314"},"text":"section 55314 of this title","children":[],"tail":", cash grants are made available to foreign purchasers, for the purpose described in paragraph (1);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea874c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55313/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial credit guarantees are blended with direct credits from the Corporation to reduce the effective rate of interest on export sales of United States agricultural commodities or their products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea874d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55313/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credit or credit guarantees for not more than 3 years are extended by the Corporation to finance or guarantee export sales of United States agricultural commodities or their products; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea874e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55313/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural commodities or their products owned or controlled by or under loan from the Corporation are exchanged or bartered for materials, goods, equipment, or services at least equal in value to the agricultural commodities or their products for which they are exchanged or bartered (determined on the basis of prevailing world market prices at the time of the exchange or barter), but this paragraph does not exempt from the cargo preference provisions referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55314/b"},"text":"section 55314(b) of this title","children":[],"tail":" any requirement otherwise applicable to the materials, goods, equipment, or services imported under the transaction."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ea874f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1644"},"text":"120 Stat. 1644","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ea8750-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ea8751-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ea8752-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55313","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1241e.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title IX, § 901a, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/99/198/tXI/s1142"},"text":"Pub. L. 99–198, title XI, § 1142","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/99/1490"},"text":"99 Stat. 1490","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
