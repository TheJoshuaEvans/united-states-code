{"tag":"section","attrib":{"id":"idf6a56846-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30911"},"text":null,"children":[{"tag":"num","attrib":{"value":"30911"},"text":"§ 30911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs and interest","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a56847-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A judgment against the United States or a federally-owned corporation under this chapter may include costs and interest at the rate of 4 percent per year until satisfied. Interest shall run as ordered by the court, except that interest is not allowable for the period before the action is filed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a56848-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30911/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Providing for Interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a), if the claim is based on a contract providing for interest, interest may be awarded at the rate and for the period provided in the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a56849-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1519"},"text":"120 Stat. 1519","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a5684a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a5684b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a5684c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30911","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:743 (2d, 3d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-03-09/ch95/s3"},"text":"Mar. 9, 1920, ch. 95, § 3","children":[],"tail":" (2d, 3d sentences), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/526"},"text":"41 Stat. 526","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:745 (last proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-03-09/ch95/s5"},"text":"Mar. 9, 1920, ch. 95, § 5","children":[],"tail":" (last proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/526"},"text":"41 Stat. 526","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1932-06-30/ch315"},"text":"June 30, 1932, ch. 315","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/47/420"},"text":"47 Stat. 420","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1950-12-13/ch1136"},"text":"Dec. 13, 1950, ch. 1136","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/1112"},"text":"64 Stat. 1112","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “and when the decree is for a money judgment” are omitted as unnecessary. The words “except that interest is not allowable for the period before the action is filed” are substituted for “","children":[{"tag":"i","attrib":{},"text":"And provided further","children":[],"tail":", That after "},{"tag":"date","attrib":{"date":"1932-06-30"},"text":"June 30, 1932","children":[],"tail":", no interest shall be allowed on any claim prior to the time when suit on such claim is brought as authorized by section 742 of this Appendix” to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for “or at any higher rate which shall be stipulated in any contract upon which such decree shall be based” in 46 App. U.S.C. 743 and “unless upon a contract expressly stipulating for the payment of interest” in 46 App. U.S.C. 745 (last proviso) for clarity and consistency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
