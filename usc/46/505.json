{"tag":"section","attrib":{"id":"idf64d35d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s505"},"text":null,"children":[{"tag":"num","attrib":{"value":"505"},"text":"§ 505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for violating regulation or order","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person convicted of knowingly and willfully violating a regulation or order of the Federal Maritime Commission or the Secretary of Transportation under subtitle IV or V of this title, for which no penalty is expressly provided, shall be fined not more than $500. Each day of a continuing violation is a separate offense.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf64d35d4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s4"},"text":"Pub. L. 109–304, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1491"},"text":"120 Stat. 1491","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf64d35d5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf64d35d6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf64d35d7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"