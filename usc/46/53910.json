{"tag":"section","attrib":{"id":"idf6e35ad3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53910"},"text":null,"children":[{"tag":"num","attrib":{"value":"53910"},"text":"§ 53910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e35ad4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accordance With Commercial Practice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this chapter, the Secretary of Transportation may act in accordance with commercial practice in the marine insurance business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35ad5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may prescribe regulations the Secretary considers appropriate to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35ad6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53910/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policies, Rates, and Annual Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may prescribe and change forms and policies, and fix and change the amounts insured and rates of premium, under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35ad7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53910/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may charge and collect an annual fee in an amount calculated to cover the expenses of processing applications for insurance, employing underwriting agents, and appointing experts under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35ad8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53910/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Claims and Judgments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may settle and pay claims, and pay judgments against the United States, related to insurance under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35ad9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53910/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Underwriting Agents","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e35ada-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53910/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may, and when the Secretary finds it practical to do so shall, employ a domestic company or group of domestic companies, authorized to do marine insurance business in a State of the United States, to act as underwriting agent for the Secretary. The services of an underwriting agent may be used in adjusting claims, but a claim may not be paid until approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e35adb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53910/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may allow the company or group of companies reasonable compensation for services as the underwriting agent. The compensation may include an allowance for expenses reasonably incurred by the agent, but may not include any amount for soliciting or stimulating business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35adc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53910/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees For Arranging Insurance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (f)(2), the Secretary may not pay an insurance broker or other person acting in a similar intermediary capacity a fee or other consideration for participating in arranging insurance when the Secretary directly insures any of the risk.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35add-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53910/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employment of Marine Insurance Experts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, without regard to the laws and regulations on the employment of Federal employees, may appoint and prescribe the duties of experts in marine insurance as the Secretary considers necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35ade-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53910/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Services of Other Government Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With the consent of another agency of the United States Government, the Secretary may use information, services, facilities, officers, and employees of the agency in carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35adf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53910/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel Location Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may prescribe by regulation vessel location reporting requirements for a vessel insured under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e35ae0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1630"},"text":"120 Stat. 1630","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e35ae1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e35ae2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e35ae3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (S