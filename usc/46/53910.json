,"text":"46 App.:1283(a) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XII, § 1203(a) (last sentence), as added "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-07/ch906"},"text":"Sept. 7, 1950, ch. 906","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/774"},"text":"64 Stat. 774","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/94/523/s1"},"text":"Pub. L. 94–523, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 17, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/2474"},"text":"90 Stat. 2474","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (e) is substituted for “may adjust and pay losses, compromise and settle claims, whether in favor of or against the United States and pay the amount of any judgment rendered against the United States in any suit, or the amount of any settlement agreed upon, in respect of any claim under insurance authorized by this subchapter” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
