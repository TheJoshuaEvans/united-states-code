{"tag":"section","attrib":{"id":"idf6fb2918-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70012"},"text":null,"children":[{"tag":"num","attrib":{"value":"70012"},"text":"§ 70012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Navigational hazards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6fb2919-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70012/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Procedure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a program to encourage fishermen and other vessel operators to report potential or existing navigational hazards involving pipelines to the Secretary through Coast Guard field offices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb291a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70012/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary’s Response.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb291b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70012/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification by the operator of a pipeline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon notification by the operator of a pipeline of a hazard to navigation with respect to that pipeline, the Secretary shall immediately notify Coast Guard headquarters, the Pipeline and Hazardous Materials Safety Administration, other affected Federal and State agencies, and vessel owners and operators in the pipeline’s vicinity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb291c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70012/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification by other persons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon notification by any other person of a hazard or potential hazard to navigation with respect to a pipeline, the Secretary shall promptly determine whether a hazard exists, and if so shall immediately notify Coast Guard headquarters, the Pipeline and Hazardous Materials Safety Administration, other affected Federal and State agencies, vessel owners and operators in the pipeline’s vicinity, and the owner and operator of the pipeline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb291d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70012/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pipeline Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “pipeline” has the meaning given the term “pipeline facility” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s60101/a/18"},"text":"section 60101(a)(18) of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6fb291e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIV/s401/a"},"text":"Pub. L. 115–282, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4259"},"text":"132 Stat. 4259","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
