{"tag":"section","attrib":{"id":"idf69bcac3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13109"},"text":null,"children":[{"tag":"num","attrib":{"value":"13109"},"text":"§ 13109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation, cooperation, and regulation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf69bcac4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out responsibilities under this chapter, the Secretary may consult with State and local governments, public and private agencies, organizations and committees, private industry, and other persons having an interest in boating safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69bcac5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may advise, assist, and cooperate with the States and other interested public and private agencies in planning, developing, and carrying out boating safety programs. Acting under section 141 ","children":[{"tag":"ref","attrib":{"idref":"fn002020"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002020"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14, the Secretary shall ensure the fullest cooperation between the State and United States Government authorities in promoting boating safety by making agreements and other arrangements with States when possible. Subject to chapter 23 "},{"tag":"ref","attrib":{"idref":"fn002020"},"text":"1","children":[],"tail":" of title 14, the Secretary may make available, on request of a State, the services of members of the Coast Guard Auxiliary to assist the State in promoting boating safety on State waters."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69bcac6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may prescribe regulations to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf69bcac7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/597"},"text":"97 Stat. 597","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1011/g"},"text":"Pub. L. 98–369, div. A, title X, § 1011(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1013"},"text":"98 Stat. 1013","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69bcac8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69bcac9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf69bcaca-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"13109","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:1481","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 13109 authorizes the Secretary to consult with State and local governments, public and private agencies, and any other persons that have an interest in boating safety.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section also authorizes the Secretary to advise and assist the States and other public and private agencies in the planning and carrying out of their boating safety and facilities improvement programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf69bcacb-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"