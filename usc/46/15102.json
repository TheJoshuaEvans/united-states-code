{"tag":"section","attrib":{"id":"idf69e3bdb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102"},"text":null,"children":[{"tag":"num","attrib":{"value":"15102"},"text":"§ 15102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Commercial Fishing Safety Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf69e3bdc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a National Commercial Fishing Safety Advisory Committee (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69e3bdd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf69e3bde-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advise and provide recommendations in writing to the Secretary on matters relating to the safe operation of vessels to which chapter 45 of this title applies, including the matters of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf69e3bdf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" navigation safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69e3be0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety equipment and procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69e3be1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine insurance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69e3be2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vessel design, construction, maintenance, and operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69e3be3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel qualifications and training;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69e3be4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review regulations proposed under chapter 45 of this title (during preparation of the regulations); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69e3be5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review marine casualties and investigations of vessels covered by chapter 45 of this title and make recommendations to the Secretary to improve safety and reduce vessel casualties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69e3be6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf69e3be7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall consist of 18 members appointed by the Secretary in accordance with this section and section 15109 of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69e3be8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expertise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69e3be9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Committee shall be appointed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf69e3bea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 10 members shall represent the commercial fishing industry and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf69e3beb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a group, shall together reflect a regional and representational balance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf69e3bec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as individuals, shall each have experience—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf69e3bed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the operation of vessels to which chapter 45 of this title applies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf69e3bee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a crew member or processing line worker on a fish processing vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0acef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent naval architects and marine engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0acf0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent manufacturers of equipment for vessels to which chapter 45 of this title applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0acf1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent education and training professionals related to fishing vessel, fish processing vessel, and fish tender vessel safety and personnel qualifications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0acf2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent underwriters that insure vessels to which chapter 45 of this title applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0acf3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent owners of vessels to which chapter 45 of this title applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0acf4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 3 members shall represent the general public and, to the extent possible, shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6a0acf5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independent expert or consultant in maritime safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6a0acf6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a marine surveyor who provides services to vessels to which chapter 45 of this title applies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6a0acf7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/c/3/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person familiar with issues affecting fishing communities and the families of fishermen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0acf8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quorum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A quorum of 10 members is required to send any written recommendations from the Committee to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0acf9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15102/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall preclude the Secretary from taking emergency action to ensure safety and preservation of life at sea.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a0acfa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVI/s601/a"},"text":"Pub. L. 115–282, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4281"},"text":"132 Stat. 4281","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8335(a)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4706"},"text":"134 Stat. 4706","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a0acfb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6a0acfc-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6a0acfd-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8335/a/1/A/i/I"},"text":"Pub. L. 116–283, § 8335(a)(1)(A)(i)(I)","children":[],"tail":", inserted “and provide recommendations in writing to” after “advise” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8335/a/1/A/i/II"},"text":"Pub. L. 116–283, § 8335(a)(1)(A)(i)(II)","children":[],"tail":", (ii), added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8335/a/1/B"},"text":"Pub. L. 116–283, § 8335(a)(1)(B)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
