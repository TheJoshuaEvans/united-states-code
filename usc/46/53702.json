l:p","attrib":{},"text":"46 App.:1279g.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XI, § 1112, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/104/297/tIII/s303/a"},"text":"Pub. L. 104–297, title III, § 303(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3616"},"text":"110 Stat. 3616","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “on terms the Secretary may prescribe” are added based on language in 46 App. U.S.C. 1274(a) (before cl. (1)). The words “the unpaid balance of” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6d9e576-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf6d9e577-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b) of this section was derived from section 1112 of act ","children":[{"tag":"date","attrib":{"date":"1936-06-29"},"text":"June 29, 1936","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/104/297/s303/a"},"text":"Pub. L. 104–297, § 303(a)","children":[],"tail":", which was classified to section 1279g of the former Appendix to this title. Section 1112 was renumbered section 1114 of the Act by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/d"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3557"},"text":"119 Stat. 3557","children":[],"tail":", which was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/b"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":". See Historical and Revision notes above and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6d9e578-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “The Secretary or Administrator, on terms the Secretary or Administrator may prescribe, may guarantee or make a commitment to guarantee the payment of the principal of and interest on an obligation eligible to be guaranteed under this chapter. A guarantee or commitment to guarantee shall cover 100 percent of the principal and interest.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/C"},"text":"Pub. L. 109–163, § 3507(a)(1)(C)","children":[],"tail":", (d). See 2006 Amendment note below and Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/a/10/B"},"text":"Pub. L. 110–181, § 3522(a)(10)(B)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/C"},"text":"Pub. L. 109–163, § 3507(a)(1)(C)","children":[],"tail":", into this section by inserting “or Administrator” after “Secretary” in two places. See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/C"},"text":"Pub. L. 109–163, § 3507(a)(1)(C)","children":[],"tail":", which directed the amendment of section 1273(a) of the former Appendix to this title from which subsec. (a) of this section was derived, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":". See 2008 Amendment note for subsec. (a) and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
