{"tag":"section","attrib":{"id":"idf6d9e567-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53702"},"text":null,"children":[{"tag":"num","attrib":{"value":"53702"},"text":"§ 53702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d9e568-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d9e569-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guarantee of payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator, on terms the Secretary or Administrator may prescribe, may guarantee or make a commitment to guarantee the payment of the principal of and interest on an obligation eligible to be guaranteed under this chapter. A guarantee or commitment to guarantee shall cover 100 percent of the principal and interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d9e56a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preferred eligible lender","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Financing Bank shall be the preferred eligible lender of the principal and interest of the guaranteed obligations issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d9e56b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Direct Loans for Fisheries","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d9e56c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this chapter, any obligation involving a fishing vessel, fishery facility, aquaculture facility, individual fishing quota, or fishing capacity reduction program issued under this chapter after ","children":[{"tag":"date","attrib":{"date":"1996-10-11"},"text":"October 11, 1996","children":[],"tail":", shall be a direct loan obligation for which the Secretary shall be the obligee, rather than an obligation issued to an obligee other than the Secretary and guaranteed by the Secretary. A direct loan obligation under this subsection shall be treated in the same manner and to the same extent as an obligation guaranteed under this chapter except with respect to provisions of this chapter that by their nature can only be applied to obligations guaranteed under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d9e56d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interest rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this chapter, the annual rate of interest an obligor shall pay on a direct loan obligation under this subsection is 2 percent plus the additional percent the Secretary must pay as interest to borrow from the Treasury the funds to make the loan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d9e56e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53702/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum obligations available for historic uses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the direct loan obligations issued by the Secretary under this chapter, the Secretary shall make a minimum of $59,000,000 available each fiscal year for historic uses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d9e56f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53702/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of obligations in limited access fisheries","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the other eligible purposes and uses of direct loan obligations provided for in this chapter, the Secretary may issue direct loan obligations for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d9e570-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53702/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financing the construction or reconstruction of a fishing vessel in a fishery managed under a limited access system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d9e571-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53702/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financing the purchase of harvesting rights in a fishery that is federally managed under a limited access system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d9e572-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1603"},"text":"120 Stat. 1603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/C"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(C)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":", 3557; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/10/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(10)(B)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s302/a/2"},"text":"Pub. L. 114–120, title III, § 302(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/52"},"text":"130 Stat. 52","children":[],"tail":"; "},{"tag":"ref","a