{"tag":"section","attrib":{"id":"idf70bf1a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80509"},"text":null,"children":[{"tag":"num","attrib":{"value":"80509"},"text":"§ 80509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf70bf1a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An owner, agent, or custodian who has been notified of an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s80505"},"text":"section 80505 of this title","children":[],"tail":" and fails to take reasonable and prompt action to prevent or stop a container subject to the order from being moved in violation of the order is liable to the United States Government for a civil penalty of not more than $5,000 for each container moved. Each day the container remains in service while the order is in effect is a separate violation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70bf1aa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment and Collection","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf70bf1ab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80509/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After notice and an opportunity for a hearing, the Secretary of the department in which the Coast Guard is operating shall assess and collect any penalty under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70bf1ac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80509/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors to consider","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In determining the amount of the penalty, the Secretary shall consider the gravity of the violation, the hazards involved, and the record of the person charged with respect to violations of the Convention, this chapter, or regulations prescribed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70bf1ad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80509/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remission, mitigation, or compromise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may remit, mitigate, or compromise a penalty under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70bf1ae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80509/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a person fails to pay a penalty under this section, the Secretary shall refer the matter to the Attorney General for collection in an appropriate district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf70bf1af-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s11"},"text":"Pub. L. 109–304, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1698"},"text":"120 Stat. 1698","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf70bf1b0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf70bf1b1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf70bf1b2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80509","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1505.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/208/s6"},"text":"Pub. L. 95–208, § 6","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 13, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1478"},"text":"91 Stat. 1478","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “On and after the date the instrument of ratification is deposited by the United States in accordance with the provisions of article VII of the Convention” are omitted as obsolete. The words “liable to the United States Government for a civil penalty” are substituted for “subject to a civil penalty” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “In determining the amount of” are substituted for “In assessing, remitting, mitigating, or compromising” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
