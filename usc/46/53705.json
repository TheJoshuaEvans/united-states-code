{"tag":"section","attrib":{"id":"idf6dc2ea7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53705"},"text":null,"children":[{"tag":"num","attrib":{"value":"53705"},"text":"§ 53705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pledge of United States Government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6dc2ea8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Full Faith and Credit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The full faith and credit of the United States Government is pledged to the payment of a guarantee made under this chapter, for both principal and interest, including interest (as may be provided for in the guarantee) accruing between the date of default under a guaranteed obligation and the date of payment in full of the guarantee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2ea9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incontestability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A guarantee or commitment to guarantee made under this chapter is conclusive evidence of the eligibility of the obligation for the guarantee. The validity of a guarantee or commitment to guarantee made under this chapter is incontestable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6dc2eaa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"da