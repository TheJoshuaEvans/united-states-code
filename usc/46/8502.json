{"tag":"section","attrib":{"id":"idf6866e1e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502"},"text":null,"children":[{"tag":"num","attrib":{"value":"8502"},"text":"§ 8502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal pilots required","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6866e1f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsections (g) and (i) of this section, a coastwise seagoing vessel shall be under the direction and control of a pilot licensed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7101"},"text":"section 7101 of this title","children":[],"tail":" if the vessel is—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6866e20-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not sailing on register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e21-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" underway;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e22-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not beyond 3 nautical miles from the baselines from which the territorial sea of the United States is measured; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e23-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6866e24-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" propelled by machinery and subject to inspection under part B of this subtitle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6866e25-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to inspection under chapter 37 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e26-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The fees charged for pilotage by pilots required under this section may not be more than the customary or legally established rates in the States in which the pilotage is performed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e27-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State or political subdivision of a State may not impose on a pilot licensed under this subtitle an obligation to procure a State or other license, or adopt any other regulation that will impede the pilot in the performance of the pilot’s duties under the laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e28-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State or political subdivision of a State may not levy pilot charges on a vessel lawfully piloted by a pilot required under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e29-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner, charterer, managing operator, agent, master, or individual in charge of a vessel operated in violation of this section or a regulation prescribed under this section is liable to the United States Government for a civil penalty of $10,000. The vessel also is liable in rem for the penalty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e2a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual serving as a pilot without having a license required by this section or a regulation prescribed under this section is liable to the Government for a civil penalty of $10,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e2b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6866e2c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall designate by regulation the areas of the approaches to and waters of Prince William Sound, Alaska, if any, on which a vessel subject to this section is not required to be under the direction and control of a pilot licensed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7101"},"text":"section 7101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e2d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In any area of Prince William Sound, Alaska, where a vessel subject to this section is required to be under the direction and control of a pilot licensed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7101"},"text":"section 7101 of this title","children":[],"tail":", the pilot may not be a member of the crew of that vessel and shall be a pilot licensed by the State of Alaska who is operating under a Federal license, when the vessel is navigating waters between 60°49′ North latitude and the Port of Valdez, Alaska."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e2e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall designate waters on which tankers over 1,600 gross tons subject to this section shall have on the bridge a master or mate licensed to direct and control the vessel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7101/c/1"},"text":"section 7101(c)(1) of this title","children":[],"tail":" who is separate and distinct from the pilot required under subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e2f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6866e30-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), a dredge to which this section would otherwise apply is exempt from the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e31-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8502/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary determines, after notice and comment, that the exemption under paragraph (1) creates a hazard to navigational safety in a specified area, the Secretary may require that a dredge exempted by paragraph (1) which is operating in that area shall comply with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6866e32-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/553"},"text":"97 Stat. 553","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s29/f/1"},"text":"Pub. L. 98–557, § 29(f)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2874"},"text":"98 Stat. 2874","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/307/s1/13"},"text":"Pub. L. 99–307, § 1(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-19"},"text":"May 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/446"},"text":"100 Stat. 446","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV"},"text":"Pub. L. 101–380, title IV","children":[],"tail":", §§ 4116(a), (b), 4302(g), "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/522"},"text":"104 Stat. 522","children":[],"tail":", 539; "},{"tag":"ref","attrib":{"href":"/us/pl/101/595/tIII/s307"},"text":"Pub. L. 101–595, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2985"},"text":"104 Stat. 2985","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIII/s301/b/7"},"text":"Pub. L. 105–383, title III, § 301(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3417"},"text":"112 Stat. 3417","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6866e33-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6866e34-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6866e35-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8502","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:215","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:364","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:391a","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:497","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8502 sets forth the provisions and requirements for pilots licensed under section 7101. It is an exception provided by law envisioned under section 8501(a).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) applies the requirement for a Federal pilot to coastwise seagoing vessels if propelled by machinery and inspected under part B or if inspected under chapter 37, including a tank barge. The section has been carefully worded to clearly set out those vessels that are required at times to have a Federal pilot.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) prohibits Federal pilot fees from being higher than those required for State pilots. Subsections (c) and (d) prohibit States from imposing impediments to the proper performance of, or levying charges related to, Federal pilotage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsections (e) and (f) prescribe civil penalties for violation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6866e36-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6866e37-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383"},"text":"Pub. L. 105–383","children":[],"tail":" substituted “not beyond 3 nautical miles from the baselines from which the territorial sea of the United States is measured” for “not on the high seas”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/595/s307/1"},"text":"Pub. L. 101–595, § 307(1)","children":[],"tail":", substituted “subsections (g) and (i)” for “subsection (g)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/s4302/g"},"text":"Pub. L. 101–380, § 4302(g)","children":[],"tail":", substituted “$10,000” for “$500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/s4116/a"},"text":"Pub. L. 101–380, § 4116(a)","children":[],"tail":", amended subsec. (g) generally. Prior to amendment, subsec. (g) read as follows: “The Secretary shall designate by regulation the areas of the approaches to and waters of Prince William Sound, Alaska, on which a vessel subject to this section is not required to be under the direction and control of a pilot licensed under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s7101"},"text":"section 7101 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/s4116/b"},"text":"Pub. L. 101–380, § 4116(b)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/595/s307/2"},"text":"Pub. L. 101–595, § 307(2)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/307"},"text":"Pub. L. 99–307","children":[],"tail":" substituted “part” for “Part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557/s29/f/1"},"text":"Pub. L. 98–557, § 29(f)(1)","children":[],"tail":", amended subsec. (a) generally, which prior to amendment read as follows: “A coastwise seagoing vessel, when not sailing on register and when underway (except on the high seas), shall be under the direction and control of a pilot licensed under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s7101"},"text":"section 7101 of this title","children":[],"tail":" if the vessel is—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) propelled by machinery and subject to inspection under part B of this subtitle; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) subject to inspection under chapter 37 of this title.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557/s29/f/2"},"text":"Pub. L. 98–557, § 29(f)(2)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6866e38-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6866e39-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" applicable to incidents occurring after "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/s1020"},"text":"section 1020 of Pub. L. 101–380","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idf6866e3a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6866e3b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Territorial Sea of United States","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For extension of territorial sea of United States, see Proc. No. 5928, set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
