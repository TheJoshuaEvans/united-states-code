{"tag":"section","attrib":{"id":"idf6a7b1c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301"},"text":null,"children":[{"tag":"num","attrib":{"value":"31301"},"text":"§ 31301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a7b1c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “acknowledge” means making—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a7b1c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an acknowledgment or notarization before a notary public or other official authorized by a law of the United States or a State to take acknowledgments of deeds; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a7b1c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certificate issued under the Hague Convention Abolishing the Requirement of Legalisation for Foreign Public Documents, 1961;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a7b1c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “district court” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a7b1ca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a district court of the United States (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s451"},"text":"section 451 of title 28","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a7b1cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District Court of Guam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a7b1cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District Court of the Virgin Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a7b1cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District Court for the Northern Mariana Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a7b1ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the High Court of American Samoa; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a7b1cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other court of original jurisdiction of a territory or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a7b1d0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “mortgagee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a7b1d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person to whom property is mortgaged; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a7b1d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when a mortgage on a vessel involves a trust, the trustee that is designated in the trust agreement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a7b1d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “necessaries” includes repairs, supplies, towage, and the use of a dry dock or marine railway;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a7b1d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “preferred maritime lien” means a maritime lien on a vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a7b1d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arising before a preferred mortgage was filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31321"},"text":"section 31321 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a7b1d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for damage arising out of maritime tort;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a7b1d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for wages of a stevedore when employed directly by a person listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31341"},"text":"section 31341 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a7b1d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for wages of the crew of the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a7b1d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for general average; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a7b1da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for salvage, including contract salvage;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a7b1db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “preferred mortgage”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a7b1dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a mortgage that is a preferred mortgage under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31322"},"text":"section 31322 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a7b1dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" also means in sections 31325 and 31326 of this title, a mortgage, hypothecation, or similar charge that is established as a security on a foreign vessel if the mortgage, hypothecation, or similar charge was executed under the laws of the foreign country under whose laws the ownership of the vessel is documented and has been registered under those laws in a public register at the port of registry of the vessel or at a central office; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a7b1de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31301/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the Department of Homeland Security, unless otherwise noted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a7b1df-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s102/c"},"text":"Pub. L. 100–710, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4739"},"text":"102 Stat. 4739","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIX/s913/a/2"},"text":"Pub. L. 111–281, title IX, § 913(a)(2)","children":[],"tail":"–(4), "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3017"},"text":"124 Stat. 3017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a7b1e0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a7b1e1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a7b1e2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31301(1), (2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"New","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31301(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:911(5)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31301(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Derived from 46:971–974","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31301(5)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:953(a)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31301(6)(A)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:922(b)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31301(6)(B)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:951 (2d par. less proviso)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31301(1) defines the term “acknowledge”. This paragraph makes a substantive change to law to expand the current law by allowing a notarization under State law, a form prescribed by the Secretary, as well as a certificate issued under the Hague Convention Abolishing the Requirement of Legalisation for Foreign Public Documents, 1961.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31301(2) defines “district court”. This paragraph makes a substantive change to law by including the District Court of Guam, the District Court of the Virgin Islands, the District Court of the Northern Mariana Islands, the High Court of American Samoa, and other Federal territorial courts as they are established. Under current law, only the district courts of the United States have jurisdiction under the Ship Mortgage Act, 1920.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31301(3) defines “mortgagee” as a person to whom property is mortgaged and the trustee authorized under section 31328 that is designated in the trust agreement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31301(4) defines “necessaries” to include repairs, supplies, towage, and the use of a drydock and marine railway for a vessel. As in all codifications, the term “includes” means “includes but is not limited to” and, therefore, is not intended to be an exclusive listing of those items that a court has determined or may determine as falling within the meaning of the term “other necessaries” as contained in current law. The definition is new, is based on 46 App. U.S.C. 971–974, and makes no substantive change to law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31301(5) defines “preferred maritime lien” to mean a lien on a vessel that arises before a preferred mortgage was filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31321"},"text":"section 31321 of this title","children":[],"tail":" for damages arising out of maritime tort, stevedore wages, crew wages, general average, and salvage. The definition is new and is based on 46 App. U.S.C. 953(a). The only substantive change to law made by this paragraph is to change the effective date from the day the preferred mortgage is recorded and endorsed to when it is filed. This change is in keeping with other changes with regard to filing. The term “duly and validly” that is in existing law is not used because it is unnecessary. An instrument that is not “duly and validly” executed is not executed under the laws of the foreign country. This makes no substantive change to law."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31301(6)(A) defines “preferred mortgage” to mean a mortgage that meets the requirements of section 31322. This clause makes no substantive change to law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31301(6)(B) defines “preferred mortgage” to also mean a mortgage on a documented foreign vessel that is preferred under sections 31325 and 31326 for purposes of enforcement of the outstanding mortgage indebtedness. Preference is only granted if the mortgage is executed under the laws of a foreign country, registered under those laws in a public register at the port of registry or at a central office. The use of the word “established” in place of “created” in the current law or “effective” as used in the treaties is not intended to make any substantive change to law. The only substantive changes to law made by this clause are the elimination of the exemption of foreign vessels of less than 200 gross tons, and clarification of the rule of interpretation that if a vessel is registered in one country, but is permitted to fly temporarily the flag of another country (such as through a demise charter), it is the law of the country in which the ownership of the vessel is documented that is used to determine when a mortgage attains preferred status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6a7b1e3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6a7b1e4-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" added par. (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6a7b1e5-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf6a7b1e6-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s107"},"text":"Pub. L. 100–710, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4752"},"text":"102 Stat. 4752","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/710/tI/s107"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This title [see Tables for classification] and amendments made by this title take effect on ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":". However, sections 31321 and 31322 of title 46 (as enacted by section 102 of this Act), United States Code (as sections 31321 and 32322 [probably should be 31322] apply to vessels for which an application for documentation has been filed), take effect on "},{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An instrument filed before ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", but not recorded before that date, is deemed to comply with "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s31321"},"text":"section 31321 of title 46","children":[],"tail":", United States Code, if it is in substantial compliance with the provisions in that section that had corresponding requirements under the law on "},{"tag":"date","attrib":{"date":"1988-12-31"},"text":"December 31, 1988","children":[],"tail":". However, the mortgage may not become a preferred mortgage until the vessel is documented."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This title and the amendments made by this title do not affect the validity of any instrument filed or recorded before ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", if there was a corresponding requirement under the law on "},{"tag":"date","attrib":{"date":"1988-12-31"},"text":"December 31, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An instrument filed or recorded before ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", is deemed to comply with any new requirement under chapter 313 of title 46, United States Code (as enacted by section 102 of this Act), affecting the validity of that instrument."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 102 of this Act and amendments made by that section [enacting former section 30101 and sections 31301 to 31309, 31321 to 31330, and 31341 to 31343 of this title and provisions set out as a note preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"section 2101 of this title","children":[],"tail":"] do not affect any civil action filed before "},{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 104(b) of this Act and the amendments made by section 104(b) of this Act [amending section 808 of the former Appendix to this title] do not apply to any change in control resulting from, or which may at any time result from, any proposed plan of reorganization filed under the United States bankruptcy laws prior to the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":"], except that transactions undertaken as a result of such a plan shall continue to be governed by section 9 of the Shipping Act, 1916 ([former] 46 App. U.S.C. 808) [see "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s56101"},"text":"46 U.S.C. 56101","children":[],"tail":", 57109], as it existed prior to the date of enactment of this Act, to the extent that such section 9 would have governed such transactions.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
