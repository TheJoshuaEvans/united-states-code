{"tag":"section","attrib":{"id":"idf6a0ad61-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108"},"text":null,"children":[{"tag":"num","attrib":{"value":"15108"},"text":"§ 15108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Towing Safety Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a0ad62-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a National Towing Safety Advisory Committee (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad63-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall advise the Secretary on matters relating to shallow-draft inland navigation, coastal waterway navigation, and towing safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad64-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ad65-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall consist of 18 members appointed by the Secretary in accordance with this section and section 15109 of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad66-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expertise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad67-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Committee shall be appointed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad68-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7 members shall represent the barge and towing industry, reflecting a regional geographic balance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad69-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent the offshore mineral and oil supply vessel industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad6a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent masters and pilots of towing vessels who hold active licenses and have experience on the Western Rivers and the Gulf Intracoastal Waterway.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad6b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent masters of towing vessels in offshore service who hold active licenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad6c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent masters of active ship-docking or harbor towing vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad6d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member shall represent licensed and unlicensed towing vessel engineers with formal training and experience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad6e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members shall represent port districts, authorities, or terminal operators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad6f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members shall represent shippers and, of the 2, 1 shall be engaged in the shipment of oil or hazardous materials by barge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad70-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15108/c/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members shall represent the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a0ad71-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVI/s601/a"},"text":"Pub. L. 115–282, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4285"},"text":"132 Stat. 4285","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
