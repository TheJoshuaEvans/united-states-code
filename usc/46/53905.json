{"tag":"section","attrib":{"id":"idf6e35aa5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53905"},"text":null,"children":[{"tag":"num","attrib":{"value":"53905"},"text":"§ 53905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency insurance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e35aa6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With the approval of the President, an agency of the United States Government may obtain insurance provided for by this chapter from the Secretary of Transportation, except as provided in sections 17302 and 17303 of title 40.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35aa7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Premium Waivers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With the approval of the President, the Secretary of Transportation may provide insurance under this chapter at the request of the Secretary of Defense and other agencies the President may prescribe, without payment of an insurance premium if the Secretary of Defense or agency agrees to indemnify the Secretary of Transportation against loss covered by the insurance. The Secretary of Defense and agencies may make such an indemnity agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35aa8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presidential Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The signature of the President (or an official designated by the President) on the agreement shall be treated as the approval required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53902/a"},"text":"section 53902(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e35aa9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1628"},"text":"120 Stat. 1628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e35aaa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e35aab-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e35aac-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"