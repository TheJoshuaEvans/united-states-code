{"tag":"section","attrib":{"id":"idf6ecf850-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101"},"text":null,"children":[{"tag":"num","attrib":{"value":"56101"},"text":"§ 56101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval required to transfer vessel to noncitizen","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ecf851-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restrictions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ecf852-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12119"},"text":"section 12119 of this title","children":[],"tail":", or section 611 of the Merchant Marine Act, 1936, a person may not, without the approval of the Secretary of Transportation—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ecf853-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" sell, lease, charter, deliver, or in any other manner transfer, or agree to sell, lease, charter, deliver, or in any other manner transfer, to a person not a citizen of the United States, an interest in or control of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6ecf854-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a documented vessel owned by a citizen of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6ecf855-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel last documented under the laws of the United States; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf856-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place under foreign registry, or operate under the authority of a foreign country, a documented vessel or a vessel last documented under the laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf857-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1)(A) does not apply to a vessel that has been operated only for pleasure or only as a fishing vessel, fish processing vessel, or fish tender vessel (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"section 2101 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf858-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval Before Documentation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To promote financing with respect to a vessel to be documented under chapter 121 of this title, the Secretary may grant approval under subsection (a) before the vessel is documented.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf859-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this subtitle, the Merchant Marine Act, 1936, or any contract with the Secretary made under this subtitle or that Act, a person may place a vessel under foreign registry without the approval of the Secretary if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ecf85a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ecf85b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, in conjunction with the Secretary of Defense, determines that at least one replacement vessel of equal or greater military capability and of a capacity that is equivalent or greater, as measured by deadweight tons, gross tons, or container equivalent units, as appropriate, is documented under chapter 121 of this title by the owner of the vessel placed under foreign registry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf85c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the replacement vessel is not more than 10 years old on the date of that documentation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf85d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an operating agreement covering the vessel under chapter 531 of this title has expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf85e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status of Prohibited Transaction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A charter, sale, or transfer of a vessel, or of an interest in or control of a vessel, in violation of this section is void.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf85f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ecf860-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person that knowingly sells, charters, or transfers a vessel, or an interest in or control of a vessel, in violation of this section shall be fined under title 18, imprisoned for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf861-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person that sells, charters, or transfers a vessel, or an interest in or control of a vessel, in violation of this section is liable to the United States Government for a civil penalty of not more than $10,000 for each violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf862-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forfeiture","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A documented vessel may be seized by and forfeited to the Government if, in violation of this section, a person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ecf863-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly sells, charters, or transfers the vessel or an interest in or control of the vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf864-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" places the vessel under foreign registry or operates the vessel under the authority of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf865-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Vessel Charters for Passenger Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Maritime Administrator shall make publicly available on an appropriate website of the Maritime Administration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ecf866-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed summary of each request for a determination, approval, or confirmation that a vessel charter for a passenger vessel is encompassed by the general approval of time charters issued pursuant to this section or regulations prescribed pursuant to such section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf867-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56101/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final action of the Administration with respect to such request, after the provision of notice and opportunity for public comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ecf868-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1651"},"text":"120 Stat. 1651","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dC/tXXXV/s3514/b/2"},"text":"Pub. L. 118–31, div. C, title XXXV, § 3514(b)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/810"},"text":"137 Stat. 810","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ecf869-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ecf86a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ecf86b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"t