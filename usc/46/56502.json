{"tag":"section","attrib":{"id":"idf6ef4209-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56502"},"text":null,"children":[{"tag":"num","attrib":{"value":"56502"},"text":"§ 56502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjusting obligations and arranging maintenance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ef420a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On written application, the Secretary of Transportation may adjust obligations and arrange for maintenance of an essential vessel as provided in this chapter if the Secretary determines, after any investigation or proceeding the Secretary considers desirable, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ef420b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the operation of the vessel in the service, route, or line to which it is assigned under this subtitle, or in which it otherwise would be operated, is not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ef420c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56502/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lawful under the Neutrality Act of 1939 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s441"},"text":"22 U.S.C. 441","children":[],"tail":" et seq.) or a proclamation issued under that Act; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ef420d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56502/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compatible with maintaining the availability of the vessel for national defense and commerce;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ef420e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is not feasible under existing law to employ the vessel in any other service or operation in foreign or domestic trade (except temporary or emergency operation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s56503/b/5"},"text":"section 56503(b)(5) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ef420f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant, because of the restrictions of the Neutrality Act of 1939 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s441"},"text":"22 U.S.C. 441","children":[],"tail":" et seq.) or the withdrawal of vessels for national defense under paragraph (1), is not earning or will not earn a reasonable return on the capital necessarily employed in its business."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ef4210-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Adjustments and arrangements under subsection (a) shall continue in effect only as long as the circumstances described in subsection (a) continue to exist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ef4211-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1657"},"text":"120 Stat. 1657","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ef4212-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ef4213-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ef4214-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"56502","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1242a(b), (e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1940-06-29/ch442"},"text":"June 29, 1940, ch. 442","children":[],"tail":", subdivs. (b), (e), "},{"tag":"html:a","attrib":{"href":"/us/stat/54/684"},"text":"54 Stat. 684","children":[],"tail":", 686; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/132"},"text":"Pub. L. 97–31, § 12(132)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/165"},"text":"95 Stat. 165","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of 46 App. U.S.C. 1242a(b) (1st sentence) is omitted as surplus. The text of 46 App. U.S.C. 1242a(e) is omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6ef4215-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6ef4216-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Neutrality Act of 1939, referred to in subsec. (a)(1)(A), (3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-11-04/ch2"},"text":"act Nov. 4, 1939, ch. 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/4"},"text":"54 Stat. 4","children":[],"tail":", which is classified generally to subchapter II (§ 441 et seq.) of chapter 9 of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s441"},"text":"section 441 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
