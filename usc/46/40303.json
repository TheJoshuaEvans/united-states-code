{"tag":"section","attrib":{"id":"idf6ac93ef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303"},"text":null,"children":[{"tag":"num","attrib":{"value":"40303"},"text":"§ 40303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ac93f0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ocean Common Carrier Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ac93f1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restrictions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An ocean common carrier agreement may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ac93f2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit or restrict a member of the agreement from engaging in negotiations for a service contract with a shipper;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ac93f3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a member of the agreement to disclose a negotiation on a service contract, or the terms of a service contract, other than those terms required to be published under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s40502/d"},"text":"section 40502(d) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ac93f4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt mandatory rules or requirements affecting the right of an agreement member to negotiate and enter into a service contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93f5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntary guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An ocean common carrier agreement may provide authority to adopt voluntary guidelines relating to the terms and procedures of an agreement member’s service contracts if the guidelines explicitly state the right of members of the agreement not to follow the guidelines. Any guidelines adopted shall be submitted confidentially to the Federal Maritime Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ac93f6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conference Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each conference agreement must—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ac93f7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state its purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93f8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide reasonable and equal terms for admission and readmission to conference membership for any ocean common carrier willing to serve the particular trade or route;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93f9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit any member to withdraw from conference membership on reasonable notice without penalty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93fa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of any member, require an independent neutral body to police fully the obligations of the conference and its members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit the conference from engaging in conduct prohibited by section 41105(1) or (3) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for a consultation process designed to promote—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ac93fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercial resolution of disputes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ac93fe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperation with shippers in preventing and eliminating malpractices;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93ff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures for promptly and fairly considering requests and complaints of shippers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac9400-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ac9401-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member of the conference may take independent action on a rate or service item on not more than 5 days’ notice to the conference; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ac9402-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except for an exempt commodity not published in the conference tariff, the conference will include the new rate or service item in its tariff for use by that member, effective no later than 5 days after receipt of the notice, and by any other member that notifies the conference that it elects to adopt the independent rate or service item on or after its effective date, in lieu of the existing conference tariff provision for that rate or service item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ac9403-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interconference Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each agreement between carriers not members of the same conference must provide the right of independent action for each carrier. Each agreement between conferences must provide the right of independent action for each conference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ac9404-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel Sharing Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ac9405-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An ocean common carrier that is the owner, operator, or bareboat, time, or slot charterer of a liner vessel documented under section 12103 or 12111(c) of this title may agree with an ocean common carrier described in paragraph (2) to which it charters or subcharters the vessel or space on the vessel that the charterer or subcharterer may not use or make available space on the vessel for the carriage of cargo reserved by law for vessels of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac9406-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40303/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Carrier described","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An ocean common carrier described in this paragraph is one that is not the owner, operator, or bareboat charterer for at least one year of liner vessels of the United States that are eligible to be included in the Maritime Security Fleet Program and are enrolled in an Emergency Preparedness Program under chapter 531 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ac9407-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1529"},"text":"120 Stat. 1529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ac9408-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ac9409-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ac940a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40303(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1704(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/98/237/s5/b"},"text":"Pub. L. 98–237, § 5(b)","children":[],"tail":"–(d), "},{"tag":"html:span","attrib":{},"text":"Mar. 20, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/70"},"text":"98 Stat. 70","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tI/s104/a"},"text":"Pub. L. 105–258, title I, § 104(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1904"},"text":"112 Stat. 1904","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40303(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1704(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40303(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1704(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40303(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1704(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/98/237/s5/g"},"text":"Pub. L. 98–237, § 5(g)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 20, 1984","children":[],"tail":"; as added "},{"tag":"html:a","attrib":{"href":"/us/pl/105/383/tIV/s424/a"},"text":"Pub. L. 105–383, title IV, § 424(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/3440"},"text":"112 Stat. 3440","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(8), the word “calendar” is omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “vessel of the United States” are substituted for “United States-flag vessel” (and similar variations) for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
