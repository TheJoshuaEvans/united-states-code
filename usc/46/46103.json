{"tag":"section","attrib":{"id":"idf6b60955-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103"},"text":null,"children":[{"tag":"num","attrib":{"value":"46103"},"text":"§ 46103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b60956-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Maritime Commission shall be deemed to be an agency for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60957-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Record","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission, through its secretary, shall keep a record of its meetings and the votes taken on any action, order, contract, or financial transaction of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60958-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonpublic Collaborative Discussions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b60959-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":", a majority of the Commissioners may hold a meeting that is not open to public observation to discuss official agency business if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b6095a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no formal or informal vote or other official agency action is taken at the meeting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b6095b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each individual present at the meeting is a Commissioner or an employee of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b6095c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 Commissioner from each political party is present at the meeting, if applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b6095d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Counsel of the Commission is present at the meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b6095e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure of nonpublic collaborative discussions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided under paragraph (3), not later than 2 business days after the conclusion of a meeting under paragraph (1), the Commission shall make available to the public, in a place easily accessible to the public—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b6095f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the individuals present at the meeting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b60960-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the matters discussed at the meeting, except for any matters the Commission properly determines may be withheld from the public under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b/c"},"text":"section 552b(c) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60961-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Commission properly determines matters may be withheld from the public under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b/c"},"text":"section 552b(c) of title 5","children":[],"tail":", the Commission shall provide a summary with as much general information as possible on those matters withheld from the public."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60962-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ongoing proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a meeting under paragraph (1) directly relates to an ongoing proceeding before the Commission, the Commission shall make the disclosure under paragraph (2) on the date of the final Commission decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60963-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation of open meetings requirements for agency action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection may be construed to limit the applicability of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":" with respect to a meeting of the Commissioners other than that described in this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60964-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statutory construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection may be construed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b60965-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the applicability of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":" with respect to any information which is proposed to be withheld from the public under paragraph (2)(B) of this subsection; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b60966-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46103/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize the Commission to withhold from any individual any record that is accessible to that individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b60967-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s4"},"text":"Pub. L. 109–304, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1489"},"text":"120 Stat. 1489","children":[],"tail":", § 303; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVII/s711/a"},"text":"Pub. L. 115–282, title VII, § 711(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4297"},"text":"132 Stat. 4297","children":[],"tail":"; renumbered § 46103 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXVI"},"text":"Pub. L. 116–283, div. G, title LVXXXVI","children":[],"tail":" [LXXXVI], § 8605(a)(3), (c), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4765"},"text":"134 Stat. 4765","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b60968-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b60969-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b6096a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1111(c) (related to records).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title II, § 201(c) (related to records), "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1986"},"text":"49 Stat. 1986","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “true” and “yea-and-nay” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6b6096b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6b6096c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8605/a/3"},"text":"Pub. L. 116–283, § 8605(a)(3)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s303"},"text":"section 303 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8605/c"},"text":"Pub. L. 116–283, § 8605(c)","children":[],"tail":", substituted “552b(c)” for “555b(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “The Federal Maritime Commission, through its secretary, shall keep a record of its meetings and the votes taken on any action, order, contract, or financial transaction of the Commission.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
