{"tag":"section","attrib":{"id":"idf6f1b30c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57306"},"text":null,"children":[{"tag":"num","attrib":{"value":"57306"},"text":"§ 57306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of trade-in allowance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f1b30d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition at Time of Contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If acquisition of an obsolete vessel under this chapter occurs when the owner contracts for the construction or purchase of the new vessel, the Secretary of Transportation shall apply the trade-in allowance to the purchase price of the new vessel rather than paying it to the owner. If the new vessel is constructed under this subtitle, the Secretary may apply the trade-in allowance to the required cash payments on terms and conditions the Secretary may prescribe. If the new vessel is not constructed under this subtitle, the Secretary shall pay the trade-in allowance to the builder of the vessel for the account of the owner when the Secretary acquires the obsolete vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b30e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition at Time of Delivery","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If acquisition of the obsolete vessel occurs when the new vessel is delivered to the owner, the Secretary shall deposit the trade-in allowance in the owner’s capital construction fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b30f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1663"},"text":"120 Stat. 1663","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b310-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f1b311-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f1b312-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"57306","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1160(b) (4th–7th sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title V, § 510(b) (4th–7th sentences), as added "},{"tag":"html:a","attrib":{"href":"/us/act/1939-08-04/ch417/s7"},"text":"Aug. 4, 1939, ch. 417, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/1184"},"text":"53 Stat. 1184","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/87/401"},"text":"Pub. L. 87–401","children":[],"tail":", subdiv. (1), "},{"tag":"html:span","attrib":{},"text":"Oct. 5, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/833"},"text":"75 Stat. 833","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/469"},"text":"Pub. L. 91–469","children":[],"tail":", §§ 12(b), 35(a), "},{"tag":"html:span","attrib":{},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1022"},"text":"84 Stat. 1022","children":[],"tail":", 1035; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/91"},"text":"Pub. L. 97–31, § 12(91)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/161"},"text":"95 Stat. 161","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “acquisition of the obsolete vessel occurs” are substituted for “title to the obsolete vessel is acquired” for consistency in the chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
