{"tag":"section","attrib":{"id":"idf66c2ef0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3706"},"text":null,"children":[{"tag":"num","attrib":{"value":"3706"},"text":"§ 3706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Product carrier minimum standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf66c2ef1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A new product carrier of at least 30,000 deadweight tons shall be equipped with protectively located segregated ballast tanks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66c2ef2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A new product carrier of at least 20,000 deadweight tons shall be equipped with a cargo tank protection system consisting of a fixed deck froth system and a fixed inert gas system or, if the product carrier carries dedicated products incompatible with the cargo tank protection system, an alternate protection system authorized by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66c2ef3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An existing product carrier of at least 40,000 deadweight tons shall be equipped with segregated ballast tanks or may operate with dedicated clean ballast tanks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66c2ef4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An existing product carrier of at least 20,000 deadweight tons but less than 40,000 deadweight tons, and at least 15 years of age, shall be equipped with segregated ballast tanks or may operate with dedicated clean ballast tanks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66c2ef5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3706/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An existing product carrier of at least 40,000 deadweight tons, or an existing product carrier of at least 20,000 deadweight tons but less than 40,000 deadweight tons that is fitted with high-capacity tank washing machines, shall be equipped with an inert gas system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf66c2ef6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/523"},"text":"97 Stat. 523","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3544/c"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3544(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2325"},"text":"132 Stat. 2325","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf66c2ef7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf66c2ef8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf66c2ef9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3706(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(7)(B)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3706(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(7)(C)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3706(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(7)(G)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3706(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(7)(H)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3706(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(7)(I)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3706 requires compliance with certain minimum standards by a product carrier, which is a self-propelled tank vessel.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3706(a) requires new product carriers of 30,000 deadweight tons or above, to have protectively located segregated ballast tanks.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3706(b) requires new product carriers of 20,000 deadweight tons or above, to have a cargo tank protection system consisting of a fixed deck froth system or a fixed inert gas system. If the products carried are incompatible with the cargo tank protection system, then an alternative protection system may be authorized.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3706(c) requires existing product carriers of 40,000 deadweight tons or above, to have segregated ballast tanks or to operate with dedicated clean ballast tanks.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3706(d) requires existing product carriers of 20,000 deadweight tons or above, but less than 40,000 deadweight tons, that are 15 years or older, to have segregated ballast tanks by ","children":[{"tag":"date","attrib":{"date":"1985-01-01"},"text":"January 1, 1985","children":[],"tail":", or on the date on which it reaches 15 years of age or, in the alternative, that the vessel operate with dedicated clean ballast tanks."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3706(e) requires existing product carriers of 40,000 deadweight tons or above, or to existing product carriers, fitted with high-capacity tank washing machines, of 20,000 deadweight tons but less than 40,000 deadweight tons, to install an inert gas system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf66c2efa-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf66c2efb-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" struck out “before "},{"tag":"date","attrib":{"date":"1986-01-02"},"text":"January 2, 1986","children":[],"tail":", or the date on which it reaches 15 years of age, whichever is later” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
