{"tag":"section","attrib":{"id":"idf69255a6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105"},"text":null,"children":[{"tag":"num","attrib":{"value":"12105"},"text":"§ 12105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of documentation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf69255a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12152"},"text":"section 12152 of this title","children":[],"tail":", the Secretary, on receipt of a proper application, shall issue a certificate of documentation or a temporary certificate of documentation for a vessel satisfying the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12103"},"text":"section 12103 of this title","children":[],"tail":". The certificate shall contain each endorsement under subchapter II of this chapter for which the owner applies and the vessel is eligible."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69255a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary Certificates for Recreational Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may delegate, subject to the supervision and control of the Secretary and under terms prescribed by regulation, to private entities determined and certified by the Secretary to be qualified, the authority to issue a temporary certificate of documentation for a recreational vessel eligible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12103"},"text":"section 12103 of this title","children":[],"tail":". A temporary certificate issued under this subsection is valid for not more than 30 days."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69255a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information To Be Included in Certificate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A certificate of documentation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf69255aa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and describe the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69255ab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the owner of the vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69255ac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain additional information prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69255ad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures To Ensure Integrity and Accuracy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe procedures to ensure the integrity of, and the accuracy of information contained in, certificates of documentation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69255ae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Period.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf69255af-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraphs (2) and (3), a certificate of documentation issued under this part is valid for a 1-year period and may be renewed for additional 1-year periods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69255b0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recreational vessels.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf69255b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The owner or operator of a recreational vessel may choose a period of effectiveness of between 1 and 5 years for a certificate of documentation for a recreational vessel or the renewal thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69255b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idf69255b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall assess and collect a fee—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf69255b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the issuance of a certificate of documentation for a recreational vessel that is equivalent to the fee established for the issuance of a certificate of documentation under section 2110; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf69255b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the renewal of a certificate of documentation for a recreational vessel that is equivalent to the number of years of effectiveness of the certificate of documentation multiplied by the fee established for the renewal of a certificate of documentation under section 2110.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf69255b6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Fees collected under this subsection—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf69255b7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited to the account from which the costs of such issuance or renewal were paid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf69255b8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69255b9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of change in information.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf69255ba-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The owner of a vessel shall notify the Coast Guard of each change in the information on which the issuance of the certificate of documentation for the vessel is based that occurs before the expiration of the certificate under this subsection, by not later than 30 days after such change.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69255bb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of certificate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The certificate of documentation for a vessel shall terminate upon the expiration of such 30-day period if the owner has not notified the Coast Guard of such change before the end of such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69255bc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12105/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State and local authority to remove abandoned and derelict vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to limit the authority of a State or local authority from taking action to remove an abandoned or derelict vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf69255bd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1493"},"text":"120 Stat. 1493","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tV/s512"},"text":"Pub. L. 115–282, title V, § 512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4275"},"text":"132 Stat. 4275","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dC/tXXXV/s3511"},"text":"Pub. L. 117–81, div. C, title XXXV, § 3511","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2238"},"text":"135 Stat. 2238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69255be-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69255bf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf69255c0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12105(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:12103(a) (less filing by owner).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12105(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:12103a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12105(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:12103(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12105(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:12103(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “eligible under” are substituted for “if the applicant for the certificate of documentation meets the requirements set out in” for consistency in the chapter and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf69255c1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf69255c2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12105, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/586"},"text":"97 Stat. 586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s104/a/4"},"text":"Pub. L. 100–710, title I, § 104(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4750"},"text":"102 Stat. 4750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/225/tIII/s301/a/5"},"text":"Pub. L. 101–225, title III, § 301(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1920"},"text":"103 Stat. 1920","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIII/s310"},"text":"Pub. L. 109–241, title III, § 310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/529"},"text":"120 Stat. 529","children":[],"tail":", originally derived from section 65h of former Title 46, Shipping, related to registry endorsements, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12111"},"text":"section 12111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf69255c3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (e)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s3511/1"},"text":"Pub. L. 117–81, § 3511(1)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A), which read as follows: “"},{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—A certificate of documentation for a recreational vessel and the renewal of such a certificate shall be effective for a 5-year period.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s3511"},"text":"Pub. L. 117–81, § 3511","children":[],"tail":", redesignated subpar. (C) as (B) and struck out former subpar. (B), which read as follows: “"},{"tag":"inline","attrib":{},"text":"Phase-in period","children":[],"tail":".—During the period beginning "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"January 1, 2019","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":", the owner or operator of a recreational vessel may choose a period of effectiveness of between 1 and 5 years for such a certificate of documentation for such vessel or the renewal thereof.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf69255c4-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf69255c5-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Certificates of Documentation for Recreational Vessels","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s311"},"text":"Pub. L. 114–120, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/57"},"text":"130 Stat. 57","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/120/tIII/s311"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":"], the Secretary of the department in which the Coast Guard is operating shall issue regulations that—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make certificates of documentation for recreational vessels effective for 5 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require the owner of such a vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to notify the Coast Guard of each change in the information on which the issuance of the certificate of documentation is based, that occurs before the expiration of the certificate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" [to] apply for a new certificate of documentation for such a vessel if there is any such change.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
