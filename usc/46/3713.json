{"tag":"section","attrib":{"id":"idf66c2f37-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3713"},"text":null,"children":[{"tag":"num","attrib":{"value":"3713"},"text":"§ 3713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf66c2f38-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf66c2f39-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3713/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violate this chapter or a regulation prescribed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f3a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3713/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuse to permit any official, authorized by the Secretary to enforce this chapter, to board a vessel or to enter a shore area, place, or premises, under a person’s control to make an inspection under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f3b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3713/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuse to obey a lawful directive issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66c2f3c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A vessel to which this chapter applies may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf66c2f3d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3713/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate on the navigable waters of the United States or use a port or place subject to the jurisdiction of the United States when not in compliance with this chapter or a regulation prescribed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f3e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3713/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to comply with a lawful directive issued under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2f3f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3713/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry a type or grade of oil or hazardous material in bulk as cargo or cargo residue unless its certificate is endorsed to allow that carriage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf66c2f40-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/525"},"text":"97 Stat. 525","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf66c2f41-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf66c2f42-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf66c2f43-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3713","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(13)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3713(a) prohibits any person from violating any provision of this chapter or a regulation prescribed under its authority. It prohibits the refusal to permit authorized officials to board a vessel or to enter a shore area for the purposes of inspection of the vessel or premises. It also prohibits the refusal to obey any lawful directive issued under this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3713(b) prohibits any vessel, subject to the provisions of this chapter from operating on the navigable waters of the United States, or from using any port or place subject to the jurisdiction of the United States while not in compliance with any provision of applicable law or regulation. It further prohibits any vessel from failing to comply with a lawful directive issued pursuant to the authority of this chapter. It also prohibits the vessel from carrying oil or hazardous material as cargo or cargo residue unless its certificate is so endorsed to permit its carriage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
