{"tag":"section","attrib":{"id":"idf6674d4f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3509"},"text":null,"children":[{"tag":"num","attrib":{"value":"3509"},"text":"§ 3509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical standards","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The owner of a vessel to which section 3507 applies shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6674d50-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3509/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a physician is always present and available to treat any passengers who may be on board the vessel in the event of an emergency situation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6674d51-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3509/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is in compliance with the Health Care Guidelines for Cruise Ship Medical Facilities established by the American College of Emergency Physicians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6674d52-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3509/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the initial safety briefing given to the passengers on board the vessel includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6674d53-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3509/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of the vessel’s medical facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6674d54-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3509/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate steps passengers should follow during a medical emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6674d55-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8322(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4702"},"text":"134 Stat. 4702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6674d56-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6674d57-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6674d58-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exemptions for Certain Passenger Vessels","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions exempting certain passenger vessels from the requirements authorized under this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11510"},"text":"section 11510 of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s3508"},"text":"section 3508 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
