{"tag":"section","attrib":{"id":"idf6aa22e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31329"},"text":null,"children":[{"tag":"num","attrib":{"value":"31329"},"text":"§ 31329.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court sales of documented vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6aa22e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31329/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A documented vessel may be sold by order of a district court only to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aa22e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31329/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person eligible to own a documented vessel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12103"},"text":"section 12103 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aa22e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31329/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mortgagee of that vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aa22e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31329/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When a vessel is sold to a mortgagee not eligible to own a documented vessel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aa22e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31329/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel must be held by the mortgagee for resale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aa22e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31329/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel held by the mortgagee is subject to chapter 563 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aa22e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31329/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of the vessel to the mortgagee is not a sale to a person not a citizen of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12132"},"text":"section 12132 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aa22e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31329/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless waived by the Secretary of Transportation, a person purchasing a vessel by court order under subsection (a)(1) of this section or from a mortgagee under subsection (a)(2) of this section must document the vessel under chapter 121 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aa22e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31329/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The vessel may be operated by the mortgagee not eligible to own a documented vessel only with the approval of the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aa22ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31329/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A sale of a vessel contrary to this section is void.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aa22eb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s31329/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to a documented vessel that has been operated only for pleasure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6aa22ec-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s102/c"},"text":"Pub. L. 100–710, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4747"},"text":"102 Stat. 4747","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tXI/s1118"},"text":"Pub. L. 104–324, title XI, § 1118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3973"},"text":"110 Stat. 3973","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/32"},"text":"Pub. L. 109–304, § 15(32)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1704"},"text":"120 Stat. 1704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIX/s913/c"},"text":"Pub. L. 111–281, title IX, § 913(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3017"},"text":"124 Stat. 3017","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6aa22ed-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6aa22ee-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6aa22ef-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31329","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:961(f)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31329 sets out certain restrictions on the court sale of a documented vessel.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31329(a) restricts the sale only to a person eligible to own a documented vessel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12102"},"text":"section 12102 of title 46","children":[],"tail":" or to the mortgagee, which may be a trustee acting as a holder of a preferred mortgage on a documented vessel for the benefit of a person not eligible to be the holder of a preferred mortgage on that vessel."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31329(b) sets out conditions on the sale to a trustee acting as a holder of a preferred mortgage on a documented vessel for the benefit of a person not eligible to be the holder of a preferred mortgage on that vessel. First, the vessel must be held by the trustee for resale. Second, while being held for resale, the vessel is subject to requisition or purchase during a national emergency under section 902 of the Merchant Marine Act, 1936 (46 App. U.S.C. 1242). And third, the sale of the vessel to the trustee is not a sale foreign within the terms of the First Proviso of section 27 of the Merchant Marine Act, 1920 (46 App. U.S.C. 883).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31329(c) requires a person that is eligible to document the vessel that purchases a vessel from the court to document the vessel. This subsection also requires the person purchasing the vessel from the trustee to document it, thereby restricting to whom the trustee can sell the vessel. Many documented vessels have no national defense utility, such as recreational vessels and fishing vessels. Therefore, both of these restrictions can be waived by the Secretary. As previously discussed, these waivers can be on a case-by-case basis or with a blanket waiver.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31329(d) prohibits a trustee from operating the vessel without the approval of the Secretary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31329(e) voids any sale that is done contrary to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6aa22f0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"house floor statement","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Under section 31329(d) a vessel may be operated by the trustee only with the approval of the Secretary. Under current law a vessel may be documented by a trust if all of the members of the trust are citizens of the United States. If the trust buying the vessel at the court sale includes foreign investors, the vessel cannot be documented. The Committee intends in this section that the vessel will only be “operated” in a maintenance manner, but not in a commercial service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6aa22f1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6aa22f2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" substituted “Secretary of Transportation” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/32/A"},"text":"Pub. L. 109–304, § 15(32)(A)","children":[],"tail":", substituted “section 12103” for “section 12102”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/32/B/i"},"text":"Pub. L. 109–304, § 15(32)(B)(i)","children":[],"tail":", substituted “chapter 563 of this title” for “section 902 of the Merchant Marine Act, 1936 (46 App. U.S.C. 1242)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/32/B/ii"},"text":"Pub. L. 109–304, § 15(32)(B)(ii)","children":[],"tail":", substituted “sale to a person not a citizen of the United States under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12132"},"text":"section 12132 of this title","children":[],"tail":"” for “sale foreign within the terms of the first proviso of section 27 of the Merchant Marine Act, 1920 (46 App. U.S.C. 883)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6aa22f3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf6aa22f4-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/710/s107"},"text":"section 107 of Pub. L. 100–710","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s31301"},"text":"section 31301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
