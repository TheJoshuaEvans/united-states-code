{"tag":"section","attrib":{"id":"idf6f3fd11-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58108"},"text":null,"children":[{"tag":"num","attrib":{"value":"58108"},"text":"§ 58108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charges for transportation subject to subtitle IV of title 49","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f3fd12-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier may not charge, collect, or receive for transportation subject to subtitle IV of title 49 of persons or property, under any joint rate, fare, or charge, or under any export, import, or other proportional rate, fare, or charge, that is based in whole or in part on the fact that the persons or property affected are to be transported to, or have been transported from, a port in a territory or possession of the United States or in a foreign country, by a carrier by water in foreign commerce, any lower rate, fare, or charge than the carrier charges, collects, or receives for the transportation of persons or similar property for the same distance, in the same direction, and over the same route, in commerce wholly within the United States, unless the vessel used for the transportation is or was at the time of the transportation documented under the laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f3fd13-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension of Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever the Secretary of Transportation believes that adequate shipping facilities to or from any port in a territory or possession of the United States or a foreign country are not being provided by vessels documented under the laws of the United States, the Secretary shall certify this fact to the Surface Transportation Board. On receiving the certification, the Board may by order suspend the operation of subsection (a) with respect to the rates, fares, and charges for the transportation by rail of persons and property transported from or to be transported to those ports, for such time and under such terms and conditions as the Secretary may specify in the order or in any supplemental order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f3fd14-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Suspension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever the Secretary believes that adequate shipping facilities are being provided to those ports by vessels documented under the laws of the United States, and certifies that fact to the Board, the Board may order the termination of the suspension.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f3fd15-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1673"},"text":"120 Stat. 1673","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f3fd16-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f3fd17-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f3fd18-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"58108","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:884.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-06-05/ch250/s28"},"text":"June 5, 1920, ch. 250, § 28","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/41/999"},"text":"41 Stat. 999","children":[],"tail":"; Ex. Ord. No. 6166, § 12, eff. "},{"tag":"html:span","attrib":{},"text":"June 10, 1933","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", §§ 204, 904, "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1987"},"text":"49 Stat. 1987","children":[],"tail":", 2016; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/50"},"text":"Pub. L. 97–31, § 12(50)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/157"},"text":"95 Stat. 157","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/88/tIII/s321/3"},"text":"Pub. L. 104–88, title III, § 321(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/109/950"},"text":"109 Stat. 950","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “territory or possession” are substituted for “possession or dependency” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
