{"tag":"section","attrib":{"id":"idf7098112-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80302"},"text":null,"children":[{"tag":"num","attrib":{"value":"80302"},"text":"§ 80302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Patrol services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7098113-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless the agreements made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s80301"},"text":"section 80301 of this title","children":[],"tail":" provide otherwise, an ice patrol shall be maintained during the entire ice season in guarding the southeastern, southern, and southwestern limits of the region of icebergs in the vicinity of the Grand Banks of Newfoundland. The patrol shall inform trans-Atlantic and other passing vessels by radio and other available means of the ice conditions and the extent of the dangerous region. During the ice season, there shall be maintained a service of study of ice and current conditions, a service of providing assistance to vessels and crews requiring assistance, and a service of removing and destroying derelicts. Any of these services may be maintained during the remainder of the year as may be advisable."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098114-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Warnings to Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The ice patrol shall warn any vessel known to be approaching a dangerous area and recommend safe routes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098115-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recording and Reporting Incidents","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7098116-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recording","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The ice patrol shall record the name of a vessel and the facts of the case when the patrol observes or knows that the vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf7098117-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80302/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is on other than a regular recognized or advertised route crossing the North Atlantic Ocean;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7098118-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80302/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has crossed the fishing banks of Newfoundland north of latitude 43 degrees north during the fishing season; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7098119-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80302/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has passed through regions known or believed to be endangered by ice when proceeding to and from ports of North America.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf709811a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The name of the vessel and all pertinent information about the incident shall be reported to the government of the country to which the vessel belongs if that government requests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf709811b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant, under the direction of the Secretary of the department in which the Coast Guard is operating, shall carry out the services provided for in this section and shall assign necessary aircraft, material, and personnel of the Coast Guard. On request of such Secretary, the head of an agency may detail personnel, lend or contribute material or equipment, or otherwise assist in carrying out the services provided for in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70bf11c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall publish an annual report of the activities of the services provided for in this section. A copy of the report shall be provided to each interested foreign government and to each agency assisting in the work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf70bf11d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s11"},"text":"Pub. L. 109–304, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1692"},"text":"120 Stat. 1692","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIII/s314/a/2"},"text":"Pub. L. 113–281, title III, § 314(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3049"},"text":"128 Stat. 3049","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3541/b/16"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3541(b)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2324"},"text":"132 Stat. 2324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf70bf11e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf70bf11f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf70bf120-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80302","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:738a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-25/ch807/s2"},"text":"June 25, 1936, ch. 807, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1922"},"text":"49 Stat. 1922","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s6/b/1"},"text":"Pub. L. 89–670, § 6(b)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/938"},"text":"80 Stat. 938","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “Secretary of the department in which the Coast Guard is operating” are substituted for “Secretary of Transportation” because of the transfer of the Coast Guard to the Department of Homeland Security (except when operating as a service in the Navy) by section 888 of the Homeland Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2249"},"text":"116 Stat. 2249","children":[],"tail":"). See also sections 1 and 3 of title 14, as amended by section 1704(a) of such Act ("},{"tag":"ref","attrib":{"href":"/us/stat/116/2314"},"text":"116 Stat. 2314","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf70bf121-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf70bf122-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" struck out “of the Coast Guard” after “The Commandant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/s314/a/2/A"},"text":"Pub. L. 113–281, § 314(a)(2)(A)","children":[],"tail":", substituted “The ice patrol” for “An ice patrol vessel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/s314/a/2/B"},"text":"Pub. L. 113–281, § 314(a)(2)(B)","children":[],"tail":", substituted “The ice patrol” for “An ice patrol vessel” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/s314/a/2/C"},"text":"Pub. L. 113–281, § 314(a)(2)(C)","children":[],"tail":", substituted “aircraft” for “vessels”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf70bf123-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf70bf124-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2017-01-01"},"text":"Jan. 1, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/s314/c"},"text":"section 314(c) of Pub. L. 113–281","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s80301"},"text":"section 80301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
