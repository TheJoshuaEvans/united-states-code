{"tag":"section","attrib":{"id":"idf67cd11a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7509"},"text":null,"children":[{"tag":"num","attrib":{"value":"7509"},"text":"§ 7509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical certification by trusted agents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf67cd11b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law and pursuant to regulations prescribed by the Secretary, a trusted agent may issue a medical certificate to an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67cd11c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7509/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must hold such certificate to qualify for a license, certificate of registry, or merchant mariner’s document, or endorsement thereto under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd11d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7509/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is qualified as to sight, hearing, and physical condition to perform the duties of such license, certificate, document, or endorsement, as determined by the trusted agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd11e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Process for Issuance of Certificates by Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A final rule implementing this section shall include a process for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67cd11f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7509/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the department in which the Coast Guard is operating to issue medical certificates to mariners who submit applications for such certificates to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd120-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7509/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trusted agent to defer to the Secretary the issuance of a medical certificate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd121-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7509/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Trusted Agent Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section the term “trusted agent” means a medical practitioner certified by the Secretary to perform physical examinations of an individual for purposes of a license, certificate of registry, or merchant mariner’s document under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67cd122-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s309/a"},"text":"Pub. L. 114–120, title III, § 309(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/56"},"text":"130 Stat. 56","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67cd123-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf67cd124-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf67cd125-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation Deadline","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s309/b"},"text":"Pub. L. 114–120, title III, § 309(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/57"},"text":"130 Stat. 57","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/120/tIII/s309/b"},"text":"“Not later than 5 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":"], the Secretary of the department in which the Coast Guard is operating shall issue a final rule implementing "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s7509"},"text":"section 7509 of title 46","children":[],"tail":", United States Code, as added by this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
