t":null,"children":[{"tag":"html:p","attrib":{},"text":"46:12106(e)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12119(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:12106(e)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), in paragraph (1), the words “satisfies the requirements for a coastwise endorsement, except for the ownership requirement otherwise applicable without regard to this section” are substituted for “otherwise eligible for documentation under this section” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12106/e/1/E"},"text":"46 U.S.C. 12106(e)(1)(E)","children":[],"tail":" for clarity. Subparagraph (A) of "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12106/e/1"},"text":"46 U.S.C. 12106(e)(1)","children":[],"tail":" is omitted as redundant to the general requirements in revised section 12112 on coastwise endorsements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “documented with a coastwise endorsement” are substituted for “documented under this section” because former section 12106 is being divided into multiple sections.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (e) is substituted for “(3) Upon termination by a demise charterer required under paragraph (1)(C), the coastwise endorsement of the vessel may, in the sole discretion of the Secretary, be continued after the termination for default of the demise charter for a period not to exceed 6 months on such terms and conditions as the Secretary may prescribe” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6970fc9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf6970fca-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12119, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/589"},"text":"97 Stat. 589","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s104/a/4"},"text":"Pub. L. 100–710, title I, § 104(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4750"},"text":"102 Stat. 4750","children":[],"tail":", originally derived from sections 65s and 881 of former Title 46, Shipping, related to list of documented vessels, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12138"},"text":"section 12138 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6970fcb-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “section 2101(28)” for “section 2101(26)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 2101(26)” for “section 2101(20)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6970fcc-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6970fcd-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application to Certain Certificates","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/tVI/s608/c"},"text":"Pub. L. 108–293, title VI, § 608(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1057"},"text":"118 Stat. 1057","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/293/tVI/s608/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending provisions from which this section was derived], and any regulations published after ","children":[{"tag":"date","attrib":{"date":"2004-02-04"},"text":"February 4, 2004","children":[],"tail":", with respect to coastwise endorsements, shall not apply to a certificate of documentation, or renewal thereof, endorsed with a coastwise endorsement for a vessel under section 12106(e) [now section 12119(b), (d)–(f)] of title 46, United States Code, or a replacement vessel of a similar size and function, that was issued prior to the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":"] as long as the vessel is owned by the person named therein, or by a subsidiary or affiliate of that person, and the controlling interest in such owner has not been transferred to a person that was not an affiliate of such owner as of the date of enactment of this Act. Notwithstanding the preceding sentence, however, the amendments made by this section shall apply, beginning 3 years after the date of enactment of this Act, with respect to offshore supply vessels (as defined in section 2101(19) [now 2101(27)] of title 46, United States Code, as that section was in effect on the date of enactment of this Act) with a certificate of documentation endorsed with a coastwise endorsement as of the date of enactment of this Act, and the Secretary of the Department in which the Coast Guard is operating shall revoke any such certificate if the vessel does not by then meet the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12106/e"},"text":"section 12106(e) of title 46","children":[],"tail":", United States Code, as amended by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Replacement Vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subsection, ‘replacement vessel’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a temporary replacement vessel for a period of not to exceed 180 days if the vessel described in paragraph (1) is unavailable due to an act of God or a marine casualty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a permanent replacement vessel if—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel described in paragraph (1) is unavailable for more than 180 days due to an act of God or a marine casualty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract to purchase or construct such replacement vessel is executed not later than ","children":[{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6970fce-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Waiver of Qualified Proprietary Cargo Requirement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/tVI/s608/d"},"text":"Pub. L. 108–293, title VI, § 608(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1057"},"text":"118 Stat. 1057","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/293/tVI/s608/d"},"text":"“The Secretary of Transportation shall waive or reduce the qualified proprietary cargo requirement of section 12106(f)(3)(A)(iii) [now section 12119(c)(3)(A)(iii)] of title 46, United States Code, for a vessel if the person that owns the vessel (or, if the vessel is owned by a trust or similar arrangement, the beneficiary of the trust or similar arrangement) notifies the Secretary that circumstances beyond the direct control of such person or its affiliates prevent, or reasonably threaten to prevent, such person from satisfying such requirement, and the Secretary does not, with good cause, determine otherwise. The waiver or reduction shall apply during the period of time that such circumstances exist.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
