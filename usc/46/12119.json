{"tag":"section","attrib":{"id":"idf6949f9b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119"},"text":null,"children":[{"tag":"num","attrib":{"value":"12119"},"text":"§ 12119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Owners engaged primarily in leasing or financing transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6949f9c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6949f9d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Affiliate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “affiliate” means, with respect to any person, any other person that is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6949f9e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly or indirectly controlled by, under common control with, or controlling that person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6949f9f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/1/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" named as being part of the same consolidated group in any report or other document submitted to the United States Securities and Exchange Commission or the Internal Revenue Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949fa0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cargo","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “cargo” does not include cargo to which title is held for non-commercial reasons and primarily for the purpose of evading the requirements of subsection (c)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949fa1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oil","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “oil” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101/28"},"text":"section 2101(28) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949fa2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Passive investment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “passive investment” means an investment in which neither the investor nor any affiliate of the investor is involved in, or has the power to be involved in, the formulation, determination, or direction of any activity or function concerning the management, use, or operation of the asset that is the subject of the investment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949fa3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified proprietary cargo","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified proprietary cargo” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6949fa4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oil, petroleum products, petrochemicals, or liquefied natural gas cargo that is beneficially owned by the person that submits to the Secretary an application or annual certification under subsection (c)(3), or by an affiliate of that person, immediately before, during, or immediately after the cargo is carried in coastwise trade on a vessel owned by that person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949fa5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oil, petroleum products, petrochemicals, or liquefied natural gas cargo not beneficially owned by the person that submits to the Secretary an application or an annual certification under subsection (c)(3), or by an affiliate of that person, but which is carried in coastwise trade by a vessel owned by that person and which is part of an arrangement in which vessels owned by that person and at least one other person are operated collectively as one fleet, to the extent that an equal amount of oil, petroleum products, petrochemicals, or liquefied natural gas cargo beneficially owned by that person, or by an affiliate of that person, is carried in coastwise trade on one or more other vessels, not owned by that person, or by an affiliate of that person, if the other vessel or vessels are also part of the same arrangement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949fa6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a towing vessel associated with a non-self-propelled tank vessel where both vessels function as a single self-propelled vessel, oil, petroleum products, petrochemicals, or liquefied natural gas cargo that is beneficially owned by the person that owns both the towing vessel and the non-self-propelled tank vessel, or any United States affiliate of that person, immediately before, during, or immediately after the cargo is carried in coastwise trade on either of those vessels; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949fa7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any oil, petroleum products, petrochemicals, or liquefied natural gas cargo carried on any vessel that is either a self-propelled tank vessel having a length of at least 210 meters or a tank vessel that is a liquefied natural gas carrier that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6949fa8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/5/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was delivered by the builder of the vessel to the owner of the vessel after ","children":[{"tag":"date","attrib":{"date":"1999-12-31"},"text":"December 31, 1999","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6949fa9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/5/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was purchased by a person for the purpose, and with the reasonable expectation, of transporting on the vessel liquefied natural gas or unrefined petroleum beneficially owned by the owner of the vessel, or an affiliate of the owner, from Alaska to the continental United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949faa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states affiliate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “United States affiliate” means, with respect to any person, an affiliate the principal place of business of which is located in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949fab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A coastwise endorsement may be issued for a vessel if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6949fac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel satisfies the requirements for a coastwise endorsement, except for the ownership requirement otherwise applicable without regard to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949fad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person that owns the vessel (or, if the vessel is owned by a trust or similar arrangement, the beneficiary of the trust or similar arrangement) meets the requirements of subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949fae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is under a demise charter to a person that certifies to the Secretary that the person is a citizen of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":" for engaging in the coastwise trade; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949faf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demise charter is for a period of at least 3 years or a shorter period as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949fb0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ownership Certification","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6949fb1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person meets the requirements of this subsection if the person transmits to the Secretary each year the certification required by paragraph (2) or (3) with respect to a vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949fb2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investment certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To meet the certification requirement of this paragraph, a person shall certify that it—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6949fb3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a leasing company, bank, or financial institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949fb4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns, or holds the beneficial interest in, the vessel solely as a passive investment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949fb5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not operate any vessel for hire and is not an affiliate of any person that operates any vessel for hire; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949fb6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is independent from, and not an affiliate of, any charterer of the vessel or any other person that has the right, directly or indirectly, to control or direct the movement or use of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949fb7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain tank vessels","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6949fb8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To meet the certification requirement of this paragraph, a person shall certify that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6949fb9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate book value of the vessels owned by the person and United States affiliates of the person does not exceed 10 percent of the aggregate book value of all assets owned by the person and its United States affiliates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6949fba-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 10 percent of the aggregate revenues of the person and its United States affiliates is derived from the ownership, operation, or management of vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6949fbb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 70 percent of the aggregate tonnage of all cargo carried by all vessels owned by the person and its United States affiliates and documented with a coastwise endorsement is qualified proprietary cargo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6949fbc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any cargo other than qualified proprietary cargo carried by all vessels owned by the person and its United States affiliates and documented with a coastwise endorsement consists of oil, petroleum products, petrochemicals, or liquified natural gas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6949fbd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no vessel owned by the person or any of its United States affiliates and documented with a coastwise endorsement carries molten sulphur; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6949fbe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person owned one or more vessels documented under this section as of ","children":[{"tag":"date","attrib":{"date":"2004-08-09"},"text":"August 9, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949fbf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application only to certain vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may make a certification under this paragraph only with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6949fc0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tank vessel having a tonnage of at least 6,000 gross tons, as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":" (or an alternative tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6949fc1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a towing vessel associated with a non-self-propelled tank vessel that meets the requirements of clause (i), where both vessels function as a single self-propelled vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949fc2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing of Demise Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The demise charter and any amendments to the charter shall be filed with the certification required by subsection (b)(3) or within 10 days after filing an amendment to the charter. The charter and amendments shall be made available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949fc3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation of Endorsement After Termination of Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When a charter required by subsection (b)(3) is terminated for default by the charterer, the Secretary may continue the coastwise endorsement for not more than 6 months on terms and conditions the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949fc4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12119/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deemed Owned by Citizens","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel satisfying the requirements of this section is deemed to be owned only by citizens of the United States under sections 12103 and 50501 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6949fc5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1501"},"text":"120 Stat. 1501","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3541/b/15"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3541(b)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2324"},"text":"132 Stat. 2324","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/k/1/F"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(k)(1)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1759"},"text":"139 Stat. 1759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6949fc6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6949fc