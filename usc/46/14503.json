{"tag":"section","attrib":{"id":"idf69e3b76-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14503"},"text":null,"children":[{"tag":"num","attrib":{"value":"14503"},"text":"§ 14503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificate of measurement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf69e3b77-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe the certificate to be issued as evidence of a vessel’s measurement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69e3b78-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The certificate shall be maintained as required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf69e3b79-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5101/3"},"text":"Pub. L. 99–509, title V, § 5101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1923"},"text":"100 Stat. 1923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIII/s303/e/2"},"text":"Pub. L. 111–281, title III, § 303(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2925"},"text":"124 Stat. 2925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69e3b7a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69e3b7b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 14503","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Source: Section (U.S. Code) 46 App. U.S.C. 72.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 14503 requires the Secretary to issue a certificate, in a manner that is to be prescribed by the Secretary, as evidence of a vessel’s regulatory measurement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf69e3b7c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf69e3b7d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
