{"tag":"section","attrib":{"id":"idf675a542-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5103"},"text":null,"children":[{"tag":"num","attrib":{"value":"5103"},"text":"§ 5103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Load line requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf675a543-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vessel may be operated only if the vessel has been assigned load lines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf675a544-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner, charterer, managing operator, agent, master, and individual in charge of a vessel shall mark and maintain the load lines permanently and conspicuously in the way prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf675a545-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A fishing vessel built on or before ","children":[{"tag":"date","attrib":{"date":"2013-07-01"},"text":"July 1, 2013","children":[],"tail":", that undergoes a major conversion completed after the later of "},{"tag":"date","attrib":{"date":"2013-07-01"},"text":"July 1, 2013","children":[],"tail":", or the date the Secretary establishes standards for an alternate loadline compliance program, shall comply with such an alternative loadline compliance program that is developed in cooperation with the commercial fishing industry and prescribed by the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf675a546-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5101/2"},"text":"Pub. L. 99–509, title V, § 5101(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1915"},"text":"100 Stat. 1915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVI/s604/d/2"},"text":"Pub. L. 111–281, title VI, § 604(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2965"},"text":"124 Stat. 2965","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tIII/s305/d/2"},"text":"Pub. L. 112–213, title III, § 305(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1565"},"text":"126 Stat. 1565","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf675a547-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf675a548-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 5103","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Source: Section (U.S. Code) 46 App. U.S.C. 86c, 88b.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5103(a) prohibits a vessel that is subject to load line requirements from operating, unless it has load lines assigned by the Secretary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5103(b) requires that load lines be permanently and conspicuously maintained in the manner prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf675a549-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf675a54a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2013-07-01"},"text":"July 1, 2013","children":[],"tail":",” for “"},{"tag":"date","attrib":{"date":"2012-07-01"},"text":"July 1, 2012","children":[],"tail":",” in two places and substituted “major conversion” for “substantial change to the dimension of or type of the vessel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
