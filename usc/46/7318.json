{"tag":"section","attrib":{"id":"idf67cd0bf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7318"},"text":null,"children":[{"tag":"num","attrib":{"value":"7318"},"text":"§ 7318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Radiotelegraph operators on Great Lakes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf67cd0c0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A radiotelegraph operator on the Great Lakes only shall have a first-class or second-class radiotelegraph operator’s license issued by the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd0c1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An endorsement as radiotelegraph operator on the Great Lakes only ends if the holder ceases to hold the license issued by the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67cd0c2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/545"},"text":"97 Stat. 545","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67cd0c3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf67cd0c4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf67cd0c5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7318","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:229c","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:229g","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:643(a)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7318 specifies that radiotelegraph operators on the Great Lakes shall have a first-class or second-class radiotelegraph operator’s license issued by the FCC and need not be licensed as a radio operator by the Coast Guard. However, an endorsement as radio telegraph operator has to be noted on his merchant mariners’ document. If the holder ceases to have a valid FCC license, then the endorsement is terminated automatically without recourse to suspension and revocation proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
