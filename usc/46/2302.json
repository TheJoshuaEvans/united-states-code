{"tag":"section","attrib":{"id":"idf6591c53-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302"},"text":null,"children":[{"tag":"num","attrib":{"value":"2302"},"text":"§ 2302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for negligent operations and interfering with safe operation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6591c54-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person operating a vessel in a negligent manner or interfering with the safe operation of a vessel, so as to endanger the life, limb, or property of a person is liable to the United States Government for a civil penalty of not more than $5,000 in the case of a recreational vessel, or $25,000 in the case of any other vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6591c55-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grossly Negligent Operation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6591c56-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Misdemeanor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person operating a vessel in a grossly negligent manner that endangers the life, limb, or property of a person commits a class A misdemeanor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6591c57-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Felony","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person operating a vessel in a grossly negligent manner that results in serious bodily injury, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1365/h/3"},"text":"section 1365(h)(3) of title 18","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6591c58-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commits a class E felony; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6591c59-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be assessed a civil penalty of not more than $35,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6591c5a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual who is under the influence of alcohol, or a dangerous drug in violation of a law of the United States when operating a vessel, as determined under standards prescribed by the Secretary by regulation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6591c5b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is liable to the United States Government for a civil penalty of not more than $5,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6591c5c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commits a class A misdemeanor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6591c5d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For a penalty imposed under this section, the vessel also is liable in rem unless the vessel is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6591c5e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by a State or a political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6591c5f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated principally for governmental purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6591c60-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified clearly as a vessel of that State or subdivision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6591c61-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6591c62-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A vessel may not transport Government-impelled cargoes if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6591c63-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel has been detained and determined to be substandard by the Secretary for violation of an international safety convention to which the United States is a party, and the Secretary has published notice of that detention and determination in an electronic form, including the name of the owner of the vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6591c64-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operator of the vessel has on more than one occasion had a vessel detained and determined to be substandard by the Secretary for violation of an international safety convention to which the United States is a party, and the Secretary has published notice of that detention and determination in an electronic form, including the name of the owner of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6591c65-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The prohibition in paragraph (1) expires for a vessel on the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6591c66-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 year after the date of the publication in electronic form on which the prohibition is based; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6591c67-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any date on which the owner or operator of the vessel prevails in an appeal of the violation of the relevant international convention on which the detention is based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6591c68-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2302/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in this subsection, the term “Government-impelled cargo” means cargo for which a Federal agency contracts directly for shipping by water or for which (or the freight of which) a Federal agency provides financing, including financing by grant, loan, or loan guarantee, resulting in shipment of the cargo by water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6591c69-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/508"},"text":"97 Stat. 508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s7/a"},"text":"Pub. L. 98–557, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2862"},"text":"98 Stat. 2862","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV"},"text":"Pub. L. 101–380, title IV","children":[],"tail":", §§ 4105(b)(2), 4302(a), "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/513"},"text":"104 Stat. 513","children":[],"tail":", 537; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tV/s5102"},"text":"Pub. L. 102–587, title V, § 5102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5071"},"text":"106 Stat. 5071","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIII"},"text":"Pub. L. 105–383, title III","children":[],"tail":", §§ 302(a), 304(c), title IV, § 408(a), "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3417"},"text":"112 Stat. 3417","children":[],"tail":", 3419, 3430; "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tIII/s325"},"text":"Pub. L. 107–295, title III, § 325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2105"},"text":"116 Stat. 2105","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7311"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1759"},"text":"139 Stat. 1759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6591c6a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6591c6b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6591c6c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2302(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:1461(d)","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:1484(b)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2302(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:1461(d)","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:1483","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2302(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:1484(b)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2302 states that the negligent operation of a vessel is prohibited. These acts are subject to civil and criminal penalties and the involved vessel is subject to an in rem action. The negligent operation provisions have their genesis in the Act of ","children":[{"tag":"date","attrib":{"date":"1940-04-25"},"text":"April 25, 1940","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/167"},"text":"54 Stat. 167","children":[],"tail":", when Congress prescribed that no person shall operate any motorboat or "},{"tag":"i","attrib":{},"text":"any vessel","children":[],"tail":" in a reckless or negligent manner. This provision was directed at all vessels and not those solely engaged in recreational boating. When the Federal Boat Safety Act of 1971, "},{"tag":"ref","attrib":{"href":"/us/pl/92/75"},"text":"P.L. 92–75","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/217"},"text":"85 Stat. 217","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t46/s1461"},"text":"46 U.S.C. 1461","children":[],"tail":") was enacted it adopted the reckless or negligent operation provisions of the 1940 Act. It adopted for the first time a provision for assessing civil penalties in addition to criminal penalties. It dropped the word “reckless” because of redundancy. It also combined the two classes of vessels; “any motorboat or any vessel” into one class by using the word “vessel” and defined vessel as including every description of watercraft."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6591c6d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6591c6e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “A person operating a vessel in a grossly negligent manner that endangers the life, limb, or property of a person commits a class A misdemeanor.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295"},"text":"Pub. L. 107–295","children":[],"tail":" substituted “$5,000 in the case of a recreational vessel, or $25,000 in the case of any other vessel” for “$1,000”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/s302/a/1"},"text":"Pub. L. 105–383, § 302(a)(1)","children":[],"tail":", substituted “Penalties for negligent operations and interfering with safe operation” for “Penalties for negligent operations” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/s302/a/2"},"text":"Pub. L. 105–383, § 302(a)(2)","children":[],"tail":", substituted “or interfering with the safe operation of a vessel, so as to endanger” for “that endangers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/s304/c"},"text":"Pub. L. 105–383, § 304(c)","children":[],"tail":", substituted “$5,000; or” for “$1,000 for a first violation and not more than $5,000 for a subsequent violation; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/s408/a"},"text":"Pub. L. 105–383, § 408(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" substituted “$1,000 for a first violation and not more than $5,000 for a subsequent violation” for “$1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/s4302/a/1"},"text":"Pub. L. 101–380, § 4302(a)(1)","children":[],"tail":", substituted “commits a class A misdemeanor” for “shall be fined not more than $5,000, imprisoned for not more than one year, or both”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":", §§ 4105(b)(2), 4302(a)(2)(A), substituted “under the influence of alcohol, or a dangerous drug in violation of a law of the United States” for “intoxicated” and struck out “, shall be” after “by the Secretary by regulation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/s4302/a/2/B"},"text":"Pub. L. 101–380, § 4302(a)(2)(B)","children":[],"tail":", substituted “is liable” for “liable”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380/s4302/a/2/C"},"text":"Pub. L. 101–380, § 4302(a)(2)(C)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “fined not more than $5,000, imprisoned for not more than one year, or both.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6591c6f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6591c70-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIV/s408/b"},"text":"Pub. L. 105–383, title IV, § 408(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3431"},"text":"112 Stat. 3431","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/383/tIV/s408/b"},"text":"“The amendment made by subsection (a) [amending this section] takes effect ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6591c71-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" applicable to incidents occurring after "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/s1020"},"text":"section 1020 of Pub. L. 101–380","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
