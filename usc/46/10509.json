{"tag":"section","attrib":{"id":"idf68d9a3b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10509"},"text":null,"children":[{"tag":"num","attrib":{"value":"10509"},"text":"§ 10509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for failing to begin voyage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68d9a3c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A seaman who fails to be on board at the time contained in the agreement required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s10502"},"text":"section 10502 of this title","children":[],"tail":", without having given 24 hours’ notice of inability to do so, shall forfeit, for each hour’s lateness, one-half of one day’s pay to be deducted from the seaman’s wages if the lateness is recorded in the official logbook on the date of the violation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9a3d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A seaman who does not report at all or subsequently deserts forfeits all wages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9a3e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10509/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to a fishing or whaling vessel or a yacht.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68d9a3f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/572"},"text":"97 Stat. 572","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68d9a40-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68d9a41-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68d9a42-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10509","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:576","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section provides for a reduction in the wages of seamen who arrive late for voyages, if their late arrival is noted in the official logbook. It does not apply to fishing vessels, whaling vessels or yachts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
