{"tag":"section","attrib":{"id":"idf6b3bfa3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42304"},"text":null,"children":[{"tag":"num","attrib":{"value":"42304"},"text":"§ 42304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action against foreign carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b3bfa4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s42306"},"text":"section 42306 of this title","children":[],"tail":", whenever the Federal Maritime Commission, after notice and opportunity for comment or hearing, determines that the conditions specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s42302/a"},"text":"section 42302(a) of this title","children":[],"tail":" exist, the Commission shall take such action to offset those conditions as it considers necessary and appropriate against any foreign carrier that is a contributing cause, or whose government is a contributing cause, to those conditions. The action may include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bfa5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limitations on voyages to and from United States ports or on the amount or type of cargo carried;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfa6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension, in whole or in part, of any or all tariffs and service contracts, including an ocean common carrier’s right to use any or all tariffs and service contracts of conferences in United States trades of which it is a member for any period the Commission specifies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfa7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension, in whole or in part, of an ocean common carrier’s right to operate under any agreement filed with the Commission, including any agreement authorizing preferential treatment at terminals, preferential terminal leases, space chartering, or pooling of cargo or revenue with other ocean common carriers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfa8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42304/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fee not to exceed $1,000,000 per voyage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bfa9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may consult with, seek the cooperation of, or make recommendations to other appropriate agencies of the United States Government prior to taking any action under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b3bfaa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1553"},"text":"120 Stat. 1553","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b3bfab-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b3bfac-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b3bfad-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":nul