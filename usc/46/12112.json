{"tag":"section","attrib":{"id":"idf69255fa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12112"},"text":null,"children":[{"tag":"num","attrib":{"value":"12112"},"text":"§ 12112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coastwise endorsement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf69255fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A coastwise endorsement may be issued for a vessel that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf69255fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12103"},"text":"section 12103 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69255fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf69255fe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12112/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was built in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69255ff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12112/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if not built in the United States—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6925600-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12112/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was captured in war by citizens of the United States and lawfully condemned as prize;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6925601-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12112/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was adjudged to be forfeited for a breach of the laws of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6925602-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12112/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifies as a wrecked vessel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12107"},"text":"section 12107 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6925603-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12112/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise qualifies under the laws of the United States to engage in the coastwise trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6925604-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Activity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the laws of the United States regulating the coastwise trade, a vessel for which a coastwise endorsement is issued may engage in the coastwise trade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6925605-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1495"},"text":"120 Stat. 1495","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6925606-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6925607-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6925608-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12112(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:12106(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12112(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:12106(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “only” is omitted because section 12102(a), as revised by the bill, contains a general requirement for appropriate documentation to engage in any trade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6925609-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf692560a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12112, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/588"},"text":"97 Stat. 588","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s104/a/4"},"text":"Pub. L. 100–710, title I, § 104(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4750"},"text":"102 Stat. 4750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/225/tIII/s301/a/11"},"text":"Pub. L. 101–225, title III, § 301(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1922"},"text":"103 Stat. 1922","children":[],"tail":", originally derived from section 65p of former Title 46, Shipping, related to vessels procured outside the United States, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12115"},"text":"section 12115 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf692560b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf692560c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Certain Vessels Engaged in Alaska Coastwise Trade","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/tVI/s608/b"},"text":"Pub. L. 108–293, title VI, § 608(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1056"},"text":"118 Stat. 1056","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/293/tVI/s608/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, a person shall be treated as a citizen of the United States under section 12102(a) [now section 12103(a), (b)] of title 46, United States Code, section 2 of the Shipping Act, 1916 ([former] 46 U.S.C. App. 802) [see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"46 U.S.C. 50501","children":[],"tail":"], and section 27 of the Merchant Marine Act, 1920 ([former] 46 U.S.C. App. 883) [see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"], for purposes of issuance of a coastwise endorsement under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12106/e"},"text":"section 12106(e) of title 46","children":[],"tail":", United States Code (as that section was in effect on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":"]), for a vessel owned by the person on the date of enactment of this Act, or any replacement vessel of a similar size and function, if the person—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned a vessel before ","children":[{"tag":"date","attrib":{"date":"2001-01-01"},"text":"January 1, 2001","children":[],"tail":", that had a coastwise endorsement under [former] "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12106/e"},"text":"section 12106(e) of title 46","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":"], derives substantially all of its revenue from leasing vessels engaged in the transportation or distribution of petroleum products and other cargo in Alaska."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on coastwise trade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel owned by a person described in paragraph (1) for which a coastwise endorsement is issued under [former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12106/e"},"text":"section 12106(e) of title 46","children":[],"tail":", United States Code, may be employed in the coastwise trade only within Alaska and in the coastwise trade to and from Alaska."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The application of this subsection to a person described in paragraph (1) shall terminate if all of that person’s vessels described in paragraph (1) are sold to a person eligible to document vessels under section 12106(a) [now section 12112(a)] of title 46, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
