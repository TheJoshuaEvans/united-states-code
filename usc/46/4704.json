{"tag":"section","attrib":{"id":"idf6735b9f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704"},"text":null,"children":[{"tag":"num","attrib":{"value":"4704"},"text":"§ 4704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of abandoned barges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6735ba0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735ba1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may remove a barge that is abandoned after complying with the following procedures:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6735ba2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the identity of the owner or operator can be determined, the Secretary shall notify the owner or operator by certified mail—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6735ba3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that if the barge is not removed it will be removed at the owner’s or operator’s expense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6735ba4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the penalty under section 4703.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735ba5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the identity of the owner or operator cannot be determined, the Secretary shall publish an announcement in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6735ba6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notice to mariners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6735ba7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an official journal of the county in which the barge is located","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that if the barge is not removed it will be removed at the owner’s or operator’s expense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735ba8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States, and any officer or employee of the United States is not liable to an owner or operator for damages resulting from removal of an abandoned barge under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735ba9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner or operator of an abandoned barge is liable, and an abandoned barge is liable in rem, for all expenses that the United States incurs in removing an abandoned barge under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735baa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735bab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, after providing notice under subsection (a)(1), solicit by public advertisement sealed bids for the removal of an abandoned barge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735bac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After solicitation under paragraph (1) the Secretary may award a contract. The contract—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6735bad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be subject to the condition that the barge and all property on the barge is the property of the barge removal contractor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735bae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must require the barge removal contractor to submit to the Secretary a plan for the removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735baf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4704/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Removal of an abandoned barge may begin thirty days after the Secretary completes the procedures under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6735bb0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/tV/s5302"},"text":"Pub. L. 102–587, title V, § 5302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5082"},"text":"106 Stat. 5082","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7347/c/3"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7347(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1781"},"text":"139 Stat. 1781","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6735bb1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6735bb2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6735bb3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsecs. (a)(2), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “subchapter” for “chapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
