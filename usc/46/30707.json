{"tag":"section","attrib":{"id":"idf6a567fa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30707"},"text":null,"children":[{"tag":"num","attrib":{"value":"30707"},"text":"§ 30707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a567fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier that violates this chapter shall be fined under title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a567fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lien","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of the fine and costs for the violation constitute a lien on the vessel engaged in the carriage. A civil action in rem to enforce the lien may be brought in the district court of the United States for any district in which the vessel is found.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a567fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposition of Fine","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Half of the fine shall go to the person injured by the violation and half to the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a567fe-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1517"},"text":"120 Stat. 1517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a567ff-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a56800-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a56801-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30707","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:194.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1893-02-13/ch105/s5"},"text":"Feb. 13, 1893, ch. 105, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/27/446"},"text":"27 Stat. 446","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “and who refuses to issue on demand the bill of lading herein provided for” are omitted as unnecessary. The words “shall be fined under title 18” are substituted for “shall be liable to a fine not exceeding $2,000” because of chapter 227 of title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “A civil action in rem to enforce the lien may be brought in the district court of the United States for any district in which the vessel is found” are substituted for “such vessel may be libeled therefor in any district court of the United States” for clarity and to modernize the language.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
