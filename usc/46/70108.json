{"tag":"section","attrib":{"id":"idf704c68b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108"},"text":null,"children":[{"tag":"num","attrib":{"value":"70108"},"text":"§ 70108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign port assessment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf704c68c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall assess the effectiveness of the antiterrorism measures maintained at—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf704c68d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a foreign port—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf704c68e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served by vessels documented under chapter 121 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c68f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from which foreign vessels depart on a voyage to the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c690-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other foreign port the Secretary believes poses a security risk to international maritime commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c691-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting an assessment under subsection (a), the Secretary shall assess the effectiveness of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf704c692-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" screening of containerized and other cargo and baggage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c693-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security measures to restrict access to cargo, vessels, and dockside property to authorized personnel only;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c694-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional security on board vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c695-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" licensing or certification of compliance with appropriate security standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c696-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the security management program of the foreign port; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c697-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate measures to deter terrorism against the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c698-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall consult with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf704c699-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of Defense and the Secretary of State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf704c69a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the terrorist threat that exists in each country involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c69b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify foreign ports that pose a high risk of introducing terrorism to international maritime commerce;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c69c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate authorities of foreign governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c69d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operators of vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c69e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Periodic Reassessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, acting through the Commandant of the Coast Guard, shall reassess the effectiveness of antiterrorism measures maintained at ports as described under subsection (a) and of procedures described in subsection (b) not less than once every 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c69f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Statutory Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The absence of an inspection of a foreign port shall not bar the Secretary from making a finding that a port in a foreign country does not maintain effective antiterrorism measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c6a0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recognition of Assessment Conducted by Other Entities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf704c6a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification and treatment of assessments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section and section 70109, the Secretary may treat an assessment that a foreign government (including, for the purposes of this subsection, an entity of or operating under the auspices of the European Union) or international organization has conducted as an assessment that the Secretary has conducted for the purposes of subsection (a), if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf704c6a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary certifies that the foreign government or international organization—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf704c6a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has conducted the assessment in accordance with subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf704c6a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has provided the Secretary with sufficient information pertaining to its assessment (including information regarding the outcome of the assessment); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6a5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foreign government that conducted the assessment is not a state sponsor of terrorism (as defined in section 3316(h)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c6a6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization to enter into an agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section and section 70109, the Secretary, in consultation with the Secretary of State, may enter into an agreement with a foreign government (including, for the purposes of this subsection, an entity of or operating under the auspices of the European Union) or international organization, under which parties to the agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf704c6a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an assessment, required under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share information pertaining to such assessment (including, but not limited to, information on the outcome of the assessment); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c6aa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section may be construed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf704c6ab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require the Secretary to treat an assessment conducted by a foreign government or an international organization as an assessment that satisfies the requirement under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6ac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the discretion or ability of the Secretary to conduct an assessment under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6ad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the authority of the Secretary to repatriate aliens to their respective countries of origin; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6ae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent the Secretary from requesting security and safety measures that the Secretary considers necessary to safeguard Coast Guard personnel during the repatriation of aliens to their respective countries of origin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c6af-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days before entering into an agreement or arrangement with a foreign government under paragraph (2), the Secretary shall notify the Committee on Homeland Security and the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate of the proposed terms of such agreement or arrangement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c6b0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Sponsors of Terrorism and International Terrorist Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf704c6b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may not enter into an agreement under subsection (f)(2) with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf704c6b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a foreign government that is a state sponsor of terrorism (as defined in section 3316(h)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity designated by the Secretary of State as a foreign terrorist organization pursuant to section 219 of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1189"},"text":"8 U.S.C. 1189","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c6b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf704c6b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deem any port that is under the jurisdiction of a foreign government that is a state sponsor of terrorism as not having effective antiterrorism measures for purposes of this section and section 70109; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6b6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70108/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately apply the sanctions described in section 70110(a) to such port.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf704c6b7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s102/a"},"text":"Pub. L. 107–295, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2079"},"text":"116 Stat. 2079","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/347/tII/s234"},"text":"Pub. L. 109–347, title II, § 234","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1918"},"text":"120 Stat. 1918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVIII/s806/a/1"},"text":"Pub. L. 111–281, title VIII, § 806(a)(1)","children":[],"tail":", (c)(2)(B), "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2992"},"text":"124 Stat. 2992","children":[],"tail":", 2993; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s317"},"text":"Pub. L. 114–120, title III, § 317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/62"},"text":"130 Stat. 62","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLVI/s5603"},"text":"Pub. L. 118–31, div. E, title LVI, § 5603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/959"},"text":"137 Stat. 959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf704c6b8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf704c6b9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf704c6ba-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s5603/1/A"},"text":"Pub. L. 118–31, § 5603(1)(A)","children":[],"tail":", substituted “if—” and subpars. (A) and (B) for “provided that the Secretary certifies that the foreign government or international organization has—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) conducted the assessment in accordance with subsection (b); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) provided the Secretary with sufficient information pertaining to its assessment (including, but not limited to, information on the outcome of the assessment).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s5603/1/B"},"text":"Pub. L. 118–31, § 5603(1)(B)","children":[],"tail":", amended par. (3) generally. Prior to amendment, text read as follows: “Nothing in this subsection shall be construed to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) require the Secretary to recognize an assessment that a foreign government or an international organization has conducted; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) limit the discretion or ability of the Secretary to conduct an assessment under this section.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s5603/2"},"text":"Pub. L. 118–31, § 5603(2)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s806/c/2/B"},"text":"Pub. L. 111–281, § 806(c)(2)(B)","children":[],"tail":", redesignated pars. (3) and (4) as (2) and (3), respectively, and struck out former par. (2) which read as follows: “the Secretary of the Treasury;”."}],"tail":"\n"},