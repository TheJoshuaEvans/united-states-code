{"tag":"section","attrib":{"id":"idf6c91d21-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s52101"},"text":null,"children":[{"tag":"num","attrib":{"value":"52101"},"text":"§ 52101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reemployment rights for certain merchant seamen","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c91d22-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s52101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who is certified by the Secretary of Transportation under subsection (c) shall be entitled to reemployment rights and other benefits substantially equivalent to the rights and benefits provided for by chapter 43 of title 38 for any member of a reserve component of the armed forces of the United States who is ordered to active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c91d23-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s52101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual may submit an application for certification under subsection (c) to the Secretary not later than 45 days after the date the individual completes a period of employment described in subsection (c)(1)(A) with respect to which the application is submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c91d24-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s52101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Determination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 20 days after the date the Secretary receives from an individual an application for certification under this subsection, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c91d25-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s52101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" determine whether the individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c91d26-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s52101/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was employed in the activation or operation of a vessel—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c91d27-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s52101/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the National Defense Reserve Fleet maintained under section 57100 in a period in which the vessel was in use or being activated for use under subsection (b) of that section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c91d28-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s52101/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requisitioned or purchased under chapter 563 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c91d29-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s52101/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned, chartered, or controlled by the United States Government and used by the Government for a war, armed conflict, national emergency, or maritime mobilization need (including for training purposes or testing for readiness and suitability for mission performance); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c91d2a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s52101/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the period of that employment, possessed a valid license, certificate of registry, or merchant mariner’s document issued under chapter 71 or 73 of this title; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91d2b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s52101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary makes affirmative determinations under subparagraphs (A) and (B) of paragraph (1), certify that individual under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c91d2c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s52101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Equivalence to Military Selective Service Act Certificate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of reemployment rights and benefits provided by this section, a certification under subsection (c) shall be considered to be the equivalent of a certificate described in section 9(a) of the Military Selective Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3808/a"},"text":"50 U.S.C. 3808(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c91d2d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1585"},"text":"120 Stat. 1585","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dC/tXXXV/s3502/b/4"},"text":"Pub. L. 115–91, div. C, title XXXV, § 3502(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1910"},"text":"131 Stat. 1910","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3546/m"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3546(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2327"},"text":"132 Stat. 2327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c91d2e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6c91d2f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6c91d30-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"52101","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1132.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title III, § 302, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/104/239/s10/a"},"text":"Pub. L. 104–239, § 10(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 8, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3133"},"text":"110 Stat. 3133","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1)(B), the words “(as applicable)” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “certificate described in section 9(a) of the Military Selective Service Act (50 App. U.S.C. 459(a))” are substituted for “certificate referred to in paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301/a"},"text":"section 4301(a) of title 38","children":[],"tail":"” because "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4301"},"text":"section 4301 of title 38","children":[],"tail":" was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/103/353/s2/a"},"text":"section 2(a) of Public Law 103–353","children":[],"tail":", and before the amendment section 4301(a)(1) referred to a certificate described in section 9(a) of the Military Selective Service Act (50 App. U.S.C. 459(a))."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6c91d31-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6c91d32-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3808/a"},"text":"50 U.S.C. 3808(a)","children":[],"tail":")” for “(50 App. U.S.C. 459(a))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (c)(1)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “section 57100” for “section 11 of the Merchant Ship Sales Act of 1946 (50 App. U.S.C. 1744)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
