{"tag":"section","attrib":{"id":"idf6ac93e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40302"},"text":null,"children":[{"tag":"num","attrib":{"value":"40302"},"text":"§ 40302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ac93e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A true copy of every agreement referred to in section 40301(a) or (b) of this title shall be filed with the Federal Maritime Commission. If the agreement is oral, a complete memorandum specifying in detail the substance of the agreement shall be filed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ac93e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ac93e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement related to transportation to be performed within or between foreign countries; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement among common carriers to establish, operate, or maintain a marine terminal in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ac93ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may by regulation prescribe the form and manner in which an agreement shall be filed and any additional information and documents necessary to evaluate the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ac93eb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1528"},"text":"120 Stat. 1528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ac93ec-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ac93ed-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ac93ee-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib