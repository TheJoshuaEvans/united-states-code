{"tag":"section","attrib":{"id":"idf704c6c2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110"},"text":null,"children":[{"tag":"num","attrib":{"value":"70110"},"text":"§ 70110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actions and assistance for foreign ports or facilities and United States territories","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf704c6c3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless the Secretary finds that a foreign port or facility maintains effective antiterrorism measures, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf704c6c4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may prescribe conditions of entry into the United States for any vessel arriving from that port or facility, or any vessel carrying cargo or passengers originating from or transshipped through that port or facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c6c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may deny entry into the United States to any vessel that does not meet such conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c6c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide public notice for passengers of the ineffective antiterrorism measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c6c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date for Sanctions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any action taken by the Secretary under subsection (a) for a particular port or facility shall take effect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf704c6c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 days after the government of the foreign country with jurisdiction over or control of that port or facility is notified under section 70109 unless the Secretary finds that the government has brought the antiterrorism measures at the port or facility up to the security level the Secretary used in making an assessment under section 70108 before the end of that 90-day period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c6c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately upon the finding of the Secretary under subsection (a) if the Secretary finds, after consulting with the Secretary of State, that a condition exists that threatens the safety or security of passengers, vessels, or crew traveling to or from the port or facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c6ca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Department To Be Notified","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary immediately shall notify the Secretary of State of a finding that a port or facility does not maintain effective antiterrorism measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c6cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action Canceled","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An action required under this section is no longer required if the Secretary decides that effective antiterrorism measures are maintained at the port or facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c6cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance for Foreign Ports, Facilities, and United States Territories.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf704c6cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in consultation with the Secretary of Transportation, the Secretary of State, and the Secretary of Energy, shall identify assistance programs that could facilitate implementation of port or facility security antiterrorism measures in foreign countries and territories of the United States. The Secretary shall establish a strategic plan to utilize those assistance programs to assist ports and facilities that are found by the Secretary under subsection (a) not to maintain effective antiterrorism measures in the implementation of port or facility security antiterrorism measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c6ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Caribbean basin","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with the Secretary of State and in consultation with the Organization of American States and the Commandant of the Coast Guard, shall place particular emphasis on utilizing programs to facilitate the implementation of port or facility security antiterrorism measures at the ports located in the Caribbean Basin, as such ports pose unique security and safety threats to the United States due to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf704c6cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategic location of such ports between South America and the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6d0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative openness of such ports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significant number of shipments of narcotics to the United States that are moved through such ports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c6d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coast Guard Assistance Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf704c6d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may lend, lease, donate, or otherwise provide equipment, and provide technical training and support, to the owner or operator of a foreign port or facility—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf704c6d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in bringing the port or facility into compliance with applicable International Ship and Port Facility Code standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the port or facility in correcting deficiencies identified in periodic port assessments and reassessments required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70108"},"text":"section 70108 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c6d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf704c6d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide such assistance based upon an assessment of the risks to the security of the United States and the inability of the owner or operator of the port or facility to bring the port or facility into compliance with those standards and to maintain compliance with, or exceed, such standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not provide such assistance unless the port or facility has been subjected to a comprehensive port security assessment by the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70110/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may only lend, lease, or otherwise provide equipment that the Secretary has first determined is not required by the Coast Guard for the performance of its missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf704c6da-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s102/a"},"text":"Pub. L. 107–295, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2080"},"text":"116 Stat. 2080","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/347/tII/s233/b"},"text":"Pub. L. 109–347, title II, § 233(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1917"},"text":"120 Stat. 1917","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVIII/s806/a/3"},"text":"Pub. L. 111–281, title VIII, § 806(a)(3)","children":[],"tail":"–(c)(2)(A), "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2992"},"text":"124 Stat. 2992","children":[],"tail":", 2993; "},{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1/12"},"text":"Pub. L. 111–330, § 1(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3570"},"text":"124 Stat. 3570","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf704c6db-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf704c6dc-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf704c6dd-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s806/c/2/A/i"},"text":"Pub. L. 111–281, § 806(c)(2)(A)(i)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/330"},"text":"Pub. L. 111–330","children":[],"tail":", inserted “or facilities” after “ports” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s806/c/2/A/ii"},"text":"Pub. L. 111–281, § 806(c)(2)(A)(ii)","children":[],"tail":", inserted “or facility” after “port” wherever appearing except in subsec. (f), which was added by "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/s806/b"},"text":"Pub. L. 111–281, § 806(b)","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s806/a/3"},"text":"Pub. L. 111–281, § 806(a)(3)","children":[],"tail":", substituted “Unless the Secretary finds that a foreign port maintains effective antiterrorism measures,” for “If the Secretary finds that a foreign port does not maintain effective antiterrorism measures,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s806/c/2/A/iii"},"text":"Pub. L. 111–281, § 806(c)(2)(A)(iii)","children":[],"tail":", substituted “Ports, Facilities,” for “Ports” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s806/c/1"},"text":"Pub. L. 111–281, § 806(c)(1)","children":[],"tail":", substituted “The Secretary shall establish a strategic plan to utilize those assistance programs to assist ports and facilities that are found by the Secretary under subsection (a) not to maintain effective antiterrorism measures in the implementation of port security antiterrorism measures.” for “The Secretary shall establish a program to utilize the programs that are capable of implementing port security antiterrorism measures at ports in foreign countries and territories of the United States that the Secretary finds to lack effective antiterrorism measures.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s806/b"},"text":"Pub. L. 111–281, § 806(b)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/s233/b/1"},"text":"Pub. L. 109–347, § 233(b)(1)","children":[],"tail":", substituted “Actions and assistance for foreign ports and United States territories” for “Actions when foreign ports not maintaining effective antiterrorism measures” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/s233/b/2"},"text":"Pub. L. 109–347, § 233(b)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf704c6de-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf704c6df-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/330/s1"},"text":"Pub. L. 111–330, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-22"},"text":"Dec. 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3569"},"text":"124 Stat. 3569","children":[],"tail":", provided that the amendment made by section 1(12) is effective with the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
