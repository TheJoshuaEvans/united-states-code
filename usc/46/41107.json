an action in rem to enforce the lien” are substituted for “may be libeled therefore” to modernize the language.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6b14e8a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6b14e8b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s8/a/1/A"},"text":"Pub. L. 117–146, § 8(a)(1)(A)","children":[],"tail":", inserted “or refunds” after “penalties” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s8/a/1/B"},"text":"Pub. L. 117–146, § 8(a)(1)(B)","children":[],"tail":", inserted “or, in addition to or in lieu of a civil penalty, is liable for the refund of a charge” after “civil penalty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s8/a/1/C"},"text":"Pub. L. 117–146, § 8(a)(1)(C)","children":[],"tail":", inserted “or, in addition to or in lieu of a civil penalty, the refund of a charge,” after “civil penalty”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
