{"tag":"section","attrib":{"id":"idf6b14e83-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41107"},"text":null,"children":[{"tag":"num","attrib":{"value":"41107"},"text":"§ 41107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monetary penalties or refunds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b14e84-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person that violates this part or a regulation or order of the Federal Maritime Commission issued under this part is liable to the United States Government for a civil penalty or, in addition to or in lieu of a civil penalty, is liable for the refund of a charge. Unless otherwise provided in this part, the amount of the penalty may not exceed $5,000 for each violation or, if the violation was willfully and knowingly committed, $25,000 for each violation. Each day of a continuing violation is a separate violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14e85-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lien on Carrier’s Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a civil penalty or, in addition to or in lieu of a civil penalty, the refund of a charge, imposed on a common carrier under this section constitutes a lien on the vessels operated by the carrier. Any such vessel is subject to an action in rem to enforce the lien in the district court of the United States for the district in which it is found.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b14e86-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1543"},"text":"120 Stat. 1543","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/146/s8/a/1"},"text":"Pub. L. 117–146, § 8(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1276"},"text":"136 Stat. 1276","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b14e87-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b14e88-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b14e89-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"tex