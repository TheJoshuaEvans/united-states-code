{"tag":"section","attrib":{"id":"idf7098060-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503"},"text":null,"children":[{"tag":"num","attrib":{"value":"70503"},"text":"§ 70503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7098061-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual may not knowingly or intentionally—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7098062-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacture or distribute, possess with intent to manufacture or distribute, or place or cause to be placed with intent to manufacture or distribute a controlled substance on board a covered vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7098063-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destroy (including jettisoning any item or scuttling, burning, or hastily cleaning a vessel), or attempt or conspire to destroy, property that is subject to forfeiture under section 511(a) of the Comprehensive Drug Abuse Prevention and Control Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s881/a"},"text":"21 U.S.C. 881(a)","children":[],"tail":") on board a covered vessel; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7098064-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conceal, or attempt or conspire to conceal, more than $100,000 in currency or other monetary instruments on the person of such individual while on board a covered vessel or in any conveyance, article of luggage, merchandise, or other container, or compartment of or aboard the covered vessel if that vessel is outfitted for smuggling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098065-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension Beyond Territorial Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) applies even though the act is committed outside the territorial jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098066-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7098067-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), subsection (a) does not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf7098068-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a common or contract carrier or an employee of the carrier who possesses or distributes a controlled substance in the lawful and usual course of the carrier’s business; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7098069-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public vessel of the United States or an individual on board the vessel who possesses or distributes a controlled substance in the lawful course of the individual’s duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf709806a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entered in manifest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) applies only if the controlled substance is part of the cargo entered in the vessel’s manifest and is intended to be imported lawfully into the country of destination for scientific, medical, or other lawful purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf709806b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Burden of Proof","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States Government is not required to negative a defense provided by subsection (c) in a complaint, information, indictment, or other pleading or in a trial or other proceeding. The burden of going forward with the evidence supporting the defense is on the person claiming its benefit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf709806c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Vessel Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section the term “covered vessel” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf709806d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel of the United States or a vessel subject to the jurisdiction of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf709806e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70503/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other vessel if the individual is a citizen of the United States or a resident alien of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf709806f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s10/2"},"text":"Pub. L. 109–304, § 10(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1687"},"text":"120 Stat. 1687","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s314/a"},"text":"Pub. L. 114–120, title III, § 314(a)","children":[],"tail":", (b), (e)(1), "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/59"},"text":"130 Stat. 59","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7324"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1770"},"text":"139 Stat. 1770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf7098070-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf7098071-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf7098072-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70503(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1903(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/96/350/s3/a"},"text":"Pub. L. 96–350, § 3(a)","children":[],"tail":", (e), (h), "},{"tag":"html:span","attrib":{},"text":"Sept. 15, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1160"},"text":"94 Stat. 1160","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/99/570/tIII/s3202"},"text":"Pub. L. 99–570, title III, § 3202","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3207-95"},"text":"100 Stat. 3207–95","children":[],"tail":", 3207–96, 3207–97; "},{"tag":"html:a","attrib":{"href":"/us/pl/99/640/s17"},"text":"Pub. L. 99–640, § 17","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3552"},"text":"100 Stat. 3552","children":[],"tail":", 3554; "},{"tag":"html:a","attrib":{"href":"/us/pl/100/690/tVII/s7402/a"},"text":"Pub. L. 100–690, title VII, § 7402(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/4483"},"text":"102 Stat. 4483","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70503(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1903(h).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70503(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1903(e) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70503(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1903(e) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before paragraph (1), the words “may not” are substituted for “It is unlawful for” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “applies to” are substituted for “is intended to reach” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf7098073-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf7098074-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7324/1"},"text":"Pub. L. 119–60, § 7324(1)","children":[],"tail":", substituted “An” for “While on board a covered vessel, an” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7324/2"},"text":"Pub. L. 119–60, § 7324(2)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “manufacture or distribute, or possess with intent to manufacture or distribute, a controlled substance;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7324/3"},"text":"Pub. L. 119–60, § 7324(3)","children":[],"tail":", inserted “on board a covered vessel” after “("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s881/a"},"text":"21 U.S.C. 881(a)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7324/4"},"text":"Pub. L. 119–60, § 7324(4)","children":[],"tail":", inserted “while on board a covered vessel” after “such individual”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s314/e/1"},"text":"Pub. L. 114–120, § 314(e)(1)","children":[],"tail":", substituted “Prohibited acts” for “Manufacture, distribution, or possession of controlled substances on vessels” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s314/a"},"text":"Pub. L. 114–120, § 314(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “An individual may not knowingly or intentionally manufacture or distribute, or possess with intent to manufacture or distribute, a controlled substance on board—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) a vessel of the United States or a vessel subject to the jurisdiction of the United States; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any vessel if the individual is a citizen of the United States or a resident alien of the United States.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s314/b"},"text":"Pub. L. 114–120, § 314(b)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
