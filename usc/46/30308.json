{"tag":"section","attrib":{"id":"idf6a2f62b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30308"},"text":null,"children":[{"tag":"num","attrib":{"value":"30308"},"text":"§ 30308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a2f62c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter does not affect the law of a State regulating the right to recover for death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a2f62d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Internal Waters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter does not apply to the Great Lakes or waters within the territorial limits of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a2f62e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1512"},"text":"120 Stat. 1512","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a2f62f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a2f630-2930-11f1-96a8-b9bd2a0a99b5"},"