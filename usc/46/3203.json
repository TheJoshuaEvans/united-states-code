{"tag":"section","attrib":{"id":"idf65b6627-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203"},"text":null,"children":[{"tag":"num","attrib":{"value":"3203"},"text":"§ 3203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety management system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf65b6628-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe regulations which establish a safety management system for responsible persons and vessels to which this chapter applies (including, for purposes of this section, all covered small passenger vessels, as defined in section 3306(n)(5)), including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf65b6629-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a safety and environmental protection policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b662a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instructions and procedures to ensure safe operation of those vessels and protection of the environment in compliance with international and United States law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b662b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defined levels of authority and lines of communications between, and among, personnel on shore and on the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b662c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for reporting accidents and nonconformities with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b662d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to sexual harassment and sexual assault, procedures for, and annual training requirements for all responsible persons and vessels to which this chapter applies on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf65b662e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf65b662f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bystander intervention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf65b6630-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf65b6631-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" response; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf65b6632-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b6633-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the list required under section 3106(a)(2) and the log book required under section 3106(a)(3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b6634-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for preparing for and responding to emergency situations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b6635-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for internal audits and management reviews of the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65b6636-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures and Training Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In prescribing regulations for the procedures and training requirements described in subsection (a)(5), such procedures and requirements shall be consistent with the requirements to report sexual harassment or sexual assault under section 10104.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65b6637-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Audits.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf65b6638-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certificates.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf65b6639-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During an audit of a safety management system of a vessel required under section 10104(e), the Secretary may suspend the Safety Management Certificate issued for the vessel under section 3205 and issue a separate Safety Management Certificate for the vessel to be in effect for a 3-month period beginning on the date of the issuance of such separate certificate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf65b663a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the conclusion of an audit of a safety management system required under section 10104(e), the Secretary shall revoke the Safety Management Certificate issued for the vessel under section 3205 if the Secretary determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf65b663b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the holder of the Safety Management Certificate knowingly, or repeatedly, failed to comply with section 10104; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf65b663c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other failure of the safety management system resulted in the failure to comply with such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b663d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documents of compliance.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf65b663e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Following an audit of the safety management system of a vessel required under section 10104(e), the Secretary may audit the safety management system of the responsible person for the vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf65b663f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During an audit under subparagraph (A), the Secretary may suspend the Document of Compliance issued to the responsible person under section 3205 and issue a separate Document of Compliance to such person to be in effect for a 3-month period beginning on the date of the issuance of such separate document.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf65b6640-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the conclusion of an assessment or an audit of a safety management system under subparagraph (A), the Secretary shall revoke the Document of Compliance issued to the responsible person if the Secretary determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf65b6641-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the holder of the Document of Compliance knowingly, or repeatedly, failed to comply with section 10104; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf65b6642-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that other failure of the safety management system resulted in the failure to comply with such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65b6643-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Code","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations prescribed under this section shall be consistent with the International Safety Management Code with respect to vessels to which this chapter applies under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s3202/a"},"text":"section 3202(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65b6644-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In prescribing regulations for passenger vessels and small passenger vessels, the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf65b6645-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the characteristics, methods of operation, and nature of the service of these vessels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65b6646-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3203/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to vessels that are ferries, the sizes of the ferry systems within which the vessels operate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf65b6647-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVI/s602/a"},"text":"Pub. L. 104–324, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3928"},"text":"110 Stat. 3928","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tIV/s405/b"},"text":"Pub. L. 108–293, title IV, § 405(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1043"},"text":"118 Stat. 1043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVI/s610/b"},"text":"Pub. L. 111–281, title VI, § 610(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2969"},"text":"124 Stat. 2969","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIV"},"text":"Pub. L. 116–283, div. G, title LVXXXIV","children":[],"tail":" [LXXXIV], § 8441(c), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4744"},"text":"134 Stat. 4744","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVI/s11610/a"},"text":"Pub. L. 117–263, div. K, title CXVI, § 11610(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4154"},"text":"136 Stat. 4154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf65b6648-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf65b6649-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf65b664a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(5) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11610/a/1"},"text":"Pub. L. 117–263, § 11610(a)(1)","children":[],"tail":", added pars. (5) and (6) and redesignated former pars. (5) and (6) as (7) and (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11610/a/2"},"text":"Pub. L. 117–263, § 11610(a)(2)","children":[],"tail":", (3), added subsecs. (b) and (c) and redesignated former subsecs. (b) and (c) as (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" inserted “(including, for purposes of this section, all covered small passenger vessels, as defined in section 3306(n)(5))” after “vessels to which this chapter applies” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" substituted “vessels to which this chapter applies under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s3202/a"},"text":"section 3202(a) of this title","children":[],"tail":"” for “vessels engaged on a foreign voyage”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf65b664b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf65b664c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Flag-State Guidance and Supplements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/265/tII/s213"},"text":"Pub. L. 115–265, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-11"},"text":"Oct. 11, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3750"},"text":"132 Stat. 3750","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/265/tII/s213"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Freight Vessels; Damage Control Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-10-11"},"text":"Oct. 11, 2018","children":[],"tail":"], the Secretary shall issue flag-State guidance for all freight vessels documented under chapter 121 of title 46, United States Code, built before "},{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":", regarding the inclusion of comprehensive damage control information in safety management plans required under chapter 32 of title 46, United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recognized Organizations; United States Supplement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commandant [of the Coast Guard] shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with recognized organizations to create a single United States Supplement to rules of such organizations for classification of vessels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by not later than 1 year after the date of the enactment of this Act, provide to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a briefing on whether it is necessary to revise part 8 of title 46, Code of Federal Regulations, to authorize only one United States Supplement to such rules.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “Secretary” and “recognized organizations” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/265/s213"},"text":"section 213 of Pub. L. 115–265","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/265/s203"},"text":"section 203 of Pub. L. 115–265","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"section 2101 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
