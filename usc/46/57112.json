{"tag":"section","attrib":{"id":"idf6f1b2d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57112"},"text":null,"children":[{"tag":"num","attrib":{"value":"57112"},"text":"§ 57112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for purchasing federally auctioned vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f1b2d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to purchase a covered vessel from the Federal Government, a person shall provide proof of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f1b2d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" liability insurance for the operator of such covered vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b2d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial resources sufficient to cover maintenance costs of such covered vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b2d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57112/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a covered vessel requiring documentation under chapter 121, an admiralty bond or stipulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b2d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Vessel Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered vessel” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f1b2da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a government owned vessel disposed of in accordance with this part and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s548"},"text":"section 548 of title 40","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b2db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel seized or forfeited pursuant to any law, and auctioned by the Federal Government, including a vessel seized or forfeited pursuant to section 7301 or 7302 of the Internal Revenue Code of 1986; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b2dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57112/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fishing vessel seized or forfeited pursuant to section 310 of the Magnuson-Stevens Fishery Conservation and Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1860"},"text":"16 U.S.C. 1860","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b2dd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXV/s3532/a"},"text":"Pub. L. 118–159, div. C, title XXXV, § 3532(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2312"},"text":"138 Stat. 2312","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b2de-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6f1b2df-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6f1b2e0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 7301 and 7302 of the Internal Revenue Code of 1986, referred to in subsec. (b)(2), are classified to sections 7301 and 7302, respectively, of Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
