{"tag":"section","attrib":{"id":"idf69bca7c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13106"},"text":null,"children":[{"tag":"num","attrib":{"value":"13106"},"text":"§ 13106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation decisions about State amounts expended","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf69bca7d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Consistent with regulations prescribed by the Secretary, the computation by a State of amounts expended for the State recreational boating safety program shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf69bca7e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition, maintenance, and operating costs of land, facilities, equipment, and supplies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69bca7f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel salaries and reimbursable expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69bca80-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of training personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69bca81-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13106/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public boat safety education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69bca82-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13106/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of carrying out the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69bca83-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13106/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other expenses that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69bca84-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall decide an issue arising out of the computation made under subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf69bca85-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/596"},"text":"97 Stat. 596","children":[],"tail":", § 13105; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1011/e"},"text":"Pub. L. 98–369, div. A, title X, § 1011(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1013"},"text":"98 Stat. 1013","children":[],"tail":"; 