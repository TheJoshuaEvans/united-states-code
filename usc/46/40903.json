{"tag":"section","attrib":{"id":"idf6aedde3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40903"},"text":null,"children":[{"tag":"num","attrib":{"value":"40903"},"text":"§ 40903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or revocation of license","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6aedde4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure To Maintain Qualifications or To Comply","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Maritime Commission, after notice and opportunity for a hearing, shall suspend or revoke an ocean transportation intermediary’s license if the Commission finds that the ocean transportation intermediary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aedde5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not qualified to provide intermediary services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedde6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully failed to comply with a provision of this part or with an order or regulation of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedde7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure To Maintain Bond, Proof of Insurance, or Other Surety","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may revoke an ocean transportation intermediary’s license for failure to maintain a bond, proof of insurance, or other surety as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s40902/a"},"text":"section 40902(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6aedde8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1539"},"text":"120 Stat. 1539","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6aedde9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6aeddea-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6aeddeb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html