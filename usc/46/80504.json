{"tag":"section","attrib":{"id":"idf70bf153-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80504"},"text":null,"children":[{"tag":"num","attrib":{"value":"80504"},"text":"§ 80504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval and examination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf70bf154-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Domicile and Principal Office in United States","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A container owner domiciled and having its principal office in the United States shall have the container—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf70bf155-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approved initially under procedures prescribed by the Secretary of the department in which the Coast Guard is operating or by the government of another country that is a party to the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70bf156-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examined periodically as provided in the Convention under procedures prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70bf157-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Domicile or Principal Office in United States","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A container owner domiciled or having its principal office in the United States shall have the container—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf70bf158-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approved initially under procedures prescribed by the Secretary or by the government of another country that is a party to the Convention; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70bf159-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examined periodically as provided in the Convention, under procedures prescribed by the government of the country in which the owner is domiciled or has its principal office, as long as that country is a party to the Convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70bf15a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Neither Domicile Nor Principal Office in United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A container owner neither domiciled nor having its principal office in the United States or another country that is a party to the Convention may submit a container for initial approval and periodic examination under procedures prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf70bf15b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s11"},"text":"Pub. L. 109–304, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1695"},"text":"120 Stat. 1695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf70bf15c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf70bf15d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf70bf15e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80504.","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1502(a) (related to approval and examination).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/208/s3/a"},"text":"Pub. L. 95–208, § 3(a)","children":[],"tail":" (related to approval and examination), "},{"tag":"html:span","attrib":{},"text":"Dec. 13, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1476"},"text":"91 Stat. 1476","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “Beginning on the date the instrument of ratification is deposited by the United States in accordance with the provisions of article VII of the Convention, for new containers, and beginning on ","children":[{"tag":"date","attrib":{"date":"1982-09-06"},"text":"September 6, 1982","children":[],"tail":", for existing containers” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a)(1) and (b)(1), the words “government of another country that is a party to the Convention” are substituted for “administration of another contracting party to the Convention” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “initial” is added for consistency in the section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
