{"tag":"section","attrib":{"id":"idf68fe4ab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11201"},"text":null,"children":[{"tag":"num","attrib":{"value":"11201"},"text":"§ 11201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for veterans’ burial and cemetery benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68fe4ac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68fe4ad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11201/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The qualified service of an individual referred to in paragraph (2) shall be considered to be active duty in the Armed Forces during a period of war for purposes of eligibility for benefits under the following provisions of title 38:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68fe4ae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11201/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 23 (relating to burial benefits).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe4af-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11201/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 24 (relating to interment in national cemeteries).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4b0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11201/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered individuals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) applies to an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68fe4b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11201/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives an honorable service certificate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s11203"},"text":"section 11203 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe4b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11201/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not eligible under any other provision of law for benefits under laws administered by the Secretary of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe4b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement for Benefits Provided","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall reimburse the Secretary of Veterans Affairs for the value of benefits that the Secretary of Veterans Affairs provides for an individual by reason of eligibility under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe4b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11201/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68fe4b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11201/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Benefits may be provided under the provisions of law referred to in subsection (a)(1) by reason of this chapter only for deaths occurring after the date of the enactment of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4b6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11201/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Burials, etc. in national cemeteries","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (1), in the case of an initial burial or columbarium placement after the date of the enactment of this chapter, benefits may be provided under chapter 24 of title 38 by reason of this chapter (regardless of the date of death), and in such a case benefits may be provided under section 2306 of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68fe4b7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tIV/s402/a"},"text":"Pub. L. 105–368, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3336"},"text":"112 Stat. 3336","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(b)(11), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4751"},"text":"134 Stat. 4751","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68fe4b8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68fe4b9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf68fe4ba-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this chapter, referred to in subsec. (c), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368"},"text":"Pub. L. 105–368","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68fe4bb-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “an individual” for “a person” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
