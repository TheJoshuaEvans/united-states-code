{"tag":"section","attrib":{"id":"idf6b14e9c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109"},"text":null,"children":[{"tag":"num","attrib":{"value":"41109"},"text":"§ 41109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b14e9d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until a matter is referred to the Attorney General, the Federal Maritime Commission may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b14e9e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after notice and opportunity for a hearing, in accordance with this part—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b14e9f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess a civil penalty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b14ea0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in addition to, or in lieu of, assessing a civil penalty under subparagraph (A), order a refund of money (including additional amounts in accordance with section 41305(c)), subject to subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b14ea1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compromise, modify, or remit, with or without conditions, a civil penalty or refund imposed under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14ea2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Amount.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b14ea3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors for consideration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of a civil penalty assessed or refund of money ordered pursuant to subsection (a), the Federal Maritime Commission shall take into consideration—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b14ea4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, circumstances, extent, and gravity of the violation committed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b14ea5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the violator—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6b14ea6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree of culpability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6b14ea7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any history of prior offenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6b14ea8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to pay; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6b14ea9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as justice may require; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b14eaa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of any refund of money ordered pursuant to subsection (a)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b14eab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commensurate reduction in civil penalty.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b14eac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any case in which the Federal Maritime Commission orders a refund of money pursuant to subsection (a)(1)(B) in addition to assessing a civil penalty pursuant to subsection (a)(1)(A), the amount of the civil penalty assessed shall be decreased by any additional amounts included in the refund of money in excess of the actual injury (as defined in section 41305(a)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b14ead-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of refunds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A refund of money ordered pursuant to subsection (a)(1)(B) shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6b14eae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considered to be compensation paid to the applicable claimant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6b14eaf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deducted from the total amount of damages awarded to that claimant in a civil action against the violator relating to the applicable violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14eb0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A civil penalty or refund of money under subparagraph (A) or (B), respectively, of subsection (a)(1) may not be imposed for conspiracy to violate subsection (a) or (d) of section 41102 or paragraph (1) or (2) of section 41104(a) or to defraud the Commission by concealing such a violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14eb1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Basis of Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission or a court may not order a person to pay the difference between the amount billed and agreed upon in writing with a common carrier or its agent and the amount set forth in a tariff or service contract by that common carrier for the transportation service provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14eb2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time Limit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A proceeding to assess a civil penalty or order a refund of money under this section must be commenced within 5 years after the date of the violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14eb3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Civil Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person against whom a civil penalty is assessed, or that is ordered to refund money, under this section may obtain review under chapter 158 of title 28.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14eb4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41109/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions To Collect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a person does not pay an assessment of a civil penalty or a refund required under this section after it has become final or after the appropriate court has entered final judgment in favor of the Commission, the Attorney General at the request of the Commission may seek to collect the amount assessed in an appropriate district court of the United States. The court shall enforce the order of the Commission unless it finds that the order was not regularly made and duly issued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b14eb5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1544"},"text":"120 Stat. 1544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/146"},"text":"Pub. L. 117–146","children":[],"tail":", §§ 8(a)(2), 15(b), "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1276"},"text":"136 Stat. 1276","children":[],"tail":", 1279.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b14eb6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b14eb7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b14eb8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41109(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1712(c) (1st, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/98/237/s13/c"},"text":"Pub. L. 98–237, § 13(c)","children":[],"tail":"–(f), "},{"tag":"html:span","attrib":{},"text":"Mar. 20, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/82"},"text":"98 Stat. 82","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tI/s112/c"},"text":"Pub. L. 105–258, title I, § 112(c)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1912"},"text":"112 Stat. 1912","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41109(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1712(c) (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41109(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1712(f)(1) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41109(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1712(f)(1) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41109(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1712(f)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41109(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1712(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41109(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1712(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6b14eb9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6b14eba-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s8/a/2/A"},"text":"Pub. L. 117–146, § 8(a)(2)(A)","children":[],"tail":", added subsecs. (a) and (b) and struck out former subsecs. (a) and (b) which related to general authority to assess a civil penalty and factors in determining the amount of a civil penalty."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s15/b"},"text":"Pub. L. 117–146, § 15(b)","children":[],"tail":", substituted “subsection (a) or (d) of section 41102 or paragraph (1) or (2) of section 41104(a)” for “section 41102(a) or 41104(1) or (2) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s8/a/2/B"},"text":"Pub. L. 117–146, § 8(a)(2)(B)","children":[],"tail":", substituted “or refund of money under subparagraph (A) or (B), respectively, of subsection (a)(1) may not be imposed” for “may not be imposed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s8/a/2/C"},"text":"Pub. L. 117–146, § 8(a)(2)(C)","children":[],"tail":", inserted “or order a refund of money” after “penalty”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s8/a/2/D"},"text":"Pub. L. 117–146, § 8(a)(2)(D)","children":[],"tail":", inserted “, or that is ordered to refund money,” after “assessed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s8/a/2/E"},"text":"Pub. L. 117–146, § 8(a)(2)(E)","children":[],"tail":", inserted “or a refund required under this section” after “penalty”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
