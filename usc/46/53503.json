{"tag":"section","attrib":{"id":"idf6d77458-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53503"},"text":null,"children":[{"tag":"num","attrib":{"value":"53503"},"text":"§ 53503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishing a capital construction fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d77459-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A citizen of the United States owning or leasing an eligible vessel may make an agreement with the Secretary under this chapter to establish a capital construction fund for the vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d7745a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowable Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of the agreement shall be to provide replacement vessels, additional vessels, or reconstructed vessels, built in the United States and documented under the laws of the United States, for operation in the foreign or domestic trade of the United States or in the fisheries of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d7745b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"ta