ll,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:104.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1908-05-28/ch212/s5"},"text":"May 28, 1908, ch. 212, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/35/425"},"text":"35 Stat. 425","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1909-08-05/ch6/s37"},"text":"Aug. 5, 1909, ch. 6, § 37","children":[],"tail":" (3d par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/36/112"},"text":"36 Stat. 112","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1948-06-26/ch673"},"text":"June 26, 1948, ch. 673","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/1051"},"text":"62 Stat. 1051","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security is substituted for the Commissioner of Customs because the functions of the Customs Service and of the Secretary of the Treasury relating thereto were transferred to the Secretary of Homeland Security by section 403(1) of the Homeland Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2178"},"text":"116 Stat. 2178","children":[],"tail":"). The functions of the Commissioner of Customs previously were vested in the Secretary of the Treasury under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s321/c"},"text":"section 321(c) of title 31","children":[],"tail":". For prior related transfers of functions, see the transfer of functions note under 46 App. U.S.C. 104."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
