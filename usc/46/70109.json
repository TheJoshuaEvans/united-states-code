{"tag":"section","attrib":{"id":"idf704c6bb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70109"},"text":null,"children":[{"tag":"num","attrib":{"value":"70109"},"text":"§ 70109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notifying foreign authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf704c6bc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless the Secretary finds that a port in a foreign country maintains effective antiterrorism measures, the Secretary shall notify the appropriate authorities of the government of the foreign country of the finding and recommend the steps necessary to improve the antiterrorism measures in use at the port.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf704c6bd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in cooperation with the Secretary of State, shall operate a port security training program for ports in foreign countries that are found under section 70108 to lack effective antiterrorism measures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf704c6be-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s102/a"},"text":"Pub. L. 107–295, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2080"},"text":"116 Stat. 2080","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVIII/s806/a/2"},"text":"Pub. L. 111–281, title VIII, § 806(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2992"},"text":"124 Stat. 2992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf704c6bf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf704c6c0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf704c6c1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" substituted “Unless the Secretary finds that a port in a foreign country maintains effective antiterrorism measures,” for “If the Secretary, after conducting an assessment under section 70108, finds that a port in a foreign country does not maintain effective antiterrorism measures,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
