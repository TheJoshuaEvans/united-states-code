{"tag":"section","attrib":{"id":"idf6fb2926-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70014"},"text":null,"children":[{"tag":"num","attrib":{"value":"70014"},"text":"§ 70014.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aiming laser pointer at vessel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6fb2927-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70014/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be unlawful to cause the beam of a laser pointer to strike a vessel operating on the navigable waters of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb2928-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70014/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall not apply to a member or element of the Department of Defense or Department of Homeland Security acting in an official capacity for the purpose of research, development, operations, testing, or training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb2929-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70014/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Laser Pointer Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section the term “laser pointer” means any device designed or used to amplify electromagnetic radiation by stimulated emission that emits a beam designed to be used by the operator as a pointer or highlighter to indicate, mark, or identify a specific position, place, item, or object.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6fb292a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII/s8342/a"},"text":"Pub. L. 116–283, div. G, title LVXXXIII, § 8342(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4709"},"text":"134 Stat. 4709","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
