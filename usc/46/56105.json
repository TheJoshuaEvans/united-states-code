{"tag":"section","attrib":{"id":"idf6ecf8a0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56105"},"text":null,"children":[{"tag":"num","attrib":{"value":"56105"},"text":"§ 56105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture procedure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ecf8a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A forfeiture under this chapter may be enforced in the same way as a forfeiture under the laws on the collection of duties. However, such a forfeiture may be remitted without seizure of the vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf8a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prior Convictions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a proceeding under this chapter to enforce a forfeiture, a prior criminal conviction of a person for a violation of this chapter with respect to the subject matter of the forfeiture is prima facie evidence of the violation against the person convicted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ecf8a3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1654"},"text":"1