{"tag":"section","attrib":{"id":"idf68d9a81-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10703"},"text":null,"children":[{"tag":"num","attrib":{"value":"10703"},"text":"§ 10703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures of masters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68d9a82-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the vessel is proceeding to the United States when a seaman dies, the master shall deliver the seaman’s money, property, and wages when the agreement required by this part is ended, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s10706"},"text":"section 10706 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9a83-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the vessel touches at a foreign port after the death of the seaman, the master shall report to the first available consular officer. The consular officer may require the master to deliver to the officer the money, property, and wages of the seaman. The consular officer shall give the master a receipt for the matters delivered and certify on the agreement the particulars of the delivery. When the agreement ends, the master shall deliver the receipt to a district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9a84-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the consular officer does not require the master to deliver the seaman’s money, property, and wages, the officer shall so certify on the agreement, and the master shall dispose of the money, property, and wages as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s10706"},"text":"section 10706 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9a85-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A deduction from the account of a deceased seaman is valid only if certified by a proper entry in the official logbook.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68d9a86-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/573"},"text":"97 Stat. 573","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/206/tIV/s418"},"text":"Pub. L. 103–206, title IV, § 418","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2438"},"text":"107 Stat. 2438","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68d9a87-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68d9a88-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68d9a89-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10703","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:622","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10703 provides for the disposal by the master of the property and wages of deceased seamen who have died outside the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68d9a8a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68d9a8b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/s418/1"},"text":"Pub. L. 103–206, § 418(1)","children":[],"tail":", substituted “in "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s10706"},"text":"section 10706 of this title","children":[],"tail":"” for “by regulations prescribed by the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/s418/2"},"text":"Pub. L. 103–206, § 418(2)","children":[],"tail":", substituted “to a district court of the United States” for “as prescribed by regulations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/s418/3"},"text":"Pub. L. 103–206, § 418(3)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t46/s10706"},"text":"section 10706 of this title","children":[],"tail":"” for “subsection (a) of this section”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
