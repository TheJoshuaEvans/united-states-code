{"tag":"section","attrib":{"id":"idf7098087-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70506"},"text":null,"children":[{"tag":"num","attrib":{"value":"70506"},"text":"§ 70506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7098088-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person violating paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70503/a"},"text":"section 70503(a) of this title","children":[],"tail":" shall be punished as provided in section 1010 of the Comprehensive Drug Abuse Prevention and Control Act of 1970 ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s960"},"text":"21 U.S.C. 960","children":[],"tail":"). However, if the offense is a second or subsequent offense as provided in section 1012(b) of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s962/b"},"text":"21 U.S.C. 962(b)","children":[],"tail":"), the person shall be punished as provided in section 1012 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s962"},"text":"21 U.S.C. 962","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098089-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attempts and Conspiracies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person attempting or conspiring to violate ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70503"},"text":"section 70503 of this title","children":[],"tail":" is subject to the same penalties as provided for violating section 70503."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf709808a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Simple Possession.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf709808b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70506/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any individual on a vessel subject to the jurisdiction of the United States who is found by the Secretary, after notice and an opportunity for a hearing, to have knowingly or intentionally possessed a controlled substance within the meaning of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s812"},"text":"21 U.S.C. 812","children":[],"tail":") shall be liable to the United States for a civil penalty of not to exceed $5,000 for each violation. The Secretary shall notify the individual in writing of the amount of the civil penalty."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf709808c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70506/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In determining the amount of the penalty, the Secretary shall consider the nature, circumstances, extent, and gravity of the prohibited acts committed and, with respect to the violator, the degree of culpability, any history of prior offenses, ability to pay, and other matters that justice requires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf709808d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70506/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of civil penalty assessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Assessment of a civil penalty under this subsection shall not be considered a conviction for purposes of State or Federal law but may be considered proof of possession if such a determination is relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf709808e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person violating paragraph (2) or (3) of section 70503(a) shall be fined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3571"},"text":"section 3571 of title 18","children":[],"tail":", imprisoned not more than 15 years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf709808f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s10/2"},"text":"Pub. L. 109–304, § 10(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1688"},"text":"120 Stat. 1688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIII/s302"},"text":"Pub. L. 111–281, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2923"},"text":"124 Stat. 2923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s314/c"},"text":"Pub. L. 114–120, title III, § 314(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/59"},"text":"130 Stat. 59","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf7098090-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf7098091-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf7098092-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70506(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1903(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/96/350/s3/g"},"text":"Pub. L. 96–350, § 3(g)","children":[],"tail":", (j), "},{"tag":"html:span","attrib":{},"text":"Sept. 15, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1160"},"text":"94 Stat. 1160","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/99/570/tIII/s3202"},"text":"Pub. L. 99–570, title III, § 3202","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3207-97"},"text":"100 Stat. 3207–97","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/99/640/s17"},"text":"Pub. L. 99–640, § 17","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3554"},"text":"100 Stat. 3554","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/647/tXII/s1203"},"text":"Pub. L. 101–647, title XII, § 1203","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/4830"},"text":"104 Stat. 4830","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70506(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1903(j).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “the commission of which was the object of the attempt or conspiracy” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf7098093-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf7098094-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Controlled Substances Act, referred to in subsec. (c)(1), is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/513"},"text":"Pub. L. 91–513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-27"},"text":"Oct. 27, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1242"},"text":"84 Stat. 1242","children":[],"tail":", which is classified principally to subchapter I (§ 801 et seq.) of chapter 13 of Title 21, Food and Drugs. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s801"},"text":"section 801 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf7098095-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s314/c/1"},"text":"Pub. L. 114–120, § 314(c)(1)","children":[],"tail":", substituted “A person violating paragraph (1) of section 70503(a)” for “A person violating section 70503”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s314/c/2"},"text":"Pub. L. 114–120, § 314(c)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
