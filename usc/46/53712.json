s","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6dea050-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/D"},"text":"Pub. L. 109–163, § 3507(a)(1)(D)","children":[],"tail":", (b)(6). See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/a/6"},"text":"Pub. L. 110–181, § 3522(a)(6)","children":[],"tail":", (10)(B), incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/D"},"text":"Pub. L. 109–163, § 3507(a)(1)(D)","children":[],"tail":", (b)(6), into this section by inserting “or Administrator” after “Secretary” wherever appearing and substituting “If the Secretary or Administrator has waived a requirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53707/d"},"text":"section 53707(d) of this title","children":[],"tail":", the loan agreement shall include requirements for additional payments, collateral, or equity contributions to meet the waived requirement upon the occurrence of verifiable conditions indicating that the obligor’s financial condition enables the obligor to meet the waived requirement.” for “These provisions include requirements for additional collateral or greater equity contributions that are effective upon the occurrence of verifiable conditions relating to the obligor’s financial condition or the status of the vessel or shipyard project.” See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/D"},"text":"Pub. L. 109–163, § 3507(a)(1)(D)","children":[],"tail":", (b)(6), which directed the amendment of section 1274(k), (m) of the former Appendix to this title from which this section was derived, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":". See 2008 Amendment notes and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
