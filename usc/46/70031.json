{"tag":"section","attrib":{"id":"idf6fb295e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70031"},"text":null,"children":[{"tag":"num","attrib":{"value":"70031"},"text":"§ 70031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in subchapters I through III and this subchapter, unless the context otherwise requires:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb295f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70031/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “marine environment” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6fb2960-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70031/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the navigable waters of the United States and the land and resources therein and thereunder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6fb2961-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70031/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waters and fishery resources of any area over which the United States asserts exclusive fishery management authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6fb2962-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70031/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the seabed and subsoil of the Outer Continental Shelf of the United States, the resources thereof, and the waters superjacent thereto; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6fb2963-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70031/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recreational, economic, and scenic values of such waters and resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb2964-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70031/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of the department in which the Coast Guard is operating, except that such term means the Secretary of Transportation with respect to the application of this chapter to the Saint Lawrence Seaway.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb2965-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70031/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “navigable waters of the United States” includes all waters of the territorial sea of the United States as described in Presidential Proclamation No. 5928 of ","children":[{"tag":"date","attrib":{"date":"1988-12-27"},"text":"December 27, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6fb2966-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIV/s401/a"},"text":"Pub. L. 115–282, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4261"},"text":"132 Stat. 4261","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8507(a)(4), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4753"},"text":"134 Stat. 4753","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6fb2967-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6fb2968-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6fb2969-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Presidential Proclamation No. 5928, referred to in par. (3), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6fb296a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “I through III” for “A through C” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
