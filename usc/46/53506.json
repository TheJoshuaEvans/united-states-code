{"tag":"section","attrib":{"id":"idf6d77475-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53506"},"text":null,"children":[{"tag":"num","attrib":{"value":"53506"},"text":"§ 53506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment and fiduciary requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d77476-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts in a capital construction fund shall be kept in the depository specified in the agreement and shall be subject to trustee and other fiduciary requirements prescribed by the Secretary. Except as provided in subsection (b), amounts in the fund may be invested only in interest-bearing securities approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d77477-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stock Investments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d77478-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With the approval of the Secretary, an agreed percentage (but not more than 60 percent) of the assets of the fund may be invested in the stock of domestic corporations that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d77479-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53506/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is fully listed and registered on an exchange registered with the Securities and Exchange Commission as a national securities exchange; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d7747a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53506/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be acquired by a prudent investor seeking a reasonable income and the preservation of capital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d7747b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preferred stock","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The preferred stock of a corporation is deemed to satisfy the requirements of this subsection, even though it may not be registered and listed because it is nonvoting stock, if the common stock of the corporation satisfies the requirements and the preferred stock otherwise would satisfy the requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d7747c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintaining Agreed Percentage","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If at any time the fair market value of the stock in the fund is more than the agreed percentage of the assets in the fund, any subsequent investment of amounts deposited in the fund, and any subsequent withdrawal from the fund, shall be made in a way that tends to restore the fair market value of the stock to not more than the agreed percentage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d7747d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1594"},"text":"120 Stat. 1594","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d7747e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6d7747f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6d77480-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53506","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1177(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title VI, § 607(c), "},{"tag":"html:a","attrib":{"href":"/us/stat/49/2005"},"text":"49 Stat. 2005","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1938-06-23/ch600"},"text":"June 23, 1938, ch. 600","children":[],"tail":", §§ 23–28, "},{"tag":"html:a","attrib":{"href":"/us/stat/52/960"},"text":"52 Stat. 960","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1939-08-04/ch417/s10"},"text":"Aug. 4, 1939, ch. 417, § 10","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/1185"},"text":"53 Stat. 1185","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-17/ch939"},"text":"July 17, 1952, ch. 939","children":[],"tail":", §§ 17–19, "},{"tag":"html:a","attrib":{"href":"/us/stat/66/764"},"text":"66 Stat. 764","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/85/637"},"text":"Pub. L. 85–637","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 14, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/216"},"text":"72 Stat. 216","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/86/518/s1"},"text":"Pub. L. 86–518, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"June 12, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/216"},"text":"74 Stat. 216","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/87/45/s6"},"text":"Pub. L. 87–45, § 6","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"May 27, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/91"},"text":"75 Stat. 91","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/87/271"},"text":"Pub. L. 87–271","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 21, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/570"},"text":"75 Stat. 570","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/pl/91/469/s21/a"},"text":"Pub. L. 91–469, § 21(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1027"},"text":"84 Stat. 1027","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/97/A"},"text":"Pub. L. 97–31, § 12(97)(A)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/162"},"text":"95 Stat. 162","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(B), the words “prudent investor” are substituted for “prudent men of discretion and intelligence in such matters” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
