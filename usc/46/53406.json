{"tag":"section","attrib":{"id":"idf6d503c0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406"},"text":null,"children":[{"tag":"num","attrib":{"value":"53406"},"text":"§ 53406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d503c1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Payments.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d503c2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations and the other provisions of this section, the Secretary shall pay to a program participant for an operating agreement under this chapter, for each vessel that is covered by the operating agreement, an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d503c3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,160,000 for each of fiscal years 2025 and 2026;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d503c4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,380,000 for each of fiscal years 2027 and 2028;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d503c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,606,000 for each of fiscal years 2029 and 2030;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d503c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,839,000 for each of fiscal years 2031 and 2032;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d503c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $9,078,000 for each of fiscal years 2033 and 2034;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d503c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $9,323,000 for each of fiscal years 2035 and 2036;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d503c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $9,574,000 for each of fiscal years 2037 and 2038; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d503ca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $9,833,000 for each of fiscal years 2039 and 2040.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d503cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount payable to a program participant under paragraph (1) for a fiscal year shall be paid in 12 equal monthly installments at the end of each month during that fiscal year. The amount payable for any fiscal year may not be reduced except as provided by this section or section 51307(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d503cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Required for Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As a condition of receiving payment under this section for a fiscal year for a vessel, the program participant shall certify, in accordance with regulations issued by the Secretary, that the vessel has been and will be operated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53405/a"},"text":"section 53405(a) of this title","children":[],"tail":" for at least 320 days during the fiscal year. Days during which the vessel is drydocked, surveyed, inspected, or repaired shall be considered days of operation for purposes of this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d503cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make any payment under this chapter for a vessel with respect to any days for which the vessel is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d503ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not operated or maintained in accordance with an operating agreement under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d503cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 20 years of age; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d503d0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" simultaneously operating under an agreement pursuant to chapter 531 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d503d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reductions in Payments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to payments under this chapter for a vessel covered by an operating agreement, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d503d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as provided in paragraph (2), may not reduce such a payment for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d503d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation of the vessel to carry military or other preference cargoes under section 55302(a), 55304, 55305, or 55314 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2631"},"text":"section 2631 of title 10","children":[],"tail":", or any other cargo preference law of the United States; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d503d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any days in which the vessel is operated under charter to the United States Government;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d503d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not make such a payment for any day that the vessel is engaged in transporting more than 7,500 tons of civilian bulk preference cargoes pursuant to section 55302(a), 55305, or 55314 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d503d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make a pro rata reduction for each day less than 320 in a fiscal year that the vessel is not operated in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53405"},"text":"section 53405 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d503d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations Regarding Noncontiguous Domestic Trade.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d503d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No program participant shall receive payments pursuant to this chapter during a period in which it participates in noncontiguous domestic trade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d503d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall not apply to a program participant that is a citizen of the United States within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":", applying the 75 percent ownership requirement of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d503da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53406/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participates in a noncontiguous trade defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection the term “participates in a noncontiguous domestic trade” means directly or indirectly owns, charters, or operates a vessel engaged in transportation of cargo between a point in the contiguous 48 States and a point in Alaska, Hawaii, or Puerto Rico, other than a point in Alaska north of the Arctic Circle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d503db-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dC/tXXXV/s3511/a"},"text":"Pub. L. 116–283, div. C, title XXXV, § 3511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4415"},"text":"134 Stat. 4415","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3517/b/3"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3517(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3074"},"text":"136 Stat. 3074","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXV/s3531/b"},"text":"Pub. L. 118–159, div. C, title XXXV, § 3531(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2312"},"text":"138 Stat. 2312","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d503dc-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6d503dd-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6d503de-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “Subject to the availability of appropriations for such purpose and the other provisions of this chapter, the Secretary shall pay to program participant for an operating agreement under this chapter an amount equal to $6,000,000 for each vessel covered by the agreement for each fiscal year that the vessel is covered by the agreement. Such amount shall be paid in equal monthly installments on the last day of each month. The amount payable under this subsection may not be reduced except as provided by this section or section 51307(b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" inserted “or section 51307(b)” after “this section”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
