 to (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s54102"},"text":"section 54102 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6c91ccd-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6c91cce-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Guidelines","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3532/c"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3532(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3092"},"text":"136 Stat. 3092","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dC/tXXXV/s3532/c"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“Not later than one year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], the Secretary of Transportation shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe guidelines for the submission of grant proposals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51706/b"},"text":"section 51706(b) of title 46","children":[],"tail":", United States Code, as amended by subsection (a); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish and maintain such guidelines on the website of the Department of Transportation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
