{"tag":"section","attrib":{"id":"idf67a6073-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7311a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7311a"},"text":"§ 7311a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Able seamen—fishing industry","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For service on a fish processing vessel, an individual may be rated as able seaman—fishing industry if the individual has at least 6 months’ service on deck on board vessels operating on the oceans or the navigable waters of the United States (including the Great Lakes).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf67a6074-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364/tIV/s402/9/D"},"text":"Pub. L. 98–364, title IV, § 402(9)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/448"},"text":"98 Stat. 448","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
