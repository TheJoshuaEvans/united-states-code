{"tag":"section","attrib":{"id":"idf7071018-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70113"},"text":null,"children":[{"tag":"num","attrib":{"value":"70113"},"text":"§ 70113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maritime intelligence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7071019-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall implement a system to collect, integrate, and analyze information concerning vessels operating on or bound for waters subject to the jurisdiction of the United States, including information related to crew, passengers, cargo, and intermodal shipments. The system may include a vessel risk profiling component that assigns incoming vessels a terrorism risk rating.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf707101a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing the information system under subsection (a), the Secretary shall consult with the Transportation Security Oversight Board and other departments and agencies, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf707101b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Integration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To deter a transportation security incident, the Secretary may collect information from public and private entities to the extent that the information is not provided by other Federal departments and agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf707101c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s102/a"},"text":"Pub. L. 107–295, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2082"},"text":"116 Stat. 2082","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tVIII/s803/a"},"text":"Pub. L. 108–293, title VIII, § 803(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1080"},"text":"118 Stat. 1080","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf707101d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf707101e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf707101f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" inserted at end “The system may include a vessel risk profiling component that assigns incoming vessels a terrorism risk rating.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
