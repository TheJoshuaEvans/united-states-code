{"tag":"section","attrib":{"id":"idf6949f4f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12116"},"text":null,"children":[{"tag":"num","attrib":{"value":"12116"},"text":"§ 12116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited endorsements for Guam, American Samoa, and Northern Mariana Islands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6949f50-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Endorsements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel satisfying the requirements of subsection (b) may be issued—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6949f51-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a coastwise endorsement to engage in the coastwise trade of fisheries products between places in Guam, American Samoa, and the Northern Mariana Islands; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f52-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fishery endorsement to engage in fishing in the territorial sea and fishery conservation zone adjacent to Guam, American Samoa, and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949f53-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An endorsement may be issued under subsection (a) for a vessel that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6949f54-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12103"},"text":"section 12103 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f55-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was not built in the United States, except that for an endorsement under subsection (a)(2), the vessel must not have been built or rebuilt in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f56-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12116/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is less than 200 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f57-2930-11f1-96a8-b9bd2a0a99b5",