<section xmlns="http://xml.house.gov/schemas/uslm/1.0" xmlns:html="http://www.w3.org/1999/xhtml" style="-uslm-lc:I80" id="idf66e78b4-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s4101"><num value="4101">§ 4101.</num><heading> Application</heading>
<chapeau style="-uslm-lc:I11" class="indent0">This chapter applies to an uninspected vessel not subject to chapter 45 of this title—</chapeau><paragraph style="-uslm-lc:I12" class="indent1" id="idf66e78b5-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s4101/1"><num value="1">(1)</num><content> on the navigable waters of the United States; or</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf66e78b6-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s4101/2"><num value="2">(2)</num><content> owned in the United States and operating on the high seas.</content>
</paragraph>
<sourceCredit id="idf66e78b7-2930-11f1-96a8-b9bd2a0a99b5">(<ref href="/us/pl/98/89">Pub. L. 98–89</ref>, <date date="1983-08-26">Aug. 26, 1983</date>, <ref href="/us/stat/97/528">97 Stat. 528</ref>; <ref href="/us/pl/100/424/s8/b">Pub. L. 100–424, § 8(b)</ref>, <date date="1988-09-09">Sept. 9, 1988</date>, <ref href="/us/stat/102/1593">102 Stat. 1593</ref>.)</sourceCredit>
<notes type="uscNote" id="idf66e78b8-2930-11f1-96a8-b9bd2a0a99b5">
<note topic="historicalAndRevision" id="idf66e78b9-2930-11f1-96a8-b9bd2a0a99b5">
