{"tag":"section","attrib":{"id":"idf6b3c03d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101"},"text":null,"children":[{"tag":"num","attrib":{"value":"46101"},"text":"§ 46101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b3c03e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Maritime Commission is an independent establishment of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3c03f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commissioners","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3c040-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission is composed of 5 Commissioners, appointed by the President by and with the advice and consent of the Senate. Not more than 3 Commissioners may be appointed from the same political party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3c041-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of each Commissioner is 5 years. When the term of a Commissioner ends, the Commissioner may continue to serve until a successor is appointed and qualified, but for a period not to exceed 2 years. Except as provided in paragraph (3), no individual may serve more than 3 terms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3c042-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vacancy shall be filled in the same manner as the original appointment. An individual appointed to fill a vacancy is appointed only for the unexpired term to which such individual is appointed. An individual appointed to fill a vacancy may serve 3 terms in addition to the remainder of the term for which such individual was appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3c043-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conflicts of interest.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b3c044-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on relationships with regulated entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commissioner may not have a pecuniary interest in, hold an official relation to, or own stocks or bonds of any entity the Commission regulates under chapter 401 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b3c045-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on other activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Commissioner may not engage in another business, vocation, or employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3c046-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Removal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may remove a Commissioner for inefficiency, neglect of duty, or malfeasance in office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3c047-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3c048-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall designate one of the Commissioners as Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3c049-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chairman is the chief executive and administrative officer of the Commission. In carrying out the duties and powers of the Commission (other than under paragraph (3)), the Chairman is subject to the policies, regulatory decisions, findings, and determinations of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3c04a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Particular duties","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b3c04b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chairman shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6b3c04c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint and supervise officers and employees of the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6b3c04d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint the heads of major organizational units (with such appointments subject to the approval of the Commission);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6b3c04e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distribute the business of the Commission among personnel and organizational units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6b3c04f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/c/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervise the expenditure of money for administrative purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6b3c050-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/c/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign Commission personnel, including Commissioners, to perform duties and powers delegated by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s46104"},"text":"section 46104 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6b3c051-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/c/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the President and the Congress requests for appropriations for the Commission (with such requests subject to the approval of the Commission).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b3c052-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subparagraph (A) (other than clause (v)) does not apply to personnel employed regularly and full-time in the offices of Commissioners other than the Chairman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3c053-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chairman may designate officers and employees under the Chairman’s jurisdiction to perform duties and powers of the Chairman, subject to the Chairman’s supervision and direction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3c054-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Seal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall have a seal which shall be judicially recognized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b3c055-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s4"},"text":"Pub. L. 109–304, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1488"},"text":"120 Stat. 1488","children":[],"tail":", § 301; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIV/s403/a"},"text":"Pub. L. 113–281, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3056"},"text":"128 Stat. 3056","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIV/s402"},"text":"Pub. L. 114–120, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/67"},"text":"130 Stat. 67","children":[],"tail":"; renumbered § 46101 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXVI"},"text":"Pub. L. 116–283, div. G, title LVXXXVI","children":[],"tail":" [LXXXVI], § 8605(a)(3), (b)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4765"},"text":"134 Stat. 4765","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVIII/s11801/a"},"text":"Pub. L. 117–263, div. K, title CXVIII, § 11801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4163"},"text":"136 Stat. 4163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b3c056-2930-11f1-96a8-b9bd2a0a99b5"},