ml:span","attrib":{},"text":"301(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1111 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Reorg. Plan No. 7 of 1961, eff. ","children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1961","children":[],"tail":", § 101, "},{"tag":"html:a","attrib":{"href":"/us/stat/75/840"},"text":"75 Stat. 840","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"301(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1111 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Reorg. Plan No. 7 of 1961, eff. ","children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1961","children":[],"tail":", § 102(a), (c), "},{"tag":"html:a","attrib":{"href":"/us/stat/75/840"},"text":"75 Stat. 840","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/88/426/tIII/s305/19/A"},"text":"Pub. L. 88–426, title III, § 305(19)(A)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/425"},"text":"78 Stat. 425","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1111 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/89/56"},"text":"Pub. L. 89–56","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"June 30, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/195"},"text":"79 Stat. 195","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"301(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1111 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Reorg. Plan No. 6 of 1949, eff. ","children":[{"tag":"html:span","attrib":{},"text":"Aug. 20, 1949","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/1069"},"text":"63 Stat. 1069","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1111 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Reorg. Plan No. 7 of 1961, eff. ","children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1961","children":[],"tail":", §§ 102(b), 104, 105(d), "},{"tag":"html:a","attrib":{"href":"/us/stat/75/840"},"text":"75 Stat. 840","children":[],"tail":", 841."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"301(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1111(c) (related to seal).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title II, § 201(c) (related to seal), "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1986"},"text":"49 Stat. 1986","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “is an independent establishment” are substituted for “shall not be a part of any executive department or under the authority of the head of any executive department” for consistency with other titles of the United States Code and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “The term of each Commissioner is 5 years, with each term beginning one year apart” are substituted for the language about terms in section 102(c) of Reorganization Plan No. 7 of 1961 (46 App. U.S.C. 1111 note) and the Act of ","children":[{"tag":"date","attrib":{"date":"1965-06-30"},"text":"June 30, 1965","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/89/56"},"text":"Pub. L. 89–56","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/195"},"text":"79 Stat. 195","children":[],"tail":"), for clarity and to eliminate executed and obsolete language."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), section 104 of Reorganization Plan No. 7 of 1961 is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c)(1) is based on section 102(b) of Reorganization Plan No. 7 of 1961. The words “from time to time” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c)(2) is based on section 1 of Reorganization Plan No. 6 of 1949.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c)(3) is based on section 2 of Reorganization Plan No. 6 of 1949 and section 105(d) of Reorganization Plan No. 7 of 1961.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c)(4) is based on section 3 of Reorganization Plan No. 6 of 1949.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6b3c059-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6b3c05a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11801/a/1"},"text":"Pub. L. 117–263, § 11801(a)(1)","children":[],"tail":", substituted “2 years” for “one year” and “3 terms” for “2 terms”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11801/a/2"},"text":"Pub. L. 117–263, § 11801(a)(2)","children":[],"tail":", substituted “to which such individual is appointed” for “of the individual being succeeded”, “3 terms” for “2 terms”, and “such” for “the predecessor of that”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8605/a/3"},"text":"Pub. L. 116–283, § 8605(a)(3)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s301"},"text":"section 301 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8605/b/1"},"text":"Pub. L. 116–283, § 8605(b)(1)","children":[],"tail":", substituted “46104” for “304”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s402/1"},"text":"Pub. L. 114–120, § 402(1)","children":[],"tail":", substituted “units (with such appointments subject to the approval of the Commission);” for “units, but only after consultation with the other Commissioners;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A)(vi). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/s402/2"},"text":"Pub. L. 114–120, § 402(2)","children":[],"tail":"–(4), added cl. (vi)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/s403/a/1"},"text":"Pub. L. 113–281, § 403(a)(1)","children":[],"tail":", amended par. (2) generally. Prior to amendment, text read as follows: “The term of each Commissioner is 5 years, with each term beginning one year apart. An individual appointed to fill a vacancy is appointed only for the unexpired term of the individual being succeeded. A vacancy shall be filled in the same manner as the original appointment. When the term of a Commissioner ends, the Commissioner may continue to serve until a successor is appointed and qualified.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/s403/a/2"},"text":"Pub. L. 113–281, § 403(a)(2)","children":[],"tail":", added pars. (3) and (4) and redesignated former par. (3) as (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6b6094b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6b6094c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVIII/s11801/b"},"text":"Pub. L. 117–263, div. K, title CXVIII, § 11801(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4163"},"text":"136 Stat. 4163","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dK/tCXVIII/s11801/b"},"text":"“The amendments made by this section [amending this section] shall not apply to Commissioners to whom section 403(b) of the Howard Coble Coast Guard and Maritime Transportation Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Public Law 113–281","children":[],"tail":") [set out below] applies.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6b6094d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIV/s403/b"},"text":"Pub. L. 113–281, title IV, § 403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3056"},"text":"128 Stat. 3056","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/281/tIV/s403/b"},"text":"“The amendment made by subsection (a)(1) [amending this section] does not apply with respect to a Commissioner of the Federal Maritime Commission appointed and confirmed by the Senate before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
