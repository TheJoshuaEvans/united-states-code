{"tag":"section","attrib":{"id":"idf68d9aed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10905"},"text":null,"children":[{"tag":"num","attrib":{"value":"10905"},"text":"§ 10905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complaints in foreign ports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68d9aee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When a complaint under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s10902/a"},"text":"section 10902(a) of this title","children":[],"tail":" is made in a foreign port, the procedures of this chapter shall be followed, with a consular officer performing the duties of the judge or justice of the peace."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9aef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On review of the marine surveyors’ report, the consular officer may approve and must certify any part of the report with which the officer agrees. If the consular officer dissents from any part of the report, the officer shall certify reasons for dissenting from that part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68d9af0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/576"},"text":"97 Stat. 576","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68d9af1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68d9af2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68d9af3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10905","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:656","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:657","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10905 provides that if a complaint of unfitness is made in a foreign port, a consular officer shall perform the duties of a judge or justice of the peace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
