{"tag":"section","attrib":{"id":"idf707104e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70118"},"text":null,"children":[{"tag":"num","attrib":{"value":"70118"},"text":"§ 70118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by State and local officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf707104f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any State or local government law enforcement officer who has authority to enforce State criminal laws may make an arrest for violation of a security zone regulation prescribed under section 70051 or security or safety zone regulation under section 70116(b) or a safety zone regulation prescribed under section 10(d) of the Deepwater Port Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1509/d"},"text":"33 U.S.C. 1509(d)","children":[],"tail":") by a Coast Guard official authorized by law to prescribe such regulations, if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7071050-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70118/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such violation is a felony; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7071051-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70118/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officer has reasonable grounds to believe that the person to be arrested has committed or is committing such violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7071052-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Powers not Affected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of this section are in addition to any power conferred by law to such officers. This section shall not be construed as a limitation of any power conferred by law to such officers, or any other officer of the United States or any State. This section does not grant to such officers any powers not authorized by the law of the State in which those officers are employed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf7071053-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/tVIII/s801/a"},"text":"Pub. L. 108–293, title VIII, § 801(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1078"},"text":"118 Stat. 1078","children":[],"tail":", § 70119; renumbered § 70118, "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIX/s901"},"text":"Pub. L. 109–241, title IX, § 901","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/565"},"text":"120 Stat. 565","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/33/A"},"text":"Pub. L. 109–304, § 15(33)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1705"},"text":"120