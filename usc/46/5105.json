{"tag":"section","attrib":{"id":"idf675a557-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5105"},"text":null,"children":[{"tag":"num","attrib":{"value":"5105"},"text":"§ 5105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Load line surveys","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf675a558-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide for annual, renewal, and other load line surveys.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf675a559-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In conducting a load line survey, the Secretary shall consider whether—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf675a55a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the hull and fittings of the vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf675a55b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5105/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are adequate to protect the vessel from the sea; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf675a55c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5105/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet other requirements the Secretary may prescribe by regulation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf675a55d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strength of the hull is adequate for all loading conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf675a55e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stability of the vessel is adequate for all loading conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf675a55f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5105/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the topsides of the vessel are arranged and constructed to allow rapid overboard drainage of deck water in heavy weather; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf675a560-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5105/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the topsides of the vessel are adequate in design, arrangement, and equipment to protect crewmembers performing outside tasks necessary for safe operation of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf675a561-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5101/2"},"text":"Pub. L. 99–509, title V, § 5101(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1916"},"text":"100 Stat. 1916","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf675a562-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf675a563-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 5105","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5105 authorizes the Secretary of Transportation to provide for load line surveys and requires that while conducting a load line survey, the Secretary must consider various strength, stability, design, and construction features of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
