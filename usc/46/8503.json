{"tag":"section","attrib":{"id":"idf6866e3c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8503"},"text":null,"children":[{"tag":"num","attrib":{"value":"8503"},"text":"§ 8503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal pilots authorized","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6866e3d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may require a pilot licensed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7101"},"text":"section 7101 of this title","children":[],"tail":" on a self-propelled vessel when a pilot is not required by State law and the vessel is—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6866e3e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in foreign commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e3f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" operating—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6866e40-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8503/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in internal waters of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6866e41-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8503/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 3 nautical miles from the baselines from which the territorial sea of the United States is measured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e42-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A requirement prescribed under subsection (a) of this section is terminated when the State having jurisdiction over the area involved—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6866e43-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes a requirement for a State licensed pilot; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6866e44-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies the Secretary of that fact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e45-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the Saint Lawrence Seaway, the Secretary may not delegate the authority under this section to an agency except the Great Lakes St. Lawrence Seaway Development Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e46-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person violating this section or a regulation prescribed under this section is liable to the United States Government for a civil penalty of not more than $25,000. Each day of a continuing violation is a separate violation. The vessel also is liable in rem for the penalty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6866e47-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person that knowingly violates this section or a regulation prescribed under this section commits a class D felony.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6866e48-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557/s29/f/3/A"},"text":"Pub. L. 98–557, § 29(f)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2874"},"text":"98 Stat. 2874","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV/s4302/h"},"text":"Pub. L. 101–380, title IV, § 4302(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/539"},"text":"104 Stat. 539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIII/s301/b/8"},"text":"Pub. L. 105–383, title III, § 301(b)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3417"},"text":"112 Stat. 3417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tV/s512/c/6/C"},"text":"Pub. L. 116–260, div. AA, title V, § 512(c)(6)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2757"},"text":"134 Stat. 2757","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6866e49-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6866e4a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6866e4b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “Great Lakes St. Lawrence Seaway Development Corporation” for “Saint Lawrence Seaway Development Corporation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383"},"text":"Pub. L. 105–383","children":[],"tail":" added par. (2) and struck out former par. (2) which read as follows: “operating on the navigable waters of the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" substituted “commits a class D felony” for “shall be fined not more than $50,000, imprisoned for not more than five years, or both”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6866e4c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statuto