{"tag":"section","attrib":{"id":"idf6a0acfe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103"},"text":null,"children":[{"tag":"num","attrib":{"value":"15103"},"text":"§ 15103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Merchant Marine Personnel Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a0acff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a National Merchant Marine Personnel Advisory Committee (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad00-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall advise the Secretary on matters relating to personnel in the United States merchant marine, including the training, qualifications, certification, documentation, and fitness of mariners.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad01-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ad02-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall consist of 19 members appointed by the Secretary in accordance with this section and section 15109 of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad03-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expertise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad04-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Committee shall be appointed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad05-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 9 members shall represent mariners and, of the 9—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6a0ad06-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" each shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6a0ad07-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a citizen of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6a0ad08-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold an active license or certificate issued under chapter 71 of this title or a merchant mariner document issued under chapter 73 of this title;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6a0ad09-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 3 shall be deck officers who represent merchant marine deck officers and, of the 3—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6a0ad0a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall be licensed for oceans any gross tons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6a0ad0b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be licensed for inland river route with a limited or unlimited tonnage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6a0ad0c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall have a master’s license or a master of towing vessels license;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6a0ad0d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall have significant tanker experience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6a0ad0e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent practicable—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idf6a0ad0f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/ii/V/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall represent labor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idf6a0ad10-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/ii/V/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall represent management;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6a0ad11-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 3 shall be engineering officers who represent merchant marine engineering officers and, of the 3—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6a0ad12-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall be licensed as chief engineer any horsepower;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6a0ad13-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be licensed as either a limited chief engineer or a designated duty engineer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6a0ad14-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent practicable—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idf6a0ad15-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/iii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall represent labor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idf6a0ad16-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/iii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall represent management;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6a0ad17-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 2 shall be unlicensed seamen who represent merchant marine unlicensed seaman and, of the 2—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6a0ad18-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall represent able-bodied seamen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6a0ad19-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall represent qualified members of the engine department; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6a0ad1a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a pilot who represents merchant marine pilots.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad1b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 6 members shall represent marine educators and, of the 6—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6a0ad1c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 3 shall be marine educators who represent maritime academies and, of the 3—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6a0ad1d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall represent State maritime academies (and are jointly recommended by such academies); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6a0ad1e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall represent either State maritime academies or the United States Merchant Marine Academy; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6a0ad1f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 shall be marine educators who represent other maritime training institutions and, of the 3, 1 shall represent the small vessel industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad20-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members shall represent shipping companies employed in ship operation management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad21-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15103/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members shall represent the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a0ad22-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVI/s601/a"},"text":"Pub. L. 115–282, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4282"},"text":"132 Stat. 4282","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
