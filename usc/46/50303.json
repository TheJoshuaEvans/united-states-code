{"tag":"section","attrib":{"id":"idf6b87a9f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50303"},"text":null,"children":[{"tag":"num","attrib":{"value":"50303"},"text":"§ 50303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operating property and extending term of notes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b87aa0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b87aa1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate or lease docks, wharves, piers, vessels, or real property under the Secretary’s control, except that the prior consent of the Secretary of Defense for such use shall be required with respect to any vessel in the Ready Reserve Force or in the National Defense Reserve Fleet which is maintained in a retention status for the Department of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b87aa2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make extensions and accept renewals of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b87aa3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50303/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promissory notes and other evidences of indebtedness on property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b87aa4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50303/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mortgages and other contracts securing the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bac495-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms of Transactions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A transaction under subsection (a) shall be on terms the Secretary considers necessary to carry out the purposes of this subtitle, but consistent with sound business practice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bac496-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts received by the Secretary from a transaction under this section are available for expenditure by the Secretary as provided in this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6bac497-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1564"},"text":"120 Stat. 1564","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3512"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/594"},"text":"122 Stat. 594","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6bac498-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6bac499-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6bac49a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"50303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1112.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title II, § 202, "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1986"},"text":"49 Stat. 1986","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1937-08-26/ch822/s1"},"text":"Aug. 26, 1937, ch. 822, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/50/839"},"text":"50 Stat. 839","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1938-06-23/ch600/s1"},"text":"June 23, 1938, ch. 600, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/52/953"},"text":"52 Stat. 953","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/60"},"text":"Pub. L. 97–31, § 12(60)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/158"},"text":"95 Stat. 158","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Notwithstanding any other provision of law” are omitted as unnecessary. In paragraph (1), the word “lands” is omitted as included in “real property”. In paragraph (2)(A), the word “promissory” is added for clarity. The words “hereby transferred”, referring to the transfer under the first sentence of section 202 of the Merchant Marine Act, 1936 (repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/31/s12/60/A"},"text":"section 12(60)(A) of Public Law 97–31","children":[],"tail":"), are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for “in accordance with good business methods and on such terms and conditions as he determines to effectuate the policy of this chapter” and “upon such terms and conditions as he may prescribe in accordance with sound business practice” for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6bac49b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6bac49c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" inserted “vessels,” after “piers,” and substituted “control, except that the prior consent of the Secretary of Defense for such use shall be required with respect to any vessel in the Ready Reserve Force or in the National Defense Reserve Fleet which is maintained in a retention status for the Department of Defense;” for “control;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
