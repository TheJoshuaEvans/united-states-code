:a","attrib":{"href":"/us/pl/97/31/s12/40"},"text":"Pub. L. 97–31, § 12(40)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/156"},"text":"95 Stat. 156","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/88/s321/1"},"text":"Pub. L. 104–88, § 321(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/109/949"},"text":"109 Stat. 949","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"50302(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:867 (proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before paragraph (1), the words “Secretary of the Army” are substituted for “Secretary of War” in section 8 of the Merchant Marine Act, 1920 (ch. 250, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/41/992"},"text":"41 Stat. 992","children":[],"tail":") because of section 205(a) of the National Security Act of 1947 (ch. 343, "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"). See "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3011"},"text":"10 U.S.C. 3011","children":[],"tail":" et seq. In paragraph (3), the words “apparatus” and “appliances” are omitted as unnecessary. In paragraph (4), the words “consult with” are substituted for “advise with” as being more grammatical."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “rates or practices” are substituted for “rates, charges, rules, or regulations” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6b87a9a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6b87a9b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" redesignated subsec. (c) as "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s54301/a"},"text":"section 54301(a) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/A/i"},"text":"Pub. L. 116–283, § 3504(1)(A)(i)","children":[],"tail":", inserted “or subsection (d)” after “this subsection” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/A/ii"},"text":"Pub. L. 116–283, § 3504(1)(A)(ii)","children":[],"tail":", inserted “, including the owners or operators of a facility, or collection of facilities at a port” after “private entities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/B/i"},"text":"Pub. L. 116–283, § 3504(1)(B)(i)","children":[],"tail":", inserted “or subsection (d)” after “this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/B/ii"},"text":"Pub. L. 116–283, § 3504(1)(B)(ii)","children":[],"tail":", substituted “90” for “60” and inserted “or subsection (d)” after “this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/C"},"text":"Pub. L. 116–283, § 3504(1)(C)","children":[],"tail":", struck out subpar. (C). Prior to amendment, text read as follows: “The Secretary may waive the cost-benefit analysis under subparagraph (A)(ii), and establish a simplified, alternative basis for determining whether a project is cost effective, for a small project described in paragraph (7)(B).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/D/i"},"text":"Pub. L. 116–283, § 3504(1)(D)(i)","children":[],"tail":", substituted “18 percent” for “25 percent” and “subsection (d). The requirement under paragraph (6)(A)(ii) shall not apply to grants made under subsection (d).” for “paragraph (3)(A) that request the lesser of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) 10 percent of the amounts made available for grants under this subsection for a fiscal year; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) $10,000,000.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/D/ii"},"text":"Pub. L. 116–283, § 3504(1)(D)(ii)","children":[],"tail":", added subpar. (C) and struck out former subpar. (C). Text read as follows: “Not more than 10 percent of the amounts made available for grants under this subsection for a fiscal year may be used to make grants for development phase activities under paragraph (3)(B).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/E/i"},"text":"Pub. L. 116–283, § 3504(1)(E)(i)","children":[],"tail":", inserted “or subsection (d)” after “a grant under this subsection” and substituted “the project for which the grant is requested” for “a project under this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/E/ii/I"},"text":"Pub. L. 116–283, § 3504(1)(E)(ii)(I)","children":[],"tail":", substituted “under this subsection or subsection (d)” for “under this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/E/ii/II"},"text":"Pub. L. 116–283, § 3504(1)(E)(ii)(II)","children":[],"tail":", inserted “for which a grant is awarded under subsection (d) or that is” after “project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/F"},"text":"Pub. L. 116–283, § 3504(1)(F)","children":[],"tail":", inserted “for grants made under this subsection and subsection (d)” after “procedures” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(10)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/G"},"text":"Pub. L. 116–283, § 3504(1)(G)","children":[],"tail":", inserted “or subsection (d)” after “this subsection” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(11)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/H/i"},"text":"Pub. L. 116–283, § 3504(1)(H)(i)","children":[],"tail":", substituted “to make grants for port development under this section” for “under this subsection” and “to make grants for port development under this section” for “to carry out this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(11)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/H/ii/I"},"text":"Pub. L. 116–283, § 3504(1)(H)(ii)(I)","children":[],"tail":", substituted “to make grants for port development under this section” for “for carrying out this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(11)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/H/ii/II"},"text":"Pub. L. 116–283, § 3504(1)(H)(ii)(II)","children":[],"tail":", substituted “for port development under this section” for “under this subsection”, and inserted “or that are returned under paragraph (9)(C)” after “the award” and “Any such amount may only be expended to award a grant under the same subsection of this section under which the original grant was made.” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/I/i"},"text":"Pub. L. 116–283, § 3504(1)(I)(i)","children":[],"tail":", inserted “and subsection (d)” after “this subsection” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(12)(A) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/1/I/ii"},"text":"Pub. L. 116–283, § 3504(1)(I)(ii)","children":[],"tail":", redesignated subpars. (B) to (D) as (A) to (C), respectively, and struck out former subpar. (A) which defined “appropriate committees of Congress”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" redesignated subsec. (d) as "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s54301/b"},"text":"section 54301(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/3"},"text":"Pub. L. 116–283, § 3504(3)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" redesignated subsec. (e) as "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s54301/c"},"text":"section 54301(c) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/2"},"text":"Pub. L. 116–283, § 3504(2)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s3504/4"},"text":"Pub. L. 116–283, § 3504(4)","children":[],"tail":", inserted “or subsection (d)” after “subsection (c)” and substituted “to any eligible applicants as described in subsection (c)(2)” for “to port authorities or commissions or their subdivisions and agents”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" added subsecs. (c) and (d) and struck out former subsec. (c), which established and set out parameters for a port infrastructure development program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/66"},"text":"Pub. L. 113–66","children":[],"tail":" inserted “and financial assistance, including grants,” after “technical assistance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6b87a9c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idf6b87a9d-2930-11f1-96a8-b9bd2a