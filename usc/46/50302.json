{"tag":"section","attrib":{"id":"idf6b87a8d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50302"},"text":null,"children":[{"tag":"num","attrib":{"value":"50302"},"text":"§ 50302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Port development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b87a8e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With the objective of promoting, encouraging, and developing ports and transportation facilities in connection with water commerce over which the Secretary of Transportation has jurisdiction, the Secretary, in cooperation with the Secretary of the Army, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b87a8f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate territorial regions and zones tributary to ports, taking into consideration the economies of transportation by rail, water, and highway and the natural direction of the flow of commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b87a90-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate the causes of congestion of commerce at ports and applicable remedies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b87a91-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate the subject of water terminals, including the necessary docks, warehouses, and equipment, to devise and suggest the types most appropriate for different locations and for the most expeditious and economical transfer or interchange of passengers or property between water carriers and rail carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b87a92-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50302/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with communities on the appropriate location and plan of construction of wharves, piers, and water terminals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b87a93-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50302/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate the practicability and advantages of harbor, river, and port improvements in connection with foreign and coastwise trade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b87a94-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50302/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate any other matter that may tend to promote and encourage the use by vessels of ports adequate to care for the freight that naturally would pass through those ports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b87a95-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Findings to Surface Transportation Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After an investigation under subsection (a), if the Secretary of Transportation believes that the rates or practices of a rail carrier subject to the jurisdiction of the Surface Transportation Board are detrimental to the objective specified in subsection (a), or that new rates or practices, new or additional port terminal facilities, or affirmative action by a rail carrier is necessary to promote that objective, the Secretary may submit findings to the Board for action the Board considers appropriate under existing law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b87a96-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1564"},"text":"120 Stat. 1564","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dC/tXXXV/s3512"},"text":"Pub. L. 111–84, div. C, title XXXV, § 3512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2722"},"text":"123 Stat. 2722","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/66/dC/tXXXV/s3505/b"},"text":"Pub. L. 113–66, div. C, title XXXV, § 3505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1086"},"text":"127 Stat. 1086","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3514/b"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3514(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1980"},"text":"133 Stat. 1980","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dC/tXXXV/s3504"},"text":"Pub. L. 116–283, div. C, title XXXV, § 3504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4399"},"text":"134 Stat. 4399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dC/tXXXV/s3513/a/2"},"text":"Pub. L. 117–81, div. C, title XXXV, § 3513(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2240"},"text":"135 Stat. 2240","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b87a97-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b87a98-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b87a99-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html: