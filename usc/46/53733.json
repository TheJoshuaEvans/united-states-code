{"tag":"section","attrib":{"id":"idf6e0ea28-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733"},"text":null,"children":[{"tag":"num","attrib":{"value":"53733"},"text":"§ 53733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shipyard modernization and improvement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e0ea29-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e0ea2a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advanced shipbuilding technology","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “advanced shipbuilding technology” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e0ea2b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" numerically controlled machine tools, robots, automated process control equipment, computerized flexible manufacturing systems, associated computer software, and other technology for improving shipbuilding and related industrial production that advance the state-of-the-art; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e0ea2c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" novel techniques and processes designed to improve shipbuilding quality, productivity, and practice, and to promote sustainable development, including engineering design, quality assurance, concurrent engineering, continuous process production technology, energy efficiency, waste minimization, design for recyclability or parts reuse, inventory management, upgraded worker skills, and communications with customers and suppliers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea2d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General shipyard facility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “general shipyard facility” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e0ea2e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for operations on land—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6e0ea2f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a structure or appurtenance thereto designed for the construction, reconstruction, repair, rehabilitation, or refurbishment of a vessel, including a graving dock, building way, ship lift, wharf, or pier crane;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6e0ea30-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the land necessary for the structure or appurtenance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6e0ea31-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment that is for use with the structure or appurtenance and that is necessary for performing a function referred to in clause (i); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e0ea32-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for operations not on land, a vessel, floating drydock, or barge built in the United States and used for, equipped to be used for, or of a type normally used for, performing a function referred to in subparagraph (A)(i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea33-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modern shipbuilding technology","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “modern shipbuilding technology” means the best available proven technology, techniques, and processes appropriate to enhancing the productivity of shipyards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0ea34-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under subchapter I of this chapter, the Administrator may guarantee or make a commitment to guarantee the payment of the principal of and interest on an obligation for advanced shipbuilding technology and modern shipbuilding technology of a general shipyard facility in the United States. Only a private shipyard is eligible to receive a guarantee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0ea35-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Other Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this section, a guarantee or commitment to guarantee under this section is subject to all the provisions applicable to a guarantee or commitment to guarantee under subchapter I of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0ea36-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Obligation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The principal amount of an obligation guaranteed under this chapter may not exceed 87.5 percent of the actual cost of the advanced shipbuilding technology or modern shipbuilding technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0ea37-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may accept the transfer of amounts from a department, agency, or instrumentality of the United States Government and may use those amounts to cover the cost (as defined in section 502 of the Federal Credit Reform Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"2 U.S.C. 661a","children":[],"tail":")) of making guarantees or commitments to guarantee under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0ea38-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53733/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Buy America","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Part I of subtitle A of title IX of division G of the Infrastructure Investment and Jobs Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Public Law 117–58","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s8301"},"text":"41 U.S.C. 8301","children":[],"tail":" note) shall apply to any funds obligated by the Administrator under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e0ea39-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1623"},"text":"120 Stat. 1623","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/2/K"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(2)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/9/F"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(9)(F)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXV/s3536"},"text":"Pub. L. 118–159, div. C, title XXXV, § 3536","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2315"},"text":"138 Stat. 2315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e0ea3a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e0ea3b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e0ea3c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53733(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1279e(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XI, § 1112, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/103/160/dA/tXIII/s1357/a"},"text":"Pub. L. 103–160, div. A, title XIII, § 1357(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/1814"},"text":"107 Stat. 1814","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53733(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1279e(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1280a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/103/160/tXIII/s1358"},"text":"Pub. L. 103–160, title XIII, § 1358","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/1816"},"text":"107 Stat. 1816","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53733(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1279e(b) (words before “except”).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53733(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1279e(b) (words beginning with “except”).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53733(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1279e(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(A)(i), the words “(as defined in title 1)” are omitted as unnecessary because chapter 1 of the revised title contains a title-wide definition of “vessel” that incorporates the definition in title 1, United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “and subject to the terms the Secretary shall be prescribe” are omitted as unnecessary because section 53702(a) of the revised title provides the Secretary authority to prescribe the terms. The words “Only a private shipyard is eligible to receive a guarantee” are substituted for 46 App. U.S.C. 1280a to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6e0ea3d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6e0ea3e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/2/K"},"text":"Pub. L. 109–163, § 3507(a)(2)(K)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/a/9/F"},"text":"Pub. L. 110–181, § 3522(a)(9)(F)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/2/K"},"text":"Pub. L. 109–163, § 3507(a)(2)(K)","children":[],"tail":", into this section by substituting “Administrator” for “Secretary”. See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/2/K"},"text":"Pub. L. 109–163, § 3507(a)(2)(K)","children":[],"tail":", which directed the amendment of section 1279e of the former Appendix to this title from which this section was derived, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":". See 2008 Amendment note for subsecs. (b), (e) and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
