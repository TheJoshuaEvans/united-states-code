{"tag":"section","attrib":{"id":"idf688b813-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9303"},"text":null,"children":[{"tag":"num","attrib":{"value":"9303"},"text":"§ 9303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States registered pilot service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf688b814-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall prescribe by regulation standards of competency to be met by each applicant for registration under this chapter. An applicant must—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf688b815-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a license as master, mate, or pilot issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7101"},"text":"section 7101 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b816-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have acquired at least 24 months licensed service or equivalent experience on vessels or integrated towing vessels and tows of at least 4,000 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":", operating on the Great Lakes or oceans, with a minimum of 6 months of that service or experience having been on the Great Lakes; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf688b817-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9303/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree that, if appointed as a United States registered pilot, the applicant will be available for service when required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b818-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall issue to each registered pilot under this chapter a certificate of registration describing the areas within which the pilot may serve. The pilot shall carry the certificate when in the service of a vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b819-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe by regulation the duration of validity of registration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b81a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may prescribe by regulation the conditions for service by United States registered pilots, including availability for service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b81b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to sections 551–559 of title 5, the Secretary may suspend or revoke a certificate of registration issued under this section if the holder fails to comply with a regulation prescribed under this chapter. Suspension or revocation of the holder’s license under chapter 77 of this title includes the holder’s certificate of registration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b81c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9303/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe by regulation rates and charges for pilotage services, giving consideration to the public interest and the costs of providing the services. The Secretary shall establish new pilotage rates by March 1 of each year. The Secretary shall establish base pilotage rates by a full ratemaking at least once every 5 years and shall conduct annual reviews of such base pilotage rates, and make adjustments to such base rates, in each intervening year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b81d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9303/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall ensure that a sufficient number of individuals are assigned to carrying out subsection (f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf688b81e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/558"},"text":"97 Stat. 558","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s735"},"text":"Pub. L. 104–324, title VII, § 735","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3941"},"text":"110 Stat. 3941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIII/s302"},"text":"Pub. L. 109–241, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/527"},"text":"120 Stat. 527","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf688b81f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf688b820-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf688b821-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9303(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:216b(a)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9303(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:216b(b)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9303(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:216b(c)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9303(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:216b(c)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9303(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:216c","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 9303 authorizes the Secretary to prescribe regulatory standards of competency for registered pilots.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) requires an applicant for registration as a pilot to have a master’s, mate’s, or pilot’s license, 24 months of licensed service, or equivalent, on vessels on the oceans or Great Lakes, with a minimum of 6 months on the Great Lakes, and agree to be available for service as a United States registered pilot if appointed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) requires the Secretary to issue a certificate of registration describing the areas of service of a registered pilot who must carry the certificate when in a vessel’s service.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) authorizes the Secretary to prescribe the duration of the validity of registration, while subsection (d) authorizes the Secretary to prescribe conditions for service by United States registered pilots.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (e) provides for the suspension or revocation of a certificate or registration by the Secretary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (f) provides for setting the rates and charges for pilotage services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf688b822-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf688b823-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s302/1"},"text":"Pub. L. 109–241, § 302(1)","children":[],"tail":", inserted at end “The Secretary shall establish new pilotage rates by March 1 of each year. The Secretary shall establish base pilotage rates by a full ratemaking at least once every 5 years and shall conduct annual reviews of such base pilotage rates, and make adjustments to such base rates, in each intervening year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241/s302/2"},"text":"Pub. L. 109–241, § 302(2)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “4,000 gross tons”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
