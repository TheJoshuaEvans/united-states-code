{"tag":"section","attrib":{"id":"idf69e3b27-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14303"},"text":null,"children":[{"tag":"num","attrib":{"value":"14303"},"text":"§ 14303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tonnage Certificate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf69e3b28-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After measuring a vessel under this chapter, the Secretary shall issue, on request of the owner, an International Tonnage Certificate (1969) and deliver it to the owner or master of the vessel. For a vessel to which the Convention does not apply, the Secretary shall prescribe a certificate to be issued as evidence of a vessel’s measurement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69e3b29-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The certificate issued under this section shall be maintained as required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf69e3b2a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5101/3"},"text":"Pub. L. 99–509, title V, § 5101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1921"},"text":"100 Stat. 1921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIII/s303/e/1"},"text":"Pub. L. 111–281, title III, § 303(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2925"},"text":"124 Stat. 2925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69e3b2b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69e3b2c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 14303","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Source: International Convention on Tonnage Measurement of Ships.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 14303(a) requires the Secretary to issue, on the request of the owner, an International Tonnage Certificate after measuring a vessel under this chapter. Section 14303(b) requires that the certificate be maintained as required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf69e3b2d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf69e3b2e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s303/e/1/C"},"text":"Pub. L. 111–281, § 303(e)(1)(C)","children":[],"tail":", struck out “International” before “Tonnage” and “(1969)” after “Certificate” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s303/e/1/A"},"text":"Pub. L. 111–281, § 303(e)(1)(A)","children":[],"tail":", inserted at end “For a vessel to which the Convention does not apply, the Secretary shall prescribe a certificate to be issued as evidence of a vessel’s measurement under this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s303/e/1/B"},"text":"Pub. L. 111–281, § 303(e)(1)(B)","children":[],"tail":", inserted “issued under this section” after “The certificate”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
