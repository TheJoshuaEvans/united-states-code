{"tag":"section","attrib":{"id":"idf6a0adca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30101"},"text":null,"children":[{"tag":"num","attrib":{"value":"30101"},"text":"§ 30101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of jurisdiction to cases of damage or injury on land","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a0adcb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The admiralty and maritime jurisdiction of the United States extends to and includes cases of injury or damage, to person or property, caused by a vessel on navigable waters, even though the injury or damage is done or consummated on land.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0adcc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A civil action in a case under subsection (a) may be brought in rem or in personam according to the principles of law and the rules of practice applicable in cases where the injury or damage has been done and consummated on navigable waters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0adcd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions Against United States","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0adce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusive remedy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a civil action against the United States for injury or damage done or consummated on land by a vessel on navigable waters, chapter 309 or 311 of this title, as appropriate, provides the exclusive remedy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0adcf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative claim","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A civil action described in paragraph (1) may not be brought until the expiration of the 6-month period after the claim has been presented in writing to the agency owning or operating the vessel causing the injury or damage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a0add0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1509"},"text":"120 Stat. 1509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a0add1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a0add2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a0add3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30101","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:740.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-19/ch526"},"text":"June 19, 1948, ch. 526","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/496"},"text":"62 Stat. 496","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the words “civil action” are substituted for “suit” for consistency with rule 2 of the Federal Rules of Civil Procedure (28 App. U.S.C.).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “for all causes of action arising after ","children":[{"tag":"date","attrib":{"date":"1948-06-19"},"text":"June 19, 1948","children":[],"tail":", and for all causes of action where suit has not been hitherto filed under the Federal Tort Claims Act” are omitted as obsolete."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6a0add4-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf6a0add5-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 30101, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s102/c"},"text":"Pub. L. 100–710, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4738"},"text":"102 Stat. 4738","children":[],"tail":", provided definitions for purposes of this subtitle, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/b"},"text":"Pub. L. 109–304, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1509"},"text":"120 Stat. 1509","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idf6a0add6-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section is popularly known as the Admiralty Extension Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
