{"tag":"section","attrib":{"id":"idf6f1b28f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57104"},"text":null,"children":[{"tag":"num","attrib":{"value":"57104"},"text":"§ 57104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition of vessels from sale of obsolete vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f1b290-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may acquire suitable documented vessels with amounts in the Vessel Operations Revolving Fund derived from the sale of obsolete vessels in the National Defense Reserve Fleet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b291-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Valuation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The acquired and obsolete vessels shall be valued at their scrap value in domestic or foreign markets as of the date of the acquisition for or sale from the Fleet. However, the value assigned to those vessels shall be determined on the same basis, with consideration given to the fair value of the cost of moving the vessel sold from the Fleet to the place of scrapping.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b292-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs Incident to Lay-Up","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Costs incident to the lay-up of the vessel acquired under this section may be paid from amounts in the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b293-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers to Non-Citizens","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel sold from the Fleet under this section may be scrapped in an approved foreign market without obtaining additional separate approval from the Secretary to transfer the vessel to a person not a citizen of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b294-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1660"},"text":"120 Stat. 1660","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b295-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f1b296-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f1b297-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"57104","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1160(i).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title V, § 510(i), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/86/575"},"text":"Pub. L. 86–575","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 5, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/312"},"text":"74 Stat. 312","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/89/254/s1"},"text":"Pub. L. 89–254, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/980"},"text":"79 Stat. 980","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/469/s13"},"text":"Pub. L. 91–469, § 13","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1022"},"text":"84 Stat. 1022","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/93/605/s1"},"text":"Pub. L. 93–605, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1965"},"text":"88 Stat. 1965","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/95/177"},"text":"Pub. L. 95–177","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 15, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1368"},"text":"91 Stat. 1368","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/91"},"text":"Pub. L. 97–31, § 12(91)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/161"},"text":"95 Stat. 161","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/595/tVII/s704"},"text":"Pub. L. 101–595, title VII, § 704","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/2994"},"text":"104 Stat. 2994","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “vessel sold from the Fleet” are substituted for “traded-out vessel” for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “without obtaining additional separate approval from the Secretary to transfer the vessel to a person not a citizen of the United States” are substituted for “Notwithstanding the provisions of sections 808 and 835 of this Appendix” for clarity and to avoid the cross references.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
