{"tag":"section","attrib":{"id":"idf6d04855-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202"},"text":null,"children":[{"tag":"num","attrib":{"value":"53202"},"text":"§ 53202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of the Cable Security Fleet","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d04856-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d04857-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, in consultation with the Operating Agency, shall establish a fleet of active, commercially viable, cable vessels to meet national security requirements. The fleet shall consist of privately owned, United States-documented cable vessels for which there are in effect Operating Agreements under this chapter, and shall be known as the Cable Security Fleet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b958-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Fleet described under this section shall include two vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b959-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A cable vessel is eligible to be included in the Fleet if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b95a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel meets the requirements of paragraph (1), (2), (3), or (4) of subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b95b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is operated (or in the case of a vessel to be constructed, will be operated) in commercial service providing cable services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b95c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is 40 years of age or less on the date the vessel is included in the Fleet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b95d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the vessel is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d2b95e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the Operating Agency to be suitable for engaging in cable services by the United States in the interest of national security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d2b95f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the Secretary to be commercially viable, whether independently or taking any payments which are the consequence of participation in the Cable Fleet into account; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b960-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d2b961-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a United States-documented vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d2b962-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is not a United States-documented vessel, but—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6d2b963-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner of the vessel has demonstrated an intent to have the vessel documented under chapter 121 of this title if it is included in the Cable Fleet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6d2b964-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time an Operating Agreement is entered into under this chapter, the vessel is eligible for documentation under chapter 121 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b965-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements Regarding Citizenship of Owners and Operators.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b966-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessels owned and operated by section 50501 citizens","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel meets the requirements of this paragraph if, during the period of an Operating Agreement under this chapter that applies to the vessel, the vessel will be owned and operated by one or more persons that are citizens of the United states ","children":[{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002037"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b967-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessels owned by a section 50501 citizen, or united states citizen trust, and chartered to a documentation citizen","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel meets the requirements of this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d2b968-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during the period of an Operating Agreement under this chapter that applies to the vessel, the vessel will be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6d2b969-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by a person that is a citizen of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":" or that is a United States citizen trust; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6d2b96a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demise chartered to and operated by a person—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6d2b96b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is eligible to document the vessel under chapter 121 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6d2b96c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairman of the board of directors, chief executive officer, and a majority of the members of the board of directors of which are citizens of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":", and are appointed and subject to removal only upon approval by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6d2b96d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that certifies to the Secretary that there are no treaties, statutes, regulations, or other laws that would prohibit the Contractor for the vessel from performing its obligations under an Operating Agreement under this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d2b96e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a vessel that will be demise chartered to a person that is owned or controlled by another person that is not a citizen of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":", the other person enters into an agreement with the Secretary not to influence the operation of the vessel in a manner that will adversely affect the interests of the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d2b96f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary and the Operating Agency notify the Committee on Armed Services and the Committee on Commerce, Science and Transportation of the Senate, and the Committee on Armed Services of the House of Representatives that they concur, and have reviewed the certification required under subparagraph (A)(ii)(III) and determined that there are no legal, operational, or other impediments that would prohibit the Contractor for the vessel from performing its obligations under an Operating Agreement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b970-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel owned and operated by a defense contractor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel meets the requirements of this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d2b971-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during the period of an Operating Agreement under this chapter that applies to the vessel, the vessel will be owned and operated by a person that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6d2b972-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to document a vessel under chapter 121 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6d2b973-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates or manages other United States-documented vessels for the Secretary of Defense, or charters other vessels to the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6d2b974-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has entered into a special security agreement for purposes of this paragraph with the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6d2b975-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes the certification described in paragraph (2)(A)(ii)(III); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6d2b976-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a vessel described in paragraph (2)(B), enters into an agreement referred to in that paragraph; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d2b977-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary and the Secretary of Defense notify the Committee on Armed Services and Committee on Commerce, Science, and Transportation of the Senate and the Committee on Armed Services of the House of Representatives that they have reviewed the certification required by subparagraph (A)(iv) and determined that there are no other legal, operational, or other impediments that would prohibit the Contractor for the vessel from performing its obligations under an Operating Agreement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b978-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel owned by a documentation citizen and chartered to a section 50501 citizen","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel meets the requirements of this paragraph if, during the period of an Operating Agreement under this chapter that applies to the vessel, the vessel will be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d2b979-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by a person that is eligible to document a vessel under chapter 121 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d2b97a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demise chartered to a person that is a citizen of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b97b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel Standards","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b97c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certificate of inspection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A cable vessel which the Secretary of the Department in which the Coast Guard is operating determines meets the criteria of subsection (b) of this section but which, on the date of enactment of the Act, is not documented under chapter 121 of this title, shall be eligible for a certificate of inspection if that Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d2b97d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is classed by, and designed in accordance with the rules of, the American Bureau of Shipping, or another classification society accepted by that Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d2b97e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel complies with applicable international agreements and associated guidelines, as determined by the country in which the vessel was documented immediately before becoming documented under chapter 121; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d2b97f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that country has not been identified by that Secretary as inadequately enforcing international vessel regulations as to that vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b980-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continued eligibility for certificate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) does not apply to a vessel after any date on which the vessel fails to comply with the applicable international agreements and associated guidelines referred to in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b981-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reliance on classification society.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d2b982-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Department in which the Coast Guard is operating may rely on a certification from the American Bureau of Shipping or, subject to subparagraph (B), another classification society accepted by that Secretary to establish that a vessel is in compliance with the requirements of paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d2b983-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign classification society","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Department in which the Coast Guard is operating may accept certification from a foreign classification society under subparagraph (A) only—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6d2b984-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that the government of the foreign country in which the society is headquartered provides access on a reciprocal basis to the American Bureau of Shipping; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6d2b985-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the foreign classification society has offices and maintains records in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b986-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Age Registration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in conjunction with the Operating Agency, may waive the application of the age restriction under subsection (b)(3) if they jointly determine that the waiver—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b987-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the national interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b988-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the subject cable vessel and any associated operating network is and will continue to be economically viable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b989-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53202/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary due to the lack of availability of other vessels and operators that comply with the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d2b98a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3521/a"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1989"},"text":"133 Stat. 1989","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d2b98b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6d2b98c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6d2b98d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Act, referred to in subsec. (d)(1), means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
