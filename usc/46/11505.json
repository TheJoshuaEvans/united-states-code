{"tag":"section","attrib":{"id":"idf6925544-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11505"},"text":null,"children":[{"tag":"num","attrib":{"value":"11505"},"text":"§ 11505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of forfeitures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6925545-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Money, property, and wages forfeited under this chapter for desertion may be applied to compensate the owner or master of the vessel for expenses caused by the desertion. The balance shall be transferred to the appropriate district court of the United States when the voyage is completed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6925546-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If it appears to the district court that the forfeiture was imposed properly, the property transferred may be sold in the same manner prescribed for the disposition of the property of deceased seamen. The court shall deposit in the Treasury as miscellaneous receipts the proceeds of the sale and any money and wages transferred to the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6925547-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When an owner or master fails to transfer the balance as required under subsection (a) of this section, the owner or master is liable to the United States Government for a civil penalty of 2 times the amount of the balance, recoverable by the Secretary in the same manner that seaman’s wages are recovered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6925548-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In all other cases of forfeiture of wages, the forfeiture shall be for the benefit of the owner of the vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6925549-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/584"},"text":"97 Stat. 584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/206/tIV/s421"},"text":"Pub. L. 103–206, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2438"},"text":"107 Stat. 2438","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf692554a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf692554b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf692554c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"11505","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:706","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 11505 provides for the disposal of wages forfeited by deserting seamen.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf692554d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf692554e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/s421/1"},"text":"Pub. L. 103–206, § 421(1)","children":[],"tail":", substituted “The balance shall be transferred to the appropriate district court of the United States when the voyage is completed.” for “The balance shall be transferred to the Secretary when the voyage is completed, as prescribed by the Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/s421/2"},"text":"Pub. L. 103–206, § 421(2)","children":[],"tail":", struck out at beginning “Within one month of receiving the balance under subsection (a) of this section, the Secretary shall transfer the balance to the appropriate district court of the United States.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
