{"tag":"section","attrib":{"id":"idf67f42b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7704"},"text":null,"children":[{"tag":"num","attrib":{"value":"7704"},"text":"§ 7704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dangerous drugs as grounds for revocation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf67f42b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If it is shown at a hearing under this chapter that a holder of a license, certificate of registry, or merchant mariner’s document issued under this part, within 10 years before the beginning of the proceedings, has been convicted of violating a dangerous drug law of the United States or of a State, the license, certificate, or document shall be suspended or revoked.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67f42b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If it is shown that a holder has been a user of, or addicted to, a dangerous drug, the license, certificate of registry, or merchant mariner’s document shall be revoked unless the holder provides satisfactory proof that the holder is cured.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67f42b4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/546"},"text":"97 Stat. 546","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/36/s1/a/9/F"},"text":"Pub. L. 99–36, § 1(a)(9)(F)","children":[],"tail":", (G), "},{"tag":"date","attrib":{"date":"1985-05-15"},"text":"May 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/68"},"text":"99 Stat. 68","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV/s4103/a/2/B"},"text":"Pub. L. 101–380, title IV, § 4103(a)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/511"},"text":"104 Stat. 511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tIV/s402"},"text":"Pub. L. 108–293, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1043"},"text":"118 Stat. 1043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3545/b"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3545(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2326"},"text":"132 Stat. 2326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67f42b5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf67f42b6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf67f42b7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7704(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:239a(a)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7704(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:239b(b)(1)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7704(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:239b(b)(2)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7704 requires the Secretary to revoke the license, certificate, or document of any individual who has been convicted of a dangerous drug law within 10 years before the beginning of the suspension or revocation procedures. This section has expanded current law to incorporate violations involving “controlled substances” which are not narcotic. This includes PCP and LSD. Unless it can be done under existing law, the suspension or revocation of an individual’s license based on the use of a “controlled substance” only applies to the use or conviction after the date of enactment of this Act.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section also provides that anyone who has been a user of or addicted to a dangerous drug since ","children":[{"tag":"date","attrib":{"date":"1954-07-14"},"text":"July 14, 1954","children":[],"tail":", may be subjected to revocation procedures unless the individual provides satisfactory proof of being cured."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In sections 7503(b)(2) and 7704(c), the term “use”, when applying to “narcotic drugs” or “controlled substances”, is not intended to include the use of “off the shelf” drugs or drugs acquired with a prescription lawfully issued by a medical doctor, as long as the drugs are used by the individual in the recommended amounts and the drugs will not impair the individual’s ability to perform duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf67f42b8-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf67f42b9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" redesignated subsecs. (b) and (c) as (a) and (b), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" inserted “suspended or” after “shall be”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" struck out subsec. (a) which defined “dangerous drug” for purpose of this section as narcotic drug, controlled substance, and marihuana."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/36/s1/a/9/F"},"text":"Pub. L. 99–36, § 1(a)(9)(F)","children":[],"tail":", substituted “merchant mariner’s document” for first reference to “document”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/36/s1/a/9/G"},"text":"Pub. L. 99–36, § 1(a)(9)(G)","children":[],"tail":", substituted “certificate of registry, or merchant mariner’s document” for “certificate, or document”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf67f42ba-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf67f42bb-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" applicable to incidents occurring after "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/s1020"},"text":"section 1020 of Pub. L. 101–380","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
