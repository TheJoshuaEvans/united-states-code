{"tag":"section","attrib":{"id":"idf6e0e9e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53723"},"text":null,"children":[{"tag":"num","attrib":{"value":"53723"},"text":"§ 53723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments by Secretary or Administrator and issuance of obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e0e9ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cash Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts required to be paid by the Secretary or Administrator under section 53721 or 53722 of this title shall be paid in cash.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0e9eb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance of Obligations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If amounts in the appropriate account under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53717"},"text":"section 53717 of this title","children":[],"tail":" are not sufficient to make a payment required under section 53721 or 53722 of this title, the Secretary or Administrator may issue obligations to the Secretary of the Treasury. The Secretary or Administrator, with the approval of the Secretary of the Treasury, shall prescribe the form, denomination, maturity, and other terms (except the interest rate) of the obligations. The Secretary of the Treasury shall set the interest rate for the obligations, considering the current average market yield on outstanding marketable obligations of the United States Government of comparable maturities during the month before the obligations are issued."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0e9ec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purchase of Obligations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury shall purchase the obligations issued under this section. To purchase the obligations, the Secretary of the Treasury may use as a public debt transaction the proceeds from the sale of securities issued under chapter 31 of title 31. The purposes for which securities may be issued under that chapter are extended to include the purchase of obligations under this subsection. The Secretary of the Treasury may sell obligations purchased under this section. A redemption, purchase, or sale of the obligations by the Secretary of the Treasury is a public debt transaction of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0e9ed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53723/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposits and Redemptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator shall deposit amounts borrowed under this section in the appropriate account under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53717"},"text":"section 53717 of this title","children":[],"tail":" and make redemptions of the obligations from that account."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e0e9ee-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1618"},"text":"120 Stat. 1618","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/G"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/10/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(10)(B)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e0e9ef-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e0e9f0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e0e9f1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"H