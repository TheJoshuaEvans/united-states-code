:", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/166"},"text":"95 Stat. 166","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/35/tXVI/s1606/e"},"text":"Pub. L. 97–35, title XVI, § 1606(e)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/752"},"text":"95 Stat. 752","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (d), the words “appropriate account under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53717"},"text":"section 53717 of this title","children":[],"tail":"” are substituted for “Federal Ship Financing Fund” because the accounts under section 53717 replace the Federal Ship Financing Fund. See the explanation for section 53717."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6e0e9f2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6e0e9f3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/G"},"text":"Pub. L. 109–163, § 3507(a)(1)(G)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/a/10/B"},"text":"Pub. L. 110–181, § 3522(a)(10)(B)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/G"},"text":"Pub. L. 109–163, § 3507(a)(1)(G)","children":[],"tail":", into this section by inserting “or Administrator” after “Secretary” in section catchline and wherever appearing in text, except when followed by “of the Treasury”. See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/G"},"text":"Pub. L. 109–163, § 3507(a)(1)(G)","children":[],"tail":", which directed the amendment of section 1275(d) of the former Appendix to this title from which this section was derived, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":". See 2008 Amendment note for subsecs. (a), (b), (d) and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
