{"tag":"section","attrib":{"id":"idf67cd126-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510"},"text":null,"children":[{"tag":"num","attrib":{"value":"7510"},"text":"§ 7510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examinations for merchant mariner credentials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf67cd127-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure Not Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary is not required to disclose to the public—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67cd128-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a question from any examination for a merchant mariner credential;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd129-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the answer to such a question, including any correct or incorrect answer that may be presented with such question; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd12a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any quality or characteristic of such a question, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf67cd12b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which such question has been, is, or may be selected for an examination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67cd12c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency of such selection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67cd12d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency that an examinee correctly or incorrectly answered such question.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd12e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Certain Questions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a), the Secretary may, for the purpose of preparation by the general public for examinations required for merchant mariner credentials, release an examination question and answer that the Secretary has retired or is not presently on or part of an examination, or that the Secretary determines is appropriate for release.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd12f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Working group.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67cd130-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of the enactment of the Coast Guard Authorization Act of 2025, and once every two years thereafter, the Commandant shall commission a working group to review questions, content, and relevancy of examinations required for merchant mariner credentials, composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf67cd131-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 subject matter expert from the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67cd132-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" representatives from training facilities and the maritime industry, of whom—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf67cd133-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-half shall be representatives from approved training facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf67cd134-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-half shall be representatives from the appropriate maritime industry;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67cd135-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 representative from the National Merchant Marine Personnel Advisory Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67cd136-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 2 representatives from the State maritime academies, of whom one shall be a representative from the deck training track and one shall be a representative of the engineer license track;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67cd137-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 2 individuals that have taken and passed the examination in the 5 years before the commissioning of the working group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67cd138-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 representative from the United States Merchant Marine Academy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67cd139-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from other Coast Guard Federal advisory committees, as appropriate, for the industry segment associated with the subject examinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67cd13a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 subject matter expert from the Maritime Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67cd13b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 human performance technology representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd13c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion of persons knowledgeable about examination type","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The working group shall include representatives knowledgeable about the examination type under review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd13d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meeting of working group.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf67cd13e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall convene the working group annually or at the creation of new examination questions, whichever occurs sooner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67cd13f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remote participation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall allow any member of the working group to participate remotely if the member of the working group does not have the means to participate in person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd140-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of questions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may not use questions developed for use in the Merchant Mariner Credentialing Examination until such questions are reviewed and approved by the working group.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd141-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf67cd142-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 270 days after the date of the enactment of the Coast Guard Authorization Act of 2025, the Commandant shall convene the working group to complete a baseline review of the Coast Guard’s Merchant Mariner Credentialing Examination, including review of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf67cd143-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" industry standards, practices, and technology to be considered in the Merchant Mariner Credentialing Examination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf67cd144-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accuracy of examination questions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf67cd145-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accuracy and availability of examination references;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf67cd146-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of merchant mariner examinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf67cd147-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/5/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevancy of examination topics and contents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf67cd148-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/5/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any redundancy of core competencies between the Merchant Mariner Credentialing Examination and Standards of Training, Certification, and Watchingkeeping competencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf67cd149-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/5/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of standard technologies in administering, scoring, and analyzing the examinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67cd14a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to commandant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon completion of the review under this paragraph, a report shall be provided to the Commandant which shall include findings of the review with recommendations for updates to the Merchant Marine Credentialling Examination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd14b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nondisclosure agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require all members of the working group to sign a nondisclosure agreement with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd14c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of members as federal employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the working group who is not a Federal Government employee shall not be considered a Federal employee in the service or the employment of the Federal Government, except that such a member shall be considered a special government employee, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s202/a"},"text":"section 202(a) of title 18","children":[],"tail":" for purposes of sections 203, 205, 207, 208, and 209 of such title and shall be subject to any administrative standards of conduct applicable to an employee of the department in which the Coast Guard is operating."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd14d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chapter ","children":[],"tail":"10"},{"tag":"inline","attrib":{},"text":" of title ","children":[],"tail":"5.—"}],"tail":null},{"tag":"content","attrib":{},"text":"Chapter 10 of title 5 shall not apply to any working group created under this section to review the Coast Guard’s merchant mariner credentialing examinations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd14e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7510/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Merchant Mariner Credential Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “merchant mariner credential” means a merchant mariner license, certificate, or document that the Secretary is authorized to issue pursuant to this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67cd14f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s315/a/1"},"text":"Pub. L. 114–120, title III, § 315(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/60"},"text":"130 Stat. 60","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3503/a"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3503(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2775"},"text":"130 Stat. 2775","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3541/b/12"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3541(b)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2323"},"text":"132 Stat. 2323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVI/s601/c/3/B"},"text":"Pub. L. 115–282, title VI, § 601(c)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4289"},"text":"132 Stat. 4289","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(b)(7), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4751"},"text":"134 Stat. 4751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/290"},"text":"Pub. L. 117–286, § 4(a)(290)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4337"},"text":"136 Stat. 4337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/g/2"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1755"},"text":"139 Stat. 1755","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67cd150-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf67cd151-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf67cd152-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Coast Guard Authorization Act of 2025, referred to in subsec. (c)(1), (5)(A), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf67cd153-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/2/A"},"text":"Pub. L. 119–60, § 7301(g)(2)(A)","children":[],"tail":", substituted “Working Group” for “Exam Review” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/2/B/i"},"text":"Pub. L. 119–60, § 7301(g)(2)(B)(i)","children":[],"tail":"–(iii), substituted “180 days” for “90 days”, “Coast Guard Authorization Act of 2025” for “Coast Guard Authorization Act of 2016”, and “questions, content, and relevancy of” for “new questions for inclusion in” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(E) to (I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/2/B/iv"},"text":"Pub. L. 119–60, § 7301(g)(2)(B)(iv)","children":[],"tail":", (v), added subpars. (E) and (F) and redesignated former subpars. (E) to (G) as (G) to (I), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/2/D"},"text":"Pub. L. 119–60, § 7301(g)(2)(D)","children":[],"tail":", (F), added par. (3) and struck out former par. (3). Prior to amendment, text read as follows: “The requirement to convene a working group under paragraph (1) does not apply unless there are new examination questions to review.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/2/F"},"text":"Pub. L. 119–60, § 7301(g)(2)(F)","children":[],"tail":", added par. (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/2/C/i"},"text":"Pub. L. 119–60, § 7301(g)(2)(C)(i)","children":[],"tail":", substituted “Review” for “Baseline review” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/2/C/ii/IV"},"text":"Pub. L. 119–60, § 7301(g)(2)(C)(ii)(IV)","children":[],"tail":"–(VII), added cl. (i), redesignated former cls. (i) to (iii) as (ii) to (iv), respectively, added cls. (v) and (vi), and redesignated former cl. (iv) as (vii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/2/C/ii/I"},"text":"Pub. L. 119–60, § 7301(g)(2)(C)(ii)(I)","children":[],"tail":"–(III), substituted “Not later than 270 days” for “Within 1 year”, “Coast Guard Authorization Act of 2025” for “Coast Guard Authorization Act of 2016”, and “Commandant” for “Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/2/C/iii"},"text":"Pub. L. 119–60, § 7301(g)(2)(C)(iii)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B). Prior to amendment, text read as follows: “The Coast Guard shall provide a progress report to the appropriate congressional committees on the review under this paragraph.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/2/D"},"text":"Pub. L. 119–60, § 7301(g)(2)(D)","children":[],"tail":", (E), redesignated par. (4) as (5) and struck out par. (5). Text read as follows: “The Coast Guard may convene the working group without all members present if any non-Coast-Guard representative is present.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/2/D"},"text":"Pub. L. 119–60, § 7301(g)(2)(D)","children":[],"tail":", (E), redesignated par. (9) as (8) and struck out par. (8). Text read as follows: “The Secretary shall ensure that the Coast Guard Performance Technology Center—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) prioritizes the review of examinations required for merchant mariner credentials; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) not later than 3 years after the date of enactment of the Coast Guard Authorization Act of 2016, completes a formal review, including an appropriate analysis, of the topics and testing methodology employed by the National Maritime Center for merchant mariner licensing.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7301/g/2/E"},"text":"Pub. L. 119–60, § 7301(g)(2)(E)","children":[],"tail":", redesignated par. (9) as (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of title 5” for “FACA” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (c)(8)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/b/7/A"},"text":"Pub. L. 116–283, § 8505(b)(7)(A)","children":[],"tail":", substituted “merchant mariner” for “merchant seamen”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/b/7/B"},"text":"Pub. L. 116–283, § 8505(b)(7)(B)","children":[],"tail":", substituted “merchant mariner license” for “merchant seaman license”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “Commandant” for “Commandant of the Coast Guard” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" inserted “National” before “Merchant Marine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3503/a"},"text":"Pub. L. 114–328, § 3503(a)","children":[],"tail":", in introductory provisions, substituted “Coast Guard Authorization Act of 2016” for “Coast Guard Authorization Act of 2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3503/b/1/A"},"text":"Pub. L. 114–328, § 3503(b)(1)(A)","children":[],"tail":", substituted “engineer” for “engine”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4)(A), (8)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3503/a"},"text":"Pub. L. 114–328, § 3503(a)","children":[],"tail":", substituted “Coast Guard Authorization Act of 2016” for “Coast Guard Authorization Act of 2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3503/b/1/B"},"text":"Pub. L. 114–328, § 3503(b)(1)(B)","children":[],"tail":", inserted a period after “App”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf67f4254-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf67f4255-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" effective as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3503/e"},"text":"section 3503(e) of Pub. L. 114–328","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2182"},"text":"section 2182 of Title 14","children":[],"tail":", Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf67f4256-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Disclosure to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s315/c"},"text":"Pub. L. 114–120, title III, § 315(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/62"},"text":"130 Stat. 62","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/120/tIII/s315/c"},"text":"“Nothing in this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7116"},"text":"section 7116 of this title","children":[],"tail":"] may be construed to authorize the withholding of information from an appropriate inspector general, the Committee on Commerce, Science, and Transportation of the Senate, or the Committee on Transportation and Infrastructure of the House of Representatives.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
