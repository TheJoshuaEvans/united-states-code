{"tag":"section","attrib":{"id":"idf6e81653-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55111"},"text":null,"children":[{"tag":"num","attrib":{"value":"55111"},"text":"§ 55111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Towing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e81654-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except when towing a vessel in distress, a vessel may not do any part of any towing described in subsection (b) unless the towing vessel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e81655-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is wholly owned by citizens of the United States for purposes of engaging in the coastwise trade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81656-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been issued a certificate of documentation with a coastwise endorsement under chapter 121 of this title or is exempt from documentation but would otherwise be eligible for such a certificate and endorsement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e81657-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable Towing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) applies to the towing of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e81658-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel between ports or places in the United States to which the coastwise laws apply, either directly or via a foreign port or place;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81659-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel from point to point within the harbors of ports or places to which the coastwise laws apply; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e8165a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55111/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel transporting valueless material or dredged material, regardless of whether it has commercial value, from a point in the United States or on the high seas within the exclusive economic zone, to another point in the United States or on the high seas within the exclusive economic zone.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e8165b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e8165c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Owner and master","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The owner and master of a vessel towing another vessel in violation of this section are each liable for a penalty of at least $350 but not more than $1,100. A penalty under this paragraph constitutes a lien on the vessel. The lien is enforceable in a district court of the United States for any district in which the vessel is found. Clearance may not be granted to the vessel until the penalties have been paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e8165d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to the penalties under paragraph (1), the towing vessel is liable for a penalty of $60 per ton based on the tonnage of each towed vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e8165e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1637"},"text":"120 Stat. 1637","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e8165f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e81660-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e81661-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55111","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:316(a), (b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 4370; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1940-06-11/ch324"},"text":"June 11, 1940, ch. 324","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/54/304"},"text":"54 Stat. 304","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/99/307/s10"},"text":"Pub. L. 99–307, § 10","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"May 19, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/447"},"text":"100 Stat. 447","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/100/329/s2"},"text":"Pub. L. 100–329, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"June 7, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/589"},"text":"102 Stat. 589","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/324/tXI/s1115/b/3"},"text":"Pub. L. 104–324, title XI, § 1115(b)(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3972"},"text":"110 Stat. 3972","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “or to do any part of such towing” and “other than a vessel in distress” in the source provision are made applicable to all the towing described in subsection (b) for clarity and consistency. In paragraph (1), the words “wholly owned by citizens of the United States for purposes of engaging in the coastwise trade” are substituted for “wholly owned by a person who is a citizen of the United States within the meaning of the laws respecting the documentation of vessels” for consistency in this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(2) is substituted for “having in force a certificate of documentation issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12106"},"text":"section 12106 of title 46","children":[],"tail":"” for consistency in this chapter and with section 12102(b) as revised by the bill."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “in the United States to which the coastwise laws apply” are substituted for “in the United States, its Territories or possessions, embraced within the coastwise laws of the United States” because of the definition of “United States” in chapter 1 of the revised title and because of section 55101 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the words “or place” are omitted as surplus. The words “as defined in the Presidential Proclamation of ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"March 10, 1983","children":[],"tail":"” are omitted because “exclusive economic zone” is defined in chapter 1 of the revised title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the penalty amounts reflect the adjustment for inflation pursuant to the Federal Civil Penalties Inflation Adjustment Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2461"},"text":"28 U.S.C. 2461","children":[],"tail":" note). See 19 C.F.R. § 4.92 (2004). In paragraph (2), the words “which sum may be recovered by way of libel or suit” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of 46 App. U.S.C. 316(b) is omitted as unnecessary because of the definition of “person” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6e81662-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6e81663-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Nonapplicability of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/329"},"text":"Pub. L. 100–329","children":[],"tail":" to Certain Vessel"}],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/329"},"text":"Pub. L. 100–329","children":[],"tail":" to section 316 of the former Appendix to this title, from which this section was derived, not applicable to a vessel engaged in the transportation of valueless material or valueless dredged material and owned or chartered by a corporation that had on file with Secretary of Transportation on "},{"tag":"date","attrib":{"date":"1989-08-01"},"text":"Aug. 1, 1989","children":[],"tail":", the certificate specified in section 883–1 of the former Appendix to this title (now "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12118"},"text":"section 12118 of this title","children":[],"tail":"), see "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/s5501/c"},"text":"section 5501(c) of Pub. L. 102–587","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s55110"},"text":"section 55110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
