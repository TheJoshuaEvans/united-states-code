{"tag":"section","attrib":{"id":"idf6fb29a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70041"},"text":null,"children":[{"tag":"num","attrib":{"value":"70041"},"text":"§ 70041.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regattas and marine parades","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6fb29aa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70041/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant of the Coast Guard may issue regulations to promote the safety of life on navigable waters during regattas or marine parades.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb29ab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70041/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail and Use of Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To enforce regulations issued under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb29ac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70041/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant may detail any public vessel in the service of the Coast Guard and make use of any private vessel tendered gratuitously for that purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb29ad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70041/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the request of the Commandant, the head of any other Federal department or agency may enforce the regulations by means of any public vessel of such department and any private vessel tendered gratuitously for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb29ae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70041/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority of the Commandant under this section may be transferred by the President for any special occasion to the head of another Federal department or agency whenever in the President’s judgment such transfer is desirable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb29af-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70041/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb29b0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70041/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any violation of regulations issued pursuant to this section the following penalties shall be incurred:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6fb29b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70041/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A licensed officer shall be liable to suspension or revocation of license in the manner prescribed by law for incompetency or misconduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6fb29b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70041/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person in charge of the navigation of a vessel other than a licensed officer shall be liable to a penalty of $5,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6fb29b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70041/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner of a vessel (including any corporate officer of a corporation owning the vessel) actually on board shall be liable to a penalty of $5,000, unless the violation of regulations occurred without the owner’s knowledge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6fb29b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70041/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other person shall be liable to a penalty of $2,500.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb29b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70041/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mitigation or remission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant may mitigate or remit any penalty provided for in this subsection in the manner prescribed by law for the mitigation or remission of penalties for violation of the navigation laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6fb29b6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIV/s406/a"},"text":"Pub. L. 115–282, title IV, § 406(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4265"},"text":"132 Stat. 4265","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
