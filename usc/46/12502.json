{"tag":"section","attrib":{"id":"idf69980db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12502"},"text":null,"children":[{"tag":"num","attrib":{"value":"12502"},"text":"§ 12502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification numbers, signal letters, and markings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf69980dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the identification of a vessel of the United States, the Secretary of Transportation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf69980dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall maintain a unique numbering system and assign a number to each vessel of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69980de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may maintain a system of signal letters for a documented vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69980df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall record a name selected by the owner of a documented vessel approved by the Secretary as the vessel’s name of record; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69980e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12502/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may establish other identification markings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69980e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manufacturer or owner of a vessel shall affix to the vessel and maintain in the manner prescribed by the Secretary the number assigned and any other markings the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69980e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Once a number is assigned under this section, it may not be used by another vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69980e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Once a documented vessel’s name is established, the name may not be changed without the approval of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69980e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person may not tamper with or falsify a number or other marking required under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf69980e5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s101/a"},"text":"Pub. L. 100–710, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4736"},"text":"102 Stat. 4736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69980e6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69980e7-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 12502","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) of this section requires the Secretary to maintain a unique numbering system for vessels of the United States. The Secretary may use existing vessel numbering systems such as the hull identification number for this purpose, but must ensure that no two existing vessels of the United States have the same number. The Secretary should consider and propose the use of a 17-digit number to implement this requirement. This subsection also requires the Secretary to maintain a system of signal letters and to record vessel names for documented vessels. The Secretary is authorized to establish other vessel identification markings for vessels of the United States, such as hailing ports.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsections (b), (c), (d), and (e) contain other requirements and restrictions concerning vessel identification markings.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section consolidates the requirements of sections 12114, 12115, 12116, and 12118 of title 46. For this reason, section 106 of this bill repeals those sections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf69980e8-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf69980e9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/710/s107"},"text":"section 107 of Pub. L. 100–710","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s31301"},"text":"section 31301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf69980ea-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Vessels Not Having Unique Number; Applicability of Provisions for Number Assignment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s104/f"},"text":"Pub. L. 100–710, title I, § 104(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4751"},"text":"102 Stat. 4751","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/710/tI/s104/f"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12502/a/1"},"text":"Section 12502(a)(1) of title 46","children":[],"tail":", United States Code (as enacted by section 101 of this Act), applies to a vessel of the United States that does not have a unique number as prescribed by the Secretary of Transportation under that section until the earlier of the following:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the next time the vessel is documented, numbered, or titled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
