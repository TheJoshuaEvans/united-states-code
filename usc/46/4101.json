{"tag":"section","attrib":{"id":"idf66e78b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4101"},"text":null,"children":[{"tag":"num","attrib":{"value":"4101"},"text":"§ 4101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"This chapter applies to an uninspected vessel not subject to chapter 45 of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf66e78b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the navigable waters of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66e78b6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned in the United States and operating on the high seas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf66e78b7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/528"},"text":"97 Stat. 528","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/424/s8/b"},"text":"Pub. L. 100–424, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1593"},"text":"102 Stat. 1593","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf66e78b8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"histo