{"tag":"section","attrib":{"id":"idf69e3b72-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14502"},"text":null,"children":[{"tag":"num","attrib":{"value":"14502"},"text":"§ 14502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measurement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall measure a vessel to which this chapter applies in the way provided by this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf69e3b73-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5101/3"},"text":"Pub. L. 99–509, title V, § 5101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1923"},"text":"100 Stat. 1923","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69e3b74-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69e3b75-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 14502","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Source: Section (U.S. Code) 46 App. U.S.C. 71, 77, 83.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 14502 requires the Secretary to measure a vessel to which this chapter applies as provided by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
