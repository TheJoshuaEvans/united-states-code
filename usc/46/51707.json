{"tag":"section","attrib":{"id":"idf6c91ccf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51707"},"text":null,"children":[{"tag":"num","attrib":{"value":"51707"},"text":"§ 51707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merchant mariner recruitment, training, and retention strategic plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c91cd0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002034"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002034"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":null},{"tag":"inline","attrib":{},"text":null,"children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" "},{"tag":"inline","attrib":{},"text":"Strategic Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c91cd1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51707/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this section, and at least once every five years thereafter until the termination date under paragraph (6), the Secretary of Transportation, acting through the Administrator of the Maritime Administration, shall publish in the Federal Register a plan to recruit, train, and retain merchant mariners for the five-year period following the date of publication of the most recently published plan under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91cd2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51707/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A plan published under paragraph (1) shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c91cd3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51707/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategy to address merchant mariner recruitment, training, and retention issues in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c91cd4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51707/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstration and research priorities concerning merchant mariner recruitment, training, and retention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91cd5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51707/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing a plan under paragraph (1), the Secretary shall take into account, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c91cd6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51707/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of existing research (as of the date of publication of the plan); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c91cd7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51707/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need to ensure results that have broad applicability for the United States merchant marine workforce development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91cd8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51707/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing a plan under paragraph (1), the Secretary shall consult with representatives of the maritime industry, labor organizations, including the Commander of the Transportation Command and the Commander of the Military Sealift Command, and other governmental entities and stakeholders in the maritime industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91cd9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51707/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transmittal to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall transmit copies of any plan published under paragraph (1) to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91cda-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51707/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement to publish a plan under this paragraph shall terminate on the date that the Administrator of the Maritime Administration determines that there is an adequate number of United States mariners for sustained strategic sealift.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c91cdb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dC/tXXXV/s3508/a"},"text":"Pub. L. 116–283, div. C, title XXXV, § 3508(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4405"},"text":"134 Stat. 4405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c91cdc-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6c91cdd-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6c91cde-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (a)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
