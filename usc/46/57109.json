{"tag":"section","attrib":{"id":"idf6f1b2bc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57109"},"text":null,"children":[{"tag":"num","attrib":{"value":"57109"},"text":"§ 57109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of vessels purchased, chartered, or leased from Secretary of Transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Unless otherwise authorized by the Secretary of Transportation, a vessel purchased, chartered, or leased from the Secretary may be operated only under a certificate of documentation with a registry or coastwise endorsement. Such a vessel, while employed solely as a merchant vessel, is subject to the laws, regulations, and liabilities governing merchant vessels, whether the United States Government has an interest in the vessel as an owner or holds a mortgage, lien, or other interest.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6f1b2bd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1661"},"text":"120 Stat. 1661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b2be-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f1b2bf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f1b2c0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":nu