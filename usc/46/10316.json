{"tag":"section","attrib":{"id":"idf68b299d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10316"},"text":null,"children":[{"tag":"num","attrib":{"value":"10316"},"text":"§ 10316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trusts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Sections 10314 and 10315 of this title do not prevent an employer from making deductions from the wages of a seaman, with the written consent of the seaman, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68b299e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10316/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deductions are paid into a trust fund established only for the benefit of seamen employed by that employer, and the families and dependents of those seamen (or of those seamen, families, and dependents jointly with other seamen employed by other employers, and the families and dependents of the other seamen); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68b299f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10316/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the payments are held in trust to provide, from principal or interest, or both, any of the following benefits for those seamen and their families and dependents:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68b29a0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10316/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical or hospital care, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68b29a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10316/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pensions on retirement or death of the seaman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68b29a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10316/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" life insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68b29a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10316/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unemployment benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68b29a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10316/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for illness or injuries resulting from occupational activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68b29a5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10316/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sickness, accident, and disability compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68b29a6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10316/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing insurance to provide any of the benefits specified in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68b29a7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/568"},"text":"97 Stat. 568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68b29a8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68b29a9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68b29aa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10316","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:599(g)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10316 qualifies the two previous sections by allowing an employer to make deductions from seamen’s wages for the purpose of placing the wages into a trust fund or holding them in trust to provide for the seamen’s benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
