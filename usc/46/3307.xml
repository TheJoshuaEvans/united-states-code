<html:tr style="-uslm-lc:I01;"><html:td style=" text-align:justify; vertical-align:top; padding-right:2pt;"><html:p style=" text-align:justify; text-indent: -1em; padding-left:1em;" class="leaders"><html:span>3307(2)</html:span></html:p></html:td><html:td style=" text-align:left; vertical-align:top; padding-left: 2pt;"><html:p style=" text-align:left; text-indent: -1em; padding-left:1em; margin-bottom:0em;">46:390a(a)</html:p><html:p style=" text-align:left; text-indent: -1em; padding-left:1em; margin-top:0em;">46:404–1(6)(i)</html:p></html:td></html:tr>
<html:tr style="-uslm-lc:I01;"><html:td style=" text-align:justify; vertical-align:top; padding-right:2pt;"><html:p style=" text-align:justify; text-indent: -1em; padding-left:1em;" class="leaders"><html:span>3307(3)</html:span></html:p></html:td><html:td style=" text-align:left; vertical-align:top; padding-left: 2pt;"><html:p style=" text-align:left; text-indent: -1em; padding-left:1em; margin-bottom:0em;">46:391(b)</html:p><html:p style=" text-align:left; text-indent: -1em; padding-left:1em; margin-bottom:0em; margin-top:0em;">46:392(b)</html:p><html:p style=" text-align:left; text-indent: -1em; padding-left:1em; margin-top:0em;">46:404–1(6)(ii)</html:p></html:td></html:tr>
