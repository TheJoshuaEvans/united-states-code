{"tag":"section","attrib":{"id":"idf6735be4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4712"},"text":null,"children":[{"tag":"num","attrib":{"value":"4712"},"text":"§ 4712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory of abandoned vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6735be5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of the Coast Guard Authorization Act of 2025, the Commandant, in consultation with the Administrator of the National Oceanic and Atmospheric Administration and relevant State agencies, shall establish and maintain a national inventory of covered vessels that are abandoned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735be6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The inventory established and maintained under subsection (a) shall include data on each vessel, including geographic information system data related to the location of each such vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735be7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4712/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant shall make the inventory established under subsection (a) publicly available on a website of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735be8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4712/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting of Potentially Abandoned Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Commandant shall develop a process by which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735be9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4712/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, Indian Tribe, Native Hawaiian organization, or person may report a covered vessel that may be abandoned to the Commandant for potential inclusion in the inventory established under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735bea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4712/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commandant shall review any such report and add such vessel to the inventory if the Commandant determines that the reported vessel is abandoned pursuant to section 4711.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735beb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4712/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clarification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except in a response action carried out under section 311(j) of the Federal Water Pollution Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1321"},"text":"33 U.S.C. 1321","children":[],"tail":") or in the case of imminent threat to life and safety, the Commandant shall not be responsible for removing any covered vessels listed on the inventory established and maintained under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6735bec-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7347/a/3"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7347(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1780"},"text":"139 Stat. 1780","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6735bed-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6735bee-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6735bef-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Coast Guard Authorization Act of 2025, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
