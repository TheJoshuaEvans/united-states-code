{"tag":"section","attrib":{"id":"idf6c6d2ee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51505"},"text":null,"children":[{"tag":"num","attrib":{"value":"51505"},"text":"§ 51505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual payments for maintenance and support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c6d2ef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may make an agreement (effective for not more than 4 years) with the following academies to provide annual payments to those academies for their maintenance and support:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c6d2f0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One State maritime academy in each State that satisfies ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51506/a"},"text":"section 51506(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2f1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each regional maritime academy that satisfies ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51506/a"},"text":"section 51506(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d2f2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c6d2f3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), an annual payment to an academy under subsection (a) shall be at least equal to the amount given to the academy for its maintenance and support by the State in which it is located, or, for a regional maritime academy, by all States cooperating to sponsor the academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2f4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount under paragraph (1) may not be more than $25,000, unless the academy satisfies ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51506/b"},"text":"section 51506(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c6d2f5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1578"},"text":"120 Stat. 1578","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3502/a"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3547"},"text":"119 Stat. 3547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3523/a/3"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3523(a)(3)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/599"},"text":"122 Stat. 599","children":[],"tail":", 600; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3515/d"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3515(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2313"},"text":"132 Stat. 2313","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c6d2f6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6c6d2f7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6c6d2f8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"51505","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1295c(d)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XIII, § 1304(d)(1), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/96/453/s2"},"text":"Pub. L. 96–453, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2004"},"text":"94 Stat. 2004","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/115/s5"},"text":"Pub. L. 101–115, § 5","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1989","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/103/693"},"text":"103 Stat. 693","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the reference to territories is omitted as unnecessary because of the definition of “State” in chapter 1 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6c6d2f9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6c6d2fa-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" amended par. (2) generally. Prior to amendment, text read as follows: “The amount under paragraph (1) may not be more than $25,000. However, if the academy satisfies "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s51506/b"},"text":"section 51506(b) of this title","children":[],"tail":", the amount shall be—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $100,000 for a State maritime academy; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $300,000 for fiscal year 2006, $400,000 for fiscal year 2007, and $500,000 for fiscal year 2008 and each fiscal year thereafter for a regional maritime academy.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3523/b"},"text":"Pub. L. 110–181, § 3523(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3502/a"},"text":"Pub. L. 109–163, § 3502(a)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3523/a/3"},"text":"Pub. L. 110–181, § 3523(a)(3)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3502/a"},"text":"Pub. L. 109–163, § 3502(a)","children":[],"tail":", into this section by substituting “$300,000 for fiscal year 2006, $400,000 for fiscal year 2007, and $500,000 for fiscal year 2008 and each fiscal year thereafter” for “$200,000”. See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3502/a"},"text":"Pub. L. 109–163, § 3502(a)","children":[],"tail":", which directed the amendment of section 1295c(d)(1) of the former Appendix to this title from which this section was derived, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3523/b"},"text":"Pub. L. 110–181, § 3523(b)","children":[],"tail":". See 2008 Amendment note for subsec. (b)(2)(B) and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
