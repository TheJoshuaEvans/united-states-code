:{},"text":"46:239(k)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6305 requires the Secretary to prescribe regulations about the form and manner of reports of investigations of marine casualties. It also provides that the reports shall be available to the public, except for any information they contain related to national security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf678163b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf678163c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383"},"text":"Pub. L. 105–383","children":[],"tail":" substituted “. This subsection does not require the release of information described by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":" or protected from disclosure by another law of the United States.” for “, except to the extent that they contain information related to the national security.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
