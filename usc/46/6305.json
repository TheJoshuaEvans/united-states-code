{"tag":"section","attrib":{"id":"idf6781634-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s6305"},"text":null,"children":[{"tag":"num","attrib":{"value":"6305"},"text":"§ 6305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports of investigations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6781635-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s6305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe regulations about the form and manner of reports of investigations conducted under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6781636-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s6305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reports of investigations conducted under this part shall be made available to the public. This subsection does not require the release of information described by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":" or protected from disclosure by another law of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6781637-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/538"},"text":"97 Stat. 538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIII/s305"},"text":"Pub. L. 105–383, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"