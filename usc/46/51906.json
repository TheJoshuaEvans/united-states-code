{"tag":"section","attrib":{"id":"idf6c91d06-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51906"},"text":null,"children":[{"tag":"num","attrib":{"value":"51906"},"text":"§ 51906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special certificates for civilian service to armed forces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c91d07-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator may issue a special certificate to an individual, or the personal representative of an individual, in recognition of service of that individual in the merchant marine of the United States, if the service has been determined to be active duty under section 401 of the GI Bill Improvement Act of 1977 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/202"},"text":"Public Law 95–202","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s106"},"text":"38 U.S.C. 106","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c91d08-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Issuance of a certificate under subsection (a) does not entitle an individual to any rights, privileges, or benefits under a law of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c91d09-2930-11f1-96a8-b9bd2a0a99b5"},"text":