{"tag":"section","attrib":{"id":"idf6d2b9a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53205"},"text":null,"children":[{"tag":"num","attrib":{"value":"53205"},"text":"§ 53205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Obligations and rights under operating agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d2b9a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation of Vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Operating Agreement under this chapter shall require that, during the period the vessel is operating under the Agreement, the vessel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b9a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53205/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be operated in the trade for Cable Services, or under a charter to the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9aa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53205/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be documented under chapter 121 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9ab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Payments by the Secretary.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b9ac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53205/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An Operating Agreement under this chapter shall require, subject to the availability of appropriations, that the Secretary make payment to the Contractor in accordance with section 53206.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9ad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53205/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operating agreement is an obligation of the united states government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An Operating Agreement under this chapter constitutes a contractual obligation of the United States Government to pay the amounts provided for in the Operating Agreement to the extent of actual appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9ae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documentation Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each vessel covered by an Operating Agreement (including an Agreement terminated under section 53204(c)(2)) shall remain documented under chapter 121 of this title, until the date the Operating Agreement would terminate according to its own terms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9af-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53205/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Security Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d2b9b0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53205/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Contractor with respect to an Operating Agreement (including an Agreement terminated under section 53204(c)(2)) shall continue to be bound by the provisions of section 53207 until the date the Operating Agreement would terminate according to its terms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d2b9b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53205/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contingency agreement with operating agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All terms and conditions of a Contingency Agreement entered into under section 53207 shall remain in effect until a date the Operating Agreement would terminate according to its terms, except that the terms of such Contingency Agreement may be modified by the mutual consent of the Contractor, and the Operating Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53205/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Operating Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Operating Agreements shall not be transferrable by the Contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d2b9b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53205/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Replacement Vessel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Contractor may replace a vessel under an Operating Agreement with another vessel that is eligible to be included in the Fleet under section 53202(b), if the Secretary and the Operating Agency jointly determine that the replacement vessel meets national security requirements and approve the replacement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d2b9b4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3521/a"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1994"},"text":"133 Stat. 1994","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
