{"tag":"section","attrib":{"id":"idf6f1b302-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57305"},"text":null,"children":[{"tag":"num","attrib":{"value":"57305"},"text":"§ 57305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of trade-in allowance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f1b303-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall determine the trade-in allowance for an obsolete vessel at the time of acquisition of the vessel. The allowance shall be the fair value of the vessel. In determining the value, the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f1b304-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scrap value of the obsolete vessel in American and foreign markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b305-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the depreciated value based on a 20-year or 25-year life, whichever applies to the obsolete vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b306-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57305/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the market value of the obsolete vessel for operation in world commerce or in the domestic or foreign commerce of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b307-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Obsolete Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If acquisition of the obsolete vessel occurs when the owner contracts for the construction of the new vessel, and the owner uses the obsolete vessel during the period of construction of the new vessel, the Secretary shall reduce the trade-in allowance by an amount representing the fair value of that use. The Secretary shall establish the rate for use of the obsolete vessel when the contract for construction of the new vessel is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b308-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1663"},"text":"120 Stat. 1663","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b309-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f1b30a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f1b30b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"57305(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1160(b) (3d sentence), (d) (1st, 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title V, § 510(b) (3d sentence), (d), as added "},{"tag":"html:a","attrib":{"href":"/us/act/1939-08-04/ch417/s7"},"text":"Aug. 4, 1939, ch. 417, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/1184"},"text":"53 Stat. 1184","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-17/ch939/s8"},"text":"July 17, 1952, ch. 939, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/762"},"text":"66 Stat. 762","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/86/518/s1"},"text":"Pub. L. 86–518, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"June 12, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/216"},"text":"74 Stat. 216","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/87/401"},"text":"Pub. L. 87–401","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 5, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/833"},"text":"75 Stat. 833","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/469/s35/a"},"text":"Pub. L. 91–469, § 35(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1035"},"text":"84 Stat. 1035","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/91"},"text":"Pub. L. 97–31, § 12(91)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/161"},"text":"95 Stat. 161","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"57305(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1160(d) (3d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “fair value” are substituted for “fair and reasonable value” to eliminate unnecessary words. In paragraph (3), the word “commerce” is substituted for “trade” for consistency in the chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “for the entire period of such use” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
