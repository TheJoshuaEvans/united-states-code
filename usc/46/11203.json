{"tag":"section","attrib":{"id":"idf68fe4c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11203"},"text":null,"children":[{"tag":"num","attrib":{"value":"11203"},"text":"§ 11203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation of qualified service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68fe4c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Record of Service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, or in the case of personnel of the Army Transport Service or the Naval Transport Service, the Secretary of Defense, shall, upon application—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68fe4c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11203/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a certificate of honorable service to an individual who, as determined by that Secretary, engaged in qualified service of a nature and duration that warrants issuance of the certificate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4ca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11203/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correct, or request the appropriate official of the Federal Government to correct, the service records of that individual to the extent necessary to reflect the qualified service and the issuance of the certificate of honorable service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe4cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing of Documentation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Secretary receiving an application under subsection (a) shall act on the application not later than 1 year after the date of that receipt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe4cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards Relating to Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making a determination under subsection (a)(1), the Secretary acting on the application shall apply the same standards relating to the nature and duration of service that apply to the issuance of honorable discharges under section 401(a)(1)(B) of the GI Bill Improvement Act of 1977 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s106"},"text":"38 U.S.C. 106","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe4cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11203/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Correction of Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An official who is requested under subsection (a)(2) to correct the service records of an individual shall make such correction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68fe4ce-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tIV/s402/a"},"text":"Pub. L. 105–368, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3337"},"text":"112 Stat. 3337","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(b)(13), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4752"},"text":"134 Stat. 4752","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68fe4cf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68fe4d0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf68fe4d1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 401(a)(1)(B) of the GI Bill Improvement Act of 1977, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/202/s401/a/1/B"},"text":"section 401(a)(1)(B) of Pub. L. 95–202","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s106"},"text":"section 106 of Title 38","children":[],"tail":", Veterans’ Benefits."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68fe4d2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/b/13/A"},"text":"Pub. L. 116–283, § 8505(b)(13)(A)","children":[],"tail":", substituted “an individual” for “a person” in subsecs. (a)(1) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8505/b/13/B"},"text":"Pub. L. 116–283, § 8505(b)(13)(B)","children":[],"tail":", substituted “that individual” for “that person”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
