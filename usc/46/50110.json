{"tag":"section","attrib":{"id":"idf6b60a1f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50110"},"text":null,"children":[{"tag":"num","attrib":{"value":"50110"},"text":"§ 50110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securing preference to vessels of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b60a20-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Possibilities of Promoting Carriage","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall investigate, determine, and keep current records of the possibilities of promoting the carriage of United States foreign trade in vessels of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a21-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inducements to Importers and Exporters","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall study and cooperate with vessel owners in devising means by which the importers and exporters of the United States can be induced to give preference to vessels of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a22-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liaison With Agencies and Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish and maintain liaison with such other agencies of the United States Government, and with such representative trade organizations throughout the United States, as may be concerned, directly or indirectly, with any movement of commodities in the waterborne export and import foreign commerce of the United States, for the purpose of securing preference to vessels of the United States in the shipment of those commodities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b60a23-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1560"},"text":"120 Stat. 1560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b60a24-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b60a25-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b60a26-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"