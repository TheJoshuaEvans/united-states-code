{"tag":"section","attrib":{"id":"idf6ef41fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56312"},"text":null,"children":[{"tag":"num","attrib":{"value":"56312"},"text":"§ 56312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documented defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In sections 56309 through 56311, the term “documented” means, with respect to a vessel, that a certificate of documentation has been issued for the vessel under chapter 121.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6ef41fd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dC/tXXXV/s3504/d"},"text":"Pub. L. 115–91, div. C, title XXXV, § 3504(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1913"},"text":"131 Stat. 1913","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
