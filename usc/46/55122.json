{"tag":"section","attrib":{"id":"idf6e816b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122"},"text":null,"children":[{"tag":"num","attrib":{"value":"55122"},"text":"§ 55122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Floating dry docks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e816b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55102"},"text":"Section 55102 of this title","children":[],"tail":" does not apply to the movement of a floating dry dock if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e816b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the floating dry dock—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e816b6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is being used to launch or raise a vessel in connection with the construction, maintenance, or repair of that vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e816b7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is owned and operated by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6e816b8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a shipyard located in the United States that is an eligible owner specified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12103/b"},"text":"section 12103(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6e816b9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an affiliate of such a shipyard; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e816ba-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6e816bb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was owned or contracted for purchase by such shipyard or affiliate prior to the date of the enactment of the Carl Levin and Howard P. “Buck” McKeon National Defense Authorization Act for Fiscal Year 2015; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6e816bc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had a letter of intent for purchase by such shipyard or affiliate signed prior to such date of enactment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e816bd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movement occurs within 5 nautical miles of the shipyard or affiliate that owns and operates such floating dry dock or, in the case of a dry dock described in paragraph (1)(C)(ii), occurs between Honolulu, Hawaii, and Pearl Harbor, Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e816be-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dry Docks for Construction of Certain Naval Vessels.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e816bf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying subsection (a) to a floating dry dock used for the construction of naval vessels in a shipyard located in the United States, the ownership and operation requirement in paragraph (1)(B) of that subsection shall be treated as satisfied and “","children":[{"tag":"date","attrib":{"date":"2017-12-19"},"text":"December 19, 2017","children":[],"tail":"” shall be substituted for the date referred to in paragraph (1)(C) of that subsection if the Secretary of the Navy determines that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e816c0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such dry dock is necessary for the timely completion of such construction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e816c1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such dry dock—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6e816c2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is owned and operated by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6e816c3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/b/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a shipyard located in the United States that is an eligible owner specified under section 12103(b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6e816c4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an affiliate of such a shipyard; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6e816c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6e816c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by the State in which the shipyard is located or a political subdivision of that State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6e816c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated by a shipyard located in the United States that is an eligible owner specified under section 12103(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e816c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after making a determination under paragraph (1), the Secretary of the Navy shall notify the Committee on Armed Services and the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Armed Services and the Committee on Commerce, Science, and Transportation of the Senate of such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e816c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “floating dry dock” means equipment with wing walls and a fully submersible deck.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e816ca-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dC/tXXXV/s3502/a"},"text":"Pub. L. 113–291, div. C, title XXXV, § 3502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3904"},"text":"128 Stat. 3904","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3508"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2780"},"text":"130 Stat. 2780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11525"},"text":"Pub. L. 117–263, div. K, title CXV, § 11525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4145"},"text":"136 Stat. 4145","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e816cb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6e816cc-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6e816cd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Carl Levin and Howard P. “Buck” McKeon National Defense Authorization Act for Fiscal Year 2015, referred to in subsec. (a)(1)(C), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6e816ce-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11525/1"},"text":"Pub. L. 117–263, § 11525(1)","children":[],"tail":", designated existing provisions as cl. (i), substituted “2015; or” for “2015; and”, and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11525/2"},"text":"Pub. L. 117–263, § 11525(2)","children":[],"tail":", inserted “or, in the case of a dry dock described in paragraph (1)(C)(ii), occurs between Honolulu, Hawaii, and Pearl Harbor, Hawaii” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
