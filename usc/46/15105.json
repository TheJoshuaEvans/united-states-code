{"tag":"section","attrib":{"id":"idf6a0ad31-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15105"},"text":null,"children":[{"tag":"num","attrib":{"value":"15105"},"text":"§ 15105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Boating Safety Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a0ad32-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a National Boating Safety Advisory Committee (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad33-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall advise the Secretary on matters relating to national boating safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad34-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ad35-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall consist of 21 members appointed by the Secretary in accordance with this section and section 15109 of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad36-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expertise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad37-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15105/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Committee shall be appointed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad38-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15105/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7 members shall represent State officials responsible for State boating safety programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad39-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15105/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7 members shall represent recreational vessel and associated equipment manufacturers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad3a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15105/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7 members shall represent the general public or national recreational boating organizations and, of the 7, at least 5 shall represent national recreational boating organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a0ad3b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVI/s601/a"},"text":"Pub. L. 115–282, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4283"},"text":"132 Stat. 4283","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
