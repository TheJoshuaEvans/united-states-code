{"tag":"section","attrib":{"id":"idf6735b9a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4703"},"text":null,"children":[{"tag":"num","attrib":{"value":"4703"},"text":"§ 4703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for unlawful abandonment of barge","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Thirty days after the notification procedures under section 4704(a)(1) are completed, the Secretary may assess a civil penalty of not more than $1,000 for each day of the violation against an owner or operator that violates section 4702. A vessel with respect to which a penalty is assessed under this subchapter is liable in rem for the penalty.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6735b9b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/tV/s5302"},"text":"Pub. L. 102–587, title V, § 5302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5082"},"text":"106 Stat. 5082","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7347/c/2"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7347(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1781"},"text":"139 Stat. 1781","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6735b9c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6735b9d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6735b9e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “subchapter” for “chapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
