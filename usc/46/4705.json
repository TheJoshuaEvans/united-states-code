{"tag":"section","attrib":{"id":"idf6735bb4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4705"},"text":null,"children":[{"tag":"num","attrib":{"value":"4705"},"text":"§ 4705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of barge removal contractors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6735bb5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A barge removal contractor and its subcontractor are not liable for damages that result from actions taken or omitted to be taken in the course of removing a barge under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735bb6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) does not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735bb7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to personal injury or wrongful death; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735bb8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the contractor or subcontractor is grossly negligent or engages in willful misconduct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6735bb9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/tV/s5302"},"text":"Pub. L. 102–587, title V, § 5302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5083"},"text":"106 Stat. 5083","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/19"},"text":"Pub. L. 109–304, § 15(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1703"},"text":"120 Stat. 1703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7347/c/4"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7347(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1781"},"text":"139 Stat. 1781","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6735bba-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6735bbb-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6735bbc-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “subchapter” for “chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" in subsec. (a) struck out par. (1) designation before “A barge removal” and substituted “subcontractor are not” for “subcontractor not”, redesignated par. (2) as subsec. (b) and subpars. (A) and (B) of former par. (2) as pars. (1) and (2) of subsec. (b), respectively, and substituted “Subsection (a)” for “Paragraph (1)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
