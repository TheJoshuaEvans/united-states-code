{"tag":"section","attrib":{"id":"idf704c6ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112"},"text":null,"children":[{"tag":"num","attrib":{"value":"70112"},"text":"§ 70112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maritime Security Advisory Committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf704c6eb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Maritime Security Advisory Committee.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf704c6ec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a National Maritime Security Advisory Committee (in this subsection referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c6ed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall advise the Secretary on matters relating to national maritime security, including on enhancing the sharing of information related to cybersecurity risks that may cause a transportation security incident, between relevant Federal agencies and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf704c6ee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and tribal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6ef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant public safety and emergency response agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6f0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant law enforcement and security organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6f1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maritime industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6f2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" port owners and operators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf704c6f3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminal owners and operators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf704c6f4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf7070fe5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall consist of at least 8 members, but not more than 21 members, appointed by the Secretary in accordance with this subsection and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s15109"},"text":"section 15109 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7070fe6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expertise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7070fe7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each of the following shall be represented by at least 1 member of the Committee:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf7070fe8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Port authorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf7070fe9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilities owners and operators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf7070fea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Terminal owners and operators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf7070feb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vessel owners and operators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf7070fec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maritime labor organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf7070fed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/3/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The academic community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf7070fee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/3/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf7070fef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/3/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The maritime industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7070ff0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Committee consists of at least 8 members who, together, satisfy the minimum representation requirements of subparagraph (C), the Secretary shall, based on the needs of the Coast Guard, determine the number of additional members of the Committee who represent each entity specified in that subparagraph. Neither this subparagraph nor any other provision of law shall be construed to require an equal distribution of members representing each entity specified in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7070ff1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s15109"},"text":"section 15109 of this title","children":[],"tail":", the Committee shall be treated as a committee established under chapter 151 of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7070ff2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Area Maritime Security Advisory Committees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7070ff3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf7070ff4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf7070ff5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish an Area Maritime Security Advisory Committee for any port area of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf7070ff6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request such a committee to review the proposed Area Maritime Transportation Security Plan developed under section 70103(b) and make recommendations to the Secretary that the committee considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7070ff7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional functions and meetings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A committee established under this subsection for an area—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf7070ff8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may advise, consult with, report to, and make recommendations to the Secretary on matters relating to maritime security in that area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf7070ff9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make available to the Congress recommendations that the committee makes to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf7070ffa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall meet at the call of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf7070ffb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/1/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, who shall call such a meeting at least once during each calendar year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf7070ffc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/1/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of the committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7070ffd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf7070ffe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each committee established under this subsection shall consist of at least 7 members appointed by the Secretary, each of whom has at least 5 years practical experience in maritime security operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7070fff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of each member of a committee established under this subsection shall be for a period of not more than 5 years, specified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7071000-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before appointing an individual to a position on a committee established under this subsection, the Secretary shall publish a notice in the Federal Register soliciting nominations for membership on the committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7071001-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Background examinations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require an individual to have passed an appropriate security background examination before appointment to a committee established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7071002-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each committee established under this subsection shall be composed of individuals who represent the interests of the port industry, terminal operators, port labor organizations, and other users of the port areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7071003-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson and vice chairperson.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf7071004-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each committee established under this subsection shall elect 1 of the committee’s members as the Chairperson and 1 of the committee’s members as the Vice Chairperson.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7071005-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vice chairperson acting as chairperson","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Vice Chairperson shall act as Chairperson in the absence or incapacity of the Chairperson, or in the event of a vacancy in the office of the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7071006-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Observers.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf7071007-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall, and the head of any other interested Federal agency may, designate a representative to participate as an observer with a committee established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7071008-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Role","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary’s designated representative to a committee established under this subsection shall act as the executive secretary of the committee and shall perform the duties set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1009/c"},"text":"section 1009(c) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7071009-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration of views","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall consider the information, advice, and recommendations of each committee established under this subsection in formulating policy regarding matters affecting maritime security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf707100a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation and expenses.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf707100b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of a committee established under this subsection, when attending meetings of the committee or when otherwise engaged in the business of the committee, is entitled to receive—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf707100c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation at a rate fixed by the Secretary, not exceeding the daily equivalent of the current rate of basic pay in effect for GS–15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" including travel time; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf707100d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel or transportation expenses under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf707100e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of a committee established under this subsection shall not be considered to be an officer or employee of the United States for any purpose based on the receipt of any payment under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf707100f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70112/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chapter ","children":[],"tail":"10"},{"tag":"inline","attrib":{},"text":" of title ","children":[],"tail":"5.—"}],"tail":null},{"tag":"content","attrib":{},"text":"Chapter 10 of title 5 does not apply to a committee established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf7071010-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s102/a"},"text":"Pub. L. 107–295, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2081"},"text":"116 Stat. 2081","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tVIII/s806"},"text":"Pub. L. 108–293, title VIII, § 806","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1082"},"text":"118 Stat. 1082","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIX/s901/m"},"text":"Pub. L. 109–241, title IX, § 901(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/565"},"text":"120 Stat. 565","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVIII/s810"},"text":"Pub. L. 111–281, title VIII, § 810","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2995"},"text":"124 Stat. 2995","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dJ/s1805/c/1"},"text":"Pub. L. 115–254, div. J, § 1805(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3534"},"text":"132 Stat. 3534","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVI/s602/a"},"text":"Pub. L. 115–282, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4290"},"text":"132 Stat. 4290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/294"},"text":"Pub. L. 117–286, § 4(a)(294)","children":[],"tail":", (295), "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4338"},"text":"136 Stat. 4338","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf7071011-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf7071012-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf7071013-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/294"},"text":"Pub. L. 117–286, § 4(a)(294)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1009/c"},"text":"section 1009(c) of title 5","children":[],"tail":".” for “section 10(c) of the Federal Advisory Committee Act (5 U.S.C. App.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/295"},"text":"Pub. L. 117–286, § 4(a)(295)","children":[],"tail":", substituted “Chapter 10 of title 5” for “FACA” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s602/a"},"text":"Pub. L. 115–282, § 602(a)","children":[],"tail":", amended section generally. Prior to amendment, section required Secretary to establish a National Maritime Security Advisory Committee and authorized Secretary to establish an Area Maritime Security Advisory Committee for any port area of the United States."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" inserted “, including on enhancing the sharing of information related to cybersecurity risks that may cause a transportation security incident, between relevant Federal agencies and—” in introductory provisions and added cls. (i) to (vi)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s810/1"},"text":"Pub. L. 111–281, § 810(1)","children":[],"tail":", amended par. (5) generally. Prior to amendment par. (5) read as follows: “The membership of an Area Maritime Security Advisory Committee shall include representatives of the port industry, terminal operators, port labor organizations, and other users of the port areas.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s810/2/A"},"text":"Pub. L. 111–281, § 810(2)(A)","children":[],"tail":", substituted “2020;” for “2008;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s810/2/B"},"text":"Pub. L. 111–281, § 810(2)(B)","children":[],"tail":", substituted “2018” for “2006”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293"},"text":"Pub. L. 108–293","children":[],"tail":" added par. (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf7071014-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf7071015-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Treatment of Existing Committee","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVI/s602/b"},"text":"Pub. L. 115–282, title VI, § 602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4293"},"text":"132 Stat. 4293","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/282/tVI/s602/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Notwithstanding any other provision of law—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an advisory committee substantially similar to the National Maritime Security Advisory Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70112/a"},"text":"section 70112(a) of title 46","children":[],"tail":", United States Code, as amended by this section, and that was in force or in effect on the day before the date of enactment of this section ["},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":"], may remain in force or in effect for a period of 2 years from the date of enactment of this section, including that the charter, membership, and other aspects of the committee may remain in force or in effect; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during the 2-year period referenced in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements relating to the National Maritime Security Advisory Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70112/a"},"text":"section 70112(a) of title 46","children":[],"tail":", United States Code, as amended by this section, shall be treated as satisfied by the substantially similar advisory committee; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the enactment of this section, including the amendments made in this section, shall not be the basis—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to deem, find, or declare such committee, including the charter, membership, and other aspects thereof, void, not in force, or not in effect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to suspend the activities of such committee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to bar the members of such committee from meeting.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf7071016-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Cybersecurity Information Sharing and Coordination in Ports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dJ/s1805/a"},"text":"Pub. L. 115–254, div. J, § 1805(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3533"},"text":"132 Stat. 3533","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dJ/s1805/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maritime Cybersecurity Risk Assessment Model","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security, through the Commandant of the Coast Guard and the Under Secretary responsible for overseeing the critical infrastructure protection, cybersecurity, and other related programs of the Department of Homeland Security, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"], coordinate with the National Maritime Security Advisory Committee, the Area Maritime Security Advisory Committees, and other maritime stakeholders, as necessary, to develop and implement a maritime cybersecurity risk assessment model, consistent with the activities described in section 2(e) of the National Institute of Standards and Technology Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s272/e"},"text":"15 U.S.C. 272(e)","children":[],"tail":"), to evaluate current and future cybersecurity risks that have the potential to affect the marine transportation system or that would cause a transportation security incident (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s70101"},"text":"section 70101 of title 46","children":[],"tail":", United States Code) in ports; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than biennially thereafter, evaluate the effectiveness of the cybersecurity risk assessment model established under paragraph (1).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf7071017-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Information Sharing","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dJ/s1805/c/2"},"text":"Pub. L. 115–254, div. J, § 1805(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3534"},"text":"132 Stat. 3534","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dJ/s1805/c/2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Commandant of the Coast Guard and the Under Secretary responsible for overseeing the critical infrastructure protection, cybersecurity, and other related programs of the Department of Homeland Security shall—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure there is a process for each Area Maritime Security Advisory Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70112"},"text":"section 70112 of title 46","children":[],"tail":", United States Code—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the sharing of information related to cybersecurity risks that may cause transportation security incidents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to timely report transportation security incidents to the national level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to disseminate such reports across the entire maritime transportation system via the National Cybersecurity and Communications Integration Center; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue voluntary guidance for the management of such cybersecurity risks in each Area Maritime Transportation Security Plan and facility security plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70103"},"text":"section 70103 of title 46","children":[],"tail":", United States Code, approved after the date that the cybersecurity risk assessment model is developed under subsection (a) of this section [set out as a note above].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
