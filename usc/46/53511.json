{"tag":"section","attrib":{"id":"idf6d774be-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511"},"text":null,"children":[{"tag":"num","attrib":{"value":"53511"},"text":"§ 53511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax treatment of nonqualified withdrawals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d774bf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53513"},"text":"section 53513 of this title","children":[],"tail":", a withdrawal from a fund that is not a qualified withdrawal shall be treated as a nonqualified withdrawal."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d774c0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Order of Withdrawals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A nonqualified withdrawal shall be treated as made—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d774c1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first from the ordinary income account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d774c2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" second from the capital gain account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d774c3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" third from the capital account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d774c4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tax Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"26 U.S.C. 1","children":[],"tail":" et seq.)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d774c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonqualified withdrawal from the ordinary income account shall be included in income as an item of ordinary income for the taxable year in which the withdrawal is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d774c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonqualified withdrawal from the capital gain account shall be included in income for the taxable year in which the withdrawal is made as an item of gain realized during that year from the disposition of an asset held for more than 6 months; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d774c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the period through the last date prescribed for payment of tax for the taxable year in which the withdrawal is made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d774c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no interest shall be payable under section 6601 of such Code (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6601"},"text":"26 U.S.C. 6601","children":[],"tail":") and no addition to the tax shall be payable under section 6651 of such Code ("},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6651"},"text":"26 U.S.C. 6651","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d774c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interest on the amount of the additional tax attributable to an amount treated as a nonqualified withdrawal from the ordinary income account or the capital gain account shall be paid at the rate determined under subsection (d) from the last date prescribed for payment of the tax for the taxable year for which the amount was deposited in the fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d774ca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no interest shall be payable on amounts treated as withdrawn on a last-in-first-out basis under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53512"},"text":"section 53512 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d774cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interest Rate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rate of interest under subsection (c)(3)(B) for a nonqualified withdrawal made in a taxable year beginning after 1971 shall be determined and published jointly by the Secretary and the Secretary of the Treasury. The rate shall be such that its relationship to 8 percent is comparable, as determined by the Secretaries under joint regulations, to the relationship between—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d774cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the money rates and investment yields for the calendar year immediately before the beginning of the taxable year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d774cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the money rates and investment yields for the calendar year 1970.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d774ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonqualified Withdrawals","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d774cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The following applicable percentage of any amount that remains in a capital construction fund at the close of the following specified taxable year following the taxable year for which the amount was deposited shall be treated as a nonqualified withdrawal:","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6d774d0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":" If the amount remains in the fund at","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"  the close of the—","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:b","attrib":{},"text":"The applicable percentage is—","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"26th taxable year","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"20 percent  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"27th taxable year","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"40 percent  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"28th taxable year","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"60 percent  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"29th taxable year","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"80 percent  ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30th taxable year","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"100 percent.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d774d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Earnings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The earnings of a capital construction fund for any taxable year (except net gains) shall be treated under this subsection as an amount deposited for the taxable year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d774d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract for qualified withdrawal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under paragraph (1), an amount shall not be treated as remaining in a capital construction fund at the close of a taxable year to the extent there is a binding contract at the close of the taxable year for a qualified withdrawal of the amount for an identified item for which the withdrawal may be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d774d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excess earnings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary determines that the balance in a capital construction fund exceeds the amount appropriate to meet the vessel construction program objectives of the person that established the fund, the amount of the excess shall be treated as a nonqualified withdrawal under paragraph (1) unless the person develops appropriate program objectives within 3 years to dissipate the excess.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d774d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amounts in fund on ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"january 1, 1987","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under this subsection, amounts in a capital construction fund on ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":", shall be treated as having been deposited in that fund on that date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d774d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tax Determinations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d774d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a taxable year for which there is a nonqualified withdrawal (including an amount treated as a nonqualified withdrawal under subsection (e)), the tax imposed by chapter 1 of the Internal Revenue Code of 1986 (26 U.S.C. ch. 1) shall be determined by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d774d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excluding the withdrawal from gross income; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d774d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the tax imposed by chapter 1 of such Code by the product of the amount of the withdrawal and the highest tax rate specified in section 1 (or section 11 for a corporation) of such Code (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"26 U.S.C. 1","children":[],"tail":", 11)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d774d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum tax rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For that portion of a nonqualified withdrawal made from the capital gain account during a taxable year to which section 1(h) or 1201(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002040"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002040"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of such Code ("},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1/h"},"text":"26 U.S.C. 1(h)","children":[],"tail":", 1201(a)) applies, the tax rate used under paragraph (1)(B) may not exceed 20 percent (or 34 percent for a corporation)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d774da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tax benefit rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If any portion of a nonqualified withdrawal is properly attributable to deposits (except earnings on deposits) made by the taxpayer in a taxable year that did not reduce the taxpayer’s liability for tax under chapter 1 of such Code (26 U.S.C. ch. 1) for a taxable year before the taxable year in which the withdrawal occurs—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d774db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that portion shall not be taken into account under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d774dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to that portion shall be allowed as a deduction under section 172 of such Code (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s172"},"text":"26 U.S.C. 172","children":[],"tail":") for the taxable year in which the withdrawal occurs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d774dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53511/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination with deduction for net operating losses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A nonqualified withdrawal excluded from gross income under paragraph (1) shall be excluded in determining taxable income under section 172(b)(2) of such Code (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s172/b/2"},"text":"26 U.S.C. 172(b)(2)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d774de-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1597"},"text":"120 Stat. 1597","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/tI/s102/c/1/E"},"text":"Pub. L. 112–240, title I, § 102(c)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2319"},"text":"126 Stat. 2319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d774df-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6d774e0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6d774e1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col"