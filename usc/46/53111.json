f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/d/1"},"text":"Pub. L. 118–159, § 3502(d)(1)","children":[],"tail":", substituted “and 2024” for “2024, and 2025”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/d/3"},"text":"Pub. L. 118–159, § 3502(d)(3)","children":[],"tail":", added par. (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/d/4"},"text":"Pub. L. 118–159, § 3502(d)(4)","children":[],"tail":", substituted “$400,500,000” for “$348,000,000” and “2027” for “2026, 2027,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/d/2"},"text":"Pub. L. 118–159, § 3502(d)(2)","children":[],"tail":", redesignated par. (4) as (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/d/5"},"text":"Pub. L. 118–159, § 3502(d)(5)","children":[],"tail":", substituted “$411,300,000” for “$378,000,000” and “and 2030;” for “, 2030, and 2031; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/d/2"},"text":"Pub. L. 118–159, § 3502(d)(2)","children":[],"tail":", redesignated par. (5) as (6). Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/d/6"},"text":"Pub. L. 118–159, § 3502(d)(6)","children":[],"tail":", substituted “$422,400,000” for “$408,000,000” and “2031 and 2032” for “2032, 2033, 2034, and 2035”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/d/2"},"text":"Pub. L. 118–159, § 3502(d)(2)","children":[],"tail":", redesignated par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (8) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3502/d/7"},"text":"Pub. L. 118–159, § 3502(d)(7)","children":[],"tail":", added pars. (8) to (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “$494,008,000” for “$314,007,780”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Pars. (3) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “$318,000,000 for each of fiscal years 2022, 2023, 2024, and 2025;” for “$222,000,000 for each fiscal year thereafter through fiscal year 2025.” in par. (3) and added pars. (4) to (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" redesignated pars. (5) to (7) as (1) to (3), respectively, and struck out former pars. (1) to (4) which set out authorized amounts for fiscal years 2006 to 2017."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s101/e/2/A"},"text":"Pub. L. 114–113, § 101(e)(2)(A)","children":[],"tail":", substituted “and 2015” for “2015, 2017, and 2018;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" struck out “2016,” after “2015,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (4) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s101/e/2/B"},"text":"Pub. L. 114–113, § 101(e)(2)(B)","children":[],"tail":", (C), added pars. (4) to (6), redesignated former par. (5) as (7), and struck out former par. (4) which read as follows: “$210,000,000 for each of fiscal years 2019, 2020, and 2021; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s3508/i/1"},"text":"Pub. L. 112–239, § 3508(i)(1)","children":[],"tail":", struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s3508/i/2"},"text":"Pub. L. 112–239, § 3508(i)(2)","children":[],"tail":", which directed amendment of par. (3) “to read as follows” and then set out pars. (3) to (5), was executed by amending par. (3) generally and adding pars. (4) and (5) to reflect the probable intent of Congress. Prior to amendment, par. (3) read as follows: “$186,000,000 for each fiscal year thereafter through fiscal year 2025.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “2025” for “2015”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
