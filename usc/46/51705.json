{"tag":"section","attrib":{"id":"idf6c91c86-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51705"},"text":null,"children":[{"tag":"num","attrib":{"value":"51705"},"text":"§ 51705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training for use of force against piracy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation, in consultation with the Secretary of Defense and the Secretary of the department in which the Coast Guard is operating, shall certify a training curriculum for United States mariners on the use of force against pirates. The curriculum shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c91c87-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51705/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on waters designated as high-risk waters by the Commandant of the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91c88-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51705/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on current threats and patterns of attack by pirates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91c89-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51705/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tactics for defense of a vessel, including instruction on the types, use, and limitations of security equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91c8a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51705/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standard rules for the use of force for self-defense as developed by the Secretary of the department in which the Coast Guard is operating under section 912(c) of the Coast Guard Authorization Act of 2010 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Public Law 111–281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s8107"},"text":"46 U.S.C. 8107","children":[],"tail":" note), including instruction on firearm safety for crewmembers of vessels carrying cargo under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s55305"},"text":"section 55305 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91c8b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51705/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures to follow to improve crewmember survivability if captured and taken hostage by pirates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c91c8c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/tV/s502/a"},"text":"Pub. L. 112–213, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1574"},"text":"126 Stat. 1574","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c91c8d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6c91c8e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6c91c8f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/tV/s502/b"},"text":"Pub. L. 112–213, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1575"},"text":"126 Stat. 1575","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/213/tV/s502/b"},"text":"“The Secretary of Transportation shall certify the curriculum required under the amendment made by subsection (a) [enacting this section] not later than 270 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
