{"tag":"section","attrib":{"id":"idf6a2f680-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30526"},"text":null,"children":[{"tag":"num","attrib":{"value":"30526"},"text":"§ 30526.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions requiring notice of claim or limiting time for bringing action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a2f681-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30526/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies only to seagoing vessels, but does not apply to pleasure yachts, tugs, towboats, towing vessels, tank vessels, fishing vessels, fish tender vessels, canal boats, scows, car floats, barges, lighters, or nondescript vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a2f682-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30526/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Time Limits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The owner, master, manager, or agent of a vessel transporting passengers or property between ports in the United States, or between a port in the United States and a port in a foreign country, may not limit by regulation, contract, or otherwise the period for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a2f683-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30526/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" giving notice of, or filing a claim for, personal injury or death, in the case of seagoing vessels, to less than 6 months after the date of the injury or death, or in the case of covered small passenger vessels, to less than two years after the date of the injury or death; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a2f684-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30526/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bringing a civil action for personal injury or death, in the case of seagoing vessels, to less than one year after the date of the injury or death, or in the case of covered small passenger vessels, to less than two years after the date of the injury or death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a2f685-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30526/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Failure To Give Notice","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When notice of a claim for personal injury or death is required by a contract, the failure to give the notice is not a bar to recovery if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a2f686-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30526/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court finds that the owner, master, or agent of the vessel had knowledge of the injury or death and the owner has not been prejudiced by the failure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a2f687-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30526/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court finds there was a satisfactory reason why the notice could not have been given; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a2f688-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30526/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner of the vessel fails to object to the failure to give the notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a2f689-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30526/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tolling of Period To Give Notice","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a claimant is a minor or mental incompetent, or if a claim is for wrongful death, any period provided by a contract for giving notice of the claim is tolled until the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a2f68a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30526/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date a legal representative is appointed for the minor, incompetent, or decedent’s estate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a2f68b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30526/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 years after the injury or death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a2f68c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1514"},"text":"120 Stat. 1514","children":[],"tail":", § 30508; renumbered § 30526 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11503/a/3"},"text":"Pub. L. 117–263, div. K, title CXV, § 11503(a)(3)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4130"},"text":"136 Stat. 4130","children":[],"tail":", 4131.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a2f68d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a2f68e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a2f68f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30508(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:183(f) (related to 46 App.:183b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 4283(f) (related to R.S. § 4283A); ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-08-29/ch804/s1"},"text":"Aug. 29, 1935, ch. 804, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/960"},"text":"49 Stat. 960","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1936-06-05/ch521/s1"},"text":"June 5, 1936, ch. 521, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1480"},"text":"49 Stat. 1480","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30508(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:183b(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 4283A, as added ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-08-29/ch804/s3"},"text":"Aug. 29, 1935, ch. 804, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/960"},"text":"49 Stat. 960","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30508(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:183b(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30508(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:183b(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For an explanation of subsection (a), see the revision notes for section 30506(a), where 46 App. U.S.C. 183(f) is also restated.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before paragraph (1), the words “sea-going vessel (other than tugs, barges, fishing vessels and their tenders)” are omitted because of subsection (a) of this section. The word “merchandise” is omitted as covered by “property”. The words “between ports in the United States, or between a port in the United States and a port in a foreign country” are substituted for “from or between ports of the United States and foreign ports” for clarity and for consistency with section 30509(a)(1) of the revised title. See ","children":[{"tag":"i","attrib":{},"text":"Burstein v. United States Lines Co.","children":[],"tail":", 43 F. Supp. 226 (S.D.N.Y. 1942), rev’d on other grounds, 134 F.2d 89 (2d Cir. 1943). The word “rule” is omitted as covered by “regulation”. In paragraph (1), the words “after the date of the injury or death” are added for clarity and consistency with paragraph (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), before paragraph (1), the words “When notice of a claim for personal injury or death is required by a contract, the failure to give the notice” are substituted for “Failure to give such notice, where lawfully prescribed in such contract” for clarity. In paragraph (1), the words “the court finds” are stated at the beginning rather than the middle to be more precise. The word “damage” is omitted as unnecessary. In paragraph (2), the words “the court finds there was a satisfactory reason” are substituted for “the court excuses such failure on the ground that for some satisfactory reason” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), before paragraph (1), the word “claimant” is substituted for “person who is entitled to recover on any such claim” to eliminate unnecessary words. The word “lawful” is omitted as unnecessary. The words “is tolled until” are substituted for “shall not be applicable so long as” and “but shall be applicable from” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6a2f690-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6a2f691-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11503/a/3"},"text":"Pub. L. 117–263, § 11503(a)(3)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s30508"},"text":"section 30508 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11503/d/1"},"text":"Pub. L. 117–263, § 11503(d)(1)","children":[],"tail":", inserted “, in the case of seagoing vessels,” after “personal injury or death” and “, or in the case of covered small passenger vessels, to less than two years after the date of the injury or death” after “date of the injury or death”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11503/d/2"},"text":"Pub. L. 117–263, § 11503(d)(2)","children":[],"tail":", inserted “, in the case of seagoing vessels,” after “personal injury or death” and “, or in the case of covered small passenger vessels, to less than two years after the date of the injury or death” after “date of the injury or death”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
