{"tag":"section","attrib":{"id":"idf66c2edf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3705"},"text":null,"children":[{"tag":"num","attrib":{"value":"3705"},"text":"§ 3705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crude oil tanker minimum standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf66c2ee0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3705/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A new crude oil tanker of at least 20,000 deadweight tons shall be equipped with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf66c2ee1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3705/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protectively located segregated ballast tanks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2ee2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3705/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a crude oil washing system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2ee3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3705/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cargo tank protection system consisting of a fixed deck froth system and a fixed inert gas system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66c2ee4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3705/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An existing crude oil tanker of at least 40,000 deadweight tons shall be equipped with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf66c2ee5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3705/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" segregated ballast tanks; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66c2ee6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3705/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a crude oil washing system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66c2ee7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3705/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An existing crude oil tanker of at least 20,000 deadweight tons but less than 40,000 deadweight tons, and at least 15 years of age, shall be equipped with segregated ballast tanks or a crude oil washing system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66c2ee8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3705/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An existing crude oil tanker of at least 20,000 deadweight tons shall be equipped with an inert gas system. However, for a crude oil tanker of less than 40,000 deadweight tons not fitted with high capacity tank washing machines, the Secretary may grant an exemption if the vessel’s owner can show clearly that compliance would be unreasonable and impracticable due to the vessel’s design characteristics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66c2ee9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3705/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A crude oil tanker engaged in transferring oil from an offshore oil exploitation or production facility on the Outer Continental Shelf of the United States shall be equipped with segregated ballast tanks, or may operate with dedicated clean ballast tanks or special ballast arrangements. However, the tanker shall comply with other applicable minimum standards of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf66c2eea-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/523"},"text":"97 Stat. 523","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3544/b"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3544(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2325"},"text":"132 Stat. 2325","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf66c2eeb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf66c2eec-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf66c2eed-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3705(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(7)(A)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3705(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(7)(D)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3705(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(7)(E)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3705(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(7)(F)","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3705(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391a(7)(M)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3705 requires compliance with certain minimum standards by a crude oil tanker, which is self-propelled. In general, the minimum required standards are consistent with those international standards that have been adopted as Protocols to the 1974 Safety of Life at Sea Convention and the 1973 Marine Pollution Convention.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3705(a) requires new crude oil tankers of 20,000 deadweight tons or above to have protectively located segregated ballast tanks, a crude oil washing system, and a specified cargo tank protection system.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3705(b) requires existing crude oil tankers of 40,000 deadweight tons or above to have segregated ballast tanks or a crude oil washing system. Compliance may be delayed until ","children":[{"tag":"date","attrib":{"date":"1985-06-01"},"text":"June 1, 1985","children":[],"tail":" for smaller tankers that have dedicated clean ballast tanks."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3705(c) requires existing crude oil tankers of 20,000 deadweight tons or above, but less than 40,000 deadweight tons, that are 15 years or older, to have segregated ballast tanks or a crude oil washing system by ","children":[{"tag":"date","attrib":{"date":"1985-01-01"},"text":"January 1, 1985","children":[],"tail":" or if less than 15 years old, by the date on which it reaches 15 years of age."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3705(d) requires existing crude oil tankers of 20,000 deadweight tons or above, to install an inert gas system. An exemption for crude oil tankers of less than 40,000 deadweight tons not fitted with high-capacity tank washing machines may be granted by the Secretary, only if it is demonstrated that compliance would be unreasonable and impracticable due to the vessel’s design characteristics.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3705(e) requires existing crude oil tankers of 20,000 deadweight tons or above, engaged in the transfer of oil from Outer Continental Shelf oil exploitation or production facilities, to have segregated ballast tanks or be operated with dedicated clean ballast tanks or special ballast arrangements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf66c2eee-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf66c2eef-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3544/b/1"},"text":"Pub. L. 115–232, § 3544(b)(1)","children":[],"tail":", struck out par. (1) designation after “(b)”, redesignated subpars. (A) and (B) of former par. (1) as pars. (1) and (2), respectively, and struck out former par. (2) which read as follows: “Compliance with paragraph (1) of this subsection may be delayed until "},{"tag":"date","attrib":{"date":"1985-06-01"},"text":"June 1, 1985","children":[],"tail":", for any tanker of less than 70,000 deadweight tons that has dedicated clean ballast tanks.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3544/b/2"},"text":"Pub. L. 115–232, § 3544(b)(2)","children":[],"tail":", struck out “before "},{"tag":"date","attrib":{"date":"1986-01-02"},"text":"January 2, 1986","children":[],"tail":", or the date on which the tanker reaches 15 years of age, whichever is later” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
