{"tag":"section","attrib":{"id":"idf6d0483e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201"},"text":null,"children":[{"tag":"num","attrib":{"value":"53201"},"text":"§ 53201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d0483f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cable services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “cable services” means the installation, maintenance, or repair of submarine cables and related equipment, and related cable vessel operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d04840-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cable vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cable vessel” means a vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d04841-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classed as a cable ship or cable vessel by, and designed in accordance with the rules of, the American Bureau of Shipping, or another classification society accepted by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d04842-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capable of installing, maintaining, and repairing submarine cables.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d04843-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cable fleet","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Cable Fleet” means the Cable Security Fleet established under section 53202(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d04844-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contingency agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Contingency Agreement” means the agreement required by section 53207.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d04845-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contractor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Contractor” means an owner or operator of a vessel that enters into an Operating Agreement for a cable vessel with the Secretary under section 53203.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d04846-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fiscal year","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “fiscal year” means any annual period beginning on October 1 and ending on September 30.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d04847-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operating agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Operating Agency” means that agency or component of the Department of Defense so designated by the Secretary of Defense under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d04848-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operating agreement or agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms “Operating Agreement” or “Agreement” mean the agreement required by section 53203.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d04849-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Person","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “person” includes corporations, partnerships, and associations existing under or authorized by the laws of the United States, or any State, Territory, District, or possession thereof, or of any foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d0484a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d0484b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “United States” includes the States, the District of Columbia, the Commonwealth of Puerto Rico, the Northern Mariana Islands, Guam, American Samoa, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d0484c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states citizen trust","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d0484d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (C), the term “United States citizen trust” means a trust that is qualified under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d0484e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A trust is qualified under this paragraph with respect to a vessel only if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6d0484f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/12/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it was created under the laws of a state of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6d04850-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/12/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the trustees is a citizen of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6d04851-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/12/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application for documentation of the vessel under chapter 121 of this title includes the affidavit of each trustee stating that the trustee is not aware of any reason involving a beneficiary of the trust that is not a citizen of the United States, or involving any other person that is not a citizen of the United States, as a result of which the beneficiary or other person would hold more than 25 percent of the aggregate power to influence, or limit the exercise of the authority of, the trustee with respect to matters involving any ownership or operation of the vessel that may adversely affect the interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d04852-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any person that is not a citizen of the United States has authority to direct, or participate in directing, the trustee for a trust in matters involving any ownership or operation of the vessel that may adversely affect the interests of the United States or in removing a trustee for a trust without cause, either directly or indirectly through the control of another person, the trust is not qualified under this paragraph unless the trust instrument provides that persons who are not citizens of the United States may not hold more than 25 percent of the aggregate authority to direct or remove a trustee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d04853-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53201/12/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This paragraph shall not be considered to prohibit a person who is not a citizen of the United States from holding more than 25 percent of the beneficial interest in a trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d04854-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3521/a"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3521(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1988"},"text":"133 Stat. 1988","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
