{"tag":"section","attrib":{"id":"idf6735bc1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4710"},"text":null,"children":[{"tag":"num","attrib":{"value":"4710"},"text":"§ 4710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735bc2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4710/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Abandon","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “abandon” means to moor, strand, wreck, sink, or leave a covered vessel unattended for longer than 45 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735bc3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4710/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered vessel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered vessel” means a vessel that is not a barge to which subchapter I applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735bc4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4710/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indian tribe","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Indian Tribe” has the meaning given such term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735bc5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4710/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Native hawaiian organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Native Hawaiian organization” has the meaning given such term in section 6207 of the Elementary and Secondary Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s7517"},"text":"20 U.S.C. 7517","children":[],"tail":") except the term includes the Department of Hawaiian Home Lands and the Office of Hawaiian Affairs."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6735bc6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7347/a/3"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7347(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1779"},"text":"139 Stat. 1779","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6735bc7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6735bc8-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6735bc9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7347/b"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7347(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1781"},"text":"139 Stat. 1781","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dG/tLXXIII/s7347/b"},"text":"“The Secretary of the department in which the Coast Guard is operating, in consultation with the Secretary of the Army, acting through the Chief of Engineers, and the Secretary of Commerce, acting through the Under Secretary for Oceans and Atmosphere, shall issue regulations with respect to the procedures for determining that a vessel is abandoned for the purposes of subchapter II of chapter 47 of title 46, United States Code (as added by this section).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
