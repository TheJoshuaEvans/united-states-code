{"tag":"section","attrib":{"id":"idf6d77481-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53507"},"text":null,"children":[{"tag":"num","attrib":{"value":"53507"},"text":"§ 53507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nontaxation of deposits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d77482-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tax Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), under the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"26 U.S.C. 1","children":[],"tail":" et seq.)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d77483-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taxable income (determined without regard to this chapter and section 7518 of such Code (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7518"},"text":"26 U.S.C. 7518","children":[],"tail":")) for the taxable year shall be reduced by the amount deposited for the taxable year out of amounts referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53505/a/1"},"text":"section 53505(a)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d77484-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a gain from a transaction referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53505/a/3"},"text":"section 53505(a)(3) of this title","children":[],"tail":" shall not be taken into account if an amount equal to the net proceeds (as defined in joint regulations) from the transaction is deposited in the fund;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d77485-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53507/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the earnings (including gains and losses) from the investment and reinvestment of amounts held in the fund shall not be taken into account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d77486-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53507/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the earnings and profits of a corporation (within the meaning of section 316 of such Code (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s316"},"text":"26 U.S.C. 316","children":[],"tail":")) shall be determined without regard to this chapter and section 7518 of such Code ("},{"tag":"ref","attrib":{"href":"/us/usc/t26/s7518"},"text":"26 U.S.C. 7518","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d77487-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53507/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in applying the tax imposed by section 531 of such Code (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s531"},"text":"26 U.S.C. 531","children":[],"tail":"), amounts held in the fund shall not be taken into account."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d77488-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53507/b"},"text":null,"childre