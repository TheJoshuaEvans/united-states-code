{"tag":"section","attrib":{"id":"idf6f66d48-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60105"},"text":null,"children":[{"tag":"num","attrib":{"value":"60105"},"text":"§ 60105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clearance of vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f66d49-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessels of the United States","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided by law, a vessel of the United States shall obtain clearance from the Secretary of Homeland Security before proceeding from a port or place in the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f66d4a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a foreign port or place;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f66d4b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for another port or place in the United States if the vessel has on board foreign merchandise for which entry has not been made; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f66d4c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60105/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outside the territorial sea to visit a hovering vessel or to receive merchandise while outside the territorial sea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f66d4d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided by law, a vessel that is not a vessel of the United States shall obtain clearance from the Secretary before proceeding from a port or place in the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f66d4e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a foreign port or place;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f66d4f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for another port or place in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f66d50-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outside the territorial sea to visit a hovering vessel or to receive or deliver merchandise while outside the territorial sea.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f66d51-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may by regulation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f66d52-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe the manner in which clearance under this section is to be obtained, including the documents, data, or information which shall be submitted or transmitted, pursuant to an authorized data interchange system, to obtain the clearance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f66d53-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit clearance to be obtained before all requirements for clearance are complied with, but only if the owner or operator of the vessel files a bond in an amount set by the Secretary conditioned on the compliance by the owner or operator with all specified requirements for clearance within a time period (not exceeding 4 business days) established by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f66d54-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60105/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit clearance to be obtained at a place other than a designated port of entry, under conditions the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f66d55-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s9/b"},"text":"Pub. L. 109–304, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1675"},"text":"120 Stat. 1675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f66d56-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f66d57-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f66d58-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60105","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:91.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 4197; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-08-05/ch438"},"text":"Aug. 5, 1935, ch. 438","children":[],"tail":", title II, § 209, "},{"tag":"html:a","attrib":{"href":"/us/stat/49/526"},"text":"49 Stat. 526","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1938-06-16/ch476/s1"},"text":"June 16, 1938, ch. 476, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/52/758"},"text":"52 Stat. 758","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1954-09-01/ch1213"},"text":"Sept. 1, 1954, ch. 1213","children":[],"tail":", title V, § 501(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1140"},"text":"68 Stat. 1140","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/182/tVI/s686/b"},"text":"Pub. L. 103–182, title VI, § 686(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/2221"},"text":"107 Stat. 2221","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/106/476/tI/s1452/a/3"},"text":"Pub. L. 106–476, title I, § 1452(a)(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/114/2167"},"text":"114 Stat. 2167","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security is substituted for the Customs Service and for the Secretary of the Treasury because the functions of the Customs Service and of the Secretary of the Treasury relating thereto were transferred to the Secretary of Homeland Security by section 403(1) of the Homeland Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2178"},"text":"116 Stat. 2178","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
