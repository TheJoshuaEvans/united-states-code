{"tag":"section","attrib":{"id":"idf67a605b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7309"},"text":null,"children":[{"tag":"num","attrib":{"value":"7309"},"text":"§ 7309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Able seamen—special","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The required service for the endorsement of able seaman—special, qualified for special service on a vessel on any waters, is at least 6 months ","children":[{"tag":"ref","attrib":{"idref":"fn002010"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002010"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “6 months’ ”."}],"tail":" service on deck on board vessels operating on the oceans or the navigable waters of the United States (including the Great Lakes)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf67a605c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/543"},"text":"97 Stat. 543","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/d/4"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1754"},"text":"139 Stat. 1754","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67a605d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf67a605e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:tabl