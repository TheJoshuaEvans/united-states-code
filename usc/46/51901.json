{"tag":"section","attrib":{"id":"idf6c91ce4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51901"},"text":null,"children":[{"tag":"num","attrib":{"value":"51901"},"text":"§ 51901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards for individual acts or service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c91ce5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may award decorations and medals of appropriate design (including ribbons, ribbon bars, emblems, rosettes, miniature facsimiles, plaques, citations, or other suitable devices or insignia) for individual acts or service in the merchant marine of the United States. The design may be similar to the design of a decoration or medal authorized for members of the armed forces for similar acts or service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c91ce6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c91ce7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Merchant Marine Distinguished Service Medal to an individual for outstanding acts, conduct, or valor beyond the line of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91ce8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Merchant Marine Meritorious Service Medal to an individual for meritorious acts, conduct, or valor in the line of duty, but not of the outstanding character that would warrant the award of the Merchant Marine Distinguished Service Medal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91ce9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51901/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decoration or medal to an individual for service during a war, national emergency proclaimed by the President or Congress, or operations by the armed forces outside the continental United States under conditions of danger to life and property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91cea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51901/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decoration or medal to an individual for other acts or service of conspicuous gallantry, intrepidity, and extraordinary heroism under conditions of danger to life and property that would warrant a similar decoration or medal for a member of the armed forces.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c91ceb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1584"},"text":"120 Stat. 1584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c91cec-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6c91ced-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6c91cee-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"