{"tag":"section","attrib":{"id":"idf6ac93c0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40104"},"text":null,"children":[{"tag":"num","attrib":{"value":"40104"},"text":"§ 40104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports filed with the Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ac93c1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ac93c2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Maritime Commission may require a common carrier or marine terminal operator, or an officer, receiver, trustee, lessee, agent, or employee of the common carrier or marine terminal operator to file with the Commission a periodical or special report, an account, record, rate, or charge, or a memorandum of facts and transactions related to the business of the common carrier or marine terminal operator, as applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93c3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any report, account, record, rate, charge, or memorandum required to be filed under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ac93c4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40104/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made under oath if the Commission requires; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ac93c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40104/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be filed in the form and within the time prescribed by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ac93c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40104/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ac93c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40104/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the scope of any filing ordered under this section to fulfill the objective of the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ac93c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40104/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a reasonable period of time for respondents to respond based upon their capabilities and the scope of the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ac93c9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conference Minutes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Conference minutes required to be filed with the Commission under this section may not be released to third parties or published by the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ac93ca-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1527"},"text":"120 Stat. 1527","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVII/s705"},"text":"Pub. L. 115–282, title VII, § 705","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4294"},"text":"132 Stat. 4294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ac93cb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ac93cc-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ac93cd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40104","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1714.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/98/237/s15"},"text":"Pub. L. 98–237, § 15","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 20, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/84"},"text":"98 Stat. 84","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/595/s3/b/3"},"text":"Pub. L. 98–595, § 3(b)(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/3133"},"text":"98 Stat. 3133","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tI/s113"},"text":"Pub. L. 105–258, title I, § 113","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1912"},"text":"112 Stat. 1912","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6ac93ce-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6ac93cf-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows: “The Federal Maritime Commission may require a common carrier or an officer, receiver, trustee, lessee, agent, or employee of the carrier to file with the Commission a periodical or special report, an account, record, rate, or charge, or a memorandum of facts and transactions related to the business of the carrier. The report, account, record, rate, charge, or memorandum shall be made under oath if the Commission requires, and shall be filed in the form and within the time prescribed by the Commission.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
