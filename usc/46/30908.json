{"tag":"section","attrib":{"id":"idf6a56835-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30908"},"text":null,"children":[{"tag":"num","attrib":{"value":"30908"},"text":"§ 30908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from arrest or seizure","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The following are not subject to arrest or seizure by judicial process in the United States:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a56836-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30908/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vessel owned by, possessed by, or operated by or for the United States or a federally-owned corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a56837-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30908/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cargo owned or possessed by the United States or a federally-owned corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a56838-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1518"},"text":"120 Stat. 1518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a56839-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a5683a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a5683b-2930-11f1-96a8-b9bd2a0a99b5"}