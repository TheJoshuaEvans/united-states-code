{"tag":"section","attrib":{"id":"idf683fcc6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301"},"text":null,"children":[{"tag":"num","attrib":{"value":"8301"},"text":"§ 8301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum number of licensed individuals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf683fcc7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in chapter 89 of this title and except for a vessel operating only on rivers, harbors, lakes (except the Great Lakes), bays, sounds, bayous, and canals, a vessel subject to inspection under chapter 33 of this title shall engage a minimum of licensed individuals as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf683fcc8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each of those vessels propelled by machinery or carrying passengers shall have a licensed master.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fcc9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A vessel of at least 1,000 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" and propelled by machinery shall have 3 licensed mates, except—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf683fcca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a vessel other than a mobile offshore drilling unit, if on a voyage of less than 400 miles from port of departure to port of final destination, the vessel shall have 2 licensed mates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf683fccb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a mobile offshore drilling unit, the vessel shall have licensed individuals as provided by regulations prescribed by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fccc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vessel of at least 200 gross tons but less than 1,000 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" and propelled by machinery shall have 2 licensed mates."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fccd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vessel of at least 100 gross tons but less than 200 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" and propelled by machinery shall have one licensed mate. However, if the vessel is on a voyage of more than 24 hours, it shall have 2 licensed mates."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fcce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A freight vessel or a passenger vessel of at least 300 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" and propelled by machinery shall have a licensed engineer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf683fccf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf683fcd0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An offshore supply vessel of less than 500 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":" or 6,000 gross tons as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" on a voyage of less than 600 miles shall have a licensed mate. If the vessel is on a voyage of at least 600 miles, however, the vessel shall have 2 licensed mates."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fcd1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An offshore supply vessel of at least 6,000 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" on a voyage of less than 600 miles shall have at least two licensed mates, provided the offshore supply vessel meets the requirements of section 8104(g)(2). An offshore supply vessel of at least 6,000 gross tons as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" on a voyage of at least 600 miles shall have three licensed mates."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fcd2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An offshore supply vessel of more than 200 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":", may not be operated without a licensed engineer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf683fcd3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) of this section does not apply to a fishing or whaling vessel, a mobile offshore drilling unit when on location, or a yacht.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf683fcd4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf683fcd5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend any part of this chapter during a national emergency proclaimed by the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf683fcd6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the number of licensed individuals on a vessel to which this chapter applies if, in the Secretary’s judgment, the vessel is not sufficiently manned for safe operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf683fcd7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s8301/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may prescribe the minimum number of licensed individuals for an oil spill response vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf683fcd8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/550"},"text":"97 Stat. 550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s29/c"},"text":"Pub. L. 98–557, § 29(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2873"},"text":"98 Stat. 2873","children":[],"tail":", 2874; "},{"tag":"ref","attrib":{"href":"/us/pl/99/640/s11/d"},"text":"Pub. L. 99–640, § 11(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3550"},"text":"100 Stat. 3550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/448/s7"},"text":"Pub. L. 100–448, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-28"},"text":"Sept. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1842"},"text":"102 Stat. 1842","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/206/tIII/s322/b"},"text":"Pub. L. 103–206, title III, § 322(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2428"},"text":"107 Stat. 2428","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s729"},"text":"Pub. L. 104–324, title VII, § 729","children":[],"tail":", title XI, § 1104(d), "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3940"},"text":"110 Stat. 3940","children":[],"tail":", 3967; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tVI/s617/c"},"text":"Pub. L. 111–281, title VI, § 617(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2973"},"text":"124 Stat. 2973","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf683fcd9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf683fcda-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf683fcdb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8301","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:223","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:404–1(8)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 8301 prescribes the minimum number of licensed individuals on board certain vessels based on the vessel’s size or propulsion, length of voyage by distance or time, or any combination of these factors.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) applies to certain merchant and passenger carrying vessels of the United States, each of which must have a licensed master regardless of the factors listed above. Subsection (b) applies to offshore supply vessels. Subsection (c) exempts fishing or whaling vessels or yachts from these requirements.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) permits the Secretary to suspend any part of this chapter during a declared national emergency or to increase the number of licensed individuals required by this chapter if required for safe operation of a vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf683fcdc-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf683fcdd-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “An offshore supply vessel on a voyage of less than 600 miles shall have a licensed mate. However, if the vessel is on a voyage of at least 600 miles, the vessel shall have 2 licensed mates. An offshore supply vessel of more than 200 gross tons as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" may not be operated without a licensed engineer.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s729/1"},"text":"Pub. L. 104–324, § 729(1)","children":[],"tail":", inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “1,000 gross tons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s729/2"},"text":"Pub. L. 104–324, § 729(2)","children":[],"tail":", inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “1,000 gross tons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s729/3"},"text":"Pub. L. 104–324, § 729(3)","children":[],"tail":", inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “200 gross tons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s729/4"},"text":"Pub. L. 104–324, § 729(4)","children":[],"tail":", inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “300 gross tons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s729/5"},"text":"Pub. L. 104–324, § 729(5)","children":[],"tail":", inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “200 gross tons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/s1104/d"},"text":"Pub. L. 104–324, § 1104(d)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, subsec. (e) read as follows: “A vessel used only to respond to a discharge of oil or a hazardous substance shall have—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) two licensed mates when the vessel is engaged in an operation over 12 hours in duration;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) one licensed mate when the vessel is engaged in an operation less than 12 hours in duration; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) if the vessel is more than 200 gross tons, a licensed engineer when the vessel is operating.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206"},"text":"Pub. L. 103–206","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/448"},"text":"Pub. L. 100–448","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “A vessel of at least 1,000 gross tons and propelled by machinery shall have 3 licensed mates. However, if the vessel is on a voyage of less than 400 miles from port of departure to port of final destination, it shall have 2 licensed mates.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/640"},"text":"Pub. L. 99–640","children":[],"tail":" inserted “, a mobile offshore drilling unit when on location,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557/s29/c"},"text":"Pub. L. 98–557, § 29(c)","children":[],"tail":", in provisions preceding par. (1) inserted exception for the Great Lakes and substituted provisions relating to inspection under chapter 33 of this title for provisions relating to applicability of part B of this subtitle."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557/s29/d"},"text":"Pub. L. 98–557, § 29(d)","children":[],"tail":", inserted “propelled by machinery or carrying passengers”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
