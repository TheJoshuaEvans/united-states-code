{"tag":"section","attrib":{"id":"idf6bac553-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401"},"text":null,"children":[{"tag":"num","attrib":{"value":"50401"},"text":"§ 50401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Committee on the Marine Transportation System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6bac554-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a United States Committee on the Marine Transportation System (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bac555-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall serve as a Federal interagency coordinating committee for the purpose of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bac556-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the adequacy of the marine transportation system (including ports, waterways, channels, and their intermodal connections);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac557-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the integration of the marine transportation system with other modes of transportation and other uses of the marine environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bac558-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating, improving the coordination of, and making recommendations with regard to Federal policies that impact the marine transportation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bd3559-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bd355a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall consist of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bd355b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd355c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd355d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd355e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd355f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3560-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3561-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3562-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3563-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3564-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3565-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3566-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Environmental Protection Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3567-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Federal Maritime Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3568-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Joint Chiefs of Staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3569-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/1/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of any other Federal agency who a majority of the voting members of the Committee determines can further the purpose and activities of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd356a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonvoting members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee may include as many nonvoting members as a majority of the voting members of the Committee determines is appropriate to further the purpose and activities of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bd356b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bd356c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordinating board.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bd356d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is hereby established, within the Committee, a Coordinating Board. Each member of the Committee may select a senior level representative to serve on such Board. The Board shall assist the Committee in carrying out its purpose and activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd356e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chair","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There shall be a Chair of the Coordinating Board. The Chair of the Coordinating Board shall rotate each year among the Secretary of Transportation, the Secretary of Defense, the Secretary of Homeland Security, and the Secretary of Commerce. The order of rotation shall be determined by a majority of the voting members of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd356f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation, in consultation with the Secretary of Defense, the Secretary of Homeland Security, and the Secretary of Commerce, shall appoint an Executive Director of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd3570-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the head of a Federal department or agency who is a member of the Committee may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6bd3571-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, on a reimbursable or nonreimbursable basis, facilities, equipment, services, personnel, and other support services to carry out the activities of the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6bd3572-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer funds to another Federal department or agency in order to carry out the activities of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bd3573-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Marine Transportation System Assessment and Strategy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after the date of enactment of this Act and every 5 years thereafter, the Committee shall provide to the Committee on Commerce, Science, and Transportation and the Committee on Environment and Public Works of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bd3574-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steps taken to implement actions recommended in the document titled “National Strategy for the Marine Transportation System: A Framework for Action” and dated July 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd3575-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conditions and performance analysis of the marine transportation system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd3576-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discussion of the challenges the marine transportation system faces in meeting user demand, including estimates of investment levels required to ensure system infrastructure meets such demand;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd3577-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan, with recommended actions, for improving the marine transportation system to meet current and future challenges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd3578-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" steps taken to implement actions recommended in previous reports required under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd3579-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a compendium of the Federal programs engaged in the maritime transportation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6bd357a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50401/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out its purpose and activities, the Committee may consult with marine transportation system-related advisory committees, interested parties, and the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6bd357b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/tIII/s310/a"},"text":"Pub. L. 112–213, title III, § 310(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1567"},"text":"126 Stat. 1567","children":[],"tail":", § 55502; renumbered § 55501, "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIII/s301/2"},"text":"Pub. L. 113–281, title III, § 301(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3042"},"text":"128 Stat. 3042","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8315, "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4699"},"text":"134 Stat. 4699","children":[],"tail":"; renumbered § 50401 and amended, "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dC/tXXXV/s3512/a/3"},"text":"Pub. L. 117–81, div. C, title XXXV, § 3512(a)(3)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2239"},"text":"135 Stat. 2239","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6bd357c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6bd357d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6bd357e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this Act, referred to in subsec. (e), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":", which enacted this section and was approved "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6bd357f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s3512/a/4"},"text":"Pub. L. 117–81, § 3512(a)(4)","children":[],"tail":", amended section catchline generally, substituting “United States Committee on the Marine Transportation System” for “United States Committee on the Marine Transportation System”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s3512/a/3"},"text":"Pub. L. 117–81, § 3512(a)(3)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s55501"},"text":"section 55501 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8315/1"},"text":"Pub. L. 116–283, § 8315(1)","children":[],"tail":", substituted “a conditions and performance analysis” for “an assessment of the condition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8315/2"},"text":"Pub. L. 116–283, § 8315(2)","children":[],"tail":"–(4), added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s55502"},"text":"section 55502 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
