{"tag":"section","attrib":{"id":"idf6ef41d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56307"},"text":null,"children":[{"tag":"num","attrib":{"value":"56307"},"text":"§ 56307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of vessels","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When a vessel requisitioned for use but not ownership is returned to the owner, the Secretary of Transportation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ef41d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56307/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" return the vessel in a condition at least as good as when taken, less ordinary wear and tear; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ef41d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56307/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay the owner an amount sufficient to recondition the vessel to that condition, less ordinary wear and tear.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ef41d6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1656"},"text":"120 Stat. 1656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ef41d7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ef41d8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ef41d9