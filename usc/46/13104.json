{"tag":"section","attrib":{"id":"idf699816d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13104"},"text":null,"children":[{"tag":"num","attrib":{"value":"13104"},"text":"§ 13104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf699816e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall allocate amounts available for allocation and distribution under this chapter for State recreational boating safety programs as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf699816f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One-third shall be allocated equally each fiscal year among eligible States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6998170-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One-third shall be allocated among eligible States that maintain a State vessel numbering system approved under chapter 123 of this title and a marine casualty reporting system approved under this chapter so that the amount allocated each fiscal year to each eligible State will be in the same ratio as the number of vessels numbered in that State bears to the number of vessels numbered in all eligible States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6998171-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13104/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One-third shall be allocated so that the amount allocated each fiscal year to each eligible State will be in the same ratio as the amount of State amounts expended by the State for the State recreational boating safety program during the prior fiscal year bears to the total State amounts expended during that fiscal year by all eligible States for State recreational boating safety programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6998172-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount received by a State under this section in a fiscal year may be not more than one-half of the total cost incurred by that State in developing, carrying out, and financing that State’s recreational boating safety program in that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6998173-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may allocate not more than 5 percent of the amounts available for allocation and distribution in a fiscal year for national boating safety activities of national nonprofit public service organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6998174-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/594"},"text":"97 Stat. 594","children":[],"tail":", § 13103; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tX/s1011/d"},"text":"Pub. L. 98–369, div. A, title X, § 1011(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1013"},"text":"98 Stat. 1013","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/595/tIII/s312/c"},"text":"Pub. L. 101–595, title III, § 312(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2987"},"text":"104 Stat. 2987","children":[],"tail":"; renumbered § 13104, "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s16/b/1"},"text":"Pub. L. 109–304, § 16(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1705"},"text":"120 Stat. 1705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6998175-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6998176-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6998177-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"13103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:1476","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 13103 requires the Secretary to allocate the amounts available for recreational boating safety and facilities improvement programs according to a specific formula:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) ⅓ shall be allocated equally to each eligible State:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) ⅓ shall be allocated to those States maintaining an approved numbering system; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(3) ⅓ shall be allocated to the State in the proportion that the State obligated in the prior fiscal year to the total amount obligated by all of the States in the prior fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6998178-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf6998179-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 13104 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s13105"},"text":"section 13105 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf699817a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s13103"},"text":"section 13103 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/595"},"text":"Pub. L. 101–595","children":[],"tail":" struck out “or obligated” after “expended” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1011/d"},"text":"Pub. L. 98–369, § 1011(d)","children":[],"tail":", redesignated subsec. (c) as (b), struck out “and facilities improvement” after “boating safety”, and struck out former subsec. (b) which related to allocation of amounts for State recreational boating facilities improvement programs by the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1011/d/1"},"text":"Pub. L. 98–369, § 1011(d)(1)","children":[],"tail":", redesignated subsec. (e) as (c). Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1011/d/1"},"text":"Pub. L. 98–369, § 1011(d)(1)","children":[],"tail":", struck out subsec. (d) which provided that an allocation or distribution of amounts under this section may not be made to a State to maintain boating facilities under that State’s approved recreational boating safety and facilities improvement program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1011/d/1"},"text":"Pub. L. 98–369, § 1011(d)(1)","children":[],"tail":", redesignated subsec. (e) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1011/d/1"},"text":"Pub. L. 98–369, § 1011(d)(1)","children":[],"tail":", struck out subsec. (f) which provided that the Secretary could extend amounts necessary to carry out this chapter but that there was a limitation on the total amount allocable."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf699817b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf699817c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"Oct. 1, 1984","children":[],"tail":", to apply with respect to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1984-09-30"},"text":"Sept. 30, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s1013"},"text":"section 1013 of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s13101"},"text":"section 13101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf699817d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Payment of Administrative Costs; Retention of Amount Prior to Allocations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/640/s7/d"},"text":"Pub. L. 99–640, § 7(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3548"},"text":"100 Stat. 3548","children":[],"tail":", which related to retention of amounts appropriated for State recreational boating safety programs prior to making allocations for a fiscal year, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/100/448/s6/b/1/B"},"text":"Pub. L. 100–448, § 6(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-28"},"text":"Sept. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1840"},"text":"102 Stat. 1840","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
