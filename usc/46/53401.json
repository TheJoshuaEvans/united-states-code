{"tag":"section","attrib":{"id":"idf6d50343-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401"},"text":null,"children":[{"tag":"num","attrib":{"value":"53401"},"text":"§ 53401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d50344-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign commerce","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign commerce” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d50345-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commerce or trade between the United States, its territories or possessions, or the District of Columbia, and a foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d50346-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commerce or trade between foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d50347-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participating fleet vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “participating Fleet vessel” means any product tank vessel covered by an operating agreement under this chapter on or after ","children":[{"tag":"date","attrib":{"date":"2022-01-01"},"text":"January 1, 2022","children":[],"tail":", that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d50348-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements of one of paragraphs (1) through (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53402/b"},"text":"section 53402(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d50349-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is no more than 20 years of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d5034a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Person","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “person” includes corporations, partnerships, and associations existing under, or authorized by, laws of the United States, or any State, territory, district, or possession thereof, or any foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d5034b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Product tank vessel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “product tank vessel” means a double-hulled tank vessel capable of carrying simultaneously more than 2 separated grades of refined petroleum products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d5034c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program participant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “program participant” means an owner or operator of a vessel that enters into an operating agreement covering a participating fleet vessel with the Secretary under section 53403.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d5034d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” means the Secretary of Transportation, unless the context indicates otherwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d5034e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states citizen trust","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States citizen trust”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d5034f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a trust for which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6d50350-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the trustees is a citizen of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6d50351-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application for documentation of the vessel under chapter 121 of this title includes an affidavit of each trustee stating that the trustee is not aware of any reason involving a beneficiary of the trust that is not a citizen of the United States, or involving any other person who is not a citizen of the United States, as a result of which the beneficiary or other person would hold more than 25 percent of the aggregate power to influence or limit the exercise of the authority of the trustee with respect to matters involving any ownership or operation of the vessel that may adversely affect the interests of the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d50352-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a trust for which any person that is not a citizen of the United States has authority to direct, or participate in directing, a trustee for a trust in matters involving any ownership or operation of the vessel that may adversely affect the interests of the United States or in removing a trustee without cause, either directly or indirectly through the control of another person, unless the trust instrument provides that persons who are not citizens of the United States may not hold more than 25 percent of the aggregate authority to so direct or remove a trustee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d50353-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include a trust for which a person who is not a citizen of the United States holds more than 25 percent of the beneficial interest in the trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d50354-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53401/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Long term charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “long term charter” means any time charter of a product tank vessel to the United States Government that, together with options, occurs for a continuous period of more than 180 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d50355-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dC/tXXXV/s3511/a"},"text":"Pub. L. 116–283, div. C, title XXXV, § 3511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4408"},"text":"134 Stat. 4408","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dC/tXXXV/s3515/a"},"text":"Pub. L. 117–81, div. C, title XXXV, § 3515(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2243"},"text":"135 Stat. 2243","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d50356-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6d50357-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6d50358-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" added par. (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6d50359-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf6d5035a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dC/tXXXV/s3511/d"},"text":"Pub. L. 116–283, div. C, title XXXV, § 3511(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4419"},"text":"134 Stat. 4419","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dC/tXXXV/s3511/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section [enacting this chapter and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53402"},"text":"section 53402 of this title","children":[],"tail":"] shall take effect on the date on which the Secretary of Defense—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed the report on United States flagged fuel tanker vessel capacity as required by section 3519 of the National Defense Authorization Act for Fiscal Year 2020 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1987"},"text":"133 Stat. 1987","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has submitted that report to the appropriate committees of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" publishes certification—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a program for United States-flagged fuel tanker vessels as prescribed in chapter 534 of title 46, United States Code, as amended by this section, for the purpose of providing additional United States-flagged fuel tanker vessels is in the national security interest of the United State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the number of such additional tankers covered under such a program that could be necessary to meet Department of Defense wartime requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate committees of congress defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section the term ‘appropriate committees of Congress’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation and the Committee on Armed Services of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure and the Committee on Armed Services of the House of Representatives.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
