{"tag":"section","attrib":{"id":"idf6998122-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12507"},"text":null,"children":[{"tag":"num","attrib":{"value":"12507"},"text":"§ 12507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6998123-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person shall be fined under title 18, imprisoned for not more than 2 years, or both, if the person with the intent to defraud—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6998124-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides false information to the Secretary of Transportation or a State issuing authority regarding the identification of a vessel under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6998125-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tampers with, removes, or falsifies the unique vessel identification number assigned to a vessel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12502"},"text":"section 12502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6998126-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person is liable to the United States Government for a civil penalty of not more than $10,000 if the person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6998127-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides false information to the Secretary or a State issuing authority regarding the identification of a vessel under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6998128-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12502"},"text":"section 12502 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6998129-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12507/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to comply with requirements prescribed by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12505"},"text":"section 12505 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf699812a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vessel involved in a violation of this chapter, or regulation under this chapter, and its equipment, may be seized by, and forfeited to, the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf699812b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12507/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person, not an individual, is involved in a violation of this chapter, the president or chief executive of the person also is subject to any penalty provided under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf699812c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s101/a"},"text":"Pub. L. 100–710, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4737"},"text":"102 Stat. 4737","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf699812d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf699812e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 12507","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section establishes criminal and civil penalties for certain violations of chapter 125 of title 46 (as enacted by this Act).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf699812f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf6998130-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/710/s107"},"text":"section 107 of Pub. L. 100–710","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s31301"},"text":"section 31301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
