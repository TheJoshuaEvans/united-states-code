{"tag":"section","attrib":{"id":"idf66e7941-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4306"},"text":null,"children":[{"tag":"num","attrib":{"value":"4306"},"text":"§ 4306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Unless permitted by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s4305"},"text":"section 4305 of this title","children":[],"tail":", a State or political subdivision of a State may not establish, continue in effect, or enforce a law or regulation establishing a recreational vessel or associated equipment performance or other safety standard or imposing a requirement for associated equipment (except insofar as the State or political subdivision may, in the absence of the Secretary’s disapproval, regulate the carrying or use of marine safety articles to meet uniquely hazardous conditions or circumstances within the State) that is not identical to a regulation prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s4302"},"text":"section 4302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf66e7942-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/531"},"text":"97 Stat. 531","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf66e7943-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf66e7944-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf66e7945-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4306","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:1459","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:1460","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4306 establishes the Federal preemption of recreational boating standards and requirements. A State or a political subdivision may not establish, continue, or enforce a law or regulation establishing a performance or other safety standard that is not identical to a Federal standard. The Secretary may grant an exemption to a State when the State requirement is one that is needed to meet uniquely hazardous conditions or circumstances within a State. This is to provide uniform standards without the imposition of excessive special requirements by individual States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
