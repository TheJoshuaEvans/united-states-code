{"tag":"section","attrib":{"id":"idf6591c8e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2305"},"text":null,"children":[{"tag":"num","attrib":{"value":"2305"},"text":"§ 2305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6591c8f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The district courts of the United States have jurisdiction to enjoin the negligent operation of vessels prohibited by this chapter on the petition of the Attorney General for the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6591c90-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When practicable, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6591c91-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give notice to any person against whom an action for injunctive relief is considered under this section an opportunity to present that person’s views; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6591c92-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except for a knowing and willful violation, give the person a reasonable opportunity to achieve compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6591c93-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The failure to give notice and opportunity to present views under subsection (b) of this section does not preclude the court from granting appropriate relief.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6591c94-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/509"},"text":"97 Stat. 509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6591c95-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6591c96-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6591c97-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2305","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:1485","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2305 provides injunctive authority to enjoin the negligent operation of vessels. This authority can also be used to enjoin the operation of foreign or domestic vessels on our waters when they are unsuitable for the voyage intended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
