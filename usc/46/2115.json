{"tag":"section","attrib":{"id":"idf656ac10-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2115"},"text":null,"children":[{"tag":"num","attrib":{"value":"2115"},"text":"§ 2115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty to enforce alcohol and dangerous drug testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who fails to implement or conduct, or who otherwise fails to comply with the requirements prescribed by the Secretary for, chemical testing for dangerous drugs or for evidence of alcohol use, as prescribed under this subtitle or a regulation prescribed by the Secretary to carry out the provisions of this subtitle, is liable to the United States Government for a civil penalty of not more than $5,000 for each violation. Each day of a continuing violation shall constitute a separate violation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf656ac11-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tIII/s303/a"},"text":"Pub. L. 104–324, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3917"},"text":"110 Stat. 3917","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIII/s304/b"},"text":"Pub. L. 105–383, title III, § 304(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3419"},"text":"112 Stat. 3419","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf656ac12-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf656ac13-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf656ac14-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383"},"text":"Pub. L. 105–383","children":[],"tail":" substituted “$5,000” for “$1,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
