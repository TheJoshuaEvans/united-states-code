{"tag":"section","attrib":{"id":"idf69e3b8b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14511"},"text":null,"children":[{"tag":"num","attrib":{"value":"14511"},"text":"§ 14511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"This subchapter applies to a vessel described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14501"},"text":"section 14501 of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf69e3b8c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14511/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner requests; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69e3b8d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14511/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the vessel is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf69e3b8e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14511/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" self-propelled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69e3b8f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14511/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 24 meters (79 feet) overall in length; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69e3b90-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14511/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not operated only for pleasure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf69e3b91-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5101/3"},"text":"Pub. L. 99–509, title V, § 5101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1924"},"text":"100 Stat. 1924","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69e3b92-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69e3b93-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 14511","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Source: Section (U.S. Code) 46 App. U.S.C. 71.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 14511 lists the types of vessels that are to be measured under the standard regulatory measurement system. They are vessels for which the owner requests a standard measurement or vessels which are self-propelled, at least 79 feet in length, and not operated only for pleasure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
