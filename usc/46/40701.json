{"tag":"section","attrib":{"id":"idf6aedd8e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40701"},"text":null,"children":[{"tag":"num","attrib":{"value":"40701"},"text":"§ 40701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6aedd8f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A controlled carrier may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aedd90-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a rate or charge in a tariff or service contract, or charge or assess a rate, that is below a just and reasonable level; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd91-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, maintain, or enforce in a tariff or service contract a classification, rule, or regulation that results, or is likely to result, in the carriage or handling of cargo at a rate or charge that is below a just and reasonable level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd92-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commission Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Maritime Commission, at any time after notice and opportunity for a hearing, may prohibit the publication or use of a rate, charge, classification, rule, or regulation that a controlled carrier has failed to demonstrate is just and reasonable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd93-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Burden of Proof","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a proceeding under this section, the burden of proof is on the controlled carrier to demonstrate that its rate, charge, classification, rule, or regulation is just and reasonable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd94-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40701/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voidness","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A rate, charge, classification, rule, or regulation that has been suspended or prohibited by the Commission is void and its use is unlawful.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6aedd95-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1535"},"text":"120 Stat. 1535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6aedd96-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6aedd97-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6aedd98-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":