{"tag":"section","attrib":{"id":"idf6f8dfe1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70004"},"text":null,"children":[{"tag":"num","attrib":{"value":"70004"},"text":"§ 70004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations by Secretary","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out the duties of the Secretary under sections 70001, 70002, and 70003, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f8dfe2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70004/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" take into account all relevant factors concerning navigation and vessel safety, protection of the marine environment, and the safety and security of United States ports and waterways, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6f8dfe3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70004/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scope and degree of the risk or hazard involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f8dfe4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70004/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vessel traffic characteristics and trends, including traffic volume, the sizes and types of vessels involved, potential interference with the flow of commercial traffic, the presence of any unusual cargoes, and other similar factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f8dfe5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70004/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" port and waterway configurations and variations in local conditions of geography, climate, and other similar factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f8dfe6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70004/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for granting exemptions for the installation and use of equipment or devices for use with vessel traffic services for certain classes of small vessels, such as self-propelled fishing vessels and recreational vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f8dfe7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70004/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proximity of fishing grounds, oil and gas drilling and production operations, or any other potential or actual conflicting activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f8dfe8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70004/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f8dfe9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70004/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic impact and effects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f8dfea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70004/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing vessel traffic services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f8dfeb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70004/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local practices and customs, including voluntary arrangements and agreements within the maritime community; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f8dfec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70004/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the earliest possible time, consult with and receive and consider the views of representatives of the maritime community, ports and harbor authorities or associations, environmental groups, and other persons who may be affected by the proposed actions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f8dfed-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIV/s401/a"},"text":"Pub. L. 115–282, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4257"},"text":"132 Stat. 4257","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
