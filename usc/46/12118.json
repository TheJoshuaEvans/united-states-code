{"tag":"section","attrib":{"id":"idf6949f6f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118"},"text":null,"children":[{"tag":"num","attrib":{"value":"12118"},"text":"§ 12118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Owners engaged primarily in manufacturing or mineral industry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6949f70-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6949f71-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bowaters corporation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Bowaters corporation” means a corporation that has filed a certificate under oath with the Secretary, in the form and at the times prescribed by the Secretary, establishing that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6949f72-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the corporation is incorporated under the laws of the United States or a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949f73-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a majority of the officers and directors of the corporation are individuals who are citizens of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949f74-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 90 percent of the employees of the corporation are residents of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949f75-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the corporation is engaged primarily in a manufacturing or mineral industry in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949f76-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total book value of the vessels owned by the corporation is not more than 10 percent of the total book value of the assets of the corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949f77-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the corporation buys or produces in the United States at least 75 percent of the raw materials used or sold in its operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f78-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Parent","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “parent” means a corporation that has filed a certificate under oath with the Secretary, in the form and at the times prescribed by the Secretary, establishing that the corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6949f79-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incorporated under the laws of the United States or a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949f7a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" controls, directly or indirectly, at least 50 percent of the voting stock of a Bowaters corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f7b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsidiary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “subsidiary” means a corporation that has filed a certificate under oath with the Secretary, in the form and at the times prescribed by the Secretary, establishing that the corporation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6949f7c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incorporated under the laws of the United States or a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949f7d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at least 50 percent of its voting stock controlled, directly or indirectly, by a Bowaters corporation or its parent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949f7e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deemed Citizen","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Bowaters corporation is deemed to be a citizen of the United States for purposes of chapters 121, 551, and 561 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s80104"},"text":"section 80104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949f7f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance of Documentation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A certificate of documentation and appropriate endorsement may be issued for a vessel that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6949f80-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned by a Bowaters corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f81-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was built in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f82-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6949f83-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is self-propelled and less than 500 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949f84-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not self-propelled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949f85-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effects of Documentation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6949f86-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6949f87-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel documented under this section may engage in the coastwise trade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949f88-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel and its owner and master are entitled to the same benefits and are subject to the same requirements and penalties as if the vessel were otherwise documented or exempt from documentation under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f89-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation of passengers or merchandise","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel documented under this section may transport passengers or merchandise for hire in the coastwise trade only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6949f8a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a service for a parent or subsidiary of the corporation owning the vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6949f8b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" when under a demise or bareboat charter, at prevailing rates for use not in the domestic noncontiguous trades, from the corporation owning the vessel to a carrier that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6949f8c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to jurisdiction under subchapter II of chapter 135 of title 49;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6949f8d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise qualifies as a citizen of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6949f8e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not owned or controlled, directly or indirectly, by the corporation owning the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949f8f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Validity of Corporate Certificate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A certificate filed by a corporation under this section remains valid only as long as the corporation continues to satisfy the conditions required of the corporation by this section. When a corporation no longer satisfies those conditions, the corporation loses its status under this section and immediately shall surrender to the Secretary any documents issued to it based on that status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949f90-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6949f91-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Falsifying material fact","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a corporation knowingly falsifies a material fact in a certificate filed under subsection (a), the vessel (or its value) documented or operated under this section shall be forfeited.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f92-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transporting merchandise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a vessel transports merchandise for hire in violation of this section, the merchandise shall be forfeited to the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f93-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transporting passengers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a vessel transports passengers for hire in violation of this section, the vessel is liable for a penalty of $200 for each passenger so transported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f94-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12118/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remission or mitigation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A penalty or forfeiture incurred under this subsection may be remitted or mitigated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2107/b"},"text":"section 2107(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"ta