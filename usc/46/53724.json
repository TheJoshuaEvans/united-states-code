{"tag":"section","attrib":{"id":"idf6e0e9f4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53724"},"text":null,"children":[{"tag":"num","attrib":{"value":"53724"},"text":"§ 53724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights to secured property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e0e9f5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquisition of Security Rights","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Secretary or Administrator makes a payment on, or assumes, an obligation under section 53721 or 53722 of this title, the Secretary or Administrator acquires the rights under the security agreement with the obligor in the security held by the Secretary or Administrator to guarantee the obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0e9f6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use and Disposition of Secured Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other law relating to the acquisition, handling, or disposal of property by the United States Government, the Secretary or Administrator has the right, in the Secretary’s or Administrator’s discretion, to complete, reconstruct, recondition, renovate, repair, maintain, operate, charter, or sell any property acquired under a security agreement with an obligor, or to place a vessel so acquired in the National Defense Reserve Fleet. The terms of a sale under this subsection shall be as approved by the Secretary or Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e0e9f7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1619"},"text":"120 Stat. 1619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/F"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/10/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(10)(B)","children":[],"tail":", (11), (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e0e9f8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e0e9f9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e0e9fa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"