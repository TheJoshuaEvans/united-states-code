{"tag":"section","attrib":{"id":"idf675a581-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s5110"},"text":null,"children":[{"tag":"num","attrib":{"value":"5110"},"text":"§ 5110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submersible vessels","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding sections 5103–5105 of this title, the Secretary may prescribe regulations for submersible vessels to provide a minimum level of safety. In developing the regulations, the Secretary shall consider factors relevant to submersible vessels, including the structure, stability, and watertight integrity of those vessels.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf675a582-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5101/2"},"text":"Pub. L. 99–509, title V, § 5101(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1917"},"text":"100 Stat. 1917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf675a583-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf675a584-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 5110","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5110 authorizes the Secretary to prescribe regulations for the marking of load lines of submersible vessels. This general authority has been included in anticipation of the commercial development of submersibles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
