{"tag":"section","attrib":{"id":"idf6e35ac6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53909"},"text":null,"children":[{"tag":"num","attrib":{"value":"53909"},"text":"§ 53909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" War risk insurance revolving fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e35ac7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is a war risk insurance revolving fund in the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35ac8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There shall be deposited in the fund amounts appropriated to carry out this chapter and amounts received in carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35ac9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53909/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There shall be paid from the fund amounts for return premiums, losses, settlements, judgments, and all liabilities incurred by the United States Government under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e35aca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53909/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may request the Secretary of the Treasury to invest such portion of the fund as is not, in the judgment of the Secretary of Transportation, required to meet the current needs of the fund. These investments shall be made by the Secretary of the Treasury in public debt securities of the Government, with maturities suitable to the needs of the fund, and bearing interest rates determined by the Secretary of the Treasury, taking into consideration current market yields on outstanding marketable obligations of the Government of comparable maturity. Interest and benefits from the securities shall be deposited in the fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e35acb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1630"},"text":"120 Stat. 1630","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dC/tXXXV/s3510/a/1"},"text":"Pub. L. 109–364, div. C, title XXXV, § 3510(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2520"},"text":"120 Stat. 2520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3526/g"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3526(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/602"},"text":"122 Stat. 602","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e35acc-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e35acd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e35ace-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53909","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1288.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XII, § 1208, as added "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-07/ch906"},"text":"Sept. 7, 1950, ch. 906","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/775"},"text":"64 Stat. 775","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/87/743"},"text":"Pub. L. 87–743","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 3, 1962","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/76/740"},"text":"76 Stat. 740","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/139"},"text":"Pub. L. 97–31, § 12(139)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/166"},"text":"95 Stat. 166","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/108/375/dC/tXXXV/s3502/b"},"text":"Pub. L. 108–375, div. C, title XXXV, § 3502(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/118/2195"},"text":"118 Stat. 2195","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1288a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1951-11-01/ch664"},"text":"Nov. 1, 1951, ch. 664","children":[],"tail":", par. under heading “War–Risk Insurance Revolving Fund”, "},{"tag":"html:a","attrib":{"href":"/us/stat/65/746"},"text":"65 Stat. 746","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/140"},"text":"Pub. L. 97–31, § 12(140)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/166"},"text":"95 Stat. 166","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the reference to the Fiscal Service [previously Division of Disbursement] in the Treasury Department is omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/s3502/b"},"text":"section 3502(b) of Public Law 108–375","children":[],"tail":", which struck the third sentence in 46 App. U.S.C. 1288 and inserted new material, was executed as if it were intended to strike the fourth sentence instead, to reflect probably [sic] intent."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of 46 App. U.S.C. 1288(b) is omitted as unnecessary because enactment of a law authorizing certain governmental functions is itself an authorization of appropriations to carry out those functions. The text of 46 App. U.S.C. 1288a is omitted as executed and impliedly repealed by 46 App. U.S.C. 1119.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6e35acf-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6e35ad0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3510/a/1"},"text":"Pub. L. 109–364, § 3510(a)(1)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/s3510/a/1"},"text":"Pub. L. 109–364, § 3510(a)(1)","children":[],"tail":", which directed the amendment of section 1288(a) of the former Appendix to this title from which this section was derived in part, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":". The substance of the amendment was incorporated in this section as enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":". See Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6e35ad1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6e35ad2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dC/tXXXV/s3510/a/2"},"text":"Pub. L. 109–364, div. C, title XXXV, § 3510(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2520"},"text":"120 Stat. 2520","children":[],"tail":", which provided that the amendments made by paragraph (1) [amending section 1288(a) of the former Appendix to this title, from which this section was derived in part] were to be effective as if enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/s3502"},"text":"section 3502 of Pub. L. 108–375","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3526/g"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3526(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/602"},"text":"122 Stat. 602","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
