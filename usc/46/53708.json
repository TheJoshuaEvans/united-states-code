{"tag":"section","attrib":{"id":"idf6dc2eee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708"},"text":null,"children":[{"tag":"num","attrib":{"value":"53708"},"text":"§ 53708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings related to economic soundness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6dc2eef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"By Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may not guarantee or make a commitment to guarantee an obligation under this chapter unless the Administrator finds that the property or project for which the obligation will be executed will be economically sound. In making that finding, the Administrator shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dc2ef0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need in the particular segment of the maritime industry for new or additional capacity, including any impact on existing equipment for which a guarantee under this chapter is in effect;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ef1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the market potential for employment of the vessel over the life of the guarantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ef2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projected revenues and expenses associated with employment of the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ef3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any charter, contract of affreightment, transportation agreement, or similar agreement or undertaking relevant to the employment of the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ef4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant criteria; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ef5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for inland waterways, the need for technical improvements, including increased fuel efficiency or improved safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2ef6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"By Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not guarantee or make a commitment to guarantee an obligation under this chapter unless the Secretary finds, at or prior to the time the commitment is made or the guarantee becomes effective, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dc2ef7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property or project for which the obligation will be executed will be economically sound; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ef8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a fishing vessel, the purpose of the financing or refinancing is consistent with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dc2ef9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wise use of the fisheries resources and the development, advancement, management, conservation, and protection of the fisheries resources; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2efa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for technical improvements, including increased fuel efficiency or improved safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2efb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Used Fishing Vessels and Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not guarantee or make a commitment to guarantee an obligation under this chapter for the purchase of a used fishing vessel or used fishery facility unless the vessel or facility will be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dc2efc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reconstructed or reconditioned in the United States and will contribute to the development of the United States fishing industry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2efd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6dc2efe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the harvesting of fish from an underused fishery; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6dc2eff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a purpose described in the definition of “fishery facility” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53701"},"text":"section 53701 of this title","children":[],"tail":" with respect to an underused fishery."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2f00-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independent Analysis","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator may make a determination that aspects of an application under this chapter require independent analysis to be conducted by third party experts due to risk factors associated with markets, technology, or financial structures. A third party independent analysis conducted under this subsection shall be performed by a private sector expert in assessing such risk factors who is selected by the Secretary or Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2f01-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53708/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Equity Because of Increased Risks","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this chapter, the Secretary or Administrator may make a determination that an application under this title requires additional equity because of increased risk factors associated with markets, technology, or financial structures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6dc2f02-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1608"},"text":"120 Stat. 1608","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/D"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(D)","children":[],"tail":", (2)(D), (b)(3)(A), (4), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":", 3556; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/4"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(4)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/597"},"text":"122 Stat. 597","children":[],"tail":", 598.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6dc2f03-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6dc2f04-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6dc2f05-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}