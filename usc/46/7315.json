{"tag":"section","attrib":{"id":"idf67cd09b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7315"},"text":null,"children":[{"tag":"num","attrib":{"value":"7315"},"text":"§ 7315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf67cd09c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nautical School Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Graduation from a nautical school program may be substituted for the sea service requirements under sections 7307 through 7311a and 7313 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd09d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Approved Training Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The satisfactory completion of a training program approved by the Secretary may be substituted for not more than one-half of the sea service requirements under sections 7307 through 7311a and 7313 of this title in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd09e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7315/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training Days","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (b), training days undertaken in connection with training programs approved by the Secretary may be substituted for days of required sea service under sections 7307 through 7311a and 7313 of this title as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf67cd09f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7315/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each shore-based training day in the form of classroom lectures may be substituted for 2 days of sea service requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd0a0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7315/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each training day of laboratory training, practical demonstrations, and other similar training, may be substituted for 4 days of sea service requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd0a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7315/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each training day of full mission simulator training may be substituted for 6 days of sea service requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf67cd0a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7315/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each training day underway on a vessel while enrolled in an approved training program may be substituted for 1½ days of sea service requirements, as long as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf67cd0a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7315/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the structured training provided while underway on a vessel is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf67cd0a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7315/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acceptable to the Secretary as part of the approved training program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf67cd0a5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7315/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fully completed by the individual; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf67cd0a6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7315/c/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tonnage of such vessel is appropriate to the endorsement being sought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd0a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7315/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “training day” means a day that consists of not less than 7 hours of training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67cd0a8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/544"},"text":"97 Stat. 544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/d/6"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1754"},"text":"139 Stat. 1754","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67cd0a9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf67cd0aa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf67cd0ab-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7315","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:672(c)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7315 specifies the training or course work that may be substituted for service requirements for an endorsement as an able seaman or a qualified member of the engine department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf67cd0ac-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf67cd0ad-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" amended section generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) Graduation from a nautical school vessel approved under law and regulation may be substituted for the service requirements under section 7307 or 7314 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) The satisfactory completion of other courses of instruction approved by the Secretary may be substituted for not more than one-third of the required service on deck at sea under sections 7307–7311 of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) The satisfactory completion of other courses of instruction approved by the Secretary may be substituted for not more than one-half of the required service at sea under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7314"},"text":"section 7314 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf67cd0ae-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf67cd0af-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/e/2"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1755"},"text":"139 Stat. 1755","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/60/dG/tLXXIII/s7301/e/2"},"text":"“The Secretary of the department in which the Coast Guard is operating shall implement the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7315"},"text":"section 7315 of title 46","children":[],"tail":", United States Code, as amended by this subsection, without regard to chapters 5 and 6 of title 5, United States Code, and Executive Orders 12866 and 13563 ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s601"},"text":"5 U.S.C. 601","children":[],"tail":" note) and 14094 (88 Fed. Reg. 21879) [former "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s601"},"text":"5 U.S.C. 601","children":[],"tail":" note].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
