{"tag":"section","attrib":{"id":"idf6b3bf51-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42104"},"text":null,"children":[{"tag":"num","attrib":{"value":"42104"},"text":"§ 42104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information, witnesses, and evidence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b3bf52-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Order To Supply Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s42101"},"text":"section 42101 of this title","children":[],"tail":", the Federal Maritime Commission may order any person (including a common carrier, tramp operator, bulk operator, shipper, shippers’ association, ocean transportation intermediary, or marine terminal operator, or an officer, receiver, trustee, lessee, agent, or employee thereof) to file with the Commission a report, answers to questions, documentary material, or other information the Commission considers necessary or appropriate. The Commission may require the response to any such order to be made under oath. The response shall be provided in the form and within the time specified by the Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bf53-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subpoenas and Discovery","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s42101"},"text":"section 42101 of this title","children":[],"tail":", the Commission may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bf54-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subpoena witnesses and evidence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bf55-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize a party to use depositions, written interrogatories, and discovery procedures that, to the extent practicable, conform to the Federal Rules of Civil Procedure (28 App. U.S.C.).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bf56-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Witness Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless otherwise prohibited by law, and subject to funds being appropriated, a witness in a proceeding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s42101"},"text":"section 42101 of this title","children":[],"tail":" is entitled to the same fees and mileage as in the courts of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bf57-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For failure to supply information ordered to be produced or compelled by subpoena under this section, the Commission may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bf58-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after notice and opportunity for a hearing, suspend tariffs and service contracts of a common carrier or the common carrier’s right to use tariffs of conferences and service contracts of agreements of which it is a member; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bf59-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess a civil penalty of not more than $5,000 for each day that the information is not provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bf5a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a person does not comply with an order or subpoena of the Commission under this section, the Commission may seek enforcement in a district court of the United States having jurisdiction over the parties. If, after hearing, the court determines that the order or subpoena was regularly made and duly issued, the court shall enforce the order or subpoena.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b3bf5b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1549"},"text":"120 Stat. 1549","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b3bf5c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b3bf5d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b3bf5e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42104(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:876(f)(1)–(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-06-05/ch250/s19/f"},"text":"June 5, 1920, ch. 250, § 19(f)","children":[],"tail":", (g); as added "},{"tag":"html:a","attrib":{"href":"/us/pl/101/595/tI/s103/2"},"text":"Pub. L. 101–595, title I, § 103(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/2979"},"text":"104 Stat. 2979","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/102/587/tVI/s6205/b/2"},"text":"Pub. L. 102–587, title VI, § 6205(b)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/5094"},"text":"106 Stat. 5094","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tIII/s301"},"text":"Pub. L. 105–258, title III, § 301","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1915"},"text":"112 Stat. 1915","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42104(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:876(g)(1), (2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42104(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:876(g)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42104(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:876(f)(4), (g)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42104(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:876(g)(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “In carrying out” are substituted for “In furtherance of the purposes of” and “In proceedings under” for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “subpoena witnesses and evidence” are substituted for “by subpoena compel the attendance of witnesses and the production of books, papers, documents, and other evidence” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “conform to the Federal Rules of Civil Procedure (28 App. U.S.C.)” are substituted for “are in conformity with the rules applicable in civil proceedings in the district courts of the United States” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), the penalties from 46 App. U.S.C. 876(f)(4) and (g)(4)(B) are combined because they are redundant.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “by an appropriate injunction or other process, mandatory or otherwise” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
