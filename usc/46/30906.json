{"tag":"section","attrib":{"id":"idf6a56821-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30906"},"text":null,"children":[{"tag":"num","attrib":{"value":"30906"},"text":"§ 30906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a56822-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A civil action under this chapter shall be brought in the district court of the United States for the district in which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a56823-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any plaintiff resides or has its principal place of business; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a56824-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel or cargo is found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a56825-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On a motion by a party, the court may transfer the action to any other district court