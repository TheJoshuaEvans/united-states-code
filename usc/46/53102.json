{"tag":"section","attrib":{"id":"idf6cdd765-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102"},"text":null,"children":[{"tag":"num","attrib":{"value":"53102"},"text":"§ 53102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Maritime Security Fleet","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6cdd766-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation, in consultation with the Secretary of Defense, shall establish a fleet of active, commercially viable, militarily useful, privately owned vessels to meet national defense and other security requirements and maintain a United States presence in international commercial shipping. The Fleet shall consist of privately owned, United States-documented vessels for which there are in effect operating agreements under this chapter, and shall be known as the Maritime Security Fleet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6cdd767-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel is eligible to be included in the Fleet if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6cdd768-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel meets the requirements of paragraph (1), (2), (3), or (4) of subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6cdd769-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is operated (or in the case of a vessel to be constructed, will be operated) in providing transportation in foreign commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6cdd76a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the vessel is self-propelled and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6cdd76b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a tank vessel that is 10 years of age or less on the date the vessel is included in the Fleet; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6cdd76c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is any other type of vessel that is 15 years of age or less on the date the vessel is included in the Fleet;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6cdd76d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6cdd76e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is suitable for use by the United States for national defense or military purposes in time of war or national emergency, as determined by the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6cdd76f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is commercially viable, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6cdd770-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6cdd771-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a United States-documented vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6cdd772-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is not a United States-documented vessel, but—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6cdd773-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner of the vessel has demonstrated an intent to have the vessel documented under chapter 121 of this title if it is included in the Fleet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6cdd774-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time an operating agreement for the vessel is entered into under this chapter, the vessel is eligible for documentation under chapter 121 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6cdd775-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements Regarding Citizenship of Owners, Charterers, and Operators","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6cdd776-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel owned and operated by section 50501 citizens","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel meets the requirements of this paragraph if, during the period of an operating agreement under this chapter that applies to the vessel, the vessel will be owned and operated by one or more persons that are citizens of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6cdd777-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel owned by section 50501 citizen or united states citizen trust, and chartered to documentation citizen","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel meets the requirements of this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6cdd778-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during the period of an operating agreement under this chapter that applies to the vessel, the vessel will be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6cdd779-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by a person that is a citizen of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":" or that is a United States citizen trust; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6cdd77a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" demise chartered to a person—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6cdd77b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is eligible to document the vessel under chapter 121 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6cdd77c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairman of the board of directors, chief executive officer, and a majority of the members of the board of directors of which are citizens of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":", and are appointed and subjected to removal only upon approval by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6cdd77d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that certifies to the Secretary that there are no treaties, statutes, regulations, or other laws that would prohibit the contractor for the vessel from performing its obligations under an operating agreement under this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6cdd77e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a vessel that will be demise chartered to a person that is owned or controlled by another person that is not a citizen of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":", the other person enters into an agreement with the Secretary not to influence the operation of the vessel in a manner that will adversely affect the interests of the United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6cdd77f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary and the Secretary of Defense notify the Committee on Armed Services and the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Armed Services of the House of Representatives that they concur with the certification required under subparagraph (A)(ii)(III), and have reviewed and agree that there are no other legal, operational, or other impediments that would prohibit the contractor for the vessel from performing its obligations under an operating agreement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6cdd780-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel owned and operated by defense contractor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel meets the requirements of this paragraph if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6cdd781-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" during the period of an operating agreement under this chapter that applies to the vessel, the vessel will be owned and operated by a person that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6cdd782-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible to document a vessel under chapter 121 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6cdd783-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates or manages other United States-documented vessels for the Secretary of Defense, or charters other vessels to the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6cdd784-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has entered into a special security agreement for purposes of this paragraph with the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6cdd785-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes the certification described in paragraph (2)(A)(ii)(III); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6cdd786-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a vessel described in paragraph (2)(B), enters into an agreement referred to in that paragraph; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6cdd787-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary and the Secretary of Defense notify the Committee on Armed Services and the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Armed Services of the House of Representatives that they concur with the certification required under subparagraph (A)(iv), and have reviewed and agree that there are no other legal, operational, or other impediments that would prohibit the contractor for the vessel from performing its obligations under an operating agreement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6cdd788-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel owned by documentation citizen and chartered to section 50501 citizen","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel meets the requirements of this paragraph if, during the period of an operating agreement under this chapter that applies to the vessel, the vessel will be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6cdd789-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned by a person that is eligible to document a vessel under chapter 121 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6cdd78a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demise chartered to a person that is a citizen of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6cdd78b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request by Secretary of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall request the Secretary of Homeland Security to issue any waiver under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s501"},"text":"section 501 of this title","children":[],"tail":" that is necessary for purposes of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6cdd78c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel Standards","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6cdd78d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certificate of inspection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel used to provide oceangoing transportation which the Secretary of the department in which the Coast Guard is operating determines meets the criteria of subsection (b) of this section but which, on the date of enactment of the Maritime Security Act of 2003, is not documented under chapter 121 of this title, shall be eligible for a certificate of inspection if the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6cdd78e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is classed by and designed in accordance with the rules of the American Bureau of Shipping, or another classification society accepted by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6cdd78f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel complies with applicable international agreements and associated guidelines, as determined by the country in which the vessel was documented immediately before becoming documented under chapter 121; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6cdd790-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that country has not been identified by the Secretary as inadequately enforcing international vessel regulations as to that vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6cdd791-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continued eligibility for certificate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) does not apply to a vessel after any date on which the vessel fails to comply with the applicable international agreements and associated guidelines referred to in paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6cdd792-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reliance on classification society","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6cdd793-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may rely on a certification from the American Bureau of Shipping or, subject to subparagraph (B), another classification society accepted by the Secretary to establish that a vessel is in compliance with the requirements of paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6cdd794-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign classification society","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may accept certification from a foreign classification society under subparagraph (A) only—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6cdd795-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that the government of the foreign country in which the society is headquartered provides access on a reciprocal basis to the American Bureau of Shipping; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6cdd796-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the foreign classification society has offices and maintains records in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6cdd797-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Waive Age Restriction for Eligibility of a Vessel To Be Included in Fleet","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense, in conjunction with the Secretary of Transportation, may waive the application of an age restriction under subsection (b)(3) if the Secretaries jointly determine that the waiver—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6cdd798-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the national interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6cdd799-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is appropriate to allow the maintenance of the economic viability of the vessel and any associated operating network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6cdd79a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary due to the lack of availability of other vessels and operators that comply with the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6cdd79b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53102/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Extend Maximum Service Age for Vessel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, in conjunction with the Secretary of Transportation, may, for a particular participating fleet vessel, treat the ages specified in section 53101(5)(A)(ii) and section 53106(c)(3) as increased by up to 5 years if the Secretaries jointly determine that it is in the national interest to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6cdd79c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dC/tXXXV/s3531/a"},"text":"Pub. L. 108–136, div. C, title XXXV, § 3531(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1805"},"text":"117 Stat. 1805","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/1"},"text":"Pub. L. 109–304, § 13(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1700"},"text":"120 Stat. 1700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dC/tXXXV/s3508/b"},"text":"Pub. L. 112–239, div. C, title XXXV, § 3508(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2223"},"text":"126 Stat. 2223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3502/a"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2774"},"text":"130 Stat. 2774","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6cdd79d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6cdd79e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6cdd79f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Maritime Security Act of 2003, referred to in subsec. (e)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6cdd7a0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3502/a/2"},"text":"Pub. L. 114–328, § 3502(a)(2)","children":[],"tail":", substituted “Authority To Waive Age Restriction for Eligibility of a Vessel To Be Included in Fleet” for “Waiver of Age Restriction” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3502/a/1"},"text":"Pub. L. 114–328, § 3502(a)(1)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239"},"text":"Pub. L. 112–239","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) related to vessel eligibility, including provisions for certain roll-on/roll-off and LASH vessels."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/1/A"},"text":"Pub. L. 109–304, § 13(a)(1)(A)","children":[],"tail":", (B), substituted “section 50501” for “section 2” in the headings of pars. (1), (2), and (4) and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":"” for “section 2 of the Shipping Act, 1916 (46 U.S.C. App. 802)” in pars. (1), (2)(A)(i), (ii)(II), (B), and (4)(B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/1/C"},"text":"Pub. L. 109–304, § 13(a)(1)(C)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t46/s501"},"text":"section 501 of this title","children":[],"tail":"” for “the first section of "},{"tag":"ref","attrib":{"href":"/us/pl/81/891"},"text":"Public Law 81–891","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/64/1120"},"text":"64 Stat. 1120","children":[],"tail":"; 46 U.S.C. App. note prec. 3)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/1/D"},"text":"Pub. L. 109–304, § 13(a)(1)(D)","children":[],"tail":", substituted “documented under chapter 121 of this title,” for “a documented vessel (as that term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12101"},"text":"section 12101 of this title","children":[],"tail":")” in introductory provisions and “documented under chapter 121” for “a documented vessel (as defined in that section)” in subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6cdd7a1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6cdd7a2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Vessel Standards","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tXI/s1137"},"text":"Pub. L. 104–324, title XI, § 1137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3988"},"text":"110 Stat. 3988","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dC/tXXXV/s3534/b/2"},"text":"Pub. L. 108–136, div. C, title XXXV, § 3534(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1818"},"text":"117 Stat. 1818","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/136/dC/tXXXV/s3534/b/2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certificate of Inspection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel used to provide transportation service as a common carrier which the Secretary of Transportation determines meets the criteria of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53102/b"},"text":"section 53102(b) of title 46","children":[],"tail":", United States Code, but which on the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":"] is not a documented vessel (as that term is defined in section 2101 [now section 106] of title 46, United States Code), shall be eligible for a certificate of inspection if the Secretary determines that—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is classed by and designed in accordance with the rules of the American Bureau of Shipping or another classification society accepted by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel complies with applicable international agreements and associated guidelines, as determined by the country in which the vessel was documented immediately before becoming a documented vessel (as defined in that section); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that country has not been identified by the Secretary as inadequately enforcing international vessel regulations as to that vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continued Eligibility for Certificate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply to a vessel after any date on which the vessel fails to comply with the applicable international agreements and associated guidelines referred to in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reliance on Classification Society.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may rely on a certification from the American Bureau of Shipping or, subject to paragraph (2), another classification society accepted by the Secretary to establish that a vessel is in compliance with the requirements of subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign classification society","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may accept certification from a foreign classification society under paragraph (1) only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that the government of the foreign country in which the society is headquartered provides access on a reciprocal basis to the American Bureau of Shipping; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the foreign classification society has offices and maintains records in the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
