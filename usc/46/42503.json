{"tag":"section","attrib":{"id":"idf6b3bfd4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503"},"text":null,"children":[{"tag":"num","attrib":{"value":"42503"},"text":"§ 42503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b3bfd5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall, not less than once each year, meet at the call of the Commission or a majority of the members of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bfd6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee Status","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the Committee shall not be considered an employee of the Federal Government by reason of service on such Committee, except for the purposes of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bfd7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 81 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfd8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 171 of title 28 and any other Federal law relating to tort liability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bfd9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Volunteer Services and Compensation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bfda-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, a member of the Committee may serve on such committee on a voluntary basis without pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfdb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No member of the Committee shall receive compensation for service on the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bfdc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status of Members.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bfdd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), with respect to a member of the Committee whom the Commission appoints to represent an entity or group—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b3bfde-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the member is authorized to represent the interests of the applicable entity or group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b3bfdf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements under Federal law that would interfere with such representation and that apply to a special Government employee (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s202/a"},"text":"section 202(a) of title 18","children":[],"tail":"), including requirements relating to employee conduct, political activities, ethics, conflicts of interest, and corruption, do not apply to the member."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfe0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (b), a member of the Committee shall be treated as a special Government employee for purposes of the committee service of the member if the member, without regard to service on the Committee, is a special Government employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bfe1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service on Committee.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bfe2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Solicitation of nominations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before appointing an individual as a member of the Committee, the Commission shall publish a timely notice in the Federal Register soliciting nominations for membership on such Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfe3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointments.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b3bfe4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After considering nominations received pursuant to a notice published under paragraph (1), the Commission may appoint a member to the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b3bfe5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall not seek, consider, or otherwise use information concerning the political affiliation of a nominee in making an appointment to the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfe6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service at pleasure of commission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Committee shall serve at the pleasure of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfe7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security background examinations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may require an individual to have passed an appropriate security background examination before appointment to the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfe8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Federal employee may not be appointed as a member of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfe9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b3bfea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/e/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of each member of the Committee shall expire on December 31 of the third full year after the effective date of the appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b3bfeb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/e/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continued service after term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the term of a member of the Committee ends, the member, for a period not to exceed 1 year, may continue to serve as a member until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vacancy on the Committee shall be filled in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for reappointments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraphs (1) and (2), the Commission may reappoint a member of a committee for any term, other than the first term of the member, without soliciting, receiving, or considering nominations for such appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bfee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staff Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall furnish to the Committee any staff and services considered by the Commission to be necessary for the conduct of the Committee’s functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bfef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chair; Vice Chair.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bff0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall elect a Chair and Vice Chair from among the committee’s members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bff1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vice chairman acting as chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Vice Chair shall act as Chair in the absence or incapacity of, or in the event of a vacancy in the office of, the Chair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bff2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcommittees and Working Groups.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bff3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chair of the Committee may establish and disestablish subcommittees and working groups for any purpose consistent with the function of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bff4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to conditions imposed by the Chair, members of the Committee may be assigned to subcommittees and working groups established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bff5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation, Advice, Reports, and Recommendations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bff6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before taking any significant action, the Commission shall consult with, and consider the information, advice, and recommendations of, the Committee if the function of the Committee is to advise the Commission on matters related to the significant action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bff7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advice, reports, and recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall submit, in writing, to the Commission its advice, reports, and recommendations, in a form and at a frequency determined appropriate by the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bff8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Explanation of actions taken","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date on which the Commission receives recommendations from the Committee under paragraph (2), the Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b3bff9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the recommendations on a public website; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b3bffa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond, in writing, to the Committee regarding the recommendations, including by providing an explanation of actions taken regarding the recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bffb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate the advice, reports, and recommendations received from the Committee under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bffc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Observers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may designate a representative to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bffd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attend any meeting of the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bffe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate as an observer at such meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bfff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42503/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall terminate on ","children":[{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b3c000-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXVI"},"text":"Pub. L. 116–283, div. G, title LVXXXVI","children":[],"tail":" [LXXXVI], § 8604(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4762"},"text":"134 Stat. 4762","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
