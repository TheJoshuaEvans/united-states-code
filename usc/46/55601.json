{"tag":"section","attrib":{"id":"idf6ea87cb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601"},"text":null,"children":[{"tag":"num","attrib":{"value":"55601"},"text":"§ 55601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States marine highway program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ea87cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea87cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is in the Department of Transportation a program, to be known as the “United States marine highway program”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea87ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional program activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established under this subsection, the Secretary of Transportation may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ea87cf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with ports, State departments of transportation, localities, other public agencies, and appropriate private sector entities on the development of landside facilities and infrastructure to support marine highway transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ea87d0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop performance measures for the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ea87d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Marine Highway Transportation Routes.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea87d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may designate a route as a marine highway transportation route, or modify such a designation, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ea87d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such route—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6ea87d4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a coordinated and capable alternative to landside transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6ecf7d5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigates or relieves landside congestion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6ecf7d6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotes marine highway transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6ecf7d7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses vessels documented under chapter 121; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf7d8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such designation or modification is requested by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6ecf7d9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of a State or territory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6ecf7da-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a metropolitan planning organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6ecf7db-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a port authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6ecf7dc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a non-Federal navigation district; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6ecf7dd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf7de-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date on which the Maritime Administrator receives a request for the designation or modification of a marine highway route under paragraph (1), the Maritime Administrator shall make a determination of whether to make the requested designation or modification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf7df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 14 days after the date on which the Maritime Administrator makes a determination under paragraph (2), the Maritime Administrator shall notify the requester of the determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf7e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Map of Marine Highway Program Routes.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ecf7e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator shall make publicly available a map showing the location of marine highway routes, including such routes along the coasts, in the inland waterways, and at sea and update that map when a marine highway route is designated or modified pursuant to subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf7e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator shall coordinate with the Administrator of the National Oceanic and Atmospheric Administration to incorporate the map referred to in paragraph (1) into the Marine Cadastre.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf7e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ecf7e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants to, or enter into contracts or cooperative agreements with, eligible entities to implement a marine highway transportation project or a component of such a project if the Secretary determines that the project or component—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ecf7e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the criteria referred to in subsection (b)(1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf7e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develops, expands, or promotes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6ecf7e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine highway transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6ecf7e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shipper use of marine highway transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf7e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ecf7ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant or to enter into a contract or cooperative agreement under this subsection, an eligible entity shall submit to the Secretary an application in such form and manner, and at such time, as the Secretary may require. Such an application shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6ecf7eb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A comprehensive description of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6ecf7ec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the marine highway route to be served by the marine highway transportation project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6ecf7ed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supporters of the marine highway transportation project, which may include business affiliations, private sector stakeholders, State departments of transportation, metropolitan planning organizations, municipalities, or other governmental entities (including Tribal governments), as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6ecf7ee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for such project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6ecf7ef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance measure for the marine highway transportation project, such as volumes of cargo or passengers moved, or contribution to environmental mitigation, safety, reduced vehicle miles traveled, or reduced maintenance and repair costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6ecf7f0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A demonstration, to the satisfaction of the Secretary, that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf6ecf7f1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the marine highway transportation project is financially viable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf6ecf7f2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds or other assistance provided under this subsection will be spent or used efficiently and effectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6ecf7f3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf7f4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pre-proposal.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idf6ecf7f5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prior to accepting a full application under subparagraph (A), the Secretary may require that an eligible entity first submit a pre-proposal that contains a brief description of the item referred to in clauses (i) through (iii) of such subparagraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6ecf7f6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Feedback","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after receiving a pre-proposal under clause (i) from an eligible entity, the Secretary shall provide to the eligible entity feedback to encourage or discourage the eligible entity from submitting a full application. An eligible entity may still submit a full application even if that eligible entity is not encouraged to do so after submitting a pre-proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf7f7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not require separate applications for project designation and for assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf7f8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant application feedback","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Following the award of assistance under this subsection for a particular fiscal year, the Secretary may provide feedback to an applicant to help such applicant improve future applications if the feedback is requested by that applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf7f9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ecf7fa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of funding opportunity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall post a notice of funding opportunity regarding grants, contracts, or cooperative agreements under this subsection not more than 60 days after the date of the enactment of the appropriations Act for the fiscal year concerned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf7fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Awarding of assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall award grants, contracts, or cooperative agreements under this subsection not later than 270 days after the date of the enactment of the appropriations Act for the fiscal year concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf7fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-federal share.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ecf7fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), not more than 80 percent of the funding for any project for which funding is provided under this subsection may come from Federal sources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf7fe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tribal governments and rural areas","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may increase the Federal share of funding for the project to an amount above 80 percent in the case of an award of assistance under this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6ecf7ff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an eligible entity that is a Tribal government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6ecf800-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a project located in a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf801-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preference for financially viable projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":" In awarding grants or entering into contracts or cooperative agreements under this subsection, the Secretary shall give a preference to a project or component of a project that presents the most financially viable transportation service and require the lowest percentage of Federal share of the funding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf802-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of unexpended funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (3)(B), amounts awarded under this subsection that are not expended by the recipient within five years after obligation of funds or that are returned shall remain available to the Secretary to make grants and enter into contracts and cooperative agreements under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf803-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions on provision of assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not provide assistance to an eligible entity under this subsection unless the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ecf804-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient funding is available to meet the non-Federal share requirement under paragraph (4);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf805-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the marine highway project for which such assistance is provided will be completed without unreasonable delay; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf806-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity has the authority to implement the proposed marine highway project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf807-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited uses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance provided under this subsection may not be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ecf808-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve port or land-based infrastructure outside the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf809-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless the Secretary determines that such activities are necessary to carry out the marine highway project for which such assistance is provided, to raise sunken vessels, construct buildings or other physical facilities, or acquire land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf80a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Geographic distribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making grants, contracts, and cooperative agreements under this section the Secretary shall take such measures so as to ensure an equitable geographic distribution of funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf80b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible entity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ecf80c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, a political subdivision of a State, or a local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf80d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States metropolitan planning organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf80e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States port authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf80f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ecf810-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55601/d/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States private sector operator of marine highway projects or private sector owners of facilities, including an Alaska Native Corporation, with an endorsement letter from the requester of a marine highway route designation or modification referred to in subsection (b)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ecf811-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXI/s1121/a"},"text":"Pub. L. 110–140, title XI, § 1121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1760"},"text":"121 Stat. 1760","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/84/dC/tXXXV/s3515"},"text":"Pub. L. 111–84, div. C, title XXXV, § 3515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2724"},"text":"123 Stat. 2724","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tIV/s405/a"},"text":"Pub. L. 112–213, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1571"},"text":"126 Stat. 1571","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8332(d)(3), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4704"},"text":"134 Stat. 4704","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3521/a/1"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3521(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3074"},"text":"136 Stat. 3074","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ecf812-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6ecf813-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6ecf814-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" amended section generally. Prior to amendment, section related to Marine highways transportation program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8332/d/3/B"},"text":"Pub. L. 116–283, § 8332(d)(3)(B)","children":[],"tail":", substituted “marine highway” for “short sea” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8332/d/3/A"},"text":"Pub. L. 116–283, § 8332(d)(3)(A)","children":[],"tail":", substituted “Marine highways” for “Short sea” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8332/d/3/C/ii"},"text":"Pub. L. 116–283, § 8332(d)(3)(C)(ii)","children":[],"tail":", which directed amendment of subsec. (a) by substituting “provide a coordinated and capable alternative to landside transportation or to promote marine highway transportation” for “mitigate landside congestion or to promote short sea transportation”, was executed by making the substitution for “mitigate landside congestion or to promote marine highway transportation” to reflect the probable intent of Congress and the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8332/d/3/B"},"text":"Pub. L. 116–283, § 8332(d)(3)(B)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8332/d/3/C/i"},"text":"Pub. L. 116–283, § 8332(d)(3)(C)(i)","children":[],"tail":", substituted “transportation program to be known as the ‘America’s Marine highway program’ ” for “transportation program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8332/d/3/D/ii"},"text":"Pub. L. 116–283, § 8332(d)(3)(D)(ii)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “documented vessels;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8332/d/3/D/i"},"text":"Pub. L. 116–283, § 8332(d)(3)(D)(i)","children":[],"tail":", which directed amendment of subsec. (b) by substituting “Marine Highway Transportation” for “Short Sea Transportation” in heading, was executed by making the amendment to subsec. (c) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/s405/a/1"},"text":"Pub. L. 112–213, § 405(a)(1)","children":[],"tail":", substituted “landside congestion or to promote short sea transportation.” for “landside congestion.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/s405/a/2"},"text":"Pub. L. 112–213, § 405(a)(2)","children":[],"tail":", substituted “coastal corridors or to promote short sea transportation” for “coastal corridors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/s405/a/3"},"text":"Pub. L. 112–213, § 405(a)(3)","children":[],"tail":", substituted “that the project uses documented vessels and—” for “that the project may—” in introductory provisions, added pars. (1) and (2), and struck out former pars. (1) and (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) offer a waterborne alternative to available landside transportation services using documented vessels; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) provide transportation services for passengers or freight (or both) that may reduce congestion on landside infrastructure using documented vessels.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/s405/a/4"},"text":"Pub. L. 112–213, § 405(a)(4)","children":[],"tail":", substituted “may” for “shall” in two places in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/84"},"text":"Pub. L. 111–84","children":[],"tail":" added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6ecf815-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf6ecf816-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6ecf817-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXI/s1121/c"},"text":"Pub. L. 110–140, title XI, § 1121(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1762"},"text":"121 Stat. 1762","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/140/tXI/s1121/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interim regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":"], the Secretary of Transportation shall issue temporary regulations to implement the program under this section. Subchapter II of chapter 5 of title 5, United States Code, does not apply to a temporary regulation issued under this paragraph or to an amendment to such a temporary regulation."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":", the Secretary of Transportation shall issue final regulations to implement the program under this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6ecf818-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Increasing Effectiveness of Marine Highways","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dC/tXXXV/s3521/d"},"text":"Pub. L. 118–31, div. C, title XXXV, § 3521(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/820"},"text":"137 Stat. 820","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/31/dC/tXXXV/s3521/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":"], the Administrator of the Maritime Administration shall complete and make publicly available on an appropriate website a study that identifies opportunities for, and barriers to, increasing the effectiveness of marine highways designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s55601"},"text":"section 55601 of title 46","children":[],"tail":", United States Code, in addressing two or more of the components described in clauses (i), (ii), and (iv) of subparagraphs [sic] (A) and subparagraph (B) of "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s50307/a/2"},"text":"section 50307(a)(2) of title 46","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning on the date that is 120 days after the date of the completion of the study required under paragraph (1), the Administrator shall carry out a one-year pilot program under which the Administrator shall select one marine highway project and implement the findings of the study with respect to that project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the completion of the pilot program under paragraph (3), the Administrator shall provide to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives, a briefing on the lessons learned from the pilot program, any recommendations based on feedback from maritime stakeholders, States, Indian Tribes, nonprofit organizations, and other stakeholders, and recommendations for establishing future marine highways in the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6ecf819-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Public Availability of Map","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3521/f"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3521(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3080"},"text":"136 Stat. 3080","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dC/tXXXV/s3521/f"},"text":"“Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"], the Maritime Administration shall make publicly available the map of marine highway program routes required to be made publicly available under subsection (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s55601"},"text":"section 55601 of title 46","children":[],"tail":", United States Code, as amended by this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
