{"tag":"section","attrib":{"id":"idf6ecf894-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56103"},"text":null,"children":[{"tag":"num","attrib":{"value":"56103"},"text":"§ 56103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditional approvals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ecf895-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In approving an act or transaction under section 56101 or 56102 of this title, the Secretary of Transportation may do so absolutely or upon conditions the Secretary considers advisable. The Secretary shall state the conditions in the notice of approval.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf896-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A violation of a condition of approval is subject to the same penalties as a violation resulting from an act done without the required approval. The violation occurs at the time the condition is violated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ecf897-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1654"},"text":"12