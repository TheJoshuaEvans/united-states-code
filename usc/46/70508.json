{"tag":"section","attrib":{"id":"idf70980af-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508"},"text":null,"children":[{"tag":"num","attrib":{"value":"70508"},"text":"§ 70508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of submersible vessel or semi-submersible vessel without nationality","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf70980b0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual may not operate by any means or embark in any submersible vessel or semi-submersible vessel that is without nationality and that is navigating or has navigated into, through, or from waters beyond the outer limit of the territorial sea of a single country or a lateral limit of that country’s territorial sea with an adjacent country, with the intent to evade detection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70980b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidence of Intent To Evade Detection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any civil enforcement proceeding for a violation of subsection (a), the presence of any of the indicia described in paragraph (1)(A), (E), (F), or (G), or in paragraph (4), (5), or (6), of section 70507(b) may be considered, in the totality of the circumstances, to be prima facie evidence of intent to evade detection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70980b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defenses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf70980b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is a defense in any civil enforcement proceeding for a violation of subsection (a) that the submersible vessel or semi-submersible vessel involved was, at the time of the violation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf70980b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel of the United States or lawfully registered in a foreign nation as claimed by the master or individual in charge of the vessel when requested to make a claim by an officer of the United States authorized to enforce applicable provisions of United States law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70980b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classed by and designed in accordance with the rules of a classification society;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70980b6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lawfully operated in government-regulated or licensed activity, including commerce, research, or exploration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70980b7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipped with and using an operable automatic identification system, vessel monitoring system, or long range identification and tracking system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70980b8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Production of documents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The defenses provided by this subsection are proved conclusively by the production of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf70980b9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" government documents evidencing the vessel’s nationality at the time of the offense, as provided in article 5 of the 1958 Convention on the High Seas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70980ba-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certificate of classification issued by the vessel’s classification society upon completion of relevant classification surveys and valid at the time of the offense; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf70980bb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" government documents evidencing licensure, regulation, or registration for research or exploration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf70980bc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70508/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person violating this section shall be liable to the United States for a civil penalty of not more than $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf70980bd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/407/tII/s202/a"},"text":"Pub. L. 110–407, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4299"},"text":"122 Stat. 4299","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
