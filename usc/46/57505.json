{"tag":"section","attrib":{"id":"idf6f1b345-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57505"},"text":null,"children":[{"tag":"num","attrib":{"value":"57505"},"text":"§ 57505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of vessels on foreign trade routes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f1b346-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall arrange for the employment of the Department of Transportation’s vessels in steamship lines on such trade routes, exclusively serving the foreign trade of the United States, as the Secretary determines are essential for the development and maintenance of the commerce of the United States and the national defense. However, the Secretary shall first determine that those routes are not being adequately served by existing steamship lines privately owned and operated by citizens of the United States and documented under the laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b347-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy To Encourage Private Operation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall have a policy of encouraging private operation of each essential steamship line now owned by the United States Government by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f1b348-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selling the line to a citizen of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b349-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demising the Secretary’s vessels on bareboat charter to citizens of the United States who agree to maintain the line in the manner provided in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b34a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1665"},"text":"120 Stat. 1665","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b34b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f1b34c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f1b34d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"57505(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1195 (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title VII, § 705 (1st, 2d sentences), "},{"tag":"html:a","attrib":{"href":"/us/stat/49/2009"},"text":"49 Stat. 2009","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/107"},"text":"Pub. L. 97–31, § 12(107)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/163"},"text":"95 Stat. 163","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"57505(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1195 (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"1936-06-29"},"text":"June 29, 1936","children":[],"tail":", and continuing thereafter” are omitted as obsolete. The words “However, the Secretary shall first determine that those routes are not being adequately served” are substituted for “"},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such needs are not being adequately served” for clarity and because provisos are disfavored in modern drafting."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “in the manner provided in section 7 of the Merchant Marine Act, 1920 [46 App. U.S.C. 866], and in strict accordance with the provisions of section 5 of said Act” are omitted because section 5 of that Act was repealed in 1988, and section 7 is being repealed as obsolete by this bill without being restated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
