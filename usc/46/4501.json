{"tag":"section","attrib":{"id":"idf670eaba-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4501"},"text":null,"children":[{"tag":"num","attrib":{"value":"4501"},"text":"§ 4501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf670eabb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter applies to an uninspected vessel which is a fishing vessel, fish processing vessel, or fish tender vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf670eabc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter does not apply to the carriage of bulk dangerous cargoes regulated under chapter 37 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf670eabd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364/tIV/s402/7/C"},"text":"Pub. L. 98–364, title IV, § 402(7)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/446"},"text":"98 Stat. 446","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/424/s2/a"},"text":"Pub. L. 100–424, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1585"},"text":"102 Stat. 1585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf670eabe-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf670eabf-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf670eac0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/424"},"text":"Pub. L. 100–424","children":[],"tail":" amended section generally, in subsec. (a) substituting provisions which related to uninspected fish processing vessel entered into service after "},{"tag":"date","attrib":{"date":"1987-12-31"},"text":"Dec. 31, 1987","children":[],"tail":", having more than 16 individuals on board primarily employed in preparation of fish on navigable waters of United States or owned in United States and operating on high seas, for provisions which related to uninspected fishing vessel, fish processing vessel, or fish tender vessel, and in subsec. (b) substituting “carriage of bulk” for “carriage of liquid bulk”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf670eac1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf670eac2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Foreign Built Vessels, Equivalent Compliance Until ","children":[{"tag":"date","attrib":{"date":"1990-07-28"},"text":"July 28, 1990","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/424/s7"},"text":"Pub. L. 100–424, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1592"},"text":"102 Stat. 1592","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/424/s7"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Until ","children":[{"tag":"date","attrib":{"date":"1990-07-28"},"text":"July 28, 1990","children":[],"tail":", a foreign built fish processing vessel subject to chapter 45 of title 46, United States Code, is deemed to comply with the requirements of that chapter if—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it has an unexpired certificate of inspection issued by a foreign country that is a party to an International Convention for Safety of Life at Sea to which the United States Government is a party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in compliance with the safety requirements of that foreign country that apply to that vessel.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
