{"tag":"section","attrib":{"id":"idf6949f60-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12117"},"text":null,"children":[{"tag":"num","attrib":{"value":"12117"},"text":"§ 12117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oil spill response vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6949f61-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A coastwise endorsement may be issued for a vessel that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6949f62-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12117/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the requirements for a coastwise endorsement, except for the ownership requirement otherwise applicable without regard to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f63-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12117/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned by a not-for-profit oil spill response cooperative or by members of such a cooperative that dedicate the vessel to use by the cooperative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f64-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12117/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least 50 percent owned by individuals or entities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12103/b"},"text":"section 12103(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6949f65-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12117/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is to be used only for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6949f66-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12117/a/4/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deploying equipment, supplies, and personnel to recover, contain, or transport oil discharged into the navigable waters of the United States or the exclusive economic zone; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6949f67-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12117/a/4/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training exercises to prepare to respond to such a discharge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6949f68-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deemed Owned by Citizens","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel satisfying subsection (a) is deemed to be owned only by citizens of the United States under sections 12103, 12132, and 50501 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6949f69-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1499"},"text":"120 Stat. 1499","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6949f6a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6949f6b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6949f6c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"