{"tag":"section","attrib":{"id":"idf688b86a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9308"},"text":null,"children":[{"tag":"num","attrib":{"value":"9308"},"text":"§ 9308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf688b86b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An owner, charterer, managing operator, agent, master, or individual in charge of a vessel knowingly allowing the vessel to be operated in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s9302"},"text":"section 9302 of this title","children":[],"tail":" is liable to the United States Government for a civil penalty of no more than $10,000 for each day during which the vessel is in violation. The vessel also is liable in rem for the penalty."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b86c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who directs the navigation of a vessel in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s9302"},"text":"section 9302 of this title","children":[],"tail":" is liable to the Government for a civil penalty of no more than $10,000 for each day during which the violation occurs."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b86d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s9308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person violating a regulation prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s9303"},"text":"section 9303 of this title","children":[],"tail":" is liable to the Government for a civil penalty of no more than $10,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf688b86e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/560"},"text":"97 Stat. 560","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV/s4108/b"},"text":"Pub. L. 101–380, title IV, § 4108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/515"},"text":"104 Stat. 515","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf688b86f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf688b870-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf688b871-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attri