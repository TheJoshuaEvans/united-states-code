{"tag":"section","attrib":{"id":"idf6e81664-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55112"},"text":null,"children":[{"tag":"num","attrib":{"value":"55112"},"text":"§ 55112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel escort operations and towing assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e81665-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except in the case of a vessel in distress, only a vessel of the United States may perform the following escort vessel operations within the navigable waters of the United States:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e81666-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operations that commence or terminate at a port or place in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81667-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operations required by United States law or regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81668-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55112/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operations provided in whole or in part within or through navigation facilities owned, maintained, or operated by the United States Government or the approaches to those facilities, other than facilities operated by the Great Lakes St. Lawrence Seaway Development Corporation on the St. Lawrence River portion of the Seaway.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e81669-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Escort Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, an escort vessel is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e8166a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any vessel that is assigned and dedicated to assist another vessel, whether or not tethered to that vessel, solely as a safety precaution to assist in controlling the speed or course of the assisted vessel in the event of a steering or propulsion equipment failure, or any other similar emergency circumstance, or in restricted waters where additional assistance in maneuvering the vessel is required to ensure its safe operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e8166b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a vessel being towed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55111"},"text":"section 55111 of this title","children":[],"tail":", any vessel that is assigned and dedicated to the vessel being towed in addition to any towing vessel required under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e8166c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not affect ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55111"},"text":"section 55111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e8166d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55112/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person violating this section is liable to the Government for a civil penalty of not more than $10,000 for each day during which the violation occurs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e8166e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1638"},"text":"120 Stat. 1638","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tV/s512/c/6/D"},"text":"Pub. L. 116–260, div. AA, title V, § 512(c)(6)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2757"},"text":"134 Stat. 2757","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e8166f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e81670-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e81671-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55112","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:316a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/107/295/tIV/s404"},"text":"Pub. L. 107–295, title IV, § 404","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/116/2114"},"text":"116 Stat. 2114","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “(as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"section 2101 of title 46","children":[],"tail":", United States Code)” are omitted because the definition of “vessel of the United States” is being moved from section 2101 to chapter 1 of the revised title and will apply title-wide."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6e81672-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6e81673-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “Great Lakes St. Lawrence Seaway Development Corporation” for “St. Lawrence Seaway Development Corporation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
