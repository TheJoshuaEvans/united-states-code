{"tag":"section","attrib":{"id":"idf6a0ad23-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15104"},"text":null,"children":[{"tag":"num","attrib":{"value":"15104"},"text":"§ 15104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Merchant Mariner Medical Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a0ad24-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a National Merchant Mariner Medical Advisory Committee (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad25-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall advise the Secretary on matters relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ad26-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical certification determinations for the issuance of licenses, certification of registry, and merchant mariners’ documents with respect to merchant mariners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad27-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical standards and guidelines for the physical qualifications of operators of commercial vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad28-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical examiner education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad29-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15104/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad2a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ad2b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall consist of 14 members appointed by the Secretary in accordance with this section and section 15109 of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad2c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expertise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad2d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15104/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Committee shall be appointed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad2e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15104/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 9 shall represent health-care professionals and have particular expertise, knowledge, and experience regarding the medical examinations of merchant mariners or occupational medicine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad2f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15104/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 shall represent professional mariners and have particular expertise, knowledge, and experience in occupational requirements for mariners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a0ad30-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVI/s601/a"},"text":"Pub. L. 115–282, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4283"},"text":"132 Stat. 4283","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
