l,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12151(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:12122(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12151(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:12122(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:14 (last proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 4136 (last proviso); ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1915-02-24/ch57"},"text":"Feb. 24, 1915, ch. 57","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/38/812"},"text":"38 Stat. 812","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/182/tVI/s686/a/4"},"text":"Pub. L. 103–182, title VI, § 686(a)(4)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/2220"},"text":"107 Stat. 2220","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:883a (2d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-07-14/ch600/s2"},"text":"July 14, 1956, ch. 600, § 2","children":[],"tail":" (2d, last sentences), "},{"tag":"html:a","attrib":{"href":"/us/stat/70/544"},"text":"70 Stat. 544","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/86/583/s2"},"text":"Pub. L. 86–583, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 5, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/321"},"text":"74 Stat. 321","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12151(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:12122(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), in restating 46 App. U.S.C. 883a (2d, last sentences), the penalty of $200 for the owner and master of the vessel is omitted because subsection (a) provides a general civil penalty for violation of this chapter. The authority to remit or mitigate a penalty under section 2107(b) is omitted because section 2107(b) applies to subtitle II and this section is in subtitle II.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf697106e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf697106f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213"},"text":"Pub. L. 112–213","children":[],"tail":" designated existing provisions as par. (1), inserted par. (1) heading, substituted “Except as provided in paragraph (2), a person that violates” for “A person that violates” and “$15,000” for “$10,000”, and added par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
