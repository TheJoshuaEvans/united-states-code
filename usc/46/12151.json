{"tag":"section","attrib":{"id":"idf697105d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12151"},"text":null,"children":[{"tag":"num","attrib":{"value":"12151"},"text":"§ 12151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf697105e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf697105f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12151/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), a person that violates this chapter or a regulation prescribed under this chapter is liable to the United States Government for a civil penalty of not more than $15,000. Each day of a continuing violation is a separate violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6971060-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12151/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities involving mobile offshore drilling units","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person that violates section 12111(d) or a regulation prescribed under that section is liable to the United States Government for a civil penalty in an amount that is $25,000 or twice the charter rate of the vessel involved in the violation (as determined by the Secretary), whichever is greater. Each day of a continuing violation is a separate violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6971061-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Seizure and Forfeiture of Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel and its equipment are liable to seizure by and forfeiture to the Government if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6971062-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12151/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner of the vessel or the representative or agent of the owner knowingly falsifies or conceals a material fact, or knowingly makes a false statement or representation, about the documentation of the vessel or in applying for documentation of the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6971063-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12151/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certificate of documentation is knowingly and fraudulently used for the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6971064-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12151/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is operated after its endorsement has been denied or revoked under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12152"},"text":"section 12152 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6971065-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12151/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is employed in a trade without an appropriate endorsement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6971066-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12151/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel has only a recreational endorsement and is operated other than for pleasure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6971067-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12151/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is a documented vessel and is placed under the command of a person not a citizen of the United States, except as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12131/b"},"text":"section 12131(b) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6971068-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12151/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is rebuilt outside the United States and a report of the rebuilding is not submitted as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12139/b"},"text":"section 12139(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6971069-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12151/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Engaging in Fishing After Falsifying Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to other penalties under this section, the owner of a documented vessel for which a fishery endorsement has been issued is liable to the Government for a civil penalty of not more than $100,000 for each day the vessel engages in fishing (as defined in section 3 of the Magnuson-Stevens Fishery Conservation and Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1802"},"text":"16 U.S.C. 1802","children":[],"tail":")) within the exclusive economic zone, if the owner or the representative or agent of the owner knowingly falsified or concealed a material fact, or knowingly made a false statement or representation, about the eligibility of the vessel under section 12113(c) or (d) of this title in applying for or applying to renew the fishery endorsement."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf697106a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1508"},"text":"120 Stat. 1508","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/213/tIII/s309"},"text":"Pub. L. 112–213, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1566"},"text":"126 Stat. 1566","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes