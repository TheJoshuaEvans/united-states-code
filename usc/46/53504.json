{"tag":"section","attrib":{"id":"idf6d77463-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53504"},"text":null,"children":[{"tag":"num","attrib":{"value":"53504"},"text":"§ 53504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits and withdrawals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d77464-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Deposits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agreement to establish a capital construction fund shall provide for the deposit in the fund of the amounts agreed to be appropriate to provide for qualified withdrawals under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53509"},"text":"section 53509 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d77465-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Deposits in and withdrawals from the fund are subject to the requirements included in the agreement or prescribed by the Secretary by regulation. However, the Secretary may not require a person to deposit in the fund for a taxable year more than 50 percent of that portion of the person’s taxable income for that year (as determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53505/a/1"},"text":"section 53505(a)(1) of this title","children":[],"tail":") that is attributable to the operation of an agreement vessel."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d77466-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1593"},"text":"120 Stat. 1593","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d77467-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6d77468-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6d77469-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","ch