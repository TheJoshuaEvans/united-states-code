"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf697102f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Documentation Surrender and Invalidation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/225/tIII/s301/b"},"text":"Pub. L. 101–225, title III, § 301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1922"},"text":"103 Stat. 1922","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/225/tIII/s301/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Section 12111(c)(3) [now section 12136(b)(2)] of title 46, United States Code, does not apply to a mortgage that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was filed or recorded before ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was not a preferred mortgage (as that term is defined in section 31301(6) of that title) on that date.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
