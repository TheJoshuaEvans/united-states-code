{"tag":"section","attrib":{"id":"idf697101e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12136"},"text":null,"children":[{"tag":"num","attrib":{"value":"12136"},"text":"§ 12136.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surrender of certificates of documentation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf697101f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12136/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Surrender","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An invalid certificate of documentation, or a certificate with an invalid endorsement, shall be surrendered as provided by regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6971020-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12136/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions for Surrender","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6971021-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12136/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessels over 1,000 tons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may condition approval of the surrender of the certificate of documentation for a vessel over 1,000 gross tons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6971022-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12136/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessels covered by mortgage","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may approve the surrender of the certificate of documentation of a vessel covered by a mortgage filed or recorded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31321"},"text":"section 31321 of this title","children":[],"tail":" only if the mortgagee consents."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6971023-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12136/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of lien","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not refuse to approve the surrender of the certificate of documentation for a vessel solely on the basis that a notice of a claim of a lien on the vessel has been recorded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31343/a"},"text":"section 31343(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6971024-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12136/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continued Application of Certain Laws","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6971025-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12136/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a), until the certificate of documentation is surrendered with the approval of the Secretary, a documented vessel is deemed to continue to be documented under this chapter for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6971026-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12136/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 313 of this title for an instrument filed or recorded before the date of invalidation and an assignment after that date;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6971027-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12136/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 56101 and 56102(a)(2) and chapter 563 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6971028-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12136/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other law of the United States identified by the Secretary by regulation as a law to which the Secretary applies this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6971029-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12136/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not apply when a vessel is forfeited or sold by order of a district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf697102a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1506"},"text":"120 Stat. 1506","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf697102b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf697102c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf697102d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null}