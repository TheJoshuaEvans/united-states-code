{"tag":"section","attrib":{"id":"idf6aede2a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104"},"text":null,"children":[{"tag":"num","attrib":{"value":"41104"},"text":"§ 41104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Common carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6aede2b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A common carrier, either alone or in conjunction with any other person, directly or indirectly, shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aede2c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow a person to obtain transportation for property at less than the rates or charges established by the carrier in its tariff or service contract by means of false billing, false classification, false weighing, false measurement, or any other unjust or unfair device or means;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede2d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide service in the liner trade that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6aede2e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not in accordance with the rates, charges, classifications, rules, and practices contained in a tariff published or a service contract entered into under chapter 405 of this title, unless excepted or exempted under section 40103 or 40501(a)(2) of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede2f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a tariff or service contract that has been suspended or prohibited by the Federal Maritime Commission under chapter 407 or 423 of this title;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede30-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unreasonably refuse cargo space accommodations when available, or resort to other unfair or unjustly discriminatory methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede31-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for service pursuant to a tariff, engage in any unfair or unjustly discriminatory practice in the matter of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6aede32-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rates or charges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede33-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cargo classifications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede34-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cargo space accommodations or other facilities, with due regard being given to the proper loading of the vessel and the available tonnage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede35-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loading and landing of freight; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede36-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjustment and settlement of claims;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede37-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for service pursuant to a service contract, engage in any unfair or unjustly discriminatory practice against any commodity group or type of shipment or in the matter of rates or charges with respect to any port;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede38-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a vessel in a particular trade for the purpose of excluding, preventing, or reducing competition by driving another ocean common carrier out of that trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede39-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer or pay any deferred rebates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede3a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for service pursuant to a tariff, give any undue or unreasonable preference or advantage or impose any undue or unreasonable prejudice or disadvantage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede3b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for service pursuant to a service contract, give any undue or unreasonable preference or advantage or impose any undue or unreasonable prejudice or disadvantage with respect to any port;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede3c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unreasonably refuse to deal or negotiate, including with respect to vessel space accommodations provided by an ocean common carrier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede3d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully accept cargo from or transport cargo for the account of a non-vessel-operating common carrier that does not have a tariff as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s40501"},"text":"section 40501 of this title","children":[],"tail":", or an ocean transportation intermediary that does not have a bond, insurance, or other surety as required by "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s40902"},"text":"section 40902 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede3e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully enter into a service contract with an ocean transportation intermediary that does not have a tariff as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s40501"},"text":"section 40501 of this title","children":[],"tail":" and a bond, insurance, or other surety as required by "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s40902"},"text":"section 40902 of this title","children":[],"tail":", or with an affiliate of such an ocean transportation intermediary;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede3f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to participate simultaneously in a rate discussion agreement and an agreement to share vessels, in the same trade, if the interplay of the authorities exercised by the specified agreements is likely, by a reduction in competition, to produce an unreasonable reduction in transportation service or an unreasonable increase in transportation cost;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede40-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess any party for a charge that is inconsistent or does not comply with all applicable provisions and regulations, including subsection (c) of section 41102 or part 545 of title 46, Code of Federal Regulations (or successor regulations);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede41-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" invoice any party for demurrage or detention charges unless the invoice includes information as described in subsection (d) showing that such charges comply with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6aede42-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all provisions of part 545 of title 46, Code of Federal Regulations (or successor regulations); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede43-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable provisions and regulations, including the principles of the final rule published on ","children":[{"tag":"date","attrib":{"date":"2020-05-18"},"text":"May 18, 2020","children":[],"tail":", entitled “Interpretive Rule on Demurrage and Detention Under the Shipping Act” (or successor rule); or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede44-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for service pursuant to a service contract, give any undue or unreasonable preference or advantage or impose any undue or unreasonable prejudice or disadvantage against any commodity group or type of shipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aede45-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, there is no private right of action to enforce the prohibition under subsection (a)(13).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aede46-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement Violation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Participants in an agreement found by the Commission to violate subsection (a)(13) shall have 90 days from the date of such Commission finding to withdraw from the agreement as necessary to comply with that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aede47-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detention and Demurrage Invoice Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aede48-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inaccurate invoice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Commission determines, after an investigation in response to a submission under section 41310, that an invoice under subsection (a)(15) was inaccurate or false, penalties or refunds under section 41107 shall be applied.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aede49-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of invoice","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An invoice under subsection (a)(15), unless otherwise determined by subsequent Commission rulemaking, shall include accurate information on each of the following, as well as minimum information as determined by the Commission:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6aede4a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Date that container is made available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede4b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The port of discharge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede4c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The container number or numbers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede4d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For exported shipments, the earliest return date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede4e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The allowed free time in days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede4f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The start date of free time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede50-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The end date of free time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede51-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicable detention or demurrage rule on which the daily rate is based.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede52-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The applicable rate or rates per the applicable rule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede53-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount due.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aede54-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The email, telephone number, or other appropriate contact information for questions or requests for mitigation of fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b14e55-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement that the charges are consistent with any of Federal Maritime Commission rules with respect to detention and demurrage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b14e56-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/d/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement that the common carrier’s performance did not cause or contribute to the underlying invoiced charges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14e57-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safe Harbor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a non-vessel operating common carrier passes through to the relevant shipper an invoice made by the ocean common carrier, and the Commission finds that the non-vessel operating common carrier is not otherwise responsible for the charge, then the ocean common carrier shall be subject to refunds or penalties pursuant to subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14e58-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41104/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elimination of Charge Obligation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Failure to include the information required under subsection (d) on an invoice with any demurrage or detention charge shall eliminate any obligation of the charged party to pay the applicable charge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b14e59-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-