[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 9, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/60"},"text":"106 Stat. 60","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tI/s109/a"},"text":"Pub. L. 105–258, title I, § 109(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1909"},"text":"112 Stat. 1909","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/383/tIV/s424/b"},"text":"Pub. L. 105–383, title IV, § 424(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/3441"},"text":"112 Stat. 3441","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6b14e5d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6b14e5e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s7/a/1/A"},"text":"Pub. L. 117–146, § 7(a)(1)(A)","children":[],"tail":", substituted “shall not” for “may not” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s7/a/1/B"},"text":"Pub. L. 117–146, § 7(a)(1)(B)","children":[],"tail":", added par. (3) and struck out former par. (3) which read as follows: “retaliate against a shipper by refusing, or threatening to refuse, cargo space accommodations when available, or resort to other unfair or unjustly discriminatory methods because the shipper has patronized another carrier, or has filed a complaint, or for any other reason;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s7/a/1/C"},"text":"Pub. L. 117–146, § 7(a)(1)(C)","children":[],"tail":", substituted “against any commodity group or type of shipment or in the matter of rates or charges” for “in the matter of rates or charges”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s7/a/1/D"},"text":"Pub. L. 117–146, § 7(a)(1)(D)","children":[],"tail":", inserted “, including with respect to vessel space accommodations provided by an ocean common carrier” after “negotiate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(14) to (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s7/a/1/E"},"text":"Pub. L. 117–146, § 7(a)(1)(E)","children":[],"tail":"–(G), added pars. (14) to (16)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s7/a/2"},"text":"Pub. L. 117–146, § 7(a)(2)","children":[],"tail":", added subsecs. (d) to (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s708/a/1"},"text":"Pub. L. 115–282, § 708(a)(1)","children":[],"tail":", designated existing provisions as subsec. (a) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s708/a/2/A"},"text":"Pub. L. 115–282, § 708(a)(2)(A)","children":[],"tail":", amended par. (11) generally. Prior to amendment, par. (11) read as follows: “knowingly and willfully accept cargo from or transport cargo for the account of an ocean transportation intermediary that does not have a tariff as required by "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s40501"},"text":"section 40501 of this title","children":[],"tail":" and a bond, insurance, or other surety as required by "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s40902"},"text":"section 40902 of this title","children":[],"tail":"; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s708/a/2/B"},"text":"Pub. L. 115–282, § 708(a)(2)(B)","children":[],"tail":", (C), added par. (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s708/a/3"},"text":"Pub. L. 115–282, § 708(a)(3)","children":[],"tail":", added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6b14e5f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf6b14e60-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVII/s708/b"},"text":"Pub. L. 115–282, title VII, § 708(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4296"},"text":"132 Stat. 4296","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/282/tVII/s708/b"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s41104/a/13"},"text":"Section 41104(a)(13) of title 46","children":[],"tail":", United States Code, as amended, shall apply to any agreement filed or with an effective date before, on, or after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6b14e61-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s7/c"},"text":"Pub. L. 117–146, § 7(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1276"},"text":"136 Stat. 1276","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/146/s7/c"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rulemaking on Unfair or Unjustly Discriminatory Methods","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":"], the Federal Maritime Commission shall initiate a rulemaking defining unfair or unjustly discriminatory methods under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s41104/a/3"},"text":"section 41104(a)(3) of title 46","children":[],"tail":", United States Code, as amended by this section. The Federal Maritime Commission shall issue a final rule not later than 1 year after the date of enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rulemaking on Unreasonable Refusal to Deal or Negotiate With Respect to Vessel Space Accommodations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date of enactment of this Act, the Federal Maritime Commission, in consultation with the Commandant of the United States Coast Guard, shall initiate a rulemaking defining unreasonable refusal to deal or negotiate with respect to vessel space under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s41104/a/10"},"text":"section 41104(a)(10) of title 46","children":[],"tail":", as amended by this section. The Federal Maritime Commission shall issue a final rule not later than 6 months after the date of enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
