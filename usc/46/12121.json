{"tag":"section","attrib":{"id":"idf6970fd8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121"},"text":null,"children":[{"tag":"num","attrib":{"value":"12121"},"text":"§ 12121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small passenger vessels and uninspected passenger vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6970fd9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6970fda-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible vessel” means a vessel that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6970fdb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was built in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6970fdc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was not built in the United States and is at least 3 years old; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6970fdd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if rebuilt, was rebuilt—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6970fde-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6970fdf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outside the United States at least 3 years before the certificate requested under subsection (b) would take effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6970fe0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Small passenger vessel; uninspected passenger vessel; passenger for hire","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms “small passenger vessel”, “uninspected passenger vessel”, and “passenger for hire” have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"section 2101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6970fe1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance of Certificate and Endorsement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding sections 12112, 12113, 12132, 55102, and 55103 of this title, the Secretary may issue a certificate of documentation with an appropriate endorsement for employment in the coastwise trade as a small passenger vessel or an uninspected passenger vessel in the case of an eligible vessel authorized to carry no more than 12 passengers for hire if the Secretary of Transportation, after notice and an opportunity for public comment, determines that the employment of the vessel in the coastwise trade will not adversely affect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6970fe2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States vessel builders; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6970fe3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coastwise trade business of any person that employs vessels built in the United States in that business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6970fe4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6970fe5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"For fraud","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall revoke a certificate or endorsement issued under subsection (b) if the Secretary of Transportation, after notice and an opportunity for a hearing, determines that the certificate or endorsement was obtained by fraud.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6970fe6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other provisions not affected","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) does not affect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6970fe7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criminal prohibition on fraud and false statements in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1001"},"text":"section 1001 of title 18","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6970fe8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12121/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other authority of the Secretary to revoke a certificate or endorsement issued under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6970fe9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","childr