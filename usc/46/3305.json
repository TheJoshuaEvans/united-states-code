{"tag":"section","attrib":{"id":"idf6604809-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305"},"text":null,"children":[{"tag":"num","attrib":{"value":"3305"},"text":"§ 3305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scope and standards of inspection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf660480a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf660480b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The inspection process shall ensure that a vessel subject to inspection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf660480c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of a structure suitable for the service in which it is to be employed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf660480d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is equipped with proper appliances for lifesaving, fire prevention, and firefighting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf660480e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has suitable accommodations for the crew, sailing school instructors, and sailing school students, and for passengers on the vessel if authorized to carry passengers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf660480f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has an adequate supply of potable water for drinking and washing by passengers and crew;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6604810-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in a condition to be operated with safety to life and property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6604811-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with applicable marine safety laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6604812-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining the adequacy of the supply of potable water under paragraph (1)(D), the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6604813-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size and type of vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6604814-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of passengers or crew on board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6604815-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration and routing of voyages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6604816-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines for potable water recommended by the Centers for Disease Control and Prevention and the Public Health Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6604817-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an inspection, or examination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s3308"},"text":"section 3308 of this title","children":[],"tail":", reveals that a life preserver, lifesaving device, or firehose is defective and incapable of being repaired, the owner or master shall destroy the life preserver, lifesaving device, or firehose in the presence of the official conducting the inspection or examination."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6604818-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nautical school vessel operated by a civilian nautical school or by an educational institution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s558"},"text":"section 558 of title 40","children":[],"tail":" shall be inspected like a small passenger vessel or a passenger vessel, depending on its tonnage."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6604819-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf660481a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commandant of the Coast Guard shall ensure that Officers in Charge, Marine Inspections consistently interpret regulations and standards under this subtitle and chapter 700 to avoid disruption and undue expense to industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf660481b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf660481c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), in the event of a disagreement regarding the condition of a vessel or the interpretation of a regulation or standard referred to in subsection (a) between a local Officer in Charge, Marine Inspection conducting an inspection of the vessel and the Officer in Charge, Marine Inspection that issued the most recent certificate of inspection for the vessel, such Officers shall seek to resolve such disagreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf660481d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a disagreement described in subparagraph (A) involves vessel design or plan review, the Coast Guard marine safety center shall be included in all efforts to resolve such disagreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf660481e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a disagreement described in subparagraph (A) or (B) cannot be resolved, the local Officer in Charge, Marine Inspection shall submit to the Commandant of the Coast Guard, through the cognizant Coast Guard district commander, a request for a final agency determination of the matter in disagreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf660481f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commandant of the Coast Guard shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6604820-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to each person affected by a decision or action by an Officer in Charge, Marine Inspection or by the Coast Guard marine safety center all information necessary for such person to exercise any right to appeal such decision or action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6604821-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such an appeal is filed, process such appeal under parts 1 through 4 of title 46, Code of Federal Regulations, as in effect on the date of enactment of the Frank LoBiondo Coast Guard Authorization Act of 2018.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6604822-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term “Officer in Charge, Marine Inspection” means any person from the civilian or military branch of the Coast Guard who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6604823-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designated as such by the Commandant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6604824-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3305/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the superintendence and direction of the cognizant Coast Guard district commander, is in charge of an inspection zone for the performance of duties with respect to the inspections under, and enforcement and administration of, subtitle II, chapter 700, and regulations under such laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6604825-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/513"},"text":"97 Stat. 513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/36/s1/a/1"},"text":"Pub. L. 99–36, § 1(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-05-15"},"text":"May 15, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/67"},"text":"99 Stat. 67","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/640/s13/e"},"text":"Pub. L. 99–640, § 13(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3551"},"text":"100 Stat. 3551","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/m/2"},"text":"Pub. L. 107–217, § 3(m)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1302"},"text":"116 Stat. 1302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tIV/s416"},"text":"Pub. L. 108–293, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1047"},"text":"118 Stat. 1047","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIX/s901/f"},"text":"Pub. L. 109–241, title IX, § 901(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/564"},"text":"120 Stat. 564","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tV/s501/a"},"text":"Pub. L. 115–282, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4268"},"text":"132 Stat. 4268","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8507(a)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4752"},"text":"134 Stat. 4752","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6604826-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6604827-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6604828-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3305","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:369","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:390a","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:391","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:392","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:395","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:404–1","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:405","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:406","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:407","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:408","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:660a","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:881","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3305 consolidates, at one place, the basic scope of coverage of the inspection process. It is to be noted that the time difference in enactment of various statutes has resulted in some anomalies. Thus, for example, R.S. 4417 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s391"},"text":"46 U.S.C. 391","children":[],"tail":") which had originally set periods of inspection and vested authority in “local inspectors” was expanded over the years to provide the base for inspection of certain classes of vessels as well as setting out the periods and scope. The distillation of inspection objectives and standards in later laws and the transfer of all functions of separately created bureaus and functionaries to the Coast Guard permit this consolidation. There are those who have a desire to see the scope and standards of inspection be more specific in law similar to those presently applicable to boilers and boiler plating that predate 1871. The Committee believes this serves no useful purpose since the specifics are either antiquated or too limiting and have, in fact, been superceded by the statutorily authorized adoption of various industrial specifications, standards, and codes by the Coast Guard. These include the American Bureau of Shipping (ABS), American Society of Mechanical Engineers (ASME), American National Standards Institute (ANSI), American Society for Testing and Materials (ASTM), American Welding Society (AWS), Underwriters Laboratories (UL), and many others. In addition, Coast Guard regulations must also implement and conform to the numerous international maritime safety treaties to which the United States is signatory. The Committee expects that the regulatory flexibility being provided will not reduce the present vessel inspection requirements that have been historically developed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3305(a) establishes the statutory scope of the Coast Guard’s vessel inspection authority and duty. The inspection process shall ensure that a vessel is of suitable structure, equipment, and accommodations, is maintained in an operating condition consistent with safety of life and property, and complies with applicable marine safety laws and regulations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) requires that defective life preservers and firehose be destroyed in the presence of the inspecting official, normally a qualified Coast Guard marine inspector. The Committee believes that if this equipment is defective for use on an inspected vessel, it should be destroyed so that it cannot be used on an uninspected or recreational vessel.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) provides flexibility in the inspection of various sizes of nautical school vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6604829-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf660482a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Frank LoBiondo Coast Guard Authorization Act of 2018, referred to in subsec. (d)(3)(B), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf660482b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “Frank LoBiondo Coast Guard Authorization Act of 2018” for “Coast Guard Authorization Act of 2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" realigned margins."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s416/b"},"text":"Pub. L. 108–293, § 416(b)","children":[],"tail":", designated existing provisions as par. (1), redesignated former pars. (1) to (6) as subpars. (A) to (F), respectively, of par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/s416/a"},"text":"Pub. L. 108–293, § 416(a)","children":[],"tail":", added par. (4) and redesignated former pars. (4) and (5) as (5) and (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s558"},"text":"section 558 of title 40","children":[],"tail":"” for “section 13 of the Coast Guard Authorization Act of 1986”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/640"},"text":"Pub. L. 99–640","children":[],"tail":" inserted “or by an educational institution under section 13 of the Coast Guard Authorization Act of 1986”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/36"},"text":"Pub. L. 99–36","children":[],"tail":" substituted “lifesaving” and “life preserver, lifesaving device, or firehose” for “life-saving” and “life preserver or firehose”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf660482c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf660482d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1984-04-15"},"text":"Apr. 15, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/89/s2/g/1"},"text":"section 2(g)(1) of Pub. L. 98–89","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
