{"tag":"section","attrib":{"id":"idf6b3bf6e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42107"},"text":null,"children":[{"tag":"num","attrib":{"value":"42107"},"text":"§ 42107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refusal of clearance and entry","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"At the request of the Federal Maritime Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bf6f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42107/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of Homeland Security shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b3bf70-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42107/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuse the clearance required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s60105"},"text":"section 60105 of this title","children":[],"tail":" to a vessel of a country that is named in a regulation prescribed by the Commission under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s42101"},"text":"section 42101 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b3bf71-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42107/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect any fees imposed by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s42106/4"},"text":"section 42106(4) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bf72-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42107/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of the department in which the Coast Guard is operating shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b3bf73-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42107/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny entry, for purposes of oceanborne trade, of a vessel of a country that is named in a regulation prescribed by the Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s42101"},"text":"section 42101 of this title","children":[],"tail":", to a port or place in the United States or the navigable waters of the United States; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b3bf74-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42107/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detain the vessel at the port or place in the United States from which it is about to depart for another port or place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b3bf75-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1551"},"text":"120 Stat. 1551","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b3bf76-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b3bf77-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"