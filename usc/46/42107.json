,"attrib":{},"text":"46 App.:876(j).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-06-05/ch250/s19/j"},"text":"June 5, 1920, ch. 250, § 19(j)","children":[],"tail":"; as added "},{"tag":"html:a","attrib":{"href":"/us/pl/101/595/tI/s103/2"},"text":"Pub. L. 101–595, title I, § 103(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/2979"},"text":"104 Stat. 2979","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tIII/s301"},"text":"Pub. L. 105–258, title III, § 301","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1915"},"text":"112 Stat. 1915","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1), the words “Secretary of Homeland Security” are substituted for “collector of customs at the port or place of destination in the United States” because the functions of the Customs Service and of the Secretary of the Treasury relating thereto were transferred to the Secretary of Homeland Security by section 403(1) of the Homeland Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2178"},"text":"116 Stat. 2178","children":[],"tail":"). The functions of the collector of customs previously were vested in the Secretary of the Treasury by Reorganization Plan No. 26 of 1950, and the office of collector of customs previously was abolished by Reorganization Plan No. 1 of 1965."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
