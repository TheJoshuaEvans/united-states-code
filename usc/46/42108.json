{"tag":"section","attrib":{"id":"idf6b3bf79-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42108"},"text":null,"children":[{"tag":"num","attrib":{"value":"42108"},"text":"§ 42108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for operating under suspended tariff or service contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A common carrier that accepts or handles cargo for carriage under a tariff or service contract that has been suspended under section 42104(d)(1) or 42106(2) of this title, or after its right to use another tariff or service contract has been suspended under those provisions, is liable to the United States Government for a civil penalty of not more than $50,000 for each day that it is found to be operating under a suspended tariff or service contract.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6b3bf7a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1551"},"text":"120 Stat. 1551","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b3bf7b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b3bf7c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b3bf7d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:the