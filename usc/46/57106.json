{"tag":"section","attrib":{"id":"idf6f1b2a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57106"},"text":null,"children":[{"tag":"num","attrib":{"value":"57106"},"text":"§ 57106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance, improvement, and operation of vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f1b2a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may maintain, repair, recondition, remodel, and improve vessels owned by the United States Government and in the possession or under the control of the Secretary, to equip them adequately for competition in the foreign trade of the United States. The Secretary may operate such a vessel or charter the vessel on terms and conditions the Secretary considers appropriate to carry out the purposes of this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f1b2a5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documentation and Restrictions on Operation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel reconditioned, remodeled, or improved under subsection (a) shall be documented under the laws of the United States and remain so documented for at least 5 years after completion of the reconditioning, remodeling, or improvement. During that period, it shall be operated on voyages that are not exclusively coastwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b2a6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1661"},"text":"120 Stat. 1661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b2a7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f1b2a8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f1b2a9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[]