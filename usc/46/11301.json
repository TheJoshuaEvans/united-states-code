{"tag":"section","attrib":{"id":"idf68fe4df-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301"},"text":null,"children":[{"tag":"num","attrib":{"value":"11301"},"text":"§ 11301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Logbook and entry requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68fe4e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except a vessel on a voyage from a port in the United States to a port in Canada, a vessel of the United States shall have an official logbook if the vessel is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68fe4e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a voyage from a port in the United States to a foreign port; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of at least 100 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" and is on a voyage between a port of the United States on the Atlantic Ocean and on the Pacific Ocean."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe4e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The master of the vessel shall make or have made in the official logbook the following entries:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68fe4e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each legal conviction of a seaman of the vessel and the punishment inflicted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each offense committed by a seaman of the vessel for which it is intended to prosecute or to enforce under a forfeiture, together with statements about reading the entry and the reply made to the charge as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s11502"},"text":"section 11502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each offense for which punishment is inflicted on board and the punishment inflicted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the conduct, character, and qualifications of each seaman of the vessel or a statement that the master declines to give an opinion about that conduct, character, and qualifications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each illness of or injury to a seaman of the vessel, the nature of the illness or injury, and the medical treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each death on board, with the cause of death, and if a seaman, the information required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s10702"},"text":"section 10702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each birth on board, with the sex of the infant and name of the parents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4eb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each marriage on board, with the names and ages of the parties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4ec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of each seaman who ceases to be a crewmember (except by death), with the place, time, manner, and the cause why the seaman ceased to be a crewmember.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4ed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wages due to a seaman who dies during the voyage and the gross amount of all deductions to be made from the wages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4ee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of the property of a seaman who dies during the voyage, including a statement of each article sold and the amount received for the property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4ef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when a marine casualty occurs, a statement about the casualty and the circumstances under which it occurred, made immediately after the casualty when practicable to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4f0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11301/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when a vessel fails to carry out ballast water management requirements as applicable and pursuant to regulations promulgated by the Secretary, including when the vessel fails to carry out ballast water management requirements due to an allowed safety exemption, a statement regarding the failure to comply and the circumstances under which the failure occurred, made immediately after the failure, when practicable to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68fe4f1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/581"},"text":"97 Stat. 581","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s30"},"text":"Pub. L. 98–557, § 30","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2875"},"text":"98 Stat. 2875","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s742"},"text":"Pub. L. 104–324, title VII, § 742","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3942"},"text":"110 Stat. 3942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIX/s903/d"},"text":"Pub. L. 115–282, title IX, § 903(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4357"},"text":"132 Stat. 4357","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68fe4f2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68fe4f3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68fe4f4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"11301","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:201","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 11301 requires United States vessels on certain types of voyages to have an official logbook and lists the types of entries that must be made in the logbook.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68fe4f5-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68fe4f6-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" added par. (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “100 gross tons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" amended subsec. (a) generally, which prior to amendment read as follows: “A vessel of the United States on a voyage between a port in the United States and a port in a foreign country, and a vessel of the United States of at least 75 gross tons on a voyage between a port of the United States on the Atlantic Ocean and a port of the United States on the Pacific Ocean, shall have an official logbook.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
