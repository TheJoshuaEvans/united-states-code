{"tag":"section","attrib":{"id":"idf6e81647-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55110"},"text":null,"children":[{"tag":"num","attrib":{"value":"55110"},"text":"§ 55110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of valueless material or dredged material","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55102"},"text":"Section 55102 of this title","children":[],"tail":" applies to the transportation of valueless material or dredged material, regardless of whether it has commercial value, from a point in the United States or on the high seas within the exclusive economic zone, to another point in the United States or on the high seas within the exclusive economic zone."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6e81648-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1637"},"text":"120 Stat. 1637","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3527/b/1"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3527(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/602"},"text":"122 Stat. 602","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e81649-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e8164a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e8164b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55110","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:883 (12th proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-06-05/ch250/s27"},"text":"June 5, 1920, ch. 250, § 27","children":[],"tail":" (12th proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/999"},"text":"41 Stat. 999","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/100/329/s1/a"},"text":"Pub. L. 100–329, § 1(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"June 7, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/588"},"text":"102 Stat. 588","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “or place” are omitted as surplus. The words “as defined in the Presidential Proclamation of ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"March 10, 1983","children":[],"tail":"” are omitted because “exclusive economic zone” is defined in chapter 1 of the revised title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6e8164c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6e8164d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" inserted “valueless material or” before “dredged material” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6e8164e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6e8164f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Nonapplicability of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/329"},"text":"Pub. L. 100–329","children":[],"tail":" to Certain Vessels"}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/tV/s5501/c"},"text":"Pub. L. 102–587, title V, § 5501(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5085"},"text":"106 Stat. 5085","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/587/tV/s5501/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Act of ","children":[{"tag":"date","attrib":{"date":"1988-06-07"},"text":"June 7, 1988","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/100/329"},"text":"Public Law 100–329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/102/588"},"text":"102 Stat. 588","children":[],"tail":") [amending sections 316 and 883 (from which this section was derived) of the former Appendix to this title and enacting provisions set out below], including the amendments made by that Act, does not apply to a vessel—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in the transportation of valueless material or valueless dredged material; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owned or chartered by a corporation that had on file with the Secretary of Transportation on ","children":[{"tag":"date","attrib":{"date":"1989-08-01"},"text":"August 1, 1989","children":[],"tail":", the certificate specified in section 27A of the Merchant Marine Act, 1920 (46 App. U.S.C. 883–1) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12118"},"text":"46 U.S.C. 12118","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6e81650-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transportation of Municipal Sewage Sludge","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/329/s3"},"text":"Pub. L. 100–329, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-07"},"text":"June 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/589"},"text":"102 Stat. 589","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/329/s3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Notwithstanding the provisions of section 1 of this Act [amending section 883 of the former Appendix to this title, from which this section was derived], a vessel may transport municipal sewage sludge if that vessel, regardless of where it was built, is documented under the laws of the United States and, on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-06-07"},"text":"June 7, 1988","children":[],"tail":"], that vessel—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in use by a municipality for the transportation of sewage sludge; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is under contract with a municipality for the transportation of sewage sludge.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6e81651-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Vessel Under Contract With Municipality for Transportation of Sewage Sludge: Applicability of Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/329/s4"},"text":"Pub. L. 100–329, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-07"},"text":"June 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/589"},"text":"102 Stat. 589","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/329/s4"},"text":"“For purposes of the first paragraph of section 805(a) of the Merchant Marine Act, 1936 (46 App. U.S.C. 1223(a)) [now ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s58101"},"text":"46 U.S.C. 58101","children":[],"tail":"], a vessel described in section 3(2) of this Act [set out as a note above] is not a vessel engaged in domestic intercoastal or coastwise service, but the prohibitions in the second paragraph apply to that vessel.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6e81652-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Certificate of Documentation to Vessel Transporting Valueless Material in Coastwise Trade, or Dredged Material, Whether or Not of Value; Issuance, Endorsement, Etc.","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/329/s5"},"text":"Pub. L. 100–329, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-06-07"},"text":"June 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/589"},"text":"102 Stat. 589","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/329/s5"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":""},"text":null,"children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“Notwithstanding the provisions of section 1 of this Act [amending section 883 of the former Appendix to this title, from which this section was derived], the Secretary of the department in which the Coast Guard is operating may issue a certificate of documentation under section 12106 [see section 12112] of title 46, United States Code, to a vessel that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in transporting only valueless material in the coastwise trade or transporting dredged material, whether or not of value, (A) from a point or place on the high seas within the Exclusive Economic Zone as defined in the Presidential Proclamation of ","children":[{"tag":"date","attrib":{"date":"1983-03-10"},"text":"March 10, 1983","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1453"},"text":"16 U.S.C. 1453","children":[],"tail":" note], to a point or place in the United States or to another point or place on the high seas within such Exclusive Economic Zone or (B) from a point or place within the United States to a point or place on the high seas within such Exclusive Economic Zone;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had a certificate of documentation issued under section 12105 [see section 12111] of that title on ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had been sold foreign or placed under a foreign registry before that certificate was issued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was built in the United States;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that such certificate of documentation shall be endorsed to restrict the use of such vessel to the transportation of valueless material in the coastwise trade, and to the transportation of dredged material, whether or not of value, (i) from a point or place on the high seas within such Exclusive Economic Zone to a point or place in the United States or to another point or place on the high seas within such Exclusive Economic Zone, or (ii) from a point or place within the United States to a point or place on the high seas within such Exclusive Economic Zone.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
