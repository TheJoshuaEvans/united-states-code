{"tag":"section","attrib":{"id":"idf6591c7c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2303a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2303a"},"text":"§ 2303a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Post serious marine casualty alcohol testing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6591c7d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2303a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish procedures to ensure that after a serious marine casualty occurs, alcohol testing of crew members or other individuals responsible for the operation or other safety-sensitive functions of the vessel or vessels involved in such casualty is conducted no later than 2 hours after the casualty occurs, unless such testing cannot be completed within that time due to safety concerns directly related to the casualty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6591c7e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2303a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The procedures in subsection (a) shall require that if alcohol testing cannot be completed within 2 hours of the occurrence of the casualty, such testing shall be conducted as soon thereafter as the safety concerns in subsection (a) have been adequately addressed to permit such testing, except that such testing may not be required more than 8 hours after the casualty occurs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6591c7f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIII/s304/d/1"},"text":"Pub. L. 105–383, title III, § 304(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3419"},"text":"112 Stat. 3419","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(b)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4751"},"text":"134 Stat. 4751","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6591c80-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6591c81-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6591c82-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “individuals” for “persons”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
