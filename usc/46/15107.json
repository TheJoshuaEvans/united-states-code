{"tag":"section","attrib":{"id":"idf6a0ad52-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107"},"text":null,"children":[{"tag":"num","attrib":{"value":"15107"},"text":"§ 15107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Navigation Safety Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a0ad53-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a National Navigation Safety Advisory Committee (in this section referred to as the “Committee”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad54-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall advise the Secretary on matters relating to maritime collisions, rammings, and groundings, Inland Rules of the Road, International Rules of the Road, navigation regulations and equipment, routing measures, marine information, and aids to navigation systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0ad55-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0ad56-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall consist of not more than 21 members appointed by the Secretary in accordance with this section and section 15109 of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad57-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expertise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad58-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Committee shall represent 1 of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6a0ad59-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commercial vessel owners or operators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad5a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Professional mariners.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad5b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recreational boaters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad5c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The recreational boating industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad5d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State agencies responsible for vessel or port safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6a0ad5e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Maritime Law Association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0ad5f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s15107/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall, based on the needs of the Coast Guard, determine the number of members of the Committee who represent each entity specified in paragraph (3). Neither this paragraph nor any other provision of law shall be construed to require an equal distribution of members representing each entity specified in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a0ad60-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVI/s601/a"},"text":"Pub. L. 115–282, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4285"},"text":"132 Stat. 4285","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
