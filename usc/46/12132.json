{"tag":"section","attrib":{"id":"idf6970ffe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12132"},"text":null,"children":[{"tag":"num","attrib":{"value":"12132"},"text":"§ 12132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss of coastwise trade privileges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6970fff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sold Foreign or Placed Under Foreign Registry","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel of more than 200 gross tons (as measured under chapter 143 of this title), eligible to engage in the coastwise trade, and later sold foreign in whole or in part or placed under foreign registry may not thereafter engage in the coastwise trade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6971000-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rebuilt Outside the United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel eligible to engage in the coastwise trade and later rebuilt outside the United States may not thereafter engage in the coastwise trade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6971001-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1505"},"text":"120 Stat. 1505","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6971002-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6971003-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6971004-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12132(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:883 (1st proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-06-05/ch250/s27"},"text":"June 5, 1920, ch. 250, § 27","children":[],"tail":" (1st proviso, 2d proviso less meaning of “rebuilt”), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/999"},"text":"41 Stat. 999","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1935-07-02/ch355"},"text":"July 2, 1935, ch. 355","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/442"},"text":"49 Stat. 442","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1956-07-14/ch600/s1"},"text":"July 14, 1956, ch. 600, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/544"},"text":"70 Stat. 544","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/86/583/s1"},"text":"Pub. L. 86–583, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"July 5, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/321"},"text":"74 Stat. 321","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/100/239/s6/c/1"},"text":"Pub. L. 100–239, § 6(c)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Jan. 11, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1782"},"text":"101 Stat. 1782","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/324/tXI/s1120/e"},"text":"Pub. L. 104–324, title XI, § 1120(e)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3978"},"text":"110 Stat. 3978","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"12132(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:883 (2d proviso less meaning of “rebuilt”).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “eligible to engage in the coastwise trade” are substituted for “having at any time acquired the lawful right to engage in the coastwise trade, either by virtue of having been built in, or documented under the laws of the United States”, and the words “thereafter engage” are substituted for “hereafter acquire the right to engage”, to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “eligible to engage in the coastwise trade” are substituted for “which has acquired the lawful right to engage in the coastwise trade, by virtue of having been built in or documented under the laws of the United States”, and the words “thereafter engage” are substituted for “have the right thereafter to engage”, to eliminate unnecessary words. See section 12101 for the meaning of “rebuilt in the United States”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
