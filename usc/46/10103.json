{"tag":"section","attrib":{"id":"idf688b88e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10103"},"text":null,"children":[{"tag":"num","attrib":{"value":"10103"},"text":"§ 10103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf688b88f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A master of a vessel to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s8701/a"},"text":"section 8701(a) of this title","children":[],"tail":" applies, who engages or discharges a seaman, shall submit reports to the vessel owner in the form, content, and manner of filing as prescribed by regulation, to ensure compliance with laws related to manning and the engagement and discharge of seamen."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf688b890-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to a ferry or towing vessel operated in connection with a ferry operation, employed only in trades other than with foreign ports, lakes, bays, sounds, bayous, canals, or harbors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf688b891-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/560"},"text":"97 Stat. 560","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/206/tIV/s417"},"text":"Pub. L. 103–206, title IV, § 417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2438"},"text":"107 Stat. 2438","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf688b892-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf688b893-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf688b894-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:643(","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")"}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10103 requires that masters who engage or discharge seamen submit to the Coast Guard reports of the manning of the vessel, and reports of shipping agreements which are not supervised by a shipping commissioner. It also contains a number of exceptions for specified vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf688b895-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf688b896-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206"},"text":"Pub. L. 103–206","children":[],"tail":" struck out “without a shipping commissioner being present” after “discharges a seaman” and inserted “to the vessel owner” after “shall submit reports”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
