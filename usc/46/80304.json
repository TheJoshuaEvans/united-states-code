{"tag":"section","attrib":{"id":"idf70bf12c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80304"},"text":null,"children":[{"tag":"num","attrib":{"value":"80304"},"text":"§ 80304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on ice patrol data","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding sections 80301 and 80302, data collected by an ice patrol conducted by the Coast Guard under this chapter may not be disseminated to a vessel unless such vessel is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf70bf12d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80304/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documented under the laws of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf70bf12e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s80304/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documented under the laws of a foreign country that made the payment or contribution required under section 80301(b) for the year preceding the year in which the data is collected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf70bf12f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIII/s314/a/3"},"text":"Pub. L. 113–281, title III, § 314(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3049"},"text":"128 Stat. 3049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf70bf130-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf70bf131-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf70bf132-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2017-01-01"},"text":"Jan. 1, 2017","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/s314/c"},"text":"section 314(c) of Pub. L. 113–281","children":[],"tail":", set out as an Effective Date of 2014 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s80301"},"text":"section 80301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
