{"tag":"section","attrib":{"id":"idf6ea877e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55331"},"text":null,"children":[{"tag":"num","attrib":{"value":"55331"},"text":"§ 55331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea877f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55331/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"American great lakes vessel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “American Great Lakes vessel” means a vessel so designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55332"},"text":"section 55332 of this title","children":[],"tail":", but only during the period the designation is in effect."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea8780-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55331/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Great lakes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Great Lakes” means Lake Superior, Lake Michigan, Lake Huron, Lake Erie, Lake Ontario, the Saint Lawrence River west of Saint Regis, New York, and their connecting and tributary waters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea8781-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55331/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Great lakes shipping season","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Great Lakes shipping season” means the period each year during which the Saint Lawrence Seaway is open for navigation by vessels, as declared by the Great Lakes St. Lawrence Seaway Development Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ea8782-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1648"},"text":"120 Stat. 1648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tV/s512/c/6/E"},"text":"Pub. L. 116–260, div. AA, title V, § 512(c)(6)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2757"},"text":"134 Stat. 2757","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ea8783-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ea8784-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ea8785-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"childre