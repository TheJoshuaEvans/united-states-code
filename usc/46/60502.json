{"tag":"section","attrib":{"id":"idf6f66dde-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60502"},"text":null,"children":[{"tag":"num","attrib":{"value":"60502"},"text":"§ 60502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discriminating duty on goods imported in foreign vessels or from contiguous countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f66ddf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Imposition of Duty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A discriminating duty of 10 percent ad valorem (in addition to other duties imposed by law) is imposed on goods—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f66de0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" imported in a vessel not of the United States unless the vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6f66de1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60502/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled by law or treaty to enter the ports of the United States on payment of the same duties as are payable on goods imported in a vessel of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f66de2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60502/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6f66de3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60502/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned only by citizens of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6f66de4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60502/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after entering a port of the United States, becomes documented as a vessel of the United States before leaving that port; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f66de5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produced or manufactured in a foreign country not contiguous to the United States and imported from a country contiguous to the United States, unless imported in the usual course of strictly retail trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f66de6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Seizure and Forfeiture","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If goods are imported without payment of the duty required by this section, the goods and the vessel in which they are imported may be seized by, and forfeited to, the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f66de7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s9/b"},"text":"Pub. L. 109–304, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1680"},"text":"120 Stat. 1680","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f66de8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f66de9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f66dea-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60502(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"19:128.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1913-10-03/ch16"},"text":"Oct. 3, 1913, ch. 16","children":[],"tail":", § IV(J)(1), "},{"tag":"html:a","attrib":{"href":"/us/stat/38/196"},"text":"38 Stat. 196","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1915-03-15/ch171/s1"},"text":"Mar. 15, 1915, ch. 171, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/38/1193"},"text":"38 Stat. 1193","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/182/tVI/s689/a/1"},"text":"Pub. L. 103–182, title VI, § 689(a)(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 8, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/2222"},"text":"107 Stat. 2222","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:146.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60502(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"19:130 (last sentence related to 19:128).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1913-10-03/ch16"},"text":"Oct. 3, 1913, ch. 16","children":[],"tail":", § IV(J)(2), "},{"tag":"html:a","attrib":{"href":"/us/stat/38/196"},"text":"38 Stat. 196","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the word “goods” is substituted for “goods, wares, or merchandise” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), subparagraphs (A) and (B) are substituted for “but this discriminating duty shall not apply to goods, wares, or merchandise which shall be imported in vessels not of the United States entitled at the time of such importation by treaty or convention or Act of Congress to be entered in the ports of the United States on payment of the same duties as shall then be payable on goods, wares, and merchandise imported in vessels of the United States, nor to goods, wares, and merchandise imported in a vessel owned by citizens of the United States but not a vessel of the United States if such vessel after entering an American port shall, before leaving the same, be documented under chapter 121 of title 46” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(2) is substituted for “or which being the production or manufacture of any foreign country not contiguous to the United States, shall come into the United States from such contiguous country” and “but this discriminating duty shall not apply . . . nor to such products or manufactures as shall be imported from such contiguous countries in the usual course of strictly retail trade” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for the source provision for consistency with section 60501(d) and to eliminate unnecessary words. See note for section 60501(d) in this report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
