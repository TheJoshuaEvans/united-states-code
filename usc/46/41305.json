“paragraph (3) or (6) of section 41104(a), or paragraph (1) or (3) of section 41105” for “41104(3) or (6), or 41105(1) or (3) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s12"},"text":"Pub. L. 117–146, § 12","children":[],"tail":", substituted “subsection (b) or (c) of section 41102” for “41102(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s15/c/2"},"text":"Pub. L. 117–146, § 15(c)(2)","children":[],"tail":", substituted “subparagraph (A) or (B) of section 41104(a)(4)” for “section 41104(4)(A) or (B) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/s402/1"},"text":"Pub. L. 113–281, § 402(1)","children":[],"tail":", struck out “, plus reasonable attorney fees” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/s402/2"},"text":"Pub. L. 113–281, § 402(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
