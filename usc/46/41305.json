{"tag":"section","attrib":{"id":"idf6b14eed-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41305"},"text":null,"children":[{"tag":"num","attrib":{"value":"41305"},"text":"§ 41305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of reparations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b14eee-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “actual injury” includes the loss of interest at commercial rates compounded from the date of injury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14eef-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basic Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the complaint was filed within the period specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s41301/a"},"text":"section 41301(a) of this title","children":[],"tail":", the Federal Maritime Commission shall direct the payment of reparations to the complainant for actual injury caused by a violation of this part."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14ef0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On a showing that the injury was caused by an activity prohibited by subsection (b) or (c) of section 41102, paragraph (3) or (6) of section 41104(a), or paragraph (1) or (3) of section 41105, the Commission may order the payment of additional amounts, but the total recovery of a complainant may not exceed twice the amount of the actual injury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14ef1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Difference Between Rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the injury was caused by an activity prohibited by subparagraph (A) or (B) of section 41104(a)(4), the amount of the injury shall be the difference between the rate paid by the injured shipper and the most favorable rate paid by another shipper.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14ef2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41305/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attorney Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any action brought under section 41301, the prevailing party may be awarded reasonable attorney fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b14ef3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1546"},"text":"120 Stat. 1546","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIV/s402"},"text":"Pub. L. 113–281, title IV, § 402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3056"},"text":"128 Stat. 3056","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/146"},"text":"Pub. L. 117–146","children":[],"tail":", §§ 12, 15(c), "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1279"},"text":"136 Stat. 1279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXV/s3535/g"},"text":"Pub. L. 118–159, div. C, title XXXV, § 3535(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2315"},"text":"138 Stat. 2315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b14ef4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b14ef5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b14ef6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":