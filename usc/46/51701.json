{"tag":"section","attrib":{"id":"idf6c91c54-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51701"},"text":null,"children":[{"tag":"num","attrib":{"value":"51701"},"text":"§ 51701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Maritime Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c91c55-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may establish and maintain a voluntary organization, to be known as the United States Maritime Service, for the training of citizens of the United States to serve on merchant vessels of the United States and to perform functions to assist the United States merchant marine, as determined necessary by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c91c56-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c91c57-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the number of individuals to be enrolled for training and reserve purposes in the Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91c58-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fix the rates of pay and allowances of the individuals without regard to chapter 51 or subchapter III of chapter 53 of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91c59-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51701/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe the course of study and the periods of training for the Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91c5a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51701/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe the uniform of the Service and the rules on providing and wearing the uniform.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c91c5b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ranks, Grades, and Ratings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The ranks, grades, and ratings for personnel of the Service shall be the same as those prescribed for personnel of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c91c5c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51701/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Medals and Awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may establish and maintain a medals and awards program to recognize distinguished service, superior achievement, professional performance, and other commendable achievement by personnel of the Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c91c5d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1582"},"text":"120 Stat. 1582","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3509"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3557"},"text":"119 Stat. 3557","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/364/dC/tXXXV/s3510/d/1"},"text":"Pub. L. 109–364, div. C, title XXXV, § 3510(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2520"},"text":"120 Stat. 2520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3523/a/4"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3523(a)(4)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/599"},"text":"122 Stat. 599","children":[],"tail":", 600.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c91c5e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historical