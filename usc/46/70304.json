{"tag":"section","attrib":{"id":"idf709800e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70304"},"text":null,"children":[{"tag":"num","attrib":{"value":"70304"},"text":"§ 70304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel advisories on security at foreign ports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf709800f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On being notified by the Secretary that the Secretary has determined that a condition exists that threatens the safety or security of passengers, passenger vessels, or crew traveling to or from a foreign port that the Secretary has determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70303/b"},"text":"section 70303(b) of this title","children":[],"tail":" does not maintain and administer effective security measures, the Secretary of State immediately shall issue a travel advisory for that port. The Secretary of State shall take the necessary steps to widely publicize the travel advisory."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098010-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lifting Advisories","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A travel advisory issued under subsection (a) may be lifted only if the Secretary, in consultation with the Secretary of State, has determined that effective security measures are maintained and administered at the port.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7098011-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of State shall notify Congress immediately of any change in the status of a travel advisory issued under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf7098012-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s10/2"},"text":"Pub. L. 109–304, § 10(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1684"},"text":"120 Stat. 1684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf7098013-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf7098014-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf7098015-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70304","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1804.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/99/399/tIX/s908"},"text":"Pub. L. 99–399, title IX, § 908","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/891"},"text":"100 Stat. 891","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/277/dG/tXXII/s2224/b"},"text":"Pub. L. 105–277, div. G, title XXII, § 2224(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/2681-819"},"text":"112 Stat. 2681–819","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “with respect to which the Secretary of Transportation had made the determination described in section 1803(d) of this Appendix” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
