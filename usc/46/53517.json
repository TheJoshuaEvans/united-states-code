{"tag":"section","attrib":{"id":"idf6d9e50c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53517"},"text":null,"children":[{"tag":"num","attrib":{"value":"53517"},"text":"§ 53517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d9e50d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 120 days after the close of each calendar year, the Secretary of Transportation and the Secretary of Commerce each shall provide the Secretary of the Treasury a written report on the capital construction funds under the particular Secretary’s jurisdiction for the calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d9e50e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall state the name and taxpayer identification number of each person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d9e50f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53517/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a capital construction fund during the calendar year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d9e510-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53517/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining a capital construction fund on the last day of the calendar year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d9e511-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53517/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminating a capital construction fund during the calendar year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d9e512-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53517/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making a deposit to or withdrawal from a capital construction fund during the calendar year, and the amount of the deposit or withdrawal; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d9e513-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53517/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" having been determined during the calendar year to have failed to fulfill a substantial obligation under a capital construction fund agreement to which the person is a party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d9e514-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1600"},"text":"120 Stat. 1600","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d9