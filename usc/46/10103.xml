<html:tr style="border-top:1px solid black; -uslm-lc:I01;"><html:td style=" text-align:justify; vertical-align:top; padding-right:2pt;"><html:p style=" text-align:justify; text-indent: -1em; padding-left:1em;" class="leaders"><html:span>10103</html:span></html:p></html:td><html:td style=" text-align:left; vertical-align:top; padding-left: 2pt;"><html:p style=" text-align:left; text-indent: -1em; padding-left:1em;">46:643(<html:i>l</html:i>)</html:p></html:td></html:tr>
</html:tbody>
