{"tag":"section","attrib":{"id":"idf6925554-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11507"},"text":null,"children":[{"tag":"num","attrib":{"value":"11507"},"text":"§ 11507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surrender of offending officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When an officer of a vessel of the United States (except the master) has violated ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2191"},"text":"section 2191 of title 18","children":[],"tail":", and the master has actual knowledge of the offense or if complaint is made within 3 days after reaching port, the master shall surrender the offending officer to the proper authorities. If the master fails to use diligence to comply with this section and the offender escapes, the owner, the master, and the vessel are liable for damages to the individual unlawfully punished."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6925555-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/584"},"text":"97 Stat. 584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6925556-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6925557-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6925558-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"11507","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:712","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 11507 requires a master of a vessel of the United States to surrender to the proper authorities any officer who has violated ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2191"},"text":"section 2191 of title 18","children":[],"tail":" (which provides a penalty for cruelty to seamen by officers), and penalizes the master for noncompliance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
