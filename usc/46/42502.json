{"tag":"section","attrib":{"id":"idf6b3bfc7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42502"},"text":null,"children":[{"tag":"num","attrib":{"value":"42502"},"text":"§ 42502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Shipper Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b3bfc8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a National Shipper Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bfc9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall advise the Federal Maritime Commission on policies relating to the competitiveness, reliability, integrity, and fairness of the international ocean freight delivery system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b3bfca-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bfcb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall consist of 24 members appointed by the Commission in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfcc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expertise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Committee shall have particular expertise, knowledge, and experience in matters relating to the function of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bfcd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the Committee shall be appointed as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b3bfce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42502/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Twelve members shall represent entities who import cargo to the United States using ocean common carriers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b3bfcf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42502/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Twelve members shall represent entities who export cargo from the United States using ocean common carriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b3bfd0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXVI"},"text":"Pub. L. 116–283, div. G, title LVXXXVI","children":[],"tail":" [LXXXVI], § 8604(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4762"},"text":"134 Stat. 4762","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXV/s3535/h"},"text":"Pub. L. 118–159, div. C, title XXXV, § 3535(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2315"},"text":"138 Stat. 2315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b3bfd1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6b3bfd2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6b3bfd3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “"},{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—Members of the Committee shall be appointed as follows:” for “"},{"tag":"inline","attrib