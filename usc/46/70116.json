{"tag":"section","attrib":{"id":"idf7071037-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70116"},"text":null,"children":[{"tag":"num","attrib":{"value":"70116"},"text":"§ 70116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Port, harbor, and coastal facility security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7071038-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may take actions described in subsection (b) to prevent or respond to an act of terrorism, cyber incidents, transnational organized crime, and foreign state threats against—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7071039-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an individual, vessel, or public or commercial structure, that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf707103a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70116/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the jurisdiction of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf707103b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70116/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located within or adjacent to the marine environment; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf707103c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel of the United States or an individual on board that vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf707103d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under subsection (a), the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf707103e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out or require measures, including inspections, port and harbor patrols, the establishment of security and safety zones, and the development of contingency plans and procedures, to prevent or respond to acts of terrorism, cyber incidents, transnational organized crime, and foreign state threats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf707103f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruit members of the Regular Coast Guard and the Coast Guard Reserve and train members of the Regular Coast Guard and the Coast Guard Reserve in the techniques of preventing and responding to acts of terrorism, cyber incidents, transnational organized crime, and foreign state threats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7071040-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70116/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dispatch properly trained and qualified, armed (as needed), Coast Guard personnel on vessels and public or commercial structures on or adjacent to waters subject to United States jurisdiction to deter or respond to acts of terrorism, cyber incidents, transnational organized crime, foreign state threats, or transportation security incidents, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70101"},"text":"section 70101 of title 46","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf7071041-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions, Administration, and Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall be treated as part of chapter 700 for purposes of sections 70031, 70032, 70033, 70035, and 70036. When preventing or responding to acts of terrorism, cyber incidents, transnational organized crime, or foreign state threats, the Secretary may carry out this section without regard to chapters 5 and 6 of title 5 or Executive Order Nos. 12866 and 13563.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf7071042-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIV/s402/b/1"},"text":"Pub. L. 115–282, title IV, § 402(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4264"},"text":"132 Stat. 4264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8341, "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4709"},"text":"134 Stat. 4709","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXVII/s7701/b"},"text":"Pub. L. 119–60, div. G, title LXXVII, § 7701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1835"},"text":"139 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf7071043-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf7071044-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf7071045-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order Nos. 12866 and 13563, referred to in subsec. (c), are set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s601"},"text":"section 601 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf7071046-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section, as added and amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":", is based on subsecs. (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/92/340/s7"},"text":"Pub. L. 92–340, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/399/tIX/s906"},"text":"Pub. L. 99–399, title IX, § 906","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/890"},"text":"100 Stat. 890","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s107/a"},"text":"Pub. L. 107–295, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2088"},"text":"116 Stat. 2088","children":[],"tail":", which was formerly classified to section 1226(a), (b) of Title 33, Navigation and Navigable Waters, before being transferred to this chapter and renumbered as this section. Subsections (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/92/340/s7"},"text":"section 7 of Pub. L. 92–340","children":[],"tail":" were also renumbered as "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s70102a"},"text":"section 70102a of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIV/s408/a"},"text":"Pub. L. 115–282, title IV, § 408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4268"},"text":"132 Stat. 4268","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf7071047-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 70116, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s102/a"},"text":"Pub. L. 107–295, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2083"},"text":"116 Stat. 2083","children":[],"tail":", related to secure systems of transportation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dJ/s1809/b"},"text":"Pub. L. 115–254, div. J, § 1809(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3538"},"text":"132 Stat. 3538","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf7071048-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7701/b/1"},"text":"Pub. L. 119–60, § 7701(b)(1)","children":[],"tail":", substituted “terrorism, cyber” for “terrorism cyber”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7701/b/2"},"text":"Pub. L. 119–60, § 7701(b)(2)","children":[],"tail":", inserted a comma after “acts of terrorism”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8341/1"},"text":"Pub. L. 116–283, § 8341(1)","children":[],"tail":", inserted “, cyber incidents, transnational organized crime, and foreign state threats” after “an act of terrorism” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8341/2/A"},"text":"Pub. L. 116–283, § 8341(2)(A)","children":[],"tail":", inserted “cyber incidents, transnational organized crime, and foreign state threats” after “terrorism”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8341/2/B"},"text":"Pub. L. 116–283, § 8341(2)(B)","children":[],"tail":", substituted “, armed (as needed),” for “armed” and “terrorism, cyber incidents, transnational organized crime, foreign state threats, or transportation security incidents,” for “terrorism or transportation security incidents,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8341/3"},"text":"Pub. L. 116–283, § 8341(3)","children":[],"tail":", substituted “70033,” for “70034,” and inserted at end “When preventing or responding to acts of terrorism, cyber incidents, transnational organized crime, or foreign state threats, the Secretary may carry out this section without regard to chapters 5 and 6 of title 5 or Executive Order Nos. 12866 and 13563.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s402/b/1"},"text":"Pub. L. 115–282, § 402(b)(1)","children":[],"tail":", transferred section catchline and subsecs. (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/92/340/s7"},"text":"section 7 of Pub. L. 92–340","children":[],"tail":" to this chapter and redesignated them as this section. See Codification note above. Catchline text was editorially conformed to the style used in this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s402/b/2"},"text":"Pub. L. 115–282, § 402(b)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
