{"tag":"section","attrib":{"id":"idf6c91c6d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51703"},"text":null,"children":[{"tag":"num","attrib":{"value":"51703"},"text":"§ 51703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c91c6e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may provide additional training on maritime subjects to supplement other training opportunities and make the training available to the personnel of the merchant marine of the United States and individuals preparing for a career in the merchant marine of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c91c6f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Equipment, Supplies, and Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c91c70-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare or buy equipment or supplies required for the additional training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c91c71-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to section 6101(b) to (d) of title 41, make contracts for services the Secretary considers necessary to prepare the equipment and supplies and to supervise and administer the additional training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c91c72-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1583"},"text":"120 Stat. 1583","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/n"},"text":"Pub. L. 111–350, § 5(n)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3853"},"text":"124 Stat. 3853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c91c73-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6c91c74-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6c91c75-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"