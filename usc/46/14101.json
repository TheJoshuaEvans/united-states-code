{"tag":"section","attrib":{"id":"idf69bcadb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14101"},"text":null,"children":[{"tag":"num","attrib":{"value":"14101"},"text":"§ 14101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf69bcadc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Convention” means the International Convention on Tonnage Measurement of Ships, 1969.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69bcadd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “existing vessel” means a vessel the keel of which was laid or that was at a similar stage of construction before ","children":[{"tag":"date","attrib":{"date":"1982-07-18"},"text":"July 18, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69bcade-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Great Lakes” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf69bcadf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14101/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Great Lakes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69bcae0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14101/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the St. Lawrence River west of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf69bcae1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14101/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rhumb line drawn from Cap des Rosiers to West Point, Anticosti Island; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf69bcae2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14101/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the north side of Anticosti Island, the meridian of longitude 63 degrees west.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf69bcae3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “vessel that engages on a foreign voyage” means a vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf69bcae4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14101/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that arrives at a place under the jurisdiction of the United States from a place in a foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69bcae5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14101/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that makes a voyage between places outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69bcae6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14101/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that departs from a place under the jurisdiction of the United States for a place in a foreign country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf69bcae7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14101/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that makes a voyage between a place within a territory or possession of the United States and another place under the jurisdiction of the United States not within that territory or possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf69bcae8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5101/3"},"text":"Pub. L. 99–509, title V, § 5101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1919"},"text":"100 Stat. 1919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIII/s303/a"},"text":"Pub. L. 111–281, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2923"},"text":"124 Stat. 2923","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69bcae9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69bcaea-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 14101","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Source: International Convention on Tonnage Measurement of Ships.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 14101 contains definitions that are limited to Part J—Measurement of Vessels. The source of these definitions is the International Convention on Tonnage Measurement of Ships in articles 2 and 4.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf69bcaeb-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf69bcaec-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s303/a/1"},"text":"Pub. L. 111–281, § 303(a)(1)","children":[],"tail":", substituted “that engages” for “engaged” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s303/a/2"},"text":"Pub. L. 111–281, § 303(a)(2)","children":[],"tail":", substituted “that arrives” for “arriving”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s303/a/3"},"text":"Pub. L. 111–281, § 303(a)(3)","children":[],"tail":", substituted “that makes” for “making” and struck out “(except a foreign vessel engaged on that voyage)” after “United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s303/a/4"},"text":"Pub. L. 111–281, § 303(a)(4)","children":[],"tail":", substituted “that departs” for “departing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s303/a/5"},"text":"Pub. L. 111–281, § 303(a)(5)","children":[],"tail":", substituted “that makes” for “making”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
