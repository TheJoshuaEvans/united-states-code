{"tag":"section","attrib":{"id":"idf6ea8753-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55314"},"text":null,"children":[{"tag":"num","attrib":{"value":"55314"},"text":"§ 55314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation requirements for certain exports sponsored by the Secretary of Agriculture","children":[],"tail":null},{"tag":"subsection","attrib":{"status":"repealed","id":"idf6ea8754-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"[(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dF/tI/s100124/a/1"},"text":"Pub. L. 112–141, div. F, title I, § 100124(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/915"},"text":"126 Stat. 915","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ea8755-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable Export Activity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The activities specified in this subsection are export activities (except inspection or weighing activities, other activities carried out for health or safety, or technical assistance provided in the handling of commercial transactions) of the Secretary of Agriculture or the Commodity Credit Corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea8756-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carried out under the Food for Peace Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"7 U.S.C. 1691","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea8757-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carried out under section 416 of the Agricultural Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431"},"text":"7 U.S.C. 1431","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea8758-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55314/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carried out under the Bill Emerson Humanitarian Trust Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1736f–1"},"text":"7 U.S.C. 1736f–1","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea8759-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55314/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under which agricultural commodities or their products are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ea875a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55314/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donated through foreign governments or private or public agencies, including intergovernmental organizations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ea875b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55314/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sold for foreign currencies or for dollars on credit terms of more than 10 years;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea875c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55314/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which agricultural commodities or their products are made available for emergency food relief at less than prevailing world market prices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea875d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55314/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which a cash grant is made directly or through an intermediary to a foreign purchaser to enable the purchaser to obtain United States agricultural commodities or their products in an amount greater than the difference between the prevailing world market price and the United States market price, free along side vessel at a United States port; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea875e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55314/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under which agricultural commodities owned or controlled by or under loan from the Corporation are exchanged or bartered for materials, goods, equipment, or services produced in foreign countries, except export activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55313/5"},"text":"section 55313(5) of this title","children":[],"tail":"."}],"t