{"tag":"section","attrib":{"id":"idf6c6d2fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506"},"text":null,"children":[{"tag":"num","attrib":{"value":"51506"},"text":"§ 51506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions to receiving payments and use of vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c6d2fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As conditions of receiving an annual payment or the use of a vessel under this chapter, a State maritime academy shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c6d2fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide courses of instruction on navigation, marine engineering (including steam and diesel propulsion), the operation and maintenance of new vessels and equipment, and innovations being introduced to the merchant marine of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2fe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree in writing to conform to the standards for courses, training facilities, admissions, and instruction that the Secretary of Transportation may establish after consultation with the superintendents of State maritime academies, which shall include standards for a program described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d2ff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree in writing to require, as a condition for graduation, that each individual who is a citizen of the United States and who is attending the academy in a merchant marine officer preparation program pass the examination required for the issuance of a license under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7101"},"text":"section 7101 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d300-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" agree that any individual enrolled at such State maritime academy in a merchant marine officer preparation program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c6d301-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall, not later than 9 months after such individual’s date of enrollment, pass an examination in form and substance satisfactory to the Secretary that demonstrates that such individual meets the medical and physical requirements—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c6d302-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required for the issuance of an original license under section 7101; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c6d303-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set by the Coast Guard for issuing merchant mariners’ documentation under section 7302, with no limit to the individual’s operational authority;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c6d304-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" following passage of the examination under subparagraph (A), shall continue to meet the requirements described in subparagraph (A) throughout the remainder of the individual’s enrollment at the State maritime academy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c6d305-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the individual has a medical or physical condition that disqualifies the individual from meeting the requirements referred to in subparagraph (A), shall be transferred to a program other than a merchant marine officer preparation program, or otherwise appropriately disenrolled from such State maritime academy, until the individual demonstrates to the Secretary that the individual meets such requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d306-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Condition to Payments of More Than ","children":[],"tail":"$25,000.—"}],"tail":null},{"tag":"content","attrib":{},"text":"As a condition of receiving an annual payment of more than $25,000 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51505"},"text":"section 51505 of this title","children":[],"tail":", a State maritime academy also must agree to admit each year a number of citizens of the United States who meet its admission requirements and reside in a State not supporting that academy. The Secretary shall determine the number of individuals to be admitted by each academy under this subsection. The number may not be more than one-third of the total number of individuals attending the academy at any time."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d307-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Armed Forces Merchant Mariner Officer Expedited Preparation Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c6d308-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State maritime academy may offer a program under which an eligible individual may complete a merchant marine officer preparation program approved by the Secretary, and the requirements for the issuance of a license under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7101"},"text":"section 7101 of this title","children":[],"tail":", in less than 3 years, without a requirement to earn a baccalaureate or other degree from the State maritime academy."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c6d309-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible individuals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, an eligible individual is an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c6d30a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6c6d30b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who served in the Armed Forces, and who was discharged or released therefrom under honorable conditions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6c6d30c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the National Guard or Reserves who has performed at least six years of service therein; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c6d30d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has earned a baccalaureate degree from an institution of higher education (as defined in section 102 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"20 U.S.C. 1002","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c6d30e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretarial Waiver Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may modify or waive any of the terms set forth in subsection (a)(4) with respect to any individual or State maritime academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c6d30f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1579"},"text":"120 Stat. 1579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dC/tXXXV/s3515"},"text":"Pub. L. 114–328, div. C, title XXXV, § 3515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2788"},"text":"130 Stat. 2788","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXV/s3534"},"text":"Pub. L. 118–159, div. C, title XXXV, § 3534","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2313"},"text":"138 Stat. 2313","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c6d310-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6c6d311-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6c6d312-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"51506","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1295c(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XIII, § 1304(f), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/96/453/s2"},"text":"Pub. L. 96–453, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2004"},"text":"94 Stat. 2004","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/115/s3/a"},"text":"Pub. L. 101–115, § 3(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 13, 1989","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/103/692"},"text":"103 Stat. 692","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “administered by the Coast Guard” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6c6d313-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6c6d314-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3534/1"},"text":"Pub. L. 118–159, § 3534(1)","children":[],"tail":", inserted before semicolon at end “, which shall include standards for a program described in subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s3534/2"},"text":"Pub. L. 118–159, § 3534(2)","children":[],"tail":", (3), added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3515/1/A"},"text":"Pub. L. 114–328, § 3515(1)(A)","children":[],"tail":", substituted “shall” for “must” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3515/1/B"},"text":"Pub. L. 114–328, § 3515(1)(B)","children":[],"tail":"–(D), added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s3515/2"},"text":"Pub. L. 114–328, § 3515(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
