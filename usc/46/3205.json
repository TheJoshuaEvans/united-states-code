{"tag":"section","attrib":{"id":"idf65dd752-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3205"},"text":null,"children":[{"tag":"num","attrib":{"value":"3205"},"text":"§ 3205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf65dd753-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance of Certificate and Document","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After verifying that the responsible person for a vessel to which this chapter applies and the vessel comply with the applicable requirements under this chapter, the Secretary shall issue for the vessel, on request of the responsible person, a Safety Management Certificate and a Document of Compliance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65dd754-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of Certificate and Document","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Safety Management Certificate and a Document of Compliance issued for a vessel under this section shall be maintained by the responsible person for the vessel as required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65dd755-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Verification of Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf65dd756-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3205/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically, or upon discovery from other sources of information acquired by the Coast Guard, including a discovery made during an audit or systematic review conducted under section 10104(e) of a failure of a responsible person or vessel to comply with a requirement of a safety management system for which a Safety Management Certificate and a Document of compliance ","children":[{"tag":"ref","attrib":{"idref":"fn002001"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002001"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Compliance”."}],"tail":" has been issued under this section, including a failure to comply with regulations prescribed under section 3203(a)(7) and (8), review whether a responsible person having a safety management plan approved under section 3204(b) and each vessel to which the plan applies is complying with the plan; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf65dd757-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3205/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoke the Secretary’s approval of the plan and each Safety Management Certificate and Document of Compliance issued to the person for a vessel to which the plan applies, if the Secretary determines that the person or a vessel to which the plan applies has not complied with the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf65dd758-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3205/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the request of the Secretary, the Secretary of Homeland Security shall withhold or revoke the clearance required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s60105"},"text":"section 60105 of this title","children":[],"tail":" of a vessel that is subject to this chapter under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s3202/a"},"text":"section 3202(a) of this title","children":[],"tail":" or to the International Safety Management Code, if the vessel does not have on board a Safety Management Certificate and a copy of a Document of Compliance for the vessel. Clearance may be granted on filing a bond or other surety satisfactory to the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf65dd759-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVI/s602/a"},"text":"Pub. L. 104–324, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3929"},"text":"110 Stat. 3929","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/10"},"text":"Pub. L. 109–304, § 15(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1703"},"text":"120 Stat. 1703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3529/b/1/A"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3529(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/603"},"text":"122 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVI/s11610/b"},"text":"Pub. L. 117–263, div. K, title CXVI, § 11610(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4155"},"text":"136 Stat. 4155","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf65dd75a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf65dd75b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf65dd75c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" inserted “, or upon discovery from other sources of information acquired by the Coast Guard, including a discovery made during an audit or systematic review conducted under section 10104(e) of a failure of a responsible person or vessel to comply with a requirement of a safety management system for which a Safety Management Certificate and a Document of compliance has been issued under this section, including a failure to comply with regulations prescribed under section 3203(a)(7) and (8),” after “periodically”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/10"},"text":"Pub. L. 109–304, § 15(10)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/10"},"text":"Pub. L. 109–304, § 15(10)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":", substituted “Secretary of Homeland Security shall withhold or revoke the clearance required by "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s60105"},"text":"section 60105 of this title","children":[],"tail":"” for “Secretary of the Treasury shall withhold or revoke the clearance required by section 4197 of the Revised Statutes (46 U.S.C. App. 91)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf65dd75d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf65dd75e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3529/b/2"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3529(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/603"},"text":"122 Stat. 603","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/181/dC/tXXXV/s3529/b/2"},"text":"“The amendments made by paragraph (1) [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s31325"},"text":"section 31325 of this title","children":[],"tail":"] shall be effective as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Public Law 109–304","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
