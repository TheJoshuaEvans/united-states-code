{"tag":"section","attrib":{"id":"idf6b60a12-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50109"},"text":null,"children":[{"tag":"num","attrib":{"value":"50109"},"text":"§ 50109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous studies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b60a13-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Subsidies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall investigate, determine, and keep current records of the extent and character of the governmental aid and subsidies granted by foreign governments to their merchant marine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a14-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Laws Applicable to Aircraft","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall investigate, determine, and keep current records of the provisions of law relating to shipping that should be made applicable to aircraft engaged in foreign commerce to further the policy in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50101"},"text":"section 50101 of this title","children":[],"tail":", and any appropriate legislation in this regard."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a15-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aid for Cotton, Coal, Lumber, and Cement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall investigate, determine, and keep current records of the advisability of enactment of suitable legislation authorizing the Secretary, in an economic or commercial emergency, to aid farmers and producers of cotton, coal, lumber, and cement in any section of the United States in the transportation and landing of their products in any foreign port, which products can be carried in dry-cargo vessels by reducing rates, by supplying additional tonnage to any American operator, or by operation of vessels directly by the Secretary, until the Secretary considers the special rate reduction and operation unnecessary for the benefit of those farmers and producers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a16-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intercoastal and Inland Water Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall investigate, determine, and keep current records of intercoastal and inland water transportation, including their relation to transportation by land and air.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a17-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50109/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obsolete Tonnage and Tramp Service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make studies and reports to Congress on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b60a18-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50109/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scrapping or removal from service of old or obsolete merchant tonnage owned by the United States Government or in use in the merchant marine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a19-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50109/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tramp shipping service and the advisability of citizens of the United States participating in that service with vessels under United States registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a1a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50109/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mortgage Loans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall investigate the legal status of mortgage loans on vessel property, with a view to the means of improving the security of those loans and of encouraging investment in American shipping.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b60a1b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1559"},"text":"120 Stat. 1559","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b60a1c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b60a1d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b60a1e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":nul