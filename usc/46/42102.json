{"tag":"section","attrib":{"id":"idf6b14f44-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42102"},"text":null,"children":[{"tag":"num","attrib":{"value":"42102"},"text":"§ 42102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations of other agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b14f45-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request to Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To further the objectives and policy set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50101"},"text":"section 50101 of this title","children":[],"tail":", the Federal Maritime Commission shall request the head of a department, agency, or instrumentality of the United States Government to suspend, modify, or annul any existing regulations, or to make new regulations, affecting shipping in the foreign trade, except regulations relating to the Public Health Service, the Consular Service, or the inspection of vessels."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14f46-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prior Review and Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A department, agency, or instrumentality of the Government may not prescribe a regulation affecting shipping in the foreign trade (except a regulation affecting the Public Health Service, the Consular Service, or the inspection of vessels) until the regulation has been submitted to the Commission for its approval and final action has been taken by the Commission or the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14f47-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission to President","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the head of a department, agency, or instrumentality of the Government refuses to comply with a request under subsection (a) or objects to a decision of the Commission under subsection (b), the Commission or the head of the department, agency, or instrumentality may submit the facts to the President. The President may establish, suspend, modify, or annul the regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b3bf48-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1549"},"text":"120 Stat. 1549","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b3bf49-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b3bf4a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b3bf4b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42102(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:876(a)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-06-05/ch250/s19/a/3"},"text":"June 5, 1920, ch. 250, § 19(a)(3)","children":[],"tail":", (b), (c), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/995"},"text":"41 Stat. 995","children":[],"tail":"; Ex. Ord. No. 6166, § 12, eff. "},{"tag":"html:span","attrib":{},"text":"June 10, 1933","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title II, § 204, title IX, § 904, "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1987"},"text":"49 Stat. 1987","children":[],"tail":", 2016; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/46"},"text":"Pub. L. 97–31, § 12(46)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/157"},"text":"95 Stat. 157","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tIII/s301"},"text":"Pub. L. 105–258, title III, § 301","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1915"},"text":"112 Stat. 1915","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42102(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:876(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42102(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:876(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “department, agency, or instrumentality” are substituted for “department, board, bureau, or agency” for consistency in the revised title. The words “the inspection of vessels” are substituted for “the steamboat inspection service” because the Steamboat Inspection Service has been abolished and its functions are now carried out by the Coast Guard.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “shall” is substituted for “is authorized and directed” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
