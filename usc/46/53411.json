},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $181,560,000 for each of fiscal years 2033 and 2034.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d50407-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53411/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $186,460,000 for each of fiscal years 2035 and 2036.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d50408-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53411/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $191,480,000 for each of fiscal years 2037 and 2038.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d50409-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53411/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $196,660,000 for each of fiscal years 2039 and 2040.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d5040a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dC/tXXXV/s3511/a"},"text":"Pub. L. 116–283, div. C, title XXXV, § 3511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4418"},"text":"134 Stat. 4418","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3501/b/1"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3501(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":