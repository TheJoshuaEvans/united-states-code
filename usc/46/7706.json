{"tag":"section","attrib":{"id":"idf67f42d0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7706"},"text":null,"children":[{"tag":"num","attrib":{"value":"7706"},"text":"§ 7706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Drug testing reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf67f42d1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Release of Drug Test Results to Coast Guard","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 weeks after receiving from a Medical Review Officer a report of a verified positive drug test or verified test violation by a civilian employee of a Federal agency, an applicant for employment by a Federal agency, an officer in the Public Health Services, or an officer in the National Oceanic and Atmospheric Administration Commissioned Officer Corps, who is employed in any capacity on board a vessel operated by the agency, the head of the agency shall release to the Commandant the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67f42d2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards, Procedures, and Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of a Federal agency shall carry out a release under subsection (a) in accordance with the standards, procedures, and regulations applicable to the disclosure and reporting to the Coast Guard of drug tests results and drug test records of individuals employed on vessels documented under the laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67f42d3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 503(e) of the Supplemental Appropriations Act, 1987 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7301"},"text":"5 U.S.C. 7301","children":[],"tail":" note), the report of a drug test of an employee or an applicant for employment by a Federal agency may be released under this section without the prior written consent of the employee or the applicant."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67f42d4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/293/tIV/s414/a"},"text":"Pub. L. 108–293, title IV, § 414(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1046"},"text":"118 Stat. 1046","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIII/s304"},"text":"Pub. L. 113–281, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3043"},"text":"128 Stat. 3043","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3541/b/13"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3541(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2323"},"text":"132 Stat. 2323","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67f42d5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf67f42d6-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf67f42d7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 503(e) of the Supplemental Appropriations Act, 1987, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/71/s503/e"},"text":"section 503(e) of Pub. L. 100–71","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7301"},"text":"section 7301 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf67f42d8-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" struck out “of the Coast Guard” after “Commandant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/s304/1"},"text":"Pub. L. 113–281, § 304(1)","children":[],"tail":", inserted “an applicant for employment by a Federal agency,” after “Federal agency,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/s304/2"},"text":"Pub. L. 113–281, § 304(2)","children":[],"tail":", inserted “or an applicant for employment by a Federal agency” after “an employee” and substituted “the employee or the applicant” for “the employee”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
