{"tag":"section","attrib":{"id":"idf6b609fa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50106"},"text":null,"children":[{"tag":"num","attrib":{"value":"50106"},"text":"§ 50106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies on the operation of vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b609fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relative Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall investigate, determine, and keep current records of the relative cost of marine insurance, maintenance, repairs, wages and subsistence of officers and crews, and all other items of expense, in the operation of comparable vessels under the laws and regulations of the United States and those of the foreign countries whose vessels are substantial competitors of American vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b609fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Shipyards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall investigate, determine, and keep current records of the number, location, and efficiency of shipyards in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b609fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Navigation Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall examine the navigation laws and regulations of the United States and make such recommendations to Congress as the Secretary considers proper for the amendment, improvement, and revision of those laws and for the development of the merchant marine of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b609fe-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1559"},"text":"120 Stat. 1559","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b609ff-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b60a00-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b60a01-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"chi