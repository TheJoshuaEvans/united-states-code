an","attrib":{},"text":"58102","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1223(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title VIII, § 805(b), "},{"tag":"html:a","attrib":{"href":"/us/stat/49/2012"},"text":"49 Stat. 2012","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/122"},"text":"Pub. L. 97–31, § 12(122)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/164"},"text":"95 Stat. 164","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/239/s4/b/2"},"text":"Pub. L. 104–239, § 4(b)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 8, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3131"},"text":"110 Stat. 3131","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “contractor under the operating-differential subsidy program or a charterer under chapter 575 of this title, receiving an operating-differential subsidy” are substituted for “contractor under part A of subchapter VI of this chapter or subchapter VII of this chapter receiving an operating-differential subsidy” for the reasons explained under section 58101.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
