n":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1950-12-13/ch1136"},"text":"Dec. 13, 1950, ch. 1136","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/1112"},"text":"64 Stat. 1112","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “officer, employee, or agent of the United States or the federally-owned corporation” are substituted for “agent or employee of the United States or of any incorporated or unincorporated agency thereof” for consistency in this chapter and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
