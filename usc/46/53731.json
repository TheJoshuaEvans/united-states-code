ll}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1279c(a) (1st sentence), (1), (4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XI, § 1110, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/96/320/tII/s203/a"},"text":"Pub. L. 96–320, title II, § 203(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 3, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/992"},"text":"94 Stat. 992","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/136"},"text":"Pub. L. 97–31, § 12(136)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/166"},"text":"95 Stat. 166","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/35/tXVI/s1606/f"},"text":"Pub. L. 97–35, title XVI, § 1606(f)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/752"},"text":"95 Stat. 752","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/239/s11/3"},"text":"Pub. L. 104–239, § 11(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 8, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3134"},"text":"110 Stat. 3134","children":[],"tail":"."}],"tail":null}],"tail":null}],"t