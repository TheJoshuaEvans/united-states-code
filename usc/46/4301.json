{"tag":"section","attrib":{"id":"idf66e78fe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4301"},"text":null,"children":[{"tag":"num","attrib":{"value":"4301"},"text":"§ 4301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf66e78ff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter applies to a recreational vessel and associated equipment carried in the vessel on waters subject to the jurisdiction of the United States (including the territorial sea of the United States as described in Presidential Proclamation No. 5928 of ","children":[{"tag":"date","attrib":{"date":"1988-12-27"},"text":"December 27, 1988","children":[],"tail":") and, for a vessel owned in the United States, on the high seas."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66e7900-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except when expressly otherwise provided, this chapter does not apply to a foreign vessel temporarily operating on waters subject to the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66e7901-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Until there is a final judicial decision that they are navigable waters of the United States, the following waters lying entirely in New Hampshire are declared not to be waters subject to the jurisdiction of the United States within the meaning of this section: Lake Winnisquam, Lake Winnipesaukee, parts of the Merrimack River, and their tributary and connecting waters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf66e7902-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/529"},"text":"97 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/383/tIII/s301/b/4"},"text":"Pub. L. 105–383, title III, § 301(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-13"},"text":"Nov. 13, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3417"},"text":"112 Stat. 3417","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf66e7903-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf66e7904-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf66e7905-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4301","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:1453","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4301 provides that this chapter is applicable to a recreational vessel that operates on waters subject to the jurisdiction of the United States or that is owned in the United States and while operating on the high seas.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"It also provides that a foreign recreational vessel that temporarily uses our waters is not subject to the requirements of this chapter. However, if the vessel remains permanently in the United States, it would be subject to the provisions of this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4301(c) recognizes the ongoing controversy over the navigability of certain waters of New Hampshire. While a recreational vessel operating on these waters need not meet the requirements of this chapter, it would be prohibited from operating on any other waters subject to the jurisdiction of the United States if it does not comply with these requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf66e7906-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf66e7907-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Presidential Proclamation No. 5928, referred to in subsec. (a), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331"},"text":"section 1331 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf66e7908-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/383"},"text":"Pub. L. 105–383","children":[],"tail":" inserted “(including the territorial sea of the United States as described in Presidential Proclamation No. 5928 of "},{"tag":"date","attrib":{"date":"1988-12-27"},"text":"December 27, 1988","children":[],"tail":")” after “of the United States”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf66e7909-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf66e790a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter effective ","children":[{"tag":"date","attrib":{"date":"1984-04-15"},"text":"Apr. 15, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/89/s2/g/1"},"text":"section 2(g)(1) of Pub. L. 98–89","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
