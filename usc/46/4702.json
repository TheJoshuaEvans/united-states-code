{"tag":"section","attrib":{"id":"idf6735b92-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4702"},"text":null,"children":[{"tag":"num","attrib":{"value":"4702"},"text":"§ 4702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abandonment of barge prohibited","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An owner or operator of a barge may not abandon it on the navigable waters of the United States. A barge is deemed not to be abandoned if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735b93-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is located at a Federally- or State-approved mooring area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b94-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is on private property with the permission of the owner of the property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735b95-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner or operator notifies the Secretary that the barge is not abandoned and the location of the barge.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6735b96-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587/tV/s5302"},"text":"Pub. L. 102–587, title V, § 5302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5082"},"text":"106 Stat. 5082","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/18"},"text":"Pub. L. 109–304, § 15(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1703"},"text":"120 Stat. 1703","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6735b97-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6735b98-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6735b99-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" struck out subsec. (a) designation before “An owner”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
