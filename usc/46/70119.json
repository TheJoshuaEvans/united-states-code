{"tag":"section","attrib":{"id":"idf707105a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70119"},"text":null,"children":[{"tag":"num","attrib":{"value":"70119"},"text":"§ 70119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf707105b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70119/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person that violates this chapter or any regulation under this chapter shall be liable to the United States for a civil penalty of not more than $25,000 for each day during which the violation continues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf707105c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70119/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing Violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum amount of a civil penalty for a violation under this section shall not exceed $50,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf707105d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s102/a"},"text":"Pub. L. 107–295, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2084"},"text":"116 Stat. 2084","children":[],"tail":", § 70117; renumbered § 70119, "},{"tag":"ref","attrib":{"href":"/us/pl/108/293/tVIII/s802/a/1"},"text":"Pub. L. 108–293, title VIII, § 802(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1078"},"text":"118 Stat. 1078","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIII/s306/a"},"text":"Pub. L. 109–241, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/528"},"text":"120 Stat. 528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf707105e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf707105f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf7071060-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 70119 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70118"},"text":"section 70118 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf7071061-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, substituted “day during which the violation continues” for “violation”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\