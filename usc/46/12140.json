{"tag":"section","attrib":{"id":"idf6971050-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12140"},"text":null,"children":[{"tag":"num","attrib":{"value":"12140"},"text":"§ 12140.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations by Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6971051-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12140/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may conduct investigations and inspections regarding compliance with this chapter and regulations prescribed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6971052-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12140/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Obtain Evidence.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6971053-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12140/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of any investigation conducted under this section, the Secretary may issue a subpoena to require the attendance of a witness or the production of documents or other evidence relevant to the matter under investigation if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6971054-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12140/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before the issuance of the subpoena, the Secretary requests a determination by the Attorney General as to whether the subpoena—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6971055-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12140/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is reasonable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6971056-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12140/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will interfere with a criminal investigation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6971057-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12140/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Attorney General—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6971058-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12140/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determines that the subpoena is reasonable and will not interfere with a criminal investigation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6971059-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12140/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to make a determination with respect to the subpoena before the date that is 30 days after the date on which the Secretary makes a request under subparagraph (A) with respect to the subpoena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf697105a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12140/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a refusal to obey a subpoena issued to any person under this section, the Secretary may invoke the aid of the appropriate district court of the United States to compel compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf697105b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/tIII/s308/a"},"text":"Pub. L. 112–213, title III, § 308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1566"},"text":"126 Stat. 1566","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
