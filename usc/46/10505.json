{"tag":"section","attrib":{"id":"idf68d9a11-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10505"},"text":null,"children":[{"tag":"num","attrib":{"value":"10505"},"text":"§ 10505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68d9a12-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68d9a13-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68d9a14-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10505/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay a seaman wages in advance of the time when the seaman has earned the wages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68d9a15-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10505/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay advance wages of the seaman to another person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68d9a16-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10505/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make to another person an order, note, or other evidence of indebtedness of the wages, or pay another person, for the engagement of seamen when payment is deducted or to be deducted from the seaman’s wage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68d9a17-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person violating this subsection is liable to the United States Government for a civil penalty of not more than $5,000. A payment made in violation of this subsection does not relieve the vessel or the master from the duty to pay all wages after they have been earned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9a18-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person demanding or receiving from a seaman or an individual seeking employment as a seaman, remuneration for providing the seaman or individual with employment, is liable to the Government for a civil penalty of not more than $5,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9a19-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The owner, charterer, managing operator, agent, or master of a vessel seeking clearance from a port of the United States shall present the agreement required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s10502"},"text":"section 10502 of this title","children":[],"tail":" at the office of clearance. Clearance may be granted to a vessel only if this section has been complied with."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9a1a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to a fishing or whaling vessel or a yacht.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68d9a1b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/571"},"text":"97 Stat. 571","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/640/s10/b/4"},"text":"Pub. L. 99–640, § 10(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-11-10"},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3550"},"text":"100 Stat. 3550","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/206/tIV/s414"},"text":"Pub. L. 103–206, title IV, § 414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2437"},"text":"107 Stat. 2437","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68d9a1c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68d9a1d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68d9a1e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10505","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:598","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:599","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10505 prohibits any person from paying a seaman on a coastwise voyage advance wages, or to pay to another person any form of a seaman’s wages prior to the commencement of the seaman’s employment. It also prohibits a person from seeking or receiving remuneration for providing a seaman with employment. This section also requires that a vessel comply with this section before clearing port. It provides penalties for offenses of its provisions. The section does not apply to fishing vessels, whaling vessels, or yachts, but does apply to vessels taking oysters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68d9a1f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68d9a20-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/s414/1"},"text":"Pub. L. 103–206, § 414(1)","children":[],"tail":", substituted “$5,000” for “$100”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206/s414/2"},"text":"Pub. L. 103–206, § 414(2)","children":[],"tail":", substituted “$5,000” for “$500”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/640"},"text":"Pub. L. 99–640","children":[],"tail":" struck out last sentence which read as follows: “However, this section applies to a vessel taking oysters.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
