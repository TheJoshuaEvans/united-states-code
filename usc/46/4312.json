{"tag":"section","attrib":{"id":"idf670ea95-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312"},"text":null,"children":[{"tag":"num","attrib":{"value":"4312"},"text":"§ 4312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Engine cut-off switches","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf670ea96-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Installation Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A manufacturer, distributor, or dealer that installs propulsion machinery and associated starting controls on a covered recreational vessel shall equip such vessel with an engine cut-off switch and engine cut-off switch link that meet American Boat and Yacht Council Standard A–33, as in effect on the date of the enactment of the Frank LoBiondo Coast Guard Authorization Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Public Law 115–282","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf670ea97-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf670ea98-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual operating a covered recreational vessel shall use an engine cut-off switch link while operating on plane or above displacement speed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf670ea99-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirement under paragraph (1) shall not apply if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf670ea9a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the main helm of the covered vessel is installed within an enclosed cabin; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf670ea9b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel does not have an engine cut-off switch and is not required to have one under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf670ea9c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Education on Cut-off Switches","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commandant of the Coast Guard, through the National Boating Safety Advisory Committee established under section 15105, may initiate a boating safety program on the use and benefits of cut-off switches for recreational vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf670ea9d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Standard for Inspection.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf670ea9e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of the enactment of this section, the Commandant shall transmit American Boat and Yacht Council Standard A–33, as in effect on the date of enactment of the Frank LoBiondo Coast Guard Authorization Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Public Law 115–282","children":[],"tail":"), to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf670ea9f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf670eaa0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf670eaa1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Coast Guard Office of Design and Engineering Standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf670eaa2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Archives and Records Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf670eaa3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The standard submitted under paragraph (1) shall be kept on file and available for public inspection at such Coast Guard office and the National Archives and Records Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf670eaa4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf670eaa5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered recreational vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered recreational vessel” means a recreational vessel that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf670eaa6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 26 feet overall in length; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf670eaa7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capable of developing 115 pounds or more of static thrust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf670eaa8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dealer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “dealer” means any person who is engaged in the sale and distribution of recreational vessels or associated equipment to purchasers whom the seller in good faith believes to be purchasing any such vessel or associated equipment for purposes other than resale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf670eaa9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distributor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “distributor” means any person engaged in the sale and distribution of recreational vessels and associated equipment for the purposes of resale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf670eaaa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Manufacturer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “equipment manufacturer” means any person engaged in the manufacture, construction, or assembly of recreational vessels or associated equipment, or the importation of recreational vessels into the United States for subsequent sale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf670eaab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Propulsion machinery","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “propulsion machinery” means a self-contained propulsion system, and includes, but is not limited to, inboard engines, outboard motors, and sterndrive engines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf670eaac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4312/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Static thrust","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “static thrust” means the forward or backwards thrust developed by propulsion machinery while stationary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf670eaad-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tV/s503/a"},"text":"Pub. L. 115–282, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4270"},"text":"132 Stat. 4270","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8316(a), title LVXXXV [LXXXV], § 8507(a)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4699"},"text":"134 Stat. 4699","children":[],"tail":", 4752.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf670eaae-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf670eaaf-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf670eab0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Frank LoBiondo Coast Guard Authorization Act of 2018, referred to in subsecs. (a) and (d)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (c)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf670eab1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8507/a/2"},"text":"Pub. L. 116–283, § 8507(a)(2)","children":[],"tail":", substituted “Frank LoBiondo Coast Guard Authorization Act of 2018 ("},{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Public Law 115–282","children":[],"tail":")” for “Coast Guard Authorization Act of 2017” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8316/a"},"text":"Pub. L. 116–283, § 8316(a)","children":[],"tail":", added subsec. (b) and redesignated former subsecs. (b) to (d) as (c) to (e), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf670eab2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf670eab3-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", unless the Commandant of the Coast Guard, prior to the date that is 90 days after "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", determines that the use requirement enacted in "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8316/a"},"text":"section 8316(a) of Pub. L. 116–283","children":[],"tail":" (amending this section) would not promote recreational boating safety. See "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8316/c"},"text":"section 8316(c) of Pub. L. 116–283","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s4311"},"text":"section 4311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf670eab4-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tV/s503/c"},"text":"Pub. L. 115–282, title V, § 503(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4271"},"text":"132 Stat. 4271","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/282/tV/s503/c"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s4312"},"text":"Section 4312 of title 46","children":[],"tail":", United States Code, as amended [probably should be “enacted”] by this section, shall take effect one year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
