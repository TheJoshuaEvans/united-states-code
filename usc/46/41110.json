{"tag":"section","attrib":{"id":"idf6b14ebb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41110"},"text":null,"children":[{"tag":"num","attrib":{"value":"41110"},"text":"§ 41110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Federal Maritime Commission shall publish on its website a calendar quarterly report that describes the total import and export tonnage and the total loaded and empty 20-foot equivalent units per vessel (making port in the United States, including any territory or possession of the United States) operated by each ocean common carrier covered under this chapter. Ocean common carriers under this chapter shall provide to the Commission all necessary information, as determined by the Commission, for completion of this report.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6b14ebc-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s9/a"},"text":"Pub. L. 117–146, § 9(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1277"},"text":"136 Stat. 1277","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b14ebd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6b14ebe-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6b14ebf-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s9/b"},"text":"Pub. L. 117–146, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1277"},"text":"136 Stat. 1277","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/146/s9/b"},"text":"“Nothing in this section [enacting this section], and the amendment made by this section, shall be construed to compel the public disclosure of any confidential or proprietary data, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
