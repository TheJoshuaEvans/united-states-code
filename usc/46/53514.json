{"tag":"section","attrib":{"id":"idf6d774f8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53514"},"text":null,"children":[{"tag":"num","attrib":{"value":"53514"},"text":"§ 53514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship of old fund to new fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d774f9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “old fund” means a capital construction fund maintained before ","children":[{"tag":"date","attrib":{"date":"1970-10-21"},"text":"October 21, 1970","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d774fa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election To Maintain Old Fund","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person maintaining an old fund may elect to continue the old fund, but may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d774fb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53514/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold amounts in the old fund beyond the expiration date provided in the agreement under which the old fund is maintained (determined without regard to an extension or renewal made after ","children":[{"tag":"date","attrib":{"date":"1970-04-14"},"text":"April 14, 1970","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d774fc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53514/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain simultaneously the old fund and a new fund established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d774fd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53514/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of New Fund Agreement to Old Fund Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a person makes an agreement under this chapter to establish a new fund, the person may agree to extend the agreement to some or all of the amounts in an old fund. Each item in the old fund to be transferred shall be transferred in a nontaxable transaction to the appropriate account in the new fund. For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53511/c/3"},"text":"section 53511(c)(3) of this title","children":[],"tail":", the date of the deposit of an item so transferred shall be "},{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", or the date of the deposit in the old fund, whichever is later."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d774fe-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1599"},"text":"120 Stat. 1599","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d774ff-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6d77500-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6d77501-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text