{"tag":"section","attrib":{"id":"idf68fe4bc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11202"},"text":null,"children":[{"tag":"num","attrib":{"value":"11202"},"text":"§ 11202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified service","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter, an individual shall be considered to have engaged in qualified service if, between ","children":[{"tag":"date","attrib":{"date":"1945-08-16"},"text":"August 16, 1945","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1946-12-31"},"text":"December 31, 1946","children":[],"tail":", the individual—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68fe4bd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11202/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was a member of the United States merchant marine (including the Army Transport Service and the Naval Transport Service) serving as a crewmember of a vessel that was—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68fe4be-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11202/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated by the War Shipping Administration or the Office of Defense Transportation (or an agent of the Administration or Office);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe4bf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11202/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated in waters other than inland waters, the Great Lakes, and other lakes, bays, and harbors of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe4c0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11202/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under contract or charter to, or property of, the Government of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe4c1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11202/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving the Armed Forces; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe4c2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11202/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while so serving, was licensed or otherwise documented for service as a crewmember of such a vessel by an officer or employee of the United States authorized to license or document the individual for such service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68fe4c3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/368/tIV/s402/a"},"text":"Pub. L. 105–368, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-11"},"text":"Nov. 11, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3336"},"text":"112 Stat. 3336","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(b)(12), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4752"},"text":"134 Stat. 4752","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68fe4c4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68fe4c5-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68fe4c6-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “an individual” for “a person” in introductory provisions and “the individual” for “the person” in introductory provisions and in par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
