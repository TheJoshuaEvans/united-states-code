{"tag":"section","attrib":{"id":"idf6e5cbdb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55101"},"text":null,"children":[{"tag":"num","attrib":{"value":"55101"},"text":"§ 55101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of coastwise laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e5cbdc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), the coastwise laws apply to the United States, including the island territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e5cbdd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The coastwise laws do not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e5cbde-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" American Samoa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e5cbdf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Northern Mariana Islands, except as provided in section 502(b) of the Covenant To Establish a Commonwealth of the Northern Mariana Islands in Political Union With the United States of America (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1801"},"text":"48 U.S.C. 1801","children":[],"tail":" note); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e5cbe0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55101/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Virgin Islands until the President declares by proclamation that the coastwise laws apply to the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e5cbe1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1632"},"text":"120 Stat. 1632","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3527/a"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3527(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/602"},"text":"122 Stat. 602","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e5cbe2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e5cbe3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e5cbe4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],