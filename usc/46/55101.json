, 1920, ch. 250, § 21","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/41/997"},"text":"41 Stat. 997","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1936-04-16/ch228"},"text":"Apr. 16, 1936, ch. 228","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1207"},"text":"49 Stat. 1207","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/47"},"text":"Pub. L. 97–31, § 12(47)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/157"},"text":"95 Stat. 157","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55101(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"48:1664.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1934-06-14/ch523"},"text":"June 14, 1934, ch. 523","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/963"},"text":"48 Stat. 963","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55101(b)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"48:1801 note (Covenant § 503(b)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/94/241/s1"},"text":"Pub. L. 94–241, § 1","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 24, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/263"},"text":"90 Stat. 263","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/213/s9"},"text":"Pub. L. 98–213, § 9","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 8, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/97/1461"},"text":"97 Stat. 1461","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/208/dA/tI/s101/d/tI"},"text":"Pub. L. 104–208, div. A, title I, § 101(d) [title I]","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3009-196"},"text":"110 Stat. 3009–196","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55101(b)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:877 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Proc. No. 3215, ","children":[{"tag":"html:span","attrib":{},"text":"Dec. 12, 1957","children":[],"tail":", 72 Stat. c19."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55101(b)(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:877 (last proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “apply to the United States, including” are substituted for “extend to” for clarity. The words “From and after ","children":[{"tag":"date","attrib":{"date":"1922-02-01"},"text":"February 1, 1922","children":[],"tail":"” and “not covered thereby on "},{"tag":"date","attrib":{"date":"1920-06-05"},"text":"June 5, 1920","children":[],"tail":"” are omitted as obsolete. The requirement to establish adequate steamship service to the island Territories and possessions is omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(2) is based on section 503(b) of the Covenant To Establish a Commonwealth of the Northern Mariana Islands in Political Union With the United States of America (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1801"},"text":"48 U.S.C. 1801","children":[],"tail":" note)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(3) is based on Proc. No. 3215, ","children":[{"tag":"date","attrib":{"date":"1957-12-12"},"text":"Dec. 12, 1957","children":[],"tail":", 72 Stat. c19, which provided that the President, “under and by virtue of the authority vested in me by the aforesaid section 21 of the Merchant Marine Act, 1920 [46 App. U.S.C. 877], do hereby declare and proclaim that the period for the establishment of an adequate shipping service for Canton Island is extended until further notice by proclamation of the President, and that the extension of the coastwise laws of the United States to Canton Island is deferred until it is declared by proclamation of the President that such adequate shipping service has been established”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(4), the words “and fix a date for the going into effect of same” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The provisos of 46 App. U.S.C. 877 relating to the Philippine Islands are omitted as obsolete because of the independence of the Philippine Islands. See Proc. No. 2695, ","children":[{"tag":"date","attrib":{"date":"1946-07-04"},"text":"July 4, 1946","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/1352"},"text":"60 Stat. 1352","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1394"},"text":"22 U.S.C. 1394","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6e5cbe5-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6e5cbe6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 502(b) of the Covenant To Establish a Commonwealth of the Northern Mariana Islands in Political Union With the United States of America, referred to in subsec. (b)(2), is contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/241/s1"},"text":"section 1 of Pub. L. 94–241","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1801"},"text":"section 1801 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6e5cbe7-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" inserted “or” after semicolon at end of par. (2), redesignated par. (4) as (3), and struck out former par. (3) which read as follows: “Canton Island until the President declares by proclamation that the coastwise laws apply to Canton Island; or”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
