{"tag":"section","attrib":{"id":"idf6fb291f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70013"},"text":null,"children":[{"tag":"num","attrib":{"value":"70013"},"text":"§ 70013.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to notify Coast Guard of release of objects into the navigable waters of the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6fb2920-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70013/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As soon as a person has knowledge of any release from a vessel or facility into the navigable waters of the United States of any object that creates an obstruction prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/s10"},"text":"section 10 of the Act of March 3, 1899","children":[],"tail":", popularly known as the Rivers and Harbors Appropriations Act of 1899 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s403"},"text":"33 U.S.C. 403","children":[],"tail":"), such person shall notify the Secretary and the Secretary of the Army of such release."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb2921-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70013/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction on Use of Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any notification provided by an individual in accordance with subsection (a) may not be used against such individual in any criminal case, except a prosecution for perjury or for giving a false statement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6fb2922-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIV/s401/a"},"text":"Pub. L. 115–282, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4259"},"text":"132 Stat. 4259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6fb2923-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6fb2924-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6fb2925-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/s10"},"text":"Section 10 of the Act of March 3, 1899","children":[],"tail":", popularly known as the Rivers and Harbors Appropriations Act of 1899, referred to in subsec. (a), means section 10 of "},{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/ch425"},"text":"act Mar. 3, 1899, ch. 425","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/1151"},"text":"30 Stat. 1151","children":[],"tail":", known as the Rivers and Harbors Appropriation Act of 1899, which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s403"},"text":"section 403 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
