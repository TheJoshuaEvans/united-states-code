{"tag":"section","attrib":{"id":"idf6bd360a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51104"},"text":null,"children":[{"tag":"num","attrib":{"value":"51104"},"text":"§ 51104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority of Secretary of the Navy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Navy, in cooperation with the Maritime Administrator and the head of each State maritime academy, shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6bd360b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51104/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training of future merchant marine officers at the United States Merchant Marine Academy and at State maritime academies includes programs for naval science training in the operation of merchant vessels as a naval and military auxiliary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6bd360c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51104/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" naval officer training programs for future officers, insofar as possible, are maintained at designated maritime academies consistent with Navy standards and needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6bd360d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1570"},"text":"120 Stat. 1570","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6