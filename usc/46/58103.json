{"tag":"section","attrib":{"id":"idf6f3fce9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58103"},"text":null,"children":[{"tag":"num","attrib":{"value":"58103"},"text":"§ 58103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employing another person as managing or operating agent","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f3fcea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except with the written consent of the Secretary of Transportation, a contractor holding a contract under the operating-differential subsidy program or under chapter 575 of this title may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f3fceb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ another person as the managing or operating agent of the operator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f3fcec-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charter a vessel, on which an operating-differential subsidy is to be paid, for operation by another person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f3fced-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s58103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Provisions to Charterer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a charter prohibited by this section is made, the person operating the chartered vessel is subject to all the provisions of this subtitle and the operating-differential subsidy program, including limitations of profits and salaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f3fcee-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1671"},"text":"120 Stat. 1671","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f3fcef-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f3fcf0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f3fcf1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"58103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1223(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title VIII, § 805(d), "},{"tag":"html:a","attrib":{"href":"/us/stat/49/2013"},"text":"49 Stat. 2013","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1938-06-23/ch600"},"text":"June 23, 1938, ch. 600","children":[],"tail":", §§ 36, 37, "},{"tag":"html:a","attrib":{"href":"/us/stat/52/963"},"text":"52 Stat. 963","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/603/s4/e"},"text":"Pub. L. 91–603, § 4(e)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1675"},"text":"84 Stat. 1675","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/122"},"text":"Pub. L. 97–31, § 12(122)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/164"},"text":"95 Stat. 164","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/239/s4/b/2"},"text":"Pub. L. 104–239, § 4(b)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 8, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3131"},"text":"110 Stat. 3131","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “contractor holding a contract under the operating-differential subsidy program or under chapter 575 of this title” are substituted for “contractor holding a contract authorized under part A of subchapter VI or VII of this chapter” for the reasons explained under section 58101.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
