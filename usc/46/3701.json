{"tag":"section","attrib":{"id":"idf6674d6a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3701"},"text":null,"children":[{"tag":"num","attrib":{"value":"3701"},"text":"§ 3701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6674d6b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “existing”, when referring to a type of vessel to which this chapter applies, means a vessel that is not a new vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6674d6c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “new”, when referring to a type of vessel to which this chapter applies, means a vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6674d6d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3701/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the building contract is placed after ","children":[{"tag":"date","attrib":{"date":"1979-06-01"},"text":"June 1, 1979","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6674d6e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3701/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the absence of a building contract, the keel of which is laid, or which is at a similar stage of construction, after ","children":[{"tag":"date","attrib":{"