{"tag":"section","attrib":{"id":"idf6b3bf64-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42106"},"text":null,"children":[{"tag":"num","attrib":{"value":"42106"},"text":"§ 42106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other actions to remedy unfavorable conditions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If the Federal Maritime Commission finds that conditions unfavorable to shipping in foreign trade as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s42101"},"text":"section 42101 of this title","children":[],"tail":" exist, the Commission may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b3bf65-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42106/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit voyages to and from United States ports or the amount or type of cargo carried;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bf66-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42106/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend, in whole or in part, tariffs and service contracts for carriage to or from United States ports, including a common carrier’s right to use tariffs of conferences and service contracts of agreements in United States trades of which it is a member for any period the Commission specifies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bf67-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42106/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend, in whole or in part, an ocean common carrier’s right to operate under any agreement filed with the Commission, including any agreement authorizing preferential treatment at terminals, preferential terminal leases, space chartering, or pooling of cargo or revenue with other ocean common carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bf68-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42106/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose a fee not to exceed $1,000,000 per voyage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b3bf69-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s42106/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take any other action the Commission finds necessary and appropriate to adjust or meet any condition unfavorable to shipping in the foreign trade of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b3bf6a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1550"},"text":"120 Stat. 1550","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b3bf6b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b3bf6c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b3bf6d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"ht