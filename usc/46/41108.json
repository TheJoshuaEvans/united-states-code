{"tag":"section","attrib":{"id":"idf6b14e8c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41108"},"text":null,"children":[{"tag":"num","attrib":{"value":"41108"},"text":"§ 41108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b14e8d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension of Tariffs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a violation of paragraph (1), (2), or (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s41104/a"},"text":"section 41104(a) of this title","children":[],"tail":", the Federal Maritime Commission may suspend any or all tariffs of the common carrier, or that common carrier’s right to use any or all tariffs of conferences of which it is a member, for a period not to exceed 12 months."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14e8e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operating Under Suspended Tariff","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A common carrier that accepts or handles cargo for carriage under a tariff that has been suspended, or after its right to use that tariff has been suspended, is liable to the United States Government for a civil penalty of not more than $50,000 for each shipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14e8f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure To Provide Information","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b14e90-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Commission finds, after notice and opportunity for a hearing, that a common carrier has failed to supply information ordered to be produced or compelled by subpoena under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s41303"},"text":"section 41303 of this title","children":[],"tail":", the Commission may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6b14e91-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41108/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend any or all tariffs of the carrier or the carrier’s right to use any or all tariffs of conferences of which it is a member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6b14e92-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41108/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request the Secretary of Homeland Security to refuse or revoke any clearance required for a vessel operated by the carrier, and when so requested, the Secretary shall refuse or revoke the clearance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b14e93-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defense based on foreign law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, in defense of its failure to comply with a subpoena or discovery order, a common carrier alleges that information or documents located in a foreign country cannot be produced because of the laws of that country, the Commission shall immediately notify the Secretary of State of the failure to comply and of the allegation relating to foreign laws. On receiving the notification, the Secretary of State shall promptly consult with the government of the nation within which the information or documents are alleged to be located for the purpose of assisting the Commission in obtaining the information or documents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14e94-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Impairing Access to Foreign Trade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Commission finds, after notice and opportunity for a hearing, that the action of a common carrier, acting alone or in concert with another person, or a foreign government has unduly impaired access of a vessel documented under the laws of the United States to ocean trade between foreign ports, the Commission shall take action that it finds appropriate, including imposing any of the penalties authorized by this section. The Commission also may take any of the actions authorized by sections 42304 and 42305 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14e95-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41108/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Order to President","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before an order under this section becomes effective, it shall be submitted immediately to the President. The President, within 10 days after receiving it, may disapprove it if the President finds that disapproval is required for reasons of national defense or foreign policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b14e96-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1543"},"text":"120 Stat. 1543","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/146/s15/a"},"text":"Pub. L. 117–146, § 15(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1279"},"text":"136 Stat. 1279","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b14e97-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b14e98-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b14e99-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"t