{"tag":"section","attrib":{"id":"idf6925599-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12104"},"text":null,"children":[{"tag":"num","attrib":{"value":"12104"},"text":"§ 12104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications for documentation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf692559a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An application for a certificate of documentation or endorsement under this chapter must be filed by the owner of the vessel. The application must be filed in the manner, be in the form, and contain the information prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf692559b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicant’s Identifying Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require the applicant to provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf692559c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the applicant is an individual, the individual’s social security number; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf692559d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the applicant is an entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf692559e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity’s taxpayer identification number; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf692559f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the entity does not have a taxpayer identification number, the social security number of an individual who is a corporate officer, general partner, or individual trustee of the entity and who signs the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf69255a0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1493"},"text":"120 Stat. 1493","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69255a1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69255a2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf69255a3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"t