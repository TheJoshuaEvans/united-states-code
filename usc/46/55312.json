{"tag":"section","attrib":{"id":"idf6ea8742-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55312"},"text":null,"children":[{"tag":"num","attrib":{"value":"55312"},"text":"§ 55312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determining prevailing world market price","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ea8743-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agricultural Commodities and Products","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prevailing world market price for agricultural commodities or their products shall be determined under this subchapter under procedures prescribed by the Secretary of Agriculture. The Secretary shall prescribe the procedures by regulation, with notice and opportunity for public comment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ea8744-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Services and Non-Agricultural Commodities and Products","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a determination of the prevailing world market price of any other type of materials, goods, equipment, or service is required to determine whether a barter or exchange transaction is subject to section 55314(b)(6) or (7) of this title, the determination shall be made by the Secretary of Agriculture in consultation with the heads of other appropriate agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ea8745-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1644"},"text":"120 Stat. 1644","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ea8746-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ea8747-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ea8748-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source