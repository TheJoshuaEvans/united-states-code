{"tag":"section","attrib":{"id":"idf662928d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3309"},"text":null,"children":[{"tag":"num","attrib":{"value":"3309"},"text":"§ 3309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificate of inspection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf662928e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When an inspection under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s3307"},"text":"section 3307 of this title","children":[],"tail":" has been made and a vessel has been found to be in compliance with the requirements of law and regulations, a certificate of inspection, in a form prescribed by the Secretary, shall be issued to the vessel."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf662928f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may issue a temporary certificate of inspection in place of a regular certificate of inspection issued under subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6629290-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3309/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At least 30 days before the current certificate of inspection issued to a vessel under subsection (a) of this section expires, the owner, charterer, managing operator, agent, master, or individual in charge of the vessel shall submit to the Secretary in writing a notice that the vessel—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6629291-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3309/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be required to be inspected; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6629292-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3309/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not be operated so as to require an inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6629293-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s3309/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certificate of inspection issued under this section shall be signed by the senior Coast Guard member or civilian employee who inspected the vessel, in addition to the officer in charge of marine inspection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6629294-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/515"},"text":"97 Stat. 515","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/498/tII/s211/a"},"text":"Pub. L. 98–498, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2303"},"text":"98 Stat. 2303","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVI/s606"},"text":"Pub. L. 104–324, title VI, § 606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3931"},"text":"110 Stat. 3931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tV/s522/c"},"text":"Pub. L. 111–281, title V, § 522(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2957"},"text":"124 Stat. 2957","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6629295-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6629296-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6629297-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3309","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:390c","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:391a(8)","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:395(d)","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:399","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3309 provides for the issuance of a certificate of inspection that attests to the fact that the vessel has been found to be in compliance with the applicable maritime safety laws and regulations. Under this provision the Coast Guard can issue a temporary certificate of inspection upon compliance with the applicable laws or regulations to facilitate the preparation, processing, and forwarding of the regular certificate of inspection to the vessel. A temporary certificate does not imply less than satisfactory compliance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6629298-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6629299-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" struck out “(but not more than 60 days)” after “30 days” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498"},"text":"Pub. L. 98–498","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf662929a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf662929b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498"},"text":"Pub. L. 98–498","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/498/s214"},"text":"section 214 of Pub. L. 98–498","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s2306"},"text":"section 2306 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf662929c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1984-04-15"},"text":"Apr. 15, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/89/s2/g/1"},"text":"section 2(g)(1) of Pub. L. 98–89","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
