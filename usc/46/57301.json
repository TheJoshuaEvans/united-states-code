{"tag":"section","attrib":{"id":"idf6f1b2e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57301"},"text":null,"children":[{"tag":"num","attrib":{"value":"57301"},"text":"§ 57301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f1b2e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “new vessel” means a vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6f1b2e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57301/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructed under this subtitle and acquired within 2 years after the date of completion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f1b2e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57301/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructed in a domestic shipyard on private account and not under this subtitle, and documented under the laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f1b2e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obsolete vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “obsolete vessel” means a vessel that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6f1b2e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57301/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of at least 1,350 gross tons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f1b2e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57301/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation believes should, because of its age, obsolescence, or other reasons, be replaced in the public interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f1b2ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57301/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been owned by a citizen of the United States for at least 3 years immediately before its acquisition under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f1b2eb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1662"},"text":"120 Stat. 1662","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f1b2ec-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f1b2ed-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","ch