{"tag":"section","attrib":{"id":"idf699817e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13105"},"text":null,"children":[{"tag":"num","attrib":{"value":"13105"},"text":"§ 13105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of allocations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf699817f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6998180-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts allocated to a State shall be available for obligation by that State for a period of 3 years after the date of allocation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6998181-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts allocated to a State that are not obligated at the end of the 3-year period referred to in paragraph (1) shall be withdrawn and allocated by the Secretary in addition to any other amounts available for allocation in the fiscal year in which they are withdrawn or the following fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6998182-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s13105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts available to the Secretary for State recreational boating safety programs for a fiscal year that have not been allocated at the end of the fiscal year shall be allocated among States in the next fiscal year in addition to amounts otherwise available for allocation to States for that next fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6998183-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/595"},"text":"97 Stat. 595","children":[],"tail":", § 13104; "},{"tag":"ref","attrib":{"href":"/us/pl/99/307/s1/18"},"text":"Pub. L. 99–307, § 1(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-05-19"},"text":"May 19, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/446"},"text":"100 Stat. 446","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/587/tV/s5101"},"text":"Pub. L. 102–587, title V, § 5101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-04"},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5070"},"text":"106 Stat. 5070","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tVII/s7405/a"},"text":"Pub. L. 105–178, title VII, § 7405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/487"},"text":"112 Stat. 487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tX/s10142"},"text":"Pub. L. 109–59, title X, § 10142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1931"},"text":"119 Stat. 1931","children":[],"tail":"; renumbered § 13105, "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s16/b/1"},"text":"Pub. L. 109–304, § 16(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1705"},"text":"120 Stat. 1705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6998184-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6998185-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6998186-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"13104","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:1477","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 13104 allows a State to use any of the amounts received from the Secretary over a 3 year period. If the State does not spend the money within that period, the amounts revert to the Secretary, who will make the amounts available along with the amounts available for that year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6998187-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf6998188-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 13105 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s13106"},"text":"section 13106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6998189-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s13104"},"text":"section 13104 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s10142/1"},"text":"Pub. L. 109–59, § 10142(1)","children":[],"tail":", substituted “3 years” for “2 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s10142/2"},"text":"Pub. L. 109–59, § 10142(2)","children":[],"tail":", substituted “3-year” for “2-year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s7405/a/1"},"text":"Pub. L. 105–178, § 7405(a)(1)","children":[],"tail":", substituted “2 years” for “3 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s7405/a/2"},"text":"Pub. L. 105–178, § 7405(a)(2)","children":[],"tail":", substituted “2-year” for “3-year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/587"},"text":"Pub. L. 102–587","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) Amounts allocated to a State shall be available for obligation by that State for a period of 3 years after the date of allocation. Amounts unobligated by the State at the end of the 3 years shall be withdrawn by the Secretary and shall be available with other amounts to be allocated by the Secretary during that fiscal year.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) Amounts available to the Secretary for State recreational boating safety programs that have not been allocated at the end of a fiscal year shall be carried forward as part of the total allocation of amounts for the next fiscal year that may be expended under this chapter.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/307"},"text":"Pub. L. 99–307","children":[],"tail":" inserted “for State recreational boating safety programs” after “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf69bca7a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf69bca7b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"From ","children":[{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", to end of fiscal year 2005, subsec. (a) of this section considered to read as immediately before enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/74/s101/b"},"text":"section 101(b) of Pub. L. 109–74","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777b"},"text":"section 777b of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2005-10-01"},"text":"Oct. 1, 2005","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/s10102"},"text":"section 10102 of Pub. L. 109–59","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s777b"},"text":"section 777b of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
