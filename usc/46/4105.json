{"tag":"section","attrib":{"id":"idf66e78e0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4105"},"text":null,"children":[{"tag":"num","attrib":{"value":"4105"},"text":"§ 4105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uninspected passenger vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf66e78e1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 43 of this title applies to an uninspected passenger vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66e78e2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf66e78e3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In applying this title with respect to an uninspected vessel of less than 24 meters overall in length that carries passengers to or from a port in the United States Virgin Islands, the Secretary shall substitute “12 passengers” for “6 passengers” each place it appears in section 2101 if the Secretary determines that the vessel complies with, as applicable to the vessel—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf66e78e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4105/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Code of Practice for the Safety of Small Commercial Motor Vessels (commonly referred to as the “Yellow Code”), as published by the U.K. Maritime and Coastguard Agency and in effect on ","children":[{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf66e78e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4105/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Code of Practice for the Safety of Small Commercial Sailing Vessels (commonly referred to as the “Blue Code”), as published by such agency and in effect on such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf66e78e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary establishes standards to carry out this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf66e78e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4105/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such standards shall be identical to those established in the Codes of Practice referred to in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf66e78e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4105/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on any dates before the date on which such standards are in effect, the Codes of Practice referred to in paragraph (1) shall apply with respect to the vessels referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66e78e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In applying this title with respect to an uninspected vessel of less than 25 feet overall in length that carries passengers on Crane Lake or waters contiguous to such lake in St. Louis County, Minnesota, the Secretary shall substitute “12 passengers” for “6 passengers” each place it appears in section 2101.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf66e78ea-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall, by regulation, require certain additional equipment which may include liferafts or other lifesaving equipment, construction standards, or specify additional operating standards for those uninspected passenger vessels defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101/55/A"},"text":"section 2101(55)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf66e78eb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/529"},"text":"97 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/206/tV/s511/b"},"text":"Pub. L. 103–206, title V, § 511(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-20"},"text":"Dec. 20, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2442"},"text":"107 Stat. 2442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIII/s319"},"text":"Pub. L. 113–281, title III, § 319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3051"},"text":"128 Stat. 3051","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3541/b/10"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3541(b)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2323"},"text":"132 Stat. 2323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tV/s502"},"text":"Pub. L. 115–282, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4269"},"text":"132 Stat. 4269","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVI/s11601/c/2"},"text":"Pub. L. 117–263, div. K, title CXVI, § 11601(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4146"},"text":"136 Stat. 4146","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7301/k/1/E"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7301(k)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1759"},"text":"139 Stat. 1759","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf66e78ec-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf66e78ed-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf66e78ee-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"4105","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:1452","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:1453","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4105 provides that an uninspected passenger vessel is subject to Chapter 43, as a recreational vessel even when it is carrying not more than six passengers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf66e78ef-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf66e78f0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “section 2101(55)(A)” for “section 2101(53)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11601/c/2/A"},"text":"Pub. L. 117–263, § 11601(c)(2)(A)","children":[],"tail":", substituted “section 2101” for “section 2101(51)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11601/c/2/A"},"text":"Pub. L. 117–263, § 11601(c)(2)(A)","children":[],"tail":", substituted “section 2101” for “section 2101(51)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s11601/c/2/B"},"text":"Pub. L. 117–263, § 11601(c)(2)(B)","children":[],"tail":", substituted “section 2101(53)(A)” for “section 2101(51)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3541/b/10/A"},"text":"Pub. L. 115–232, § 3541(b)(10)(A)","children":[],"tail":", substituted “section 2101(51)” for “section 2101(42)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s502/2"},"text":"Pub. L. 115–282, § 502(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3541/b/10/B"},"text":"Pub. L. 115–232, § 3541(b)(10)(B)","children":[],"tail":", substituted “section 2101(51)(A)” for “section 2101(42)(A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s502/1"},"text":"Pub. L. 115–282, § 502(1)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" added subsec. (b), redesignated former subsec. (b) as (c), and in subsec. (c) substituted “The” for “Within twenty-four months of the date of enactment of this subsection, the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/206"},"text":"Pub. L. 103–206","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
