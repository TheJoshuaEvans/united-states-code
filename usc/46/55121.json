{"tag":"section","attrib":{"id":"idf6e816aa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55121"},"text":null,"children":[{"tag":"num","attrib":{"value":"55121"},"text":"§ 55121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of merchandise and passengers on Canadian vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e816ab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Between Rochester and Alexandria Bay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Until passenger service is established by vessels of the United States between the port of Rochester, New York, and the port of Alexandria Bay, New York, the Secretary of Homeland Security may issue annually permits to Canadian passenger vessels to transport passengers between those ports. Canadian vessels holding such a permit are not subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55103"},"text":"section 55103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e816ac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Within Alaska or Between Alaska and Other Points in the United States","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until the Secretary of Transportation determines that service by vessels of the United States is available to provide the transportation described in paragraph (1) or (2), sections 55102 and 55103 of this title do not apply to the transportation on Canadian vessels of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e816ad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55121/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passengers between ports in southeastern Alaska; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e816ae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passengers or merchandise between Hyder, Alaska, and other points in southeastern Alaska or in the United States outside Alaska.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e816af-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1641"},"text":"120 Stat. 1641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e816b0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e816b1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e816b2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"c