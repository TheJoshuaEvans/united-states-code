attrib":{"href":"/us/usc/t31/s321/c"},"text":"section 321(c) of title 31","children":[],"tail":". For prior related transfers of functions, see the transfer of functions note under 46 App. U.S.C. 289a."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
