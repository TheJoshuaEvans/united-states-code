{"tag":"section","attrib":{"id":"idf6b14ee4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41304"},"text":null,"children":[{"tag":"num","attrib":{"value":"41304"},"text":"§ 41304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings and orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b14ee5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Opportunity for Hearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Maritime Commission shall provide an opportunity for a hearing before issuing an order relating to a violation of this part or a regulation prescribed under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14ee6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modification of Order","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may reverse, suspend, or modify any of its orders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14ee7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rehearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On application of a party to a proceeding, the Commission may grant a rehearing of the same or any matter determined in the proceeding. Except by order of the Commission, a rehearing does not operate as a stay of an order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14ee8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Effectiveness","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An order of the Commission remains in effect for the period specified in the order or until suspended, modified, or set aside by the Commission or a court of competent jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b14ee9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1546"},"text":"120 Stat. 1546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b14eea-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b14eeb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b14eec-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"childre