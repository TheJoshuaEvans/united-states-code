{"tag":"section","attrib":{"id":"idf6ea87af-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55335"},"text":null,"children":[{"tag":"num","attrib":{"value":"55335"},"text":"§ 55335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocations and terminations of designations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ea87b0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55335/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"After notice and an opportunity for a hearing, the Secretary of Transportation may revoke a designation of a vessel as an American Great Lakes vessel if the Secretary finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea87b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55335/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel does not meet a requirement for the designation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea87b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55335/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel has been operated in violation of this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea87b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55335/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner or operator of the vessel has violated an agreement made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55332/b"},"text":"section 55332(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ea87b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55335/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terminations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On petition and a showing of good cause by the owner of a vessel, the Secretary may terminate the designation of a vessel as an American Great Lakes vessel. The Secretary may impose conditions in a termination order to prevent significant adverse effects on other operators of vessels of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ea87b5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1650"},"text":"120 Stat. 1650","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ea87b6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ea87b7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ea87b8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55335","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1241t(a), (c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/101/624/tXV/s1524/a"},"text":"Pub. L. 101–624, title XV, § 1524(a)","children":[],"tail":", (c), "},{"tag":"html:span","attrib":{},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3667"},"text":"104 Stat. 3667","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “construction and purchase” before “agreement” are omitted because the source provision for section 55332(b) of the revised title does not say anything about construction.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “vessels of the United States” are substituted for “United States-flag vessel” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
