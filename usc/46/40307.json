{"tag":"section","attrib":{"id":"idf6ac942f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307"},"text":null,"children":[{"tag":"num","attrib":{"value":"40307"},"text":"§ 40307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from antitrust laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6aedd20-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The antitrust laws do not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aedd21-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement (including an assessment agreement) that has been filed and is effective under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd22-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement that is exempt under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s40103"},"text":"section 40103 of this title","children":[],"tail":" from any requirement of this part;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd23-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an agreement or activity within the scope of this part, whether permitted under or prohibited by this part, undertaken or entered into with a reasonable basis to conclude that it is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6aedd24-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to an agreement on file with the Federal Maritime Commission and in effect when the activity takes place; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6aedd25-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s40103"},"text":"section 40103 of this title","children":[],"tail":" from any filing or publication requirement of this part;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd26-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement or activity relating to transportation services within or between foreign countries, whether or not via the United States, unless the agreement or activity has a direct, substantial, and reasonably foreseeable effect on the commerce of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd27-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement or activity relating to the foreign inland segment of through transportation that is part of transportation provided in a United States import or export trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd28-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement or activity to provide wharfage, dock, warehouse, or other terminal facilities outside the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd29-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement, modification, or cancellation approved before ","children":[{"tag":"date","attrib":{"date":"1984-06-18"},"text":"June 18, 1984","children":[],"tail":", by the Commission under section 15 of the Shipping Act, 1916, or permitted under section 14b of that Act, and any properly published tariff, rate, fare, or charge, or classification, rule, or regulation explanatory thereof implementing that agreement, modification, or cancellation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd2a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This part does not extend antitrust immunity to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aedd2b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement with or among air carriers, rail carriers, motor carriers, tug operators, or common carriers by water not subject to this part relating to transportation within the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd2c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discussion or agreement among common carriers subject to this part relating to the inland divisions (as opposed to the inland portions) of through rates within the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd2d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agreement among common carriers subject to this part to establish, operate, or maintain a marine terminal in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd2e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loyalty contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd2f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retroactive Effect of Determinations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A determination by an agency or court that results in the denial or removal of the immunity to the antitrust laws under subsection (a) does not remove or alter the antitrust immunity for the period before the determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd30-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40307/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relief Under Clayton Act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may not recover damages under section 4 of the Clayton Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s15"},"text":"15 U.S.C. 15","children":[],"tail":"), or obtain injunctive relief under section 16 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s26"},"text":"15 U.S.C. 26","children":[],"tail":"), for conduct prohibited by this part."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6aedd31-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1531"},"text":"120 Stat. 1531","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tVII/s709/c"},"text":"Pub. L. 115–282, title VII, § 709(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4297"},"text":"132 Stat. 4297","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6aedd32-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6aedd33-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6aedd34-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40307","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1706.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/98/237/s7"},"text":"Pub. L. 98–237, § 7","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 20, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/73"},"text":"98 Stat. 73","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tI/s105"},"text":"Pub. L. 105–258, title I, § 105","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1905"},"text":"112 Stat. 1905","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(1) is substituted for “any agreement that has been filed under section 1704 of this Appendix and is effective under section 1704(d) [redesignated as (e)] or section 1705 of this Appendix” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(2) is substituted for “any agreement that . . . is exempt under section 1715 of this Appendix from any requirement of this chapter” in 46 App. U.S.C. 1706(a)(1) for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(7), the words “subject to section 1719(e)(2) of this Appendix” are omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6aedd35-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6aedd36-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 15 of the Shipping Act, 1916, referred to in subsec. (a)(7), which was classified to section 814 of the former Appendix to this title, was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s335/b/3"},"text":"Pub. L. 104–88, title III, § 335(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-12-29"},"text":"Dec. 29, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/954"},"text":"109 Stat. 954","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 14b of the Shipping Act, 1916, referred to in subsec. (a)(7), which was classified to section 813a of former Title 46, Shipping, was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/237/s20/a"},"text":"Pub. L. 98–237, § 20(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-20"},"text":"Mar. 20, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/88"},"text":"98 Stat. 88","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6aedd37-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" inserted “tug operators,” after “motor carriers,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
