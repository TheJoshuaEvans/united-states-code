{"tag":"section","attrib":{"id":"idf67cd113-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7508"},"text":null,"children":[{"tag":"num","attrib":{"value":"7508"},"text":"§ 7508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to extend the duration of medical certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf67cd114-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Granting of Extensions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may extend for not more than one year a medical certificate issued to an individual holding a license, merchant mariner’s document, or certificate of registry issued under chapter 71 or 73 if the Secretary determines that the extension is required to enable the Coast Guard to eliminate a backlog in processing applications for medical certificates or is in response to a national emergency or natural disaster.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf67cd115-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Manner of Extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An extension under this section may be granted to an individual or a specifically identified group of individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf67cd116-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/213/tIII/s306/a"},"text":"Pub. L. 112–213, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-20"},"text":"Dec. 20, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1565"},"text":"126 Stat. 1565","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(b)(6), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4751"},"text":"134 Stat. 4751","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf67cd117-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf67cd118-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf67cd119-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “an individual or a specifically identified group of individuals” for “individual seamen or a specifically identified group of seamen”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
