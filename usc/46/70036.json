{"tag":"section","attrib":{"id":"idf6fb2994-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036"},"text":null,"children":[{"tag":"num","attrib":{"value":"70036"},"text":"§ 70036.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6fb2995-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb2996-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who is found by the Secretary, after notice and an opportunity for a hearing, to have violated subchapters I through III or this subchapter or a regulation issued under subchapters I through III or this subchapter shall be liable to the United States for a civil penalty, not to exceed $25,000 for each violation. Each day of a continuing violation shall constitute a separate violation. The amount of such civil penalty shall be assessed by the Secretary, or the Secretary’s designee, by written notice. In determining the amount of such penalty, the Secretary shall take into account the nature, circumstances, extent, and gravity of the prohibited acts committed and, with respect to the violator, the degree of culpability, any history of prior offenses, ability to pay, and such other matters as justice may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb2997-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compromise, modification, or remission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may compromise, modify, or remit, with or without conditions, any civil penalty that is subject to imposition or that has been imposed under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb2998-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure to pay penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any person fails to pay an assessment of a civil penalty after it has become final, the Secretary may refer the matter to the Attorney General of the United States, for collection in any appropriate district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb2999-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Penalty.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb299a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Class d felony","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who willfully and knowingly violates subchapters I through III or this subchapter or any regulation issued thereunder commits a class D felony.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb299b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Class c felony","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who, in the willful and knowing violation of subchapters I through III or this subchapter or of any regulation issued thereunder, uses a dangerous weapon, or engages in conduct that causes bodily injury or fear of imminent bodily injury to any officer authorized to enforce the provisions of such a subchapter or the regulations issued under such subchapter, commits a class C felony.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb299c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In Rem Liability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any vessel that is used in violation of subchapters I, II, or III or this subchapter, or any regulations issued under such subchapter, shall be liable in rem for any civil penalty assessed pursuant to subsection (a) and may be proceeded against in the United States district court for any district in which such vessel may be found.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb299d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Injunction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States district courts shall have jurisdiction to restrain violations of subchapter I, II, or III or this subchapter or of regulations issued under such subchapter, for cause shown.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb299e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Denial of Entry","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in section 70021 or 70022, the Secretary may, subject to recognized principles of international law, deny entry by any vessel that is not in compliance with subchapter I, II, or III or this subchapter or the regulations issued under such subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb299f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" into the navigable waters of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb29a0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any port or place under the jurisdiction of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb29a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withholding of Clearance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb29a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any owner, operator, or individual in charge of a vessel is liable for a penalty or fine under this section, or if reasonable cause exists to believe that the owner, operator, or individual in charge may be subject to a penalty or fine under this section, the Secretary of the Treasury, upon the request of the Secretary, shall with respect to such vessel refuse or revoke any clearance required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s60105"},"text":"section 60105 of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb29a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70036/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Granting clearance refused or revoked","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Clearance refused or revoked under this subsection may be granted upon filing of a bond or other surety satisfactory to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6fb29a4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIV/s401/a"},"text":"Pub. L. 115–282, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4262"},"text":"132 Stat. 4262","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], §§ 8507(a)(9), 8508(2)(B), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4753"},"text":"134 Stat. 4753","children":[],"tail":", 4755.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6fb29a5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6fb29a6-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6fb29a7-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8507/a/9"},"text":"Pub. L. 116–283, § 8507(a)(9)","children":[],"tail":", substituted “I through III” for “A through C” and “I, II, or III” for “A, B, or C” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8508/2/B"},"text":"Pub. L. 116–283, § 8508(2)(B)","children":[],"tail":", inserted “or 70022” after “section 70021” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
