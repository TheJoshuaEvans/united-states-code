{"tag":"section","attrib":{"id":"idf68fe44d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11108"},"text":null,"children":[{"tag":"num","attrib":{"value":"11108"},"text":"§ 11108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68fe44e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withholding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Wages due or accruing to a master or seaman on a vessel in the foreign, coastwise, intercoastal, interstate, or noncontiguous trade or an individual employed on a fishing vessel or any fish processing vessel may not be withheld under the tax laws of a State or a political subdivision of a State. However, this section does not prohibit withholding wages of a seaman on a vessel in the coastwise trade between ports in the same State if the withholding is under a voluntary agreement between the seaman and the employer of the seaman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe44f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68fe450-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on jurisdiction to tax","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual to whom this subsection applies is not subject to the income tax laws of a State or political subdivision of a State, other than the State and political subdivision in which the individual resides, with respect to compensation for the performance of duties described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe451-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection applies to an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf68fe452-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11108/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged on a vessel to perform assigned duties in more than one State as a pilot licensed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s7101"},"text":"section 7101 of this title","children":[],"tail":" or licensed or authorized under the laws of a State; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf68fe453-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11108/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who performs regularly assigned duties while engaged as a master, officer, or crewman on a vessel operating on navigable waters in 2 or more States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68fe454-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/580"},"text":"97 Stat. 580","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/364/tIV/s402/14"},"text":"Pub. L. 98–364, title IV, § 402(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-17"},"text":"July 17, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/450"},"text":"98 Stat. 450","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/489/s1"},"text":"Pub. L. 106–489, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2207"},"text":"114 Stat. 2207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIX/s906"},"text":"Pub. L. 111–281, title IX, § 906","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3012"},"text":"124 Stat. 3012","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68fe455-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68fe456-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68fe457-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"11108","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:601","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 11108 prohibits the mandatory withholding of state or local taxes from crewmembers on certain specified vessels. It permits, however, voluntary withholding agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68fe458-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68fe459-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281"},"text":"Pub. L. 111–281","children":[],"tail":" amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “who performs regularly-assigned duties while engaged as a master, officer, or crewman on a vessel operating on the navigable waters of more than one State.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/489"},"text":"Pub. L. 106–489","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/364"},"text":"Pub. L. 98–364","children":[],"tail":" substituted “an individual employed on a fishing vessel or any fish processing vessel” for “a fisherman employed on a fishing vessel”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
