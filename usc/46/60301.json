{"tag":"section","attrib":{"id":"idf6f66d6f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60301"},"text":null,"children":[{"tag":"num","attrib":{"value":"60301"},"text":"§ 60301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regular tonnage taxes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f66d70-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lower Rate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A tax is imposed at the rate of 4.5 cents per ton, not to exceed a total of 22.5 cents per ton per year, for fiscal years 2006 through 2010, and 2 cents per ton, not to exceed a total of 10 cents per ton per year, for each fiscal year thereafter, at each entry in a port of the United States of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f66d71-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel entering from a foreign port or place in North America, Central America, the West Indies Islands, the Bahama Islands, the Bermuda Islands, or the coast of South America bordering the Caribbean Sea; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f66d72-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a vessel returning to the same port or place in the United States from which it departed, and not entering the United States from another port or place, except—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6f66d73-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60301/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vessel of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f66d74-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60301/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recreational vessel (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"section 2101 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f66d75-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60301/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a barge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f66d76-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Higher Rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A tax is imposed at the rate of 13.5 cents per ton, not to exceed a total of 67.5 cents per ton per year, for fiscal years 2006 through 2010, and 6 cents per ton, not to exceed a total of 30 cents per ton per year, for each fiscal year thereafter, on a vessel at each entry in a port of the United States from a foreign port or place not named in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f66d77-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s60301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for Vessels Entering Other Than by Sea","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply to a vessel entering other than by sea from a foreign port or place at which tonnage, lighthouse, or other equivalent taxes are not imposed on vessels of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f66d78-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s9/b"},"text":"Pub. L. 109–304, § 9(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1677"},"text":"120 Stat. 1677","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tIV/s4001"},"text":"Pub. L. 109–171, title IV, § 4001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/27"},"text":"120 Stat. 27","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3524"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/600"},"text":"122 Stat. 600","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f66d79-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f66d7a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f66d7b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"ta