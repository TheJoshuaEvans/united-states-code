n":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60301(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:132.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1910-03-08/ch86"},"text":"Mar. 8, 1910, ch. 86","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/36/234"},"text":"36 Stat. 234","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/101/508/tX/s10402/b"},"text":"Pub. L. 101–508, title X, § 10402(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/1388-399"},"text":"104 Stat. 1388–399","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/66/tIX/s9001/b"},"text":"Pub. L. 103–66, title IX, § 9001(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/402"},"text":"107 Stat. 402","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/33/tIX/s9201/b"},"text":"Pub. L. 105–33, title IX, § 9201(b)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/111/671"},"text":"111 Stat. 671","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the tax rates for fiscal years 1991 through 2002 are omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “West Indies Islands” are substituted for “West India Islands” to conform to current geographic terminology. The word “Newfoundland” is omitted because Newfoundland is now part of Canada.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the reference to the definitions in section 2101 is confined to “recreational vessel” because the definitions of “vessel of the United States” and “barge” are being moved to chapter 1 of the revised title and being made applicable title-wide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6f66d7c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6f66d7d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3524/b"},"text":"Pub. L. 110–181, § 3524(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/s4001"},"text":"Pub. L. 109–171, § 4001","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3524/a/1"},"text":"Pub. L. 110–181, § 3524(a)(1)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/s4001"},"text":"Pub. L. 109–171, § 4001","children":[],"tail":", into this section by substituting “4.5 cents per ton, not to exceed a total of 22.5 cents per ton per year, for fiscal years 2006 through 2010, and 2 cents per ton, not to exceed a total of 10 cents per ton per year, for each fiscal year thereafter,” for “2 cents per ton (but not more than a total of 10 cents per ton per year)” in subsec. (a) and “13.5 cents per ton, not to exceed a total of 67.5 cents per ton per year, for fiscal years 2006 through 2010, and 6 cents per ton, not to exceed a total of 30 cents per ton per year, for each fiscal year thereafter,” for “6 cents per ton (but not more than a total of 30 cents per ton per year)” in subsec. (b). See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s4001"},"text":"Pub. L. 109–171, § 4001","children":[],"tail":", which directed the amendment of sections 121 and 132 of the former Appendix to this title from which this section was derived, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3524/b"},"text":"Pub. L. 110–181, § 3524(b)","children":[],"tail":". See 2008 Amendment note for subsecs. (a), (b) and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
