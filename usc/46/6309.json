{"tag":"section","attrib":{"id":"idf6781659-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s6309"},"text":null,"children":[{"tag":"num","attrib":{"value":"6309"},"text":"§ 6309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voyage data recorder access","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Coast Guard shall have full, concurrent, and timely access to and ability to use voyage data recorder data and audio held by any Federal agency in all marine casualty investigations, regardless of which agency is the investigative lead.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf678165a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/265/tII/s207/a"},"text":"Pub. L. 115–265, title II, § 207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-11"},"text":"Oct. 11, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3747"},"text":"132 Stat. 3747","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
