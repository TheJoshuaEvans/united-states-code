{"tag":"section","attrib":{"id":"idf64d35cc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s504"},"text":null,"children":[{"tag":"num","attrib":{"value":"504"},"text":"§ 504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remission of fees and penalties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any part of a fee, tax, or penalty paid or a forfeiture incurred under a law or regulation relating to vessels or seamen may be remitted if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf64d35cd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s504/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" application for the remission is made within one year after the date of the payment or forfeiture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf64d35ce-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s504/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is found that the fee, tax, penalty, or forfeiture was improperly or excessively imposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf64d35cf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s4"},"text":"Pub. L. 109–304, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1491"},"text":"120 Stat. 1491","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf64d35d0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf64d35d1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf64d35d2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"504","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:2108.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section replaces ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s2108"},"text":"46 U.S.C. 2108","children":[],"tail":", which was enacted as part of the codification of subtitle II of title 46 in 1983. That provision was based on "},{"tag":"ref","attrib":{"href":"/us/act/1884-06-26/ch121/s26"},"text":"section 26 of the Act of June 26, 1884, ch. 121","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/23/59"},"text":"23 Stat. 59","children":[],"tail":", which prior to the subtitle II codification appeared at "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s8"},"text":"46 U.S.C. 8","children":[],"tail":" (1982 ed.). In the enactment of "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s2108"},"text":"46 U.S.C. 2108","children":[],"tail":", the scope of the 1884 provision was narrowed, presumably inadvertently. This section restores the remissions authority to its prior scope. Note that 19 C.F.R. § 4.24 (2003) still refers to “the authority to make refunds in accordance with "},{"tag":"ref","attrib":{"href":"/us/act/1884-06-26/s26"},"text":"section 26 of the Act of June 26, 1884","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t46/s8"},"text":"46 U.S.C. 8","children":[],"tail":")” as if that provision had not been replaced by "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s2108"},"text":"46 U.S.C. 2108","children":[],"tail":" in 1983."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
