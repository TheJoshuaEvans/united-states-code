{"tag":"section","attrib":{"id":"idf692556f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12102"},"text":null,"children":[{"tag":"num","attrib":{"value":"12102"},"text":"§ 12102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessels requiring documentation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6925570-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided, a vessel may engage in a trade only if the vessel has been issued a certificate of documentation with an endorsement for that trade under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6925571-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessels Less Than ","children":[],"tail":"5"},{"tag":"inline","attrib":{},"text":" Net Tons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel of less than 5 net tons may engage in a trade without being documented if the vessel otherwise satisfies the requirements to engage in the particular trade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6925572-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Barges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A barge qualified to engage in the coastwise trade may engage in the coastwise trade, without being documented, on rivers, harbors, lakes (except the Great Lakes), canals, and inland waters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6925573-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aquaculture Waiver.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6925574-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12102/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permitting of nonqualified vessels to perform certain aquaculture support operations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 12113 and any other law, the Secretary of Transportation may issue a waiver allowing a documented vessel with a registry endorsement or a foreign flag vessel to be used in operations that treat aquaculture fish for or protect aquaculture fish from disease, parasitic infestation, or other threats to their health if the Secretary finds, after publishing a notice in the Federal Register, that a suitable vessel of the United States is not available that could perform those services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6925575-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12102/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Vessels operating under a waiver issued under this subsection may not engage in any coastwise transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6925576-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1492"},"text":"120 Stat. 1492","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/281/tIX/s901/c/1"},"text":"Pub. L. 111–281, title IX, § 901(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3008"},"text":"124 Stat. 3008","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6925577-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6925578-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6925579-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib