{"tag":"section","attrib":{"id":"idf656ac15-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116"},"text":null,"children":[{"tag":"num","attrib":{"value":"2116"},"text":"§ 2116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marine safety strategy, goals, and performance assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf656ac16-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Long-Term Strategy and Goals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conjunction with existing federally required strategic planning efforts, the Secretary shall develop a long-term strategy for improving vessel safety and the safety of individuals on vessels. The 5-year strategy shall include the issuance of a plan and schedule for achieving the following goals:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf656ac17-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reducing the number and rates of marine casualties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf656ac18-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving the consistency and effectiveness of vessel and operator enforcement and compliance programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf656ac19-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identifying and targeting enforcement efforts at high-risk vessels and operators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf656ac1a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving research efforts to enhance and promote vessel and operator safety and performance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf656ac1b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 5","children":[{"tag":"inline","attrib":{},"text":"-Year Strategy and Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf656ac1c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Measurable goals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The 5-year strategy and plan shall include specific numeric or measurable goals designed to achieve the goals set forth in subsection (a). The purposes of the numeric or measurable goals are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf656ac1d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To increase the number of safety examinations on all high-risk vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf656ac1e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To eliminate the backlog of marine safety-related rulemakings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf656ac1f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To improve the quality and effectiveness of marine safety information databases by ensuring that all Coast Guard personnel accurately and effectively report all safety, casualty, and injury information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf656ac20-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide for a sufficient number of Coast Guard marine safety personnel, and provide adequate facilities and equipment to carry out the functions referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s504/c"},"text":"section 504(c) of title 14","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf656ac21-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resource needs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The 5-year strategy and plan shall include estimates of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf656ac22-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funds and staff resources needed to accomplish each activity included in the strategy and plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf656ac23-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the staff skills and training needed for timely and effective accomplishment of each goal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf656ac24-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission With the President’s Budget","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 5 years after the date of the enactment of the Elijah E. Cummings Coast Guard Authorization Act of 2020, and every 5 years thereafter, the Secretary shall submit to Congress the strategy and plan not later than 60 days following the transmission of the President’s budget submission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf656ac25-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Achievement of Goals.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf656ac26-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Progress assessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In conjunction with the submission of the 5-year strategy and plan, the Commandant shall assess the progress of the Coast Guard toward achieving the goals set forth in subsection (b). The Commandant shall convey the Commandant’s assessment to the employees of the marine safety workforce and shall identify any deficiencies that should be remedied before the next progress assessment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf656ac27-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Periodic briefings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall periodically brief the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf656ac28-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the performance of the marine safety program in achieving the goals of the marine safety strategy and plan under subsection (a) for the period covered by the briefing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf656ac29-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on the program’s mission performance in achieving numerical measurable goals established under subsection (b), including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf656ac2a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of civilian and military Coast Guard personnel assigned to marine safety positions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf656ac2b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of marine safety positions that are understaffed to meet the workload required to accomplish each activity included in the strategy and plan under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf656ac2c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2116/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on how to improve performance of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf656ac2d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/tV/s522/a"},"text":"Pub. L. 111–281, title V, § 522(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2956"},"text":"124 Stat. 2956","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tII/s221/b/1/A"},"text":"Pub. L. 113–281, title II, § 221(b)(1)(A)","children":[],"tail":", title III, § 307(a), "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3037"},"text":"128 Stat. 3037","children":[],"tail":", 3045; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV"},"text":"Pub. L. 115–232, div. C, title XXXV","children":[],"tail":", §§ 3541(b)(7), 3546(b), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2323"},"text":"132 Stat. 2323","children":[],"tail":", 2326; "},{"tag":"ref","attrib":{"href":"/us/pl/115/265/tII/s214"},"text":"Pub. L. 115–265, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-11"},"text":"Oct. 11, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3751"},"text":"132 Stat. 3751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8240(c), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4666"},"text":"134 Stat. 4666","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXVII/s7701/f/2"},"text":"Pub. L. 119–60, div. G, title LXXVII, § 7701(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1835"},"text":"139 Stat. 1835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf656ac2e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf656ac2f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf656ac30-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Elijah E. Cummings Coast Guard Authorization Act of 2020, referred to in subsec. (c), is the date of enactment of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf656ac31-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" substituted “section 504(c)” for “section 93(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/c/1"},"text":"Pub. L. 116–283, § 8240(c)(1)","children":[],"tail":", substituted “The 5-year strategy shall include the issuance of a plan” for “The strategy shall include the issuance of a triennial plan” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/c/2/A"},"text":"Pub. L. 116–283, § 8240(c)(2)(A)","children":[],"tail":", substituted “5-Year Strategy and Plan” for “Contents of Strategy and Triennial Plans” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/c/2/B"},"text":"Pub. L. 116–283, § 8240(c)(2)(B)","children":[],"tail":", substituted “5-year strategy and plan” for “strategy and triennial plans” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/c/2/C/i"},"text":"Pub. L. 116–283, § 8240(c)(2)(C)(i)","children":[],"tail":", substituted “5-year strategy and plan” for “strategy and triennial plans” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/c/2/C/ii"},"text":"Pub. L. 116–283, § 8240(c)(2)(C)(ii)","children":[],"tail":", substituted “plan” for “plans”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/c/3"},"text":"Pub. L. 116–283, § 8240(c)(3)","children":[],"tail":", substituted “Not later than 5 years after the date of the enactment of the Elijah E. Cummings Coast Guard Authorization Act of 2020, and every 5 years thereafter, the Secretary” for “Beginning with fiscal year 2020 and triennially thereafter, the Secretary” and struck out “triennial” after “the strategy and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/c/4/A"},"text":"Pub. L. 116–283, § 8240(c)(4)(A)","children":[],"tail":", substituted “In conjunction with the submission of the 5-year strategy and plan” for “No less frequently than semiannually”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/c/4/B/i"},"text":"Pub. L. 116–283, § 8240(c)(4)(B)(i)","children":[],"tail":", (ii), substituted “Periodic briefings” for “Report to congress” in heading and “periodically brief the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives” for “report triennially to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/c/4/B/iii"},"text":"Pub. L. 116–283, § 8240(c)(4)(B)(iii)","children":[],"tail":", struck out “annual” after “safety strategy and” and substituted “for the period covered by the briefing” for “for the year covered by the report”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s8240/c/4/B/iv"},"text":"Pub. L. 116–283, § 8240(c)(4)(B)(iv)","children":[],"tail":", substituted “plan” for “plans”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/265/s214/1"},"text":"Pub. L. 115–265, § 214(1)","children":[],"tail":", substituted “of a triennial” for “each year of an annual” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/265/s214/2"},"text":"Pub. L. 115–265, § 214(2)","children":[],"tail":", substituted “Triennial” for “Annual” in heading and “triennial” for “annual” in introductory provisions of pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/265/s214/3/B"},"text":"Pub. L. 115–265, § 214(3)(B)","children":[],"tail":", substituted “triennial plan” for “annual plan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/265/s214/3/A"},"text":"Pub. L. 115–265, § 214(3)(A)","children":[],"tail":", which directed substitution of “fiscal year 2020 and triennially” for “fiscal year 2011 and each fiscal year”, was executed by substituting “Beginning with fiscal year 2020 and triennially thereafter, the” for “The”, to reflect the probable intent of Congress and the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3546/b"},"text":"Pub. L. 115–232, § 3546(b)","children":[],"tail":". See below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3546/b"},"text":"Pub. L. 115–232, § 3546(b)","children":[],"tail":", substituted “The” for “Beginning with fiscal year 2011 and each fiscal year thereafter, the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s3541/b/7"},"text":"Pub. L. 115–232, § 3541(b)(7)","children":[],"tail":", substituted “the Commandant shall assess” for “the Coast Guard Commandant shall assess”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/265/s214/4"},"text":"Pub. L. 115–265, § 214(4)","children":[],"tail":", substituted “triennially” for “annually” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/s307/a"},"text":"Pub. L. 113–281, § 307(a)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t14/s93/c"},"text":"section 93(c) of title 14","children":[],"tail":"” for “section 93(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281/s221/b/1/A"},"text":"Pub. L. 113–281, § 221(b)(1)(A)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “on the program’s mission performance in achieving numerical measurable goals established under subsection (b); and”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6591c32-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6591c33-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Domestic Vessel Compliance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/265/tII/s204"},"text":"Pub. L. 115–265, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-11"},"text":"Oct. 11, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3745"},"text":"132 Stat. 3745","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/265/tII/s204"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date on which the President submits to the Congress a budget each year pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", United States Code, the Commandant [of the Coast Guard] shall publish on a publicly accessible Website information documenting domestic vessel compliance with the requirements of subtitle II of title 46, United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information required under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include flag-State detention rates for each type of inspected vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any recognized organization that inspected or surveyed a vessel that was later subject to a Coast Guard-issued control action attributable to a major nonconformity that the recognized organization failed to identify in such inspection or survey.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “recognized organization” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/265/s204"},"text":"section 204 of Pub. L. 115–265","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/265/s203"},"text":"section 203 of Pub. L. 115–265","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"section 2101 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
