{"tag":"section","attrib":{"id":"idf7071020-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70114"},"text":null,"children":[{"tag":"num","attrib":{"value":"70114"},"text":"§ 70114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automatic identification systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf7071021-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"System Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf7071022-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2), the following vessels, while operating on the navigable waters of the United States, shall be equipped with and operate an automatic identification system under regulations prescribed by the Secretary:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf7071023-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70114/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A self-propelled commercial vessel of at least 65 feet overall in length.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7071024-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70114/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vessel carrying more than a number of passengers for hire determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7071025-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70114/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A towing vessel of more than 26 feet overall in length and 600 horsepower.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7071026-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70114/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other vessel for which the Secretary decides that an automatic identification system is necessary for the safe navigation of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf7071027-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf7071028-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70114/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt a vessel from paragraph (1) if the Secretary finds that an automatic identification system is not necessary for the safe navigation of the vessel on the waters on which the vessel operates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf7071029-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70114/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waive the application of paragraph (1) with respect to operation of vessels on navigable waters of the United States specified by the Secretary if the Secretary finds that automatic identification systems are not needed for safe navigation on those waters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf707102a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations implementing subsection (a), including requirements for the operation and maintenance of the automatic identification systems required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf707102b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s102/a"},"text":"Pub. L. 107–295, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2082"},"text":"116 Stat. 2082","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf707102c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf707102d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf707102e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/295/tI/s102/e"},"text":"Pub. L. 107–295, title I, § 102(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2084"},"text":"116 Stat. 2084","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/295/tI/s102/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Schedule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70114"},"text":"Section 70114 of title 46","children":[],"tail":", United States Code, as enacted by this Act, shall apply as follows:"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On and after ","children":[{"tag":"date","attrib":{"date":"2003-01-01"},"text":"January 1, 2003","children":[],"tail":", to any vessel built after that date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On and after ","children":[{"tag":"date","attrib":{"date":"2003-07-01"},"text":"July 1, 2003","children":[],"tail":", to any vessel built before the date referred to in subparagraph (A) that is—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a passenger vessel required to carry a certificate under the International Convention for the Safety of Life at Sea, 1974 (SOLAS) [see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1602"},"text":"33 U.S.C. 1602","children":[],"tail":" and notes thereunder];"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tanker; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a towing vessel engaged in moving a tank vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On and after ","children":[{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":", to all other vessels built before the date referred to in subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms in this subsection have the same meaning as those terms have under section 2101 [now also 115] of title 46, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
