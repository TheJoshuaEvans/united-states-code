{"tag":"section","attrib":{"id":"idf6e81692-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55117"},"text":null,"children":[{"tag":"num","attrib":{"value":"55117"},"text":"§ 55117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Great Lakes rail route","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55102"},"text":"Section 55102 of this title","children":[],"tail":" does not apply to the transportation of merchandise loaded on a railroad car or to a motor vehicle with or without a trailer, and with its passengers or contents when accompanied by the operator, when the railroad car or motor vehicle is transported in a railroad car ferry operated between fixed terminals on the Great Lakes as part of a rail route, if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e81693-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55117/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the car ferry is owned by a common carrier by water and operated as part of a rail route with the approval of the Surface Transportation Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81694-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55117/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stock of the common carrier by water, or its predecessor, was owned or controlled by a common carrier by rail prior to ","children":[{"tag":"date","attrib":{"date":"1920-06-05"},"text":"June 5, 1920","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81695-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55117/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the stock of the common carrier owning the car ferry is, with the approval of the Board, now owned or controlled by a common carrier by rail; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e81696-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55117/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the car ferry is built in and documented under the laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e81697-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1640"},"text":"120 Stat. 1640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e81698-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e81699-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e8169a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":