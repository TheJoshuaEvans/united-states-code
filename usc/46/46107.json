{"tag":"section","attrib":{"id":"idf6b609a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46107"},"text":null,"children":[{"tag":"num","attrib":{"value":"46107"},"text":"§ 46107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b609a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Maritime Commission may make such expenditures as are necessary in the performance of its functions from funds appropriated or otherwise made available to it, which appropriations are authorized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b609a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s46107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a), the Federal Maritime Commission may not expend any funds appropriated or otherwise made available to it to a non-Federal entity to issue an award, prize, commendation, or other honor that is not related to the purposes set forth in section 40101.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b609aa-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s4"},"text":"Pub. L. 109–304, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/14