{"tag":"section","attrib":{"id":"idf6b14ecf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41302"},"text":null,"children":[{"tag":"num","attrib":{"value":"41302"},"text":"§ 41302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b14ed0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Maritime Commission, on complaint or its own motion, may investigate any conduct, agreement, fee, or charge that the Commission believes may be in violation of this part. The Commission may by order disapprove, cancel, or modify any agreement that operates in violation of this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14ed1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effectiveness of Agreement, Fee, or Charge During Investigation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless an injunction is issued under section 41306 or 41307 of this title, an agreement, fee, or charge under investigation by the Commission remains in effect until the Commission issues its order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14ed2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Date for Decision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 10 days after the initiation of a proceeding under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s41301"},"text":"section 41301 of this title","children":[],"tail":", the Commission shall set a date by which it will issue its final decision. The Commission by order may extend the date for good cause."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14ed3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sanctions for Delay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, within the period for final decision under subsection (c), the Commission determines that it is unable to issue a final decision because of undue delay caused by a party to the proceeding, the Commission may impose sanctions, including issuing a decision adverse to the delaying party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b14ed4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s41302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall make a written report of every investigation under this part in which a hearing was held, stating its conclusions, decisions, findings of fact, and order. The Commission shall provide a copy of the report to all parties and publish the report for public information. A published report is competent evidence in a court of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b14ed5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1545"},"text":"120 Stat. 1545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/146/s11/a"},"text":"Pub. L. 117–146, § 11(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1278"},"text":"136 Stat. 1278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXV/s3535/f"},"text":"Pub. L. 118–159, div. C, title XXXV, § 3535(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2315"},"text":"138 Stat. 2315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b14ed6-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b14ed7-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b14ed8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision