b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6b14eda-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “conduct, agreement” for “conduct agreement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s11/a/1"},"text":"Pub. L. 117–146, § 11(a)(1)","children":[],"tail":", substituted “agreement, fee, or charge” for “or agreement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s11/a/2/B"},"text":"Pub. L. 117–146, § 11(a)(2)(B)","children":[],"tail":", inserted “, fee, or charge” after “agreement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146/s11/a/2/A"},"text":"Pub. L. 117–146, § 11(a)(2)(A)","children":[],"tail":", substituted “Agreement, Fee, or Charge” for “Agreement” in heading. Quoted text appearing in directory language was conformed to the style used in this title to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
