<section xmlns="http://xml.house.gov/schemas/uslm/1.0" xmlns:html="http://www.w3.org/1999/xhtml" style="-uslm-lc:I80" id="idf65dd765-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301"><num value="3301">§ 3301.</num><heading> Vessels subject to inspection</heading>
<chapeau style="-uslm-lc:I11" class="indent0">The following categories of vessels are subject to inspection under this part:</chapeau><paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd766-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/1"><num value="1">(1)</num><content> freight vessels.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd767-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/2"><num value="2">(2)</num><content> nautical school vessels.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd768-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/3"><num value="3">(3)</num><content> offshore supply vessels.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd769-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/4"><num value="4">(4)</num><content> passenger vessels.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd76a-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/5"><num value="5">(5)</num><content> sailing school vessels.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd76b-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/6"><num value="6">(6)</num><content> seagoing barges.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd76c-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/7"><num value="7">(7)</num><content> seagoing motor vessels.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd76d-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/8"><num value="8">(8)</num><content> small passenger vessels.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd76e-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/9"><num value="9">(9)</num><content> steam vessels.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd76f-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/10"><num value="10">(10)</num><content> tank vessels.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd770-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/11"><num value="11">(11)</num><content> fish processing vessels.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd771-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/12"><num value="12">(12)</num><content> fish tender vessels.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd772-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/13"><num value="13">(13)</num><content> Great Lakes barges.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd773-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/14"><num value="14">(14)</num><content> oil spill response vessels.</content>
</paragraph>
<paragraph style="-uslm-lc:I12" class="indent1" id="idf65dd774-2930-11f1-96a8-b9bd2a0a99b5" identifier="/us/usc/t46/s3301/15"><num value="15">(15)</num><content> towing vessels.</content>
</paragraph>
