{"tag":"section","attrib":{"id":"idf68d9ab6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10710"},"text":null,"children":[{"tag":"num","attrib":{"value":"10710"},"text":"§ 10710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unclaimed money, property, and wages","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68d9ab7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When a claim for the money, property, or wages of a deceased seaman held by a district court of the United States has not been substantiated within 6 years after their receipt by the court, the court, if a subsequent claim is made, may allow or refuse the claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68d9ab8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, after money, property, and wages have been held by the court for 6 years, it appears to the court that no claim will have to be satisfied, the property shall be sold. The money and wages and the proceeds from the sale shall be deposited in the Treasury trust fund receipt account “Unclaimed Moneys of Individuals Whose Whereabouts are Unknown”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68d9ab9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/574"},"text":"97 Stat. 574","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68d9aba-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68d9abb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68d9abc-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10710","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:628","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10710 provides that if no claim is made to a deceased seaman’s property and wages within six years, the court shall sell the property and deposit the proceeds into the Treasury trust fund receipt account “Unclaimed Moneys of Individuals Whose Whereabouts are Unknown”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
