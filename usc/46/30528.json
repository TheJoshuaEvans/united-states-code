:span","attrib":{},"text":"30510","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:183(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 4283(g); ","children":[{"tag":"html:a","attrib":{"href":"/us/pl/104/324/s1129/a"},"text":"Pub. L. 104–324, § 1129(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3984"},"text":"110 Stat. 3984","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “civil action” are substituted for “suit” for consistency in the revised title. The words “is entitled to rely on any statutory” are substituted for “shall be entitled to rely upon any and all statutory” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6a2f6a9-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6a2f6aa-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s30510"},"text":"section 30510 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
