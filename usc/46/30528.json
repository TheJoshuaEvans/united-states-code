{"tag":"section","attrib":{"id":"idf6a2f6a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30528"},"text":null,"children":[{"tag":"num","attrib":{"value":"30528"},"text":"§ 30528.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vicarious liability for medical malpractice with regard to crew","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In a civil action by any person in which the owner or operator of a vessel or employer of a crewmember is claimed to have vicarious liability for medical malpractice with regard to a crewmember occurring at a shoreside facility, and to the extent the damages resulted from the conduct of any shoreside doctor, hospital, medical facility, or other health care provider, the owner, operator, or employer is entitled to rely on any statutory limitations of liability applicable to the doctor, hospital, medical facility, or other health care provider in the State of the United States in which the shoreside medical care was provided.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6a2f6a5-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1515"},"text":"120 Stat. 1515","children":[],"tail":", § 30510; renumbered § 30528, "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXV/s11503/a/3"},"text":"Pub. L. 117–263, div. K, title CXV, § 11503(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4130"},"text":"136 Stat. 4130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a2f6a6-2930-11f1-96a8-b9bd2a0a99b5"},"t