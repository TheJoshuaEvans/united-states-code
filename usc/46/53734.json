{"tag":"section","attrib":{"id":"idf6e0ea3f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734"},"text":null,"children":[{"tag":"num","attrib":{"value":"53734"},"text":"§ 53734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replacement of vessels because of changes in operating standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6e0ea40-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter, the Secretary or Administrator, on terms the Secretary or Administrator may prescribe, may guarantee or make a commitment to guarantee the payment of the principal of and interest on an obligation that aids in financing or refinancing (including reimbursement of an obligor for expenditures previously made for) a contract for the construction or reconstruction of a vessel if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e0ea41-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is designed and to be used for commercial use in coastwise, intercoastal, or foreign trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea42-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction or reconstruction is necessary to replace a vessel that cannot continue to be operated because of a change required by law in the standards for the operation of vessels, and the applicant for the guarantee or commitment would not otherwise legally be able to continue operating vessels in the trades in which the applicant operated vessels before the change;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea43-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant is presently engaged in transporting cargoes in vessels of the type and class that will be constructed or reconstructed under this section and agrees to employ vessels constructed or reconstructed under this section as replacements only for vessels made obsolete by the change in operating standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea44-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity of the vessels to be constructed or reconstructed under this section will not increase the cargo carrying capacity of the vessels being replaced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea45-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary or Administrator has not determined that the market demand for the vessel over its useful life will diminish so as to make granting the guarantee fiduciarily imprudent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea46-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel, if to be reconstructed, will have a useful life of at least 15 years after the reconstruction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea47-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary or Administrator has considered the criteria specified in section 53708(a)(3)–(5) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0ea48-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term and Amount of Obligation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e0ea49-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of an obligation guaranteed under this section may not exceed 25 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea4a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of an obligation guaranteed under this section may not exceed 87.5 percent of the actual cost or depreciated actual cost to the applicant for the construction or reconstruction of the vessel. The Secretary or Administrator may not establish a percentage under this paragraph that is to be applied uniformly to all guarantees or commitments to guarantee made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0ea4b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Other Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A guarantee or commitment to guarantee under this section is also subject to sections 53701, 53702(a), 53704, 53705, 53707(a), 53708(d) and (e), 53709(a), 53710(a)(1), (2), and (4) and (c), 53711(a), 53713, 53714, 53717, and 53721–53725 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0ea4c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security Against Default","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator shall require by regulation that an applicant under this section provide adequate security against default.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6e0ea4d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guarantee Fees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or Administrator may establish a fee for the guarantee of an obligation under this section that is in addition to the fee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53714"},"text":"section 53714 of this title","children":[],"tail":". The fee may be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e0ea4e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annual fee of not more than an additional 1 percent added to the fee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53714"},"text":"section 53714 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea4f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53734/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fee based on the amount of the obligation versus the percentage of the obligor’s fleet being replaced by vessels constructed or reconstructed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e0ea50-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1624"},"text":"120 Stat. 1624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/E"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/10/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(10)(B)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e0ea51-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e0ea52-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e0ea53-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53734(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274a(a), (b)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XI, § 1104B, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/101/380/tIV/s4115/f/2"},"text":"Pub. L. 101–380, title IV, § 4115(f)(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/521"},"text":"104 Stat. 521","children":[],"tail":"; amended "},{"tag":"html:a","attrib":{"href":"/us/pl/102/587/tVI/s6204"},"text":"Pub. L. 102–587, title VI, § 6204","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 4, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/5094"},"text":"106 Stat. 5094","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/103/160/dA/tXIII/s1356/4"},"text":"Pub. L. 103–160, div. A, title XIII, § 1356(4)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/1814"},"text":"107 Stat. 1814","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/239/s11/2"},"text":"Pub. L. 104–239, § 11(2)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 8, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3134"},"text":"110 Stat. 3134","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53734(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274a(b) (less (3)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53734(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274a(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53734(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274a(c)(1) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53734(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1274a(c)(1) (2d sentence), (2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), in paragraph (1), the words “as defined in section 1244 of this Appendix” are omitted because the definition of “foreign commerce or trade” in chapter 1 of the revised title applies without having to say so specifically. Paragraph (6) is substituted for 46 App. U.S.C. 1274a(b)(3) to improve the organization of the source provisions.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “by rule, regulation, or procedure” are omitted as unnecessary and for consistency with section 53709(d) of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (c) and (e), the language concerning the Vessel Replacement Guarantee Fund and the Federal Ship Financing Fund is omitted as obsolete. See the explanation for section 53717.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6e0ea54-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6e0ea55-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":", repealed "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/E"},"text":"Pub. L. 109–163, § 3507(a)(1)(E)","children":[],"tail":". See 2006 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/a/10/B"},"text":"Pub. L. 110–181, § 3522(a)(10)(B)","children":[],"tail":", incorporated the substance of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/E"},"text":"Pub. L. 109–163, § 3507(a)(1)(E)","children":[],"tail":", into this section by inserting “or Administrator” after “Secretary” wherever appearing. See 2006 Amendment note below and "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s18/a"},"text":"section 18(a) of Pub. L. 109–304","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s3507/a/1/E"},"text":"Pub. L. 109–163, § 3507(a)(1)(E)","children":[],"tail":", which directed the amendment of section 1274a of the former Appendix to this title from which this section was derived, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s3522/b"},"text":"Pub. L. 110–181, § 3522(b)","children":[],"tail":". See 2008 Amendment notes and Historical and Revision notes above."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
