{"tag":"section","attrib":{"id":"idf6fb2909-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70011"},"text":null,"children":[{"tag":"num","attrib":{"value":"70011"},"text":"§ 70011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waterfront safety","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6fb290a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may take such action as is necessary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb290b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70011/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent damage to, or the destruction of, any bridge or other structure on or in the navigable waters of the United States, or any land structure or shore area immediately adjacent to such waters, including damage or destruction resulting from cyber incidents, transnational organized crime, or foreign state threats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb290c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70011/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the navigable waters and the resources therein from harm resulting from vessel or structure damage, destruction, or loss or harm resulting from cyber incidents, transnational organized crime, or foreign state threats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb290d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Actions authorized by subsection (a) include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6fb290e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70011/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing procedures, measures, and standards for the handling, loading, unloading, storage, stowage, and movement on a structure (including the emergency removal, control, and disposition) of explosives or other dangerous articles and substances, including oil or hazardous material as those terms are defined in section 2101;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb290f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70011/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribing minimum safety equipment requirements for a structure to assure adequate protection from fire, explosion, natural disaster, and other serious accidents or casualties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb2910-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70011/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing water or waterfront safety zones, or other measures, for limited, controlled, or conditional access and activity when necessary for the protection of any vessel, structure, waters, or shore area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb2911-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70011/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing procedures for examination to assure compliance with the requirements prescribed under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6fb2912-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70011/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibiting a representative of a government of country that the Secretary of State has determined has repeatedly provided support for acts of international terrorism under section 620A of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2371"},"text":"22 U.S.C. 2371","children":[],"tail":") from visiting a facility for which a facility security plan is required under section 70103(c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6fb2913-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s70011/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section, with respect to structures, prohibits a State or political subdivision thereof from prescribing higher safety equipment requirements or safety standards than those that may be prescribed by regulations under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6fb2914-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tIV/s401/a"},"text":"Pub. L. 115–282, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4258"},"text":"132 Stat. 4258","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/tLXXIII/s7321/c"},"text":"Pub. L. 119–60, div. G, title LXXIII, § 7321(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1766"},"text":"139 Stat. 1766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6fb2915-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6fb2916-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6fb2917-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7321/c/1"},"text":"Pub. L. 119–60, § 7321(c)(1)","children":[],"tail":", inserted “, including damage or destruction resulting from cyber incidents, transnational organized crime, or foreign state threats” after “adjacent to such waters”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7321/c/2"},"text":"Pub. L. 119–60, § 7321(c)(2)","children":[],"tail":", inserted “or harm resulting from cyber incidents, transnational organized crime, or foreign state threats” after “loss”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s7321/d"},"text":"Pub. L. 119–60, § 7321(d)","children":[],"tail":", added par. (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
