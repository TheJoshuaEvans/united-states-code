{"tag":"section","attrib":{"id":"idf6971015-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12135"},"text":null,"children":[{"tag":"num","attrib":{"value":"12135"},"text":"§ 12135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Invalidation of certificates of documentation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A certificate of documentation or an endorsement on the certificate is invalid if the vessel for which it is issued—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6971016-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12135/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no longer meets the requirements of this chapter and regulations prescribed under this chapter applicable to the certificate or endorsement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6971017-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12135/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is placed under the command of an individual not a citizen or noncitizen national (as such term is described in section 308 of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1408"},"text":"8 U.S.C. 1408","children":[],"tail":")) of the United States in violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s12131"},"text":"section 12131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6971018-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/