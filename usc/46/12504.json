{"tag":"section","attrib":{"id":"idf6998103-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12504"},"text":null,"children":[{"tag":"num","attrib":{"value":"12504"},"text":"§ 12504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information available from the system","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For law enforcement or other purposes and under conditions prescribed by the Secretary of Transportation, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6998104-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12504/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make available information in the vessel identification system to a State making information available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12503/a"},"text":"section 12503(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6998105-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12504/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make available information in the vessel identification system to others.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6998106-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/710/tI/s101/a"},"text":"Pub. L. 100–710, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-23"},"text":"Nov. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4736"},"text":"102 Stat. 4736","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/225/tIII/s302/3"},"text":"Pub. L. 101–225, title III, § 302(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1923"},"text":"103 Stat. 1923","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6998107-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6998108-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 12504","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section requires that the Secretary make available information maintained in the vessel identification system to a State participating in the system for law enforcement or other purposes. The Secretary may make available information in the system to others, under conditions the Secretary may prescribe. At first, the Secretary may elect to deal only with the States. However, the Committee firmly expects that information will be made available through computer terminals in satellite offices or direct computer access by modem. In this manner, boating organizations or financial or documentation services could retrieve data without paper transactions for a fee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6998109-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf699810a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/225"},"text":"Pub. L. 101–225","children":[],"tail":" substituted “Secretary of Transportation, the Secretary” for “Secretary, the Secretary of Transportation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf699810b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf699810c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"Jan. 1, 1989","children":[],"tail":", with certain exceptions and qualifications, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/710/s107"},"text":"section 107 of Pub. L. 100–710","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s31301"},"text":"section 31301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
