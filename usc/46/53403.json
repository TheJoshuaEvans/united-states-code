{"tag":"section","attrib":{"id":"idf6d5038f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53403"},"text":null,"children":[{"tag":"num","attrib":{"value":"53403"},"text":"§ 53403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of operating agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d50390-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall require, as a condition of including any vessel in the Fleet, that the program participant of the vessel enter into an operating agreement with the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d50391-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure for Applications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d50392-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible vessels","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall accept an application for an operating agreement for an eligible product tank vessel under the priority under paragraph (2) only from a person that has authority to enter into an operating agreement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d50393-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of priority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may enter into a new operating agreement with an applicant that meets the requirements of section 53402(c) for a vessel that meets the qualifications of section 53402(b), and shall give priority to applications based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d50394-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53403/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vessel capabilities, as established by the Secretary of Defense; then","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d50395-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53403/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after consideration of vessel type, according to an applicant’s record of owning and operating vessels; then","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d50396-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53403/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after consideration of ownership and operation, according to such additional priorities as the Secretary of Transportation may consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d50397-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53403/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Concurrence of award","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may not approve an application for an operating agreement without the concurrence of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d50398-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may not award operating agreements under this chapter that require payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53406"},"text":"section 53406 of this title","children":[],"tail":" for more than—."},{"tag":"ref","attrib":{"idref":"fn002039"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002039"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should not appear."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d50399-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53403/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of fiscal years 2022 and 2023, 10 vessels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d5039a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53403/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any subsequent fiscal year, 20 vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d5039b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judicial Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No court shall have jurisdiction to review the Secretary’s decision with respect to the award or non-award of an operating agreement issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d5039c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dC/tXXXV/s3511/a"},"text":"Pub. L. 116–283, div. C, title XXXV, § 3511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4412"},"text":"134 Stat. 4412","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3501/b/2"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3501(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3064"},"text":"136 Stat. 3064","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d5039d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6d5039e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6d5039f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “The Secretary” for “For any fiscal year, the Secretary” and “more than—” for “more than 10 vessels”, designated existing provisions as introductory provisions, and added pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
