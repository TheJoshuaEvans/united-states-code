{"tag":"section","attrib":{"id":"idf6ea8788-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332"},"text":null,"children":[{"tag":"num","attrib":{"value":"55332"},"text":"§ 55332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designating American Great Lakes vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ea8789-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall designate a vessel as an American Great Lakes vessel if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea878a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an application for designation is submitted to the Secretary under regulations prescribed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea878b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is documented under the laws of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea878c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the vessel, on the effective date of the designation, is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ea878d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1, but not more than 6, years old; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ea878e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1, but not more than 11, years old if the Secretary finds that suitable vessels are not available to provide the type of service for which the vessel will be used after the designation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea878f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel has not previously been designated as an American Great Lakes vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea8790-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner makes an agreement as provided under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ea8791-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel may be designated as an American Great Lakes vessel only if the person that will be the owner of the vessel at the time of the designation makes an agreement with the Secretary providing that if the Secretary determines that the vessel is necessary to the defense of the United States, the United States Government will have an exclusive right, during the 120-day period following the date of a revocation of the designation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s55335"},"text":"section 55335 of this title","children":[],"tail":", to purchase the vessel for a price equal to the greater of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea8792-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approximate world market value of the vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea8793-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of the vessel to the owner less a reasonable amount for depreciation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ea8794-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Foreign Documentation and Sale Not Prohibited","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other law, if the Government does not exercise its right of purchase under an agreement under subsection (b), the owner of the vessel is not prohibited from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea8795-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documenting the vessel under the laws of a foreign country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea8796-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selling the vessel to a person not a citizen of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ea8797-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55332/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations establishing requirements for submitting applications under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ea8798-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1649"},"text":"120 Stat. 1649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ea8799-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ea879a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ea879b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"55332","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1241r.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/101/624/tXV/s1522"},"text":"Pub. L. 101–624, title XV, § 1522","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3665"},"text":"104 Stat. 3665","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “for purposes of sections 1241q to 1241v of this Appendix” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), before paragraph (1), the words “construction and purchase” before “agreement” are omitted because the source provision for subsection (b) does not say anything about construction.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
