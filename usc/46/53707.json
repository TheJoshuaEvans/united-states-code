{"tag":"section","attrib":{"id":"idf6dc2edb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53707"},"text":null,"children":[{"tag":"num","attrib":{"value":"53707"},"text":"§ 53707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings related to obligors and operators","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6dc2edc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsible Obligor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator may not guarantee or make a commitment to guarantee an obligation under this chapter unless the Secretary or Administrator finds that the obligor is responsible and has the ability, experience, financial resources, and other qualifications necessary for the adequate operation and maintenance of each vessel that will serve as security for the guarantee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2edd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operators of Liner Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may not guarantee or make a commitment to guarantee a loan for the construction, reconstruction, or reconditioning of a liner vessel under this chapter unless the Chairman of the Federal Maritime Commission certifies that the operator of the vessel has not been found by the Commission to have committed, within the previous 5 years—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dc2ede-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a violation of part A of subtitle IV of this title that involves unjust or unfair discriminatory treatment or undue or unreasonable prejudice or disadvantage with respect to a United States shipper, ocean transportation intermediary, ocean common carrier, or port; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2edf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a violation of part B of subtitle IV of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2ee0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53707/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operators of Fishing Vessels","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not guarantee or make a commitment to guarantee a loan for the construction, reconstruction, or reconditioning of a fishing vessel under this chapter if the operator of the vessel has been—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dc2ee1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53707/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held liable, or the vessel has been held liable in rem, for a civil penalty under section 308 of the Magnuson-Stevens Fishery Conservation and Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1858"},"text":"16 U.S.C. 1858","children":[],"tail":") and the operator has not paid the penalty;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ee2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53707/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" found guilty of an offense under section 309 of the Magnuson-Stevens Fishery Conservation and Management Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1859"},"text":"16 U.S.C. 1859","children":[],"tail":") and not paid the assessed fine or served the assessed sentence;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ee3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53707/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held liable for a civil or criminal penalty under section 105 of the Marine Mammal Protection Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1375"},"text":"16 U.S.C. 1375","children":[],"tail":") and not paid the assessed fine or served the assessed sentence; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ee4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53707/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" held liable for a civil penalty by the Coast Guard under this title or title 33 and not paid the assessed fine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6dc2ee5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53707/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waivers Concerning Financial Condition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or Administrator shall prescribe regulations concerning circumstances under which waivers of, or exceptions to, otherwise applicable regulatory requirements concerning financial condition can be made. The regulations shall require that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dc2ee6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53707/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic soundness requirements in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53708/a"},"text":"section 53708(a) of this title","children":[],"tail":" are met after the waiver of the financial condition requirement; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dc2ee7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53707/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary or Administrator considers necessary, the waiver shall provide for the imposition of other requirements on the obligor designed to compensate for any significant increase in risk associated with the obligor’s failure to meet regulatory requirements applicable to financial condition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6dc2ee8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1607"},"text":"120 Stat. 1607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/D"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(D)","children":[],"tail":", (b)(3)(B), (C), (c)(1), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":", 3556; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/3"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(3)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/597"},"text":"122 Stat. 597","children":[],"tail":", 598.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6dc2ee9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6dc2eea-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6dc2eeb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section",