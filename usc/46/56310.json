{"tag":"section","attrib":{"id":"idf6ef41e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56310"},"text":null,"children":[{"tag":"num","attrib":{"value":"56310"},"text":"§ 56310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary purchase or charter agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"During any period in which vessels may be requisitioned under this chapter as amended,","children":[{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" the President is authorized through the Secretary of Transportation to acquire by voluntary agreement of purchase or charter the ownership or use of any merchant vessel not owned by citizens of the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf6ef41ea-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dC/tXXXV/s3504/b"},"text":"Pub. L. 115–91, div. C, title XXXV, § 3504(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1912"},"text":"131 Stat. 1912","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ef41eb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6ef41ec-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf6ef41ed-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"chi