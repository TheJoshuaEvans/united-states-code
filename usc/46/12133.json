{"tag":"section","attrib":{"id":"idf6971005-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12133"},"text":null,"children":[{"tag":"num","attrib":{"value":"12133"},"text":"§ 12133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty to carry certificate on vessel and allow examination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6971006-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duty To Carry","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The certificate of documentation of a vessel shall be carried on the vessel unless the vessel is exempt by regulation from carrying the certificate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6971007-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The owner or individual in charge of a vessel required to carry its certificate of documentation shall make the certificate available for examination at the request of an officer enforcing the revenue laws or as otherwise required by law or regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6971008-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s12133/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person willfully violating subsection (b) shall be fined under title 18, imprisoned for not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6971009-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s5"},"text":"Pub. L. 109–304, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1505"},"text":"120 Stat. 1505","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf697100a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf697100b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf697100c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":