{"tag":"section","attrib":{"id":"idf6c46230-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322"},"text":null,"children":[{"tag":"num","attrib":{"value":"51322"},"text":"§ 51322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of cadets from sexual assault onboard vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6c46231-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Maritime Administrator, after consulting with the Commandant of the Coast Guard, shall establish—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c46232-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria, to which an owner or operator of a vessel engaged in commercial service shall adhere prior to carrying a cadet performing their Sea Year service from the United States Merchant Marine Academy, that addresses prevention of, and response to, sexual harassment, dating violence, domestic violence, sexual assault, and stalking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46233-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process for collecting pertinent information from such owners or operators and verifying their compliance with the criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46234-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c46235-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As part of training that shall be provided not less than semiannually to all midshipmen of the Academy, pursuant to section 51318, the Maritime Administrator shall develop and implement comprehensive in-person sexual assault risk-reduction and response training that, to the extent practicable, conforms to best practices in the sexual assault prevention and response field and includes appropriate scenario-based training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c46236-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development and consultation with experts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing the sexual assault risk-reduction and response training under subparagraph (A), the Maritime Administrator shall consult with and incorporate, as appropriate, the recommendations and views of experts in the sexual assault field.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c46237-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At a minimum, the criteria established under subsection (a) shall require the vessel owners or operators to have policies that address—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c46238-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communication between a cadet and an individual ashore who is trained in responding to incidents of sexual harassment, dating violence, domestic violence, sexual assault, and stalking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46239-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety and security of cadet staterooms while a cadet is onboard the vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c4623a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements for crew to report complaints or incidents of sexual assault, sexual harassment, dating violence, domestic violence, and stalking consistent with the requirements in section 10104;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c4623b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance of records of reports of sexual harassment, dating violence, domestic violence, sexual assault, and stalking onboard a vessel carrying a cadet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c4623c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance of records of sexual harassment, dating violence, domestic violence, sexual assault, and stalking training as required under subsection (f);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c4623d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement for the owner or operator provide each cadet a copy of the policies and procedures related to sexual harassment, dating violence, domestic violence, sexual assault, and stalking policies that pertain to the vessel on which they will be employed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c4623e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other issues the Maritime Administrator determines necessary to ensure the safety of cadets during Sea Year training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c4623f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Self-certification by Owners or Operators","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Maritime Administrator shall require the owner or operator of any commercial vessel that is carrying a cadet from the United States Merchant Marine Academy to annually certify that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c46240-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel owner or operator is in compliance with the criteria established under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46241-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vessel is in compliance with the International Convention of Safety of Life at Sea, 1974 (32 UST 47) and sections 8106 and 70103(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c46242-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information, Training, and Resources","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Maritime Administrator shall ensure that a cadet participating in Sea Year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c46243-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives training specific to vessel safety, including sexual harassment, dating violence, domestic violence, sexual assault, and stalking prevention and response training, prior to the cadet boarding a vessel for Sea Year training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46244-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is equipped with an appropriate means of communication and has been trained on its use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46245-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has access to a helpline to report incidents of sexual harassment, dating violence, domestic violence, sexual assault, or stalking that is monitored by trained personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46246-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is informed of the legal requirements for vessel owners and operators to provide for the security of individuals onboard, including requirements under section 70103(c) and chapter 81.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c46247-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Checks of Commercial Vessels.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c46248-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than biennially, staff of the Academy or staff of the Maritime Administration shall conduct both random and targeted unannounced checks of not less than 10 percent of the commercial vessels that host a cadet from the Academy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46249-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The vessel operator shall make available to staff conducting a vessel check such information as the Maritime Administrator determines is necessary to determine whether the vessel is being operated in compliance with the criteria established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c4624a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Removal of students","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If staff of the Academy or staff of the Maritime Administration determine that a commercial vessel is not in compliance with the criteria established under subsection (a), the staff—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c4624b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may remove a cadet of the Academy from the vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c4624c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall report such determination of non-compliance to the owner or operator of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c4624d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of Sexual Assault Training Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator shall require the owner or operator of a commercial vessel, and the seafarer union for a commercial vessel, to maintain records of sexual assault training for any person required to have such training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c4624e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sea Year Survey.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c4624f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator shall require each cadet from the Academy, upon completion of the cadet’s Sea Year, to complete a survey regarding the environment and conditions during the Sea Year of the vessel to which the cadet was assigned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46250-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Maritime Administrator shall make available to the public for each year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6c46251-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the questions used in the survey required by paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6c46252-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregated data received from such surveys.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c46253-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Noncommercial Vessels.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6c46254-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A public vessel (as defined in section 2101) shall not be subject to the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6c46255-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for participation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator may establish criteria and requirements that the operators of public vessels shall meet to participate in the Sea Year program of the United States Merchant Marine Academy that addresses prevention of, and response to, sexual harassment, dating violence, domestic violence, sexual assault, and stalking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6c46256-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s51322/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sharing of Best Practices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator shall share with State maritime academies best practices for, and lessons learned with respect to, the prevention of, and response to, sexual harassment, dating violence, domestic violence, sexual assault, and stalking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6c46257-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dC/tXXXV/s3516/a"},"text":"Pub. L. 115–91, div. C, title XXXV, § 3516(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1927"},"text":"131 Stat. 1927","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dC/tXXXV/s3515/b"},"text":"Pub. L. 115–232, div. C, title XXXV, § 3515(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2312"},"text":"132 Stat. 2312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV"},"text":"Pub. L. 117–263, div. C, title XXXV","children":[],"tail":", §§ 3513(a), 3531(g), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3066"},"text":"136 Stat. 3066","children":[],"tail":", 3088.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6c46258-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6c46259-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6c4625a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3513/a/1"},"text":"Pub. L. 117–263, § 3513(a)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which related to riding gangs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3531/g"},"text":"Pub. L. 117–263, § 3531(g)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3513/a/1"},"text":"Pub. L. 117–263, § 3513(a)(1)","children":[],"tail":", added subsecs. (b) to (d). Former subsecs. (b) to (d) redesignated (e) to (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3513/a/2"},"text":"Pub. L. 117–263, § 3513(a)(2)","children":[],"tail":", redesignated subsec. (b) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3513/a/3"},"text":"Pub. L. 117–263, § 3513(a)(3)","children":[],"tail":", added pars. (2) and (3) and struck out former par. (2), which related to removal of students."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3513/a/2"},"text":"Pub. L. 117–263, § 3513(a)(2)","children":[],"tail":", (4), redesignated subsec. (c) as (f) and substituted “and the seafarer union” for “or the seafarer union”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3513/a/2"},"text":"Pub. L. 117–263, § 3513(a)(2)","children":[],"tail":", redesignated subsec. (d) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h), (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s3513/a/5"},"text":"Pub. L. 117–263, § 3513(a)(5)","children":[],"tail":", added subsecs. (h) and (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, text read as follows: “The Maritime Administrator shall require the owner or operator of a commercial vessel, or the seafarer union for a commercial vessel, to maintain records of sexual assault training for the crew and passengers of any vessel hosting a cadet from the Academy.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6c4625b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf6c4625c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3513/b"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3513(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3068"},"text":"136 Stat. 3068","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dC/tXXXV/s3513/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator may prescribe rules necessary to carry out the amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s51319"},"text":"section 51319 of this title","children":[],"tail":" and repealing provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s51318"},"text":"section 51318 of this title","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interim rules","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Maritime Administrator may prescribe interim rules necessary to carry out the amendments made by this section. For this purpose, the Maritime Administrator in prescribing rules under paragraph (1) is excepted from compliance with the notice and comment requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", United States Code. All rules prescribed under the authority of the amendments made by this section shall remain in effect until superseded by a final rule.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
