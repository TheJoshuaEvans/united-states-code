{"tag":"section","attrib":{"id":"idf64ac47e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s301"},"text":null,"children":[{"tag":"num","attrib":{"value":"301"},"text":"§ 301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automatic execution of conforming changes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf64ac47f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When an amendment to a covered maritime law adds a section or larger organizational unit to the covered maritime law, repeals or transfers a section or larger organizational unit in the covered maritime law, or amends the designation or heading of a section or larger organizational unit in the covered maritime law, that amendment also shall have the effect of amending any analysis, table of contents, or similar tabular entries in the covered maritime law to alter the table to conform to the changes made by the amendment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf64d3580-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to an amendment described in such subsection when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf64d3581-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendment or a clerical amendment enacted at the same time expressly amends a table of sections, table of contents, or similar tabular entries in the covered maritime law to alter the table to conform to the changes made by the amendment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf64d3582-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendment otherwise expressly exempts itself from the operation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf64d3583-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Maritime Law Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “covered maritime law” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf64d3584-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s301/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf64d3585-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s301/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Maritime Administration authorization Act that authorizes funds to be appropriated for a fiscal year to the Maritime Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf64d3586-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s301/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other law designated in the text thereof as a covered maritime law for purposes of application of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf64d3587-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/dG/s7103/b"},"text":"Pub. L. 119–60, div. G, § 7103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1662"},"text":"139 Stat. 1662","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf64d3588-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf64d3589-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf64d358a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 301 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s46101"},"text":"section 46101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
