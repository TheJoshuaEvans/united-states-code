{"tag":"section","attrib":{"id":"idf6b60a02-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50107"},"text":null,"children":[{"tag":"num","attrib":{"value":"50107"},"text":"§ 50107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies on marine insurance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b60a03-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50107/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine into the subject of marine insurance, the number of companies in the United States, domestic and foreign, engaging in marine insurance, the extent of the insurance on hulls and cargoes placed or written in the United States, and the extent of reinsurance of American maritime risks in foreign companies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a04-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50107/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ascertain what steps may be necessary to develop an ample marine insurance system as an aid in the development of the merchant marine of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b60a05-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1559"},"text":"120 Stat. 1559","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b60a06-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","ch