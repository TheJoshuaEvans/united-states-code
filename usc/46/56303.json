{"tag":"section","attrib":{"id":"idf6ecf8ba-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56303"},"text":null,"children":[{"tag":"num","attrib":{"value":"56303"},"text":"§ 56303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ecf8bb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As soon as practicable, the Secretary of Transportation shall determine and pay just compensation for a vessel requisitioned under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf8bc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors Not Affecting Value","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The value of a vessel may not be considered enhanced by the circumstances requiring its requisition. Consequential damages arising from the requisition may not be paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf8bd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Construction-Differential Subsidy","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ecf8be-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"If paid","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a construction-differential subsidy has been paid for the vessel, the value of the vessel at the time of requisition shall be determined under section 802 of the Merchant Marine Act, 1936.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf8bf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"If not paid","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a construction-differential subsidy has not been paid for the vessel, the value of any national defense features previously paid for by the United States Government shall be excluded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf8c0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s56303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loss or Damage During Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a vessel is lost or damaged by a risk assumed by the Government under the charter, but a valuation for the vessel or a means of compensation has not been agreed to, the Secretary shall pay just compensation for the loss or damage, to the extent the person is not reimbursed through insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ecf8c1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1655"},"text":"120 Stat. 1655","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ecf8c2-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ecf8c3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ecf8c4-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attri