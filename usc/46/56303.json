ren":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 802 of the Merchant Marine Act, 1936, referred to in subsec. (c)(1), is section 802 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"act June 29, 1936, ch. 858","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1985"},"text":"49 Stat. 1985","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53101"},"text":"section 53101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
