{"tag":"section","attrib":{"id":"idf69bcafa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14104"},"text":null,"children":[{"tag":"num","attrib":{"value":"14104"},"text":"§ 14104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Measurement to determine application of a law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf69bcafb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the application of a law of the United States to a vessel depends on the vessel’s tonnage, the vessel shall be measured under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69bcafc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a statute allows for an alternate tonnage to be prescribed under this section, the Secretary may prescribe it by regulation. Any such regulation shall be considered to be an interpretive regulation for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":". Until an alternate tonnage is prescribed, the statutorily established tonnage shall apply to vessels measured under chapter 143 or chapter 145 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf69bcafd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s14104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each Federal agency shall ensure that regulations issued by the agency that specify particular tonnages comply with the alternate tonnages implemented by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf69bcafe-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tV/s5101/3"},"text":"Pub. L. 99–509, title V, § 5101(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1920"},"text":"100 Stat. 1920","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s702"},"text":"Pub. L. 104–324, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3933"},"text":"110 Stat. 3933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf69bcaff-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf69bcb00-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"Revised section 14104","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Source: Section (U.S. Code) 46 App. U.S.C. 71.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 14104 requires that a vessel be measured under Part J of this subtitle when the application of a U.S. law to the vessel depends on its tonnage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf69bcb01-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf69bcb02-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
