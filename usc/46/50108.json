{"tag":"section","attrib":{"id":"idf6b60a09-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50108"},"text":null,"children":[{"tag":"num","attrib":{"value":"50108"},"text":"§ 50108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies on cargo carriage and cargo containers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6b60a0a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Studies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall study—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6b60a0b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50108/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods of encouraging the development and implementation of new concepts for the carriage of cargo in the domestic and foreign commerce of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6b60a0c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50108/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic and technological aspects of the use of cargo containers as a method of carrying out the policy in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50101"},"text":"section 50101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6b60a0d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s50108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out subsection (a) and the policy in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50101"},"text":"section 50101 of this title","children":[],"tail":", the United States Government may not give preference as between carriers based on the length, height, or width of cargo containers or the length, height, or width of cargo container cells. This restriction applies to all existing container vessels and any container vessel to be constructed or rebuilt."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6b60a0e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/b"},"text":"Pub. L. 109–304, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1559"},"text":"120 Stat. 1559","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6b60a0f-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6b60a10-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6b60a11-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attri