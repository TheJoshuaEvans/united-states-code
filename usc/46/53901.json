.:1281(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title XII, § 1201(c), as added "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-07/ch906"},"text":"Sept. 7, 1950, ch. 906","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/773"},"text":"64 Stat. 773","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/pl/107/107/tXXXV/s3502"},"text":"Pub. L. 107–107, title XXXV, § 3502","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/115/1392"},"text":"115 Stat. 1392","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1)(A), the words “a documented vessel with a registry or coastwise endorsement under chapter 121 of this title” are substituted for “any vessel registered, enrolled, or licensed under the laws of the United States” because of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s12101/b"},"text":"46 U.S.C. 12101(b)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1)(B). the words “or any department or agency thereof” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1)(C), the word “fisheries” is substituted for “fishing trade or industry” because of the definition of “fisheries” in chapter 1 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
