{"tag":"section","attrib":{"id":"idf6e0ea71-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53901"},"text":null,"children":[{"tag":"num","attrib":{"value":"53901"},"text":"§ 53901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6e0ea72-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"American vessel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “American vessel” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e0ea73-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53901/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a documented vessel with a registry or coastwise endorsement under chapter 121 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e0ea74-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53901/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an undocumented vessel owned or chartered by or made available to the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e0ea75-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53901/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tug, barge, or other watercraft (whether or not documented) owned by a citizen of the United States and used in essential water transportation or in the fisheries, except only for sport fishing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea76-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cargo","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “cargo” includes a loaded or empty container on a vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea77-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation in the waterborne commerce of the united states","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “transportation in the waterborne commerce of the United States” includes the operation of a vessel in the fisheries, except only for sport fishing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6e0ea78-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"War risks","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “war risks” includes, to the extent the Secretary of Transportation determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6e0ea79-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53901/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any part of a loss excluded from marine insurance coverage under a “free of capture or seizure” clause or analogous clause; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6e0ea7a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53901/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other loss from a hostile act, including confiscation, expropriation, nationalization, or deprivation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6e0ea7b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1626"},"text":"120 Stat. 1626","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6e0ea7c-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6e0ea7d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6e0ea7e-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null