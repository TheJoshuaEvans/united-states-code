{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-03-09/ch95/s4"},"text":"Mar. 9, 1920, ch. 95, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/41/526"},"text":"41 Stat. 526","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “on a statement” are substituted for “upon the suggestion” as more appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
