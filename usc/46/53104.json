{"tag":"section","attrib":{"id":"idf6d047b0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104"},"text":null,"children":[{"tag":"num","attrib":{"value":"53104"},"text":"§ 53104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effectiveness of operating agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d047b1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effectiveness, Generally","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may enter into an operating agreement under this chapter for fiscal year 2006. Except as provided in subsection (b), the agreement shall be effective only for 1 fiscal year, but shall be renewable, subject to the availability of appropriations, for each subsequent fiscal year through the end of fiscal year 2040.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047b2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessels Under Charter to United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless an earlier date is requested by the applicant, the effective date for an operating agreement with respect to a vessel that is, on the date of entry into an operating agreement, on charter to the United States Government, other than a charter pursuant to an Emergency Preparedness Agreement under section 53107, shall be the expiration or termination date of the Government charter covering the vessel, or any earlier date the vessel is withdrawn from that charter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047b3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d047b4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination by secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the contractor with respect to an operating agreement materially fails to comply with the terms of the agreement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d047b5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall notify the contractor and provide a reasonable opportunity to comply with the operating agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047b6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall terminate the operating agreement if the contractor fails to achieve such compliance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d047b7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon such termination, any funds obligated by the agreement shall be available to the Secretary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047b8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Early termination by contractor, generally","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An operating agreement under this chapter shall terminate on a date specified by the contractor if the contractor notifies the Secretary, by not later than 60 days before the effective date of the termination, that the contractor intends to terminate the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047b9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonrenewal for Lack of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, by the first day of a fiscal year, sufficient funds have not been appropriated under the authority provided by this chapter for that fiscal year, then the Secretary shall notify the Committee on Armed Services and the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Armed Services of the House of Representatives that operating agreements authorized under this chapter for which sufficient funds are not available will not be renewed for that fiscal year if sufficient funds are not appropriated by the 60th day of that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d047ba-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Release of Vessels From Obligations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If funds are not appropriated for payments under an operating agreement under this chapter for any fiscal year by the 60th day of that fiscal year, then—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d047bb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each vessel covered by the operating agreement is thereby released from any further obligation under the operating agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047bc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner or operator of the vessel may transfer and register such vessel under a foreign registry that is acceptable to the Secretary of Transportation and the Secretary of Defense, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s56101"},"text":"section 56101 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d047bd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53104/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if chapter 563 of this title is applicable to such vessel after registration of the vessel under such a registry, then the vessel is available to be requisitioned by the Secretary of Transportation pursuant to chapter 563.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d047be-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dC/tXXXV/s3531/a"},"text":"Pub. L. 108–136, div. C, title XXXV, § 3531(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1810"},"text":"117 Stat. 1810","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/3"},"text":"Pub. L. 109–304, § 13(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1701"},"text":"120 Stat. 1701","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dC/tXXXV/s3502/1"},"text":"Pub. L. 111–383, div. C, title XXXV, § 3502(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-07"},"text":"Jan. 7, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/4518"},"text":"124 Stat. 4518","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dC/tXXXV/s3508/d"},"text":"Pub. L. 112–239, div. C, title XXXV, § 3508(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2224"},"text":"126 Stat. 2224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3502/b"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1969"},"text":"133 Stat. 1969","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dC/tXXXV/s3502/b"},"text":"Pub. L. 118–159, div. C, title XXXV, § 3502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2304"},"text":"138 Stat. 2304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d047bf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6d047c0-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6d047c1-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" substituted “2040” for “2035”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" substituted “2035” for “2025”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s3508/d/1"},"text":"Pub. L. 112–239, § 3508(d)(1)","children":[],"tail":", struck out par. (3) which related to early termination by contractor, with available replacement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s3508/d/2"},"text":"Pub. L. 112–239, § 3508(d)(2)","children":[],"tail":", struck out “an operating agreement under this chapter is terminated under subsection (c)(3), or if” after “If” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/383"},"text":"Pub. L. 111–383","children":[],"tail":" substituted “2025” for “2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/3/A"},"text":"Pub. L. 109–304, § 13(a)(3)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t46/s50501"},"text":"section 50501 of this title","children":[],"tail":"” for “section 2 of the Shipping Act, 1916 (46 U.S.C. App. 802)” in subcls. (I) and (II)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/3/B"},"text":"Pub. L. 109–304, § 13(a)(3)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t46/s56101"},"text":"section 56101 of this title","children":[],"tail":"” for “section 9 of the Shipping Act, 1916 (46 U.S.C. App. 808)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s13/a/3/C"},"text":"Pub. L. 109–304, § 13(a)(3)(C)","children":[],"tail":", substituted “chapter 563 of this title” and “chapter 563” for “section 902 of the Merchant Marine Act, 1936 (46 U.S.C. App. 1242)” and “section 902 of such Act”, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
