{"tag":"section","attrib":{"id":"idf68fe41c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11103"},"text":null,"children":[{"tag":"num","attrib":{"value":"11103"},"text":"§ 11103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Slop chests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68fe41d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A vessel to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s11102"},"text":"section 11102 of this title","children":[],"tail":" applies shall be provided with a slop chest containing sufficient clothing for the intended voyage for each seaman, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68fe41e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" boots or shoes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe41f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hats or caps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe420-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" underclothing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe421-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outer clothing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe422-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11103/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foul weather clothing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe423-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11103/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" everything necessary for the wear of a seaman; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68fe424-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11103/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete supply of tobacco and blankets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe425-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Merchandise in the slop chest shall be sold to a seaman desiring it, for the use of the seaman, at a profit of not more than 10 percent of the reasonable wholesale value of the merchandise at the port at which the voyage began.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68fe426-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s11103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to a vessel on a voyage to Canada, Bermuda, the West Indies, Mexico, or Central America, or a fishing or whaling vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68fe427-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/578"},"text":"97 Stat. 578","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68fe428-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68fe429-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68fe42a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"11103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:670","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"46:671","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 11103 requires that a United States vessel on a foreign or intercoastal domestic voyage be equipped with a slop chest and lists the items the slop chest must contain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
