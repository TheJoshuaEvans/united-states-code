{"tag":"section","attrib":{"id":"idf6d7746a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53505"},"text":null,"children":[{"tag":"num","attrib":{"value":"53505"},"text":"§ 53505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ceiling on deposits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d7746b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Deposits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount deposited in a capital construction fund for a taxable year may not exceed the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d7746c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that portion of the taxable income of the owner or lessee for the taxable year (computed under chapter 1 of the Internal Revenue Code of 1986 (26 U.S.C. ch. 1) but without regard to the carryback of net operating loss or net capital loss or this chapter) that is attributable to the operation of agreement vessels in the foreign or domestic trade of the United States or in the fisheries of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d7746d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount allowable as a deduction under section 167 of such Code (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s167"},"text":"26 U.S.C. 167","children":[],"tail":") for the taxable year for agreement vessels;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d7746e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53505/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the transaction is not taken into account for purposes of paragraph (1), the net proceeds (as defined in joint regulations) from the disposition of an agreement vessel or from insurance or indemnity attributable to an agreement vessel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d7746f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53505/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipts from the investment or reinvestment of amounts held in the fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d77470-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reductions for Lessees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a lessee, the maximum amount that may be deposited for an agreement vessel under subsection (a)(2) for any period shall be reduced by any amount the owner is required or permitted, under the capital construction fund agreement, to deposit for that period for the vessel under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d77471-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1593"},"text":"120 Stat. 1593","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d77472-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6d77473-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6d77474-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"