{"tag":"section","attrib":{"id":"idf6ea87a1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55334"},"text":null,"children":[{"tag":"num","attrib":{"value":"55334"},"text":"§ 55334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ea87a2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), an American Great Lakes vessel may not be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ea87a3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55334/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" engage in trade—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ea87a4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55334/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from a port in the United States that is not located on the Great Lakes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ea87a5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55334/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between ports in the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea87a6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55334/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transport bulk cargo (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s40102"},"text":"section 40102 of this title","children":[],"tail":") that is subject to section 55305 or 55314 of this title or "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2631"},"text":"section 2631 of title 10","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ea87a7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55334/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide a service (except ocean freight service) as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6ea87a8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55334/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract carrier; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6ea87a9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55334/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a common carrier on a fixed advertised schedule offering frequent sailings at regular intervals in the foreign trade of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ea87aa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Off-Season Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An American Great Lakes vessel may be used for not more than 90 days during any 12-month period to engage in trade prohibited by subsection (a)(1)(A), except during the Great Lakes shipping season.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ea87ab-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1649"},"text":"120 Stat. 1649","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ea87ac-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6ea87ad-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6ea87ae-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":