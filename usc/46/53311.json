{"tag":"section","attrib":{"id":"idf6d50333-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53311"},"text":null,"children":[{"tag":"num","attrib":{"value":"53311"},"text":"§ 53311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxation of deposits on failure of conditions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A deposited gain, if otherwise taxable income under the law applicable to the taxable year in which the gain was realized, shall be included in gross income for that taxable year, except for purposes of the declared value excess profits tax and the capital stock tax, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d50334-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53311/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deposited gain is not expended or obligated within the appropriate period under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53310"},"text":"section 53310 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d50335-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53311/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deposited gain is withdrawn before the end of that period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d50336-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53311/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction related to that deposited gain has not progressed to the extent of 5 percent of completion within the appropriate period under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s53310"},"text":"section 53310 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d50337-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53311/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation finds and certifies to the Secretary of the Treasury that, for causes within the control of the taxpayer, the entire construction related to that deposited gain is not completed with reasonable dispatch.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d50338-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1590"},"text":"120 Stat. 1590","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6d50339-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6d5033a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6d5033b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"53311","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1161(i).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title V, § 511(i), as added "},{"tag":"html:a","attrib":{"href":"/us/act/1940-10-10/ch849"},"text":"Oct. 10, 1940, ch. 849","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/54/1107"},"text":"54 Stat. 1107","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-17/ch939/s13/b"},"text":"July 17, 1952, ch. 939, § 13(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/764"},"text":"66 Stat. 764","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/92/A"},"text":"Pub. L. 97–31, § 12(92)(A)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/161"},"text":"95 Stat. 161","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last sentence of 46 App. U.S.C. 1161(i) is omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
