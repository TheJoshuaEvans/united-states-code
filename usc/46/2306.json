{"tag":"section","attrib":{"id":"idf6591c98-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306"},"text":null,"children":[{"tag":"num","attrib":{"value":"2306"},"text":"§ 2306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vessel reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6591c99-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6591c9a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An owner, charterer, managing operator, or agent of a vessel of the United States, having reason to believe (because of lack of communication with or nonappearance of a vessel or any other incident) that the vessel may have been lost or imperiled, immediately shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6591c9b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6591c9c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use all available means to determine the status of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6591c9d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When more than 48 hours have passed since the owner, charterer, managing operator, or agent of a vessel required to report to the United States Flag Merchant Vessel Location Filing System under authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50113"},"text":"section 50113 of this title","children":[],"tail":" has received a communication from the vessel, the owner, charterer, managing operator, or agent immediately shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6591c9e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6591c9f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use all available means to determine the status of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6591ca0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An owner, charterer, managing operator, or agent of a vessel of the United States notifying the Coast Guard under paragraph (1) or (2) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6591ca1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the name and identification number of the vessel, the names of individuals on board, and other information that may be requested by the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6591ca2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit written confirmation to the Coast Guard within 24 hours after nonwritten notification to the Coast Guard under such paragraphs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6591ca3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An owner, charterer, managing operator, or agent violating this subsection is liable to the United States Government for a civil penalty of not more than $5,000 for each day during which the violation occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6591ca4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6591ca5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The master of a vessel of the United States required to report to the System shall report to the owner, charterer, managing operator, or agent at least once every 48 hours.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6591ca6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A master violating this subsection is liable to the Government for a civil penalty of not more than $1,000 for each day during which the violation occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6591ca7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s2306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6591ca8-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498/tII/s212/a/3"},"text":"Pub. L. 98–498, title II, § 212(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2305"},"text":"98 Stat. 2305","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s15/9"},"text":"Pub. L. 109–304, § 15(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1703"},"text":"120 Stat. 1703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8505(b)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4751"},"text":"134 Stat. 4751","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6591ca9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6591caa-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6591cab-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" amended par. (3) generally. Prior to amendment, par. (3) read as follows: “A person notifying the Coast Guard under paragraph (1) or (2) of this subsection shall provide the name and identification number of the vessel, the names of individuals on board, and other information that may be requested by the Coast Guard. The owner, charterer, managing operator, or agent also shall submit written confirmation to the Coast Guard within 24 hours after nonwritten notification to the Coast Guard under those paragraphs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t46/s50113"},"text":"section 50113 of this title","children":[],"tail":"” for “section 212(A) of the Merchant Marine Act, 1936 (46 App. U.S.C. 1122a),”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf6591cac-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf6591cad-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/498/tII/s214"},"text":"Pub. L. 98–498, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2306"},"text":"98 Stat. 2306","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/498/tII/s214"},"text":"“Sections 211(a) and 212 of this subtitle [enacting this section and amending sections 2302, 3309, 6101, and 6103 of this title] are effective one hundred and eighty days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf6591cae-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
