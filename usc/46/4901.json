{"tag":"section","attrib":{"id":"idf6735bf2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901"},"text":null,"children":[{"tag":"num","attrib":{"value":"4901"},"text":"§ 4901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surveillance requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6735bf3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vessel engaged in commercial service that does not carry passengers, shall maintain a video surveillance system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735bf4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements in this section shall apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735bf5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" documented vessels with overnight accommodations for at least 10 individuals on board that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6735bf6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a voyage of at least 600 miles and crosses seaward of the Boundary Line; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735bf7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 24 meters (79 feet) in overall length and required to have a load line under chapter 51;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735bf8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documented vessels of at least 500 gross tons as measured under section 14502, or an alternate tonnage measured under section 14302 as prescribed by the Secretary under section 14104 on an international voyage; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735bf9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vessels with overnight accommodations for at least 10 individuals on board that are operating for no less than 72 hours on waters superjacent to the outer Continental Shelf (as defined in section 2(a) of the Outer Continental Shelf Lands Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1331/a"},"text":"43 U.S.C. 1331(a)","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002007"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002007"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Another closing parenthesis probably should precede the period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735bfa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Placement of Video and Audio Surveillance Equipment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735bfb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The owner of a vessel to which this section applies shall install video and audio surveillance equipment aboard the vessel not later than 2 years after enactment of the Don Young Coast Guard Authorization Act of 2022, or during the next scheduled drydock, whichever is later.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735bfc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Locations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Video and audio surveillance equipment shall be placed in passageways on to which doors from staterooms open. Such equipment shall be placed in a manner ensuring the visibility of every door in each such passageway.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735bfd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of Video and Audio Surveillance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The owner of a vessel to which this section applies shall provide clear and conspicuous signs on board the vessel notifying the crew of the presence of video and audio surveillance equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735bfe-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to Video and Audio Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The owner of a vessel to which this section applies shall ensure that access to records of video and audio surveillance is not used as part of a labor action against a crew member or employment dispute unless used in a criminal or civil action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735bff-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retention Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The owner of a vessel to which this section applies shall retain all records of audio and video surveillance for not less than 1 year after the footage is obtained. Any video and audio surveillance found to be associated with an alleged incident should be preserved for not less than 5 years from the date of the alleged incident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735c00-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personnel Training","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A vessel owner or employer of a seafarer shall provide training for all individuals employed by the owner or employer for the purpose of responding to incidents of sexual assault or sexual harassment, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6735c01-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such training to ensure the individuals—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6735c02-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain audio and visual records and other evidence objectively; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6735c03-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act impartially without influence from the company or others; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6735c04-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training on applicable Federal, State, Tribal, and local laws and regulations regarding sexual assault and sexual harassment investigations and reporting requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735c05-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Owner","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “owner” means the owner, charterer, managing operator, master, or other individual in charge of a vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6735c06-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s4901/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Fishing vessels, fish processing vessels, and fish tender vessels are exempt from this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6735c07-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dK/tCXVI/s11607/a"},"text":"Pub. L. 117–263, div. K, title CXVI, § 11607(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4150"},"text":"136 Stat. 4150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6735c08-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6735c09-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6735c0a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of the Don Young Coast Guard Authorization Act of 2022, referred to in subsec. (c)(1), means enactment of div. K of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
