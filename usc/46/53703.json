{"tag":"section","attrib":{"id":"idf6d9e579-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703"},"text":null,"children":[{"tag":"num","attrib":{"value":"53703"},"text":"§ 53703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application and administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6d9e57a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for Decision","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d9e57b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator shall approve or deny an application for a loan guarantee under this chapter within 270 days after the date on which the signed application is received by the Secretary or Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d9e57c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On request by an applicant, the Secretary or Administrator may extend the 270-day period in paragraph (1) to a date not later than 2 years after the date on which the signed application was received by the Secretary or Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d9e57d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification of Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator may not guarantee or make a commitment to guarantee an obligation under this chapter unless the Secretary or Administrator certifies that a full and fair consideration of all the regulatory requirements, including economic soundness and financial requirements applicable to the obligor and related parties, and a thorough assessment of the technical, economic, and financial aspects of the loan application, has been made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d9e57e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independent Analysis.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d9e57f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To assess and mitigate the risks due to factors associated with markets, technology, financial, or legal structures related to an application or guarantee under this chapter, the Secretary or Administrator may utilize third party experts, including legal counsel, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d9e580-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" process and review applications under this chapter, including conducting independent analysis and review of aspects of an application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d9e581-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the Secretary or Administrator in structuring and documenting the obligation guarantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d9e582-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze and review aspects of, structure, and document the obligation guarantee during the term of the guarantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d9e583-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommend financial covenants or financial ratios to be met by the applicant during the time a guarantee under this chapter is outstanding that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf6d9e584-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on the financial covenants or financial ratios, if any, that are then applicable to the obligor under private sector credit agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf6d9e585-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in lieu of other financial covenants applicable to the obligor under this chapter with respect to requirements regarding long-term debt-to-equity, minimum working capital, or minimum amount of equity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d9e586-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the Secretary or Administrator to protect the security interests of the Government relating to an obligation guarantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d9e587-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Private sector expert","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Independent analysis, review, and representation conducted under this subsection shall be performed by a private sector expert in the applicable field who is selected by the Secretary or Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6d9e588-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessels of National Interest.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6d9e589-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator may post a notice in the Federal Register regarding the availability of funding for obligation guarantees under this chapter for the construction, reconstruction, or reconditioning of a Vessel of National Interest and include a timeline for the submission of applications for such vessels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6d9e58a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel characteristics.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6d9e58b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Administrator, in consultation with the Secretary of Defense, the Secretary of the Department in which the Coast Guard is operating when it is not operating as service in the Department of the Navy, or the heads of other Federal agencies, shall develop and publish a list of vessel types that would be considered Vessels of National Interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6d9e58c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53703/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Such list shall be reviewed and revised every four years or as necessary, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6d9e58d-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1604"},"text":"120 Stat. 1604","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/a/1/D"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(a)(1)(D)","children":[],"tail":", (2)(G), (b)(7), "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3555"},"text":"119 Stat. 3555","children":[],"tail":", 3556; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/10/B"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(10)(B)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/598"},"text":"122 Stat. 598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dC/tXXXV/s3506/c"},"text":"Pub. L. 116–92, div. C, title XXXV, § 3506(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/u