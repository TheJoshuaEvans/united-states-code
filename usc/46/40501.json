{"tag":"section","attrib":{"id":"idf6aedd3d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501"},"text":null,"children":[{"tag":"num","attrib":{"value":"40501"},"text":"§ 40501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rate and tariff requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6aedd3e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Automated Tariff System","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aedd3f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each common carrier and conference shall keep open to public inspection in an automated tariff system, tariffs showing all its rates, charges, classifications, rules, and practices between all points or ports on its own route and on any through transportation route that has been established. However, a common carrier is not required to state separately or otherwise reveal in tariffs the inland divisions of a through rate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd40-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) does not apply with respect to bulk cargo, forest products, recycled metal scrap, new assembled motor vehicles, waste paper, or paper waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd41-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Tariffs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A tariff under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aedd42-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the places between which cargo will be carried;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd43-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" list each classification of cargo in use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd44-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state the level of compensation, if any, of any ocean freight forwarder by a carrier or conference;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd45-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state separately each terminal or other charge, privilege, or facility under the control of the carrier or conference and any rules that in any way change, affect, or determine any part or the total of the rates or charges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd46-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include sample copies of any bill of lading, contract of affreightment, or other document evidencing the transportation agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd47-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include copies of any loyalty contract, omitting the shipper’s name.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd48-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic Access","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A tariff under subsection (a) shall be made available electronically to any person, without time, quantity, or other limitation, through appropriate access from remote locations. A reasonable fee may be charged for such access, except that no fee may be charged for access by a Federal agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd49-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time-Volume Rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A rate contained in a tariff under subsection (a) may vary with the volume of cargo offered over a specified period of time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd4a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Dates","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aedd4b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Increases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A new or initial rate or change in an existing rate that results in an increased cost to a shipper may not become effective earlier than 30 days after publication. However, for good cause, the Federal Maritime Commission may allow the rate to become effective sooner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd4c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Decreases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A change in an existing rate that results in a decreased cost to a shipper may become effective on publication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd4d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Marine Terminal Operator Schedules","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A marine terminal operator may make available to the public a schedule of rates, regulations, and practices, including limitations of liability for cargo loss or damage, pertaining to receiving, delivering, handling, or storing property at its marine terminal. Any such schedule made available to the public is enforceable by an appropriate court as an implied contract without proof of actual knowledge of its provisions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6aedd4e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6aedd4f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall by regulation prescribe the requirements for the accessibility and accuracy of automated tariff systems established under this section. The Commission, after periodic review, may prohibit the use of any automated tariff system that fails to meet the requirements established under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd50-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remote terminals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may not require a common carrier to provide a remote terminal for electronic access under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6aedd51-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s40501/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Marine terminal operator schedules","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall by regulation prescribe the form and manner in which marine terminal operator schedules authorized by this section shall be published.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6aedd52-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s7"},"text":"Pub. L. 109–304, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1532"},"text":"120 Stat. 1532","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6aedd53-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6aedd54-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6aedd55-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40501(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1707(a)(1) (1st, 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/98/237/s8/a"},"text":"Pub. L. 98–237, § 8(a)","children":[],"tail":", (b), (d), (f), (g), "},{"tag":"html:span","attrib":{},"text":"Mar. 20, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/74"},"text":"98 Stat. 74","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/105/258/tI/s106/a"},"text":"Pub. L. 105–258, title I, § 106(a)","children":[],"tail":", (c), (e), (f), "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/1905"},"text":"112 Stat. 1905","children":[],"tail":", 1907."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40501(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1707(a)(1) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40501(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1707(a)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40501(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1707(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40501(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1707(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40501(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1707(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40501(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1707(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the words “ocean freight forwarder” are substituted for “ocean transportation intermediary, as defined in section 1702(17)(A) of this Appendix” because the definition of “ocean transportation intermediary” in section 1702(17)(A) contains a definition of “ocean freight forwarder” which is restated as a separate definition.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the word “calendar” is omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(1), the words “subject to section 1709(d) of this Appendix” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
