{"tag":"section","attrib":{"id":"idf68b2903-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10303"},"text":null,"children":[{"tag":"num","attrib":{"value":"10303"},"text":"§ 10303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68b2904-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A seaman shall be served at least 3 meals a day that total at least 3,100 calories, including adequate water and adequate protein, vitamins, and minerals in accordance with the United States Recommended Daily Allowances.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68b2905-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The text of subsection (a) of this section shall be included in the agreement required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s10302"},"text":"section 10302 of this title","children":[],"tail":". A copy of the text also shall be posted in a conspicuous place in the galley and forecastle of each vessel."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68b2906-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to a fishing or whaling vessel or a yacht.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68b2907-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/562"},"text":"97 Stat. 562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68b2908-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf68b2909-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf68b290a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"10303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:713","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10303 requires that seamen be served adequate food and water and that the text of this requirement be posted in the galley. The provisions do not apply to fishing vessels, whaling vessels, or yachts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
