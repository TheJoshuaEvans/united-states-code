:{},"text":"Section 10301 specifies that vessels on foreign and intercoastal voyages (except for fishing vessels and foreign vessels) are subject to the seamen protection and relief provisions contained in chapter 103.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf68b28ee-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf68b28ef-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" inserted “or to riding gang members” after “voyage”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “75 gross tons”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
