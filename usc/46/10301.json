{"tag":"section","attrib":{"id":"idf68b28e4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10301"},"text":null,"children":[{"tag":"num","attrib":{"value":"10301"},"text":"§ 10301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf68b28e5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as otherwise specifically provided, this chapter applies to a vessel of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf68b28e6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a voyage between a port in the United States and a port in a foreign country (except a port in Canada, Mexico, or the West Indies); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf68b28e7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of at least 75 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":" on a voyage between a port of the United States on the Atlantic Ocean and a port of the United States on the Pacific Ocean."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68b28e8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter does not apply to a vessel on which the seamen are entitled by custom or agreement to share in the profit or result of a voyage or to riding gang members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf68b28e9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s10301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless otherwise provided, this chapter does not apply to a foreign vessel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf68b28ea-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/561"},"text":"97 Stat. 561","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s737"},"text":"Pub. L. 104–324, title VII, § 737","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3941"},"text":"110 Stat. 3941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIII/s312/c/2"},"text":"Pub. L. 109–241, title III, § 312(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/533"},"text":"120 Stat. 533","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf68b28eb-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","chil