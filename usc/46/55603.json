{"tag":"section","attrib":{"id":"idf6ecf823-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55603"},"text":null,"children":[{"tag":"num","attrib":{"value":"55603"},"text":"§ 55603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multistate, State, Tribal, and regional transportation planning","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6ecf824-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in consultation with Federal entities, State and local governments, Tribal governments, and appropriate private sector entities, may develop strategies to encourage the use of marine highway transportation for transportation of passengers and cargo.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6ecf825-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Strategies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary develops strategies under subsection (a), the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6ecf826-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the extent to which States, local governments, and Tribal governments include marine highway transportation and other marine transportation solutions in transportation planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf827-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage State and Tribal departments of transportation to develop strategies, where appropriate, to incorporate marine highway transportation, ferries, and other marine transportation solutions for regional and interstate transport of freight and passengers in transportation planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6ecf828-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s55603/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage groups of States, Tribal governments, and multistate transportation entities to determine how marine highways can address congestion, bottlenecks, and other interstate transportation challenges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6ecf829-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dC/tXXXV/s3521/b/1"},"text":"Pub. L. 117–263, div. C, title XXXV, § 3521(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3078"},"text":"136 Stat. 3078","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6ecf82a-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6ecf82b-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf6ecf82c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 55603, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXI/s1121/a"},"text":"Pub. L. 110–140, title XI, § 1121(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1761"},"text":"121 Stat. 1761","children":[],"tail":", which related to an interagency board to identify and seek solutions to impediments hindering effective use of short sea transportation, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXIII"},"text":"Pub. L. 116–283, div. G, title LVXXXIII","children":[],"tail":" [LXXXIII], § 8332(d)(1), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4704"},"text":"134 Stat. 4704","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
