{"tag":"section","attrib":{"id":"idf6f3fca3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531"},"text":null,"children":[{"tag":"num","attrib":{"value":"57531"},"text":"§ 57531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction and charter of vessels for unsuccessful routes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6f3fca4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of Transportation finds that a trade route determined to be essential under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s50103"},"text":"section 50103 of this title","children":[],"tail":" cannot be successfully developed and maintained and the Secretary’s replacement program cannot be achieved under private operation of the trade route by a citizen of the United States with vessels documented under chapter 121 of this title, without further aid by the United States Government in addition to the financial aid authorized under title V of the Merchant Marine Act, 1936, the Secretary, without advertisement or competition, may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f3fca5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have constructed, in private shipyards or in navy yards, vessels of the types necessary for the trade route; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f3fca6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demise charter those new vessels to the operator of vessels of the United States established on the trade route.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f3fca7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of Charter Hire","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f3fca8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The annual charter hire under subsection (a) shall be at least 4 percent of the price (referred to in this section as the “foreign cost”) at which the vessel would be sold if constructed under title V of the Merchant Marine Act, 1936, plus—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6f3fca9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a percentage of the depreciated foreign cost computed annually determined by the Secretary of the Treasury, taking into consideration the current average market yield on outstanding marketable obligations of the Government with remaining periods to maturity comparable to the term of the charter, adjusted to the nearest one-eighth percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f3fcaa-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an allowance adequate in the judgment of the Secretary of Transportation to cover administrative costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f3fcab-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Depreciation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Depreciation under paragraph (1)(A) shall be based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6f3fcac-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 25-year life for dry-cargo and passenger vessels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f3fcad-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 20-year life for tankers and other bulk liquid carrier vessels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f3fcae-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Option To Purchase","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The charter may contain an option to the charterer to purchase the vessels from the Secretary of Transportation within 5 years after delivery under the charter, on the same terms and conditions as provided in title V of the Merchant Marine Act, 1936, for the purchase of new vessels from the Secretary. However—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f3fcaf-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase price shall be the foreign cost less depreciation to the date of purchase based on the useful life specified in subsection (b)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f3fcb0-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the required cash payment payable at the time of the purchase shall be 25 percent of the purchase price;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f3fcb1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the charter may provide that any part of the charter hire paid in excess of the minimum charter hire provided for in this section may be credited against the cash payment payable at the time of the purchase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f3fcb2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the balance of the purchase price shall be paid within the remaining years of useful life (as specified in subsection (b)(2)) after the date of delivery of the vessel under the charter and in approximately equal annual installments, except that the first installment, which shall be payable on the next ensuing anniversary date of the delivery under the charter, shall be a proportionate part of the annual installment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f3fcb3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" interest shall be payable on the unpaid balances from the date of purchase, at a rate not less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6f3fcb4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rate determined by the Secretary of the Treasury, taking into consideration the current average market yield on outstanding marketable obligations of the Government with remaining periods to maturity comparable to the average maturities of the loans, adjusted to the nearest one-eighth percent; plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f3fcb5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an allowance adequate in the judgment of the Secretary of Transportation to cover administrative costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6f3fcb6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation of Vessel","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6f3fcb7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permissible voyages","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The charter shall provide for operation of the vessel exclusively—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf6f3fcb8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in foreign trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f3fcb9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a round-the-world voyage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f3fcba-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a round voyage from the west coast of the United States to a European port that includes an intercoastal port of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f3fcbb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a round voyage from the Atlantic coast of the United States to the Orient that includes an intercoastal port of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf6f3fcbc-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a voyage in foreign trade on which the vessel may stop at Hawaii or an island territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6f3fcbd-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s57531/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Domestic trade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The charter shall provide if the vessel is operated in domestic trade on any of the services specified in paragraph (1), the charterer will pay annually to the Secretary of Transportation that proportion of ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"25","children":[],"tail":" of the difference between the domestic and foreign cost of the vessel as the gross revenue derived from the domestic trade bears to the gross revenue derived from the entire voyages completed during the preceding year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6f3fcbe-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1668"},"text":"120 Stat. 1668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/120/tIII/s313/b/2"},"text":"Pub. L. 114–120, title III, § 313(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-08"},"text":"Feb. 8, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/58"},"text":"130 Stat. 58","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6f3fcbf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6f3fcc0-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6f3fcc1-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"57531","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:1204.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"June 29, 1936, ch. 858","children":[],"tail":", title VII, § 714, "},{"tag":"html:a","attrib":{"href":"/us/stat/49/2011"},"text":"49 Stat. 2011","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1938-06-23/ch600/s32"},"text":"June 23, 1938, ch. 600, § 32","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/52/962"},"text":"52 Stat. 962","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1939-08-04/ch417/s12"},"text":"Aug. 4, 1939, ch. 417, § 12","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/1186"},"text":"53 Stat. 1186","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/86/3/s18/b/3"},"text":"Pub. L. 86–3, § 18(b)(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Mar. 18, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/12"},"text":"73 Stat. 12","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/86/518/s5"},"text":"Pub. L. 86–518, § 5","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"June 12, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/216"},"text":"74 Stat. 216","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/91/469/s22"},"text":"Pub. L. 91–469, § 22","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1032"},"text":"84 Stat. 1032","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/97/31/s12/116"},"text":"Pub. L. 97–31, § 12(116)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/164"},"text":"95 Stat. 164","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “demise charter” are substituted for “demise . . . or bare-boat charter” to eliminate unnecessary words. The words “operator of vessels of the United States” are substituted for “American-flag operator” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(2) is substituted for “Upon the basis of a twenty-five year life of the vessel” because of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/518/s9"},"text":"section 9 of Public Law 86–518","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"1960-06-12"},"text":"June 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/217"},"text":"74 Stat. 217","children":[],"tail":"), which provided that “Nothing in any amendment made by this Act [including section 5 substituting ‘twenty-five’ for ‘twenty’ in 46 App. U.S.C. 1204] shall operate or be interpreted to change from twenty to twenty-five years the provisions of the Merchant Marine Act, 1936, as amended, relating to the commercial expectancy or period of depreciation of any tanker or other liquid bulk carrier.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), in paragraphs (1) and (4), references to the useful life specified in subsection (b)(2) are substituted for references to the twenty-five year useful life for the reason stated in explaining subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf6f3fcc2-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf6f3fcc3-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Merchant Marine Act, 1936, referred to in subsecs. (a), (b)(1), (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-29/ch858"},"text":"act June 29, 1936, ch. 858","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1985"},"text":"49 Stat. 1985","children":[],"tail":". Title V of the Act enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s53101"},"text":"section 53101 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1936 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf6f3fcc4-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/120"},"text":"Pub. L. 114–120","children":[],"tail":" substituted “title V” for “titles V and VI” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
