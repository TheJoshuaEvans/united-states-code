{"tag":"section","attrib":{"id":"idf6781665-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101"},"text":null,"children":[{"tag":"num","attrib":{"value":"7101"},"text":"§ 7101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuing and classifying licenses and certificates of registry","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6781666-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Licenses and certificates of registry are established for individuals who are required to hold licenses or certificates under this subtitle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6781667-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed by the Secretary, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6781668-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues the licenses and certificates of registry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6781669-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may classify the licenses and certificates of registry as provided in subsections (c) and (f) of this section, based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf678166a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tonnage, means of propulsion, and horsepower of machine-propelled vessels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf678166b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waters on which vessels are to be operated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf678166c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other reasonable standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf678166d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may issue licenses in the following classes to applicants found qualified as to age, character, habits of life, experience, professional qualifications, and physical fitness:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf678166e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" masters, mates, and engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf678166f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pilots.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6781670-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6781671-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" radio officers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6781672-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In classifying individuals under subsection (c)(1) of this section, the Secretary shall establish, when possible, suitable career patterns and service and other qualifying requirements appropriate to the particular service or industry in which the individuals are engaged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6781673-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual may be issued a license under subsection (c)(2) of this section only if the applicant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6781674-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least 21 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6781675-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of sound health and has no physical limitations that would hinder or prevent the performance of a pilot’s duties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6781676-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a thorough physical examination each year while holding the license, except that this requirement does not apply to an individual who will serve as a pilot only on a vessel of less than 1,600 gross tons as measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6781677-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates, to the satisfaction of the Secretary, that the applicant has the requisite general knowledge and skill to hold the license;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6781678-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates proficiency in the use of electronic aids to navigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6781679-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintains adequate knowledge of the waters to be navigated and knowledge of regulations for the prevention of collisions in those waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf678167a-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has sufficient experience, as decided by the Secretary, to evidence ability to handle any vessel of the type and size which the applicant may be authorized to pilot; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf678167b-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets any other requirement the Secretary considers reasonable and necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf678167c-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may issue certificates of registry in the following classes to applicants found qualified as to character, knowledge, skill, and experience:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf678167d-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf678167e-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical doctors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf678167f-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional nurses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6781680-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not issue a license or certificate of registry under this section unless an individual applying for the license or certificate makes available to the Secretary, under section 206(b)(7) of the National Driver Register Act of 1982 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s401"},"text":"23 U.S.C. 401","children":[],"tail":" note), any information contained in the National Driver Register related to an offense described in section 205(a)(3)(A) or (B) of that Act committed by the individual."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6781681-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may review the criminal record of an individual who applies for a license or certificate of registry under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6781682-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall require the testing of an individual who applies for issuance or renewal of a license or certificate of registry under this chapter for use of a dangerous drug in violation of law or Federal regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6781683-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may issue a license under this section in a class under subsection (c) to an applicant that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6781684-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at least 3 months of qualifying service on vessels of the uniformed services (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a"},"text":"section 101(a) of title 10","children":[],"tail":") of appropriate tonnage or horsepower within the 7-year period immediately preceding the date of application; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6781685-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s7101/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies all other requirements for such a license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6781686-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/89"},"text":"Pub. L. 98–89","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-26"},"text":"Aug. 26, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/539"},"text":"97 Stat. 539","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/557/s29/a"},"text":"Pub. L. 98–557, § 29(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2873"},"text":"98 Stat. 2873","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/tIV/s4101/a"},"text":"Pub. L. 101–380, title IV, § 4101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/509"},"text":"104 Stat. 509","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tVII/s720"},"text":"Pub. L. 104–324, title VII, § 720","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3938"},"text":"110 Stat. 3938","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/281/tIII/s305/a"},"text":"Pub. L. 113–281, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3043"},"text":"128 Stat. 3043","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6781687-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6781688-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6781689-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"2"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source section (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7101","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:214","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:224","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:226","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:228","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:229","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:229a","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:229b","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:242","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:243","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:244","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46:247","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7101(a) provides the authority for the establishment of licenses and certificates of registry for officers and individuals operating vessels who are required to hold them under Subtitle II.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) authorizes the Secretary to issue licenses and certificates of registry based on tonnage, means of propulsion, horsepower, vessel operating area, and other reasonable standards.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) authorizes the Secretary to issue licenses to masters, mates, engineers, pilots, operators, and radio officers when found qualified as to age, character, habits of life, experience, professional qualifications, and physical fitness. These qualifying standards must by necessity be reasonable and related to the rigors of the profession.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) requires the Secretary to establish, when possible, suitable career patterns and service for and other qualifying requirements appropriate to the particular service or industry for the individuals so engaged.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (e) sets forth the requirements that pilots must meet before being issued a license.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (f) authorizes the Secretary to issue certificates of registry to qualified individuals as pursers, medical doctors, and professional nurses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf678168a-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf678168b-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 205(a)(3)(A) or (B) and 206(b)(7) of the National Driver Register Act of 1982, referred to in subsec. (g), are sections 205(a)(3)(A), (B) and 206(b)(7) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/364"},"text":"Pub. L. 97–364","children":[],"tail":", which are set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s401"},"text":"section 401 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf678168c-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/281"},"text":"Pub. L. 113–281","children":[],"tail":" added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" inserted “as measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14502"},"text":"section 14502 of this title","children":[],"tail":", or an alternate tonnage measured under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14302"},"text":"section 14302 of this title","children":[],"tail":" as prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s14104"},"text":"section 14104 of this title","children":[],"tail":"” after “1,600 gross tons”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsecs. (g) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" added subsecs. (g) to (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/557"},"text":"Pub. L. 98–557","children":[],"tail":" inserted exemption for pilots on a vessel of less than 1,600 gross tons."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf678168d-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf678168e-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/380"},"text":"Pub. L. 101–380","children":[],"tail":" applicable to incidents occurring after "},{"tag":"date","attrib":{"date":"1990-08-18"},"text":"Aug. 18, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/380/s1020"},"text":"section 1020 of Pub. L. 101–380","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2701"},"text":"section 2701 of Title 33","children":[],"tail":", Navigation and Navigable Waters."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf678168f-2930-11f1-96a8-b9bd2a0a99b5"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Plan for Licensing Operators of Fishing Industry Vessels","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/424/s3"},"text":"Pub. L. 100–424, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1590"},"text":"102 Stat. 1590","children":[],"tail":", required the Secretary of the department in which the Coast Guard is operating, within two years after "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", to prepare and submit to the Congress a plan for the licensing of operators of documented fishing, fish processing, and fish tender vessels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
