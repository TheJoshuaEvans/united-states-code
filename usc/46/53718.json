{"tag":"section","attrib":{"id":"idf6dea0c1-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53718"},"text":null,"children":[{"tag":"num","attrib":{"value":"53718"},"text":"§ 53718.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator shall report to Congress annually on the loan guarantee program under this chapter. Each report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6dea0c2-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53718/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size, in dollars, of the portfolio of loans guaranteed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea0c3-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53718/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size, in dollars, of projects in the portfolio facing financial difficulties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea0c4-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53718/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and type of projects covered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea0c5-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53718/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a profile of pending loan applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea0c6-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53718/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of appropriations available for new guarantees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea0c7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53718/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a profile of each project approved since the last report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6dea0c8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s53718/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a profile of any defaults since the last report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6dea0c9-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s8/c"},"text":"Pub. L. 109–304, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1617"},"text":"120 Stat. 1617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dC/tXXXV/s3507/c/3"},"text":"Pub. L. 109–163, div. C, title XXXV, § 3507(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3556"},"text":"119 Stat. 3556","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dC/tXXXV/s3522/a/9/C"},"text":"Pub. L. 110–181, div. C, title XXXV, § 3522(a)(9)(C)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12