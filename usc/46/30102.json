{"tag":"section","attrib":{"id":"idf6a0add7-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30102"},"text":null,"children":[{"tag":"num","attrib":{"value":"30102"},"text":"§ 30102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability to passengers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf6a0add8-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The owner and master of a vessel, and the vessel, are liable for personal injury to a passenger or damage to a passenger’s baggage caused by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf6a0add9-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a neglect or failure to comply with part B or F of subtitle II of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf6a0adda-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a known defect in the steaming apparatus or hull of the vessel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf6a0addb-2930-11f1-96a8-b9bd2a0a99b5","identifier":"/us/usc/t46/s30102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Not Subject to Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A liability imposed under this section is not subject to limitation under chapter 305 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf6a0addc-2930-11f1-96a8-b9bd2a0a99b5"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304/s6/c"},"text":"Pub. L. 109–304, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1509"},"text":"120 Stat. 1509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf6a0addd-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idf6a0adde-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idf6a0addf-2930-11f1-96a8-b9bd2a0a99b5"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30102","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"46 App.:491 (words before semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 4493 (words before semicolon).","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before paragraph (1), the words “or either of them” are omitted as unnecessary. The words “are liable for personal injury to a passenger or damage to a passenger’s baggage” are substituted for “Whenever damage is sustained by any passenger or his baggage” and “shall be liable to each and every person so injured” for clarity and to eliminate unnecessary words. The words “from explosion, fire, collision, or other cause” are omitted as unnecessary. The words “caused by” are substituted for “if it happens through” to eliminate unnecessary words. In paragraph (1), the words “part B or F of subtitle II of this title” are substituted for “title 52 of the Revised Statutes” because of the prior codification of subtitle II of title 46. In paragraph (2), the word “imperfections” is omitted as included in “defect”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for “to the full amount of damage” for clarity. See ","children":[{"tag":"i","attrib":{},"text":"Hines v. Butler","children":[],"tail":", 278 F. 877, 880, 881 (4th Cir. 1921), cert. denied, 257 U.S. 659 (1922); "},{"tag":"i","attrib":{},"text":"The Annie Faxon","children":[],"tail":", 75 F. 312, 317–319 (9th Cir. 1896)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
