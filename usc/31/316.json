{"tag":"section","attrib":{"id":"idbcd8c1c1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316"},"text":null,"children":[{"tag":"num","attrib":{"value":"316"},"text":"§ 316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treasury Attaché Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcd8c1c2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established the Treasury Financial Attaché Program, under which the Secretary of the Treasury shall appoint employees of the Department of the Treasury as a Treasury Financial Attaché, who shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd8c1c3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further the work of the Department of the Treasury in developing and executing the financial and economic policy of the United States Government and the international fight against terrorism, money laundering, and other illicit finance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1c4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be co-located in a United States Embassy, a similar United States Government facility, or a foreign government facility, as the Secretary determines is appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1c5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain relationships with foreign counterparts, including employees of ministries of finance, central banks, international financial institutions, and other relevant official entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1c6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach to local and foreign financial institutions and other commercial actors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1c7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with representatives of the Department of Justice at United States Embassies who perform similar functions on behalf of the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1c8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other actions as the Secretary determines are appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd8c1c9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Number of Attachés.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd8c1ca-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The number of Treasury Financial Attachés appointed under this section at any one time shall be not fewer than 6 more employees than the number of employees of the Department of the Treasury serving as Treasury attachés on the date of enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1cb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional posts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury may establish additional posts subject to the availability of appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd8c1cc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd8c1cd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Treasury Financial Attaché appointed under this section and located at a United States Embassy shall receive compensation, including allowances, at the higher of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd8c1ce-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of compensation, including allowances, provided to a Foreign Service officer serving at the same embassy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd8c1cf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of compensation, including allowances, the Treasury Financial Attaché would otherwise have received, absent the application of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1d0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s316/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Phase in","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The compensation described in paragraph (1) shall be phased in over 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcd8c1d1-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dF/tLXI/s6106/a"},"text":"Pub. L. 116–283, div. F, title LXI, § 6106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4556"},"text":"134 Stat. 4556","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcd8c1d2-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcd8c1d3-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcd8c1d4-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (b)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
