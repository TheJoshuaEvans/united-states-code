{"tag":"section","attrib":{"id":"idbd715885-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335"},"text":null,"children":[{"tag":"num","attrib":{"value":"5335"},"text":"§ 5335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on concealment of the source of assets in monetary transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd715886-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Monetary Transaction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term the term “monetary transaction”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd715887-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the deposit, withdrawal, transfer, or exchange, in or affecting interstate or foreign commerce, of funds or a monetary instrument (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1956/c/5"},"text":"section 1956(c)(5) of title 18","children":[],"tail":") by, through, or to a financial institution (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1956/c/6"},"text":"section 1956(c)(6) of title 18","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd715888-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any transaction that would be a financial transaction under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1956/c/4/B"},"text":"section 1956(c)(4)(B) of title 18","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd715889-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any transaction necessary to preserve the right to representation of a person as guaranteed by the Sixth Amendment to the Constitution of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd71588a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person shall knowingly conceal, falsify, or misrepresent, or attempt to conceal, falsify, or misrepresent, from or to a financial institution, a material fact concerning the ownership or control of assets involved in a monetary transaction if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd71588b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person or entity who owns or controls the assets is a senior foreign political figure, or any immediate family member or close associate of a senior foreign political figure, as set forth in this title or the regulations promulgated under this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71588c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate value of the assets involved in 1 or more monetary transactions is not less than $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd71588d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Source of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person shall knowingly conceal, falsify, or misrepresent, or attempt to conceal, falsify, or misrepresent, from or to a financial institution, a material fact concerning the source of funds in a monetary transaction that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd71588e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves an entity found to be a primary money laundering concern under section 5318A or the regulations promulgated under this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71588f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violates the prohibitions or conditions prescribed under section 5318A(b)(5) or the regulations promulgated under this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd715890-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person convicted of an offense under subsection (b) or (c), or a conspiracy to commit an offense under subsection (b) or (c), shall be imprisoned for not more than 10 years, fined not more than $1,000,000, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd715891-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forfeiture.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd715892-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal forfeiture.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd715893-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court, in imposing a sentence under subsection (d), shall order that the defendant forfeit to the United States any property involved in the offense and any property traceable thereto.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd715894-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The seizure, restraint, and forfeiture of property under this paragraph shall be governed by section 413 of the Controlled Substances Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s853"},"text":"21 U.S.C. 853","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd715895-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil forfeiture.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd715896-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any property involved in a violation of subsection (b) or (c), or a conspiracy to commit a violation of subsection (b) or (c), and any property traceable thereto may be seized and forfeited to the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd715897-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5335/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Seizures and forfeitures under this paragraph shall be governed by the provisions of chapter 46 of title 18 relating to civil forfeitures, except that such duties, under the customs laws described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s981/d"},"text":"section 981(d) of title 18","children":[],"tail":", given to the Secretary of the Treasury shall be performed by such officers, agents, and other persons as may be designated for that purpose by the Secretary of Homeland Security or the Attorney General."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd715898-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dF/tLXIII/s6313/a"},"text":"Pub. L. 116–283, div. F, title LXIII, § 6313(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4596"},"text":"134 Stat. 4596","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
