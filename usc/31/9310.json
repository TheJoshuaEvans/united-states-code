{"tag":"section","attrib":{"id":"idbd92c2f0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9310"},"text":null,"children":[{"tag":"num","attrib":{"value":"9310"},"text":"§ 9310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individual sureties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If another applicable Federal law or regulation permits the acceptance of a bond from a surety that is not subject to sections 9305 and 9306 and is based on a pledge of assets by the surety, the assets pledged by such surety shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd92c2f1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9310/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consist of eligible obligations described under section 9303(a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd92c2f2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9310/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be submitted to the official of the Government required to approve or accept the bond, who shall deposit the obligations as described under section 9303(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd92c2f3-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVIII/s874/a/1"},"text":"Pub. L. 114–92, div. A, title VIII, § 874(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/940"},"text":"129 Stat. 940","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd92c2f4-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd92c2f5-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd92c2f6-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 year after ","children":[{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/s874/c"},"text":"section 874(c) of Pub. L. 114–92","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s694b"},"text":"section 694b of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
