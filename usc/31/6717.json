{"tag":"section","attrib":{"id":"idbd86b576-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6717"},"text":null,"children":[{"tag":"num","attrib":{"value":"6717"},"text":"§ 6717.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd86b577-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6717/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeals in Federal Court of Appeals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A unit of general local government which receives notice from the Secretary about withholding payments under section 6703(f), suspending payments under section 6713(a)(1)(B), or terminating payments under section 6712(d)(2)(A), may apply for review of the action of the Secretary by filing a petition for review with the court of appeals of the United States for the circuit in which the government is located. The petition shall be filed by the 60th day after the date the notice is received. The clerk of the court shall immediately send a copy of the petition to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd86b578-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6717/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing of Record of Administrative Proceeding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall file with the court a record of the proceeding on which the Secretary based the action. The court may consider only objections to the action of the Secretary that were presented before the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd86b579-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6717/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Court Action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court may affirm, change, or set aside any part of the action of the Secretary. The findings of fact by the Secretary are conclusive if supported by substantial evidence in the record. If a finding is not supported by substantial evidence in the record, the court may remand the case to the Secretary to take additional evidence. Upon such a remand, the Secretary may make new or modified findings and shall certify additional proceedings to the court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd86b57a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6717/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review Only by Supreme Court","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A judgment of a court under this section may be reviewed only by the Supreme Court under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254"},"text":"section 1254 of title 28","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd86b57b-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31001/a"},"text":"Pub. L. 103–322, title III, § 31001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1878"},"text":"108 Stat. 1878","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd86b57c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd86b57d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd86b57e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6717, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1025"},"text":"96 Stat. 1025","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/185"},"text":"Pub. L. 98–185","children":[],"tail":", §§ 7, 9(h), "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1310"},"text":"97 Stat. 1310","children":[],"tail":", 1312, related to discrimination proceedings, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIV/s14001/a/1"},"text":"Pub. L. 99–272, title XIV, § 14001(a)(1)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/327"},"text":"100 Stat. 327","children":[],"tail":", 329, eff. "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
