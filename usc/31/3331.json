{"tag":"section","attrib":{"id":"idbd250de3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331"},"text":null,"children":[{"tag":"num","attrib":{"value":"3331"},"text":"§ 3331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substitute checks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd250de4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, “original check”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250de5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means an order for the payment of money—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd250de6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payable on demand;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250de7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that does not bear interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250de8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drawn by an authorized disbursing official or agent of the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250de9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of which is deposited with the Treasury or another account available for payment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250dea-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include coins and currency of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250deb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Secretary of the Treasury is satisfied that an original check is lost, stolen, destroyed in any part, or is so defaced that the value to the owner or holder is impaired, the Secretary may issue a substitute check to the owner or holder of the original check. Except as provided in subsection (c) or (f) of this section, the substitute check is payable from the amount available to pay the original check.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250dec-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When the Secretary is satisfied that an original check drawn on a depositary in a foreign country or a territory or possession of the United States is lost, stolen, destroyed in part, or is so defaced that its value to the owner or holder is impaired, the drawer of the original check (or another official designated by the Secretary with the approval of the head of the agency on whose behalf the original check was issued) may issue to the owner or holder of the check a substitute check. The drawer or official shall issue the substitute check by the last day of the fiscal year after the fiscal year in which the original check was issued—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250ded-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using the current date; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250dee-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drawn on the account of the drawer of the original check or another account available for payment of the substitute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250def-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A substitute check issued under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250df0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be paid only if the original check has not been paid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250df1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include information necessary to identify the original check;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250df2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that is drawn on the Treasury—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd250df3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is deemed to be an original check; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250df4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is paid under the same conditions as the original check; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250df5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not relieve a disbursing or certifying official from liability to the Government for payment resulting from erroneously issuing the original check.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250df6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before issuing a substitute check under this section, the Secretary may require the owner or holder of the original check to agree to indemnify the Government with security in the form and amount the Secretary decides is necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250df7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive any provision of this section as may be necessary to ensure that claimants receive timely payments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250df8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3331/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under conditions the Secretary may prescribe, the Secretary may delegate duties and powers of the Secretary under this section to the head of an agency. Consistent with a delegation from the Secretary under this subsection, the head of an agency may delegate those duties and powers to an officer or employee of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd250df9-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/955"},"text":"96 Stat. 955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/452/s1/11"},"text":"Pub. L. 97–452, § 1(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2468"},"text":"96 Stat. 2468","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tIII/s31001/x/2"},"text":"Pub. L. 104–134, title III, § 31001(x)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-377"},"text":"110 Stat. 1321–377","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd250dfa-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd250dfb-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd250dfc-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1982 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3331(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:528(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3646(a)–(c), (f), (g); ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1885-02-16/ch123"},"text":"Feb. 16, 1885, ch. 123","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/23/306"},"text":"23 Stat. 306","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1906-03-23/ch1129"},"text":"Mar. 23, 1906, ch. 1129","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/84"},"text":"34 Stat. 84","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1906-06-19/ch3434"},"text":"June 19, 1906, ch. 3434","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/301"},"text":"34 Stat. 301","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1908-05-27/ch206"},"text":"May 27, 1908, ch. 206","children":[],"tail":"(par. beginning on p. 415 amending §§ 3646, 3647), "},{"tag":"html:a","attrib":{"href":"/us/stat/35/415"},"text":"35 Stat. 415","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1909-02-23/ch174"},"text":"Feb. 23, 1909, ch. 174","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/35/643"},"text":"35 Stat. 643","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1916-03-21/ch52"},"text":"Mar. 21, 1916, ch. 52","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/37"},"text":"39 Stat. 37","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1937-07-08/ch444/s9"},"text":"July 8, 1937, ch. 444, § 9","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/50/482"},"text":"50 Stat. 482","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1939-08-10/ch665"},"text":"Aug. 10, 1939, ch. 665","children":[],"tail":", §§ 5–7, "},{"tag":"html:a","attrib":{"href":"/us/stat/53/1359"},"text":"53 Stat. 1359","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1945-12-03/ch515/s1"},"text":"Dec. 3, 1945, ch. 515, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/592"},"text":"59 Stat. 592","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1947-07-11/ch222/s4/c"},"text":"July 11, 1947, ch. 222, § 4(c)","children":[],"tail":", (d)(related to § 3646(c)), (e), (f), "},{"tag":"html:a","attrib":{"href":"/us/stat/61/309"},"text":"61 Stat. 309","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/183"},"text":"Pub. L. 85–183","children":[],"tail":", §§ 4, 5(a), (c), "},{"tag":"html:a","attrib":{"href":"/us/stat/71/465"},"text":"71 Stat. 465","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/310/s231/s"},"text":"Pub. L. 92–310, § 231(s)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/211"},"text":"86 Stat. 211","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 22, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/380"},"text":"Pub. L. 95–380","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/725"},"text":"92 Stat. 725","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3331(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:528(a)(less last 28 words before proviso, proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3331(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:528(c)(1st sentence 1st–158th words, 171st–195th words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3331(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:528(a)(last 28 words before proviso, proviso), (c)(1st sentence 159th–170th words, 237th–last words, last sentence), (f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3331(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:528(b), (c)(1st sentence 196th–236th words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “The term . . . wherever used” are omitted as unnecessary. In clause (1), before subclause (A), the words “check, warrant, or other” are omitted as surplus. In subclause (C), the word “duly” is omitted as surplus. The words “disbursing official or agent” are substituted for “officer or agent” for consistency in the revised title. The words “any wholly owned or mixed-ownership Government corporation” are omitted as already being included in the restated source provisions and because of section 101 of the revised title. Therefore, the text is not meant to exclude employees of wholly owned Government corporations and mixed-ownership Government corporations. The words “the District of Columbia, or the District Unemployment Compensation Board” are omitted because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1973-12-24/s448"},"text":"section 448 of the Act of December 24, 1973","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/93/198"},"text":"Pub. L. 93–198","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/801"},"text":"87 Stat. 801","children":[],"tail":"). The words “or by any entity owned or controlled by the United States” are omitted as unnecessary. In subclause (D), the words “and covered . . . or deposited with the Treasurer of the United States” are omitted as surplus. The words “or another account available for payment” are added for clarity and consistency in the revised section. In clause (2), the word “money” is omitted as being covered by “coins and currency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the words “When the Secretary is satisfied” are substituted for “whenever it is clearly proved to the satisfaction of the Secretary” to eliminate unnecessary words. The words “mutilated or” are omitted as being covered by “defaced”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), before clause (1), the words “Notwithstanding the provisions of subsections (a) and (b) of this section” are omitted as unnecessary. The words “including the Panama Canal Zone” are omitted because of the Panama Canal Treaty of 1977. The words “official designated” are substituted for “officer or employee of the United States as may be authorized” for consistency in the revised title and with other titles of the United States Code. The word “agency” is substituted for “department or agency” because of section 101 of the revised title and for consistency. In clause (2), the words “drawn on” are substituted for “drawn against” for consistency in the revised chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(3), before subclause (A), the word “Treasury” is substituted for “Treasurer of the United States” because of the source provisions restated in section 321 of the revised title and Department of the Treasury Order 229 of ","children":[{"tag":"date","attrib":{"date":"1974-01-14"},"text":"January 14, 1974","children":[],"tail":" (39 F.R. 2280)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(4), the word “official” is substituted for “officer” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “surety or” are omitted as surplus. The words “the receipt and approval by the Secretary of the Treasury of” are omitted because of the restatement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd250dfd-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1983 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This restates, as 31:3331(f), section 3646(h) of the Revised Statutes that was inadvertently omitted from the codification of title 31 by the Act of ","children":[{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1084"},"text":"96 Stat. 1084","children":[],"tail":"). It provides authority for the Secretary of the Treasury to delegate duties and powers related to issuing substitute checks to heads of other agencies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “terms and” are omitted as surplus. The words “duties and powers” are substituted for “power, authority, or discretion” for consistency in the revised title and with other titles of the United States Code. The words “in whole or in part” are omitted as surplus. The words “to such individuals as he may designate within the Treasury Department” are omitted because of 31:321(b)(2). The word “agency” is coextensive with and substituted for “other department or agency of the Government or of any Federal Reserve bank” because of 31:101. The words “terms and conditions” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd250dfe-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd250dff-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s31001/x/2/A"},"text":"Pub. L. 104–134, § 31001(x)(2)(A)","children":[],"tail":", substituted “subsection (c) or (f)” for “subsection (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s31001/x/2/B"},"text":"Pub. L. 104–134, § 31001(x)(2)(B)","children":[],"tail":", (C), added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452"},"text":"Pub. L. 97–452","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd250e00-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd250e01-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452/s2/i"},"text":"Pub. L. 97–452, § 2(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2479"},"text":"96 Stat. 2479","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/452/s2/i"},"text":"“The amendments made by section 1(11), (14), (19), (22), (24), (26), and (27) [amending this section and sections 3702, 5103, 5154, 6501, 9101, 9107, and 9108 of this title] are effective as of ","children":[{"tag":"date","attrib":{"date":"1982-09-13"},"text":"September 13, 1982","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
