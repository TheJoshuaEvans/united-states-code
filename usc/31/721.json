{"tag":"section","attrib":{"id":"idbcf08ff1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s721"},"text":null,"children":[{"tag":"num","attrib":{"value":"721"},"text":"§ 721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to certain information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf08ff2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No provision of the Social Security Act, including section 453(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s653"},"text":"42 U.S.C. 653","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")), shall be construed to limit, amend, or supersede the authority of the Comptroller General to obtain any information or to inspect any record under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s716"},"text":"section 716 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf08ff3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The specific reference to a statute in subsection (a) shall not be construed to affect access by the Government Accountability Office to information under statutes that are not so referenced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf08ff4-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/3/s2/a"},"text":"Pub. L. 115–3, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-01-31"},"text":"Jan. 31, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/7"},"text":"131 Stat. 7","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf08ff5-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf08ff6-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcf08ff7-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":", which is classified generally to chapter 7 (§ 301 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
