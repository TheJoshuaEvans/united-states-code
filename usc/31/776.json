ren":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/87"},"text":"Pub. L. 86–87","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/198"},"text":"73 Stat. 198","children":[],"tail":", 199."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"776(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43b(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"776(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43b(","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")(words before last comma)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"776(d)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43b(j)(last 13 words before colon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43b(","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")(words after last comma)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"776(d)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43b(m)(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “due and” and “or other period” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the word “dependent” is added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b)(3) and (c), the words “of a Comptroller General or retired Comptroller General” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3) and (4), the words “and paid” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2)(A), the words “duly appointed” are omitted as surplus. The word “individual” is substituted for “person” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2)(B), the words “payment may be made” and “the expiration of . . . from” are omitted as surplus. The words “to the payment” are substituted for “thereto” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), the words “A benefit” are substituted for “None of the moneys mentioned” to eliminate unnecessary words. The words “either in law or equity” and “execution, levy, attachment, garnishment, or other” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf7bba3-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf7bba4-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426/s206/1"},"text":"Pub. L. 100–426, § 206(1)","children":[],"tail":", inserted “before age 55” after “remarries”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426/s206/2"},"text":"Pub. L. 100–426, § 206(2)","children":[],"tail":", inserted “(unless the child is then a student as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s771/1/C"},"text":"section 771(1)(C) of this title","children":[],"tail":")” after “age”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf7bba5-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf7bba6-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426"},"text":"Pub. L. 100–426","children":[],"tail":" effective after end of 60-day period beginning "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/426/s208"},"text":"section 208 of Pub. L. 100–426","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s772"},"text":"section 772 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
