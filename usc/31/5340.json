{"tag":"section","attrib":{"id":"idbd73a2b3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5340"},"text":null,"children":[{"tag":"num","attrib":{"value":"5340"},"text":"§ 5340.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd73a2b4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5340/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department of the treasury law enforcement organizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Department of the Treasury law enforcement organizations” has the meaning given to such term in section 9705(n).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2b5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5340/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Money laundering and related financial crime","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “money laundering and related financial crime”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd73a2b6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5340/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the movement of illicit cash or cash equivalent proceeds into, out of, or through the United States, or into, out of, or through United States financial institutions, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5312"},"text":"section 5312 of title 31","children":[],"tail":", United States Code; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd73a2b7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5340/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given that term (or the term used for an equivalent offense) under State and local criminal statutes pertaining to the movement of illicit cash or cash equivalent proceeds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2b8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5340/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2b9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5340/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attorney general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Attorney General” means the Attorney General of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd73a2ba-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/310/s2/a"},"text":"Pub. L. 105–310, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href"