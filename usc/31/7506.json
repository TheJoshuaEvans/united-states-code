tag":"ref","attrib":{"href":"/us/pl/104/156"},"text":"Pub. L. 104–156","children":[],"tail":" struck out “; report” after “Effective date” in section catchline and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) This chapter shall apply to any State or local government with respect to any of its fiscal years which begin after ","children":[{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) The Director, on or before ","children":[{"tag":"date","attrib":{"date":"1987-05-01"},"text":"May 1, 1987","children":[],"tail":", and annually thereafter, shall submit to each House of Congress a report on operations under this chapter. Each such report shall specifically identify each Federal agency or State or local government which is failing to comply with this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
