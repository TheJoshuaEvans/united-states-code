{"tag":"section","attrib":{"id":"idbd7ace15-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102"},"text":null,"children":[{"tag":"num","attrib":{"value":"6102"},"text":"§ 6102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program information requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7ace16-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall collect and review information on domestic assistance programs and shall provide such information to the Administrator. The information on each domestic assistance program shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7ace17-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identification of the program by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7ace18-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace19-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizing law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace1a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administering office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace1b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identifying number assigned by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7ace1c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7ace1d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace1e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" objectives of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace1f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" types of activities financed under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace20-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligibility requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace21-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" types of assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace22-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses, and restrictions on the use, of assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace23-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses of core-based statistical area (as defined in section 4 of the MAPS Act of 2021) delineations (as chosen from standardized categories of uses determined by the Director), for purposes including prime recipient and subrecipient eligibility for, and distribution of, any Federal service, benefit, or funding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace24-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" duties of recipients under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7ace25-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a specification of each formula governing eligibility for assistance or the distribution of assistance under the program, which shall be described through the use of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7ace26-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the language used to specify each such formula in the law authorizing the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace27-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the language used to specify each such formula in any Federal rule promulgated pursuant to the law authorizing the program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace28-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mathematical statement which is derived from the language referred to in subparagraphs (A) and (B) of this paragraph;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7ace29-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of all data and statistical estimates used to carry out each formula specified pursuant to paragraph (3), and an identification of the sources of such data and estimates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7ace2a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" financial information, including the—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7ace2b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts appropriated for the current fiscal year or, if unavailable, the amounts requested by the President and the amounts obligated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace2c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" average amounts of awards made in past years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7ace2d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of information contacts, including the administering office and regional and local offices with their addresses and telephone numbers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7ace2e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a general description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7ace2f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application requirements and procedures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7ace30-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practical, an estimate of the time required to process the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7ace31-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On request of the Director, an agency shall give to the Director current information on all domestic assistance programs administered by the agency. The Director shall be responsible for ensuring that the Administrator incorporates all relevant information received on a regular basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7ace32-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7ace33-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure that information and catalogs under this chapter are made available to the public at reasonable prices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7ace34-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may develop information services to assist State and local governments in identifying and obtaining sources of assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7ace35-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure that the information in the computerized system is made current on a regular basis and that the printed catalog and supplements thereto contain the most current data available at the time of printing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7ace36-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall transmit annually the information compiled under paragraphs (3) and (4) of subsection (a) to the Committee on Government Operations of the House of Representatives and the Committee on Governmental Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7ace37-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1001"},"text":"96 Stat. 1001","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/169"},"text":"Pub. L. 98–169","children":[],"tail":", §§ 1(2), 2, 3(b), (c), "},{"tag":"date","attrib":{"date":"1983-11-29"},"text":"Nov. 29, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1113"},"text":"97 Stat. 1113","children":[],"tail":", 1114; "},{"tag":"ref","attrib":{"href":"/us/pl/117/219/s6/a"},"text":"Pub. L. 117–219, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-05"},"text":"Dec. 5, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2273"},"text":"136 Stat. 2273","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7ace38-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd7ace39-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd7ace3a-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6102(a).","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1703(a)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/220"},"text":"Pub. L. 95–220","children":[],"tail":", §§ 4, 5(d), (e), "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1615"},"text":"91 Stat. 1615","children":[],"tail":", 1616."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6102(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1703(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6102(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1704(d), (e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words in parentheses are omitted as unnecessary because of the restatement. The words “information on domestic assistance programs. The information on each domestic assistance program shall include the following” are substituted for “a Federal Assistance Information Data Base . . . For each Federal domestic assistance program the data base shall” for clarity and consistency. In clause (1)(A), the word “law” is substituted for “statute” for consistency. In clause (2)(H), the word “obligations” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the word “catalogs” is added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “further”, “officials”, and “Federal” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd7ace3b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd7ace3c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4 of the MAPS Act of 2021, referred to in subsec. (a)(2)(G), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219/s4"},"text":"section 4 of Pub. L. 117–219","children":[],"tail":", which is set out as a note under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd7ace3d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(2)(G), (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219"},"text":"Pub. L. 117–219","children":[],"tail":" added subpar. (G) and redesignated former subpar. (G) as (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/169/s2/1"},"text":"Pub. L. 98–169, § 2(1)","children":[],"tail":", substituted “collect and review information on domestic assistance programs and shall provide such information to the Administrator” for “prepare and maintain information on domestic assistance programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/169/s1/2"},"text":"Pub. L. 98–169, § 1(2)","children":[],"tail":", substituted “Director” for “Director of the Office of Management and Budget”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/169/s3/b/1"},"text":"Pub. L. 98–169, § 3(b)(1)","children":[],"tail":", struck out subpar. (E) relating to formulas governing distribution of amounts, and redesignated subpars. (F) to (H) as (E) to (G), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/169/s3/b/2"},"text":"Pub. L. 98–169, § 3(b)(2)","children":[],"tail":", (3), added pars. (3) and (4) and redesignated former pars. (3) to (5) as (5) to (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/169/s2/2"},"text":"Pub. L. 98–169, § 2(2)","children":[],"tail":", substituted “The Director shall be responsible for ensuring that the Administrator incorporates all relevant information received on a regular basis” for “The Director shall incorporate on a regular basis all relevant information received”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/169/s2/3"},"text":"Pub. L. 98–169, § 2(3)","children":[],"tail":", substituted “Administrator” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/169/s2/4"},"text":"Pub. L. 98–169, § 2(4)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/169/s3/c"},"text":"Pub. L. 98–169, § 3(c)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd7ace3e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbd7ace3f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Governmental Affairs of Senate changed to Committee on Homeland Security and Governmental Affairs of Senate, effective ","children":[{"tag":"date","attrib":{"date":"2005-01-04"},"text":"Jan. 4, 2005","children":[],"tail":", by Senate Resolution No. 445, One Hundred Eighth Congress, "},{"tag":"date","attrib":{"date":"2004-10-09"},"text":"Oct. 9, 2004","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Government Operations of House of Representatives treated as referring to Committee on Government Reform and Oversight of House of Representatives by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a"},"text":"section 1(a) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress. Committee on Government Reform and Oversight of House of Representatives changed to Committee on Government Reform of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, "},{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":". Committee on Government Reform of House of Representatives changed to Committee on Oversight and Government Reform of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, "},{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7ace40-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (c)(4) of this section relating to annually transmitting information to certain committees of Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of this title","children":[],"tail":", and page 173 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7ace41-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219/s2"},"text":"Pub. L. 117–219, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-05"},"text":"Dec. 5, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2271"},"text":"136 Stat. 2271","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/219/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal programs use core-based statistical area delineations to determine the delivery of Federal services, benefits, and funding to people in the United States, such as in criteria for eligibility or distribution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Core-based statistical area delineations provide a nationally consistent set of standards for collecting, tabulating, and publishing Federal statistics for geographic areas, and they are not intended for any public or private sector non-statistical uses such as program administration or service delivery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Updates to core-based statistical area delineations may cause widespread disruption to the delivery of Federal services, benefits, and funding to people in the United States based on the reliance of Federal programs on these delineations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There does not exist any comprehensive list of Federal programs that rely on core-based statistical area delineations. Such a list is valuable for the study of how Federal services, benefits, and funding are distributed to people in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increased transparency on the impacts of any update to core-based statistical area delineations may be overly burdensome due to the anticipated variety of Federal programs that rely on these delineations. Any requirement for complete disclosure of these impacts prior to implementation of new delineations may unintentionally cause the existing delineations to ossify.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to prevent any disruption to service delivery of Federal programs based on updates to core-based statistical area delineations, and ensure the independence of Federal statistical policymaking, Congress must sever the link between future updates to core-based statistical area delineations and any automatic impact on Federal programs that rely on these delineations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “core-based statistical area” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219/s2"},"text":"section 2 of Pub. L. 117–219","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/219/s4"},"text":"section 4 of Pub. L. 117–219","children":[],"tail":", set out below.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7ace42-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purpose of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219"},"text":"Pub. L. 117–219","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219/s3"},"text":"Pub. L. 117–219, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-05"},"text":"Dec. 5, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2272"},"text":"136 Stat. 2272","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/219/s3"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“This [sic] purpose of this Act [see Short Title of 2022 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6101"},"text":"section 6101 of this title","children":[],"tail":"] is to ensure—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transparency in how core-based statistical area delineations are used in domestic assistance programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" independence of the Office of Management and Budget in establishing and updating core-based statistical area delineations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “core-based statistical area” and “domestic assistance program” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219/s3"},"text":"section 3 of Pub. L. 117–219","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/219/s4"},"text":"section 4 of Pub. L. 117–219","children":[],"tail":", set out below.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7ace43-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Content Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219/s6/b"},"text":"Pub. L. 117–219, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-05"},"text":"Dec. 5, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2273"},"text":"136 Stat. 2273","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/219/s6/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In collecting and reviewing the information required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6102/a/2/G"},"text":"section 6102(a)(2)(G) of title 31","children":[],"tail":", United States Code, as amended by subsection (a) of this section, the Director shall include as standardized categories—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the most current core-based statistical area delineation has been affirmatively adopted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6309"},"text":"section 6309 of title 31","children":[],"tail":", United States Coded [sic], as added by this Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which historical core-based statistical area delineation was maintained, in cases where an updated delineation has not been affirmatively adopted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6309"},"text":"section 6309 of title 31","children":[],"tail":", United States Coded [sic], as added by this Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" what purpose the core-based statistical area delineation serves, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine eligibility for any Federal service, benefit, or funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine distribution of any Federal service, benefit, or funding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other standardized category of purpose determined by the Director;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether the use of core-based statistical area delineation directly concerns any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prime recipient of any Federal service, benefit, or funding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subrecipient of any Federal service, benefit, or funding; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date when the information collected in this subsection was last updated.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “core-based statistical area” and “Director” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219/s6/b"},"text":"section 6(b) of Pub. L. 117–219","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/219/s4"},"text":"section 4 of Pub. L. 117–219","children":[],"tail":", set out below.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7ace44-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Accessibility Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219/s6/c"},"text":"Pub. L. 117–219, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-05"},"text":"Dec. 5, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2273"},"text":"136 Stat. 2273","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/219/s6/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Director shall ensure that the information collected and reviewed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6102/a/2/G"},"text":"section 6102(a)(2)(G) of title 31","children":[],"tail":", United States Code, as amended by subsection (a) of this section, shall be—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicly accessible as an open Government data asset;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" presented in a user-friendly visual format with search and download capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" easily discoverable by the public on relevant government websites; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" updated not less frequently than once every year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “Director” and “open Government data asset” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219/s6/c"},"text":"section 6(c) of Pub. L. 117–219","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/219/s4"},"text":"section 4 of Pub. L. 117–219","children":[],"tail":", set out below.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7ace45-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation Timeline","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219/s6/d"},"text":"Pub. L. 117–219, § 6(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12