ext":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3528(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:82c(less provisos).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1941-12-29/ch641/s2"},"text":"Dec. 29, 1941, ch. 641, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/55/875"},"text":"55 Stat. 875","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/310/s231/cc"},"text":"Pub. L. 92–310, § 231(cc)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/213"},"text":"86 Stat. 213","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:82f(related to certifying officers).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-04-28/ch247/s301"},"text":"Apr. 28, 1942, ch. 247, § 301","children":[],"tail":"(1st par. proviso under heading “Bureau of Accounts” related to certifying officers), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/244"},"text":"56 Stat. 244","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3528(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:82c(1st proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3528(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:82c(last proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:82g(related to certifying officers).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-06-01/ch320"},"text":"June 1, 1942, ch. 320","children":[],"tail":"(related to certifying officers), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/306"},"text":"56 Stat. 306","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3528(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:82e(related to 31:82c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1941-12-29/ch641/s4"},"text":"Dec. 29, 1941, ch. 641, § 4","children":[],"tail":"(related to § 2), "},{"tag":"html:a","attrib":{"href":"/us/stat/55/876"},"text":"55 Stat. 876","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the word “official” is substituted for “officer or employee” and “officer” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “the existence and correctness of” are omitted as surplus. In clause (1), the words “or otherwise stated on” are omitted as surplus. The word “records” is substituted for “papers” for consistency. Clause (2) is substituted for 31:82f(related to certifying officers) because of the restatement. In clause (4), before subclause (A), the word “repaying” is substituted for “and required to make good to the United States” to eliminate unnecessary words. The words “the amount of” are omitted as surplus. In subclause (A), the word “inaccurate” is substituted for “false, inaccurate” to eliminate an unnecessary word. The words “made by him” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “in his discretion” and “for any payment otherwise proper” are omitted as surplus. Clause (2)(B) is substituted for “the payment was not contrary to any statutory provision specifically prohibiting payments of the character involved” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), before clause (1), the word “services” in 31:82c(last proviso) is omitted as surplus. The words “On and after ","children":[{"tag":"date","attrib":{"date":"1942-06-01"},"text":"June 1, 1942","children":[],"tail":"” in 31:82g(related to certifying officers) are omitted as executed. The word “audit” is substituted for “examination” for consistency in the revised title and with other titles of the Code. The words “of the transportation bill” are omitted as surplus. In clause (2), the words “equalization and other” in 31:82g are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “under the jurisdiction” are omitted as surplus. The words “a military department of the Department of Defense” are substituted for “the Department of the Army, the Navy Department (including the Marine Corps)” for consistency with title 10. The words “and the Panama Canal” (subsequently changed to “the Canal Zone Government” by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-26/s2/a/1"},"text":"section 2(a)(1) of the Act of September 26, 1950","children":[],"tail":" (ch. 1049, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1038"},"text":"64 Stat. 1038","children":[],"tail":")) are omitted because of the Panama Canal Act of 1979 ("},{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/452"},"text":"93 Stat. 452","children":[],"tail":"). The word “pay” is substituted for “salaries” for consistency in the revised title and with other titles of the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd333e5e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1984 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This clarifies section 3528(b) by restoring the authority of the Comptroller General to deny relief to certifying officials in the same way relief may be denied to disbursing officials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd333e5f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd333e60-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/264/s3/a/2/A"},"text":"Pub. L. 105–264, § 3(a)(2)(A)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/264/s3/a/2/B"},"text":"Pub. L. 105–264, § 3(a)(2)(B)","children":[],"tail":", inserted “and the Administrator of General Services has determined that verification by a prepayment audit conducted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3726/a"},"text":"section 3726(a) of this title","children":[],"tail":" for a particular mode or modes of transportation, or for an agency or subagency, will not adequately protect the interests of the Government” after “deductions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/264/s3/a/2/C"},"text":"Pub. L. 105–264, § 3(a)(2)(C)","children":[],"tail":", inserted “and the Administrator of General Services has determined that verification by a prepayment audit conducted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3726/a"},"text":"section 3726(a) of this title","children":[],"tail":" for a particular mode or modes of transportation, or for an agency or subagency, will not adequately protect the interests of the Government” after “agreement”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" struck out subsec. (d) which read as follows: “This section does not apply to disbursements of a military department of the Department of Defense, except disbursements for departmental pay and expenses in the District of Columbia.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/216"},"text":"Pub. L. 98–216","children":[],"tail":" designated existing provisions as par. (1), substituted designations of subpars. (A) and (B) and cls. (i), (ii), and (iii) for former designations of pars. (1) and (2) and subpars. (A), (B), and (C), respectively, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd333e61-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd333e62-47c4-11f1-bea6-82cea744851c"}