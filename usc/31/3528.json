{"tag":"section","attrib":{"id":"idbd333e45-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528"},"text":null,"children":[{"tag":"num","attrib":{"value":"3528"},"text":"§ 3528.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities and relief from liability of certifying officials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd333e46-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A certifying official certifying a voucher is responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd333e47-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information stated in the certificate, voucher, and supporting records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd333e48-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the computation of a certified voucher under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3325"},"text":"section 3325 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd333e49-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legality of a proposed payment under the appropriation or fund involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd333e4a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" repaying a payment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd333e4b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" illegal, improper, or incorrect because of an inaccurate or misleading certificate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd333e4c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibited by law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd333e4d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that does not represent a legal obligation under the appropriation or fund involved; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd333e4e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verifying transportation rates, freight classifications, and other information provided on a Government bill of lading or transportation request, unless the Administrator of General Services has determined that verification by a prepayment audit conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3726/a"},"text":"section 3726(a) of this title","children":[],"tail":" for a particular mode or modes of transportation, or for an agency or subagency, will not adequately protect the interests of the Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd333e4f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd333e50-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Comptroller General may relieve a certifying official from liability when the Comptroller General decides that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd333e51-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the certification was based on official records and the official did not know, and by reasonable diligence and inquiry could not have discovered, the correct information; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd333e52-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd333e53-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligation was incurred in good faith;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd333e54-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no law specifically prohibited the payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd333e55-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Government received value for payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd333e56-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General may deny relief when the Comptroller General decides the head of the agency did not carry out diligently collection action under procedures prescribed by the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd333e57-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Comptroller General shall relieve a certifying official from liability for an overpayment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd333e58-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a common carrier under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3726"},"text":"section 3726 of this title","children":[],"tail":" when the Comptroller General decides the overpayment occurred only because the administrative audit before payment did not verify transportation rates, freight classifications, or land-grant deductions and the Administrator of General Services has determined that verification by a prepayment audit conducted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3726/a"},"text":"section 3726(a) of this title","children":[],"tail":" for a particular mode or modes of transportation, or for an agency or subagency, will not adequately protect the interests of the Government; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd333e59-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3528/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided under a Government bill of lading or transportation request when the overpayment was the result of using improper transportation rates or classifications or the failure to deduct the proper amount under a land-grant law or agreement and the Administrator of General Services has determined that verification by a prepayment audit conducted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3726/a"},"text":"section 3726(a) of this title","children":[],"tail":" for a particular mode or modes of transportation, or for an agency or subagency, will not adequately protect the interests of the Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd333e5a-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/966"},"text":"96 Stat. 966","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/216/s1/4"},"text":"Pub. L. 98–216, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-02-14"},"text":"Feb. 14, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/4"},"text":"98 Stat. 4","children":[],"ta