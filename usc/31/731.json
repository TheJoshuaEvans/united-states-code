 for consistency with other provisions of the subchapter. The words “officers (except the Deputy Comptroller General) and employees” are substituted for “personnel” in 31:52–1, and the word “powers” is substituted for “functions”, for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for 31:52–4(b) to eliminate unnecessary words. The words “officers and” are added for consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (c) and (d), the words “basic pay” are substituted for “compensation” for consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “United States” and “positions at” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “in the General Accounting Office”, “prescribed . . . under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"”, and “of the Office” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), before clause (1), the words “procure the services of” are substituted for “employ” for consistency with 5:3109. The words “at rates not in excess of the maximum daily rate prescribed for GS–18 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" for persons in the Government service employed intermittently” are omitted as unnecessary because of 5:3109. In clause (1), the word “periods” is omitted as surplus. Clause (2) is substituted for 31:1154(d)(last sentence) to eliminate unnecessary words. The words “and consultants” are added because of 5:3109."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf0901a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcf0901b-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5401"},"text":"Section 5401 of title 5","children":[],"tail":", referred to in subsec. (b), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/89/s3/a/1"},"text":"Pub. L. 103–89, § 3(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"Sept. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/981"},"text":"107 Stat. 981","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Level IV of the Executive Schedule, referred to in subsecs. (c) and (e), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this subsection, referred to in subsec. (h)(5), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1043 of the Internal Revenue Code of 1986, referred to in subsec. (i)(6), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1043"},"text":"section 1043 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf0901c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (i)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 131 of title 5;” for “the Ethics in Government Act of 1978 (5 U.S.C. App.);”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" added subsec. (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (i)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “chapter 21 of title 41” for “section 27 of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s423"},"text":"41 U.S.C. 423","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/323/s9/a/1"},"text":"Pub. L. 110–323, § 9(a)(1)","children":[],"tail":", struck out subsec. (d) which read as follows: “When a change in organization, management responsibility, or workload makes it necessary, the Comptroller General may fix the rate of basic pay of 5 positions at rates not more than the rate for level IV of the Executive Schedule.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/323/s9/a/2"},"text":"Pub. L. 110–323, § 9(a)(2)","children":[],"tail":", substituted “daily rate for level IV of the Executive Schedule” for “maximum daily rate for GS–18 under section 5332 of such title” and “more than 20 experts and consultants may be procured for terms of not more than 3 years, but which shall be renewable.” for “more than—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 15 experts and consultants may be procured for terms of not more than 3 years, but which shall be renewable; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 10 experts and consultants may be procured permanently, temporarily, or intermittently to carry out sections 717(b)–(d) and 719(b)(1)(A) of this title at rates that are not more than the rate for level IV of the Executive Schedule.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/323/s9/a/3"},"text":"Pub. L. 110–323, § 9(a)(3)","children":[],"tail":", added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271/s5"},"text":"Pub. L. 108–271, § 5","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271/s6"},"text":"Pub. L. 108–271, § 6","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h), (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271/s7"},"text":"Pub. L. 108–271, § 7","children":[],"tail":", added subsecs. (h) and (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/303/s5/1"},"text":"Pub. L. 106–303, § 5(1)","children":[],"tail":", substituted “terms of not more than 3 years, but which shall be renewable” for “not more than 3 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/303/s5/2"},"text":"Pub. L. 106–303, § 5(2)","children":[],"tail":", substituted “level IV” for “level V”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/89"},"text":"Pub. L. 103–89","children":[],"tail":" inserted before period at end “, as in effect on "},{"tag":"date","attrib":{"date":"1993-10-31"},"text":"October 31, 1993","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5401"},"text":"section 5401 of title 5","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5401/a"},"text":"section 5401(a) of title 5","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/236"},"text":"Pub. L. 98–236","children":[],"tail":" substituted “title 5 at rates not in excess of the maximum daily rate for GS–18 under section 5332 of such title” for “title 5” in provisions preceding par. (1) and “15” for “10” in par. (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf0901d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf0901e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dI/tI/s1301/b"},"text":"Pub. L. 114–113, div. I, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","at