{"tag":"section","attrib":{"id":"idbd27574d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3336"},"text":null,"children":[{"tag":"num","attrib":{"value":"3336"},"text":"§ 3336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic benefit transfer pilot","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd27574e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3336/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress finds that:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd27574f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3336/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Electronic benefit transfer (EBT) is a safe, reliable, and economical way to provide benefit payments to individuals who do not have an account at a financial institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd275750-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3336/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The designation of financial institutions as financial agents of the Federal Government for EBT is an appropriate and reasonable use of the Secretary’s authority to designate financial agents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd275751-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3336/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A joint federal-state ","children":[{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" EBT system offers convenience and economies of scale for those states "},{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":" (and their citizens) that wish to deliver "},{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":" state-administered benefits on a single card by entering into a partnership with the federal "},{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":" government."},{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd275752-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3336/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary’s designation of a financial agent to deliver EBT is a specialized service not available through ordinary business channels and may be offered to the states ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" pursuant to section 6501 "},{"tag":"i","attrib":{},"text":"et seq","children":[],"tail":". of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd275753-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3336/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall continue to carry out the existing EBT pilot to disburse benefit payments electronically to recipients who do not have an account at a financial institution, which shall include the designation of one or more financial institution ","children":[{"tag":"ref","attrib":{"idref":"fn002046"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002046"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “institutions”."}],"tail":" as a financial agent of the Government, and the offering to the participating states "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the opportunity to contract with the financial agent selected by the Secretary, as described in the Invitation for Expressions of Interest to Acquire EBT Services for the Southern Alliance of States dated "},{"tag":"date","attrib":{"date":"1995-03-09"},"text":"March 9, 1995","children":[],"tail":", as amended as of "},{"tag":"date","attrib":{"date":"1995-06-30"},"text":"June 30, 1995","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-07-07"},"text":"July 7, 1995","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1995-08-01"},"text":"August 1, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd275754-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3336/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The selection and designation of financial agents, the design of the pilot program, and any other matter associated with or related to the EBT pilot described in subsection (b) shall not be subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd275755-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tVI/s664"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title VI, § 664]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–385.)"}],"tail":"\n"}],"tail":null}
