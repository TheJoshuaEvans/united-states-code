<html:tr style="-uslm-lc:I01;"><html:td style=" text-align:left; vertical-align:top; border-right:1px solid black; padding-right:2pt;"><html:p style=" text-align:left; text-indent: -1em; padding-left:1em;" class="leaders"><html:span>6903(b)(2)</html:span></html:p></html:td><html:td style=" text-align:left; vertical-align:top; border-right:1px solid black; border-left:1px solid black; padding-right:2pt; padding-left: 2pt;"><html:p style=" text-align:left; text-indent: -1em; padding-left:1em;">31:1602(a)(last sentence).</html:p></html:td><html:td style=" text-align:right; vertical-align:top; border-left:1px solid black; padding-left: 2pt;" /></html:tr>
