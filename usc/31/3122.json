 § 7(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/668"},"text":"63 Stat. 668","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 21, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/597/s2/d"},"text":"Pub. L. 89–597, § 2(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/824"},"text":"80 Stat. 824","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3122(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:772.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1918-07-09/ch142/s4"},"text":"July 9, 1918, ch. 142, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/40/845"},"text":"40 Stat. 845","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “war-savings certificates” are omitted because the authority to issue them was ended by section 2(b)(3) of the Public Debt Act of 1941 (ch. 7, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/55/7"},"text":"55 Stat. 7","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “in his discretion” are omitted as surplus. The word “obligation” is substituted for “bonds and certificates of indebtedness, Treasury bills” for consistency and to eliminate unnecessary words. The words “and arising from the payment of internal revenue taxes” are omitted as superseded by 26:6302(c). The word “conditions” is substituted for “terms and conditions” because it is inclusive. The words “upon and” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “The Secretary may designate a bank or trust company that is a depositary under subsection (a) of this section” are substituted for “Any incorporated bank or trust company designated as a depositary by the Secretary of the Treasury under the authority conferred by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s771"},"text":"section 771 of this title","children":[],"tail":", which gives security for such deposits as, and to amounts, by him prescribed, may, upon and subject to such terms and conditions as the Secretary of the Treasury may prescribe, act” to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
