{"tag":"section","attrib":{"id":"idbd2c3997-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354"},"text":null,"children":[{"tag":"num","attrib":{"value":"3354"},"text":"§ 3354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Do Not Pay Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd2c3998-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prepayment and Preaward Procedures.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c3999-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each executive agency shall review prepayment and preaward procedures and ensure that a thorough review of available databases with relevant information on eligibility occurs to determine program or award eligibility and prevent improper payments before the release of any Federal funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c399a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Databases","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At a minimum and before issuing any payment or award, each executive agency shall review as appropriate the following databases to verify eligibility of the payment and award:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c399b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The death records maintained by the Commissioner of Social Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c399c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The System for Award Management Exclusion Records, formerly known as the Excluded Parties List System, of the General Services Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c399d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Debt Check Database of the Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c399e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Credit Alert System or Credit Alert Interactive Voice Response System of the Department of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c399f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The List of Excluded Individuals/Entities of the Office of Inspector General of the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39a0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information regarding incarcerated individuals maintained by the Commissioner of Social Security under sections 202(x) and 1611(e) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s402/x"},"text":"42 U.S.C. 402(x)","children":[],"tail":", 1382(e))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c39a1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Do Not Pay Initiative.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c39a2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is the Do Not Pay Initiative, which shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c39a3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of the databases described in subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39a4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of other databases designated by the Director of the Office of Management and Budget, or the designee of the Director, in consultation with executive agencies and in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39a5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other databases","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making designations of other databases under paragraph (1)(B), the Director of the Office of Management and Budget, or the head of any executive agency designated by the Director, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c39a6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider any database that substantially assists in preventing improper payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39a7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide public notice and an opportunity for comment before designating a database under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39a8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access and review.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c39a9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of identifying and preventing improper payments, each executive agency shall have access to, and use of, the Do Not Pay Initiative to verify payment or award eligibility in accordance with subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39aa-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matching programs.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idbd2c39ab-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of the agency operating the Working System may, in consultation with the Office of Management and Budget, waive the requirements of section 552a(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of title 5 in any case or class of cases for computer matching activities conducted under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd2c39ac-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Management and Budget may issue guidance that establishes requirements governing waivers under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39ad-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each State and any contractor, subcontractor, or agent of a State, including a State auditor or State program responsible for reducing improper payments of a federally funded State-administered program, and the judicial and legislative branches of the United States, as defined in paragraphs (2) and (3), respectively, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s202/e"},"text":"section 202(e) of title 18","children":[],"tail":", shall have access to, and use of, the Do Not Pay Initiative for the purpose of verifying payment or award eligibility for payments."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39ae-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consistency with privacy act of 1974","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To ensure consistency with the principles of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (commonly known as the “Privacy Act of 1974”), the Director of the Office of Management and Budget may issue guidance that establishes privacy and other requirements that shall be incorporated into Do Not Pay Initiative access agreements with States, including any contractor, subcontractor, or agent of a State, and the judicial and legislative branches of the United States, as defined in paragraphs (2) and (3), respectively, of "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s202/e"},"text":"section 202(e) of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39af-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment otherwise required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When using the Do Not Pay Initiative, an executive agency shall recognize that there may be circumstances under which the law requires a payment or award to be made to a recipient, regardless of whether that recipient is identified as potentially ineligible under the Do Not Pay Initiative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39b0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office of Management and Budget shall submit to Congress an annual report, which may be included as part of another report submitted to Congress by the Director, regarding the operation of the Do Not Pay Initiative, which shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c39b1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an evaluation of whether the Do Not Pay Initiative has reduced improper payments or improper awards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39b2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the frequency of corrections or identification of incorrect information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c39b3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial Working System","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The working system required to be established under section 5(d) of the Improper Payments Elimination and Recovery Improvement Act of 2012, as in effect on the day before the date of enactment of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c39b4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall continue to be in effect on and after the date of enactment of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39b5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require each executive agency to review all payments and awards for all programs and activities of that executive agency through the working system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c39b6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Facilitating Data Access by Federal Agencies and Offices of Inspectors General for Purposes of Program Integrity.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c39b7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computer matching by executive agencies for purposes of investigation and prevention of improper payments and fraud.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c39b8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this paragraph, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":" (commonly known as the “Privacy Act of 1974”), the head of each executive agency may enter into computer matching agreements with other heads of executive agencies that allow ongoing data matching, which shall include automated data matching, in order to assist in the detection and prevention of improper payments."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39b9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date on which a proposal for an agreement under subparagraph (A) has been presented to a Data Integrity Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a/u"},"text":"section 552a(u) of title 5","children":[],"tail":" for consideration, the Data Integrity Board shall respond to the proposal."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39ba-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement described in subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd2c39bb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have a termination date of less than 3 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd2c39bc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 3-month period ending on the date on which the agreement is scheduled to terminate, may be renewed by the executive agencies entering the agreement for not more than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39bd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiple agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this paragraph, section 552a(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1) of title 5 shall be applied by substituting “between the source agency and the recipient agency or non-Federal agency or an agreement governing multiple agencies” for “between the source agency and the recipient agency or non-Federal agency” in the matter preceding subparagraph (A)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39be-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost-benefit analysis","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A justification under section 552a(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1)(B) of title 5 relating to an agreement under subparagraph (A) is not required to contain a specific estimate of any savings under the computer matching agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39bf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance and procedures by the office of management and budget","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidance, rules, and procedures required to be issued, clarified, and established under paragraphs (3) and (4) of section 5(e) of the Improper Payments Elimination and Recovery Improvement Act of 2012, as in effect on the day before the date of enactment of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c39c0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall continue to be in effect on and after the date of enactment of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39c1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be modified as determined appropriate by the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39c2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each executive agency, in consultation with the Inspector General of the executive agency, shall ensure that any information provided to an individual or entity under this subsection is provided in accordance with protocols established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39c3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection shall be construed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c39c4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to affect the rights of an individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a/p"},"text":"section 552a(p) of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39c5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to impede the exercise of an exemption provided to Inspectors General or by an executive agency in coordination with an Inspector General under section 6(j) of the Inspector General Act of 1978 (5 U.S.C. App.).","children":[{"tag":"ref","attrib":{"idref":"fn002048"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002048"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c39c6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan To Curb Federal Improper Payments to Deceased Individuals by Improving the Quality and Use by Federal Agencies of the Social Security Administration Death Master File and Other Death Data.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c39c7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In conjunction with the Commissioner of Social Security and in consultation with relevant stakeholders that have an interest in or responsibility for providing the data, and each State, the Director of the Office of Management and Budget shall conduct a study and update the plan required to be established under section 5(g) of the Improper Payments Elimination and Recovery Improvement Act of 2012, as in effect on the day before the date of enactment of this section, for improving the quality, accuracy, and timeliness of death data maintained by the Social Security Administration, including death information reported to the Commissioner under section 205(r) of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s405/r"},"text":"42 U.S.C. 405(r)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39c8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional actions under plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan described in this subsection shall include recommended actions by executive agencies to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c39c9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the quality and frequency of access to the Death Master File and other death data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39ca-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieve a goal of at least daily access as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39cb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for all States and other data providers to use improved and electronic means for providing data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39cc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify improved methods by executive agencies for determining ineligible payments due to the death of a recipient through proactive verification means; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39cd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address improper payments made by executive agencies to deceased individuals as part of Federal retirement programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39ce-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3354/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after the date of enactment of this section, the Director of the Office of Management and Budget shall submit a report to Congress on the plan described in this subsection, including recommended legislation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd2c39cf-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117/s2/a"},"text":"Pub. L. 116–117, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/126"},"text":"134 Stat. 126","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd2c39d0-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd2c39d1-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd2c39d2-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5 of the Improper Payments Elimination and Recovery Improvement Act of 2012, referred to in subsecs. (c), (d)(2), and (e)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/248/s5"},"text":"section 5 of Pub. L. 112–248","children":[],"tail":", which was formerly set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3321"},"text":"section 3321 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/117/s3/a/3"},"text":"Pub. L. 116–117, § 3(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/133"},"text":"134 Stat. 133","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (c), (d)(2), and (e)(1), (3), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117"},"text":"Pub. L. 116–117","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6(j) of the Inspector General Act of 1978, referred to in subsec. (d)(4)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/452/s6/j"},"text":"section 6(j) of Pub. L. 95–452","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s406/j"},"text":"section 406(j) of Title 5","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(b), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4224"},"text":"136 Stat. 4224","children":[],"tail":", 4361."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
