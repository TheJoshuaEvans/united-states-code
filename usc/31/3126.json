ch. 51, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/47"},"text":"59 Stat. 47","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 22, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/346/s103"},"text":"Pub. L. 86–346, § 103","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/31/622"},"text":"31 Stat. 622","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 17, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/595/s2"},"text":"Pub. L. 90–595, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/1155"},"text":"82 Stat. 1155","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3126(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:757c(i)(5th, 6th sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “qualified” and “authorized or” are omitted as surplus. The words “officer or employee of the Department of the Treasury” are substituted for “Treasury of the United States” and “Treasurer” because of the source provisions restated in section 321 of the revised title and for consistency with other titles of the United States Code. The text of 31:757c(i)(3d sentence) is omitted as surplus because of 39:410. The words “under regulations prescribed by him” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd202b8c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd202b8d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/h/4/A"},"text":"Pub. L. 107–217, § 3(h)(4)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s17303/a"},"text":"section 17303(a) of title 40","children":[],"tail":"” for “section 2 of the Government Losses in Shipment Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s722"},"text":"40 U.S.C. 722","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/h/4/B"},"text":"Pub. L. 107–217, § 3(h)(4)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s17304/c"},"text":"Section 17304(c) of title 40","children":[],"tail":"” for “Section 3 of the Government Losses in Shipment Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s723"},"text":"40 U.S.C. 723","children":[],"tail":") (related to finality of decisions of the Secretary)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
