{"tag":"section","attrib":{"id":"idbd761351-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362"},"text":null,"children":[{"tag":"num","attrib":{"value":"5362"},"text":"§ 5362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd761352-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bet or wager","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “bet or wager”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd761353-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the staking or risking by any person of something of value upon the outcome of a contest of others, a sporting event, or a game subject to chance, upon an agreement or understanding that the person or another person will receive something of value in the event of a certain outcome;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd761354-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the purchase of a chance or opportunity to win a lottery or other prize (which opportunity to win is predominantly subject to chance);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd761355-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any scheme of a type described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s3702"},"text":"section 3702 of title 28","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd761356-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any instructions or information pertaining to the establishment or movement of funds by the bettor or customer in, to, or from an account with the business of betting or wagering; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd761357-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd761358-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity governed by the securities laws (as that term is defined in section 3(a)(47) of the Securities Exchange Act of 1934 ","children":[{"tag":"ref","attrib":{"idref":"fn002101"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002101"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a closing parenthesis."}],"tail":" for the purchase or sale of securities (as that term is defined in section 3(a)(10) of that Act);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd761359-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any transaction conducted on or subject to the rules of a registered entity or exempt board of trade under the Commodity Exchange Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd76135a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any over-the-counter derivative instrument;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd76135b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other transaction that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd76135c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is excluded or exempt from regulation under the Commodity Exchange Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd76135d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is exempt from State gaming or bucket shop laws under section 12(e) of the Commodity Exchange Act or section 28(a) of the Securities Exchange Act of 1934;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd76135e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract of indemnity or guarantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd76135f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contract for insurance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd761360-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any deposit or other transaction with an insured depository institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd761361-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" participation in any game or contest in which participants do not stake or risk anything of value other than—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd761362-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/viii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personal efforts of the participants in playing the game or contest or obtaining access to the Internet; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd761363-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/viii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" points or credits that the sponsor of the game or contest provides to participants free of charge and that can be used or redeemed only for participation in games or contests offered by the sponsor; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd761364-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" participation in any fantasy or simulation sports game or educational game or contest in which (if the game or contest involves a team or teams) no fantasy or simulation sports team is based on the current membership of an actual team that is a member of an amateur or professional sports organization (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s3701"},"text":"section 3701 of title 28","children":[],"tail":") and that meets the following conditions:"}],"tail":null},{"tag":"subclause","attrib":{"id":"idbd761365-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/ix/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All prizes and awards offered to winning participants are established and made known to the participants in advance of the game or contest and their value is not determined by the number of participants or the amount of any fees paid by those participants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd761366-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/ix/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All winning outcomes reflect the relative knowledge and skill of the participants and are determined predominantly by accumulated statistical results of the performance of individuals (athletes in the case of sports events) in multiple real-world sporting or other events.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd761367-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/ix/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No winning outcome is based—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbd761368-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/ix/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the score, point-spread, or any performance or performances of any single real-world team or any combination of such teams; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbd761369-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/1/E/ix/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely on any single performance of an individual athlete in any single real-world sporting or other event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd76136a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Business of betting or wagering","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “business of betting or wagering” does not include the activities of a financial transaction provider, or any interactive computer service or telecommunications service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd76136b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designated payment system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “designated payment system” means any system utilized by a financial transaction provider that the Secretary and the Board of Governors of the Federal Reserve System, in consultation with the Attorney General, jointly determine, by regulation or order, could be utilized in connection with, or to facilitate, any restricted transaction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd76136c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial transaction provider","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “financial transaction provider” means a creditor, credit card issuer, financial institution, operator of a terminal at which an electronic fund transfer may be initiated, money transmitting business, or international, national, regional, or local payment network utilized to effect a credit transaction, electronic fund transfer, stored value product transaction, or money transmitting service, or a participant in such network, or other participant in a designated payment system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd76136d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Internet","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Internet” means the international computer network of interoperable packet switched data networks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd76136e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interactive computer service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “interactive computer service” has the meaning given the term in section 230(f) of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s230/f"},"text":"47 U.S.C. 230(f)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd76136f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restricted transaction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “restricted transaction” means any transaction or transmittal involving any credit, funds, instrument, or proceeds described in any paragraph of section 5363 which the recipient is prohibited from accepting under section 5363.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd761370-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd761371-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means any State of the United States, the District of Columbia, or any commonwealth, territory, or other possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd761372-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unlawful internet gambling.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd761373-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “unlawful Internet gambling” means to place, receive, or otherwise knowingly transmit a bet or wager by any means which involves the use, at least in part, of the Internet where such bet or wager is unlawful under any applicable Federal or State law in the State or Tribal lands in which the bet or wager is initiated, received, or otherwise made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd761374-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intrastate transactions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “unlawful Internet gambling” does not include placing, receiving, or otherwise transmitting a bet or wager where—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd761375-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bet or wager is initiated and received or otherwise made exclusively within a single State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd761376-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the bet or wager and the method by which the bet or wager is initiated and received or otherwise made is expressly authorized by and placed in accordance with the laws of such State, and the State law or regulations include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd761377-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" age and location verification requirements reasonably designed to block access to minors and persons located out of such State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd761378-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate data security standards to prevent unauthorized access by any person whose age and current location has not been verified in accordance with such State’s law or regulations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd761379-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the bet or wager does not violate any provision of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd76137a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Interstate Horseracing Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3001"},"text":"15 U.S.C. 3001","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd76137b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 178 of title 28 (commonly known as the “Professional and Amateur Sports Protection Act”);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd76137c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Gambling Devices Transportation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1171"},"text":"15 U.S.C. 1171","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd76137d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/B/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Gaming Regulatory Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"25 U.S.C. 2701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd76137e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intratribal transactions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “unlawful Internet gambling” does not include placing, receiving, or otherwise transmitting a bet or wager where—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd76137f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the bet or wager is initiated and received or otherwise made exclusively—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd761380-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the Indian lands of a single Indian tribe (as such terms are defined under the Indian Gaming Regulatory Act); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd761381-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between the Indian lands of 2 or more Indian tribes to the extent that intertribal gaming is authorized by the Indian Gaming Regulatory Act;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd761382-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the bet or wager and the method by which the bet or wager is initiated and received or otherwise made is expressly authorized by and complies with the requirements of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd761383-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable tribal ordinance or resolution approved by the Chairman of the National Indian Gaming Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd761384-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to class III gaming, the applicable Tribal-State Compact;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd761385-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the applicable tribal ordinance or resolution or Tribal-State Compact includes—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd761386-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" age and location verification requirements reasonably designed to block access to minors and persons located out of the applicable Tribal lands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd761387-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate data security standards to prevent unauthorized access by any person whose age and current location has not been verified in accordance with the applicable tribal ordinance or resolution or Tribal-State Compact; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd761388-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the bet or wager does not violate any provision of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd761389-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Interstate Horseracing Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3001"},"text":"15 U.S.C. 3001","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd76138a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 178 of title 28 (commonly known as the “Professional and Amateur Sports Protection Act”);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd76138b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Gambling Devices Transportation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1171"},"text":"15 U.S.C. 1171","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd76138c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/C/iv/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Indian Gaming Regulatory Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"25 U.S.C. 2701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd76138d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interstate horseracing.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idbd76138e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “unlawful Internet gambling” shall not include any activity that is allowed under the Interstate Horseracing Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3001"},"text":"15 U.S.C. 3001","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd76138f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction regarding preemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subchapter may be construed to preempt any State law prohibiting gambling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd761390-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the sense of Congress that this subchapter shall not change which activities related to horse racing may or may not be allowed under Federal law. This subparagraph is intended to address concerns that this subchapter could have the effect of changing the existing relationship between the Interstate Horseracing Act and other Federal statutes in effect on the date of the enactment of this subchapter. This subchapter is not intended to change that relationship. This subchapter is not intended to resolve any existing disagreements over how to interpret the relationship between the Interstate Horseracing Act and other Federal statutes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd761391-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/10/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intermediate routing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The intermediate routing of electronic data shall not determine the location or locations in which a bet or wager is initiated, received, or otherwise made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd761392-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other terms.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd761393-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit; creditor; credit card; and card issuer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms “credit”, “creditor”, “credit card”, and “card issuer” have the meanings given the terms in section 103 of the Truth in Lending Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1602"},"text":"15 U.S.C. 1602","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd761394-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic fund transfer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “electronic fund transfer”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd761395-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/11/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in section 903 of the Electronic Fund Transfer Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1693a"},"text":"15 U.S.C. 1693a","children":[],"tail":"), except that the term includes transfers that would otherwise be excluded under section 903(6)(E) of that Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd761396-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/11/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any fund transfer covered by Article 4A of the Uniform Commercial Code, as in effect in any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd761397-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial institution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “financial institution” has the meaning given the term in section 903 of the Electronic Fund Transfer Act, except that such term does not include a casino, sports book, or other business at or through which bets or wagers may be placed or received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd761398-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/11/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Insured depository institution","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “insured depository institution”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd761399-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/11/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in section 3(c) of the Federal Deposit Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/c"},"text":"12 U.S.C. 1813(c)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd76139a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/11/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an insured credit union (as defined in section 101 of the Federal Credit Union Act).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd76139b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5362/11/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Money transmitting business and money transmitting service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms “money transmitting business” and “money transmitting service” have the meanings given the terms in section 5330(d) (determined without regard to any regulations prescribed by the Secretary thereunder).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd76139c-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tVIII/s802/a"},"text":"Pub. L. 109–347, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1953"},"text":"120 Stat. 1953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd76139d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd76139e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd76139f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 3(a)(47) and 28(a) of the Securities Exchange Act of 1934, referred to in par. (1)(E)(i), (iv)(II), are classified to sections 78c(a)(47) and 78bb(a), respectively, of Title 15, Commerce and Trade.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Commodity Exchange Act, referred to in par. (1)(E)(ii), (iv)(II), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369"},"text":"act Sept. 21, 1922, ch. 369","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/998"},"text":"42 Stat. 998","children":[],"tail":", which is classified generally to chapter 1 (§ 1 et seq.) of Title 7, Agriculture. Section 12(e) of the Act is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s16/e"},"text":"section 16(e) of Title 7","children":[],"tail":". For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"section 1 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Interstate Horseracing Act of 1978, referred to in par. (10)(B)(iii)(I), (C)(iv)(I), (D)(i), (iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/515"},"text":"Pub. L. 95–515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1811"},"text":"92 Stat. 1811","children":[],"tail":", which is classified generally to chapter 57 (§ 3001 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3001"},"text":"section 3001 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Gambling Devices Transportation Act, referred to in par. (10)(B)(iii)(III), (C)(iv)(III), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-01-02/ch1194"},"text":"act Jan. 2, 1951, ch. 1194","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1134"},"text":"64 Stat. 1134","children":[],"tail":", which is classified generally to chapter 24 (§ 1171 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1171"},"text":"section 1171 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Gaming Regulatory Act, referred to in par. (10)(B)(iii)(IV), (C)(i), (iv)(IV), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497"},"text":"Pub. L. 100–497","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2467"},"text":"102 Stat. 2467","children":[],"tail":", which is classified principally to chapter 29 (§ 2701 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2701"},"text":"section 2701 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this subchapter, referred to in par. (10)(D)(iii), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347"},"text":"Pub. L. 109–347","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 101 of the Federal Credit Union Act, referred to in par. (11)(D)(ii), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
