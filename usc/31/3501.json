/531/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3516"},"text":"section 3516 of this title","children":[],"tail":", amending sections 1116, 3515, and 3521 of this title, and enacting provisions set out as notes under sections 1116 and 3516 of this title] may be cited as the ‘Reports Consolidation Act of 2000’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
