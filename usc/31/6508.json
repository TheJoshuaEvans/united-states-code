{"tag":"section","attrib":{"id":"idbd81fa0a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6508"},"text":null,"children":[{"tag":"num","attrib":{"value":"6508"},"text":"§ 6508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd81fa0b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd81fa0c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When requested by a committee of Congress having jurisdiction over a grant program, the Comptroller General shall study the program. The study shall include a review of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd81fa0d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6508/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the extent to which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd81fa0e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6508/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program conflicts with or duplicates other grant programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd81fa0f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6508/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more effective, efficient, economical, and uniform administration of the program may be achieved by changing the requirements and procedures applicable to it; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd81fa10-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6508/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" budgetary, accounting, reporting, and administrative procedures of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd81fa11-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General shall submit to Congress a report on a study made under this subsection and any recommendations. To the extent practicable, a report on an expiring program shall be submitted in the year before the year in which a program ends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd81fa12-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd81fa13-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6508/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When requested by a committee of Congress having jurisdiction over a grant program, the Advisory Commission on Intergovernmental Relations shall study the intergovernmental relations aspects of the program, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd81fa14-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6508/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the program on the structural organization of States and local governments and on Federal-State-local fiscal relations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd81fa15-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6508/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of administration of the program by the United States Government and State and local governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd81fa16-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6508/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall submit to the committee requesting the study and to Congress a report and any recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd81fa17-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1010"},"text":"96 Stat. 1010","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd81fa18-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd81fa19-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd81fa1a-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6508(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"42:4242.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/577"},"text":"Pub. L. 90–577","children":[],"tail":", §§ 602, 603, "},{"tag":"html:a","attrib":{"href":"/us/stat/82/1107"},"text":"82 Stat. 1107","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6508(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"42:4243.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “of Congress” are added for clarity. The words “grant program” are substituted for “grant-in-aid program” for consistency in the chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the words “The study shall include a review of” are substituted for “to determine” for clarity. In clause (B), the words “among other relevant matters” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(B), the words “administration of the program by the United States Government” are substituted for “Federal administration” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “requesting the study” are added for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
