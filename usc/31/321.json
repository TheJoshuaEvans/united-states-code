ag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1917-06-12/ch27/s1"},"text":"June 12, 1917, ch. 27, § 1","children":[],"tail":"(4th par. under heading “Miscellaneous Objects, Treasury Department”), "},{"tag":"html:a","attrib":{"href":"/us/stat/40/118"},"text":"40 Stat. 118","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1921-03-04/ch161/s1"},"text":"Mar. 4, 1921, ch. 161, § 1","children":[],"tail":"(1st par. under heading “Miscellaneous Objects, Treasury Department”), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/1374"},"text":"41 Stat. 1374","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"321(b)(5)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:486.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1904-04-28/ch1762/s1"},"text":"Apr. 28, 1904, ch. 1762, § 1","children":[],"tail":"(proviso immediately before heading “Revenue-Cutter Service”), "},{"tag":"html:a","attrib":{"href":"/us/stat/33/460"},"text":"33 Stat. 460","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"321(b)(6)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1023(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1955-06-01/ch119/s1/a"},"text":"June 1, 1955, ch. 119, § 1(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/69/82"},"text":"69 Stat. 82","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"321(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1001(note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Reorg. Plan No. 26 of 1950, eff. ","children":[{"tag":"html:span","attrib":{},"text":"July 31, 1950","children":[],"tail":", § 1(a), (b), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/1280"},"text":"64 Stat. 1280","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)–(3), the words between the 2d and 3d semicolons are omitted as superseded by section 3512 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the word “digest” is omitted as being included in “prepare”. The word “receipts” is substituted for “revenue”, and the words “managing the public debt” are substituted for “for the support of the public credit”, for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “carry out” are substituted for “generally shall perform” for consistency in the revised title and with other titles of the United States Code. The words “that the Secretary is required” are substituted for “as he shall be directed” because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the word “issue” is substituted for “shall grant” for consistency. The words “under limitations herein established or to be provided” are omitted as unnecessary. The word “consistent” is substituted for “in pursuance of”, and the words “by law” are omitted, for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(4) is included to reflect all the major duties of the Secretary of the Treasury. See chapter 51 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(5), before subclause (A), the words “prescribe regulations” are substituted for “make and issue from time to time such instructions and regulations” for consistency in the revised title and to eliminate unnecessary words. The words “applicable to anyone” are substituted for “to the several collectors, receivers, depositaries, officers, and others” for clarity and to eliminate unnecessary words. In subclause (A), the words “for the Government” are inserted because ","children":[{"tag":"ref","attrib":{"href":"/us/act/1864-06-30/s8"},"text":"section 8 of the Act of June 30, 1864","children":[],"tail":" (ch. 172, "},{"tag":"ref","attrib":{"href":"/us/stat/13/221"},"text":"13 Stat. 221","children":[],"tail":"), from which section 251 of the Revised Statutes is derived, used the phrase “in behalf of the United States”. In subclause (B), the words “those notes and securities” are substituted for “the same” for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(6), the word “collect” is substituted for “superintend the collection” because of the source provisions restated in section 321(c) of the revised title. The word “receipts” is substituted for “revenue” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(7), the words “Secretary of the Treasury” are substituted for “General Counsel of the Department of the Treasury, under the direction of the Secretary of the Treasury” because of the source provisions restated in subsection (c) of this section. The words “with a view to prosecuting persons” are substituted for “for the prosecution of persons charged with the commission thereof” for clarity. The words “take steps to discover fraud and attempted fraud” are substituted for “take cognizance of all frauds or attempted frauds” for clarity. The words “involving receipts” are substituted for “upon the revenue” for consistency in the revised title. The words “decide on ways to prevent and detect fraud” are substituted for “exercise a general supervision over the measures for their prevention and detection” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(8), before subclause (A), the word “maintain” is substituted for “shall be kept” for consistency. The words “all moneys” and “internal” are omitted as unnecessary because of the restatement. The words “duties or” are omitted as being included in “taxes”. The word “possession” is added for consistency in the revised title and with other titles of the Code. The word “listing” is substituted for “so as to exhibit, as far as may be” for clarity and to eliminate unnecessary words. In subclause (A), the word “kind” is substituted for “species” for consistency. The words “that shall accrue” are omitted as surplus. In subclause (B), the words “each tax” are substituted for “each source of revenue” for clarity. In subclause (C), the word “pay” is substituted for “compensation” for consistency. The words “officers and employees” are substituted for “collectors and deputy collectors, inspectors, and other officers” for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(1) is included as a general statement of the authority of the Secretary of the Treasury to prescribe regulations to avoid repeating each time specific authority of the Secretary to carry out certain provisions of law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “make such provisions” in 31:1001(note) are omitted as unnecessary. The words “or by any agency” are omitted and the words “duties and powers” are substituted for “function”, for consistency in the revised title and with other titles of the Code. The words “including any function transferred to the Secretary by the provisions of this reorganization plan” are omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the word “effect ” is omitted as unnecessary. The words “(available or to be made available)” are omitted as surplus. The words “delegation made under clause (2) of this subsection” are substituted for “provisions of this reorganization plan” because the only provision of Reorganization Plan No. 26 of 1950 (eff. ","children":[{"tag":"date","attrib":{"date":"1950-07-31"},"text":"July 31, 1950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1281"},"text":"64 Stat. 1281","children":[],"tail":") that continues to have legal effect is section 2 that is restated in clause (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(4), before subclause (A), the word “detail” is substituted for “to use for, and in connection with” to eliminate unnecessary words. The words “in addition to details authorized under another law” are substituted for 31:1017(last sentence) to eliminate unnecessary words and because subsequent laws would also provide additional authority to detail. The words “and the several branches of the public service under its control” are omitted as being included in “Department”. The words “officers and employees” are substituted for “persons” for clarity and consistency in the revised title. In subclause (B), the words “agents or from the appropriation for the foregoing purpose” are omitted as unnecessary because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(5), the words “the proceeds thereof to be accounted for and paid into the Treasury of the United States” are omitted as unnecessary because of section 3302 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(6), the word “buy” is substituted for “make expenditures” for consistency in the revised title and with other titles of the Code. The words “officers or employees” are substituted for “civilian employees”, and the words “in carrying out their duties and powers” are substituted for “in the performance of their official duties”, for consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcdb0bed-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcdb0bee-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s502/b"},"text":"Pub. L. 111–203, § 502(b)","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s378/1/A"},"text":"Pub. L. 111–203, § 378(1)(A)","children":[],"tail":", inserted “and” at end of par. (1), substituted period for “; and” at end of par. (2), and struck out par. (3) which read as follows: “of the Director of the Office of Thrift Supervision;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s378/1/B"},"text":"Pub. L. 111–203, § 378(1)(B)","children":[],"tail":", struck out subsec. (e). Text read as follows: “The Secretary of the Treasury may not merge or consolidate the Office of Thrift Supervision, or any of the functions or responsibilities of the Office or the Director of such office, with the Office of the Comptroller of the Currency or the Comptroller of the Currency.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s307/b"},"text":"Pub. L. 101–73, § 307(b)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/s307/d"},"text":"Pub. L. 101–73, § 307(d)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcdb0bef-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcdb0bf0-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s378/1"},"text":"section 378(1) of Pub. L. 111–203","children":[],"tail":" effective on the transfer date, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s351"},"text":"section 351 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s906"},"text":"section 906 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s502/b"},"text":"section 502(b) of Pub. L. 111–203","children":[],"tail":" effective 1 day after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcdb0bf1-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Aircraft in Emergency Law Enforcement Support","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/52/tI/s107"},"text":"Pub. L. 104–52, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/476"},"text":"109 Stat. 476","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/52/tI/s107"},"text":"“The Secretary of the Treasury is authorized in fiscal year 1996 and hereafter, to use Treasury Department aircraft, with or without reimbursement, to assist bureaus within the Department of the Treasury or other Federal agencies, Departments or offices outside of the Department of the Treasury to provide emergency law enforcement support to protect human life, property, public health, or safety.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbcdb0bf2-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcdb0bf3-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Emergency Preparedness Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For assignment of certain emergency preparedness functions to Secretary of the Treasury, see Parts 1, 2, and 15 of Ex. Ord. No. 12656, ","children":[{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", 53 F.R. 47491, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5195"},"text":"section 5195 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
