{"tag":"section","attrib":{"id":"idbcd8c1d6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321"},"text":null,"children":[{"tag":"num","attrib":{"value":"321"},"text":"§ 321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority of the Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcd8c1d7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Treasury shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd8c1d8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare plans for improving and managing receipts of the United States Government and managing the public debt;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1d9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out services related to finances that the Secretary is required to perform;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1da-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue warrants for money drawn on the Treasury consistent with appropriations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1db-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mint coins, engrave and print currency and security documents, and refine and assay bullion, and may strike medals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1dc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prescribe regulations that the Secretary considers best calculated to promote the public convenience and security, and to protect the Government and individuals from fraud and loss, that apply to anyone who may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd8c1dd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive for the Government, Treasury notes, United States notes, or other Government securities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd8c1de-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be engaged or employed in preparing and issuing those notes or securities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1df-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect receipts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1e0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a view to prosecuting persons, take steps to discover fraud and attempted fraud involving receipts and decide on ways to prevent and detect fraud;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1e1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" maintain separate accounts of taxes received in each State, territory, and possession of the United States, and collection district, with each account listing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd8c1e2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each kind of tax;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd8c1e3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of each tax; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd8c1e4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the money paid as pay and allowances to officers and employees of the Department collecting taxes in that State, territory, possession, or district; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1e5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the President on major domestic and international prudential policy issues in connection with all lines of insurance except health insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd8c1e6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd8c1e7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe regulations to carry out the duties and powers of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1e8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delegate duties and powers of the Secretary to another officer or employee of the Department of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1e9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer within the Department the records, property, officers, employees, and unexpended balances of appropriations, allocations, and amounts of the Department that the Secretary considers necessary to carry out a delegation made under clause (2) of this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1ea-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" detail, in addition to details authorized under another law, not more than 6 officers and employees of the Department at any one time to enforce the laws related to the Department, except that of those 6 officers and employees not more than 4 officers and employees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd8c1eb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid from the appropriations for the collection of customs may be so detailed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd8c1ec-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid from the appropriations for internal revenue may be so detailed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd8c1ed-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid from the appropriations for suppressing counterfeiting and other crimes may be so detailed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1ee-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize, at rates and under conditions prescribed by the Secretary, the private use of telephone lines controlled by the Department when the use does not interfere with Department business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1ef-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buy arms and ammunition required by officers and employees of the Department in carrying out their duties and powers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1f0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any other provision of law, fulfill any requirement to issue a report on the financial condition of any fund on the books of the Treasury by including the required information in a consolidated report, except that information with respect to a specific fund shall be separately reported if the Secretary determines that the consolidation of such information would result in an unwarranted delay in the availability of such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd8c1f1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Duties and powers of officers and employees of the Department are vested in the Secretary except duties and powers—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd8c1f2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vested by subchapter II of chapter 5 of title 5 in administrative law judges employed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1f3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the Comptroller of the Currency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd8c1f4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd8c1f5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury may accept, hold, administer, and use gifts and bequests of property, both real and personal, for the purpose of aiding or facilitating the work of the Department of the Treasury. Gifts and bequests of money and the proceeds from sales of other property received as gifts or bequests shall be deposited in the Treasury in a separate fund and shall be disbursed on order of the Secretary of the Treasury. Property accepted under this paragraph, and the proceeds thereof, shall be used as nearly as possible in accordance with the terms of the gift or bequest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1f6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of the Federal income, estate, and gift taxes, property accepted under paragraph (1) shall be considered as a gift or bequest to or for the use of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1f7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury may invest and reinvest the fund in public debt securities with maturities suitable for the needs of the fund and bearing interest at rates determined by the Secretary of the Treasury, taking into consideration the current average market yield on outstanding marketable obligations of the United States of comparable maturities. Income accruing from the securities, and from any other property accepted under paragraph (1), shall be deposited to the credit of the fund, and shall be disbursed on order of the Secretary of the Treasury for purposes as nearly as possible in accordance with the terms of the gifts or bequests.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdb0be8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s321/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall, not less frequently than annually, make a public disclosure of the amount (and sources) of the gifts and bequests received under this subsection, and the purposes for which amounts in the separate fund established under this subsection are expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcdb0be9-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/880"},"text":"96 Stat. 880","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s445"},"text":"Pub. L. 98–369, div. A, title IV, § 445","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/816"},"text":"98 Stat. 816","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIII/s307/b"},"text":"Pub. L. 101–73, title III, § 307(b)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/353"},"text":"103 Stat. 353","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1132/b"},"text":"Pub. L. 104–66, title I, § 1132(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/725"},"text":"109 Stat. 725","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s378/1"},"text":"Pub. L. 111–203, title III, § 378(1)","children":[],"tail":", title V, § 502(b), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1570"},"text":"124 Stat. 1570","children":[],"tail":", 1588.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcdb0bea-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcdb0beb-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbcdb0bec-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"321(a)(1)– (3)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1002(less words between 1st and 2d semicolons and between 4th and 5th semicolons).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 248(less words between 4th and 5th semicolons).","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"321(a)(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(no source).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"321(a)(5)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:427.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 251(words after “Treasury” and before “shall prescribe forms of entries”).","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"321(a)(6)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1002(words between 1st and 2d semicolons).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"321(a)(7)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1011.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 376; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1934-05-10/ch277/s512/b"},"text":"May 10, 1934, ch. 277, § 512(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/759"},"text":"48 Stat. 759","children":[],"tail":"."}],"tail":null}],"tail":null}]