:null,"children":[{"tag":"html:p","attrib":{},"text":"31 App.:1803(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “be construed to” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “not paid under this chapter” are substituted for “which a Federal agency has failed to pay in accordance with the requirements of section 2 or 3 of this chapter” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the word “accruing” is added for clarity. The word “both” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “with respect to disputes concerning discounts”, “by the required payment date”, and “other allegations concerning” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd4d7c30-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd4d7c31-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/h/8/A"},"text":"Pub. L. 111–350, § 5(h)(8)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s7103"},"text":"section 7103 of title 41","children":[],"tail":"” for “section 6 of the Contract Disputes Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s605"},"text":"41 U.S.C. 605","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/h/8/B"},"text":"Pub. L. 111–350, § 5(h)(8)(B)","children":[],"tail":", substituted “chapter 71 of title 41” for “the Contract Disputes Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s601"},"text":"41 U.S.C. 601","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/h/8/C"},"text":"Pub. L. 111–350, § 5(h)(8)(C)","children":[],"tail":", substituted “section 7109(a)(1) and (b) of title 41” for “section 12 of the Contract Disputes Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s611"},"text":"41 U.S.C. 611","children":[],"tail":")” and “section 7109(a)(1) and (b) may” for “section 12 may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/h/8/D"},"text":"Pub. L. 111–350, § 5(h)(8)(D)","children":[],"tail":", substituted “chapter 71 of title 41” for “the Contract Disputes Act of 1978 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s601"},"text":"41 U.S.C. 601","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/496"},"text":"Pub. L. 100–496","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3906"},"text":"section 3906 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
