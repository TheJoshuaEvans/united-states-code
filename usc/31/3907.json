{"tag":"section","attrib":{"id":"idbd4d7c24-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3907"},"text":null,"children":[{"tag":"num","attrib":{"value":"3907"},"text":"§ 3907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd4d7c25-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A claim for an interest penalty not paid under this chapter may be filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7103"},"text":"section 7103 of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd4d7c26-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd4d7c27-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3907/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An interest penalty under this chapter does not continue to accrue—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd4d7c28-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3907/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after a claim for a penalty is filed under chapter 71 of title 41; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd4d7c29-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3907/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for more than one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4d7c2a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3907/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) of this subsection does not prevent an interest penalty from accruing under section 7109(a)(1) and (b) of title 41 after a penalty stops accruing under this chapter. A penalty accruing under section 7109(a)(1) and (b) may accrue on an unpaid contract payment and on the unpaid penalty under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd4d7c2b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3904"},"text":"section 3904 of this title","children":[],"tail":", this chapter does not require an interest penalty on a payment that is not made because of a dispute between the head of an agency and a business concern over the amount of payment or compliance with the contract. A claim related to the dispute, and interest payable for the period during which the dispute is being resolved, is subject to chapter 71 of title 41."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd4d7c2c-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452/s1/18/A"},"text":"Pub. L. 97–452, § 1(18)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2477"},"text":"96 Stat. 2477","children":[],"tail":", § 3906; renumbered § 3907, "},{"tag":"ref","attrib":{"href":"/us/pl/100/496/s9/a/1"},"text":"Pub. L. 100–496, § 9(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2460"},"text":"102 Stat. 2460","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/h/8"},"text":"Pub. L. 111–350, § 5(h)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3849"},"text":"124 Stat. 3849","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd4d7c2d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd4d7c2e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd4d7c2f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","chi