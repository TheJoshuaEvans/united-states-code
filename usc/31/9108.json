text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-12-06/ch557/s303"},"text":"Dec. 6, 1945, ch. 557, § 303","children":[],"tail":"(less (d)(1st sentence related to § 302)), "},{"tag":"html:a","attrib":{"href":"/us/stat/59/601"},"text":"59 Stat. 601","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1956-07-26/ch741/s201/a/4"},"text":"July 26, 1956, ch. 741, § 201(a)(4)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/667"},"text":"70 Stat. 667","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"May 7, 1971","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/12/s5"},"text":"Pub. L. 92–12, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/85/37"},"text":"85 Stat. 37","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 20, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/351/s301/c"},"text":"Pub. L. 95–351, § 301(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/514"},"text":"92 Stat. 514","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/35/s396/h/3"},"text":"Pub. L. 97–35, § 396(h)(3)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/441"},"text":"95 Stat. 441","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9108(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:868(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9108(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:868(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9108(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:868(d)(less 1st sentence related to 31:867).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “on or after ","children":[{"tag":"date","attrib":{"date":"1945-12-06"},"text":"December 6, 1945","children":[],"tail":"” are omitted as executed. The words “wholly owned or mixed-ownership” are omitted because of section 9101(1) of the revised title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the word “Before” is substituted for “which are” for clarity. The words “bonds, notes, debentures, and other similar” are omitted as surplus. The words “as have been” are omitted as executed. In clause (1), the words “terms and” are omitted as surplus. The restatement of the source provisions does not affect other existing laws.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “Government” is added for consistency. The words “for its own account and in its own right and interest, at any one time aggregating” and “his approval with respect to any transaction or classes of transactions subject to the provisions of . . . for such period of time and” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “agency” is substituted for “Federal agency” because of section 101 of the revised title. The words “any of the functions vested in him by” and “for such purpose” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), the words “(when the ownership, control, and operation of the Bank are converted under section 410(a) of the Rural Electrification Act of 1936 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s950/a"},"text":"7 U.S.C. 950(a)","children":[],"tail":"))” are added because of 7:943(c) and 950(a). The words “head of each” are added for consistency. The words “be required to” are omitted as surplus."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd90524e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1983 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 31:9107(c)(3) and 9108(d)(2) because the National Consumer Cooperative Bank is no longer a mixed-ownership Government corporation. Section 396(h)(2) and (3) and (i) of the Omnibus Budget Reconciliation Act of 1981 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/440"},"text":"95 Stat. 440","children":[],"tail":") provided that references to the Bank in sections 302 and 303(d)(2d sentence) of the Government Corporation Control Act would be deleted on the day after the Final Government Equity Redemption Date. "},{"tag":"ref","attrib":{"href":"/us/act/1981-12-23/s501/36"},"text":"Section 501(36) of the Act of December 23, 1981","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/97/101"},"text":"Pub. L. 97–101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1440"},"text":"95 Stat. 1440","children":[],"tail":"), provided that the Redemption Date was "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd90524f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd905250-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" struck out “the Rural Telephone Bank (when the ownership, control, and operation of the Bank are converted under section 410(a) of the Rural Electrification Act of 1936 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s950/a"},"text":"7 U.S.C. 950(a)","children":[],"tail":")),” after “do not apply to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452"},"text":"Pub. L. 97–452","children":[],"tail":" struck out “the National Consumer Cooperative Bank,” after “the Regional Banks for Cooperatives,” which had already been struck out by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":". See 1982 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s2"},"text":"Pub. L. 97–258, § 2","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), struck out “the National Consumer Cooperative Bank,” after “Regional Banks for Cooperatives,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd905251-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd905252-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452"},"text":"Pub. L. 97–452","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/452/s2/i"},"text":"section 2(i) of Pub. L. 97–452","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3331"},"text":"section 3331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd905253-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s2"},"text":"Pub. L. 97–258, § 2","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1062"},"text":"96 Stat. 1062","children":[],"tail":", provided that the amendment made by such section is effective "},{"tag":"date","attrib":{"date":"1982-01-01"},"text":"Jan. 1, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
