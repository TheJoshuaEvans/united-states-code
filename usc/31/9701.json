{"tag":"section","attrib":{"id":"idbd92c333-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9701"},"text":null,"children":[{"tag":"num","attrib":{"value":"9701"},"text":"§ 9701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees and charges for Government services and things of value","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd92c334-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the sense of Congress that each service or thing of value provided by an agency (except a mixed-ownership Government corporation) to a person (except a person on official business of the United States Government) is to be self-sustaining to the extent possible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd92c335-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of each agency (except a mixed-ownership Government corporation) may prescribe regulations establishing the charge for a service or thing of value provided by the agency. Regulations prescribed by the heads of executive agencies are subject to policies prescribed by the President and shall be as uniform as practicable. Each charge shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd92c336-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fair; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd92c337-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd92c338-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9701/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs to the Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd92c339-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9701/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of the service or thing to the recipient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd92c33a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9701/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public policy or interest served; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd92c33b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9701/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant facts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd92c33c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section does not affect a law of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd92c33d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9701/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibiting the determination and collection of charges and the disposition of those charges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd92c33e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9701/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribing bases for determining charges, but a charge may be redetermined under this section consistent with the prescribed bases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd92c33f-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1051"},"text":"96 Stat. 1051","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd92c340-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd92c341-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd92c342-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9701","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:483a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1951-08-31/ch376/s501"},"text":"Aug. 31, 1951, ch. 376, § 501","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/65/290"},"text":"65 Stat. 290","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “agency (except a mixed-ownership Government corporation)” are substituted for “Federal agency (including wholly owned Government corporations as defined in the Government Corporation Control Act of 1945 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s841"},"text":"31 U.S.C. 841","children":[],"tail":" et seq.]” because of section 101 of the revised title and for consistency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “each service or thing of value provided” are substituted for “any work, service, publication, report, document, benefit, privilege, authority, use, franchise, license, permit, certificate, registration or similar thing of value or utility performed, furnished, provided, granted, prepared, or issued” for consistency and to eliminate unnecessary words. The words “(including groups, associations, organizations, partnerships, corporations, or businesses)” are omitted as being included in “person” under 1:1.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “may prescribe regulations establishing the charge for a service or thing of value provided by the agency” are substituted for “is authorized by regulation . . . to prescribe therefor such fee, charge, or price, if any, as he shall determine, in case none exists, or redetermine, in case of any existing one” for consistency, to eliminate unnecessary words, and because of the restatement. In clause (1), the words “and equitable” are omitted as being included in “fair”. In clause (2)(A), the words “direct and indirect” are omitted as surplus. In clause (2)(B), the words “of the service or thing” are added for clarity. In clause (2)(D), the words “and any amount so determined or redetermined shall be collected and paid into the Treasury as miscellaneous receipts” are omitted as unnecessary because of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302/a"},"text":"section 3302(a) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is substituted for 31:483a(provisos) for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd92c343-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd92c344-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/393/tVI/s638/a"},"text":"Pub. L. 102–393, title VI, § 638(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1779"},"text":"106 Stat. 1779","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/393/tVI/s638/a"},"text":"“This section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9703"},"text":"section 9703 of this title","children":[],"tail":" and amending sections 981 and 982 of Title 18, Crimes and Criminal Procedure, "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1509"},"text":"section 1509 of Title 21","children":[],"tail":", Food and Drugs, "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s524"},"text":"section 524 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, and "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s2003"},"text":"section 2003 of Title 39","children":[],"tail":", Postal Service] may be cited as the ‘Treasury Forfeiture Fund Act of 1992’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
