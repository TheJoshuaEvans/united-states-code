{"tag":"section","attrib":{"id":"idbce96403-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s502"},"text":null,"children":[{"tag":"num","attrib":{"value":"502"},"text":"§ 502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbce96404-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the Office of Management and Budget is the Director of the Office of Management and Budget. The Director is appointed by the President, by and with the advice and consent of the Senate. Under the direction of the President, the Director shall administer the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce96405-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office has a Deputy Director of the Office of Management and Budget, appointed by the President, by and with the advice and consent of the Senate. The Deputy Director—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbce96406-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall carry out the duties and powers prescribed by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96407-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acts as the Director when the Director is absent or unable to serve or when the office of Director is vacant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce96408-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office has a Deputy Director for Management appointed by the President, by and with the advice and consent of the Senate. The Deputy Director for Management shall be the chief official responsible for financial management in the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce96409-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office has 3 Assistant Directors who shall carry out the duties and powers prescribed by the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce9640a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office may have not more than 6 additional officers, each of whom is appointed in the competitive service by the Director, with the approval of the President. Each additional officer shall carry out the duties and powers prescribed by the Director. The Director shall specify the title of each additional officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce9640b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Director and Deputy Director are absent or unable to serve or when the offices of Director and Deputy Director are vacant, the President may designate an officer of the Office to act as Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbce9640c-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/886"},"text":"96 Stat. 886","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/576/tII/s201"},"text":"Pub. L. 101–576, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2839"},"text":"104 Stat. 2839","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbce9640d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbce9640e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbce9640f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{}