ag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Dec. 28, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/220/s6"},"text":"Pub. L. 95–220, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1616"},"text":"91 Stat. 1616","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6104(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1705(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6104(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1705(b), (c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6104(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1705(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words in parentheses are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the word “Federal” is omitted as unnecessary. The words “system under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6102/a"},"text":"section 6102(a) of this title","children":[],"tail":"” are substituted for “data base” for clarity and consistency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), before clause (1), the text of 31:1705(e)(1) is omitted as unnecessary because of section 6102(c) of the revised title. The words “The Director” are added for clarity and consistency. The words “member of Congress” are substituted for “Members of Congress, Delegates, Resident Commissioners” for consistency. In clause (6), the words “depository library of United States Government publications” are substituted for “Federal deposit libraries” as being more precise. In clause (7), the word “depository” is substituted for “other local repositories” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd7d3f80-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd7d3f81-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/169/s4"},"text":"Pub. L. 98–169, § 4","children":[],"tail":", substituted “Administrator” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/169/s1/2"},"text":"Pub. L. 98–169, § 1(2)","children":[],"tail":", substituted “Director” for “Director of the Office of Management and Budget”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/169/s4"},"text":"Pub. L. 98–169, § 4","children":[],"tail":", substituted “Administrator” for “Director” in provisions preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/169/s3/e"},"text":"Pub. L. 98–169, § 3(e)","children":[],"tail":", amended par. (1) generally, substituting provisions requiring that the catalog contain all substantive information on domestic assistance programs that is in the system under section 6102(a)(1), (2), and (5)–(7) of this title, and such portions or summaries, as the Administrator considers appropriate, of information in the system under section 6102(a)(3), (4) of this title, at the time the catalog is prepared, for provision requiring that the catalog contain all such information in the system under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6102/a"},"text":"section 6102(a) of this title","children":[],"tail":" at the time the catalog was prepared."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b)(2), (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/169/s4"},"text":"Pub. L. 98–169, § 4","children":[],"tail":", substituted “Administrator” for “Director” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
