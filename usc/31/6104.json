{"tag":"section","attrib":{"id":"idbd7d3f69-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104"},"text":null,"children":[{"tag":"num","attrib":{"value":"6104"},"text":"§ 6104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Catalog of Federal domestic assistance programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7d3f6a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall prepare and publish each year a catalog of domestic assistance programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7d3f6b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In a form selected by the Administrator, the catalog shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d3f6c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7d3f6d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all substantive information on domestic assistance programs that, at the time the catalog is prepared, is in the system under paragraphs (1), (2), (5), (6), and (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6102/a"},"text":"section 6102(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d3f6e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such portions or summaries, as the Administrator considers appropriate, of the information on domestic assistance programs that, at the time the catalog is prepared, is in the system under paragraphs (3) and (4) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6102/a"},"text":"section 6102(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f6f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information the Administrator decides may be helpful to a potential applicant for or beneficiary of assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f70-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed index.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7d3f71-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When the Administrator decides it is necessary, the Administrator shall prepare and publish—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d3f72-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplements to the catalog; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f73-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specialized compilations by function of information in the catalog.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7d3f74-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator may distribute a catalog without cost to each—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d3f75-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" member of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f76-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" department, agency, and instrumentality of the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f77-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f78-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general purpose unit of a local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f79-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribe recognized by the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f7a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depository library of Government publications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f7b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6104/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" depository designated by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7d3f7c-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1002"},"text":"96 Stat. 1002","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/169/s1/2"},"text":"Pub. L. 98–169, § 1(2)","children":[],"tail":", 3(e), 4, "},{"tag":"date","attrib":{"date":"1983-11-29"},"text":"Nov. 29, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1113"},"text":"97 Stat. 1113","children":[],"tail":", 1114.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7d3f7d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd7d3f7e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"htm