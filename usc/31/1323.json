{"tag":"section","attrib":{"id":"idbd0ace4b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1323"},"text":null,"children":[{"tag":"num","attrib":{"value":"1323"},"text":"§ 1323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust funds for certain fees, donations, quasi-public amounts, and unearned amounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0ace4c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts from the following sources held in checking accounts of disbursing officials shall be deposited in the Treasury to the appropriate trust fund receipt accounts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0ace4d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1323/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unearned money, lands (Department of the Interior).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0ace4e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1323/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reentry permit fees (Department of Justice).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0ace4f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1323/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" naturalization fees (Department of Justice).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0ace50-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1323/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" registry fees (Department of Justice).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0ace51-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts deposited under subsection (a) of this section are appropriated for refunds. Earned parts of those amounts shall be transferred and credited to the appropriate receipt fund accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0ace52-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1323/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Donations, quasi-public amounts, and unearned amounts shall be deposited in the Treasury as trust funds and are appropriated for disbursement under the terms of the trusts when the donation or amount is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0ace53-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1323/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administered by officers and employees of the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0ace54-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1323/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carried in checking accounts of disbursing officials or others required to account to the Comptroller General (except clerks and marshals of the United States district courts).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0ace55-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/922"},"text":"96 Stat. 922","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0ace56-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd0ace57-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd0ace58-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1323(a), (b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:725r(less proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1934-06-26/ch756/s19"},"text":"June 26, 1934, ch. 756, § 19","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/1232"},"text":"48 Stat. 1232","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1944-12-21/ch631/s2"},"text":"Dec. 21, 1944, ch. 631, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/845"},"text":"58 Stat. 845","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1323(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:725r(proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “Effective ","children":[{"tag":"date","attrib":{"date":"1935-07-01"},"text":"July 1, 1935","children":[],"tail":"” are omitted as executed. In clauses (2)–(4), the words “Department of Justice” are substituted for “Labor Department” (subsequently changed to “Justice Department” because of Reorganization Plan No. 5 of 1940 (eff. "},{"tag":"date","attrib":{"date":"1940-06-14"},"text":"June 14, 1940","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/1238"},"text":"54 Stat. 1238","children":[],"tail":")) for consistency with title 28."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words related to Patent Office (subsequently changed to Patent and Trademark Office because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1975-01-02/s3"},"text":"section 3 of the Act of January 2, 1975","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/93/596"},"text":"Pub. L. 93–596","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1949"},"text":"88 Stat. 1949","children":[],"tail":")), are omitted as superseded by 35:42."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “officers and employees of the United States Government” are substituted for “officers of the United States by virtue of their official capacity” for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
