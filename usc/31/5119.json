":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5119(b)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:404.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1878-05-31/ch146"},"text":"May 31, 1878, ch. 146","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/20/87"},"text":"20 Stat. 87","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 30, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/66/s7"},"text":"Pub. L. 87–66, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/147"},"text":"75 Stat. 147","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:420.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3580.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:914.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:916.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5119(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:915(c)(words before last comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5119(c)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:405a–2.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:915(c)(words after last comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5119(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:917.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Secretary may not redeem” are substituted for “no . . . shall be redeemed” in 31:408a(less last proviso) because of the source provisions restated in section 321 of the revised title. The words “United States currency (including Federal reserve notes and circulating notes of Federal reserve banks and national banks)” are substituted for “currency of the United States” and the text of 31:444(1st sentence words between 2d and 3d semicolons) for consistency with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5103"},"text":"section 5103 of this title","children":[],"tail":" and to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “upon completion of the transfers and credits authorized and directed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s912"},"text":"section 912 of this title","children":[],"tail":"” in 31:915 and “and the amount of the payment credited as a public debt receipt in accordance with such section” are omitted as executed. In clause (B), the text of 31:405a–3(last sentence) and 31:915(a)(4) is consolidated. The text of 31:405a–3(1st sentence) is omitted as executed. In clauses (C) and (E), the citations in parentheses are included only for information purposes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “cancel and destroy” are substituted for “retired” in 31:914 for consistency in the revised section. The words “paragraph (1) of this subsection” are substituted for “Any currency the funds for the redemption or security of which have been transferred pursuant to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s912"},"text":"section 912 of this title","children":[],"tail":", and any Federal Reserve notes as to which payment has been made under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s913"},"text":"section 913 of this title","children":[],"tail":"” because of the restatement. The words “presented to the Secretary” are substituted for “presentation at the Treasury” because of the source provisions restated in section 321(c) of the revised title. The text of 31:916 is omitted as unnecessary because of the restatement. The text of 31:404 and 31:420 is omitted as superseded by the source provisions restated in this subsection and subsection (c). The words “All acts and parts of acts in conflict herewith are hereby repealed” in the Act of "},{"tag":"date","attrib":{"date":"1878-05-31"},"text":"May 31, 1878","children":[],"tail":" (ch. 146, "},{"tag":"ref","attrib":{"href":"/us/stat/20/87"},"text":"20 Stat. 87","children":[],"tail":"), are omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “When the Secretary makes a determination under this subsection” are added because of the restatement. The words “on the books of the Treasury” are omitted as surplus. The text of 31:405(e)(2)(1st sentence) is omitted as superseded by the source provisions restated in subsection (b).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “paper” is omitted as surplus. The words “(including circulating notes of Federal Reserve banks and national banks)” are substituted for “including bank notes” for consistency in the section. The words “heretofore or hereafter issued” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd598ae5-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd598ae6-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1890-07-14/ch708"},"text":"Act of July 14, 1890, ch. 708","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/289"},"text":"26 Stat. 289","children":[],"tail":", referred to in subsec. (b)(1)(C), which was known as the Sherman Purchase of Silver Act of "},{"tag":"date","attrib":{"date":"1890-07-14"},"text":"July 14, 1890","children":[],"tail":", was classified to sections 408, 410, 412, and 453 of former Title 31, and sections 122 and 145 of Title 12, Banks and Banking, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1069"},"text":"96 Stat. 1069","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4 of the Old Series Currency Adjustment Act, referred to in subsec. (b)(1)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/66/s4"},"text":"section 4 of Pub. L. 87–66","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-06-30"},"text":"June 30, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/146"},"text":"75 Stat. 146","children":[],"tail":", which was classified to section 913 of former Title 31, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1079"},"text":"96 Stat. 1079","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Acts ","children":[{"tag":"date","attrib":{"date":"1862-02-25"},"text":"February 25, 1862","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1862-07-11"},"text":"July 11, 1862","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1863-03-03"},"text":"March 3, 1863","children":[],"tail":", and resolution "},{"tag":"date","attrib":{"date":"1863-01-17"},"text":"January 17, 1863","children":[],"tail":", referred to in subsec. (b)(1)(E), are acts "},{"tag":"ref","attrib":{"href":"/us/act/1862-02-25/ch33"},"text":"Feb. 25, 1862, ch. 33","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/345"},"text":"12 Stat. 345","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/act/1862-07-11/ch142"},"text":"July 11, 1862, ch. 142","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/532"},"text":"12 Stat. 532","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/act/1863-03-03/ch73"},"text":"Mar. 3, 1863, ch. 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/709"},"text":"12 Stat. 709","children":[],"tail":", and resolution "},{"tag":"date","attrib":{"date":"1863-01-17"},"text":"Jan. 17, 1863","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/822"},"text":"12 Stat. 822","children":[],"tail":", respectively, which are not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd598ae7-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/390"},"text":"Pub. L. 102–390","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “The Secretary shall redeem from the general fund of the Treasury and cancel and destroy currency referred to in paragraph (1) of this subsection when the currency is presented to the Secretary.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
