{"tag":"section","attrib":{"id":"idbd598acf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119"},"text":null,"children":[{"tag":"num","attrib":{"value":"5119"},"text":"§ 5119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redemption and cancellation of currency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd598ad0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except to the extent authorized in regulations the Secretary of the Treasury prescribes with the approval of the President, the Secretary may not redeem United States currency (including Federal reserve notes and circulating notes of Federal reserve banks and national banks) in gold. However, the Secretary shall redeem gold certificates owned by the Federal reserve banks at times and in amounts the Secretary decides are necessary to maintain the equal purchasing power of each kind of United States currency. When redemption in gold is authorized, the redemption may be made only in gold bullion bearing the stamp of a United States mint or assay office in an amount equal at the time of redemption to the currency presented for redemption.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd598ad1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd598ad2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (c)(1) of this section, the following are public debts bearing no interest:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd598ad3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gold certificates issued before ","children":[{"tag":"date","attrib":{"date":"1934-01-30"},"text":"January 30, 1934","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd598ad4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" silver certificates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd598ad5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notes issued under the Act of ","children":[{"tag":"date","attrib":{"date":"1890-07-14"},"text":"July 14, 1890","children":[],"tail":" (ch. 708, "},{"tag":"ref","attrib":{"href":"/us/stat/26/289"},"text":"26 Stat. 289","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd598ad6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal Reserve notes for which payment was made under section 4 of the Old Series Currency Adjustment Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd598ad7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States currency notes, including those issued under ","children":[{"tag":"ref","attrib":{"href":"/us/act/1862-02-25/s1"},"text":"section 1 of the Act of February 25, 1862","children":[],"tail":" (ch. 33, "},{"tag":"ref","attrib":{"href":"/us/stat/12/345"},"text":"12 Stat. 345","children":[],"tail":"), the Act of "},{"tag":"date","attrib":{"date":"1862-07-11"},"text":"July 11, 1862","children":[],"tail":" (ch. 142, "},{"tag":"ref","attrib":{"href":"/us/stat/12/532"},"text":"12 Stat. 532","children":[],"tail":"), the resolution of "},{"tag":"date","attrib":{"date":"1863-01-17"},"text":"January 17, 1863","children":[],"tail":" (P.R. 9; "},{"tag":"ref","attrib":{"href":"/us/stat/12/822"},"text":"12 Stat. 822","children":[],"tail":"), "},{"tag":"ref","attrib":{"href":"/us/act/1863-03-03/s2"},"text":"section 2 of the Act of March 3, 1863","children":[],"tail":" (ch. 73, "},{"tag":"ref","attrib":{"href":"/us/stat/12/710"},"text":"12 Stat. 710","children":[],"tail":"), or "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5115"},"text":"section 5115 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd598ad8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Redemption, cancellation, and destruction of currency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd598ad9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" redeem any currency described in paragraph (1) from the general fund of the Treasury upon presentment to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd598ada-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cancel and destroy such currency upon redemption.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary shall not be required to reissue United States currency notes upon redemption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd598adb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd598adc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may determine the amount of the following United States currency that will not be presented for redemption because the currency has been destroyed or irretrievably lost:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd598add-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" circulating notes of Federal reserve banks and national banks issued before ","children":[{"tag":"date","attrib":{"date":"1929-07-01"},"text":"July 1, 1929","children":[],"tail":", for which the United States Government has assumed liability."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd598ade-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outstanding currency referred to in subsection (b)(1) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd598adf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Secretary makes a determination under this subsection, the Secretary shall reduce the amount of that currency outstanding by the amount the Secretary determines will not be redeemed and credit the appropriate receipt account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd598ae0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5119/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide a historical collection of United States currency, the Secretary may withhold from cancellation and destruction and transfer to a special account one piece of each design, issue, or series of each denomination of each kind of currency (including circulating notes of Federal reserve banks and national banks) after redemption. The Secretary may make appropriate entries in Treasury accounts because of the transfers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd598ae1-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/985"},"text":"96 Stat. 985","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/390/tII/s226/b"},"text":"Pub. L. 102–390, title II, § 226(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1630"},"text":"106 Stat. 1630","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tVI/s602/g/14"},"text":"Pub. L. 103–325, title VI, § 602(g)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2294"},"text":"108 Stat. 2294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd598ae2-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd598ae3-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd598ae4-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":