{"tag":"section","attrib":{"id":"idbd0f8929-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1349"},"text":null,"children":[{"tag":"num","attrib":{"value":"1349"},"text":"§ 1349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse personnel actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0f892a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1349/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer or employee of the United States Government or of the District of Columbia government violating section 1341(a) or 1342 of this title shall be subject to appropriate administrative discipline including, when circumstances warrant, suspension from duty without pay or removal from office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f892b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1349/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An officer or employee who willfully uses or authorizes the use of a passenger motor vehicle or aircraft owned or leased by the United States Government (except for an official purpose authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1344"},"text":"section 1344 of this title","children":[],"tail":") or otherwise violates section 1344 shall be suspended without pay by the head of the agency. The officer or employee shall be suspended for at least one month, and when circumstances warrant, for a longer period or summarily removed from office."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0f892c-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/926"},"text":"96 Stat. 926","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0f892d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd0f892e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd0f892f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1349(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:665(i)(1)(words before semicolon related to (a), (b)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3679(i)(1)(words before semicolon related to (a), (b)); ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1905-03-03/ch1484/s4"},"text":"Mar. 3, 1905, ch. 1484, § 4","children":[],"tail":"(1st par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/33/1257"},"text":"33 Stat. 1257","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1906-02-27/ch510/s3"},"text":"Feb. 27, 1906, ch. 510, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/48"},"text":"34 Stat. 48","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-06/ch896/s1211"},"text":"Sept. 6, 1950, ch. 896, § 1211","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/768"},"text":"64 Stat. 768","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1349(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:638a(c)(2)(2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1914-07-16/ch141/s5/c/2"},"text":"July 16, 1914, ch. 141, § 5(c)(2)","children":[],"tail":"(2d sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/38/508"},"text":"38 Stat. 508","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch744/s16/a"},"text":"Aug. 2, 1946, ch. 744, § 16(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/810"},"text":"60 Stat. 810","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “In addition to any penalty or liability under other law” are omitted as surplus. The words “District of Columbia government” are added because of section 47–105 of the D.C. Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “of the Government” and “from duty” are omitted as unnecessary because of the restatement. The word “pay” is substituted for “compensation” for consistency. The word “agency” is substituted for “department” because of section 101 of the revised title and for consistency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
