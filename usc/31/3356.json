{"tag":"section","attrib":{"id":"idbd2c39d7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3356"},"text":null,"children":[{"tag":"num","attrib":{"value":"3356"},"text":"§ 3356.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improving the use of data by executive agencies for curbing improper payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd2c39d8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3356/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prompt Reporting of Death Information by the Department of State and the Department of Defense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The procedure required to be established under section 7(a) of the Improper Payments Elimination and Recovery Improvement Act of 2012, as in effect on the day before the date of enactment of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c39d9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3356/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall continue to be in effect on and after the date of enactment of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39da-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3356/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be modified as determined appropriate by the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c39db-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3356/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prompt Reporting of Death Information by the Department of Veterans Affairs and the Office of Personnel Management","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, the Secretary of Veterans Affairs and the Director of the Office of Personnel Management shall establish a procedure under which the Secretary and the Director—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c39dc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3356/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall promptly and on a regular basis submit information relating to the deaths of individuals, including stopped payments data as applicable, to each executive agency for which the Director of the Office of Management and Budget determines receiving and using such information would be relevant and necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39dd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3356/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the centralized access of death data for the use of reducing improper payments, may identify additional Federal sources of death data and direct the data owner to provide that data to 1 or more executive agencies for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c39de-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3356/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance to Executive Agencies Regarding Data Access and Use for Improper Payments Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidance required to be issued under section 7(b) of the Improper Payments Elimination and Recovery Improvement Act of 2012, as in effect on the day before the date of enactment of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c39df-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3356/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall continue to be in effect on and after the date of enactment of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39e0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3356/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be modified as determined appropriate by the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd2c39e1-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117/s2/a"},"text":"Pub. L. 116–117, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/130"},"text":"134 Stat. 130","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd2c39e2-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd2c39e3-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd2c39e4-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in text, is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117"},"text":"Pub. L. 116–117","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 7 of the Improper Payments Elimination and Recovery Improvement Act of 2012, referred to in subsecs. (a) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/248/s7"},"text":"section 7 of Pub. L. 112–248","children":[],"tail":", which was formerly set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3321"},"text":"section 3321 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/117/s3/a/3"},"text":"Pub. L. 116–117, § 3(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/133"},"text":"134 Stat. 133","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
