{"tag":"section","attrib":{"id":"idbcd8c1b8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s315"},"text":null,"children":[{"tag":"num","attrib":{"value":"315"},"text":"§ 315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing in office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When the term of office of an officer of the Department of the Treasury ends, the officer may continue to serve until a successor is appointed and qualified.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbcd8c1b9-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/880"},"text":"96 Stat. 880","children":[],"tail":", § 309; renumbered § 310, "},{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIII/s307/a/1"},"text":"Pub. L. 101–73, title III, § 307(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/352"},"text":"103 Stat. 352","children":[],"tail":"; renumbered § 311, "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s361/a/1"},"text":"Pub. L. 107–56, title III, § 361(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/329"},"text":"115 Stat. 329","children":[],"tail":"; renumbered § 312, "},{"tag":"ref","attrib":{"href":"/us/pl/108/177/tI/s105/a/1/A"},"text":"Pub. L. 108–177, title I, § 105(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2603"},"text":"117 Stat.