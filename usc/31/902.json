{"tag":"section","attrib":{"id":"idbcfa051d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902"},"text":null,"children":[{"tag":"num","attrib":{"value":"902"},"text":"§ 902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority and functions of agency Chief Financial Officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcfa051e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agency Chief Financial Officer shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcfa051f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report directly to the head of the agency regarding financial management matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcfa0520-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee all financial management activities relating to the programs and operations of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcfa0521-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop and maintain an integrated agency accounting and financial management system, including financial reporting and internal controls, which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcfa0522-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with applicable accounting principles, standards, and requirements, and internal control standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa0523-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with such policies and requirements as may be prescribed by the Director of the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa0524-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with any other requirements applicable to such systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa0525-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcfa0526-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete, reliable, consistent, and timely information which is prepared on a uniform basis and which is responsive to the financial information needs of agency management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcfa0527-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and reporting of cost information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcfa0528-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of accounting and budgeting information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcfa0529-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/3/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the systematic measurement of performance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcfa052a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the head of the agency regarding the selection of the Deputy Chief Financial Officer of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcfa052b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" direct, manage, and provide policy guidance and oversight of agency financial management personnel, activities, and operations, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcfa052c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the preparation and annual revision of an agency plan to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcfa052d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the 5-year financial management plan prepared by the Director of the Office of Management and Budget under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3512/a/3"},"text":"section 3512(a)(3) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcfa052e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with the requirements established under sections 3515 and subsections (e) and (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3521"},"text":"section 3521 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa052f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of agency financial management budgets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa0530-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recruitment, selection, and training of personnel to carry out agency financial management functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa0531-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approval and management of agency financial management systems design or enhancement projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa0532-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of agency asset management systems, including systems for cash management, credit management, debt collection, and property and inventory management and control;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcfa0533-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepare and transmit, by not later than 60 days after the submission of the audit report required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3521/f"},"text":"section 3521(f) of this title","children":[],"tail":", an annual report to the agency head and the Director of the Office of Management and Budget, which shall include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcfa0534-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description and analysis of the status of financial management of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa0535-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual financial statements prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3515"},"text":"section 3515 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa0536-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the audit report transmitted to the head of the agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3521/f"},"text":"section 3521(f) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa0537-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the reports on internal accounting and administrative control systems submitted to the President and the Congress under the amendments made by the Federal Managers’ Financial Integrity Act of 1982 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/255"},"text":"Public Law 97–255","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa0538-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information the head of the agency considers appropriate to fully inform the President and the Congress concerning the financial management of the agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcfa0539-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the financial execution of the budget of the agency in relation to actual expenditures, and prepare and submit to the head of the agency timely performance reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcfa053a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review, on a biennial basis, the fees, royalties, rents, and other charges imposed by the agency for services and things of value it provides, and make recommendations on revising those charges to reflect costs incurred by it in providing those services and things of value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcfa053b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcfa053c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the authority otherwise provided by this section, each agency Chief Financial Officer—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcfa053d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (2), shall have access to all records, reports, audits, reviews, documents, papers, recommendations, or other material which are the property of the agency or which are available to the agency, and which relate to programs and operations with respect to which that agency Chief Financial Officer has responsibilities under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa053e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may request such information or assistance as may be necessary for carrying out the duties and responsibilities provided by this section from any Federal, State, or local governmental entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa053f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent and in such amounts as may be provided in advance by appropriations Acts, may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcfa0540-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into contracts and other arrangements with public agencies and with private persons for the preparation of financial statements, studies, analyses, and other services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcfa0541-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such payments as may be necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcfa0542-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (1)(B), this subsection does not provide to an agency Chief Financial Officer any access greater than permitted under any other law to records, reports, audits, reviews, documents, papers, recommendations, or other material of any Office of Inspector General established under chapter 4 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcfa0543-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/576/tII/s205/a"},"text":"Pub. L. 101–576, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2843"},"text":"104 Stat. 2843","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/49"},"text":"Pub. L. 117–286, § 4(b)(49)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4348"},"text":"136 Stat. 4348","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcfa0544-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcfa0545-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcfa0546-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Managers’ Financial Integrity Act of 1982, referred to in subsec. (a)(6)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/255"},"text":"Pub. L. 97–255","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/814"},"text":"96 Stat. 814","children":[],"tail":", which added subsec. (d) to section 66a of former Title 31, Money and Finance. Section 66a of former Title 31 was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1068"},"text":"96 Stat. 1068","children":[],"tail":", and reenacted by the first section thereof as "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3512"},"text":"section 3512 of this title","children":[],"tail":". Provisions relating to reports on internal accounting and administrative control systems are restated in section 3512(d)(2) and (3) of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcfa0547-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 4 of title 5.” for “the Inspector General Act of 1978 (5 U.S.C. App.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
