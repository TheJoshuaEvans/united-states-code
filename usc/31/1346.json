{"tag":"section","attrib":{"id":"idbd0d1902-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1346"},"text":null,"children":[{"tag":"num","attrib":{"value":"1346"},"text":"§ 1346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissions, councils, boards, and inter­agency and similar groups","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0d1903-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1346/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0d1904-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1346/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" public money and appropriations are not available to pay—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0d1905-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1346/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pay or expenses of a commission, council, board, or similar group, or a member of that group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0d1906-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1346/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses related to the work or the results of work or action of that group; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0d1907-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1346/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the detail or cost of personal services of an officer or employee from an executive agency in connection with that group; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0d1908-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1346/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accounting or disbursing official, absent a special appropriation to pay the account or charge, may not allow or pay an account or charge related to that group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0d1909-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1346/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriations of an executive agency are available for the expenses of an interagency group conducting activities of interest common to executive agencies when the group includes a representative of the agency. The representatives receive no additional pay because of membership in the group. An officer or employee of an executive agency not a representative of the group may not receive additional pay for providing services for the group.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0d190a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1346/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1347"},"text":"section 1347 of this title","children":[],"tail":", this section does not apply to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0d190b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1346/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commissions, councils, boards, or similar groups authorized by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0d190c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1346/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" courts-martial or courts of inquiry of the armed forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0d190d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1346/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contingent fund related to foreign relations at the disposal of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0d190e-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/925"},"text":"96 Stat. 925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0d190f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd0d1910-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd0d1911-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1346(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:672(1st sentence less words between 4th and 5th commas).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3681.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:673(less words between 11th comma and semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1909-03-04/ch299/s9"},"text":"Mar. 4, 1909, ch. 299, § 9","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/35/1027"},"text":"35 Stat. 1027","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1346(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:691.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-05-03/ch106/s214"},"text":"May 3, 1945, ch. 106, § 214","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/134"},"text":"59 Stat. 134","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1346(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:672(1st sentence words between 4th and 5th commas), (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:673(words between 11th comma and semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “executive agency” are substituted for “any executive department or other Government establishment” for clarity and because of section 102 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before subclause (A), the words “made by Congress” are omitted as surplus. In subclause (C), the words “the detail or cost of personal services of an officer” are substituted for “by detail, hereafter or heretofore made, or otherwise personal services” to eliminate unnecessary words and for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “of the Government” are omitted as surplus. The words “absent a special appropriation” are substituted for “until special appropriations shall have been made by law” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “On or after ","children":[{"tag":"date","attrib":{"date":"1945-05-03"},"text":"May 3, 1945","children":[],"tail":"” are omitted as executed. The words “interagency group” are substituted for “committees, boards, or other interagency groups” to eliminate unnecessary words. The words “includes a representative of the agency” are substituted for “composed in whole or in part of representatives thereof” for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “authorized by law” are substituted for “unless the creation . . . shall be or shall have been authorized by law” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “armed forces” are substituted for “military or naval service of the United States” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c)(3) is substituted for the last sentence of 31:672 to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
