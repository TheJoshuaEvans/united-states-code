{"tag":"section","attrib":{"id":"idbd250dca-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330"},"text":null,"children":[{"tag":"num","attrib":{"value":"3330"},"text":"§ 3330.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of Department of Veterans Affairs checks for the benefit of individuals in foreign countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd250dcb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250dcc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A check is deemed to be issued for sending to a foreign country and subject to this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3329"},"text":"section 3329 of this title","children":[],"tail":" if the check is—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd250dcd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" drawn on public money;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250dce-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for benefits under laws carried out by the Secretary of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250dcf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be sent to a person in the United States or a territory or possession of the United States, and the person is legally responsible for the care of an individual in a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250dd0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Veterans Affairs shall notify the Secretary of the Treasury of each check described under paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250dd1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Veterans Affairs may exempt a check from paragraph (1) of this subsection if the application of paragraph (1) would reduce, discontinue, or deny benefits for the care of a dependent of an individual in a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250dd2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the amount of checks (representing payments to an individual under laws administered by the Secretary of Veterans Affairs) transferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3329/b/4"},"text":"section 3329(b)(4) of this title","children":[],"tail":" equals $1,000, the amounts of additional checks (except checks under contracts of insurance) payable to the individual under those laws shall be deposited in the Treasury as miscellaneous receipts. An amount transferred under section 3329(b)(4) or deposited as miscellaneous receipts is deemed to be payment for all purposes to the individual entitled to payment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250dd3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the payee of a check for pension, compensation, or emergency officers’ retirement pay under laws administered by the Secretary of Veterans Affairs dies while the amount of the check is in the special deposit account, the amount is payable (subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3329"},"text":"section 3329 of this title","children":[],"tail":" and this section) as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250dd4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the death of the veteran, to the surviving spouse, or, if there is no surviving spouse, to children of the veteran under 18 years of age at the time of the veteran’s death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250dd5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the death of the surviving spouse, to children of the spouse under 18 years of age at the time of the spouse’s death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250dd6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the death of an apportionee of a part of the veteran’s pension, compensation, or emergency officers’ retirement pay but before all of the apportioned amount is paid to the veteran, the apportioned amount not paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250dd7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, only to the extent necessary to reimburse a person for burial expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250dd8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250dd9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A payment may be made under subsection (c) of this section only if a claim for payment is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd250dda-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" filed with the Secretary of Veterans Affairs by the end of the first year after the date of the death of the individual entitled to payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250ddb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completed by submitting the necessary evidence by the 6th month after the date the Secretary of Veterans Affairs requests the evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250ddc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3330/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment shall include only amounts due at the time of death under ratings or decisions existing at the time of the death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd250ddd-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/954"},"text":"96 Stat. 954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13"},"text":"Pub. L. 102–54, § 13","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3), (4)(A), "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/277"},"text":"105 Stat. 277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/f/1/I"},"text":"Pub. L. 103–272, § 4(f)(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1362"},"text":"108 Stat. 1362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd250dde-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd250ddf-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd250de0-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3330(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:123(provisos).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1940-10-09/ch796"},"text":"Oct. 9, 1940, ch. 796","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/54/1086"},"text":"54 Stat. 1086","children":[],"tail":", § 1(provisos); added "},{"tag":"html:a","attrib":{"href":"/us/act/1942-12-02/ch659"},"text":"Dec. 2, 1942, ch. 659","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/1028"},"text":"56 Stat. 1028","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3330(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:124(last par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1940-10-09/ch796"},"text":"Oct. 9, 1940, ch. 796","children":[],"tail":", §§ 2(last par.), 3(last par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/54/1086"},"text":"54 Stat. 1086","children":[],"tail":", 1087."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3330(c), (d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:125(last par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “laws carried out” are substituted for “laws administered”, and the words “Administrator of Veterans’ Affairs” and “Administrator” are substituted for “Veterans’ Administration”, for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the word “issued” is substituted for “drawn” for clarity and consistency. Clause (A) is substituted for “drawn against funds of the United States” for consistency in the chapter. In clause (C), the words “guardian, curator, conservator, or other” are omitted as surplus. The words “legally responsible for” are substituted for “vested with” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3329/b/4"},"text":"section 3329(b)(4) of this title","children":[],"tail":"” are substituted for “to the special deposit account” for clarity and because of the restatement. The words “deposited in” are substituted for “covered into” for clarity and consistency in the revised title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), before clause (1), the word “accruing” is omitted as surplus. In clauses (1) and (2), the words “surviving spouse” and “spouse” are substituted for “widow”, and the word “spouse’s” is substituted for “widow’s”, to conform to amendments made generally to title 38 by the Veterans Disability Compensation and Survivor Benefits Act of 1976 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/433"},"text":"Pub. L. 94–433","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1374"},"text":"90 Stat. 1374","children":[],"tail":"). In clause (1), the words “first to” are omitted as surplus. In clause (4), the word “only” is substituted for “no disbursement whatsoever of such pension, compensation, or emergency officers’ retirement pay shall be made or allowed except so much” to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1)(B), the word “completed” is substituted for “perfected” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), the words “and unpaid” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd250de1-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd250de2-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":" substituted “Secretary of Veterans Affairs” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13"},"text":"Pub. L. 102–54, § 13","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(4)(A), substituted “Department of Veterans Affairs” for “Veterans’ Administration” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13"},"text":"Pub. L. 102–54, § 13","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3)(A), substituted “Secretary of Veterans Affairs” for “Administrator of Veterans’ Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13"},"text":"Pub. L. 102–54, § 13","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3)(B), substituted “Secretary of Veterans Affairs” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13"},"text":"Pub. L. 102–54, § 13","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3)(C), substituted “laws administered by the Secretary of Veterans Affairs” for “laws carried out by the Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13"},"text":"Pub. L. 102–54, § 13","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3)(B), substituted “Secretary of Veterans Affairs” for “Administrator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
