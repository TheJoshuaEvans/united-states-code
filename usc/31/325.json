{"tag":"section","attrib":{"id":"idbcdb0c22-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s325"},"text":null,"children":[{"tag":"num","attrib":{"value":"325"},"text":"§ 325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International affairs authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcdb0c23-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary of the Treasury, the Secretary may provide officers and employees of the Department of the Treasury carrying out international affairs duties and powers of the Department with allowances and benefits comparable to those provided under chapter 9 of title I of the Foreign Service Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4081"},"text":"22 U.S.C. 4081","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdb0c24-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following amounts may be appropriated to the Secretary for the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcdb0c25-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s325/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $22,896,000 to carry out the international affairs duties and powers of the Department (including amounts for official functions and reception and representation expenses).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdb0c26-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s325/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not more than $1,000,000 for increases in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcdb0c27-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s325/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay, under section 5382(c) and subchapter I of chapter 53 of title 5 (except section 5305, or corresponding prior provision of such title), of officers and employees carrying out the duties and powers referred to in clause (1) of this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcdb0c28-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s325/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" departmental contributions attributable to those pay increases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcdb0c29-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s325/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowances and benefits, because of cost of living increases, provided under subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdb0c2a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s325/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Necessary amounts may be appropriated to the Secretary for each fiscal year beginning after ",