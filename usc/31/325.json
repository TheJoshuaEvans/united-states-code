e (1), the words “fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1982-09-30"},"text":"September 30, 1982","children":[],"tail":"” are substituted for “fiscal year 1982” for consistency in the revised title and with other titles of the Code. In clause (2), the word “pay” is substituted for “salaries” for consistency in the revised title and with other titles of the Code. The word “departmental” is substituted for “agency” because of the source provisions restated in section 321 of the revised title. The words “those pay increases” are substituted for “thereto” for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is substituted for the words “and such sums as may be necessary for each fiscal year thereafter” both times they appear.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcdb0c34-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcdb0c35-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" substituted “(except section 5305, or corresponding prior provision of such title)” for “(except section 5303)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcdb0c36-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcdb0c37-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" effective on such date as the President shall determine, but not earlier than 90 days, and not later than 180 days, after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see section 529 [title III, § 305] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcdb0c38-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study on Role of Gold in Domestic and International Monetary Systems; Establishment of Commission; Report to Congress; Availability of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/389/s10"},"text":"Pub. L. 96–389, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-07"},"text":"Oct. 7, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1555"},"text":"94 Stat. 1555","children":[],"tail":", as amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/47/s2"},"text":"Pub. L. 97–47, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-09-30"},"text":"Sept. 30, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/954"},"text":"95 Stat. 954","children":[],"tail":", provided that the Secretary of the Treasury establish and chair a commission consisting of three members of the Board of Governors of the Federal Reserve System, two members of the Council of Economic Advisors, and four private citizens with business, finance, or academic backgrounds, to be designated by the Secretary, and one majority and one minority member each from the Joint Economic Committee, the Senate Committee on Banking, Housing, and Urban Affairs, and the House Committee on Banking, Finance and Urban Affairs to be designated by the Speaker of the House and the President of the Senate, respectively. The commission was to conduct a study to assess and make recommendations with regard to the policy of the United States Government concerning the role of gold in domestic and international monetary systems, and transmit to Congress a report containing its findings and recommendations not later than "},{"tag":"date","attrib":{"date":"1982-03-31"},"text":"March 31, 1982","children":[],"tail":". Sums appropriated pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/95/612/s5"},"text":"section 5 of Public Law 95–612","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/pl/95/612/s5"},"text":"Pub. L. 95–612, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-08"},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3092"},"text":"92 Stat. 3092","children":[],"tail":", which was not classified to the Code] were made available to the commission to carry out its functions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
