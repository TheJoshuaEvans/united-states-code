{"tag":"section","attrib":{"id":"idbd57198b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5115"},"text":null,"children":[{"tag":"num","attrib":{"value":"5115"},"text":"§ 5115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States currency notes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd57198c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Treasury may issue United States currency notes. The notes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd57198d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are payable to bearer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd57198e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in a form and in denominations of at least one dollar that the Secretary prescribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd57198f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount of United States currency notes outstanding and in circulation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd571990-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be more than $300,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd571991-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be held or used for a reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd571992-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/983"},"text":"96 Stat. 983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd571993-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd571994-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd571995-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5115(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:401.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3571.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5115(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:402.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1874-06-20/ch343/s6"},"text":"June 20, 1874, ch. 343, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/18/124"},"text":"18 Stat. 124","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1875-01-14/ch15/s3"},"text":"Jan. 14, 1875, ch. 15, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/18/296"},"text":"18 Stat. 296","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “United States currency notes” are substituted for “United States notes” for clarity and consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the first sentence is added for clarity and because of the restatement. The words “shall not bear interest” are omitted because of the source provisions restated in section 5118 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “in circulation” are substituted for “to be used as a part of the circulation medium” to eliminate unnecessary words. In clause (1), the words “the sum of” are omitted as surplus. The words “which said sum shall appear in each monthly statement of the public debt” are omitted because of the source provisions restated in section 5118 of the revised title. In clause (2), the words “and no part thereof shall” are omitted because of the restatement. The text of section 3(less 2d sentence) of the Act of ","children":[{"tag":"date","attrib":{"date":"1875-01-14"},"text":"January 14, 1875","children":[],"tail":" (ch. 15, "},{"tag":"ref","attrib":{"href":"/us/stat/18/296"},"text":"18 Stat. 296","children":[],"tail":"), is omitted as executed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
