{"tag":"section","attrib":{"id":"idbd7fb0ea-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6505"},"text":null,"children":[{"tag":"num","attrib":{"value":"6505"},"text":"§ 6505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to provide specialized or technical services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7fb0eb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may prescribe statistical and other studies and compilations, development projects, technical tests and evaluations, technical information, training activities, surveys, reports, documents, and other similar services that an executive agency is especially competent and authorized by law to provide. The services prescribed must be consistent with and further the policy of the United States Government of relying on the private enterprise system to provide services reasonably and quickly available through ordinary business channels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7fb0ec-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of an executive agency may provide services prescribed by the President under this section to a State or local government when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7fb0ed-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" written request is made by the State or local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb0ee-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of pay and all other identifiable costs of providing the services is made to the executive agency by the State or local government making the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7fb0ef-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment received by an executive agency for providing services under this section shall be deposited to the credit of the principal appropriation from which the cost of providing the services has been paid or will be charged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7fb0f0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority under this section is in addition to authority under another law in effect on ","children":[{"tag":"date","attrib":{"date":"1968-10-16"},"text":"October 16, 1968","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7fb0f1-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1007"},"text":"96 Stat. 1007","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7fb0f2-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd7fb0f3-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd7fb0f4-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6505(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"42:4201(8).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/577"},"text":"Pub. L. 90–577","children":[],"tail":", §§ 108, 303, 305, "},{"tag":"html:a","attrib":{"href":"/us/stat/82/1100"},"text":"82 Stat. 1100","children":[],"tail":", 1102, 1103."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"42:4222(proviso, words after proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/577/s302"},"text":"Pub. L. 90–577, § 302","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/1102"},"text":"82 Stat. 1102","children":[],"tail":"; Reorg. Plan No. 2 of 1970, eff. "},{"tag":"html:span","attrib":{},"text":"July 1, 1970","children":[],"tail":", § 102(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/84/2085"},"text":"84 Stat. 2085","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6505(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"42:4222(words before proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6505(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"42:4223.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6505(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"42:4225.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “executive agency” are substituted for “Federal department or agency” and “department or agency of the executive branch of the Federal Government” because of the definition in sections 102 and 6501(3) of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the source provisions are consolidated to eliminate an unnecessary definition. The word “President” is substituted for “Director of the Office of Management and Budget” in 42:4222(proviso, words after proviso) because sections 101 and 102(a) of Reorganization Plan No. 2 of 1970 (eff. ","children":[{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2085"},"text":"84 Stat. 2085","children":[],"tail":") designated the Bureau of the Budget as the Office of Management and Budget and transferred all functions of the Bureau to the President. The words “rules and regulations” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “may” is substituted for “is authorized within his discretion” for clarity and to omit unnecessary words. The words “specialized or technical services” are omitted because of consolidation of the source provisions. The words “direct or indirect” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “Payment” is substituted for “moneys” for consistency in the section. The words “All” and “or any bureau or other administrative division thereof” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “and does not supersede” are omitted as unnecessary. The words “authority under another law in effect on ","children":[{"tag":"date","attrib":{"date":"1968-10-16"},"text":"October 16, 1968","children":[],"tail":"” are substituted for “authority now possessed” for clarity. The words “by any Federal department or agency with respect to furnishing services, whether on a reimbursable or nonreimbursable basis, to State and local units of government” are omitted as unnecessary."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd7fb0f5-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7fb0f6-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Performance of Specialized or Technical Services","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/541/tII/s211"},"text":"Pub. L. 106–541, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-11"},"text":"Dec. 11, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2592"},"text":"114 Stat. 2592","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/66/tI/s109"},"text":"Pub. L. 107–66, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/496"},"text":"115 Stat. 496","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/66/tI/s109"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘State’ has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6501"},"text":"section 6501 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corps of Engineers may provide specialized or technical services to a Federal agency (other than an agency of the Department of Defense) or a State or local government under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6505"},"text":"section 6505 of title 31","children":[],"tail":", United States Code, only if the chief executive of the requesting entity submits to the Secretary [of the Army]—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written request describing the scope of the services to be performed and agreeing to reimburse the Corps for all costs associated with the performance of the services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that includes adequate facts to establish that the services requested are not reasonably and quickly available through ordinary business channels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corps Agreement To Perform Services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, after receiving a request described in subsection (b) to provide specialized or technical services, shall, before entering into an agreement to perform the services—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the requirements of subsection (b) are met with regard to the request for services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute a certification that includes adequate facts to establish that the Corps is uniquely equipped to perform such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report to Congress.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than the last day of each calendar year, the Secretary shall provide to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate a report identifying any request submitted by a Federal agency (other than an agency of the Department of Defense) or a State or local government to the Corps to provide specialized or technical services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include, with respect to each request described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the scope of services requested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the certifications required under subsection (b) and (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated and final cost of the services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of reimbursement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the scope of services performed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copies of all certifications in support of the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Engineering Research and Development Center","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Engineering Research and Development Center is exempt from the requirements of this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7fb0f7-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transportation of State Prisoners","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/119/tI"},"text":"Pub. L. 105–119, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-26"},"text":"Nov. 26, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2444"},"text":"111 Stat. 2444","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/119/tI"},"text":"“That, for fiscal year 1998 and thereafter, the service of maintaining and transporting State, local, or territorial prisoners shall be considered a specialized or technical service for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6505"},"text":"31 U.S.C. 6505","children":[],"tail":", and any prisoners so transported shall be considered persons (transported for other than commercial purposes) whose presence is associated with the performance of a governmental function for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102"},"text":"49 U.S.C. 40102","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/a/tI"},"text":"Pub. L. 104–208, div. A, title I, § 101(a) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009"},"text":"110 Stat. 3009","children":[],"tail":", 3009–5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
