{"tag":"section","attrib":{"id":"idbd3a6a5a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3713"},"text":null,"children":[{"tag":"num","attrib":{"value":"3713"},"text":"§ 3713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority of Government claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd3a6a5b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd3a6a5c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3713/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A claim of the United States Government shall be paid first when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd3a6a5d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3713/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person indebted to the Government is insolvent and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd3a6a5e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3713/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the debtor without enough property to pay all debts makes a voluntary assignment of property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd3a6a5f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3713/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property of the debtor, if absent, is attached; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd3a6a60-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3713/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act of bankruptcy is committed; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3a6a61-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3713/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estate of a deceased debtor, in the custody of the executor or administrator, is not enough to pay all debts of the debtor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd3a6a62-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3713/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not apply to a case under title 11.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd3a6a63-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A representative of a person or an estate (except a trustee acting under title 11) paying any part of a debt of the person or estate before paying a claim of the Government is liable to the extent of the payment for unpaid claims of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd3a6a64-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/972"},"text":"96 Stat. 972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd3a6a65-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd3a6a66-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd3a6a67-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3713(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:191.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3466; ","children":[{"tag":"html:span","attrib":{},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/598/s322/a"},"text":"Pub. L. 95–598, § 322(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2678"},"text":"92 Stat. 2678","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3713(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:192.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3467; restated ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1934-05-10/ch277/s518/a"},"text":"May 10, 1934, ch. 277, § 518(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/760"},"text":"48 Stat. 760","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/598/s322/b"},"text":"Pub. L. 95–598, § 322(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2679"},"text":"92 Stat. 2679","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the word “claim” is substituted for “debts” for consistency. The word “due” is omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the word “paid” is substituted for “satisfied” for consistency. In clause (A)(i), the words “and the priority established shall extend as well to cases in which” are omitted because of the restatement. In clause (A)(ii), the word “property” is substituted for “estate and effects” to eliminate unnecessary words. The words “absconding, concealed, or” and “by process of law” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “The priority established under . . . however” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “A representative of a person or an estate” are substituted for “executor, administrator, or assignee, or other” for clarity and to eliminate unnecessary words. The words “for whom or for which he acts”, “satisfies and”, and “from such person or estate” are omitted as surplus. The word “liable” is substituted for “answerable in his own person and estate” for consistency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
