{"tag":"section","attrib":{"id":"idbd5bd4c1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135"},"text":null,"children":[{"tag":"num","attrib":{"value":"5135"},"text":"§ 5135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Citizens Coinage Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd5bd4c2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5bd4c3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is hereby established the Citizens Coinage Advisory Committee (in this section referred to as the “Advisory Committee”) to advise the Secretary of the Treasury on the selection of themes and designs for coins.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5bd4c4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight of advisory committee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Committee shall be subject to the authority of the Secretary of the Treasury (hereafter in this section referred to as the “Secretary”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5bd4c5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5bd4c6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall consist of 11 members appointed by the Secretary as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd5bd4c7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Seven persons appointed by the Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd5bd4c8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be appointed from among individuals who are specially qualified to serve on the Advisory Committee by virtue of their education, training, or experience as a nationally or internationally recognized curator in the United States of a numismatic collection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd5bd4c9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be appointed from among individuals who are specially qualified to serve on the Advisory Committee by virtue of their experience in the medallic arts or sculpture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd5bd4ca-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be appointed from among individuals who are specially qualified to serve on the Advisory Committee by virtue of their education, training, or experience in American history;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd5bd4cb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one of whom shall be appointed from among individuals who are specially qualified to serve on the Advisory Committee by virtue of their education, training, or experience in numismatics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd5bd4cc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three of whom shall be appointed from among individuals who can represent the interests of the general public in the coinage of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd5bd4cd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Four persons appointed by the Secretary on the basis of the recommendations of the following officials who shall make the selection for such recommendation from among citizens who are specially qualified to serve on the Advisory Committee by virtue of their education, training, or experience:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd5bd4ce-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One person recommended by the Speaker of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd5bd4cf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One person recommended by the minority leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd5bd4d0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One person recommended by the majority leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd5bd4d1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One person recommended by the minority leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5bd4d2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd5bd4d3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), members of the Advisory Committee shall be appointed for a term of 4 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd5bd4d4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms of initial appointees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As designated by the Secretary at the time of appointment, of the members first appointed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd5bd4d5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four of the members appointed under paragraph (1)(A) shall be appointed for a term of 4 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd5bd4d6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the four members appointed under paragraph (1)(B) shall be appointed for a term of 3 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd5bd4d7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three of the members appointed under paragraph (1)(A) shall be appointed for a term of 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5bd4d8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation of public advisory status","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No individual may be appointed to the Advisory Committee while serving as an officer or employee of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5bd4d9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation of service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each appointed member may continue to serve for up to 6 months after the expiration of the term of office to which such member was appointed until a successor has been appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5bd4da-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancy and removal.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd5bd4db-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any vacancy on the Advisory Committee shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd5bd4dc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Removal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Advisory Committee members shall serve at the discretion of the Secretary and may be removed at any time for good cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5bd4dd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chairperson of the Advisory Committee shall be appointed for a term of 1 year by the Secretary from among the members of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5bd4de-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay and expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the Advisory Committee shall serve without pay for such service but each member of the Advisory Committee shall be reimbursed from the United States Mint Public Enterprise Fund for travel, lodging, meals, and incidental expenses incurred in connection with attendance of such members at meetings of the Advisory Committee in the same amounts and under the same conditions as employees of the United States Mint who engage in official travel, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5bd4df-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd5bd4e0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Committee shall meet at the call of the Secretary, the chairperson, or a majority of the members, but not less frequently than twice annually.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd5bd4e1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Open meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each meeting of the Advisory Committee shall be open to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd5bd4e2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prior notice of meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Timely notice of each meeting of the Advisory Committee shall be published in the Federal Register, and timely notice of each meeting shall be made to trade publications and publications of general circulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5bd4e3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quorum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Seven members of the Advisory Committee shall constitute a quorum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5bd4e4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties of the Advisory Committee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Advisory Committee are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5bd4e5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advising the Secretary of the Treasury on any theme or design proposals relating to circulating coinage, bullion coinage, congressional gold medals and national and other medals produced by the Secretary of the Treasury in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5111"},"text":"section 5111 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5bd4e6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Advising the Secretary of the Treasury with regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd5bd4e7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the events, persons, or places that the Advisory Committee recommends be commemorated by the issuance of commemorative coins in each of the 5 calendar years succeeding the year in which a commemorative coin designation is made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd5bd4e8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mintage level for any commemorative coin recommended under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd5bd4e9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed designs for commemorative coins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5bd4ea-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The expenses of the Advisory Committee that the Secretary of the Treasury determines to be reasonable and appropriate shall be paid by the Secretary from the United States Mint Public Enterprise Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5bd4eb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Support, Technical Services, and Advice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the request of the Advisory Committee, or as necessary for the Advisory Committee to carry out the responsibilities of the Advisory Committee under this section, the Director of the United States Mint shall provide to the Advisory Committee the administrative support, technical services, and advice that the Secretary of the Treasury determines to be reasonable and appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5bd4ec-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the duties of the Advisory Committee under this section, the Advisory Committee may consult with the Commission of Fine Arts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5bd4ed-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5bd4ee-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than September 30 of each year, the Advisory Committee shall submit a report to the Secretary, the Committee on Financial Services of the House of Representatives and the Committee on Banking, Housing, and Urban Affairs of the Senate. Should circumstances arise in which the Advisory Committee cannot meet the September 30 deadline in any year, the Secretary shall advise the Chairpersons of the Committee on Financial Services of the House of Representatives and the Committee on Banking, Housing, and Urban Affairs of the Senate of the reasons for such delay and the date on which the submission of the report is anticipated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5bd4ef-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The report required by paragraph (1) shall describe the activities of the Advisory Committee during the preceding year and the reports and recommendations made by the Advisory Committee to the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5bd4f0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5135/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chapter ","children":[],"tail":"10"},{"tag":"inline","attrib":{},"text":" of Title ","children":[],"tail":"5"},{"tag":"inline","attrib":{},"text":" Does Not Apply","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the requirements of subsection (b)(8), chapter 10 of title 5 shall not apply with respect to the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd5bd4f1-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/390/tII/s229/a"},"text":"Pub. L. 102–390, title II, § 229(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1631"},"text":"106 Stat. 1631","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tV/s529/d"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title V, § 529(d)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–352; "},{"tag":"ref","attrib":{"href":"/us/pl/104/329/tIII/s303/a"},"text":"Pub. L. 104–329, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-20"},"text":"Oct. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4014"},"text":"110 Stat. 4014","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/15/tI/s103/a"},"text":"Pub. L. 108–15, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-23"},"text":"Apr. 23, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/616"},"text":"117 Stat. 616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/196"},"text":"Pub. L. 117–286, § 4(a)(196)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4327"},"text":"136 Stat. 4327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd5bd4f2-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd5bd4f3-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd5bd4f4-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of Title 5” for “Federal Advisory Committee Act” in heading and “chapter 10 of title 5” for “the Federal Advisory Committee Act” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/15"},"text":"Pub. L. 108–15","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text provided for the establishment of the Citizens Commemorative Coin Advisory Committee and contained provisions concerning its oversight, membership, duties, and funding, the term of each membership, and the compensation of each member."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/329"},"text":"Pub. L. 104–329","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “Each member appointed under clause (i) or (iii) of paragraph (3)(A) shall be appointed for a term of 4 years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s101/f/tV/s529/d/1"},"text":"Pub. L. 104–208, § 101(f) [title V, § 529(d)(1)]","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “No individual shall be appointed to serve as a member of the Advisory Committee for a term in excess of 5 years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s101/f/tV/s529/d/2"},"text":"Pub. L. 104–208, § 101(f) [title V, § 529(d)(2)]","children":[],"tail":", added par. (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd5bd4f5-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd5bd4f6-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Abolishment of Citizens Commemorative Coin Advisory Committee; Continuity of Members","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/15/tI/s103/b"},"text":"Pub. L. 108–15, title I, § 103(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2003-04-23"},"text":"Apr. 23, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/618"},"text":"117 Stat. 618","children":[],"tail":", 619, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/15/tI/s103/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Abolishment of Citizens Commemorative Coin Advisory Committee.","children":[],"tail":"—"}],"tail":null},{"tag":"content","attrib":{},"text":"Effective on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-04-23"},"text":"Apr. 23, 2003","children":[],"tail":"], the Citizens Commemorative Coin Advisory Committee (established by "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5135"},"text":"section 5135 of title 31","children":[],"tail":", United States Code, as in effect before the amendment made by subsection (a)) is hereby abolished."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuity of Members of Citizens Commemorative Coin Advisory Committee.","children":[],"tail":"—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5135/b"},"text":"section 5135(b) of title 31","children":[],"tail":", United States Code, any person who is a member of the Citizens Commemorative Coin Advisory Committee on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2003-04-23"},"text":"Apr. 23, 2003","children":[],"tail":"], other than the member of such committee who is appointed from among the officers or employees of the United States Mint, may continue to serve the remainder of the term to which such member was appointed as a member of the Citizens Coinage Advisory Committee in one of the positions as determined by the Secretary.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd5bd4f7-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Staggered Terms for Members of Citizens Commemorative Coin Advisory Committee","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/329/tIII/s303/b"},"text":"Pub. L. 104–329, title III, § 303(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-20"},"text":"Oct. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4014"},"text":"110 Stat. 4014","children":[],"tail":", provided that members serving on the Citizens Commemorative Coin Advisory Committee as of "},{"tag":"date","attrib":{"date":"1996-10-20"},"text":"Oct. 20, 1996","children":[],"tail":", would be deemed to have been appointed to terms which ended on "},{"tag":"date","attrib":{"date":"1997-12-31"},"text":"Dec. 31, 1997","children":[],"tail":", 1998, or 1999."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd5bd4f8-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Status of Members of Citizens Commemorative Coin Advisory Committee","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/329/tIII/s303/c"},"text":"Pub. L. 104–329, title III, § 303(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-20"},"text":"Oct. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4015"},"text":"110 Stat. 4015","children":[],"tail":", provided that members appointed to the Citizens Commemorative Coin Advisory Committee under clause (i) or (iii) of subsec. (a)(3)(A) of this section would not be treated as special Government employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
