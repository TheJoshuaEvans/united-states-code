{"tag":"section","attrib":{"id":"idbd92c319-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9503"},"text":null,"children":[{"tag":"num","attrib":{"value":"9503"},"text":"§ 9503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports about Government pension plans","children":[],"tail":null},{"tag":"subsection","attrib":{"status":"repealed","id":"idbd92c31a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"[(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/362/tXV/s1501/a"},"text":"Pub. L. 105–362, title XV, § 1501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3294"},"text":"112 Stat. 3294","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd92c31b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This chapter does not prevent a Government pension plan from using the services of an enrolled actuary employed by an agency administering the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd92c31c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The requirements of this section are satisfied with respect to the Thrift Savings Plan described under subchapter III of chapter 84 of title 5, by preparation and transmission of the report described under section 8439(b) of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd92c31d-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1050"},"text":"96 Stat. 1050","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tII/s2081"},"text":"Pub. L. 104–66, title II, § 2081","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/729"},"text":"109 Stat. 729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tXV/s1501/a"},"text":"Pub. L. 105–362, title XV, § 1501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3294"},"text":"112 Stat. 3294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd92c31e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd92c31f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd92c320-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9503(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:68a(a), (b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-12/ch946"},"text":"Sept. 12, 1950, ch. 946","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/832"},"text":"64 Stat. 832","children":[],"tail":", § 121; added "},{"tag":"html:span","attrib":{},"text":"Nov. 4, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/595/s1"},"text":"Pub. L. 95–595, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2541"},"text":"92 Stat. 2541","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9503(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:68a(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “Notwithstanding any other provision of law or any administrative determination to the contrary . . . Federal” are omitted as unnecessary. The words “and each plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s68c/b"},"text":"section 68c(b) of this title","children":[],"tail":"” are omitted as unnecessary because of the restatement. In clause (1), before subclause (A), the words “required by such section” are omitted as unnecessary because of the restatement. In subclause (A), the word “information” is substituted for “information and data” because it is inclusive and for consistency. In clause (4), the words “and shall not supersede” are omitted as surplus. In clause (5), the words “the Comptroller General deems” are omitted as unnecessary. The words “under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1023"},"text":"section 1023 of title 29","children":[],"tail":"” are omitted as unnecessary because of the restatement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “This chapter does not prevent” are substituted for “Nothing in this chapter shall preclude” for clarity. The words “or agencies” are omitted as unnecessary because of 1:1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd92c321-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd92c322-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/362"},"text":"Pub. L. 105–362","children":[],"tail":" struck out subsec. (a) which required Government pension plans to be subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s1023"},"text":"29 U.S.C. 1023","children":[],"tail":", except for officers or employees of the Central Intelligence Agency unless the President specifically approves application of the requirements of section 1023 in writing for such officers and employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbd92c323-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idbd92c324-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 12177. Delegation of Functions to Director of Office of Management and Budget and Secretary of the Treasury","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12177, ","children":[{"tag":"date","attrib":{"date":"1979-12-10"},"text":"Dec. 10, 1979","children":[],"tail":", 44 F.R. 71805, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President of the United States of America by Section 121(a)(1) of the Budget and Accounting Procedures Act of 1950, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/stat/92/2541"},"text":"92 Stat. 2541","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/595"},"text":"Public Law 95–595","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s68a"},"text":"31 U.S.C. 68a","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9503"},"text":"31 U.S.C. 9503","children":[],"tail":"] and "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"Section 301 of Title 3","children":[],"tail":" of the United States Code, and in order to provide consistency among the financial and actuarial statements of Federal Government pension plans, it is hereby ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1–101. All the functions vested in the President by Section 121(a) of the Budget and Accounting Procedures Act of 1950, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s68a"},"text":"31 U.S.C. 68a","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9503"},"text":"31 U.S.C. 9503","children":[],"tail":"], are delegated to the Director of the Office of Management and Budget. The Director may, from time to time, designate other officers or agencies of the Federal Government to perform any or all of the functions hereby delegated to the Director, subject to such instructions, limitations, and directions as the Director deems appropriate."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1–102. The head of an Executive agency responsible for the administration of any Federal Government pension plan within the meaning of Section 123(a) of the Budget and Accounting Procedures Act of 1950, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s68c"},"text":"31 U.S.C. 68c","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9502/1"},"text":"31 U.S.C. 9502(1)","children":[],"tail":"], except subsections (a)(9) and (b), shall ensure that the administrators of those plans comply with the form, manner, and time of filing as required by the Director of the Office of Management and Budget."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1–103. Subject to the provisions of Section 1–101 of this Order, and in the absence of any contrary delegation or direction by the Director, the Secretary of the Treasury, with respect to the development of the form and content of the annual reports, shall perform the functions set forth in Section 121(a) of the Budget and Accounting Procedures Act of 1950, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s68a"},"text":"31 U.S.C. 68a","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9503"},"text":"31 U.S.C. 9503","children":[],"tail":"]. In performing this function, the Secretary shall also be responsible for consulting with the Comptroller General."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Jimmy Carter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
