{"tag":"section","attrib":{"id":"idbd92c2d5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9307"},"text":null,"children":[{"tag":"num","attrib":{"value":"9307"},"text":"§ 9307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil actions and judgments against surety corporations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd92c2d6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd92c2d7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9307/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A surety corporation providing a surety bond under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9304"},"text":"section 9304 of this title","children":[],"tail":" may be sued in a court of the United States having jurisdiction of civil actions on surety bonds in—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd92c2d8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9307/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the judicial district in which the surety bond was provided; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd92c2d9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9307/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the district in which the principal office of the corporation is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd92c2da-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9307/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under sections 9304–9308 of this title, a surety bond is deemed to be provided in the district—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd92c2db-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9307/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the principal office of the surety corporation is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd92c2dc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9307/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which the surety bond is returnable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd92c2dd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9307/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the surety bond is filed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd92c2de-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9307/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the person required to provide a surety bond resided when the bond was provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd92c2df-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In a proceeding against a surety corporation providing a surety bond under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9304"},"text":"section 9304 of this title","children":[],"tail":", the corporation may not deny its power to provide a surety bond or to assume liability."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd92c2e0-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1049"},"text":"96 Stat. 1049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd92c2e1-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd92c2e2-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd92c2e3-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9307(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6:10.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9307(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6:12.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the words “corporation providing a surety bond” are substituted for “company doing business” for consistency. The words “in respect thereof” are omitted as surplus. The words “civil actions on surety bonds” are substituted for “actions or suits upon such recognizance, stipulation, bond, or undertaking” for consistency. In clause (A), the words “the surety bond was provided” are substituted for “such recognizance, stipulation, bond, or undertaking was made or guaranteed” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), before clause (A), the words “a surety bond is deemed to be provided” are substituted for “such recognizance, stipulation, bond, or undertaking shall be treated as made or guaranteed” for consistency. In clause (A), the words “principal office of the surety corporation” are substituted for “office” for clarity and consistency. In clause (D), the words “person required to provide a surety bond resided when the bond was provided” are substituted for “principal in such recognizance, stipulation, bond, or undertaking resided when it was made or guaranteed” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for 6:12 to eliminate unnecessary words and for consistency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
