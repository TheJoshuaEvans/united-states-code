{"tag":"section","attrib":{"id":"idbd7d3f5a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6103"},"text":null,"children":[{"tag":"num","attrib":{"value":"6103"},"text":"§ 6103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to computer information system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7d3f5b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall maintain a computerized information system providing access to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d3f5c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information described in paragraphs (1), (2), (5), (6), and (7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6102/a"},"text":"section 6102(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f5d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such portions or summaries, as the Administrator considers appropriate, of the information described in paragraphs (3) and (4) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7d3f5e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the greatest extent practicable, the Administrator shall provide for the widespread availability of the information by available computer terminals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7d3f5f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When the Administrator decides the efficiency of the information system under subsection (a) of this section requires it, the Administrator may make contracts with private organizations to obtain computer time-sharing services, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d3f60-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computer telecommunications networks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f61-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computer software; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f62-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" associated services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7d3f63-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1002"},"text":"96 Stat. 1002","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/169"},