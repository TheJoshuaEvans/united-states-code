{"tag":"section","attrib":{"id":"idbd846bfc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6708"},"text":null,"children":[{"tag":"num","attrib":{"value":"6708"},"text":"§ 6708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments of local government allocations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd846bfd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount allocated to a unit of general local government for a payment period may not exceed the adjusted taxes imposed by the unit of general local government as determined under section 6705(b)(3).","children":[{"tag":"ref","attrib":{"idref":"fn002112"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002112"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “6705(c)(3).”"}],"tail":" Amounts in excess of adjusted taxes shall be paid to the Governor of the State in which the unit of local government is located."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd846bfe-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"De Minimis Allocations to Units of General Local Government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the amount allocated to a unit of general local government (except an Indian tribe or an Alaskan native ","children":[{"tag":"ref","attrib":{"idref":"fn002113"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002113"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be capitalized."}],"tail":" village) for a payment period would be less than $5,000 but for this subsection or is waived by the governing authority of the unit of general local government, the Secretary shall pay the amount to the Governor of the State in which the unit is located."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd846bff-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Payments to States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Governor of a State shall use all amounts paid to the Governor under subsections (a) and (b) for programs described in section 6701(a)(2) in areas of the State where are located the units of general local government with respect to which amounts are paid under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd846c00-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6708/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"De Minimis Allocations to Indian Tribes and Alaskan Native Villages.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd846c01-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6708/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aggregation of de minimis allocations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the amount allocated to an Indian tribe or an Alaskan native ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" village for a payment period would be less than $5,000 but for this subsection or is waived by the chief elected official of the tribe or village, the amount—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd846c02-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6708/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be paid to the tribe or village (except under paragraph (2)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd846c03-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6708/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be aggregated with other such amounts and available for use by the Attorney General under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd846c04-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6708/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of aggregated amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts aggregated under paragraph (1) for a payment period shall be available for use by the Attorney General to make grants in the payment period on a competitive basis to Indian Tribes ","children":[{"tag":"ref","attrib":{"idref":"fn002114"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002114"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" and Alaskan native "},{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" village "},{"tag":"ref","attrib":{"idref":"fn002115"},"text":"4","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002115"},"text":null,"children":[{"tag":"num","attrib":{},"text":"4","children":[],"tail":" So in original. Probably should be “villages”."}],"tail":" for—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd846c05-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6708/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs described in section 6701(a)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd846c06-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6708/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renovating or building prisons or other correctional facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd846c07-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31001/a"},"text":"Pub. L. 103–322, title III, § 31001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1872"},"text":"108 Stat. 1872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd846c08-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd846c09-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"E