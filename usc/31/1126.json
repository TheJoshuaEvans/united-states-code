{"tag":"section","attrib":{"id":"idbd06141d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126"},"text":null,"children":[{"tag":"num","attrib":{"value":"1126"},"text":"§ 1126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program Management Improvement Officers and Program Management Policy Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd06141e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Management Improvement Officers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd06141f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each agency described in section 901(b) shall designate a senior executive of the agency, who has significant program and project management oversight responsibilities, as the Program Management Improvement Officer of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd061420-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Program Management Improvement Officer of an agency designated under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd061421-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement program management policies established by the agency under section 503(c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd061422-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a strategy for enhancing the role of program managers within the agency that includes the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd061423-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Enhanced training and educational opportunities for program managers that shall include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd061424-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training in the relevant competencies encompassed with program and project manager within the private sector for program managers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd061425-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training that emphasizes cost containment for large projects and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd061426-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mentoring of current and future program managers by experienced senior executives and program managers within the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd061427-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improved career paths and career opportunities for program managers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd061428-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan to encourage the recruitment and retention of highly qualified individuals to serve as program managers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd061429-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improved means of collecting and disseminating best practices and lessons learned to enhance program management across the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd06142a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Common templates and tools to support improved data gathering and analysis for program management and oversight purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd06142b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to department of defense","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall not apply to the Department of Defense to the extent that the provisions of this subsection are substantially similar to or duplicative of the provisions of chapter 87 of title 10. For purposes of paragraph (1), the Under Secretary of Defense for Acquisition and Sustainment (or a designee of the Under Secretary) shall be considered the Program Management Improvement Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd06142c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Management Policy Council.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd06142d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Office of Management and Budget a council to be known as the “Program Management Policy Council” (in this subsection referred to as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd06142e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose and functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall act as the principal interagency forum for improving agency practices related to program and project management. The Council shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd06142f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and assist the Deputy Director for Management of the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd061430-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review programs identified as high risk by the Government Accountability Office and make recommendations for actions to be taken by the Deputy Director for Management of the Office of Management and Budget or a designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd061431-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" discuss topics of importance to the workforce, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd061432-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" career development and workforce development needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd061433-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policy to support continuous improvement in program and project management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd061434-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" major challenges across agencies in managing programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd061435-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise on the development and applicability of standards governmentwide for program management transparency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd061436-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the information published on a website described in section 1122.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd061437-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd061438-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed of the following members:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd061439-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Five members from the Office of Management and Budget as follows:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd06143a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Director for Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd06143b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Office of Electronic Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd06143c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/3/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of Federal Procurement Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd06143d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/3/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Controller of the Office of Federal Financial Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd06143e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/3/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Performance and Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd06143f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Program Management Improvement Officer from each agency described in section 901(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd085d30-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other full-time or permanent part-time officer or employee of the Federal Government or member of the Armed Forces designated by the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd085d31-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson and vice chairperson.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idbd085d32-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Deputy Director for Management of the Office of Management and Budget shall be the Chairperson of the Council. A Vice Chairperson shall be elected by the members and shall serve a term of not more than 1 year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd085d33-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chairperson shall preside at the meetings of the Council, determine the agenda of the Council, direct the work of the Council, and establish and direct subgroups of the Council as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d34-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall meet not less than four times per fiscal year and may meet at the call of the Chairperson or a majority of the members of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d35-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1126/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each agency with a Project Management Improvement Officer serving on the Council shall provide administrative support to the Council, as appropriate, at the request of the Chairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd085d36-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/264/s2/b/1"},"text":"Pub. L. 114–264, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-14"},"text":"Dec. 14, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1372"},"text":"130 Stat. 1372","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tIX/s902/86"},"text":"Pub. L. 116–92, div. A, title IX, § 902(86)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1554"},"text":"133 Stat. 1554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVIII/s884"},"text":"Pub. L. 116–283, div. A, title VIII, § 884","children":[],"tail":", div. H, title XCVI, § 9601(c)(2)(D), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3790"},"text":"134 Stat. 3790","children":[],"tail":", 4828.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd085d37-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd085d38-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"idbd085d39-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Another section 1126, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s861/b/1"},"text":"Pub. L. 114–328, div. A, title VIII, § 861(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2299"},"text":"130 Stat. 2299","children":[],"tail":", which was substantially identical to section 1126 as added by "},{"tag":"ref","attrib":{"href":"/us/pl/114/264"},"text":"Pub. L. 114–264","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s810/b"},"text":"Pub. L. 115–91, div. A, title VIII, § 810(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1458"},"text":"131 Stat. 1458","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd085d3a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s884/1"},"text":"Pub. L. 116–283, § 884(1)","children":[],"tail":", inserted “, who has significant program and project management oversight responsibilities,” after “senior executive of the agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9601/c/2/D"},"text":"Pub. L. 116–283, § 9601(c)(2)(D)","children":[],"tail":", substituted “a website described in” for “the website of the Office of Management and Budget pursuant to”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s884/2"},"tex