{"tag":"section","attrib":{"id":"idbd275733-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3334"},"text":null,"children":[{"tag":"num","attrib":{"value":"3334"},"text":"§ 3334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cancellation and proceeds distribution of Treasury checks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd275734-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3334/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd275735-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3334/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide monthly to each agency that authorizes the issuance of Treasury checks a list of those checks issued for such agency on or after such effective date that have not been paid and have become more than 12 months old during the preceding month, beginning with the fourteenth month following the effective date of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd275736-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3334/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such checks shall be canceled by the Secretary and the proceeds thereof shall be returned to the agency concerned and credited to the appropriation or fund account initially charged for the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd275737-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3334/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Checks Issued Before Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd275738-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3334/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 18 months after the effective date of this section, the Secretary shall identify and cancel all Treasury checks issued before such effective date that have not been paid in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3328"},"text":"section 3328 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd275739-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3334/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proceeds from checks canceled pursuant to paragraph (1) shall be applied to eliminate the balances in accounts that represent uncollectible accounts receivable and other costs associated with the payment of checks and check claims by the Department of the Treasury on behalf of all payment certifying agencies. Any remaining proceeds shall be deposited to the miscellaneous receipts of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd27573a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3334/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Effect on Underlying Obligation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to affect the underlying obligation of the United States, or any agency thereof, for which a Treasury check was issued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd27573b-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/tX/s1003"},"text":"Pub. L. 100–86, title X, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/658"},"text":"101 Stat. 658","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd27573c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd27573d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd27573e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Such effective date, and the effective date of this section, referred to in subsecs. (a)(1) and (b)(1), is 6 months after ","children":[{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", or on such later date as the Secretary of the Treasury may prescribe in regulations. See Effective Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd27573f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd275740-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", or on such later date as the Secretary of the Treasury may prescribe in regulations, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/s1006"},"text":"section 1006 of Pub. L. 100–86","children":[],"tail":", set out as an Effective Date of 1987 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3328"},"text":"section 3328 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd275741-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provision permitting Secretary of the Treasury to prescribe rules, regulations, and procedures as necessary to implement this section, including recertification of Treasury checks which have been canceled or for which a claim has been asserted or barred, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/s1005"},"text":"section 1005 of Pub. L. 100–86","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3328"},"text":"section 3328 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
