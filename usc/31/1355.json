{"tag":"section","attrib":{"id":"idbd0f89ab-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1355"},"text":null,"children":[{"tag":"num","attrib":{"value":"1355"},"text":"§ 1355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of funds for portraits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0f89ac-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1355/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No funds appropriated or otherwise made available to the Federal Government may be used to pay for the painting of a portrait of an officer or employee of the Federal Government, including the President, the Vice President, a Member of Congress, the head of an executive agency, or the head of an office of the legislative branch.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f89ad-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1355/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f89ae-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1355/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “executive agency” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s133"},"text":"section 133 of title 41","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f89af-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1355/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Member of Congress” includes a 