{"tag":"section","attrib":{"id":"idbd5e4511-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142"},"text":null,"children":[{"tag":"num","attrib":{"value":"5142"},"text":"§ 5142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bureau of Engraving and Printing Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd5e4512-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Department of the Treasury has a Bureau of Engraving and Printing Fund. Amounts—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5e4513-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Fund are available to operate the Bureau of Engraving and Printing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5e4514-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the Fund remain available until expended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5e4515-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be appropriated to the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5e4516-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Fund consists of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5e4517-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property and physical assets (except buildings and land) acquired by the Bureau;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5e4518-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all amounts received by the Bureau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5e4519-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceeds from the disposition of property and assets acquired by the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5e451a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The capital of the Fund consists of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5e451b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts appropriated to the Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5e451c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical assets of the Bureau (except buildings and land) as of the close of business ","children":[{"tag":"date","attrib":{"date":"1951-06-30"},"text":"June 30, 1951","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5e451d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all payments made after ","children":[{"tag":"date","attrib":{"date":"1974-06-30"},"text":"June 30, 1974","children":[],"tail":", under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5143"},"text":"section 5143 of this title","children":[],"tail":" at prices adjusted to permit buying capital equipment and to provide future working capital."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5e451e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall deposit each fiscal year, in the Treasury as miscellaneous receipts, amounts accruing to the Fund in the prior fiscal year that the Secretary decides are in excess of the needs of the Fund. However, the Secretary may use the excess amounts to restore capital of the Fund reduced by the difference between the charges for services of the Bureau and the cost of providing those services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5e451f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5142/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall maintain a special deposit account in the Treasury for the Fund. The Secretary shall credit the account with amounts appropriated to the Fund and receipts of the Bureau without depositing the receipts in the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd5e4520-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/990"},"text":"96 Stat. 990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd5e4521-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd5e4522-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd5e4523-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5142(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:181a(a)(1st sentence), (d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-08-04/ch558/s2"},"text":"Aug. 4, 1950, ch. 558, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/409"},"text":"64 Stat. 409","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5142(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:181a(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5142(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:181a(a)(last sentence), (b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:181(note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 31, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/81/s100"},"text":"Pub. L. 95–81, § 100","children":[],"tail":"(par. under heading “Bureau of Engraving and Printing”), "},{"tag":"html:a","attrib":{"href":"/us/stat/91/342"},"text":"91 Stat. 342","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5142(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:181a(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5142(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:181a(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “as of ","children":[{"tag":"date","attrib":{"date":"1951-07-01"},"text":"July 1, 1951","children":[],"tail":"” are omitted as executed. In clause (1), the words “subsequent to "},{"tag":"date","attrib":{"date":"1951-06-30"},"text":"June 30, 1951","children":[],"tail":"” are omitted as executed. In clause (2), the words “remain available until expended” are substituted for “shall be available without fiscal year limitation” for consistency in the revised title and with other titles of the United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “amounts received by the Bureau” are substituted for “all amounts recoverable as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s181"},"text":"section 181 of this title","children":[],"tail":" for the costs of work and services performed by the Bureau, and all other amounts receivable by the Bureau from whatever sources derived” to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “amounts appropriated to the Fund” are substituted for “an initial appropriation by the Congress to the fund of not to exceed $5,000,000 and such additional amounts as from time to time may be appropriated for the purposes of the fund” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “such inventories and other physical assets to be capitalized at fair and reasonable values to be determined by the Secretary” are omitted as executed. The words “receivables and the inventories” are omitted as covered by “physical assets”. The words “unexpended balances of appropriations” are omitted as unnecessary because of clause (1).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “$5,000,000, to remain available until expended” are omitted as unnecessary because of the source provision restated in subsection (a)(2) of this section. The text of 31:181a(a)(3) and (b) is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “each fiscal year” are substituted for “ensuing fiscal year”, and the words “prior fiscal year” are added, because of the restatement. The word “Secretary” is added because of sections 301 and 303 of the revised title. The words “decides are in excess of the needs of the Fund” are substituted for “surplus” for consistency in the chapter. The words “may use” are substituted for “may be applied first” to eliminate unnecessary words. The word “reduced” is substituted for “impairment” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “Secretary shall maintain” are substituted for “shall be established” because of sections 301 and 303 of the revised title and to eliminate executed words. The words “in the Treasury” are substituted for “with the Treasurer of the United States” because of Department of the Treasury Order 229 of ","children":[{"tag":"date","attrib":{"date":"1974-01-14"},"text":"January 14, 1974","children":[],"tail":" (39 F.R. 2280). The text of 31:181a(f)(last sentence) is omitted as unnecessary because of the source provisions restated in section 3325 of the revised title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd5e4524-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd5e4525-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Replacement Currency Production Facility","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6/dD/tI/s127"},"text":"Pub. L. 116–6, div. D, title I, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-15"},"text":"Feb. 15, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/149"},"text":"133 Stat. 149","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dE/tI/s127"},"text":"Pub. L. 117–328, div. E, title I, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4660"},"text":"136 Stat. 4660","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dE/tI/s127"},"text":"“Beginning in fiscal year 2019 and for each fiscal year thereafter, amounts in the Bureau of Engraving and Printing Fund may be used for the acquisition of necessary land for, and construction of, a replacement currency production facility, including public improvements in the area around such facility to mitigate traffic impacts caused by the construction and occupancy of the facility.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
