{"tag":"section","attrib":{"id":"idbd76130c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5351"},"text":null,"children":[{"tag":"num","attrib":{"value":"5351"},"text":"§ 5351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of financial crime-free communities support program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd76130d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5351/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury, in consultation with the Attorney General, shall establish a program to support local law enforcement efforts in the development and implementation of a program for the detection, prevention, and suppression of money laundering and related financial crimes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd76130e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5351/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program, the Secretary of the Treasury, in consultation with the Attorney General, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd76130f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5351/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make and track grants to grant recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd761310-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5351/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for technical assistance and training, data collection, and dissemination of information on state-of-the-art practices that the Secretary determines to be effective in detecting, preventing, and suppressing money laundering and related financial crimes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd761311-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5351/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the general administration of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd761312-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5351/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall appoint an administrator to carry out the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd761313-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5351/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may employ any necessary staff and may enter into contracts or agreements with Federal and State law enforcement agencies to delegate authority for the execution of grants and for such other activities necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd761314-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/310/s2/a"},"text":"Pub. L. 105–310, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2946"},"text":"112 Stat. 2946","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
