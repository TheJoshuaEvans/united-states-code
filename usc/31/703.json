b":{},"text":"31:42(a)(1st sentence words after comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18/s302/a"},"text":"June 10, 1921, ch. 18, § 302(a)","children":[],"tail":"(1st sentence words after 1st comma, last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/42/23"},"text":"42 Stat. 23","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Apr. 3, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/226/s104/a"},"text":"Pub. L. 96–226, § 104(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/314"},"text":"94 Stat. 314","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"703(a)(2), (3)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:42(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18"},"text":"June 10, 1921, ch. 18","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/42/20"},"text":"42 Stat. 20","children":[],"tail":", § 302(b); added "},{"tag":"html:span","attrib":{},"text":"Apr. 3, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/226/s104/a"},"text":"Pub. L. 96–226, § 104(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/314"},"text":"94 Stat. 314","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"703(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43(1st par. 1st, 2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18/s303"},"text":"June 10, 1921, ch. 18, § 303","children":[],"tail":"(1st par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/42/23"},"text":"42 Stat. 23","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Apr. 3, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/226/s104/b/1"},"text":"Pub. L. 96–226, § 104(b)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/315"},"text":"94 Stat. 315","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"703(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:42(a)(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"703(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1944-06-27/ch286/s101"},"text":"June 27, 1944, ch. 286, § 101","children":[],"tail":"(last par. on p. 371), "},{"tag":"html:a","attrib":{"href":"/us/stat/58/371"},"text":"58 Stat. 371","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"703(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43(1st par. 3d–last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"703(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:42a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/426/s203/a"},"text":"Pub. L. 88–426, § 203(a)","children":[],"tail":", (b), "},{"tag":"html:a","attrib":{"href":"/us/stat/78/415"},"text":"78 Stat. 415","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Dec. 16, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/206/s219/1"},"text":"Pub. L. 90–206, § 219(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/639"},"text":"81 Stat. 639","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Aug. 9, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/82/s204/b"},"text":"Pub. L. 94–82, § 204(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/89/421"},"text":"89 Stat. 421","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a)(1), (b), (d), and (e), the word “Deputy” is substituted for “Assistant” because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1971-07-09/s101"},"text":"section 101 of the Act of July 9, 1971","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/92/51"},"text":"Pub. L. 92–51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/143"},"text":"85 Stat. 143","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “The Comptroller General and Deputy Comptroller General” are added because of the restatement. The words “by and” are added for consistency. The words “and shall receive salaries of $10,000 and $7,500 a year, respectively” in section 302(a)(1st sentence words after 2d comma) of the Budget and Accounting Act, 1921 (ch. 18, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/42/23"},"text":"42 Stat. 23","children":[],"tail":"), are omitted as superseded by subsection (f) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), before clause (A), the words “after ","children":[{"tag":"date","attrib":{"date":"1980-04-03"},"text":"April 3, 1980","children":[],"tail":"” are omitted as executed. In clause (E), the words “of the United States” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “because of a vacancy in the office of the Comptroller General” are substituted for “under paragraph (1)” for clarity. The word “recommend” is substituted for “submit” and “submitted” for consistency. The words “to the President for consideration the names of”, “for the Office of Comptroller General”, and “within his discretion” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “the term of . . . is 15 years” are substituted for “shall hold office for fifteen years” for consistency. The words “eligible for” are omitted as surplus. The words “the term of . . . expires on” are substituted for “shall hold office from the date of his appointment until” to eliminate unnecessary words and for consistency. The words “to fill a vacancy in the Office of” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “carries out duties and powers prescribed” are substituted for “perform such duties as may be assigned” for consistency. The words “to him” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “officer or” are added for consistency in the revised title. The text of section 101(last par. on p. 371 words before colon) of the Act of ","children":[{"tag":"date","attrib":{"date":"1944-06-27"},"text":"June 27, 1944","children":[],"tail":" (ch. 286, "},{"tag":"ref","attrib":{"href":"/us/stat/58/371"},"text":"58 Stat. 371","children":[],"tail":"), is omitted as expired."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(1), before clause (A), the words “from his office” are omitted as surplus. In clause (A), the words “and for no other cause and in no other manner” are omitted as surplus. In clause (B), before subclause (i), the words “opportunity for a” are added for consistency. The words “guilty of” are omitted as surplus. In subclause (i), the word “disability” is substituted for “incapacitated” for consistency in the chapter and with title 5. In subclause (iv), the words “in office” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(2), the words “from office” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), before clause (1), the words “basic pay” are substituted for “compensation” for consistency with other titles of the United States Code. In clauses (1) and (2), the words “of the United States” and “positions at” are omitted as surplus. In clause (1), the words “of subchapter II of chapter 53 of title 5” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcebd4bb-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcebd4bc-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426"},"text":"Pub. L. 100–426","children":[],"tail":" substituted “may retire after becoming 70 years of age and completing 10 years of service as Comptroller General or Deputy Comptroller General (as the case may be)” for “retires on becoming 70 years of age”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcebd4bd-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbcebd4be-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Governmental Affairs of Senate changed to Committee on Homeland Security and Governmental Affairs of Senate, effective ","children":[{"tag":"date","attrib":{"date":"2005-01-04"},"text":"Jan. 4, 2005","children":[],"tail":", by Senate Resolution No. 445, One Hundred Eighth Congress, "},{"tag":"date","attrib":{"date":"2004-10-09"},"text":"Oct. 9, 2004","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Government Operations of House of Representatives treated as referring to Committee on Government Reform and Oversight of House of Representatives by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/14/s1/a"},"text":"section 1(a) of Pub. L. 104–14","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s21"},"text":"section 21 of Title 2","children":[],"tail":", The Congress. Committee on Government Reform and Oversight of House of Representatives changed to Committee on Government Reform of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, "},{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":". Committee on Government Reform of House of Representatives changed to Committee on Oversight and Government Reform of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, "},{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcebd4bf-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426"},"text":"Pub. L. 100–426","children":[],"tail":" effective after end of 60-day period beginning "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/426/s208"},"text":"section 208 of Pub. L. 100–426","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s772"},"text":"section 772 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbcebd4c0-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcebd4c1-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Salary Increases","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1987—Salaries of Comptroller General and Deputy Comptroller General increased respectively to $89,500 and $82,500 per annum, on recommendation of the President of the United States, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s358"},"text":"section 358 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Salaries of Comptroller General and Deputy Comptroller General increased respectively to $57,500 and $52,500 per annum, on recommendation of the President of the United States, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s358"},"text":"section 358 of Title 2","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Salaries of Comptroller General and Assistant Comptroller General increased respectively to $42,500 and $40,000 per annum, on recommendation of the President of the United States, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s358"},"text":"section 358 of Title 2","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
