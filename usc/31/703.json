{"tag":"section","attrib":{"id":"idbcebd49b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703"},"text":null,"children":[{"tag":"num","attrib":{"value":"703"},"text":"§ 703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller General and Deputy Comptroller General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcebd49c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcebd49d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General and Deputy Comptroller General are appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcebd49e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When a vacancy occurs in the office of Comptroller General or Deputy Comptroller General, a commission is established to recommend individuals to the President for appointment to the vacant office. The commission shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcebd49f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Speaker of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcebd4a0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President pro tempore of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcebd4a1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the majority and minority leaders of the House of Representatives and the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcebd4a2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chairmen and ranking minority members of the Committee on Governmental Affairs of the Senate and the Committee on Government Operations of the House; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcebd4a3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the office of Deputy Comptroller General is vacant, the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcebd4a4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A commission established because of a vacancy in the office of the Comptroller General shall recommend at least 3 individuals. The President may ask the commission to recommend additional individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcebd4a5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (e) of this section, the term of the Comptroller General is 15 years. The Comptroller General may not be reappointed. The term of the Deputy Comptroller General expires on the date an individual is appointed Comptroller General. The Deputy Comptroller General may continue to serve until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcebd4a6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Deputy Comptroller General—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcebd4a7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carries out duties and powers prescribed by the Comptroller General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcebd4a8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acts for the Comptroller General when the Comptroller General is absent or unable to serve or when the office of Comptroller General is vacant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcebd4a9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General shall designate an officer or employee of the Government Accountability Office to act as Comptroller General when the Comptroller General and Deputy Comptroller General are absent or unable to serve or when the offices of Comptroller General and Deputy Comptroller General are vacant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcebd4aa-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcebd4ab-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A Comptroller General or Deputy Comptroller General may retire after becoming 70 years of age and completing 10 years of service as Comptroller General or Deputy Comptroller General (as the case may be). Either may be removed at any time by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcebd4ac-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impeachment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcebd4ad-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" joint resolution of Congress, after notice and an opportunity for a hearing, only for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcebd4ae-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permanent disability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcebd4af-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inefficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcebd4b0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neglect of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcebd4b1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/e/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" malfeasance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcebd4b2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/e/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a felony or conduct involving moral turpitude.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcebd4b3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Comptroller General or Deputy Comptroller General removed from office under paragraph (1) of this subsection may not be reappointed to the office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcebd4b4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The annual rate of basic pay of the—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcebd4b5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Comptroller General is equal to the rate for level II of the Executive Schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcebd4b6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s703/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Deputy Comptroller General is equal to the rate for level III of the Executive Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcebd4b7-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/888"},"text":"96 Stat. 888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/426/tII/s201"},"text":"Pub. L. 100–426, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1599"},"text":"102 Stat. 1599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcebd4b8-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","a