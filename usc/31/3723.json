{"tag":"section","attrib":{"id":"idbd4195d5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3723"},"text":null,"children":[{"tag":"num","attrib":{"value":"3723"},"text":"§ 3723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small claims for privately owned property damage or loss","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd4195d6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of an agency (except a military department of the Department of Defense or the Coast Guard) may settle a claim for not more than $1,000 for damage to, or loss of, privately owned property that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd4195d7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3723/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is caused by the negligence of an officer or employee of the United States Government acting within the scope of employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd4195d8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3723/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be settled under chapter 171 of title 28.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd4195d9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A claim under this section may be allowed only if it is presented to the head of the agency within one year after it accrues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd4195da-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3723/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A claim under this section may be paid as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of this title","children":[],"tail":" only if the claimant accepts the amount of the settlement in complete satisfaction of the claim against the Government."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd4195db-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/975"},"text":"96 Stat. 975","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd4195dc-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd4195dd-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd4195de-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"