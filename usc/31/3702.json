l":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3702(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:236.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1928-04-10/ch334"},"text":"Apr. 10, 1928, ch. 334","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/45/413"},"text":"45 Stat. 413","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “Comptroller General” are substituted for “General Accounting Office” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Except as provided in this chapter or another law” are added for clarity. The words “and demands whatever” and “and adjusted” are omitted as surplus. The words “officers or employees of the General Accounting Office” are substituted for “of his subordinates” for clarity and consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “or demand” are omitted as surplus. The word “Government” is substituted for “United States” for consistency in the revised title and with other titles of the Code. The word “representative” is substituted for “agent or attorney” to eliminate unnecessary words. The words “received by the Comptroller General” are substituted for “received in said office” for clarity and consistency. The words “the date” are omitted as surplus. Clause (A) is added for clarity. In clause (B), the words “cognizable by the General Accounting Office under sections 71 and 236 of this title” are omitted as unnecessary because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “member of the armed forces” are substituted for “person serving in the military or naval forces of the United States” for consistency with title 10. The words “to the Comptroller General” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the words “to the claimant” are omitted as surplus. The words “not received in the time required” are substituted for “barred by” because of the restatement. The words “no further communication is required” are substituted for “such action shall be a complete response without further communication” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the text of 31:122(1st sentence words before 2d comma and last sentence) is omitted as executed. The words “Secretary of the Treasury” are substituted for “Treasury Department” for consistency. The word “Secretary” is substituted for “Treasurer of the United States” because of Department of the Treasury Order 229 of ","children":[{"tag":"date","attrib":{"date":"1974-01-14"},"text":"January 14, 1974","children":[],"tail":" (39 F.R. 2280)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “report . . . on” are substituted for “submit the same . . . by a special report . . . the material facts” to eliminate unnecessary words. The words “or demand” are omitted as surplus. The word “Government” is substituted for “United States”, and the words “presented under this section” are substituted for “filed in the General Accounting Office” for consistency. The words “lawfully”, “the use of”, and “thereon” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd381fd1-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1983 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 31:3702(b)(2) by inserting a word inadvertently omitted in the codification of title 31.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd381fd2-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd381fd3-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this subsection, referred to in subsec. (c)(1), probably means the effective date of subsec. (c) of this section as amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/s1004/b"},"text":"section 1004(b) of Pub. L. 100–86","children":[],"tail":", which is effective 6 months after "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", or on such later date as the Secretary of the Treasury may prescribe in regulations. See Effective Date of 1987 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd381fd4-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/s635/a"},"text":"Pub. L. 107–314, § 635(a)","children":[],"tail":". See 2002 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s635/b/1"},"text":"Pub. L. 107–314, § 635(b)(1)","children":[],"tail":", substituted “The Secretary of Defense” for “Upon the request of the Secretary concerned (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of title 37","children":[],"tail":", United States Code), the Secretary of Defense”, struck out “and, subject to paragraph (2), settle the claim” before period at end of first sentence, and inserted at end “In the case of a claim by or with respect to a member of the uniformed services who is not under the jurisdiction of the Secretary of a military department, such a waiver may be made only upon the request of the Secretary concerned (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of title 37","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s635/a"},"text":"Pub. L. 107–314, § 635(a)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":", substituted “a claim referred to in subsection (a)(1)(A)” for “a claim for pay, allowances, or payment for unused accrued leave under title 37 or a claim for retired pay under title 10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314/s635/b/2"},"text":"Pub. L. 107–314, § 635(b)(2)","children":[],"tail":", substituted “under subsection (a)(1)(A)” for “under paragraph (1)” and inserted before period at end “, except that in the case of a claim for retired pay or survivor benefits, if the obligation claimed would have been paid from a trust fund if timely paid, the payment of the claim shall be made from that trust fund”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 664(a)], inserted “payments for unused accrued leave,” after “transportation,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title VI, § 664(b)], substituted “claim for pay, allowances, or payment for unused accrued leave under title 37 or a claim for retired pay under title 10” for “claim for pay or allowances provided under title 37”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s1012/1"},"text":"Pub. L. 105–85, § 1012(1)","children":[],"tail":", substituted “Secretary of Defense” for “Comptroller General”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85/s1012/2"},"text":"Pub. L. 105–85, § 1012(2)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “Payment of a claim settled under paragraph (1) shall be subject to the availability of appropriations for payment of that particular claim.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s202/n/1/A"},"text":"Pub. L. 104–316, § 202(n)(1)(A)","children":[],"tail":", struck out “of the Comptroller General” after “Authority” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s202/n/1/B"},"text":"Pub. L. 104–316, § 202(n)(1)(B)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “Except as provided in this chapter or another law, the Comptroller General shall settle all claims of or against the United States Government. A claim that was not administratively examined before submission to the Comptroller General shall be examined by 2 officers or employees of the General Accounting Office independently of each other.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s202/n/1/C"},"text":"Pub. L. 104–316, § 202(n)(1)(C)","children":[],"tail":", in introductory provisions substituted “The claim must be received by the official responsible under subsection (a) for settling the claim or by the agency that conducts the activity from which the claim arises within 6 years after the claim accrues except—” for “The claim must be received by the Comptroller General within 6 years after the claim accrues except—”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s202/n/1/D"},"text":"Pub. L. 104–316, § 202(n)(1)(D)","children":[],"tail":", substituted “received” for “presented to the Comptroller General” and “in paragraph” for “in clause”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s202/n/1/E"},"text":"Pub. L. 104–316, § 202(n)(1)(E)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “The Comptroller General shall return a claim not received in the time required under this subsection with a copy of this subsection and no further communication is required.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s202/n/1/F"},"text":"Pub. L. 104–316, § 202(n)(1)(F)","children":[],"tail":", substituted “official responsible under subsection (a) for settling the claim” for “Comptroller General” before “shall report to Congress” and “official” for “Comptroller General” before “believes” and before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86"},"text":"Pub. L. 100–86","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “A claim on a check or warrant that the records of the Comptroller General or the Secretary of the Treasury show as being paid must be presented to the Comptroller General or the Secretary within 6 years after the check or warrant was issued.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452"},"text":"Pub. L. 97–452","children":[],"tail":" inserted “this” before “subsection”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd381fd5-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd381fd6-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1056/e/2"},"text":"Pub. L. 109–163, div. A, title X, § 1056(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3440"},"text":"119 Stat. 3440","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/383/dA/tX/s1075/h/3"},"text":"Pub. L. 111–383, div. A, title X, § 1075(h)(3)","children":[],"tail"