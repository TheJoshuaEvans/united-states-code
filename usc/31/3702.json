{"tag":"section","attrib":{"id":"idbd381fb7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702"},"text":null,"children":[{"tag":"num","attrib":{"value":"3702"},"text":"§ 3702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to settle claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd381fb8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in this chapter or another law, all claims of or against the United States Government shall be settled as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd381fb9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense shall settle—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd381fba-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" claims involving uniformed service members’ pay, allowances, travel, transportation, payments for unused accrued leave, retired pay, and survivor benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd381fbb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" claims by transportation carriers involving amounts collected from them for loss or damage incurred to property incident to shipment at Government expense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd381fbc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Personnel Management shall settle claims involving Federal civilian employees’ compensation and leave.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd381fbd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of General Services shall settle claims involving expenses incurred by Federal civilian employees for official travel and transportation, and for relocation expenses incident to transfers of official duty station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd381fbe-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Management and Budget shall settle claims not otherwise provided for by this subsection or another provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd381fbf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd381fc0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A claim against the Government presented under this section must contain the signature and address of the claimant or an authorized representative. The claim must be received by the official responsible under subsection (a) for settling the claim or by the agency that conducts the activity from which the claim arises within 6 years after the claim accrues except—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd381fc1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as provided in this chapter or another law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd381fc2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a claim of a State, the District of Columbia, or a territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd381fc3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the claim of a member of the armed forces accrues during war or within 5 years before war begins, the claim must be received within 5 years after peace is established or within the period provided in paragraph (1) of this subsection, whichever is later.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd381fc4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A claim that is not received in the time required under this subsection shall be returned with a copy of this subsection, and no further communication is required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd381fc5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"One-Year Limit for Check Claims","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd381fc6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any claim on account of a Treasury check shall be barred unless it is presented to the agency that authorized the issuance of such check within 1 year after the date of issuance of the check or the effective date of this subsection, whichever is later.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd381fc7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection affects the underlying obligation of the United States, or any agency thereof, for which a Treasury check was issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd381fc8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The official responsible under subsection (a) for settling the claim shall report to Congress on a claim against the Government that is timely presented under this section that may not be adjusted by using an existing appropriation, and that the official believes Congress should consider for legal or equitable reasons. The report shall include recommendations of the official.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd381fc9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd381fca-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may waive the time limitations set forth in subsection (b) or (c) in the case of a claim referred to in subsection (a)(1)(A). In the case of a claim by or with respect to a member of the uniformed services who is not under the jurisdiction of the Secretary of a military department, such a waiver may be made only upon the request of the Secretary concerned (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of title 37","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd381fcb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment of a claim settled under subsection (a)(1)(A) shall be made from an appropriation that is available, for the fiscal year in which the payment is made, for the same purpose as the appropriation to which the obligation claimed would have been charged if the obligation had been timely paid, except that in the case of a claim for retired pay or survivor benefits, if the obligation claimed would have been paid from a trust fund if timely paid, the payment of the claim shall be made from that trust fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd381fcc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3702/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not apply to a claim in excess of $25,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd381fcd-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/970"},"text":"96 Stat. 970","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/452/s1/14"},"text":"Pub. L. 97–452, § 1(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2470"},"text":"96 Stat. 2470","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/tX/s1004/b"},"text":"Pub. L. 100–86, title X, § 1004(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/659"},"text":"101 Stat. 659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tVI/s608"},"text":"Pub. L. 104–201, div. A, title VI, § 608","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2542"},"text":"110 Stat. 2542","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tII/s202/n/1"},"text":"Pub. L. 104–316, title II, § 202(n)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3843"},"text":"110 Stat. 3843","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1012"},"text":"Pub. 