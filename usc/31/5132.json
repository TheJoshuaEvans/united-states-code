,{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:369.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3552; restated ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-10/ch172"},"text":"May 10, 1950, ch. 172","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/157"},"text":"64 Stat. 157","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 5, 1962","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/643/s2"},"text":"Pub. L. 87–643, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/76/440"},"text":"76 Stat. 440","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/35/s382/b/1"},"text":"Pub. L. 97–35, § 382(b)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/432"},"text":"95 Stat. 432","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5132(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:361(1st sentence words after 1st comma, last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1878-06-19/ch329/s1"},"text":"June 19, 1878, ch. 329, § 1","children":[],"tail":"(2d sentence words before last semicolon on p. 191), "},{"tag":"html:a","attrib":{"href":"/us/stat/20/191"},"text":"20 Stat. 191","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1898-07-07/ch571"},"text":"July 7, 1898, ch. 571","children":[],"tail":"(7th par. 1st sentence words after 1st comma, last sentence under heading “Mints and Assay Offices”), "},{"tag":"html:a","attrib":{"href":"/us/stat/30/661"},"text":"30 Stat. 661","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5132(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:253.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 345.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “Secretary of the Treasury shall deposit in the Treasury as miscellaneous receipts” are substituted for “shall . . . be covered into the Treasury” in 31:369 because of the source provisions restated in section 321(c) of the revised title. The words “amounts the Secretary receives from the operations of the Bureau of the Mint” are substituted for “The money arising from all charges and deductions on and from gold and silver bullion and from all other sources” for clarity and to eliminate unnecessary words. The words “amounts from” are substituted for “money arising from the manufacture and sale of” to eliminate unnecessary words. The words “numismatic items” are substituted for “medals, proof coins, and uncirculated coins” for consistency with section 5111(a)(3) of the revised title. The words “minting coins” are substituted for “silver or minor coinage” for consistency with section 5112 of the revised title. The words “made by law” are omitted as surplus. The words “on estimates furnished by the Secretary of the Treasury” are omitted because of section 1108 of the revised title. The text of 31:273(1st, 2d sentences) is omitted because of section 321 of the revised title and the other source provisions restated in this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “ending September 30” are added for clarity and consistency in the revised title. The words “to pay costs” are substituted for “for all expenditures (salaries and expenses)” for consistency in the revised title and to eliminate unnecessary words. The words “not herein otherwise provided for” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “refining” is substituted for “parting and refining” for consistency in the revised chapter. The words “mints and assay offices” are substituted for “coinage mints and assay office at New York” because of the source provisions restated in section 5131(b) of the revised title. The words “pursuant to law” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the text of 31:253(less 18th–38th words) is omitted as superseded by the source provisions restated in section 321(c) of the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd598b43-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd598b44-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1983 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5132(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31 App.:369.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/253/s202"},"text":"Pub. L. 97–253, § 202","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/790"},"text":"96 Stat. 790","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd598b45-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1984 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This is necessary because the language was restated by section 382(h)(1) of the Omnibus Budget Reconciliation Act of 1981 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/432"},"text":"95 Stat. 432","children":[],"tail":") but inadvertently codified as 31:5132(a)(1) (last sentence) by "},{"tag":"ref","attrib":{"href":"/us/act/1982-09-13/s1"},"text":"section 1 of the Act of September 13, 1982","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/989"},"text":"96 Stat. 989","children":[],"tail":".)"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd598b46-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd598b47-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Strategic and Critical Materials Stock Piling Act, referred to in subsec. (a)(2)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190"},"text":"act June 7, 1939, ch. 190","children":[],"tail":", as revised generally by "},{"tag":"ref","attrib":{"href":"/us/pl/96/41/s2"},"text":"Pub. L. 96–41, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-30"},"text":"July 30, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/319"},"text":"93 Stat. 319","children":[],"tail":", which is classified generally to subchapter III (§ 98 et seq.) of chapter 5 of Title 50, War and National Defense. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98"},"text":"section 98 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd598b48-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" substituted “not less than 90 percent silver” for “90 percent silver and 10 percent copper”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/445"},"text":"Pub. L. 106–445","children":[],"tail":" substituted “paragraphs (2)” for “paragraphs (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/390/s225/b/3"},"text":"Pub. L. 102–390, § 225(b)(3)","children":[],"tail":", substituted “United States Mint” for “Bureau of the Mint” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/390/s221/c/1/A"},"text":"Pub. L. 102–390, § 221(c)(1)(A)","children":[],"tail":", amended second sentence generally. Prior to amendment, second sentence read as follows: “However, amounts from numismatic items shall be reimbursed to the current appropriation used to pay the cost of preparing and selling the items.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/390/s221/c/1/B"},"text":"Pub. L. 102–390, § 221(c)(1)(B)","children":[],"tail":", amended last sentence generally. Prior to amendment, last sentence read as follows: “The Secretary may not use amounts the Secretary receives from profits on minting coins or from charges on gold or silver bullion under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5122"},"text":"section 5122 of this title","children":[],"tail":" to pay officers and employees.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/390/s211"},"text":"Pub. L. 102–390, § 211","children":[],"tail":", which directed the substitution of “$54,208,000” for “$46,511,000” and “1993” for “1988” in par. (2), and the striking out of pars. (3) and (4), was executed by making the substitution in par. (3) and striking out pars. (4) and (5) to reflect the probable intent of Congress and the intervening amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/101/585"},"text":"Pub. L. 101–585","children":[],"tail":" redesignating pars. (2) to (4) as (3) to (5). See 1990 Amendment note below. Prior to being struck out, par. (4) provided that not more than $75,000 be expended for purpose of hosting International Mint Directors’ Conference in the United States in 1988, and par. (5) authorized Director of the Mint to collect from participants at Conference reasonable fees and assessments in connection with Conference, administer such amounts, and spend such amounts to pay expenses incurred in connection with Conference."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/390/s225/b/4"},"text":"Pub. L. 102–390, § 225(b)(4)","children":[],"tail":", substituted “United States Mint” for “Bureau”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(2) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/585"},"text":"Pub. L. 101–585","children":[],"tail":" added par. (2), redesignated former pars. (2) to (4) as (3) to (5), respectively, and substituted “(3)” for “(2)” in par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/274/s1"},"text":"Pub. L. 100–274, § 1","children":[],"tail":", added pars. (2) to (4) and struck out former par. (2) which read as follows: “Not more than $50,165,000 may be appropriated to the Secretary for the fiscal year ending "},{"tag":"date","attrib":{"date":"1983-09-30"},"text":"September 30, 1983","children":[],"tail":", to pay costs of the mints and assay offices.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/274/s2/c/3"},"text":"Pub. L. 100–274, § 2(c)(3)","children":[],"tail":", struck out “and assay offices” after “amounts appropriated for the mints” in last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/185"},"text":"Pub. L. 99–185","children":[],"tail":" inserted “paragraphs (1) through (6) of” before “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112/a"},"text":"section 5112(a) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/61"},"text":"Pub. L. 99–61","children":[],"tail":" inserted “minted under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112/a"},"text":"section 5112(a) of this title","children":[],"tail":"” after “proof coins”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/216"},"text":"Pub. L. 98–216","children":[],"tail":" struck out provision requiring the Secretary to pay the costs of the mints and assay offices not provided for in this subsection out of appropriations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/151"},"text":"Pub. L. 98–151","children":[],"tail":" inserted provisions relating to authority of Secretary to sell sets of uncirculated and proof coins and solicitation of such sales through the customer lists of the Bureau of the Mint."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452"},"text":"Pub. L. 97–452","children":[],"tail":" substituted “$50,165,000” for “$54,706,000”, and “1983” for “1982”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd5bd439-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd5bd43a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/390/tII/s221/e"},"text":"Pub. L. 102–390, title II, § 221(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1629"},"text":"106 Stat. 1629","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/390/tII/s221/e"},"text":"“The amendments made by this section [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5134"},"text":"section 5134 of this title","children":[],"tail":", amending this section, amending and repealing provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112"},"text":"section 5112 of this title","children":[],"tail":"] shall apply with respect to fiscal years beginning after fiscal year 1992.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd5bd43b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/185"},"text":"Pub. L. 99–185","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", except that no coins may be issued or sold under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112/i"},"text":"section 5112(i) of this title","children":[],"tail":" before "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/185/s3"},"text":"section 3 of Pub. L. 99–185","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112"},"text":"section 5112 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/61"},"text":"Pub. L. 99–61","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", with exception as to issuance or sale of coins under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112/e"},"text":"section 5112(e) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/61/s205"},"text":"section 205 of Pub. L. 99–61","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112"},"text":"section 5112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd5bd43c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/216"},"text":"Pub. L. 98–216","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/216/s4/c"},"text":"section 4(c) of Pub. L. 98–216","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s490"},"text":"section 490 of Title 18","children":[],"tail":", Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd5bd43d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Numismatic Public Enterprise Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":"All assets and liabilities of Numismatic Public Enterprise Fund transferred to United States Mint Public Enterprise Fund and Numismatic Public Enterprise Fund to cease to exist as separate fund as its activities and functions are subsumed under and subject to United States Mint Public Enterprise Fund, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5136"},"text":"section 5136 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
