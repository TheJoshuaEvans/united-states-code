{"tag":"section","attrib":{"id":"idbd86b58c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719"},"text":null,"children":[{"tag":"num","attrib":{"value":"6719"},"text":"§ 6719.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd86b58d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports by Secretary to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before June 2 of each year prior to 2002, the Secretary personally shall report to the Congress on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd86b58e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status and operation of the Local Government Fiscal Assistance Fund during the prior fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b58f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the administration of this chapter, including a complete and detailed analysis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd86b590-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions taken to comply with sections 6711 through 6715, including a description of the kind and extent of noncompliance and the status of pending complaints;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b591-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which units of general local government receiving payments under this chapter have complied with the requirements of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b592-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the way in which payments under this chapter have been distributed in the jurisdictions receiving payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b593-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant problems in carrying out this chapter and recommendations for legislation to remedy the problems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd86b594-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports by Units of General Local Government to Secretary.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd86b595-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the end of each fiscal year, each unit of general local government which received a payment under this chapter for the fiscal year shall submit a report to the Secretary. The report shall be submitted in the form and at a time prescribed by the Secretary and shall be available to the public for inspection. The report shall state—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd86b596-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts and purposes for which the payment has been appropriated, expended, or obligated in the fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b597-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship of the payment to the relevant functional items in the budget of the government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b598-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the differences between the actual and proposed use of the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b599-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6719/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide a copy of a report submitted under paragraph (1) by a unit of general local government to the chief executive officer of the State in which the government is located. The Secretary shall provide the report in the manner and form prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd86b59a-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31001/a"},"text":"Pub. L. 103–322, title III, § 31001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1879"},"text":"108 Stat. 1879","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd86b59b-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd86b59c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd86b59d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6719, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1027"},"text":"96 Stat. 1027","children":[],"tail":", related to compliance agreements, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIV/s14001/a/1"},"text":"Pub. L. 99–272, title XIV, § 14001(a)(1)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/327"},"text":"100 Stat. 327","children":[],"tail":", 329, eff. "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
