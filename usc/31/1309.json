{"tag":"section","attrib":{"id":"idbd085db1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1309"},"text":null,"children":[{"tag":"num","attrib":{"value":"1309"},"text":"§ 1309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Social security tax","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Amounts made available for the compensation of officers and employees of the United States Government may be used to pay taxes imposed on an agency as an employer under chapter 21 of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3101"},"text":"26 U.S.C. 3101","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd085db2-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/919"},"text":"96 Stat. 919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd085db3-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd085db4-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd085db5-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children"