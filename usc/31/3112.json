null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:767b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1933-03-03/ch212/s1"},"text":"Mar. 3, 1933, ch. 212, § 1","children":[],"tail":"(last par. on p. 1492), "},{"tag":"html:a","attrib":{"href":"/us/stat/47/1492"},"text":"47 Stat. 1492","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1934-03-15/ch70/s1"},"text":"Mar. 15, 1934, ch. 70, § 1","children":[],"tail":"(2d complete par. on p. 428), "},{"tag":"html:a","attrib":{"href":"/us/stat/48/428"},"text":"48 Stat. 428","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3112(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:767(2d sentence related to price, terms, and conditions, 3d, 4th sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “cumulative” is omitted as surplus. The words “under this chapter” are substituted for “under the First Liberty Bond Act, the Second Liberty Bond Act, the Third Liberty Bond Act, the Fourth Liberty Bond Act, or under this Act, and outstanding on ","children":[{"tag":"date","attrib":{"date":"1920-07-01"},"text":"July 1, 1920","children":[],"tail":", and of bonds and notes thereafter issued, under any of such Acts or under any of such Acts as amended” to eliminate unnecessary words, reference to laws that have been executed, and to reflect consolidation of the public debt authority in the revised chapter. The words “and all additions thereto” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(1) and (2) is substituted for 31:767(last sentence) to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the text of 31:767b(related to 31:767a) is omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “conditions” is substituted for “terms and conditions” because it is inclusive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1de126-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd1de127-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The First Liberty Bond Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-04-24/ch4"},"text":"act Apr. 24, 1917, ch. 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/35"},"text":"40 Stat. 35","children":[],"tail":", which enacted sections 746, 755, 755a, 759, 764, 774, and 804 of former Title 31 and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s462a"},"text":"section 462a of Title 12","children":[],"tail":", Banks and Banking, and amended sections 745 and 768 of former Title 31, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1072"},"text":"96 Stat. 1072","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Second Liberty Bond Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1917-09-24/ch56"},"text":"act Sept. 24, 1917, ch. 56","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/288"},"text":"40 Stat. 288","children":[],"tail":", which enacted sections 747, 752 to 754b, 757, 757b, 757c to 757e, 758, 760, 765, 766, 771, 773, and 801 and amended sections 745, 764, 769, and 774 of former Title 31, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1072"},"text":"96 Stat. 1072","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Third Liberty Bond Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-04-04/ch44"},"text":"act Apr. 4, 1918, ch. 44","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/502"},"text":"40 Stat. 502","children":[],"tail":", which enacted sections 765, 766, and 774 and amended sections 752, 752a, 754, and 771 of former Title 31, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1072"},"text":"96 Stat. 1072","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Fourth Liberty Bond Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1918-07-09/ch142"},"text":"act July 9, 1918, ch. 142","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/844"},"text":"40 Stat. 844","children":[],"tail":", which enacted sections 750 and 772 and amended sections 752 and 774 of former Title 31, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1072"},"text":"96 Stat. 1072","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Victory Liberty Loan Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1919-03-03/ch100"},"text":"act Mar. 3, 1919, ch. 100","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/1309"},"text":"40 Stat. 1309","children":[],"tail":", which enacted sections 749, 753, 763, 767, 802, and 803 and amended sections 750, 754, and 774 of former Title 31 and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s343"},"text":"section 343 of Title 15","children":[],"tail":", Commerce and Trade, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1072"},"text":"96 Stat. 1072","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 301 and 302 of the Emergency Relief and Construction Act of 1932, referred to in subsec. (b)(3), are sections 301 and 302 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1932-07-21/ch520"},"text":"act July 21, 1932, ch. 520","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/709"},"text":"47 Stat. 709","children":[],"tail":", which are not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
