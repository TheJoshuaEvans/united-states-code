{"tag":"section","attrib":{"id":"idbd1b711b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3112"},"text":null,"children":[{"tag":"num","attrib":{"value":"3112"},"text":"§ 3112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sinking fund for retiring and cancelling bonds and notes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1de11c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Treasury has a sinking fund for retiring bonds and notes issued under this chapter. Amounts in the fund are appropriated for payment of bonds and notes at maturity or for their redemption or purchase before maturity by the Secretary of the Treasury. The fund is available until all the bonds and notes are retired.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1de11d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For each fiscal year, an amount is appropriated equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1de11e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the interest that would have been payable during the fiscal year for which the appropriation is made on the bonds and notes bought, redeemed, or paid out of the fund during that or prior years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1de11f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2.5 percent of the total amount of bonds and notes issued under the First Liberty Bond Act, the Second Liberty Bond Act, the Third Liberty Bond Act, the Fourth Liberty Bond Act, and the Victory Liberty Loan Act and outstanding on ","children":[{"tag":"date","attrib":{"date":"1920-07-01"},"text":"July 1, 1920","children":[],"tail":", less an amount equal to the par amount of obligations of governments of foreign countries that the United States Government held on "},{"tag":"date","attrib":{"date":"1920-07-01"},"text":"July 1, 1920","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1de120-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3112/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2.5 percent of the total amount expended after ","children":[{"tag":"date","attrib":{"date":"1933-06-29"},"text":"June 29, 1933","children":[],"tail":", from appropriations made or authorized in sections 301 and 302 of the Emergency Relief and Construction Act of 1932."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1de121-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may prescribe the price and conditions for paying, redeeming, and buying bonds and notes under this section. The average cost of bonds and notes bought under this section may not be more than par value and accrued interest. Bonds and notes bought, redeemed, or paid out of the sinking fund must be canceled and retired and may not be reissued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1de122-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/943"},"text":"96 Stat. 943","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1de123-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd1de124-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd1de125-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":