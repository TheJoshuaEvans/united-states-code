{"tag":"section","attrib":{"id":"idbd14448b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1536"},"text":null,"children":[{"tag":"num","attrib":{"value":"1536"},"text":"§ 1536.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crediting payments from purchases between executive agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd14448c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1536/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An advance payment made on an order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1535"},"text":"section 1535 of this title","children":[],"tail":" is credited to a special working fund that the Secretary of the Treasury considers necessary to be established. Except as provided in this section, any other payment is credited to the appropriation or fund against which charges were made to fill the order."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd14448d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1536/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An amount paid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1535"},"text":"section 1535 of this title","children":[],"tail":" may be expended in providing goods or services or for a purpose specified for the appropriation or fund credited. Where goods are provided from stocks on hand, the amount received in payment is credited so as to be available to replace the goods unless—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd14448e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1536/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another law authorizes the amount to be credited to some other appropriation or fund; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd14448f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1536/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the executive agency filling the order decides that replacement is not necessary, in which case, the amount received is deposited in the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd144490-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1536/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not affect other laws about working funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd144491-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/934"},"text":"96 Stat. 934","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd144492-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd144493-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd144494-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead",