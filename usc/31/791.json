{"tag":"section","attrib":{"id":"idbcf7bbe0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s791"},"text":null,"children":[{"tag":"num","attrib":{"value":"791"},"text":"§ 791.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center for Audit Excellence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf7bbe1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s791/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall establish, maintain, and operate a center within the Government Accountability Office to be known as the “Center for Audit Excellence” (hereafter in this subchapter referred to as the “Center”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7bbe2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s791/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose and Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf7bbe3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s791/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Center shall build institutional auditing capacity and promote good governance by providing affordable, relevant, and high-quality training, technical assistance, and products and services to qualified personnel and entities of governments (including the Federal Government, State and local governments, tribal governments, and governments of foreign nations), international organizations, and other private organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7bbe4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s791/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of qualified personnel and entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Personnel and entities shall be considered qualified for purposes of receiving training, technical assistance, and products or services from the Center under paragraph (1) in accordance with such criteria as the Comptroller General may establish and publish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7bbe5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s791/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf7bbe6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s791/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permitting charging of fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General may establish, charge, and collect fees (on a reimbursable or advance basis) for the training, technical assistance, and products and services provided by the Center under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7bbe7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s791/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit into separate account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall deposit all fees collected under paragraph (1) into the Center for Audit Excellence Account established under section 792.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7bbe8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s791/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gifts of Property and Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General may accept and use conditional or non-conditional gifts of property (both real and personal) and services (including services of guest lecturers) to support the operation of the Center, except that the Comptroller General may not accept or use such a gift if the Comptroller General determines that the acceptance or use of the gift would compromise or appear to compromise the integrity of the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7bbe9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s791/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of Congress Regarding Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the sense of Congress that the Center should be staffed primarily by personnel of the Government Accountability Office who are not otherwise engaged in carrying out other duties of the Office under this chapter, so as to ensure that the operation of the Center will not detract from or impact the oversight and audit work of the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf7bbea-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1401/a/1"},"text":"Pub. L. 113–235, div. H, title I, § 1401(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2539"},"text":"128 Stat. 2539","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf7bbeb-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf7bbec-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcf7bbed-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Approval of Business Plan","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1401/b"},"text":"Pub. L. 113–235, div. H, title I, § 1401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2541"},"text":"128 Stat. 2541","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/235/dH/tI/s1401/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Comptroller General may not begin operating the Center for Audit Excellence under subchapter VII of chapter 7 of title 31, United States Code (as added by subsection (a)) until—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller General submits a business plan for the Center to the Committees on Appropriations of the House of Representatives and Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each such Committee approves the plan.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
