{"tag":"section","attrib":{"id":"idbd229c4d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324"},"text":null,"children":[{"tag":"num","attrib":{"value":"3324"},"text":"§ 3324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd229c4e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in this section, a payment under a contract to provide a service or deliver an article for the United States Government may not be more than the value of the service already provided or the article already delivered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd229c4f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An advance of public money may be made only if it is authorized by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd229c50-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specific appropriation or other law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd229c51-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the President to be made to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd229c52-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a disbursing official if the President decides the advance is necessary to carry out—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd229c53-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duties of the official promptly and faithfully; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd229c54-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an obligation of the Government; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd229c55-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual serving in the armed forces at a distant station if the President decides the advance is necessary to disburse regularly pay and allowances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd229c56-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before the Secretary of the Treasury acts on a requisition for an advance, the Comptroller General shall act on the requisition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3522"},"text":"section 3522 of this title","children":[],"tail":". The Comptroller General does not countersign a requisition for an advance."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd229c57-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of an agency may pay in advance from appropriations available for the purpose—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd229c58-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the Secretary of the Army, charges for messages sent by the Secretary of the Army for the head of the agency, including charges for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd229c59-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of tolls of commercial carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd229c5a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leasing facilities for sending messages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd229c5b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" installing and maintaining facilities for sending messages; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd229c5c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3324/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charges for a publication printed or recorded in any way for the auditory or visual use of the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd229c5d-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/950"},"text":"96 Stat. 950","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd229c5e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd229c5f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd229c60-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"t