ail":"; "},{"tag":"html:span","attrib":{},"text":"July 20, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/91/s1"},"text":"Pub. L. 87–91, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/211"},"text":"75 Stat. 211","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:530b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1930-06-12/ch470"},"text":"June 12, 1930, ch. 470","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/580"},"text":"46 Stat. 580","children":[],"tail":", § 2; added "},{"tag":"html:span","attrib":{},"text":"Dec. 22, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/534"},"text":"Pub. L. 93–534","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1731"},"text":"88 Stat. 1731","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:686–2.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1926-04-15/ch146/s101"},"text":"Apr. 15, 1926, ch. 146, § 101","children":[],"tail":"(proviso on p. 267), "},{"tag":"html:a","attrib":{"href":"/us/stat/44/267"},"text":"44 Stat. 267","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Except as provided in this section” are added for clarity. The words “already provided” and “already delivered” are substituted for “rendered . . . delivered previously to such payment” for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “in any case” and “It shall, however, be lawful under the special direction of” are omitted as surplus. In clause (2)(A)(i), the word “official” is substituted for “officer” for consistency in the revised title. The words “of the Government” are omitted as surplus. Clause (2)(A)(ii) is substituted for “the public engagements” for clarity. In clause (2)(B), the word “individual” is substituted for “persons” for consistency. The words “armed forces” are substituted for “military and naval service” for consistency with title 10. The words “and proper” are omitted as unnecessary. The words “disburse regularly pay and allowances” are substituted for “discharge of the pay and emoluments to which they may be entitled cannot be regularly effected” to eliminate unnecessary words, for clarity, and for consistency with title 37.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Comptroller General” are substituted for “General Accounting Office” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), before clause (1), the words “On and after ","children":[{"tag":"date","attrib":{"date":"1926-04-15"},"text":"April 15, 1926","children":[],"tail":"” in 31:686–2 are omitted as executed. The word “agency” is substituted for “department or establishment” because of section 101 of the revised title and for consistency. The words “may pay in advance from appropriations available for the purpose” are substituted for “may transfer in advance . . . such amounts as may be necessary to defray the expense of” for clarity and consistency. In clause (1), the words “Secretary of the Army” are substituted for “Signal Corps of the Army” because of 10:3012. The title of Secretary of War was changed to Secretary of the Army, and the Department of War was designated the Department of the Army by "},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/s205/a"},"text":"section 205(a) of the Act of July 26, 1947","children":[],"tail":" (ch. 343, "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"), and by sections 1 and 53 of the Act of "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"August 10, 1956","children":[],"tail":" (ch. 1041, "},{"tag":"ref","attrib":{"href":"/us/stat/70A/157"},"text":"70A Stat. 157","children":[],"tail":", 676). Clause (2) is substituted for 31:530a and 530b to eliminate unnecessary words. The words “or the municipal government of the District of Columbia” are omitted because of sections 441–445 and 736 of the Act of "},{"tag":"date","attrib":{"date":"1973-12-24"},"text":"December 24, 1973","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/93/198"},"text":"Pub. L. 93–198","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/798"},"text":"87 Stat. 798","children":[],"tail":", 823)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd229c61-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd229c62-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"International Refugee Organization","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Funds available for expenditure without regard to this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s289c"},"text":"section 289c of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbd229c63-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd229c64-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exemption of Functions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Functions authorized by Foreign Assistance Act of 1961, as amended, as exempt, see Ex. Ord. No. 11223, ","children":[{"tag":"date","attrib":{"date":"1965-05-12"},"text":"May 12, 1965","children":[],"tail":", 30 F.R. 6635, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2393"},"text":"section 2393 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
