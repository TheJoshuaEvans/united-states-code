{"tag":"section","attrib":{"id":"idbd202b98-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3129"},"text":null,"children":[{"tag":"num","attrib":{"value":"3129"},"text":"§ 3129.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation to pay expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd202b99-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3129/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts to pay necessary expenses (including rent) for an issue of obligations authorized under this chapter are appropriated to the Secretary of the Treasury. However, the amount appropriated under this section may not be more than—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd202b9a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3129/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" .2 percent of the amount of bonds and notes authorized under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd202b9b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3129/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" .1 percent of the amount of certificates of indebtedness authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3104"},"text":"section 3104 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd202b9c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3129/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" .1 percent of the amount of certificates of indebtedness authorized under the First Liberty Bond Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd202b9d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3129/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An appropriation under this section is available for obligation only through the end of the fiscal year after the fiscal year in which the issue was made. During a period for which an appropriation for a specified amount is made for expenses for which this section makes an appropriation for an unspecified amount, only the appropriation for the specified amount is available for obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd202b9e-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/947"},"text":"96 Stat. 947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd202b9f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd202ba0-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd202ba1-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p"