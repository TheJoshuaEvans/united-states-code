","attrib":{},"text":"31:733(words after semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3699(words after semicolon); restated ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1934-01-30/ch6/s9"},"text":"Jan. 30, 1934, ch. 6, § 9","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/341"},"text":"48 Stat. 341","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:734.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3700; restated ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1934-01-30/ch6/s8"},"text":"Jan. 30, 1934, ch. 6, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/341"},"text":"48 Stat. 341","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5116(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:335.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3526; restated ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-05-10/ch173"},"text":"May 10, 1950, ch. 173","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/157"},"text":"64 Stat. 157","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1956-07-09/ch535/s2"},"text":"July 9, 1956, ch. 535, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/518"},"text":"70 Stat. 518","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 23, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/81/s205"},"text":"Pub. L. 89–81, § 205","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/256"},"text":"79 Stat. 256","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:394.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 23, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/81/s104"},"text":"Pub. L. 89–81, § 104","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/255"},"text":"79 Stat. 255","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5116(b)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:405a–1.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"June 4, 1963","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/36/s2"},"text":"Pub. L. 88–36, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/77/54"},"text":"77 Stat. 54","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 23, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/81/s209"},"text":"Pub. L. 89–81, § 209","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/257"},"text":"79 Stat. 257","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"June 24, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/29/s3"},"text":"Pub. L. 90–29, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/77"},"text":"81 Stat. 77","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “With the approval of the President” are applied to 31:733(words after semicolon) because of 31:822b. The words “at home or abroad” in 31:733(words after semicolon) and 734 are omitted as surplus. The words “terms and” are omitted as included in “conditions”. The text of 31:733(proviso) is omitted as superseded by the Bretton Woods Agreement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s286"},"text":"22 U.S.C. 286","children":[],"tail":" et seq.) and sections 6 and 9 of the Act of "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"October 19, 1976","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/94/564"},"text":"Pub. L. 94–564","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2661"},"text":"90 Stat. 2661","children":[],"tail":"), repealing 31:449 that provided for parity of the dollar on terms of gold and special drawing rights. The text of 31:734(1st sentence words after semicolon) is omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “coinage metal fund” are substituted for “bullion fund” in 31:335 as being more precise and because of section 5111 of the revised title. The words “after ","children":[{"tag":"date","attrib":{"date":"1965-07-23"},"text":"July 23, 1965","children":[],"tail":"” in 31:394 are omitted as executed. The words “to procure bullion for coinage” and 31:335(2d–last sentences) are omitted as obsolete because the Secretary of the Treasury has authority to mint coins containing silver only under section 5112(e) of the revised title and the Secretary holds sufficient silver to mint those coins. See Sen. Rept. No. 91–1084 (1970)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the word “terms” is omitted as being included in “conditions”. The words “for at least” are substituted for “at a price not less than the monetary value of” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd5719a4-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd5719a5-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Strategic and Critical Materials Stock Piling Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-06-07/ch190"},"text":"act June 7, 1939, ch. 190","children":[],"tail":", as revised generally by "},{"tag":"ref","attrib":{"href":"/us/pl/96/41/s2"},"text":"Pub. L. 96–41, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-07-30"},"text":"July 30, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/319"},"text":"93 Stat. 319","children":[],"tail":", which is classified generally to subchapter III (§ 98 et seq.) of chapter 5 of Title 50, War and National Defense. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s98"},"text":"section 98 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd5719a6-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/201"},"text":"Pub. L. 107–201","children":[],"tail":" inserted after second sentence “At such time as the silver stockpile is depleted, the Secretary shall obtain silver as described in paragraph (1) to mint coins authorized under section 5112(e). If it is not economically feasible to obtain such silver, the Secretary may obtain silver for coins authorized under section 5112(e) from other available sources. The Secretary shall not pay more than the average world price for silver under any circumstances. As used in this paragraph, the term ‘average world price’ means the price determined by a widely recognized commodity exchange at the time the silver is obtained by the Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/274"},"text":"Pub. L. 100–274","children":[],"tail":" amended last sentence generally, substituting “shall be deposited by the Secretary in the general fund of the Treasury and shall be used for the sole purpose of reducing the national debt” for “shall be deposited in the general fund of the Treasury”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/185"},"text":"Pub. L. 99–185","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/61/s203/1"},"text":"Pub. L. 99–61, § 203(1)","children":[],"tail":", (2), substituted “The Secretary may buy silver” for “The Secretary shall buy silver”, and struck out provision directing that the Secretary pay $1.25 a fine troy ounce for silver."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/61/s203/3"},"text":"Pub. L. 99–61, § 203(3)","children":[],"tail":", inserted provision directing that the Secretary obtain the silver for the coins authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112/e"},"text":"section 5112(e) of this title","children":[],"tail":" by purchase from stockpiles established under the Strategic and Critical Materials Stock Piling Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd5719a7-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd5719a8-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/185"},"text":"Pub. L. 99–185","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", except that no coins may be issued or sold under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112/i"},"text":"section 5112(i) of this title","children":[],"tail":" before "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/185/s3"},"text":"section 3 of Pub. L. 99–185","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112"},"text":"section 5112 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/61"},"text":"Pub. L. 99–61","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", with exception as to issuance or sale of coins under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112/e"},"text":"section 5112(e) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/61/s205"},"text":"section 205 of Pub. L. 99–61","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112"},"text":"section 5112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd5719a9-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/201/s3/a/2"},"text":"Pub. L. 107–201, § 3(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-23"},"text":"July 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/737"},"text":"116 Stat. 737","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/201/s3/a/2"},"text":"“The Secretary of the Treasury shall issue regulations to implement the amendments made by paragraph (1) [amending this section].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd5719aa-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings Concerning American Eagle Silver Bullion Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/201/s2"},"text":"Pub. L. 107–201, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-23"},"text":"July 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/736"},"text":"116 Stat. 736","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/201/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the American Eagle Silver Bullion coin leads the global market, and is the largest and most popular silver coin program in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established in 1986, the American Eagle Silver Bullion Program is the most successful silver bullion program in the world;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" from fiscal year 1995 through fiscal year 2001, the American Eagle Silver Bullion Program generated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revenues of $264,100,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient profits to significantly reduce the national debt;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the depletion of silver reserves in the Defense Logistic Agency’s Strategic and Critical Materials Stockpile, it is necessary for the Department of the Treasury to acquire silver from other sources in order to preserve the American Eagle Silver Bullion Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the ability to obtain silver from other sources, the United States Mint can continue the highly successful American Eagle Silver Bullion Program, exercising sound business judgment and market acquisition practices in its approach to the silver market, resulting in continuing profitability of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in 2001, silver was commercially produced in 12 States, including, [sic] Alaska, Arizona, California, Colorado, Idaho, Missouri, Montana, Nevada, New Mexico, South Dakota, Utah, and Washington;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nevada is the largest silver producing State in the Nation, producing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 17,500,000 ounces of silver in 2001; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 34 percent of United States silver production in 2000;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the mining industry in Idaho is vital to the economy of the State, and the Silver Valley in northern Idaho leads the world in recorded silver production, with over 1,100,000,000 ounces of silver produced between 1884 and 2001;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the largest, active silver producing mine in the Nation is the McCoy/Cove Mine in Nevada, which produced more than 107,000,000 ounces of silver between 1989 and 2001;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"“(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the mining industry in Idaho—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs more than 3,000 people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contributes more than $900,000,000 to the Idaho economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produces $70,000,000 worth of silver per year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"“(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the silver mines of the Comstock lode, the premier silver producing deposit in Nevada, brought people and wealth to the region, paving the way for statehood in 1864, and giving Nevada its nickname as ‘the Silver State’;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"“(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" mines in the Silver Valley—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent an important part of the mining history of Idaho and the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have served in the past as key components of the United States war effort; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"“(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" silver has been mined in Nevada throughout its history, with every significant metal mining camp in Nevada producing some silver.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd5719ab-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annual Report on Silver Purchases in Support of American Eagle Silver Bullion Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/201/s3/c"},"text":"Pub. L. 107–201, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-23"},"text":"July 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/737"},"text":"116 Stat. 737","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/201/s3/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the United States Mint shall prepare and submit to Congress an annual report on the purchases of silver made pursuant to this Act [amending this section and enacting provisions set out as notes under this section and sections 5101 and 5112 of this title] and the amendments made by this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Concurrent submission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The report required by paragraph (1) may be incorporated into the annual report of the Director of the United States Mint on the operations of the mint and assay offices, referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s1329"},"text":"section 1329 of title 44","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd5719ac-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Coinage Metal Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":"All assets and liabilities of Coinage Metal Fund transferred to United States Mint Public Enterprise Fund and such coinage fund to cease to exist as separate fund as its activities and functions are subsumed under and subject to United States Mint Public Enterprise Fund, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5136"},"text":"section 5136 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
