{"tag":"section","attrib":{"id":"idbd250d8c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328"},"text":null,"children":[{"tag":"num","attrib":{"value":"3328"},"text":"§ 3328.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paying checks and drafts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd250d8d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time Limit on Treasury Checks.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250d8e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in sections 3329 and 3330 of this title—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd250d8f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall not be required to pay a Treasury check issued on or after the effective date of this section unless it is negotiated to a financial institution within 12 months after the date on which the check was issued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250d90-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall not be required to pay a Treasury check issued before the effective date of this section unless it is negotiated to a financial institution within 12 months after such effective date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250d91-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deferral pending settlement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the time limitations imposed by paragraph (1), if the Secretary is on notice of a question of law or fact about whether a Treasury check is properly payable when the check is presented for payment, the Secretary may defer payment on such check until the question is settled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250d92-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection shall be construed to affect the underlying obligation of the United States, or any agency thereof, for which a Treasury check was issued.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250d93-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250d94-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a check issued by a disbursing official and drawn on a designated depositary is not paid by the last day of the fiscal year after the fiscal year in which the check was issued, the amount of the check is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd250d95-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withdrawn from the account with the depositary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250d96-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposited in the Treasury for credit to a consolidated account of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250d97-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A claim for the proceeds of an unpaid check under this subsection may be paid from a consolidated account by a check drawn on the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250d98-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A limitation imposed on a claim against the United States Government under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3702"},"text":"section 3702 of this title","children":[],"tail":" does not apply to an unpaid check drawn on the Treasury or a designated depositary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250d99-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may prescribe regulations the Secretary decides are necessary to carry out subsections (a)–(c) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250d9a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250d9b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall prescribe regulations on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd250d9c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcing the speedy presentation of Government drafts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250d9d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying drafts, including the place of payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250d9e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying drafts if presentment is not made as required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250d9f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulations prescribed under paragraph (1) of this subsection shall prevent, as far as may be practicable, Government drafts from being used or placed in circulation as paper currency or a medium of exchange.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250da0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3328/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Decline Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section limits the authority of the Secretary to decline payment of a Treasury check after first examination thereof at the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd250da1-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/952"},"text":"96 Stat. 952","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/tX/s1002"},"text":"Pub. L. 100–86, title X, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/658"},"text":"101 Stat. 658","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s115/d"},"text":"Pub. L. 104–316, title I, § 115(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3834"},"text":"110 Stat. 3834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd250da2-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd250da3-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd250da4-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3328(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:132(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-07-11/ch222/s1"},"text":"July 11, 1947, ch. 222, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/308"},"text":"61 Stat. 308","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/183/s1"},"text":"Pub. L. 85–183, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/71/464"},"text":"71 Stat. 464","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3328(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:134(less last 30 words before 1st proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-07-11/ch222/s3"},"text":"July 11, 1947, ch. 222, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/309"},"text":"61 Stat. 309","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Aug. 28, 1957","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/183/s2"},"text":"Pub. L. 85–183, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/71/464"},"text":"71 Stat. 464","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3328(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:132(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3328(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:132(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3328(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:134(last 30 words before 1st proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3328(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:527","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3645.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the word “Treasury” is substituted for “Treasurer of the United States” because of the source provisions restated in section 321 of the revised title and Department of the Treasury Order 229 of ","children":[{"tag":"date","attrib":{"date":"1974-01-14"},"text":"January 14, 1974","children":[],"tail":" (39 F.R. 2280)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a)(1) and (b), the words “Comptroller General” are substituted for “General Accounting Office” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a)(1) and (c), the words “heretofore or hereafter” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “Except as provided in sections 3330 and 3331 of this title” are added for clarity. The words “including those drawn by wholly owned and mixed-ownership Government corporations” are omitted as surplus. The words “Secretary of the Treasury” are substituted for “Treasurer of the United States” after “for payment the” because of the source provisions restated in section 321(c) of the revised title. The words “doubtful”, “for payment”, and “of such check” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), before clause (A), the words “When the Secretary decides it is appropriate” are substituted for “at appropriate intervals” for clarity. In clauses (A) and (B), the words “on the books” are omitted as surplus. In clause (A), the words “drawn on the Treasury” are added for clarity and consistency. In clause (B), the words “from the accounts . . . for the payment of unpaid checks . . . of the Treasury” are omitted as surplus. The words “and to transfer to such consolidated account or accounts the balance of the special deposit account established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s132"},"text":"section 132 of this title","children":[],"tail":"”, and the words “any unpaid checks heretofore payable from the special deposit account”, are omitted as executed because the account was established under 31:132 as originally enacted in 1947 and then abolished by the 1957 amendment to that section. The text of 31:134(1st proviso) is omitted as superseded by "},{"tag":"ref","attrib":{"href":"/us/act/1973-12-24/s448"},"text":"section 448 of the Act of December 24, 1973","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/93/198"},"text":"Pub. L. 93–198","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/801"},"text":"87 Stat. 801","children":[],"tail":"). The text of 31:134(last proviso) is omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “issued by a disbursing official” are substituted for “drawn by authorized officers of the United States” for consistency. In clause (B), the words “or accounts on the books” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is substituted for 31:132(c) for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “rules and” and “or proper” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(1), before clause (A), the word “prescribe” is substituted for “issue and publish” for consistency in the revised title and with other titles of the United States Code. In clause (B), the words “and to prescribe the time, according to the different distances of the depositaries from the seat of Government, within which all drafts upon them, respectively, shall be presented for payment” are omitted as superseded by subsection (a) of the revised section. Clause (C) is substituted for 31:527(words between semi­colons) to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(2), the words “and directions” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd250da5-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd250da6-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this section, referred to in subsec. (a)(1), probably means the effective date of subsec. (a) of this section as amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/s1002"},"text":"section 1002 of Pub. L. 100–86","children":[],"tail":", which is effective 6 months after "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", or on such later date as the Secretary of the Treasury may prescribe in regulations. See "},{"tag":"ref","attrib":{"href":"/us/pl/100/86/s1006"},"text":"section 1006 of Pub. L. 100–86","children":[],"tail":", set out as a note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd250da7-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s115/d/1"},"text":"Pub. L. 104–316, § 115(d)(1)","children":[],"tail":", substituted “until the question is settled” for “until the Comptroller General settles the question”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s115/d/2"},"text":"Pub. L. 104–316, § 115(d)(2)","children":[],"tail":", struck out “on settlement by the Comptroller General” after “the Treasury”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s115/d/3"},"text":"Pub. L. 104–316, § 115(d)(3)","children":[],"tail":", substituted “The” for “With the approval of the Comptroller General, the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/s1002/1"},"text":"Pub. L. 100–86, § 1002(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Except as provided in sections 3329 and 3330 of this title, a check drawn on the Treasury may be paid at any time. However, if the Secretary of the Treasury is on notice of a question of law or fact about the check when the check is presented, the Secretary shall defer payment until the Comptroller General settles the question.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) When the Secretary decides it is appropriate, the Secretary may transfer—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the amount of an unpaid check drawn on the Treasury from the account on which it was drawn to a consolidated account of the Treasury available for paying checks; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) an amount available, but not required, for paying checks drawn on the Treasury to the appropriate receipt account.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/s1002/2"},"text":"Pub. L. 100–86, § 1002(2)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd250da8-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd250da9-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/tX/s1006"},"text":"Pub. L. 100–86, title X, § 1006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/659"},"text":"101 Stat. 659","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/86/tX/s1006"},"text":"“The amendments made by sections 1002, 1003, and 1004 [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3334"},"text":"section 3334 of this title","children":[],"tail":" and amending this section and sections 3702 and 3712 of this title] shall become effective 6 months after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":"] or on such later date as the Secretary of the Treasury may prescribe in regulations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd250daa-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/86/tX/s1005"},"text":"Pub. L. 100–86, title X, § 1005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-08-10"},"text":"Aug. 10, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/659"},"text":"101 Stat. 659","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/86/tX/s1005"},"text":"“The Secretary of the Treasury may prescribe such rules, regulations, and procedures as the Secretary deems necessary to implement the amendments made by sections 1002, 1003, and 1004 [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3334"},"text":"section 3334 of this title","children":[],"tail":" and amending this section and sections 3702 and 3712 of this title], including the recertification of Treasury checks which have been canceled or for which a claim has been asserted or barred.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
