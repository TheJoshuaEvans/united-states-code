":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1304(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:724a(1st sentence words before 1st proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-07-27/ch748/s1302"},"text":"July 27, 1956, ch. 748, § 1302","children":[],"tail":"(1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/70/694"},"text":"70 Stat. 694","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 30, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/187/s3"},"text":"Pub. L. 87–187, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/416"},"text":"75 Stat. 416","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 18, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/506/s6"},"text":"Pub. L. 89–506, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/307"},"text":"80 Stat. 307","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 23, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/350/s1/c"},"text":"Pub. L. 91–350, § 1(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/449"},"text":"84 Stat. 449","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"May 4, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/26/s101"},"text":"Pub. L. 95–26, § 101","children":[],"tail":"(2d par. under heading “Claims and Judgments”), "},{"tag":"html:a","attrib":{"href":"/us/stat/91/96"},"text":"91 Stat. 96","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Mar. 7, 1978","children":[],"tail":", "},{"tag":"html:a"