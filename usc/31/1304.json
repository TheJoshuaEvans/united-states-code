"html:span","attrib":{},"text":"1304(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:724a(1st sentence last proviso)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “out of any money in the Treasury not otherwise appropriated” are omitted as surplus. The words “awards rendered by the Indian Claims Commission” are omitted as executed because under 25:70v the Commission was dissolved and all of its outstanding cases were transferred to the Court of Claims. Under 25:70v–3, judgments on cases transferred to the Court of Claims are judgments under 28:2517 and 2518 and are therefore included under clause (3)(A) of the subsection.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the text of 28:2516(b)(less 1st sentence words after last comma) is omitted as superseded by 31:724a.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(A), the words “through the day before the date” are substituted for “to the date” as being more precise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd085d80-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd085d81-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2518"},"text":"Section 2518 of title 28","children":[],"tail":", referred to in 