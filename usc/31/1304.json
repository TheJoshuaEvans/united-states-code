{"tag":"section","attrib":{"id":"idbd085d5f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304"},"text":null,"children":[{"tag":"num","attrib":{"value":"1304"},"text":"§ 1304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judgments, awards, and compromise settlements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd085d60-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Necessary amounts are appropriated to pay final judgments, awards, compromise settlements, and interest and costs specified in the judgments or otherwise authorized by law when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd085d61-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment is not otherwise provided for;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d62-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment is certified by the Secretary of the Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d63-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the judgment, award, or settlement is payable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd085d64-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under section 2414, 2517, 2672, or 2677 of title 28;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd085d65-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3723"},"text":"section 3723 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd085d66-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a decision of a board of contract appeals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd085d67-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in excess of an amount payable from the appropriations of an agency for a meritorious claim under section 2733, 2733a, or 2734 of title 10, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t32/s715"},"text":"section 715 of title 32","children":[],"tail":", or "},{"tag":"ref","attrib":{"href":"/us/usc/t51/s20113"},"text":"section 20113 of title 51","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd085d68-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd085d69-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Interest may be paid from the appropriation made by this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd085d6a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a judgment of a district court, only when the judgment becomes final after review on appeal or petition by the United States Government, and then only from the date of filing of the transcript of the judgment with the Secretary of the Treasury through the day before the date of the mandate of affirmance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd085d6b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a judgment of the Court of Appeals for the Federal Circuit or the United States Court of Federal Claims under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2516/b"},"text":"section 2516(b) of title 28","children":[],"tail":", only from the date of filing of the transcript of the judgment with the Secretary of the Treasury through the day before the date of the mandate of affirmance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d6c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest payable under this subsection in a proceeding reviewed by the Supreme Court is not allowed after the end of the term in which the judgment is affirmed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd085d6d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd085d6e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A judgment or compromise settlement against the Government shall be paid under this section and sections 2414, 2517, and 2518 ","children":[{"tag":"ref","attrib":{"idref":"fn002033"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002033"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 28 when the judgment or settlement arises out of an express or implied contract made by—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd085d6f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Army and Air Force Exchange Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd085d70-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Navy Exchanges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd085d71-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Marine Corps Exchanges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd085d72-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Coast Guard Exchanges; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd085d73-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Exchange Councils of the National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d74-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Exchange making the contract shall reimburse the Government for the amount paid by the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd085d75-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Beginning not later than the date that is 60 days after the date of enactment of the John D. Dingell, Jr. Conservation, Management, and Recreation Act, and unless the disclosure of such information is otherwise prohibited by law or a court order, the Secretary of the Treasury shall make available to the public on a website, as soon as practicable, but not later than 30 days after the date on which a payment under this section is tendered, the following information with regard to that payment:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd085d76-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the specific agency or entity whose actions gave rise to the claim or judgment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d77-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the plaintiff or claimant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d78-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of counsel for the plaintiff or claimant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d79-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount paid representing principal liability, and any amounts paid representing any ancillary liability, including attorney fees, costs, and interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d7a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A brief description of the facts that gave rise to the claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d7b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1304/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the agency that submitted the claim.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd085d7c-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", §§ 1, 2(m)(2), "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/917"},"text":"96 Stat. 917","children":[],"tail":", 1062; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/b/1"},"text":"Pub. L. 102–572, title IX, § 902(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tII/s202/m"},"text":"Pub. L. 104–316, title II, § 202(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3843"},"text":"110 Stat. 3843","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/b"},"text":"Pub. L. 111–314, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3440"},"text":"124 Stat. 3440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/9/tIV/s4201/b"},"text":"Pub. L. 116–9, title IV, § 4201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-03-12"},"text":"Mar. 12, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/764"},"text":"133 Stat. 764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVII/s731/c/2"},"text":"Pub. L. 116–92, div. A, title VII, § 731(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attr