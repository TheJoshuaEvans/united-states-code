{"tag":"section","attrib":{"id":"idbd846c29-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6711"},"text":null,"children":[{"tag":"num","attrib":{"value":"6711"},"text":"§ 6711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited discrimination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd846c2a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person in the United States shall be excluded from participating in, be denied the benefits of, or be subject to discrimination under, a program or activity of a unit of general local government because of race, color, national origin, or sex if the government receives a payment under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd846c2b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following prohibitions and exemptions also apply to a program or activity of a unit of general local government if the government receives a payment under this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd846c2c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6711/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A prohibition against discrimination because of age under the Age Discrimination Act of 1975.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd846c2d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6711/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A prohibition against discrimination against an otherwise qualified handicapped individual under section 504 of the Rehabilitation Act of 1973.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd846c2e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6711/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A prohibition against discrimination because of religion, or an exemption from that prohibition, under the Civil Rights Act of 1964 or title VIII of the Act of ","children":[{"tag":"date","attrib":{"date":"1968-04-11"},"text":"April 11, 1968","children":[],"tail":" (popularly known as the Civil Rights Act of 1968)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd846c2f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6711/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Applicability of Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsections (a) and (b) do not apply if the government shows, by clear and convincing evidence, that a payment received under this chapter is not used to pay for any part of the program or activity with respect to which the allegation of discrimination is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd846c30-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6711/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investigation Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall try to make agreements with heads of agencies of the United States Government and State agencies to investigate noncompliance with this section. An agreement shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd846c31-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6711/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the cooperative efforts to be taken (including sharing civil rights enforcement personnel and resources) to obtain compliance with this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd846c32-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6711/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for notifying immediately the Secretary of actions brought by the United States Government or State agencies against a unit of general local government alleging a violation of a civil rights law or a regulation prescribed under a civil rights law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd846c33-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31001/a"},"text":"Pub. L. 103–322, title III, § 31001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1874"},"text":"108 Stat. 1874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd846c34-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd846c35-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd846c36-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Age Discrimination Act of 1975, referred to in subsec. (b)(1), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/135"},"text":"Pub. L. 94–135","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/728"},"text":"89 Stat. 728","children":[],"tail":", which is classified generally to chapter 76 (§ 6101 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6101"},"text":"section 6101 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 504 of the Rehabilitation Act of 1973, referred to in subsec. (b)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"section 794 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Civil Rights Act of 1964, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Pub. L. 88–352","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-07-02"},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":", which is classified principally to subchapters II to IX (§ 2000a et seq.) of chapter 21 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000a"},"text":"section 2000a of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Title VIII of the Act of ","children":[{"tag":"date","attrib":{"date":"1968-04-11"},"text":"April 11, 1968","children":[],"tail":", referred to in subsec. (b)(3), is title VIII of "},{"tag":"ref","attrib":{"href":"/us/pl/90/284"},"text":"Pub. L. 90–284","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"Apr. 11, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/81"},"text":"82 Stat. 81","children":[],"tail":", known as the Fair Housing Act, which is classified principally to subchapter I (§ 3601 et seq.) of chapter 45 of Title 42. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"section 3601 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd846c37-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6711, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1021"},"text":"96 Stat. 1021","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/185/s4"},"text":"Pub. L. 98–185, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1309"},"text":"97 Stat. 1309","children":[],"tail":", related to State variation of local government allocations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIV/s14001/a/1"},"text":"Pub. L. 99–272, title XIV, § 14001(a)(1)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/327"},"text":"100 Stat. 327","children":[],"tail":", 329, eff. "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
