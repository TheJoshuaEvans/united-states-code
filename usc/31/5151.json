{"tag":"section","attrib":{"id":"idbd5e4539-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151"},"text":null,"children":[{"tag":"num","attrib":{"value":"5151"},"text":"§ 5151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conversion of currency of foreign countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd5e453a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5e453b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “buying rate” means the buying rate in the market in New York, New York, for cable transfers payable in the currency of a foreign country to be converted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5e453c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when merchandise is exported on a day that banks are generally closed in New York, the buying rate at noon on the last prior business day is deemed to be the buying rate at noon on the day the merchandise is exported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5e453d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The value of coins of a foreign country expressed in United States money is the value of the pure metal of the standard coin of the foreign country. The Secretary of the Treasury shall estimate the values of standard coins of the country quarterly and publish the values on the first day of January, April, July, and October of each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5e453e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in this section, conversion of currency of a foreign country into United States currency for assessment and collection of duties on merchandise imported into the United States shall be made at values published by the Secretary under subsection (b) of this section for the quarter in which the merchandise is exported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5e453f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary has not published a value for the quarter in which the merchandise is exported, or if the value published by the Secretary varies by at least 5 percent from a value measured by the buying rate at noon on the day the merchandise is exported, the conversion of the currency of the foreign country shall be made at a value—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5e4540-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equal to the buying rate at noon on the day the merchandise is exported; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5e4541-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribed by regulation of the Secretary for the currency that is equal to the first buying rate certified for that currency by the Federal Reserve Bank of New York under subsection (e) of this section in the quarter in which the merchandise is exported, but only if the buying rate at noon on the day the merchandise is exported varies less than 5 percent from the buying rate first certified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5e4542-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Federal Reserve Bank of New York shall decide the buying rate and certify the rate to the Secretary. The Secretary shall publish the rate at times and to the extent the Secretary considers necessary. In deciding the buying rate, the Bank may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5e4543-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the last ascertainable transactions and quotations (direct or through exchange of other currencies); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5e4544-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if there is no buying rate, calculate the rate from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd5e4545-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actual transactions and quotations in demand or time bills of exchange; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd5e4546-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5151/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the last ascertainable transactions and quotations outside the United States in or for exchange payable in United States currency or foreign currency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd5e4547-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/991"},"text":"96 Stat. 991","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd5e4548-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd5e4549-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd5e454a-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5151(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:372(c)(2)(1st sentence), (3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1930-06-17/ch497/s522/c"},"text":"June 17, 1930, ch. 497, § 522(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/740"},"text":"46 Stat. 740","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1956-08-02/ch887/s3"},"text":"Aug. 2, 1956, ch. 887, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/946"},"text":"70 Stat. 946","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5151(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:372(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1894-08-27/ch349/s25"},"text":"Aug. 27, 1894, ch. 349, § 25","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/28/552"},"text":"28 Stat. 552","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1921-05-27/ch14/s403/a"},"text":"May 27, 1921, ch. 14, § 403(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/42/17"},"text":"42 Stat. 17","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1930-06-17/ch497/s522/a"},"text":"June 17, 1930, ch. 497, § 522(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/739"},"text":"46 Stat. 739","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5151(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:372(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1930-06-17/ch497/s522/b"},"text":"June 17, 1930, ch. 497, § 522(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/740"},"text":"46 Stat. 740","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5151(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:372(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5151(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:372(c)(2)(2d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “United States money” are substituted for “money of account” for consistency in the chapter. The words “standard coins of the country” are substituted for “values of standard coins in circulation of the various nations of the world” to eliminate unnecessary words. The words “Secretary of the Treasury” are substituted for “Director of the Mint” because of the source provisions restated in section 321(c) of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “on or after ","children":[{"tag":"date","attrib":{"date":"1930-06-17"},"text":"June 17, 1930","children":[],"tail":"” are omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1), the words “buying rate at noon on the day the merchandise is exported” are substituted for “such buying rate” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), the words “that is equal to” are substituted for “at a value measured by” because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(2), the words “buying rate” are substituted for “market buying rate for such cable transfers” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
