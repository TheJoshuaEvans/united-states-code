, before clause (1), the first sentence is substituted for 31:52–3(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1)(1st sentence) for consistency with other titles of the United States Code. The word “review” is substituted for “appeal” for consistency. The words “the procedures of”, “any other provision of law”, “of a final decision of the Board . . . the date . . . of the Board”, and “In any case filed under paragraph (1) . . . review the record and” are omitted as surplus. The words “final decision” are substituted for “agency action, findings, or conclusions” for consistency. Clause (2) is substituted for 31:52–3("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2)(B) to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcf54b17-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1984 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This clarifies section 755 by conforming it more closely to the language of the source provision of the section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf54b18-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcf54b19-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 312(e)(2) of the Architect of the Capitol Human Resources Act, referred to in subsec. (b), was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1831/e/2"},"text":"section 1831(e)(2) of Title 2","children":[],"tail":", The Congress, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/1/tV/s504/c/1"},"text":"Pub. L. 104–1, title V, § 504(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/41"},"text":"109 Stat. 41","children":[],"tail":", except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1435"},"text":"section 1435 of Title 2","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 706(k) of the Civil Rights Act of 1964, referred to in subsec. (b), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–5/k"},"text":"section 2000e–5(k) of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf54b1a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/283/s312/e/4/C/i"},"text":"Pub. L. 103–283, § 312(e)(4)(C)(i)","children":[],"tail":", substituted “, (7) or (9)” for “or (7)” in introductory provisions. See Application of Provisions Amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/283"},"text":"Pub. L. 103–283","children":[],"tail":" note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/283/s312/e/4/C/ii"},"text":"Pub. L. 103–283, § 312(e)(4)(C)(ii)","children":[],"tail":", substituted “applicant for employment, or employee of the Architect of the Capitol, the Botanic Garden, or the Senate Restaurants” for “or applicant for employment”, and inserted “or under section 312(e)(2) of the Architect of the Capitol Human Resources Act” after “of this title”. See Application of Provisions Amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/283"},"text":"Pub. L. 103–283","children":[],"tail":" note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426/s103/a"},"text":"Pub. L. 100–426, § 103(a)","children":[],"tail":", (b)(1), designated existing provisions as subsec. (a) and substituted “Federal Circuit” for “District of Columbia Circuit or by the court of appeals of the United States for the circuit in which the petitioner resides”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426/s103/b/2"},"text":"Pub. L. 100–426, § 103(b)(2)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/216"},"text":"Pub. L. 98–216","children":[],"tail":" substituted “A final decision under section 753(a)(1)–(3), (6), or (7) of this title may be reviewed by the United States Court of Appeals for the District of Columbia Circuit or by the court of appeals of the United States for the circuit in which the petitioner resides” for “A person may apply for review of a final decision under section 753(a)(1)–(3), (6), or (7) of this title by filing a petition for review with the United States Court of Appeals for the District of Columbia Circuit or with the court of appeals of the United States for the circuit in which the person resides” in provisions preceding par. (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf54b1b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf54b1c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426/tI/s103/c"},"text":"Pub. L. 100–426, title I, § 103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1599"},"text":"102 Stat. 1599","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/426/tI/s103/c"},"text":"“Nothing in any of the amendments made by this section [amending this section] shall apply with respect to an appeal pending on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcf54b1d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Provisions Amended by Pub. L. 103–283","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/283/s312/e"},"text":"section 312(e) of Pub. L. 103–283","children":[],"tail":" to be applied and administered as if section 312(e) and the amendments made by section 312(e) had not been enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/1/s504/c/2"},"text":"section 504(c)(2) of Pub. L. 104–1","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s751"},"text":"section 751 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
