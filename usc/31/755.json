{"tag":"section","attrib":{"id":"idbcf54b0d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s755"},"text":null,"children":[{"tag":"num","attrib":{"value":"755"},"text":"§ 755.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf54b0e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s755/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A final decision under section 753(a)(1)–(3), (6),,","children":[{"tag":"ref","attrib":{"idref":"fn002021"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002021"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Second comma probably should follow “(7)”."}],"tail":" (7) or (9) of this title may be reviewed by the United States Court of Appeals for the Federal Circuit. Chapter 158 of title 28 applies to a review under this subchapter, except the petition for review shall be filed by the 30th day after the petitioner receives notice of the decision. The court shall set aside a final decision the court decides is—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf54b0f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s755/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arbitrary, capricious, an abuse of discretion, or otherwise not consistent with law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54b10-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s755/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not made consistent with required procedures; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54b11-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s755/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unsupported by substantial evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf54b12-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s755/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an officer, employee, applicant for employment, or employee of the Architect of the Capitol, the Botanic Garden, or the Senate Restaurants is the prevailing party in a proceeding under this section, and the decision is based on a finding of discrimination prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s732/f"},"text":"section 732(f) of this title","children":[],"tail":" or under section 312(e)(2) "},{"tag":"ref","attrib":{"idref":"fn002022"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002022"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of the Architect of the Capitol Human Resources Act, attorney’s fees may be allowed by the court in accordance with the standards prescribed under section 706(k) of the Civil Rights Act of 1964."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf54b13-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/902"},"text":"96 Stat. 902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/216/s1/1"},"text":"Pub. L. 98–216, § 1(1)","children":[],"