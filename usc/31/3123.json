"children":[{"tag":"html:p","attrib":{},"text":"31:731.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3693.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:753(d)(2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1917-09-24/ch56"},"text":"Sept. 24, 1917, ch. 56","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/40/288"},"text":"40 Stat. 288","children":[],"tail":", § 18(d)(2d sentence); added "},{"tag":"html:a","attrib":{"href":"/us/act/1919-03-03/ch100/s1"},"text":"Mar. 3, 1919, ch. 100, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/40/1310"},"text":"40 Stat. 1310","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:768(words before semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1910-02-04/ch25/s1"},"text":"Feb. 4, 1910, ch. 25, § 1","children":[],"tail":"(words before semicolon), "},{"tag":"html:a","attrib":{"href":"/us/stat/36/192"},"text":"36 Stat. 192","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3123(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:732.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3698.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:733(words before semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3699(words before semicolon); restated ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1934-01-30/ch6/s9"},"text":"Jan. 30, 1934, ch. 6, § 9","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/341"},"text":"48 Stat. 341","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3123(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:766.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1917-09-24/ch56"},"text":"Sept. 24, 1917, ch. 56","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/40/288"},"text":"40 Stat. 288","children":[],"tail":", § 16; added "},{"tag":"html:a","attrib":{"href":"/us/act/1918-04-04/ch44/s6"},"text":"Apr. 4, 1918, ch. 44, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/40/505"},"text":"40 Stat. 505","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/809/s401"},"text":"Pub. L. 89–809, § 401","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/1590"},"text":"80 Stat. 1590","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “legal tender” are substituted for “in coin or its equivalent” in 31:731 and “gold coin of the present standard of value” in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1910-02-01/s1"},"text":"section 1 of the Act of Feb. 1, 1910","children":[],"tail":", and section 18(d)(2d sentence) of the Second Liberty Bond Act because of "},{"tag":"ref","attrib":{"href":"/us/act/1933-06-05/s1"},"text":"section 1 of the Act of June 5, 1933","children":[],"tail":" (ch. 48, "},{"tag":"ref","attrib":{"href":"/us/stat/48/113"},"text":"48 Stat. 113","children":[],"tail":"). The words “obligations of the Government” are substituted for 31:731(1st sentence 18th–last words), “thereof” in 31:753(d), and 31:768(1st 17 words) for clarity and consistency and to eliminate unnecessary words. The text of 31:731(last sentence) is omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “cause to be”, “out of any money in the Treasury not otherwise appropriated”, “falling”, “any portion of”, and “authorized by law” in 31:732 are omitted as surplus. The text of 31:733(words between semicolon and colon) is omitted as unnecessary because of chapter 53 of the revised title. The text of 31:733(words after colon) is omitted as superseded by the Bretton Woods Agreement Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s286"},"text":"22 U.S.C. 286","children":[],"tail":" et seq.) and sections 6 and 9 of the Act of "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/94/564"},"text":"Pub. L. 94–564","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2661"},"text":"90 Stat. 2661","children":[],"tail":"), repealing 31:449 that provided for parity of the dollar on terms of gold and special drawing rights."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “currency” is substituted for “money or . . . moneys” for clarity and because of 1:1.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “but not also in United States gold coin” and “in such manner” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “dollar” before “amount”, and “value”, are added for clarity. The words “estimated by the Director of the Mint, and” are omitted because of the source provisions restated in section 321(c) of the revised title. The word “published” is substituted for “proclaimed” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “as he may determine” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
