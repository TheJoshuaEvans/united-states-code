{"tag":"section","attrib":{"id":"idbd7d3fe3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6302"},"text":null,"children":[{"tag":"num","attrib":{"value":"6302"},"text":"§ 6302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d3fe4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “executive agency” does not include a mixed-ownership Government corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3fe5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “grant agreement” and “cooperative agreement” do not include an agreement under which is provided only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7d3fe6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6302/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct United States Government cash assistance to an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d3fe7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6302/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subsidy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d3fe8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6302/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d3fe9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6302/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan guarantee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d3fea-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6302/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3feb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “local government” means a unit of government in a State, a local public authority, a special district, an intrastate district, a council of governments, a sponsor group representative organization, an interstate entity, or another instrumentality of a local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3fec-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “other recipient” means a person or recipient (except a State or local government) authorized to receive United States Government assistance or procurement contracts and includes a charitable or educational institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3fed-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","childre