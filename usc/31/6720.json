{"tag":"section","attrib":{"id":"idbd86b59e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720"},"text":null,"children":[{"tag":"num","attrib":{"value":"6720"},"text":"§ 6720.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions, application, and administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd86b59f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd86b5a0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “unit of general local government” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd86b5a1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a county, township, city, or political subdivision of a county, township, or city, that is a unit of general local government as determined by the Secretary of Commerce for general statistical purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b5a2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia and the recognized governing body of an Indian tribe or Alaskan Native village that carries out substantial governmental duties and powers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b5a3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “payment period” means each 1-year period beginning on October 1 of the years 1994 through 2000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b5a4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State and local taxes” means taxes imposed by a State government or unit of general local government or other political subdivision of a State government for public purposes (except employee and employer assessments and contributions to finance retirement and social insurance systems and other special assessments for capital outlay) as determined by the Secretary of Commerce for general statistical purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b5a5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means any of the several States and the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b5a6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “income” means the total money income received from all sources as determined by the Secretary of Commerce for general statistical purposes, which for units of general local government is reported by the Bureau of the Census for 1990 in the publication Summary Social, Economic, and Housing Characteristics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b5a7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “per capita income” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd86b5a8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the United States, the income of the United States divided by the population of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b5a9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a State, the income of that State, divided by the population of that State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b5aa-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a unit of general local government, the income of that unit of general local government divided by the population of the unit of general local government;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b5ab-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “finding of discrimination” means a decision by the Secretary about a complaint described in section 6716(b), a decision by a State or local administrative agency, or other information (under regulations prescribed by the Secretary) that it is more likely than not that a unit of general local government has not complied with section 6711(a) or (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b5ac-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “holding of discrimination” means a holding by a United States court, a State court, or an administrative law judge appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3105"},"text":"section 3105 of title 5","children":[],"tail":", United States Code, that a unit of general local government expending amounts received under this chapter has—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd86b5ad-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excluded a person in the United States from participating in, denied the person the benefits of, or subjected the person to discrimination under, a program or activity because of race, color, national origin, or sex; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b5ae-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violated a prohibition against discrimination described in section 6711(b); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b5af-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd86b5b0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation of Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may enter into agreements with other executive branch departments and agencies to delegate to that department or agency all or part of the Secretary’s responsibility for administering this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd86b5b1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Subsumed Areas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the entire geographic area of a unit of general local government is located in a larger entity, the unit of general local government is deemed to be located in the larger entity. If only part of the geographic area of a unit is located in a larger entity, each part is deemed to be located in the larger entity and to be a separate unit of general local government in determining allocations under this chapter. Except as provided in regulations prescribed by the Secretary, the Secretary shall make all data computations based on the ratio of the estimated population of the part to the population of the entire unit of general local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd86b5b2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6720/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Boundary and Other Changes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a boundary line change, a State statutory or constitutional change, annexation, a governmental reorganization, or other circumstance results in the application of sections 6704 through 6708 in a way that does not carry out the purposes of sections 6701 through 6708, the Secretary shall apply sections 6701 through 6708 under regulations of the Secretary in a way that is consistent with those purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd86b5b3-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31001/a"},"text":"Pub. L. 103–322, title III, § 31001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1880"},"text":"108 Stat. 1880","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd86b5b4-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd86b5b5-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd86b5b6-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 6720 to 6724 were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIV/s14001/a/1"},"text":"Pub. L. 99–272, title XIV, § 14001(a)(1)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/327"},"text":"100 Stat. 327","children":[],"tail":", 329, eff. "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6720, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1027"},"text":"96 Stat. 1027","children":[],"tail":", related to enforcement by Attorney General of prohibitions on discrimination."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6721, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1028"},"text":"96 Stat. 1028","children":[],"tail":", related to civil action by person adversely affected."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6722, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1028"},"text":"96 Stat. 1028","children":[],"tail":", related to judicial review."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6723, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1029"},"text":"96 Stat. 1029","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/185/s8"},"text":"Pub. L. 98–185, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1310"},"text":"97 Stat. 1310","children":[],"tail":", related to audits, investigations, and reviews."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6724, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1030"},"text":"96 Stat. 1030","children":[],"tail":", related to reports to Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
