{"tag":"section","attrib":{"id":"idbd0f89cf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1502"},"text":null,"children":[{"tag":"num","attrib":{"value":"1502"},"text":"§ 1502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Balances available","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0f89d0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The balance of an appropriation or fund limited for obligation to a definite period is available only for payment of expenses properly incurred during the period of availability or to complete contracts properly made within that period of availability and obligated consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1501"},"text":"section 1501 of this title","children":[],"tail":". However, the appropriation or fund is not available for expenditure for a period beyond the period otherwise authorized by law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f89d1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A provision of law requiring that the balance of an appropriation or fund be returned to the general fund of the Treasury at the end of a definite period does not affect the status of lawsuits or rights of action involving the right to an amount payable from the balance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0f89d2-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/928"},"text":"96 Stat. 928","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0f89d3-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd0f89d4-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd0f89d5-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1502(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:200(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-08-26/ch935/s1311/d"},"text":"Aug. 26, 1954, ch. 935, § 1311(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/831"},"text":"68 Stat. 831","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:712a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-07-06/ch299/s1"},"text":"July 6, 1949, ch. 299, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/407"},"text":"63 Stat. 407","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1502(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:665b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/52/s111"},"text":"Pub. L. 93–52, § 111","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/134"},"text":"87 Stat. 134","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) restates the source provisions to eliminate unnecessary words and for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “balance of an appropriation or fund” are substituted for “unexpended funds” for clarity and consistency in the revised chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd0f89d6-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd0f89d7-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Quarterly Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/75/dB/tV/s523"},"text":"Pub. L. 119–75, div. B, title V, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-02-03"},"text":"Feb. 3, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/321"},"text":"140 Stat. 321","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/75/dB/tV/s523"},"text":"“Not later than 30 days after the end of each calendar quarter, beginning with the first month of fiscal year 2026 the Departments of Labor, Health and Human Services and Education and the Social Security Administration shall provide the Committees on Appropriations of the House of Representatives and Senate a report on the status of balances of appropriations: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That for balances that are unobligated and uncommitted, committed, and obligated but unexpended, the monthly reports shall separately identify the amounts attributable to each source year of appropriation (beginning with fiscal year 2012, or, to the extent feasible, earlier fiscal years) from which balances were derived.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/47/dD/tV/s524"},"text":"Pub. L. 118–47, div. D, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-23"},"text":"Mar. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/707"},"text":"138 Stat. 707","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dH/tV/s524"},"text":"Pub. L. 117–328, div. H, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4912"},"text":"136 Stat. 4912","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dH/tV/s524"},"text":"Pub. L. 117–103, div. H, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/500"},"text":"136 Stat. 500","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dH/tV/s525"},"text":"Pub. L. 116–260, div. H, title V, § 525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":