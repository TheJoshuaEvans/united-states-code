":"129 Stat. 2653","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dG/tV/s523"},"text":"Pub. L. 113–235, div. G, title V, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2518"},"text":"128 Stat. 2518","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/dH/tV/s524"},"text":"Pub. L. 113–76, div. H, title V, § 524","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/413"},"text":"128 Stat. 413","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dF/tV/s526"},"text":"Pub. L. 112–74, div. F, title V, § 526","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1115"},"text":"125 Stat. 1115","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd0f89d8-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Energy and Water Development Appropriations Limited to Fiscal Year In Which Appropriated","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/377/tV/s501"},"text":"Pub. L. 102–377, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1342"},"text":"106 Stat. 1342","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/377/tV/s501"},"text":"“No part of any appropriation contained in this Act or subsequent Energy and Water Development Appropriations Acts shall remain available for obligation beyond the fiscal year specified in such Acts therein unless expressly so provided therein.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
