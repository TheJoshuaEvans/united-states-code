{"tag":"section","attrib":{"id":"idbcdd7cb6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333"},"text":null,"children":[{"tag":"num","attrib":{"value":"333"},"text":"§ 333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of misuse of Department of the Treasury names, symbols, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcdd7cb7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person may use, in connection with, or as a part of, any advertisement, solicitation, business activity, or product, whether alone or with other words, letters, symbols, or emblems—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcdd7cb8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the words “Department of the Treasury”, or the name of any service, bureau, office, or other subdivision of the Department of the Treasury,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7cb9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the titles “Secretary of the Treasury” or “Treasurer of the United States” or the title of any other officer or employee of the Department of the Treasury,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7cba-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the abbreviations or initials of any entity referred to in paragraph (1),","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7cbb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the words “United States Savings Bond” or the name of any other obligation issued by the Department of the Treasury,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7cbc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any symbol or emblem of an entity referred to in paragraph (1) (including the design of any envelope or stationary used by such an entity), and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7cbd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any colorable imitation of any such words, titles, abbreviations, initials, symbols, or emblems,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in a manner which could reasonably be interpreted or construed as conveying the false impression that such advertisement, solicitation, business activity, or product is in any manner approved, endorsed, sponsored, or authorized by, or associated with, the Department of the Treasury or any entity referred to in paragraph (1) or any officer or employee thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdd7cbe-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Disclaimers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any determination of whether a person has violated the provisions of subsection (a) shall be made without regard to any use of a disclaimer of affiliation with the United States Government or any particular agency or instrumentality thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdd7cbf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcdd7cc0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury may impose a civil penalty on any person who violates the provisions of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7cc1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount of penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of the civil penalty imposed by paragraph (1) shall not exceed $5,000 for each use of any material in violation of subsection (a). If such use is in a broadcast or telecast, the preceding sentence shall be applied by substituting “$25,000” for “$5,000”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7cc2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time limitations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcdd7cc3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury may assess any civil penalty under paragraph (1) at any time before the end of the 3-year period beginning on the date of the violation with respect to which such penalty is imposed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcdd7cc4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury may commence a civil action to recover any penalty imposed under this subsection at any time before the end of the 2-year period beginning on the date on which such penalty was assessed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7cc5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination with subsection","children":[],"tail":" (d).—"}],"tail":null},{"tag":"content","attrib":{},"text":"No penalty may be assessed under this subsection with respect to any violation after a criminal proceeding with respect to such violation has been commenced under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdd7cc6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Penalty.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcdd7cc7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any person knowingly violates subsection (a), such person shall, upon conviction thereof, be fined not more than $10,000 for each such use or imprisoned not more than 1 year, or both. If such use is in a broadcast or telecast, the preceding sentence shall be applied by substituting “$50,000” for “$10,000”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7cc8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person may be prosecuted, tried, or punished under paragraph (1) for any violation of subsection (a) unless the indictment is found or the information instituted during the 3-year period beginning on the date of the violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7cc9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s333/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination with subsection","children":[],"tail":" (c).—"}],"tail":null},{"tag":"content","attrib":{},"text":"No criminal proceeding may be commenced under this subsection with respect to any violation if a civil penalty has previously been assessed under subsection (c) with respect to such violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcdd7cca-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/tIII/s312"},"text":"Pub. L. 103–296, title III, § 312","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1528"},"text":"108 Stat. 1528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcdd7ccb-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcdd7ccc-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbcdd7ccd-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/tIII/s312/m"},"text":"Pub. L. 103–296, title III, § 312(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1530"},"text":"108 Stat. 1530","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/296/tIII/s312/m"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–10"},"text":"section 1320b–10 of Title 42","children":[],"tail":", The Public Health and Welfare] shall apply with respect to violations occurring after "},{"tag":"date","attrib":{"date":"1995-03-31"},"text":"March 31, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition of misuse of department of the treasury names, symbols, etc","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3) [enacting provisions set out below] shall take effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":"], and the amendments made by paragraphs (1) and (2) of subsection ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") [enacting this section] shall apply with respect to violations occurring after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcdd7cce-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Implementation of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296/tIII/s312"},"text":"Pub. L. 103–296, title III, § 312","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3), "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1530"},"text":"108 Stat. 1530","children":[],"tail":", required the Secretary of the Treasury to submit a report to Congress by "},{"tag":"date","attrib":{"date":"1996-05-01"},"text":"May 1, 1996","children":[],"tail":", on the implementation of the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/s312"},"text":"section 312 of Pub. L. 103–296","children":[],"tail":" (enacting this section and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1320b–10"},"text":"section 1320b–10 of Title 42","children":[],"tail":"), with such report to include the number of cases in which the Secretary has notified persons of violations of this section, the number of prosecutions commenced under such section, and the total amount of the penalties collected in such prosecutions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
