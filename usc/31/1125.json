{"tag":"section","attrib":{"id":"idbd0613f2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125"},"text":null,"children":[{"tag":"num","attrib":{"value":"1125"},"text":"§ 1125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elimination of unnecessary agency reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0613f3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0613f4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget justification materials","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “budget justification materials” has the meaning given the term in section 3(b)(2) of the Federal Funding Accountability and Transparency Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6101"},"text":"31 U.S.C. 6101","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/109/282"},"text":"Public Law 109–282","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0613f5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan or report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “plan or report” means any plan or report submitted to Congress, any committee of Congress, or subcommittee thereof, by not less than 1 agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0613f6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with Federal law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0613f7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the direction or request of a congressional report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0613f8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recurring plan or report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “recurring plan or report” means a plan or report submitted on a recurring basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0613f9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relevant congressional committee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “relevant congressional committee”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0613fa-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a congressional committee to which a recurring plan or report is required to be submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0613fb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any plan or report that is required to be submitted solely to the Committee on Armed Services of the House of Representatives or the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0613fc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Identification of Unnecessary Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0613fd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each agency shall include in the budget justification materials of the agency the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0613fe-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraphs (2) and (3), the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd0613ff-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of each recurring plan or report submitted by the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd061400-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An identification of whether the recurring plan or report listed in clause (i) was included in the most recent report issued by the Clerk of the House of Representatives concerning the reports that any agency is required by law or directed or requested by a committee report to make to Congress, any committee of Congress, or subcommittee thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd061401-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If applicable, the unique alphanumeric identifier for the recurring plan or report as required by section 7243(b)(1)(C)(vii) of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Public Law 117–263","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd061402-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The identification of any recurring plan or report the head of the agency determines to be outdated or duplicative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd061403-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to each recurring plan or report identified in subparagraph (A)(iv), the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd061404-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A recommendation on whether to sunset, modify, consolidate, or reduce the frequency of the submission of the recurring plan or report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd061405-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A citation to each provision of law or directive or request in a congressional report that requires or requests the submission of the recurring plan or report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd061406-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of the relevant congressional committees for the recurring plan or report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd061407-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A justification explaining, with respect to each recommendation described in subparagraph (B)(i) relating to a recurring plan or report—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd061408-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" why the head of the agency made the recommendation, which may include an estimate of the resources expended by the agency to prepare and submit the recurring plan or report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd061409-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the understanding of the head of the agency of the purpose of the recurring plan or report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd06140a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency consultation.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd06140b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In preparing the list required under paragraph (1)(A), if, in submitting a recurring plan or report, an agency is required to coordinate or consult with another agency or entity, the head of the agency submitting the recurring plan or report shall consult with the head of each agency or entity with whom consultation or coordination is required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd06140c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion in list","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, after a consultation under subparagraph (A), the head of each agency or entity consulted under that subparagraph agrees that a recurring plan or report is outdated or duplicative, the head of the agency required to submit the recurring plan or report shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd06140d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the recurring plan or report in the list described in paragraph (1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd06140e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify each agency or entity with which the head of the agency is required to coordinate or consult in submitting the recurring plan or report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd06140f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disagreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the head of any agency or entity consulted under subparagraph (A) does not agree that a recurring plan or report is outdated or duplicative, the head of the agency required to submit the recurring plan or report shall not include the recurring plan or report in the list described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd061410-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Government-wide or multi-agency plan and report submissions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a recurring plan or report required to be submitted by not less than 2 agencies, the Director of the Office of Management and Budget shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd061411-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether the requirement to submit the recurring plan or report is outdated or duplicative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd061412-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to Congress accordingly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd061413-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan and report submissions conformity to the access to congressionally mandated reports act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to an agency recommendation, citation, or justification made under subparagraph (B) or (C) of paragraph (1) or a recommendation by the Director of the Office of Management and Budget under paragraph (3), the agency or Director, as applicable, shall also provide this information to the Director of the Government Publishing Office in conformity with the agency submission requirements under section 7244(a) of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Public Law 117–263","children":[],"tail":"; chapter 41 of title 44 note) in conformity with guidance issued by the Director of the Office of Management and Budget under section 7244(b) of such Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd061414-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction on Agency Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to exempt the head of an agency from a requirement to submit a recurring plan or report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd061415-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1125/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request for Elimination of Unnecessary Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to including the list of plans and reports determined to be outdated or duplicative by each agency in the budget justification materials of each agency, the Director of the Office of Management and Budget may concurrently submit to Congress legislation to eliminate or consolidate such plans and reports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd061416-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/352/s11/b"},"text":"Pub. L. 111–352, § 11(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3881"},"text":"124 Stat. 3881","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/172/s2/a"},"text":"Pub. L. 118–172, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2593"},"text":"138 Stat. 2593","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd061417-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd061418-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd061419-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 7243(b)(1)(C)(vii) and 7244(a), (b) of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023, referred to in subsec. (b)(1)(A)(iii), (4), are sections 7243(b)(1)(C)(vii) and 7244(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", which are set out in a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s4101"},"text":"section 4101 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd06141a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/172/s2/a/2"},"text":"Pub. L. 118–172, § 2(a)(2)","children":[],"tail":", added subsecs. (a) and (b) and struck out former subsecs. (a) and (b) which related to agency identification of unnecessary reports and plans and reports for first year of implementation and subsequent years, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/172/s2/a/2"},"text":"Pub. L. 118–172, § 2(a)(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/172/s2/a/3"},"text":"Pub. L. 118–172, § 2(a)(3)","children":[],"tail":", substituted “in the budget justification materials of each agency” for “in the budget of the United States Government, as provided by section 1105(a)(37)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/172/s2/a/1"},"text":"Pub. L. 118–172, § 2(a)(1)","children":[],"tail":", redesignated subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd06141b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd06141c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Updated OMB Guidance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/172/s2/c/2"},"text":"Pub. L. 118–172, § 2(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2596"},"text":"138 Stat. 2596","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/172/s2/c/2"},"text":"“Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], the Director of the Office of Management and Budget shall issue updated guidance to agencies to ensure that the requirements under subsections (a) and (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1125"},"text":"section 1125 of title 31","children":[],"tail":", United States Code, as amended by this Act, for agency submissions of recommendations and justifications for plans and reports to sunset, modify, consolidate, or reduce the frequency of the submission of [sic] are also submitted as a separate attachment in conformity with the agency submission requirements of electronic copies of reports submitted by agencies under section 7244(a) of the James M. Inhofe National Defense Authorization Act for Fiscal Year 2023 ("},{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Public Law 117–263","children":[],"tail":"; chapter 41 of title 44, United States Code, note ["},{"tag":"ref","attrib":{"href":"/us/usc/t44/s4101"},"text":"44 U.S.C. 4101","children":[],"tail":" note prec.]) for publication on the online portal established under section 7243 of such Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
