{"tag":"section","attrib":{"id":"idbd7d404d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402"},"text":null,"children":[{"tag":"num","attrib":{"value":"6402"},"text":"§ 6402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data standards for grant reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7d404e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d404f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of standard-setting agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall designate the Executive department that administers the greatest number of programs under which Federal awards are issued in a calendar year as the standard-setting agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4050-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of enactment of this chapter, the Secretary and the Director shall establish Governmentwide data standards for information reported by recipients of Federal awards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4051-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The data standards established under paragraph (2) shall include, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7fb052-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" standard definitions for data elements required for managing Federal awards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fb053-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unique identifiers for Federal awards and recipients of Federal awards that can be consistently applied Governmentwide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7fb054-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The data standards established under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7fb055-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include core data elements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb056-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may cover information required by law to be reported to any agency by recipients of Federal awards, including audit-related information reported under chapter 75 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb057-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used by the Director or any agency to require the collection of any data not otherwise required under Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7fb058-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The data standards established under subsection (a) shall, to the extent reasonable and practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7fb059-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" render information reported by recipients of Federal awards fully searchable and machine-readable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb05a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be nonproprietary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb05b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate standards developed and maintained by voluntary consensus standards bodies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb05c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be consistent with and implement applicable accounting and reporting principles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb05d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate the data standards established under the Federal Funding Accountability and Transparency Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6101"},"text":"31 U.S.C. 6101","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7fb05e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the data standards under subsection (a), the Secretary and the Director shall consult with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7fb05f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury to ensure that the data standards established under subsection (a) incorporate the data standards established under the Federal Funding Accountability and Transparency Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6101"},"text":"31 U.S.C. 6101","children":[],"tail":" note);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb060-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of each agency that issues Federal awards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb061-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recipients of Federal awards and organizations representing recipients of Federal awards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb062-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private sector experts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb063-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the public, including privacy experts, privacy advocates, auditors, and industry stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb064-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6402/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7fb065-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/103/s4/a"},"text":"Pub. L. 116–103, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3268"},"text":"133 Stat. 3268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7fb066-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd7fb067-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd7fb068-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in subsec. (a)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/103"},"text":"Pub. L. 116–103","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Funding Accountability and Transparency Act of 2006, referred to in subsecs. (c)(5) and (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/282"},"text":"Pub. L. 109–282","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-26"},"text":"Sept. 26, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1186"},"text":"120 Stat. 1186","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6101"},"text":"section 6101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd7fb069-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7fb06a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Consolidation of Assistance-Related Information; Publication of Public Information as Open Data","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/103/s6"},"text":"Pub. L. 116–103, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3270"},"text":"133 Stat. 3270","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/103/s6"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection of Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 5 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":"], the Secretary and the Director shall, using the data standards established under chapter 64 of title 31, United States Code, as added by section 4(a) of this Act, enable the collection, public display, and maintenance of Federal award information as a Governmentwide data set, subject to reasonable restrictions established by the Director to ensure protection of personally identifiable information and otherwise sensitive information."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary and the Director shall require the publication of data reported by recipients of Federal awards that is collected from all agencies on a single public portal, which may be an existing Governmentwide website, as determined appropriate by the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"FOIA","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall require the disclosure to the public of information that would be exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", United States Code (commonly known as the ‘Freedom of Information Act’).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of terms used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/103/s6"},"text":"section 6 of Pub. L. 116–103","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/103/s3"},"text":"section 3 of Pub. L. 116–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6401"},"text":"section 6401 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7fb06b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Evaluation of Nonproprietary Identifiers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/103/s7"},"text":"Pub. L. 116–103, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3270"},"text":"133 Stat. 3270","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/103/s7"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director and the Secretary shall determine whether to use nonproprietary identifiers described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6402/a/3/B"},"text":"section 6402(a)(3)(B) of title 31","children":[],"tail":", United States Code, as added by section 4(a) of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors to Be Considered","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making the determination under subsection (a), the Director and the Secretary shall consider factors such as accessibility and cost to recipients of Federal awards, agencies that issue Federal awards, private sector experts, and members of the public, including privacy experts, privacy advocates, transparency experts, and transparency advocates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication and Report on Determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than the earlier of 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":"] or the date on which the Director and the Secretary establish data standards under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6402/a/2"},"text":"section 6402(a)(2) of title 31","children":[],"tail":", United States Code, as added by section 4(a) of this Act, the Director and the Secretary shall publish and submit to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Oversight and Reform [now Committee on Oversight and Accountability] of the House of Representatives a report explaining the reasoning for the determination made under subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of terms used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/103/s7"},"text":"section 7 of Pub. L. 116–103","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/103/s3"},"text":"section 3 of Pub. L. 116–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6401"},"text":"section 6401 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
