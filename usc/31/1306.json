{"tag":"section","attrib":{"id":"idbd085d9b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1306"},"text":null,"children":[{"tag":"num","attrib":{"value":"1306"},"text":"§ 1306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of foreign credits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd085d9c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Foreign credits (including currencies) owed to or owned by the United States may be used by any agency for any purpose for which appropriations are made for the agency for the current fiscal year (including the carrying out of Acts requiring or authorizing the use of such credits), but only when reimbursement therefor is made to the Treasury from applicable appropriations of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd085d9d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception to Reimbursement Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Credits described in subsection (a) that are received as exchanged allowances, or as the proceeds of the sale of personal property, may be used in whole or partial payment for the acquisition of similar items, to the extent and in the manner authorized by law, without reimbursement to the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd085d9e-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/918"},"text":"96 Stat. 918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tVI/s612/a"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title VI, § 612(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–355.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd085d9f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd085da0-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd085da1-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1306","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:724.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-07-15/ch758/s1415"},"text":"July 15, 1952, ch. 758, § 1415","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/662"},"text":"66 Stat. 662","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “are not available for expenditure by agencies except as provided annually in general appropriation laws” are substituted for “will not be available for expenditure by agencies of the United States after ","children":[{"tag":"date","attrib":{"date":"1953-06-30"},"text":"June 30, 1953","children":[],"tail":", except as may be provided for annually in appropriation Acts” because of section 101 of the revised title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd085da2-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd085da3-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows: “Foreign credits owed to or owned by the Treasury are not available for expenditure by agencies except as provided annually in general appropriation laws.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd085da4-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd085da5-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tVI/s612/b"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title VI, § 612(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–356, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/208/dA/tI/s101/f/tVI/s612/b"},"text":"“The amendment made by this section [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":"] and shall apply thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd085da6-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Appropriations of Excess Currencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/391/tV/s566"},"text":"Pub. L. 102–391, title V, § 566","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1680"},"text":"106 Stat. 1680","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/391/tV/s566"},"text":"“The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1306"},"text":"section 1306 of title 31","children":[],"tail":", United States Code, shall not be waived to carry out the provisions of the Foreign Assistance Act of 1961 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.] by any provision of law enacted after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":"] unless such provision makes specific reference to this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriations acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/513/tV/s570"},"text":"Pub. L. 101–513, title V, § 570","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2041"},"text":"104 Stat. 2041","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/167/tV/s583"},"text":"Pub. L. 101–167, title V, § 583","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1251"},"text":"103 Stat. 1251","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
