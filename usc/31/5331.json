{"tag":"section","attrib":{"id":"idbd6ee838-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331"},"text":null,"children":[{"tag":"num","attrib":{"value":"5331"},"text":"§ 5331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports relating to coins and currency received in nonfinancial trade or business","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd6ee839-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coin and Currency Receipts of More Than ","children":[],"tail":"$10,000.—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6ee83a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd6ee83b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is engaged in a trade or business, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6ee83c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, in the course of such trade or business, receives more than $10,000 in coins or currency in 1 transaction (or 2 or more related transactions), or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71583d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is required to file a report under section 6050I(g) of the Internal Revenue Code of 1986,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall file a report described in subsection (b) with respect to such transaction (or related transactions) with the Financial Crimes Enforcement Network at such time and in such manner as the Secretary may, by regulation, prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd71583e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form and Manner of Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report is described in this subsection if such report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd71583f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in such form as the Secretary may prescribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd715840-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd715841-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address, and such other identification information as the Secretary may require, of the person from whom the coins or currency was received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd715842-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of coins or currency received;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd715843-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date and nature of the transaction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd715844-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information, including the identification of the person filing the report, as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd715845-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd715846-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amounts received by financial institutions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not apply to amounts received in a transaction reported under section 5313 and regulations prescribed under such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd715847-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transactions occurring outside the united states","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except to the extent provided in regulations prescribed by the Secretary, subsection (a) shall not apply to any transaction if the entire transaction occurs outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd715848-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Currency Includes Foreign Currency and Certain Monetary Instruments.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd715849-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “currency” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd71584a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign currency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd71584b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent provided in regulations prescribed by the Secretary, any monetary instrument (whether or not in bearer form) with a face amount of not more than $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd71584c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5331/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1)(B) shall not apply to any check drawn on the account of the writer in a financial institution referred to in subparagraph (A), (B), (C), (D), (E), (F), (G), (J), (K), (R), or (S) of section 5312(a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd71584d-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s365/a"},"text":"Pub. L. 107–56, title III, § 365(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/333"},"text":"115 Stat. 333","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dC/tI/s120"},"text":"Pub. L. 112–74, div. C, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/891"},"text":"125 Stat. 891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd71584e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd71584f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd715850-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 6050I(g) of the Internal Revenue Code of 1986, referred to in subsec. (a)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6050I"},"text":"section 6050I of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd715851-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74"},"text":"Pub. L. 112–74","children":[],"tail":" redesignated pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1), substituted “, and” for “; and” in subpar. (A), inserted “or” at end of subpar. (B), and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd715852-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd715853-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s365/e"},"text":"Pub. L. 107–56, title III, § 365(e)","children":[],"tail":", formerly § 365(f), "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/335"},"text":"115 Stat. 335","children":[],"tail":", renumbered § 365(e) by "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVI/s6202/n/2"},"text":"Pub. L. 108–458, title VI, § 6202(n)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3746"},"text":"118 Stat. 3746","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/458/tVI/s6202/n/2"},"text":"“Regulations which the Secretary [of the Treasury] determines are necessary to implement this section [enacting this section and amending sections 5312, 5317, 5318, 5321, 5324, 5326, and former 5328 of this title] shall be published in final form before the end of the 6-month period beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
