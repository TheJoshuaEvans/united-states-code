{"tag":"section","attrib":{"id":"idbd6ee7e8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5325"},"text":null,"children":[{"tag":"num","attrib":{"value":"5325"},"text":"§ 5325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification required to purchase certain monetary instruments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd6ee7e9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No financial institution may issue or sell a bank check, cashier’s check, traveler’s check, or money order to any individual in connection with a transaction or group of such contemporaneous transactions which involves United States coins or currency (or such other monetary instruments as the Secretary may prescribe) in amounts or denominations of $3,000 or more unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6ee7ea-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5325/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the individual has a transaction account with such financial institution and the financial institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd6ee7eb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5325/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verifies that fact through a signature card or other information maintained by such institution in connection with the account of such individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6ee7ec-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5325/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" records the method of verification in accordance with regulations which the Secretary of the Treasury shall prescribe; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6ee7ed-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5325/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual furnishes the financial institution with such forms of identification as the Secretary of the Treasury may require in regulations which the Secretary shall prescribe and the financial institution verifies and records such information in accordance with regulations which such Secretary shall prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd6ee7ee-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Secretary Upon Request","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any information required to be recorded by any financial institution under paragraph (1) or (2) of subsection (a) shall be reported by such institution to the Secretary of the Treasury at the request of such Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd6ee7ef-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5325/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transaction Account Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “transaction account” has the meaning given to such term in section 19(b)(1)(C) of the Federal Reserve Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd6ee7f0-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6185/b"},"text":"Pub. L. 100–690, title VI, § 6185(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4355"},"text":"102 Stat. 4355","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd6ee7f1-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd6ee7f2-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd6ee7f3-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 19(b)(1)(C) of the Federal Reserve Act, referred to in subsec. (c), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1/C"},"text":"section 461(b)(1)(C) of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
