{"tag":"section","attrib":{"id":"idbd3f4c5c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C"},"text":null,"children":[{"tag":"num","attrib":{"value":"3720C"},"text":"§ 3720C.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt Collection Improvement Account","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd3f4c5d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd3f4c5e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby established in the Treasury a special fund to be known as the “Debt Collection Improvement Account” (hereinafter in this section referred to as the “Account”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd3f4c5f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Account shall be maintained and managed by the Secretary of the Treasury, who shall ensure that agency programs are credited with amounts transferred under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd3f4c60-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd3f4c61-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after the end of a fiscal year, an agency may transfer to the Account the amount described in paragraph (3), as adjusted under paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd3f4c62-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Agency transfers to the Account may include collections from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd3f4c63-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" salary, administrative, and tax refund offsets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3f4c64-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3f4c65-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private collection agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3f4c66-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sales of delinquent loans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3f4c67-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracts to locate or recover assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd3f4c68-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount referred to in paragraph (1) shall be 5 percent of the amount of delinquent debt collected by an agency in a fiscal year, minus the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd3f4c69-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent of the amount of delinquent nontax debt collected by the agency in the previous fiscal year, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3f4c6a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 percent of the average annual amount of delinquent nontax debt collected by the agency in the previous 4 fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd3f4c6b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In consultation with the Secretary of the Treasury, the Office of Management and Budget may adjust the amount described in paragraph (3) for an agency to reflect the level of effort in credit management programs by the agency. As an indicator of the level of effort in credit management, the Office of Management and Budget shall consider the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd3f4c6c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of days between the date a claim or debt became delinquent and the date which an agency referred the debt or claim to the Secretary of the Treasury or obtained an exemption from this referral under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3711/g/2"},"text":"section 3711(g)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3f4c6d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ratio of delinquent debts or claims to total receivables for a given program, and the change in this ratio over a period of time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd3f4c6e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd3f4c6f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury may make payments from the Account solely to reimburse agencies for qualified expenses. For agencies with franchise funds, such payments may be credited to subaccounts designated for debt collection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd3f4c70-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section, the term “qualified expenses” means expenditures for the improvement of credit management, debt collection, and debt recovery activities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd3f4c71-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" account servicing (including cross-servicing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3711/g"},"text":"section 3711(g) of this title","children":[],"tail":"),"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3f4c72-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automatic data processing equipment acquisitions,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3f4c73-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delinquent debt collection,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3f4c74-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures to minimize delinquent debt,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3f4c75-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sales of delinquent debt,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3f4c76-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" asset disposition, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3f4c77-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training of personnel involved in credit and debt management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd3f4c78-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd3f4c79-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts transferred to the Account shall be available to the Secretary of the Treasury for purposes of this section to the extent and in amounts provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd3f4c7a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As soon as practicable after the end of the third fiscal year after which amounts transferred are first available pursuant to this section, and every 3 years thereafter, any uncommitted balance in the Account shall be transferred to the general fund of the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd3f4c7b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For direct loans and loan guarantee programs subject to title V of the Congressional Budget Act of 1974, amounts credited in accordance with subsection (c) shall be considered administrative costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd3f4c7c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3720C/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall prescribe such rules, regulations, and procedures as the Secretary considers necessary or appropriate to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd3f4c7d-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/tIII/s31001/t/1"},"text":"Pub. L. 104–134, title III, § 31001(t)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-373"},"text":"110 Stat. 1321–373","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd3f4c7e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd3f4c7f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd3f4c80-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Congressional Budget Act of 1974, referred to in subsec. (d), is titles I through IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text":"Pub. L. 93–344","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/297"},"text":"88 Stat. 297","children":[],"tail":". Title V of the Act, known as the Federal Credit Reform Act of 1990, is classified generally to subchapter III (§ 661 et seq.) of chapter 17A of Title 2, The Congress. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
