nd Budget” because sections 101 and 102(a) of Reorganization Plan No. 2 of 1970 (eff. "},{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2085"},"text":"84 Stat. 2085","children":[],"tail":") designated the Bureau of the Budget as the Office of Management and Budget and transferred all functions of the Bureau to the President."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd11fa4e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd11fa4f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" inserted at end “A copy of each report shall also be transmitted to the Comptroller General on the same date the report is transmitted to the President and Congress.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
