{"tag":"section","attrib":{"id":"idbd11fa45-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1517"},"text":null,"children":[{"tag":"num","attrib":{"value":"1517"},"text":"§ 1517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited obligations and expenditures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd11fa46-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer or employee of the United States Government or of the District of Columbia government may not make or authorize an expenditure or obligation exceeding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd11fa47-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1517/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an apportionment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd11fa48-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1517/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount permitted by regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1514/a"},"text":"section 1514(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd11fa49-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an officer or employee of an executive agency or of the District of Columbia government violates subsection (a) of this section, the head of the executive agency or the Mayor of the District of Columbia, as the case may be, shall report immediately to the President and Congress all relevant facts and a statement of actions taken. A copy of each report shall also be transmitted to the Comptroller General on the same date the report is transmitted to the President and Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd11fa4a-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/932"},"text":"96 Stat. 932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dG/tI/s1401/b"},"text":"Pub. L. 108–447, div. G, title I, § 1401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3192"},"text":"118 Stat. 3192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd11fa4b-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd11fa4c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd11fa4d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision 