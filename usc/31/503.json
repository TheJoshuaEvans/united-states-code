{"tag":"section","attrib":{"id":"idbce96412-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503"},"text":null,"children":[{"tag":"num","attrib":{"value":"503"},"text":"§ 503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Deputy Director for Management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbce96413-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the direction and approval of the Director, the Deputy Director for Management shall establish governmentwide financial management policies for executive agencies and shall perform the following financial management functions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbce96414-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Perform all functions of the Director, including all functions delegated by the President to the Director, relating to financial management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96415-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide overall direction and leadership to the executive branch on financial management matters by establishing financial management policies and requirements, and by monitoring the establishment and operation of Federal Government financial management systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96416-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review agency budget requests for financial management systems and operations, and advise the Director on the resources required to develop and effectively operate and maintain Federal Government financial management systems and to correct major deficiencies in such systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96417-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review and, where appropriate, recommend to the Director changes to the budget and legislative proposals of agencies to ensure that they are in accordance with financial management plans of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96418-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Monitor the financial execution of the budget in relation to actual expenditures, including timely performance reports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96419-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Oversee, periodically review, and make recommendations to heads of agencies on the administrative structure of agencies with respect to their financial management activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce9641a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop and maintain qualification standards for agency Chief Financial Officers and for agency Deputy Chief Financial Officers appointed under sections 901 and 903, respectively (excluding any officer designated or appointed under section 901(c)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce9641b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide advice to agency heads with respect to the selection of agency Chief Financial Officers and Deputy Chief Financial Officers (excluding any officer designated or appointed under section 901(c)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce9641c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide advice to agencies regarding the qualifications, recruitment, performance, and retention of other financial management personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce9641d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assess the overall adequacy of the professional qualifications and capabilities of financial management staffs throughout the Government and make recommendations on ways to correct problems which impair the capacity of those staffs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce9641e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Settle differences that arise among agencies regarding the implementation of financial management policies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce9641f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chair the Chief Financial Officers Council established by section 302 of the Chief Financial Officers Act of 1990.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96420-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communicate with the financial officers of State and local governments, and foster the exchange with those officers of information concerning financial management standards, techniques, and processes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96421-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issue such other policies and directives as may be necessary to carry out this section, and perform any other function prescribed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce96422-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to the direction and approval of the Director, the Deputy Director for Management shall establish general management policies for executive agencies and perform the following general management functions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbce96423-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate and supervise the general management functions of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96424-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Perform all functions of the Director, including all functions delegated by the President to the Director, relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbce96425-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" managerial systems, including the systematic measurement of performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce96426-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procurement policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce96427-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant, cooperative agreement, and assistance management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce96428-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and statistical policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce96429-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" property management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce9642a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human resources management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce9642b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulatory affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce9642c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other management functions, including organizational studies, long-range planning, program evaluation, productivity improvement, and experimentation and demonstration programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce9642d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide complete, reliable, and timely information to the President, the Congress, and the public regarding the management activities of the executive branch.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce9642e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilitate actions by the Congress and the executive branch to improve the management of Federal Government operations and to remove impediments to effective administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce9642f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chair the Chief Information Officers Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3603"},"text":"section 3603 of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96430-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Provide leadership in management innovation, through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbce96431-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experimentation, testing, and demonstration programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce96432-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adoption of modern management concepts and technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96433-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Work with State and local governments to improve and strengthen intergovernmental relations, and provide assistance to such governments with respect to intergovernmental programs and cooperative arrangements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96434-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Review and, where appropriate, recommend to the Director changes to the budget and legislative proposals of agencies to ensure that they respond to program evaluations by, and are in accordance with general management plans of, the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96435-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide advice to agencies on the qualification, recruitment, performance, and retention of managerial personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96436-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Perform any other functions prescribed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce96437-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program and Project Management.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbce96438-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the direction and approval of the Director, the Deputy Director for Management or a designee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbce96439-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt governmentwide standards, policies, and guidelines for program and project management for executive agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce9643a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee implementation of program and project management for the standards, policies, and guidelines established under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce9643b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chair the Program Management Policy Council established under section 1126(b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce9643c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish standards and policies for executive agencies, consistent with widely accepted standards for program and project management planning and delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce9643d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage with the private sector to identify best practices in program and project management that would improve Federal program and project management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce9643e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct portfolio reviews to address programs identified as high risk by the Government Accountability Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce9643f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than annually, conduct portfolio reviews of agency programs in coordination with Project Management Improvement Officers designated under section 1126(a)(1) to assess the quality and effectiveness of program management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce96440-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a 5-year strategic plan for program and project management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96441-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to department of defense","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to the Department of Defense to the extent that the provisions of that paragraph are substantially similar to or duplicative of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbce96442-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of chapter 87 of title 10; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbce96443-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s503/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policy, guidance, or instruction of the Department related to program management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbce96444-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/576/tII/s202/b"},"text":"Pub. L. 101–576, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2839"},"text":"104 Stat. 2839","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/f/1/B"},"text":"Pub. L. 103–272, § 4(f)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1361"},"text":"108 Stat. 1361","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/58/tVI/s638/g"},"text":"Pub. L. 106–58, title VI, § 638(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-09-29"},"text":"Sept. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/476"},"text":"113 Stat. 476","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/tI/s102/b"},"text":"Pub. L. 107–347, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2910"},"text":"116 Stat. 2910","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/264/s2/a/1"},"text":"Pub. L. 114–264, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-14"},"text":"Dec. 14, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1371"},"text":"130 Stat. 1371","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s861/a/1"},"text":"Pub. L. 114–328, div. A, title VIII, § 861(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2298"},"text":"130 Stat. 2298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s810/a"},"text":"Pub. L. 115–91, div. A, title VIII, § 810(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1458"},"text":"13