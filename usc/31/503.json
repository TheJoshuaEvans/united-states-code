rds, Policies, and Guidelines for Program and Project Management; Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/264/s2/a/2"},"text":"Pub. L. 114–264, § 2(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2016-12-14"},"text":"Dec. 14, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1372"},"text":"130 Stat. 1372","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/264/s2/a/2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for standards, policies, and guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-14"},"text":"Dec. 14, 2016","children":[],"tail":"], the Deputy Director for Management of the Office of Management and Budget shall issue the standards, policies, and guidelines required under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s503/c"},"text":"section 503(c) of title 31","children":[],"tail":", United States Code, as added by paragraph (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date on which the standards, policies, and guidelines are issued under paragraph (2), the Deputy Director for Management of the Office of Management and Budget, in consultation with the Program Management Policy Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1126/b"},"text":"section 1126(b) of title 31","children":[],"tail":", United States Code, as added by subsection (b)(1), and the Director of the Office of Management and Budget, shall issue any regulations as are necessary to implement the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s503/c"},"text":"section 503(c) of title 31","children":[],"tail":", United States Code, as added by paragraph (1).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVIII/s861/a/2"},"text":"Pub. L. 114–328, div. A, title VIII, § 861(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2299"},"text":"130 Stat. 2299","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tVIII/s810/c"},"text":"Pub. L. 115–91, div. A, title VIII, § 810(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1458"},"text":"131 Stat. 1458","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
