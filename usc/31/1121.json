{"tag":"section","attrib":{"id":"idbd061352-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121"},"text":null,"children":[{"tag":"num","attrib":{"value":"1121"},"text":"§ 1121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Progress reviews and use of performance information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd061353-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Performance Information To Achieve Federal Government Priority Goals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less than quarterly, the Director of the Office of Management and Budget, with the support of the Performance Improvement Council, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd061354-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each Federal Government priority goal required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1120/a"},"text":"section 1120(a) of this title","children":[],"tail":", review with the appropriate lead Government official the progress achieved during the most recent quarter, overall trend data, and the likelihood of meeting the planned level of performance;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd061355-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in such reviews officials from the agencies, organizations, and program activities that contribute to the accomplishment of each Federal Government priority goal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd061356-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess whether agencies, organizations, program activities, regulations, tax expenditures, policies, and other activities are contributing as planned to each Federal Government priority goal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd061357-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" categorize the Federal Government priority goals by risk of not achieving the planned level of performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd061358-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the Federal Government priority goals at greatest risk of not meeting the planned level of performance, identify prospects and strategies for performance improvement, including any needed changes to agencies, organizations, program activities, regulations, tax expenditures, policies or other activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd061359-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Use of Performance Information To Achieve Agency Priority Goals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less than quarterly, at each agency required to develop agency priority goals required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1120/b"},"text":"section 1120(b) of this title","children":[],"tail":", the head of the agency and Chief Operating Officer, with the support of the agency Performance Improvement Officer, shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd06135a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each agency priority goal, review with the appropriate goal leader the progress achieved during the most recent quarter, overall trend data, and the likelihood of meeting the planned level of performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd06135b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with relevant personnel within and outside the agency who contribute to the accomplishment of each agency priority goal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd06135c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess whether relevant organizations, program activities, regulations, policies, and other activities are contributing as planned to the agency priority goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd06135d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" categorize agency priority goals by risk of not achieving the planned level of performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd06135e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for agency priority goals at greatest risk of not meeting the planned level of performance, identify prospects and strategies for performance improvement, including any needed changes to agency program activities, regulations, policies, or other activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd06135f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Reviews of Progress Towards Strategic Goals and Objectives.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd061360-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered goal defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “covered goal” means a goal or objective established in the strategic plan of the agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s306/a"},"text":"section 306(a) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd061361-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than annually and consistent with guidance issued by the Director of the Office of Management and Budget, the head and Chief Operating Officer of each agency,","children":[{"tag":"ref","attrib":{"idref":"fn002032"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002032"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd061362-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each covered goal, review with the appropriate agency official responsible for the covered goal—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd061363-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the progress achieved toward the covered goal—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd061364-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the most recent fiscal year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd061365-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from recent sources of evidence available at the time of the review; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd061366-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood that the agency will achieve the covered goal;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd061367-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with relevant personnel within and outside the agency who contribute to the accomplishment of each covered goal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd061368-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess progress toward each covered goal by reviewing performance information and other types of evidence relating to each covered goal, such as program evaluations and statistical data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd061369-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify whether additional evidence is necessary to better assess progress toward each covered goal, and prioritize the development of the evidence described in subparagraph (C), such as through the plans required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s312"},"text":"section 312 of title 5","children":[],"tail":", if applicable;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd06136a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess whether relevant organizations, program activities, regulations, policies, and other activities contribute as planned to each covered goal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd06136b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, leverage the assessment performed under subparagraph (E) as part of the portfolio reviews required under section 503(c)(1)(G);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd06136c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any risks or impediments that would reduce or otherwise decrease the likelihood that the agency will achieve the covered goal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd06136d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each covered goal at greatest risk of not being achieved, identify prospects and strategies for performance improvement, including any necessary changes to program activities, regulations, policies, or other activities of the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd06136e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In fulfilling the requirements of paragraph (2), the head and Chief Operating Officer of each agency shall be supported by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd06136f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Performance Improvement Officer of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd061370-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, the Chief Data Officer, Evaluation Officer, Program Management Improvement Officer, and Statistical Official of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd061371-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1121/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other senior agency official designated by the head of the agency, the sustained involvement of whom may help the agency increase the likelihood of achieving 1 or more covered goals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd061372-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/352/s6"},"text":"Pub. L. 111–352, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3875"},"text":"124 Stat. 3875","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/190/s2/a/1"},"text":"Pub. L. 118–190, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2653"},"text":"138 Stat. 2653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd061373-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd061374-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd061375-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/190/s2/a/1/A"},"text":"Pub. L. 118–190, § 2(a)(1)(A)","children":[],"tail":", substituted “Progress reviews and use of performance information” for “Quarterly priority progress reviews and use of performance information” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/190/s2/a/1/B"},"text":"Pub. L. 118–190, § 2(a)(1)(B)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
