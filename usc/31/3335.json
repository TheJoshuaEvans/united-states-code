{"tag":"section","attrib":{"id":"idbd275742-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3335"},"text":null,"children":[{"tag":"num","attrib":{"value":"3335"},"text":"§ 3335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely disbursement of Federal funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd275743-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3335/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each head of an executive agency (other than the Tennessee Valley Authority) shall, under such regulations as the Secretary of the Treasury shall prescribe, provide for the timely disbursement of Federal funds through cash, checks, electronic funds transfer, or any other means identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd275744-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3335/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may collect from any executive agency which does not comply with subsection (a) a charge in an amount the Secretary determines to be the cost to the general fund of the Treasury caused by such noncompliance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd275745-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3335/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amounts of charges collected from an executive agency under this section shall be deposited in the Treasury and credited as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd275746-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3335/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any charge assessed by the Secretary under this section, to the maximum extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd275747-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3335/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be paid out of appropriations available for executive agency operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd275748-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3335/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be paid from amounts available for funding programs of an executive agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd275749-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/453/s4/a"},"text":"Pub. L. 101–453, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-24"},"text":"Oct. 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1058"},"text":"104 Stat. 1058","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd27574a-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd27574b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd27574c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/453/s4/c"},"text":"Pub. L. 101–453, § 4(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-24"},"text":"Oct. 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1059"},"text":"104 Stat. 1059","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/589/s2/1"},"text":"Pub. L. 102–589, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-11-10"},"text":"Nov. 10, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/5133"},"text":"106 Stat. 5133","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/589/s2/1"},"text":"“The Secretary of the Treasury shall prescribe regulations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3335"},"text":"section 3335 of title 31","children":[],"tail":", United States Code, as added by subsection (a), to ensure the full implementation of that section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
