{"tag":"section","attrib":{"id":"idbd0d1912-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1347"},"text":null,"children":[{"tag":"num","attrib":{"value":"1347"},"text":"§ 1347.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations or authorizations required for agencies in existence for more than one year","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0d1913-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1347/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency in existence for more than one year may not use amounts otherwise available for obligation to pay its expenses without a specific appropriation or specific authorization by law. If the principal duties and powers of the agency are substantially the same as or similar to the duties and powers of an agency established by executive order, the agency established later is deemed to have been in existence from the date the agency established by the order came into existence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0d1914-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1347/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as specifically authorized by law, another agency may not use amounts available for obligation to pay expenses to carry out duties and powers substantially the same as or similar to the principal duties and powers of an agency that is prohibited from using amounts under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0d1915-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/925"},"text":"96 Stat. 925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0d1916-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd0d1917-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd0d1918-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1347(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:696(1st, 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1944-06-27/ch286/s213"},"text":"June 27, 1944, ch. 286, § 213","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/387"},"text":"58 Stat. 387","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1347(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:696(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the word “agency” is substituted for “agency or instrumentality” because of section 101 of the revised title and for consistency. The words “amounts otherwise available for obligation” are substituted for “any appropriation or fund made available by this or any other Act”, and the words “duties and powers” are substituted for “functions”, for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “After ","children":[{"tag":"date","attrib":{"date":"1945-01-01"},"text":"January 1, 1945","children":[],"tail":"” are omitted as executed. The words “including those established by Executive order” are omitted the first time they appear as surplus. The words “from the date . . . came into existence” are substituted for “during the existence” for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “amounts” is substituted for “appropriations” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
