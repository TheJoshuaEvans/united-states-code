ail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:757c–2(a)(1st sentence), (b)(1)(1st sentence), (c)(1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1917-09-24/ch56"},"text":"Sept. 24, 1917, ch. 56","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/40/288"},"text":"40 Stat. 288","children":[],"tail":", § 22A(a)–(c)(1st sentence), (d); added "},{"tag":"html:span","attrib":{},"text":"Nov. 8, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/800/s5"},"text":"Pub. L. 89–800, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/1514"},"text":"80 Stat. 1514","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3106(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:757c–2(b)(1)(2d sentence words after 1st comma), (2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3106(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:757c–2(a)(last sentence), (b)(1)(2d sentence words before 1st comma, 3d, last sentences), (d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “In addition to the United States savings bonds authorized to be issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s757c"},"text":"section 757c of this title","children":[],"tail":"” are omitted as surplus. The words “through the United States Postal Service or otherwise” are omitted as surplus and unnecessary because of 39:411. The words “and may buy, redeem, and make refunds under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3111"},"text":"section 3111 of this title","children":[],"tail":"” are added because of the restatement. The words “and to retire any outstanding obligations of the United States bearing interest or issued on a discount basis” are omitted as unnecessary because of section 3111 of the revised title. The words “as the terms thereof may provide” are omitted because of the restatement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “conditions” is substituted for “terms” for consistency in the revised title and with other titles of the United States Code. The words “by regulations” are omitted as unnecessary. The words “at their option” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Section 3105(c)(1)–(5) of this title applies to this section” are substituted for 31:757c–2(a)(last sentence) and (b)(1)(2d sentence words before 1st comma, 3d sentence) to eliminate unnecessary words. The words “by regulations” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd1b70ee-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd1b70ef-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1983 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3106(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31 App.:757c–2 (b)(1) (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/248/s289/a/2"},"text":"Pub. L. 97–248, § 289(a)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/571"},"text":"96 Stat. 571","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1b70f0-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd1b70f1-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452"},"text":"Pub. L. 97–452","children":[],"tail":" struck out provisions that the issue price of retirement and savings bonds and the conditions under which they could be redeemed could give an investment yield of not more than 5 percent a year compounded semiannually."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
