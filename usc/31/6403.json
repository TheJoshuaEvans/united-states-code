{"tag":"section","attrib":{"id":"idbd7fb06c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6403"},"text":null,"children":[{"tag":"num","attrib":{"value":"6403"},"text":"§ 6403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance applying data standards for grant reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7fb06d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after the date of enactment of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7fb06e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary and the Director shall jointly issue guidance to all agencies directing the agencies to apply the data standards established under section 6402(a) to all applicable reporting by recipients of Federal awards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb06f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director shall prescribe guidance applying the data standards established under section 6402(a) to audit-related information reported under chapter 75 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7fb070-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidance issued under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7fb071-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the extent reasonable and practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7fb072-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6403/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the disruption of existing reporting practices of, and not increase the reporting burden on, agencies or recipients of Federal awards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fb073-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6403/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explore opportunities to implement modern technologies in reporting relating to Federal awards;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb074-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the Director to permit exceptions for classes of Federal awards, including exceptions for Federal awards granted to Indian Tribes and Tribal organizations consistent with the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"25 U.S.C. 5301","children":[],"tail":" et seq.), if the Director publishes a list of those exceptions and submits the list to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Oversight and Reform of the House of Representatives; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb075-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6403/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration the consultation required under section 6402(d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7fb076-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updating Guidance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7fb077-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6403/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than once every 10 years, the Director shall update the guidance issued under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb078-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6403/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In updating guidance under paragraph (1), the Director shall, to the maximum extent practicable, follow the procedures for the development of the data standards and guidance prescribed under this section and section 6402.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7fb079-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/103/s4/a"},"text":"Pub. L. 116–103, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3269"},"text":"133 Stat. 3269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7fb07a-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd7fb07b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd7fb07c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/103"},"text":"Pub. L. 116–103","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Self-Determination and Education Assistance Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2203"},"text":"88 Stat. 2203","children":[],"tail":", which is classified principally to chapter 46 (§ 5301 et seq.) of Title 25, Indians. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/93/638/s1"},"text":"section 1 of Pub. L. 93–638","children":[],"tail":", set out as a Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5301"},"text":"section 5301 of Title 25","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd7fb07d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbd7fb07e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
