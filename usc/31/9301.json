{"tag":"section","attrib":{"id":"idbd905270-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9301"},"text":null,"children":[{"tag":"num","attrib":{"value":"9301"},"text":"§ 9301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd905271-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person” means an individual, a trust, an estate, a partnership, and a corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd905272-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “eligible obligation” means any security designated as acceptable in lieu of a surety bond by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd905273-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1046"},"text":"96 Stat. 1046","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tIX/s901/a"},"text":"Pub. L. 109–351, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2007"},"text":"120 Stat. 2007","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd905274-47c4-11f1-bea6-82cea744851c"},"text":"