en":[{"tag":"html:p","attrib":{},"text":"6:15(10th, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words after the semicolon are omitted as unnecessary because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (2) is substituted for 6:15(last sentence) for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd905277-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd905278-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351"},"text":"Pub. L. 109–351","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “ ‘Government obligation’ means a public debt obligation of the United States Government and an obligation whose principal and interest is unconditionally guaranteed by the Government.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
