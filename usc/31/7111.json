{"tag":"section","attrib":{"id":"idbd8b96b7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7111"},"text":null,"children":[{"tag":"num","attrib":{"value":"7111"},"text":"§ 7111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"By ","children":[{"tag":"date","attrib":{"date":"1984-02-03"},"text":"February 3, 1984","children":[],"tail":", the President shall submit to Congress a report on actions taken under this chapter and make recommendations for its continuation, amendment, or termination. The report shall include a detailed evaluation of the operation of the chapter, including information on the benefits and costs of jointly financed projects that accrue to participating States, local governments, private nonprofit organizations, and the United States Government."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd8b96b8-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1039"},"text":"96 Stat. 1039","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd8b96b9-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd8b96ba-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd8b96bb-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7111","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"42:4260.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Dec. 5, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/510/s11"},"text":"Pub. L. 93–510, § 11","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1608"},"text":"88 Stat. 1608","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “By ","children":[{"tag":"date","attrib":{"date":"1984-02-03"},"text":"February 3, 1984","children":[],"tail":"” are substituted for “at least one year prior to the expiration of this chapter” for clarity and to reflect the 5-year extension granted the joint funding simplification program by the Act of "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"December 16, 1980","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/96/534"},"text":"Pub. L. 96–534","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3164"},"text":"94 Stat. 3164","children":[],"tail":"). The word “comprehensive” is omitted as unnecessary. The word “amendment” is substituted for “modification” for clarity. The word “include” is substituted for “provide”, and the word “operation” is substituted for “functioning”, for consistency in the chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
