{"tag":"section","attrib":{"id":"idbd86b551-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6714"},"text":null,"children":[{"tag":"num","attrib":{"value":"6714"},"text":"§ 6714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd86b552-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6714/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Types of Compliance Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A compliance agreement is an agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd86b553-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6714/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approved by the Secretary, between the governmental authority responsible for prosecuting a claim or complaint that is the basis of a holding of discrimination and the chief executive officer of the unit of general local government that has not complied with section 6711(a) or (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b554-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6714/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between the Secretary and the chief executive officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd86b555-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6714/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A compliance agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd86b556-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6714/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall state the conditions the unit of general local government has agreed to comply with that would satisfy the obligations of the government under sections ","children":[{"tag":"ref","attrib":{"idref":"fn002117"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002117"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 6711(a) and (b);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b557-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6714/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall cover each matter that has been found not to comply, or would not comply, with section 6711(a) or (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b558-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6714/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be a series of agreements that dispose of those matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd86b559-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6714/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Agreements to Parties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall submit a copy of a compliance agreement to each person who filed a complaint referred to in section 6716(b), or, if an agreement under subsection (a)(1), each person who filed a complaint with a governmental authority, about a failure to comply with section 6711(a) or (b). The Secretary shall submit the copy by the 15th day after an agreement is made. However, if the Secretary approves an agreement under subsection (a)(1) after the agreement is made, the Secretary may submit the copy by the 15th day after approval of the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd86b55a-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31001/a"},"text":"Pub. L. 103–322, title III, § 31001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1877"},"text":"108 Stat. 1877","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd86b55b-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd86b55c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd86b55d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6714, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1023"},"text":"96 Stat. 1023","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/185/s6"},"text":"Pub. L. 98–185, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1310"},"text":"97 Stat. 1310","children":[],"tail":", related to public hearings, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIV/s14001/a/1"},"text":"Pub. L. 99–272, title XIV, § 14001(a)(1)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/327"},"text":"100 Stat. 327","children":[],"tail":", 329, eff. "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
