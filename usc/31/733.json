{"tag":"section","attrib":{"id":"idbcf30097-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733"},"text":null,"children":[{"tag":"num","attrib":{"value":"733"},"text":"§ 733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior Executive Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf30098-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Comptroller General may establish a General Accounting Office Senior Executive Service ","children":[{"tag":"ref","attrib":{"idref":"fn002014"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002014"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" —"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf30099-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3131"},"text":"section 3131 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf3009a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing requirements for positions consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a/2"},"text":"section 3132(a)(2) of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf3009b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing rates of basic pay—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf3009c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than the maximum rate or less than the minimum rate for the Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf3009d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjusted annually by the Comptroller General after taking into consideration the factors listed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s732/c/3"},"text":"section 732(c)(3) of this title","children":[],"tail":", except that an adjustment under this subparagraph shall not be applied in the case of any officer or employee whose performance is not at a satisfactory level, as determined by the Comptroller General for purposes of such adjustment;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf3009e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing a performance appraisal system consistent with subchapter II of chapter 43 of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf3009f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing the Comptroller General to award ranks to officers and employees in the Office Senior Executive Service consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4507"},"text":"section 4507 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf300a0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for removal consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3592"},"text":"section 3592 of title 5","children":[],"tail":", and for removal or suspension consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7543"},"text":"section 7543 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf300a1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing the Comptroller General to reassign an officer or employee in the Office Senior Executive Service to any senior-level position established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s732a"},"text":"section 732a of this title","children":[],"tail":", as the Comptroller General determines necessary and appropriate; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf300a2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allowing the Comptroller General to pay performance awards to officers and employees of the Office Senior Executive Service consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5384"},"text":"section 5384 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf300a3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (a), the Comptroller General may apply any part of title 5 that applies to an applicant for or officer or employee in the Senior Executive Service under title 5 to the Office Senior Executive Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf300a4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office Senior Executive Service may include positions referred to in section 731(c), (e)(1), or (e)(2) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf300a5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s733/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 732(b)(6), (c), (d)(1)–(4), and (e) of this title does not apply to the Office Senior Executive Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf300a6-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/899"},"text":"96 Stat. 899","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/326/s1/c"},"text":"Pub. L. 98–326, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-