r entitlement for any person who is not an officer or employee of the United States acting in such capacity, and no person not an officer or employee of the United States acting in such capacity to have standing to file any civil action in any court of the United States to enforce any provision or amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/103/62"},"text":"Pub. L. 103–62","children":[],"tail":", or to be construed as superseding any statutory requirement, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/62/s10"},"text":"section 10 of Pub. L. 103–62","children":[],"tail":", set out as a Construction of 1993 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
