{"tag":"section","attrib":{"id":"idbcd8c1a9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s314"},"text":null,"children":[{"tag":"num","attrib":{"value":"314"},"text":"§ 314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcd8c1aa-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary and the United States Trade Representative are authorized, jointly, to negotiate and enter into covered agreements on behalf of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd8c1ab-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Consultation With Congress.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd8c1ac-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before initiating negotiations to enter into a covered agreement under subsection (a), during such negotiations, and before entering into any such agreement, the Secretary and the United States Trade Representative shall jointly consult with the Committee on Financial Services and the Committee on Ways and Means of the House of Representatives and the Committee on Banking, Housing, and Urban Affairs and the Committee on Finance of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1ad-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The consultation described in paragraph (1) shall include consultation with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd8c1ae-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s314/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd8c1af-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s314/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how and to what extent the agreement will achieve the applicable purposes, policies, priorities, and objectives of section 313 and this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd8c1b0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s314/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of the agreement, including the general effect of the agreement on existing State laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd8c1b1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission and Layover Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered agreement under subsection (a) may enter into force with respect to the United States only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd8c1b2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s314/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary and the United States Trade Representative jointly submit to the congressional committees specified in subsection (b)(1), on a day on which both Houses of Congress are in session, a copy of the final legal text of the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd8c1b3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s314/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a period of 90 calendar days beginning on the date on which the copy of the final legal text of the agreement is submitted to the congressional committees under paragraph (1) has expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcd8c1b4-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/tV/s502/a/3"},"text":"Pub. L. 111–203, title V, § 502(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1588"},"text":"124 Stat. 1588","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcd8c1b5-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcd8c1b6-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbcd8c1b7-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 1 day after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
