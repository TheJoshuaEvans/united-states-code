Pub. L. 95–351, § 301(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/514"},"text":"92 Stat. 514","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/35/s396/h/2"},"text":"Pub. L. 97–35, § 396(h)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/440"},"text":"95 Stat. 440","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9107(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:867(1st sentence last proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9107(c)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:868(d)(1st sentence related to 31:867).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-12-06/ch577/s303/d"},"text":"Dec. 6, 1945, ch. 577, § 303(d)","children":[],"tail":"(1st sentence related to § 302), "},{"tag":"html:a","attrib":{"href":"/us/stat/59/602"},"text":"59 Stat. 602","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9107(c)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:867(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “After ","children":[{"tag":"date","attrib":{"date":"1949-06-30"},"text":"June 30, 1949","children":[],"tail":"” are omitted as executed. The words “Government corporation” are substituted for “corporations or agencies subject to this chapter” because of section 9101(1) of the revised title. The words “notwithstanding the provisions of any other law”, “or more . . . for banking and checking purposes”, and “including amounts appropriated, from whatever source derived” are omitted as surplus. The words “if the cash will be expended as provided by law” are substituted for 31:870(proviso) to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the words “banking or checking” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Secretary of the Treasury” are substituted for “Treasurer of the United States” because of the source provisions restated in section 321(c) of the revised title. The words “wholly owned and mixed-ownership” and “under such conditions as he may determine” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “establishment and” and “in any one bank” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “head of each” are added for consistency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd90523a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1983 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 31:9107(c)(3) and 9108(d)(2) because the National Consumer Cooperative Bank is no longer a mixed-ownership Government corporation. Section 396(h)(2) and (3) and (i) of the Omnibus Budget Reconciliation Act of 1981 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/440"},"text":"95 Stat. 440","children":[],"tail":") provided that references to the Bank in sections 302 and 303(d)(2d sentence) of the Government Corporation Control Act would be deleted on the day after the Final Government Equity Redemption Date. "},{"tag":"ref","attrib":{"href":"/us/act/1981-12-23/s501/36"},"text":"Section 501(36) of the Act of December 23, 1981","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/97/101"},"text":"Pub. L. 97–101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1440"},"text":"95 Stat. 1440","children":[],"tail":"), provided that the Redemption Date was "},{"tag":"date","attrib":{"date":"1981-12-31"},"text":"December 31, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd90523b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd90523c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452"},"text":"Pub. L. 97–452","children":[],"tail":" struck out “the National Consumer Cooperative Bank,” after “Regional Banks for Cooperatives,” which had already been struck out by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":". See 1982 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s2"},"text":"Pub. L. 97–258, § 2","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), struck out “the National Consumer Cooperative Bank,” after “Regional Banks for Cooperatives,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd90523d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd90523e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment effective ","children":[{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/452/s2/i"},"text":"section 2(i) of Pub. L. 97–452","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3331"},"text":"section 3331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd90523f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258/s2"},"text":"Pub. L. 97–258, § 2","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1062"},"text":"96 Stat. 1062","children":[],"tail":", provided that the amendment made by such section is effective "},{"tag":"date","attrib":{"date":"1982-01-01"},"text":"Jan. 1, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
