{"tag":"section","attrib":{"id":"idbd90522f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9107"},"text":null,"children":[{"tag":"num","attrib":{"value":"9107"},"text":"§ 9107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd905230-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With the approval of the Comptroller General, a Government corporation may consolidate its cash into an account if the cash will be expended as provided by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd905231-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall keep the accounts of a Government corporation. If the Secretary approves, a Federal reserve bank or a bank designated as a depositary or fiscal agent of the United States Government may keep the accounts. The Secretary may waive the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd905232-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd905233-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9107/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (b) of this section does not apply to maintaining a temporary account of not more than $50,000 in one bank.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd905234-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9107/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (b) of this section does not apply to a mixed-ownership Government corporation when the corporation has no capital of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd905235-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9107/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (b) of this section does not apply to the Federal Intermediate Credit Banks, the Central Bank for Cooperatives, the Regional Banks for Cooperatives, or the Federal Land Banks. However, the head of each of those banks shall report each year to the Secretary the names of depositaries where accounts are kept. If the Secretary considers it advisable when an annual report is received, the Secretary may make a written report to the corporation, the President, and Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd905236-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", §§ 1, 2("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1044"},"text":"96 Stat. 1044","children":[],"tail":", 1062; "},{"tag":"ref","attrib":{"href":"/us/pl/97/452/s1/27"},"text":"Pub. L. 97–452, § 1(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2478"},"text":"96 Stat. 2478","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes",