{"tag":"section","attrib":{"id":"idbd2c39f9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358"},"text":null,"children":[{"tag":"num","attrib":{"value":"3358"},"text":"§ 3358.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency working group for Governmentwide payment integrity improvement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd2c39fa-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Working Group.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c39fb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of enactment of this section, there is established an interagency working group on payment integrity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c39fc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to improve—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd2c39fd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State-administered Federal programs to determine eligibility processes and data sharing practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd2c39fe-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the guidelines described in section 3357(b) and other best practices and techniques for detecting, preventing, and responding to improper payments, including improper payments that are the result of fraud; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd2c39ff-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sharing and development of data analytics techniques to help prevent and identify potential improper payments, including those that are the result of fraud; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c3a00-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify any additional activities that will improve payment integrity of Federal programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c3a01-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The interagency working group established under paragraph (1) shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c3a02-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c3a03-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from each of the agencies described in paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s901/b"},"text":"section 901(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c3a04-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other representatives of other executive agencies determined appropriate by the Director of the Office of Management and Budget, which may include the Chief Information Officer, the Chief Procurement Officer, the Chief Risk Officer, or the Chief Operating Officer of an executive agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c3a05-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The working group established under subsection (a)(1) may consult with Offices of Inspectors General and Federal and non-Federal experts on fraud risk assessments, administrative controls over payment integrity, financial controls, and other relevant matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c3a06-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The working group established under subsection (a)(1) shall hold not fewer than 4 meetings per year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c3a07-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 240 days after the date of enactment of this section, the working group established under subsection (a)(1) shall submit to Congress a report that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c3a08-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan containing tangible solutions to prevent and reduce improper payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c3a09-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3358/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for State agencies to work with Federal agencies to regularly review lists of beneficiaries of State-managed Federal programs for duplicate enrollment between States, including how the Do Not Pay Business Center and the data analytics initiative of the Department of the Treasury could aid in the detection of duplicate enrollment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd2c3a0a-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117/s2/a"},"text":"Pub. L. 116–117, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/132"},"text":"134 Stat. 132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd2c3a0b-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd2c3a0c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd2c3a0d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (a)(1) and (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117"},"text":"Pub. L. 116–117","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
