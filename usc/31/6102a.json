{"tag":"section","attrib":{"id":"idbd7d3f48-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6102a"},"text":"§ 6102a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance awards information system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7d3f49-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d3f4a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the United States Government assistance awards information system established as a result of the study conducted under section 9 of the Federal Program Information Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f4b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the system on a quarterly basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7d3f4c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To carry out subsection (a) of this section, the Director—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d3f4d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may delegate the responsibility for carrying out subsection (a) of this section to the head of another executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f4e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall review a report the head of an agency submits to the Director on the method of carrying out subsection (a) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d3f4f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may validate, by appropriate means, the method by which an agency prepares the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7d3f50-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6102a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall transmit promptly after the end of each calendar quarter, free of charge, the data in the system required by subsection (a) to the Committee on Rules and Administration of the Senate and to the Committee on House Oversight of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7d3f51-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452/s1/23/A"},"text":"Pub. L. 97–452, § 1(23)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2477"},"text":"96 Stat. 2477","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/169/s1/2"},"text":"Pub. L. 98–169, § 1(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-29"},"text":"Nov. 29, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1113"},"text":"97 Stat. 1113","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/547/s2/b/1"},"text":"Pub. L. 99–547, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3060"},"text":"100 Stat. 3060","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s219/b/2"},"text":"Pub. L. 104–186, title II, § 219(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1748"},"text":"110 Stat. 1748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7d3f52-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd7d3f53-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd7d3f54-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr",