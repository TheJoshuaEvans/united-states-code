{"tag":"section","attrib":{"id":"idbd86b53c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713"},"text":null,"children":[{"tag":"num","attrib":{"value":"6713"},"text":"§ 6713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension and termination of payments in discrimination proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd86b53d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Imposition and Continuation of Suspensions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd86b53e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall suspend payment under this chapter to a unit of general local government—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd86b53f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if an administrative law judge appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3105"},"text":"section 3105 of title 5","children":[],"tail":", United States Code, issues a preliminary decision in a proceeding under section 6712(d)(1) that the government is not likely to prevail in showing compliance with section 6711(a) and (b);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b540-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the administrative law judge decides at the end of the proceeding that the government has not complied with section 6711(a) or (b), unless the government makes a compliance agreement under section 6714 by the 30th day after the decision; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b541-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if required under section 6712(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b542-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effectiveness","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A suspension already ordered under paragraph (1)(A) continues in effect if the administrative law judge makes a decision under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd86b543-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lifting of Suspensions and Terminations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a holding of discrimination is reversed by an appellate court, a suspension or termination of payments in a proceeding based on the holding shall be discontinued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd86b544-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resumption of Payments Upon Attaining Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may resume payment to a unit of general local government of payments suspended by the Secretary only—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd86b545-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as of the time of, and under the conditions stated in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd86b546-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approval by the Secretary of a compliance agreement under section 6714(a)(1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b547-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a compliance agreement entered into by the Secretary under section 6714(a)(2);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b548-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the government complies completely with an order of a United States court, a State court, or administrative law judge that covers all matters raised in a notice of noncompliance submitted by the Secretary under section 6712(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b549-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a United States court, a State court, or an administrative law judge decides (including a judge in a proceeding under section 6712(d)(1)), that the government has complied with sections ","children":[{"tag":"ref","attrib":{"idref":"fn002116"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002116"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 6711(a) and (b); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b54a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a suspension is discontinued under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd86b54b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Damages as Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subsection (c)(2), compliance by a government may consist of the payment of restitution to a person injured because the government did not comply with section 6711(a) or (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd86b54c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6713/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resumption of Payments Upon Reversal by Court","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may resume payment to a unit of general local government of payments terminated under section 6712(d)(2)(A) only if the decision resulting in the termination is reversed by an appellate court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd86b54d-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31001/a"},"text":"Pub. L. 103–322, title III, § 31001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1876"},"text":"108 Stat. 1876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd86b54e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd86b54f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd86b550-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6713, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1022"},"text":"96 Stat. 1022","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/185"},"text":"Pub. L. 98–185","children":[],"tail":", §§ 5, 9(e), "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1309"},"text":"97 Stat. 1309","children":[],"tail":", 1312, related to information used in allocation formulas, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIV/s14001/a/1"},"text":"Pub. L. 99–272, title XIV, § 14001(a)(1)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/327"},"text":"100 Stat. 327","children":[],"tail":", 329, eff. "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
