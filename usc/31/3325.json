{"tag":"section","attrib":{"id":"idbd229c65-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3325"},"text":null,"children":[{"tag":"num","attrib":{"value":"3325"},"text":"§ 3325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vouchers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd229c66-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3325/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A disbursing official in the executive branch of the United States Government shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd229c67-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3325/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" disburse money only as provided by a voucher certified by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd229c68-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3325/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the executive agency concerned; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd229c69-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3325/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of the executive agency having written authorization from the head of the agency to certify vouchers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd229c6a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3325/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" examine a voucher if necessary to decide if it is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd229c6b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3325/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in proper form;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd229c6c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3325/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified and approved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd229c6d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3325/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" computed correctly on the facts certified; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd229c6e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3325/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except for the correctness of computations on a voucher or pursuant to payment intercepts or offsets pursuant to section 3716 or 3720A of this title,,","children":[{"tag":"ref","attrib":{"idref":"fn002044"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002044"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" be held accountable for carrying out clauses (1) and (2) of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd229c6f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3325/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to officers and employees referred to in subsection (a)(1)(B) of this section as having authorization to certify vouchers, members of the armed forces may certify vouchers when authorized, in writing, by the Secretary of Defense or, in the case of the Coast Guard when it is not operating as a service in the Navy, by the Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd229c70-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3325/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On request, the Secretary of the Treasury may provide to the appropriate officer or employee of the United States Government a list of persons receiving periodic payments from the Government. When certified and in proper form, the list may be used as a voucher on which the Secretary may disburse money.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd229c71-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3325/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of an executive agency or an officer or employee of an executive agency referred to in subsection (a)(1)(B), as applicable, shall include with each certified voucher submitted to a disbursing official pursuant to this section the taxpayer identifying number of each person to whom payment may be made under the voucher.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd229c72-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/951"},"text":"96 Stat. 951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tIX/s913/b"},"text":"Pub. L. 104–106, div. A, title IX, § 913(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/411"},"text":"110 Stat. 411","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tIII/s31001/g/1/B"},"text":"Pub. L. 104–134, title III, § 31001(g)(1)(B)","children":[],"tail":", (y), "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-363"},"text":"110 Stat. 1321–363","children":[],"tail":", 1321–378; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1009/b"},"text":"Pub. L. 104–201, div. A, title X, § 1009(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2634"},"text":"110 Stat. 2634","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIX/s902/b/2"},"text":"Pub. L. 109–241, title IX, § 902(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/566"},"text":"120 Stat. 566","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd229c73-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd229c74-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd229c75-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3325(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:82b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1941-12-29/ch641"},"text":"Dec. 29, 1941, ch. 641","children":[],"tail":", §§ 1, 4(related to § 1), "},{"tag":"html:a","attrib":{"href":"/us/stat/55/875"},"text":"55 Stat. 875","children":[],"tail":", 876."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:82f(related to disbursing officers).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-04-28/ch247/s301"},"text":"Apr. 28, 1942, ch. 247, § 301","children":[],"tail":"(1st par. proviso under heading “Bureau of Accounts” related to disbursing officers), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/244"},"text":"56 Stat. 244","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3325(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:82e(related to 31:82b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3325(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:82a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1937-05-14/ch180/s1"},"text":"May 14, 1937, ch. 180, § 1","children":[],"tail":"(2d par. last proviso on p. 140), "},{"tag":"html:a","attrib":{"href":"/us/stat/50/140"},"text":"50 Stat. 140","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s82"},"text":"section 82 of this title","children":[],"tail":", and section 4 of Executive Order Numbered 6166, dated "},{"tag":"date","attrib":{"date":"1933-06-10"},"text":"June 10, 1933","children":[],"tail":"” in 31:82b are omitted as unnecessary. In clause (1), the word “duly” is omitted as surplus. In clause (1)(A) and (B), the words “executive agency” are substituted for “department, establishment or agency concerned” because of section 102 of the revised title and for consistency. In clause (2)(C), the words “basis of the” are omitted as surplus. In clause (3), the words “for carrying out clauses (1) and (2) of this subsection” are substituted for “accordingly” for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “under the jurisdiction” are omitted as surplus. The words “a military department of the Department of Defense” are substituted for “the Department of the Army, the Navy Department (including the Marine Corps)” for consistency with title 10. The words “and the Panama Canal” (subsequently changed to “the Canal Zone Government” by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-26/s2/a/1"},"text":"section 2(a)(1) of the Act of September 26, 1950","children":[],"tail":" (ch. 1049, "},{"tag":"ref","attrib":{"href":"/us/stat/64/1038"},"text":"64 Stat. 1038","children":[],"tail":")) are omitted because of 22:ch. 51. The word “pay” is substituted for “salaries” for consistency in the revised title and with other titles of the United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “On and after ","children":[{"tag":"date","attrib":{"date":"1937-05-14"},"text":"May 14, 1937","children":[],"tail":"” are omitted as executed. The words “Secretary of the Treasury” are substituted for “Division of Disbursement, Treasury Department” in section 1(last proviso of 2d par. on p. 140) of the Act of "},{"tag":"date","attrib":{"date":"1937-05-14"},"text":"May 14, 1937","children":[],"tail":", because of section 1(a) of Reorganization Plan No. III of 1940 (eff. "},{"tag":"date","attrib":{"date":"1940-06-30"},"text":"June 30, 1940","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/1231"},"text":"54 Stat. 1231","children":[],"tail":") and section 321(c) of the revised title. The word “appropriate” is added for clarity. The words “officer or employee of the United States Government” are substituted for “administrative officers” for consistency in the revised title and with other titles of the United States Code. The words “addressographed or stenciled” and “administratively revised and” are omitted as surplus. The words “disburse public money” are substituted for “make payment” for consistency."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd250d76-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd250d77-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" substituted “Secretary of Homeland Security” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s31001/g/1/B"},"text":"Pub. L. 104–134, § 31001(g)(1)(B)","children":[],"tail":", inserted “or pursuant to payment intercepts or offsets pursuant to section 3716 or 3720A of this title,” after “voucher”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “members of the armed forces may certify vouchers when authorized, in writing, by the Secretary of Defense or, in the case of the Coast Guard when it is not operating as a service in the Navy, by the Secretary of Transportation” for “members of the armed forces under the jurisdiction of the Secretary of Defense may certify vouchers when authorized, in writing, by the Secretary to do so”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows: “Subsection (a) of this section does not apply to disbursements of a military department of the Department of Defense, except for disbursements for departmental pay and expenses in the District of Columbia.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s31001/y"},"text":"Pub. L. 104–134, § 31001(y)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
