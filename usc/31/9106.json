{"tag":"section","attrib":{"id":"idbd90521c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9106"},"text":null,"children":[{"tag":"num","attrib":{"value":"9106"},"text":"§ 9106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd90521d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd90521e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Government corporation shall submit an annual management report to the Congress not later than 180 days after the end of the Government corporation’s fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd90521f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A management report under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd905220-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9106/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of financial position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd905221-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9106/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd905222-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9106/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of cash flows;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd905223-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9106/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reconciliation to the budget report of the Government corporation, if applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd905224-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9106/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement on internal accounting and administrative control systems by the head of the management of the corporation, consistent with the requirements for agency statements on internal accounting and administrative control systems under the amendments made by the Federal Managers’ Financial Integrity Act of 1982 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/255"},"text":"Public Law 97–255","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd905225-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9106/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report resulting from an audit of the financial statements of the corporation conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9105"},"text":"section 9105 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd905226-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9106/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other comments and information necessary to inform the Congress about the operations and financial condition of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd905227-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Government corporation shall provide the President, the Director of the Office of Management and Budget, and the Comptroller General of the United States a copy of the management report when it is submitted to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd905228-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1044"},"text":"96 Stat. 1044","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/576/tIII/s306/a"},"text":"Pub. L. 101–576, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2854"},"text":"104 Stat. 2854","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd905229-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd90522a-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd90522b-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9106(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:851(1st–3d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-12-06/ch557/s106"},"text":"Dec. 6, 1945, ch. 557, § 106","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/599"},"text":"59 Stat. 599","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 30, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/518/s2/b"},"text":"Pub. L. 88–518, § 2(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/698"},"text":"78 Stat. 698","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/604/s601/b"},"text":"Pub. L. 93–604, § 601(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1962"},"text":"88 Stat. 1962","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:858(1st–3d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-12-06/ch557/s203"},"text":"Dec. 6, 1945, ch. 557, § 203","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/600"},"text":"59 Stat. 600","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 30, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/518/s1/b"},"text":"Pub. L. 88–518, § 1(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/698"},"text":"78 Stat. 698","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/604/s601/d"},"text":"Pub. L. 93–604, § 601(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1963"},"text":"88 Stat. 1963","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9106(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:851(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:858(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “of a Government corporation” are added for clarity. In clause (5), the words “program, expenditure, or other”, “observed in the course of the audit”, and “of law” are omitted as surplus. In clause (6), the word “statement” is substituted for “report” for consistency. The words “noted in the audit” are omitted as surplus. The word “made” is substituted for “accomplished” for consistency. In clause (7), the word “other” is added for clarity because of the restatement. The words “with respect thereto” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “The Comptroller General” are added for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd90522c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd90522d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Managers’ Financial Integrity Act of 1982, referred to in subsec. (a)(2)(E), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/255"},"text":"Pub. L. 97–255","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/814"},"text":"96 Stat. 814","children":[],"tail":", which added subsec. (d) to section 66a of former Title 31, Money and Finance. Section 66a of former Title 31 was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s5/b"},"text":"Pub. L. 97–258, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1068"},"text":"96 Stat. 1068","children":[],"tail":", and reenacted by the first section thereof as "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3512"},"text":"section 3512 of this title","children":[],"tail":". Provisions relating to statements on internal accounting and administrative control systems are restated in section 3512(d)(2) and (3) of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd90522e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/576"},"text":"Pub. L. 101–576","children":[],"tail":" substituted “Management” for “Audit” in section catchline and amended text of section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Comptroller General shall submit to Congress a report on each audit of a Government corporation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9105"},"text":"section 9105 of this title","children":[],"tail":" not later than 6.5 months after the end of the last year covered by the audit. The report shall state the scope of the audit and include—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) a statement (showing intercorporate relations) of assets, liabilities, capital, and surplus or deficit;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) a statement of surplus or deficit analysis;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) a statement of income and expenditures;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) a statement of sources and the use of money;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) specifically each financial transaction or undertaking the Comptroller General believes was carried out or made without authority of law;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) comments and information the Comptroller General considers necessary to keep Congress informed about the operations and financial condition of the Government corporation, including a statement of impaired capital noticed and recommendations for the return of capital of the United States Government or the payment of dividends the Comptroller General believes should be made; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) other recommendations the Comptroller General considers advisable.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) The Comptroller General shall give the President, the Secretary of the Treasury, and the Government corporation a copy of the report when it is submitted to Congress.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
