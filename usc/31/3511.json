{"tag":"section","attrib":{"id":"idbd2c3a1f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3511"},"text":null,"children":[{"tag":"num","attrib":{"value":"3511"},"text":"§ 3511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prescribing accounting requirements and developing accounting systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd2c3a20-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General shall prescribe the accounting principles, standards, and requirements that the head of each executive agency shall observe. Before prescribing the principles, standards, and requirements, the Comptroller General shall consult with the Secretary of the Treasury and the President on their accounting, financial reporting, and budgetary needs, and shall consider the needs of the heads of the other executive agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c3a21-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Requirements prescribed under subsection (a) of this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c3a22-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for suitable integration between the accounting process of each executive agency and the accounting of the Department of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c3a23-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the head of each agency to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3512"},"text":"section 3512 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c3a24-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3511/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide a method of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c3a25-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3511/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated accounting for the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c3a26-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3511/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete disclosure of the results of the financial operations of each agency and the Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c3a27-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3511/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial information and control the President and Congress require to carry out their responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c3a28-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Consistent with subsections (a) and (b) of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c3a29-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3511/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authority of the Comptroller General continues under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s121/b"},"text":"section 121(b) of title 40","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c3a2a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3511/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller General may prescribe the forms, systems, and procedures that the judicial branch of the Government (except the Supreme Court) shall observe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c3a2b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3511/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General, the Secretary, and the President shall conduct a continuous program for improving accounting and financial reporting in the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd2c3a2c-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/959"},"text":"96 Stat. 959","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/h/5"},"text":"Pub. L. 107–217, § 3(h)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1299"},"text":"116 Stat. 1299","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd2c3a2d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd2c3a2e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd2c3a2f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3511(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:66(a)(1st sentence words before last comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-12/ch946"},"text":"Sept. 12, 1950, ch. 946","children":[],"tail":", §§ 111(f), 112(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/835"},"text":"64 Stat. 835","children":[],"tail":"; Reorg. Plan No. 2 of 1970, eff. "},{"tag":"html:span","attrib":{},"text":"July 1, 1970","children":[],"tail":", § 102(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/84/2085"},"text":"84 Stat. 2085","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3511(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:66(a)(1st sentence words after last comma, 2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3511(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:49","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18/s309"},"text":"June 10, 1921, ch. 18, § 309","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/42/25"},"text":"42 Stat. 25","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:66(a)(3d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3511(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:65(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “the head of” are added for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “of the United States” are omitted as surplus. The word “President” is substituted for “Director of the Office of Management and Budget” because sections 101 and 102(a) of Reorganization Plan No. 2 of 1970 (eff. ","children":[{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2085"},"text":"84 Stat. 2085","children":[],"tail":") redesignated the Bureau of the Budget as the Office of Management and Budget and transferred all functions of the Bureau to the President."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the words “as a whole” and “respective” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c)(2) is substituted for 31:49 and the words “and, to the extent he deems necessary, the authority vested in him by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s49"},"text":"section 49 of this title","children":[],"tail":"” in 31:66(a) for clarity and consistency. H. Rept. 2556, 81st Cong. (1950), states that the Comptroller General will be able to prescribe appropriation and fund accounting systems under 31:49 “in terms of principles, standards and related requirements rather than in terms of detailed forms and procedures”. The reference to the judicial branch covers authority that the Comptroller General was given under 31:49 that applies to departments and establishments except the Supreme Court that was not superseded by the source provisions restated in subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd2c3a30-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd2c3a31-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s121/b"},"text":"section 121(b) of title 40","children":[],"tail":"” for “section 205(b) of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s486/b"},"text":"40 U.S.C. 486(b)","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd2c3a32-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd2c3a33-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Adoption of Capital Accounting Standards","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/576/tIII/s307"},"text":"Pub. L. 101–576, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2855"},"text":"104 Stat. 2855","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/576/tIII/s307"},"text":"“No capital accounting standard or principle, including any human capital standard or principle, shall be adopted for use in an executive department or agency until such standard has been reported to the Congress and a period of 45 days of continuous session of the Congress has expired.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
