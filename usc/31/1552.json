","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-07-25/ch727"},"text":"July 25, 1956, ch. 727","children":[],"tail":", §§ 1(c)(last sentence), (d), 5, "},{"tag":"html:a","attrib":{"href":"/us/stat/70/648"},"text":"70 Stat. 648","children":[],"tail":", 649."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1552(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:701(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1552(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:705.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the text of 31:701(b)(1)(A) and (2)(A) and the words “for the period commencing on ","children":[{"tag":"date","attrib":{"date":"1976-07-01"},"text":"July 1, 1976","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1976-09-30"},"text":"September 30, 1976","children":[],"tail":", and for any fiscal year commencing on or after "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"October 1, 1976","children":[],"tail":"” are omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “period of availability ends” are substituted for “that period or the fiscal year or years, as the case may be, for which the appropriation is available for obligation” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “reverts to the Treasury” are substituted for “if the appropriation was derived in whole or in part from the general fund, shall revert to such fund” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “not received before” are substituted for “not received until after” for clarity. The words “unless otherwise authorized by law” are omitted as surplus. The words “Comptroller General” are substituted for “General Accounting Office” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the text of 31:701(d)(last sentence) is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), before clause (1), the word “heading” is substituted for “heads” for clarity and consistency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1444c9-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd1444ca-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" amended text generally, revising and restating former subsecs. (a) to (d) as subsecs. (a) and (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd1444cb-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd1444cc-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" applicable to any appropriation account the obligated balance of which, on "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", has not been transferred under subsec. (a)(1) of this section, as in effect "},{"tag":"date","attrib":{"date":"1990-11-04"},"text":"Nov. 4, 1990","children":[],"tail":", with transitional provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1405/b"},"text":"section 1405(b) of Pub. L. 101–510","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd1444cd-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Audit of Obligated Balances of Department of Defense","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1406"},"text":"Pub. L. 101–510, div. A, title XIV, § 1406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1680"},"text":"104 Stat. 1680","children":[],"tail":", required the Secretary of Defense to provide for an audit of each account of the Department of Defense established under subsec. (a)(1) of this section, as in effect on the day before "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", and to provide Congress with a final report on the audit by "},{"tag":"date","attrib":{"date":"1991-12-31"},"text":"Dec. 31, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
