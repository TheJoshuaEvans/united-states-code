{"tag":"section","attrib":{"id":"idbd1444c2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1552"},"text":null,"children":[{"tag":"num","attrib":{"value":"1552"},"text":"§ 1552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure for appropriation accounts available for definite periods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1444c3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1552/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On September 30th of the 5th fiscal year after the period of availability for obligation of a fixed appropriation account ends, the account shall be closed and any remaining balance (whether obligated or unobligated) in the account shall be canceled and thereafter shall not be available for obligation or expenditure for any purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1444c4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1552/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collections authorized or required to be credited to an appropriation account, but not received before closing of the account under subsection (a) or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1555"},"text":"section 1555 of this title","children":[],"tail":" shall be deposited in the Treasury as miscellaneous receipts."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1444c5-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/935"},"text":"96 Stat. 935","children":[],"tail":"; "},{"tag":"r