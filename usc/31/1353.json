{"tag":"section","attrib":{"id":"idbd0f8990-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353"},"text":null,"children":[{"tag":"num","attrib":{"value":"1353"},"text":"§ 1353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of travel and related expenses from non-Federal sources","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0f8991-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the Administrator of General Services, in consultation with the Director of the Office of Government Ethics, shall prescribe by regulation the conditions under which an agency in the executive branch (including an independent agency) may accept payment, or authorize an employee of such agency to accept payment on the agency’s behalf, from non-Federal sources for travel, subsistence, and related expenses with respect to attendance of the employee (or the spouse of such employee) at any meeting or similar function relating to the official duties of the employee. Any cash payment so accepted shall be credited to the appropriation applicable to such expenses. In the case of a payment in kind so accepted, a pro rata reduction shall be made in any entitlement of the employee to payment from the Government for such expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f8992-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in this section or section 4111 or 7342 of title 5, an agency or employee may not accept payment for expenses referred to in subsection (a). An employee who accepts any payment in violation of the preceding sentence—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f8993-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be required, in addition to any penalty provided by law, to repay, for deposit in the general fund of the Treasury, an amount equal to the amount of the payment so accepted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f8994-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a repayment under paragraph (1), shall not be entitled to any payment from the Government for such expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f8995-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f8996-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “executive branch” means all executive agencies (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f8997-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “employee in the executive branch” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0f8998-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appointed officer or employee in the executive branch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f8999-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expert or consultant in the executive branch, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f899a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “payment” means a payment or reimbursement, in cash or in kind.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f899b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0f899c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each agency of the executive branch shall, in the manner provided in paragraph (2), submit to the Director of the Office of Government Ethics reports of payments of more than $250 accepted under this section with respect to employees of the agency. The Director shall make such reports available for public inspection and copying.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f899d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The reports required by paragraph (1) shall, with respect to each payment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0f899e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the amount and method of payment, the name of the person making the payment, the name of the employee, the nature of the meeting or similar function, the time and place of travel, the nature of the expenses, and such other information as the Administrator of General Services may prescribe by regulation under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f899f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be submitted not later than May 31 of each year with respect to payments in the preceding period beginning on October 1 and ending on March 31; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0f89a0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1353/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be submitted not later than November 30 of each year with respect to payments in the preceding period beginning on April 1 and ending on September 30.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0f89a1-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/tIII/s302/a"},"text":"Pub. L. 101–194, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1745"},"text":"103 Stat. 1745","children":[],"tail":", § 1352; renumbered § 1353 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/b/1"},"text":"Pub. L. 101–280, § 4(b)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1990-05-04"},"text":"May 4, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/157"},"text":"104 Stat. 157","children":[],"tail":", 158.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0f89a2-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0f89a3-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd0f89a4-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/b/1"},"text":"Pub. L. 101–280, § 4(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1352"},"text":"section 1352 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/c/1"},"text":"Pub. L. 101–280, § 4(c)(1)","children":[],"tail":", substituted “in the executive branch (including an independent agency) may accept payment, or authorize an employee of such agency to accept payment on the agency’s behalf,” for “or employee in the executive branch may accept payment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/c/2/A"},"text":"Pub. L. 101–280, § 4(c)(2)(A)","children":[],"tail":", inserted “or 7342” after “section 4111”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/c/2/B"},"text":"Pub. L. 101–280, § 4(c)(2)(B)","children":[],"tail":", substituted “(1),” for “(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/c/3"},"text":"Pub. L. 101–280, § 4(c)(3)","children":[],"tail":", substituted “all executive agencies” for “any executive agency”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
