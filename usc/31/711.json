b":{},"text":"Feb. 15, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/191/s8/e/4"},"text":"Pub. L. 96–191, § 8(e)(4)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/33"},"text":"94 Stat. 33","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:52–1(related to direct).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Feb. 15, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/191/s2"},"text":"Pub. L. 96–191, § 2","children":[],"tail":"(related to direct), "},{"tag":"html:a","attrib":{"href":"/us/stat/94/27"},"text":"94 Stat. 27","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:117.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 297.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words “may . . . prescribe regulations to carry out the duties and powers of the Comptroller General” are substituted for “shall make such rules and regulations as may be necessary for carrying on the work of the General Accounting Office” in 31:52(d) for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the word “delegate” is substituted for “direct” in 31:52–1, and the words “officers and employees” are substituted for “personnel”, and 31:52(c) is omitted, for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3), the words “rules and” in 31:52(d) are omitted as surplus. The words “representatives of persons” are substituted for “attorneys” for clarity and consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (4), the words “in any case in which they may deem it necessary for the due” in 31:117 are omitted as surplus. The words “auditing and settling” are substituted for “examination” for consistency. The words “with which they shall be charged” are omitted because of the restatement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcebd519-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcebd51a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcebd51b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Expired Appropriations Available for Deposit Into Employees’ Compensation Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/6/dF/tVI/s1611"},"text":"Pub. L. 113–6, div. F, title VI, § 1611","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-03-26"},"text":"Mar. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/427"},"text":"127 Stat. 427","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/6/dF/tVI/s1611"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Available balances of expired Government Accountability Office appropriations shall be available to the Government Accountability Office to make the deposit to the credit of the Employees’ Compensation Fund required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8147/b"},"text":"section 8147(b) of title 5","children":[],"tail":"[,] United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall apply with respect to fiscal year 2013 and each fiscal year thereafter.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
