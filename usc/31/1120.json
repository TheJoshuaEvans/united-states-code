{"tag":"section","attrib":{"id":"idbd03a329-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120"},"text":null,"children":[{"tag":"num","attrib":{"value":"1120"},"text":"§ 1120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Government and agency priority goals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd03a32a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Government Priority Goals.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd03a32b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of the Office of Management and Budget shall coordinate with agencies to develop priority goals to improve the performance and management of the Federal Government. Such Federal Government priority goals shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd03a32c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outcome-oriented goals covering a limited number of crosscutting policy areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a32d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" goals for management improvements needed across the Federal Government, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd03a32e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd03a32f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human capital management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd03a330-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information technology management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd03a331-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procurement and acquisition management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd03a332-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real property management;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd03a333-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Federal Government priority goals shall be long-term in nature. Such goals shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd03a334-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be updated and revised not less frequently than during the first year of each Presidential term;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a335-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made publicly available not less frequently than concurrently with the submission of the budget of the United States Government under section 1105(a) made during the first full fiscal year following any year during which a term of the President commences under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s101"},"text":"section 101 of title 3","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a336-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include plans for the successful achievement of each goal within each single Presidential term; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a337-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explicitly cite to any specific contents of the budget described in subparagraph (B) that support the achievement of each goal. As needed, the Director of the Office of Management and Budget may make adjustments to the Federal Government priority goals to reflect significant changes in the environment in which the Federal Government is operating, with appropriate notification of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd03a338-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When developing or making adjustments to Federal Government priority goals, the Director of the Office of Management and Budget shall consult periodically with the Congress, including obtaining majority and minority views from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd03a339-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Appropriations of the Senate and the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a33a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on the Budget of the Senate and the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a33b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a33c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Oversight and Government Reform of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a33d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Finance of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a33e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Ways and Means of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a33f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other committees as determined appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd03a340-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Management and Budget shall consult with the appropriate committees of Congress at least once every 2 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd03a341-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of the Office of Management and Budget shall make information about the Federal Government priority goals available on a website described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1122"},"text":"section 1122 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd03a342-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Government performance plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115/a"},"text":"section 1115(a) of this title","children":[],"tail":" shall be consistent with the Federal Government priority goals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd03a343-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Priority Goals.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd03a344-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Every 2 years, the head of each agency listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s901/b"},"text":"section 901(b) of this title","children":[],"tail":", or as otherwise determined by the Director of the Office of Management and Budget, shall identify agency priority goals from among the performance goals of the agency. The Director of the Office of Management and Budget shall determine the total number of agency priority goals across the Government, and the number to be developed by each agency. The agency priority goals shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd03a345-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect the highest priorities of the agency, as determined by the head of the agency and informed by the Federal Government priority goals provided under subsection (a) and the consultations with Congress and other interested parties required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s306/d"},"text":"section 306(d) of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a346-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have ambitious targets that can be achieved within a 2-year period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a347-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a clearly identified agency official, known as a goal leader, who is responsible for the achievement of each agency priority goal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a348-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have interim quarterly targets for performance indicators if more frequent updates of actual performance provides data of significant value to the Government, Congress, or program partners at a reasonable level of administrative burden; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd03a349-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have clearly defined quarterly milestones.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd03a34a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an agency priority goal includes any program activity or information that is specifically authorized under criteria established by an Executive order to be kept secret in the interest of national defense or foreign policy and is properly classified pursuant to such Executive order, the head of the agency shall make such information available in the classified appendix provided under section 1115(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd03a34b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1120/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The functions and activities of this section shall be considered to be inherently governmental functions. The development of Federal Government and agency priority goals shall be performed only by Federal employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd03a34c-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/352/s5"},"text":"Pub. L. 111–352, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3873"},"text":"124 Stat. 3873","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCVI/s9601/c/2/C"},"text":"Pub. L. 116–283, div. H, title XCVI, § 9601(c)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4828"},"text":"134 Stat. 4828","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/190/s4"},"text":"Pub. L. 118–190, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2655"},"text":"138 Stat. 2655","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd03a34d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd03a34e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd03a34f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/190"},"text":"Pub. L. 118–190","children":[],"tail":" substituted “Such goals shall—” and subpars. (A) to (D) for “At a minimum, the Federal Government priority goals shall be updated or revised every 4 years and made publicly available concurrently with the submission of the budget of the United States Government made in the first full fiscal year following any year in which the term of the President commences under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s101"},"text":"section 101 of title 3","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" substituted “a website described in” for “the website described under”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd061350-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbd061351-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
