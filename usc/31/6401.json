{"tag":"section","attrib":{"id":"idbd7d4031-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401"},"text":null,"children":[{"tag":"num","attrib":{"value":"6401"},"text":"§ 6401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d4032-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “agency” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/f"},"text":"section 552(f) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4033-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Core data elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “core data elements” means data elements relating to financial management, administration, or management that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7d4034-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not program-specific in nature or program-specific outcome measures, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115/h"},"text":"section 1115(h) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d4035-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are required by agencies for all or the vast majority of recipients of Federal awards for purposes of reporting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4036-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Director” means the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4037-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive department","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Executive department” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4038-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal award","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Federal award”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7d4039-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means the transfer of anything of value for a public purpose of support or stimulation authorized by a law of the United States, including financial assistance and Government facilities, services, and property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d403a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a grant, a subgrant, a cooperative agreement, or any other transaction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d403b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include a transaction or agreement—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd7d403c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/5/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that provides for conventional public information services or procurement of property or services for the direct benefit or use of the Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd7d403d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/5/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that provides only—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd7d403e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/5/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct Government cash assistance to an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd7d403f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/5/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subsidy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd7d4040-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/5/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd7d4041-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/5/C/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan guarantee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd7d4042-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/5/C/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insurance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4043-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” means the head of the standard-setting agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4044-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standard-setting agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “standard-setting agency” means the Executive department designated under section 6402(a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4045-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6401/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means each State of the United States, the District of Columbia, each commonwealth, territory, or possession of the United States, and each federally recognized Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7d4046-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/103/s4/a"},"text":"Pub. L. 116–103, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3267"},"text":"133 Stat. 3267","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7d4047-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd7d4048-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbd7d4049-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/103/s1/a"},"text":"Pub. L. 116–103, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3266"},"text":"133 Stat. 3266","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/103/s1/a"},"text":"“This Act [enacting this chapter, amending sections 7502 and 7505 of this title, and enacting provisions set out as notes under this section and sections 6402 and 7505 of this title] may be cited as the ‘Grant Reporting Efficiency and Agreements Transparency Act of 2019’ or the ‘GREAT Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7d404a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/103/s8"},"text":"Pub. L. 116–103, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3271"},"text":"133 Stat. 3271","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/103/s8"},"text":"“Nothing in this Act [see Short Title note set out above], or the amendments made by this Act, shall be construed to require the collection of data that is not otherwise required under any Federal law, rule, or regulation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7d404b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/103/s2"},"text":"Pub. L. 116–103, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3266"},"text":"133 Stat. 3266","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/103/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purposes of this Act [see Short Title note set out above] are to—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modernize reporting by recipients of Federal grants and cooperative agreements by creating and imposing data standards for the information that those recipients are required by law to report to the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement the recommendation by the Director of the Office of Management and Budget contained in the report submitted under section 5(b)(6) of the Federal Funding Accountability and Transparency Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6101"},"text":"31 U.S.C. 6101","children":[],"tail":" note) relating to the development of a ‘comprehensive taxonomy of standard definitions for core data elements required for managing Federal financial assistance awards’;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce burden and compliance costs of recipients of Federal grants and cooperative agreements by enabling technology solutions, existing or yet to be developed, for use in both the public and private sectors to better manage the data that recipients already provide to the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen oversight and management of Federal grants and cooperative agreements by agencies by consolidating the collection and display of and access to open data that has been standardized and, where appropriate, increasing transparency to the public.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idbd7d404c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/103/s3"},"text":"Pub. L. 116–103, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-30"},"text":"Dec. 30, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3267"},"text":"133 Stat. 3267","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/103/s3"},"text":"“In this Act [see Short Title note set out above], the terms ‘agency’, ‘Director’, ‘Federal award’, and ‘Secretary’ have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6401"},"text":"section 6401 of title 31","children":[],"tail":", United States Code, as added by section 4(a) of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
