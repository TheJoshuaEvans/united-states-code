tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375"},"text":"Pub. L. 108–375","children":[],"tail":" not to be construed to authorize the use of a protest under this subchapter with regard to a decision made by an agency tender official, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/s326/e"},"text":"section 326(e) of Pub. L. 108–375","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3551"},"text":"section 3551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
