{"tag":"section","attrib":{"id":"idbd48c24c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3808"},"text":null,"children":[{"tag":"num","attrib":{"value":"3808"},"text":"§ 3808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd48c24d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3808/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A notice to the person alleged to be liable with respect to a claim or statement shall be mailed or delivered in accordance with section 3803(d)(1) not later than the later of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd48c24e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3808/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 years after the date on which the violation of section 3802 is committed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd48c24f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3808/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 years after the date on which facts material to the action are known or reasonably should have been known by the authority head, but in no event more than 10 years after the date on which the violation is committed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd48c250-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3808/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civil action to recover a penalty or assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3806"},"text":"section 3806 of this title","children":[],"tail":" shall be commenced within 3 years after the date on which the determination of liability for such penalty or assessment becomes final."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd48c251-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3808/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If at any time during the course of proceedings brought pursuant to this chapter the authority head receives or discovers any specific information regarding bribery, gratuities, conflict of interest, or other corruption or similar activity in relation to a false claim or statement, the authority head shall immediately report such information to the Attorney General, and in the case of an authority in which an Office of Inspector General is established by chapter 4 of title 5 or by any other Federal law, to the Inspector General of that authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd48c252-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVI/s6103/a"},"text":"Pub. L. 99–509, title VI, § 6103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1947"},"text":"100 Stat. 1947","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/57"},"text":"Pub. L. 117–286, § 4(b)(57)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4349"},"text":"136 Stat. 4349","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLII/s5203/h"},"text":"Pub. L. 118–159, div. E, title LII, § 5203(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2443"},"text":"138 Stat. 2443","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd48c253-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd48c254-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd48c255-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" added subsec. (a) and struck out former subsec. (a) which read as follows: “A hearing under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803/d/2"},"text":"section 3803(d)(2) of this title","children":[],"tail":" with respect to a claim or statement shall be commenced within 6 years after the date on which such claim or statement is made, presented, or submitted.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 4 of title 5” for “the Inspector General Act of 1978”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
